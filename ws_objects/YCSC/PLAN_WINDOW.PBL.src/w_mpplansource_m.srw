end type

event pb_delete::clicked;call super::clicked;dwitemstatus l_status
long   ll_row, ll_count, ll_cnt, ll_max
string ls_sosno, ls_divid
		

if tab_1.SelectedTab <> 2 then return
if dw5.rowcount()     < 1 then return

dw5.accepttext()
dw6.accepttext()
l_status  = dw5.getitemstatus(1, 0, primary!)
ls_sosno  = dw5.object.sos_no[1]

choose case is_dwidx
	case "dw4", "dw5"
		ls_divid = dw5.object.div_id[1]
		if ls_divid <> "" then 
			MessageBox("확인","결재 완료된 신청서는 삭제할 수 없습니다!",information!)
			return
		else
			ls_sosno = dw5.object.sos_no[1]
			if MessageBox("삭제","신청번호 : " + ls_sosno + "~n~n삭제 하시겠습니까?",question!,okcancel!,1) = 2 then	return			
		end if
		
		DELETE FROM itemsosdet WHERE sos_no = :ls_sosno;
		if sqlca.sqlcode <> 0 then
			rollback;
			MessageBox("삭제","itemsosdet 삭제 중 오류가 발생 하였습니다.")
			return
		end if
		dw6.reset()
		
		dw5.deleterow(1)
		if wf_update1(dw5,'Y') = false then
			return
		end if
		dw5.reset()
		dw4.retrieve()

	case "dw6"
		for ll_row = 1 to dw6.rowcount()
			if dw6.object.chk[ll_row] = "Y" then
				ll_cnt = ll_cnt + 1
			end if
		next		
		if MessageBox("삭제",string(ll_cnt) + " 행 삭제 하시겠습니까?",question!,okcancel!,2) = 2 then return
		
		ll_cnt = 0
		ll_max = dw6.rowcount()
		for ll_row = dw6.rowcount() to 1 step -1
			if dw6.object.chk[ll_row] = "Y" then
				ll_cnt = ll_cnt + 1
				dw6.deleterow( ll_row )
			end if
		next
		
		if ll_max = ll_cnt then		// 행전체 삭제됨
			ls_sosno = dw5.object.sos_no[1]
			if MessageBox("삭제","신청번호 : " + ls_sosno + "~n~n삭제 하시겠습니까?",question!,okcancel!,1) = 1 then	
				dw5.deleterow(1)
				if wf_update1(dw5,"N") = false then
					return
				else
					MessageBox("확인","신청번호 : " + ls_sosno + "~n~n삭제 완료.")
				end if
				
				dw4.retrieve()	// 신청목록 조회
			end if
		else
			MessageBox("확인", string(ll_cnt) + " 건 행삭제 하였습니다.")
		end if		
end choose		
end event

type pb_insert from w_inheritance`pb_insert within w_mpplansource_m
integer x = 3159
integer y = 56
integer taborder = 180
end type

event pb_insert::clicked;call super::clicked;dwitemstatus l_status
long   ll_row, ll_count, ll_cnt, ll_max
string ls_sosno
		

if tab_1.SelectedTab <> 2 then return
if dw5.rowcount()     < 1 then return

dw5.accepttext()
dw6.accepttext()
l_status  = dw5.getitemstatus(1, 0, primary!)
ls_sosno  = dw5.object.sos_no[1]

if (isnull(ls_sosno) or ls_sosno = "") and (dw6.rowcount() > 0) then is_dwidx = "dw6"

choose case is_dwidx
	case "dw5"
		if MessageBox("확인","신규작성 하시겠습니까?",question!,okcancel!,2) = 2 then return

		dw5.reset()
		dw6.reset()
		
		ll_row = dw5.insertrow(0)
		ll_row = dw6.insertrow(0)
		dw6.scrolltorow(ll_row)

		dw5.setcolumn("cust_no")
		dw5.setfocus()

	case "dw4", "dw6"
		ll_row = dw6.insertrow(0)
		
		dw6.object.seq_no[ll_row] = ll_row		
		dw6.scrolltorow(ll_row)
end choose

end event

type pb_retrieve from w_inheritance`pb_retrieve within w_mpplansource_m
integer x = 2962
integer y = 56
integer taborder = 170
end type

event pb_retrieve::clicked;//==GF_USEPROGRAM(프로그램 사용현황)==============================================================
GF_USEPROGRAM( gs_userid, Parent.ClassName(), "R", string(gf_today(),'yyyy/mm/dd'), Parent.Title )
//================================================================================================

string ls_area, ls_sdate, ls_edate, ls_sosno, ls_wcname, ls_flag, ls_Filter
long   ll_row

DateTime ld_time
SELECT TOP 1 GETDATE() INTO :ld_time FROM LOGIN;
st_time.text = string(ld_time,"yyyy/mm/dd hh:mm:ss")

ls_sdate = em_1.text
ls_edate = em_2.text

dw3.setfilter("")
dw3.filter()

ls_area   = dw_area.object.area[dw_area.getrow()]
ls_wcname = idwc_wc.getitemstring(idwc_wc.getrow(), "work_name")

if ls_wcname = "전체" then ls_wcname = ""
ls_wcname = trim(ls_wcname) + "%"  //작업장명

choose case tab_1.selectedtab
	case 1	// 미생산계획
		tab_1.tabpage_1.cbx_1.checked = false	// 선택
		
		dw3.reset()
		dw3.Modify("DataWindow.Trailer.1.Height=0")
		
		if dw3.retrieve( ls_area ) < 1 then
			MessageBox("확인","해당하는 조건의 데이터가 존재하지 않습니다.", Exclamation!)
		else
			if MidA(ls_wcname,2,2) = '00' then
				ls_wcname = MidA(ls_wcname,1,1) + '%'
				ls_Filter = "wc_no like '" + ls_wcname + "'"
			else
				ls_Filter = "wc_no like '" + ls_wcname + "'"
			end if
			dw3.SetFilter(ls_Filter)
			dw3.Filter()
			
			////////////////////////////////////////////////////////
			// 작업장별 수주품목이 없으면 물품별소계 기능 DISABLE
			////////////////////////////////////////////////////////
			ll_row = dw3.FilteredCount()
			ll_row = dw3.RowCount()
			if ll_row > 0 then
				cb_group.enabled = true
			else
				cb_group.enabled = false
			end if
		end if	

	case 2	// 소재신청
		if dw4.rowcount() < 1 then return
		
		ls_sosno = dw4.object.sos_no[dw4.getrow()]  // 소재신청 리스트
		if isnull(ls_sosno) or ls_sosno = "" then return
		
		ll_row = dw5.retrieve( ls_sosno )
		if ll_row < 1 then
			MessageBox("확인","해당하는 조건의 데이터가 존재하지 않습니다.", Exclamation!)
		else
			string ls_scene_code, ls_scene_name
			
			dw5.getchild("scene_code", idwc_scene)
			idwc_scene.settransobject(sqlca)

			dw5.setredraw(false)
			setnull(ls_scene_code)
			setnull(ls_scene_name)
			ls_scene_code = dw5.object.scene_code[1]
			SELECT scene_desc INTO :ls_scene_name FROM scene WHERE scene_code = :ls_scene_code;
			idwc_scene.SetItem(1, "scene_code", ls_scene_code)
			idwc_scene.SetItem(1, "scene_desc", ls_scene_name)
			dw5.setredraw(true)
			
			// 상세내역			
			dw6.retrieve( ls_sosno )
		end if

	case 3	// 제품별 공정단계
		if dw7.retrieve() < 1 then
			MessageBox("확인","해당하는 조건의 데이터가 존재하지 않습니다.", Exclamation!)
		else
			tab_1.tabpage_3.cb_17.triggerevent(clicked!)
		end if		
end choose

end event

