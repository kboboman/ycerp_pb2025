																						null wall7,
																						null ceilling7, 
																						null pilotis7,
																				 		null etc7,
                                            														null salesman7                                            
																				  from sale_scene_interior
																				  where seq = 6
																				  union all
																				  select  scene_code,
																						 null interior_name1, 
																						 null wall1, 
																						 null ceilling1, 
																						null pilotis1,
																				 		null etc1,
                                            														null salesman1,                                            
																						null interior_name2, 
																						null wall2, 
																						null ceilling2, 
																						null pilotis2,
																				 		null etc2,
                                           														 null salesman2,                                            
																						null interior_name3,  
																						null wall3,
																						null ceilling3, 
																						null pilotis3,
																				 		null etc3,
                                            														null salesman3,                                            
																						null interior_name4,  
																						null wall4,
																						null ceilling4, 
																						null pilotis4,
																				 		null etc4,
                                            														null salesman4,                                            
																						null interior_name5,  
																						null wall5,
																						null ceilling5, 
																						null pilotis5,
																				 		null etc5,
                                            														null salesman5,                                            
																						null interior_name6,  
																						null wall6,
																						null ceilling6, 
																						null pilotis6,
																				 		null etc6,
                                            														null salesman6,                                            
																						interior_name interior_name7,  
																						wall wall7,
																						ceilling ceilling7, 
																						pilotis pilotis7,
																				 		etc etc7,
                                            														salesman salesman7                                            
																				  from sale_scene_interior
																				  where seq = 7
																	 ) a
																	 group by a.scene_code

										  ) g on  a.scene_code = g.scene_code
										  left outer join SALEPRE_PROJECT h with(nolock)  on a.project_code = h.project_code
where isnull(a.project_code,'%') like :as_project_code
    and isnull(a.con_code, '') like :as_con_code
    and isnull(a.SALE_END_YN,'Y') LIKE :AS_SALE_END_YN
    and  (ISNULL(A.PERSON1, :as_person) LIKE :as_person or  ISNULL(A.PERSON2, ISNULL( A.PERSON1, :as_person) ) like :as_person)
    and a.kind_gubun = 'A'" arguments=(("as_con_code", string),("as_project_code", string),("as_fr_date", string),("as_to_date", string),("as_sale_end_yn", string),("as_person", string))  sort="scene_name A " )
