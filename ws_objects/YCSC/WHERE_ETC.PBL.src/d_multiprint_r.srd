table(column=(type=char(10) updatewhereclause=yes name=item_no dbname="inspdet.item_no" )
 column=(type=decimal(1) updatewhereclause=yes name=item_wid dbname="compute_0002" )
 retrieve="SELECT	item_no, convert(decimal (5,1) , substring(qa,5,4) + '.' + substring(qa, 10,1))
  FROM	inspdet
 WHERE 	inspdet.insp_no = :AG_insp_no 
   AND	inspdet.oi_no = :AG_row;" arguments=(("ag_insp_no", string),("ag_row", number)) )
