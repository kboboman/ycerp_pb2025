table(column=(type=long update=yes updatewhereclause=yes identity=yes name=id dbname="id" )
 column=(type=datetime update=yes updatewhereclause=yes name=diary_date dbname="diary_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=work_no dbname="work_no" )
 column=(type=char(10) updatewhereclause=yes name=work_name dbname="work_name" )
 column=(type=char(50) updatewhereclause=yes name=interview dbname="interview" )
 column=(type=char(255) update=yes updatewhereclause=yes name=contents dbname="contents" )
 column=(type=char(10) updatewhereclause=yes name=employee dbname="employee" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=long update=yes updatewhereclause=yes name=cqty dbname="cqty" )
 column=(type=char(10) update=yes updatewhereclause=yes name=user_id dbname="user_id" )
 column=(type=char(10) updatewhereclause=yes name=input_name dbname="input_name" )
 column=(type=char(1) updatewhereclause=yes name=sw_modify dbname="sw_modify" )
 retrieve="  SELECT id         = a.id
       , diary_date = a.diary_date   
       , work_no    = a.work_no   
       , work_name  = isnull(c.work_name, '일반작업')
       , interview  = a.interview
       , contents   = replace(convert(varchar(4099),a.contents), char(13) + char(10), ' | ')
       , employee   = a.employee
       , user_name  = l.user_name    
       , cqty       = a.cqty
       , user_id    = a.user_id
       , input_name = u.user_name
       , sw_modify  = 'X'  
    FROM plan_diary A
         LEFT OUTER JOIN wc       C  ON a.work_no  = c.work_no
         LEFT OUTER JOIN login    L  ON a.employee = l.user_id
         LEFT OUTER JOIN login    U  ON a.user_id  = u.user_id
   WHERE ( a.diary_date  BETWEEN :as_sdate AND :as_edate )
     AND ( :as_workno   <> '%' AND a.work_no     = :as_workno
           OR
           :as_workno    = '%' AND a.work_no  LIKE :as_workno
         )
     AND ( :as_employee <> '%' AND a.employee    = :as_employee
           OR
           :as_employee  = '%' AND a.employee LIKE :as_employee
         )
" arguments=(("as_employee", string),("as_workno", string),("as_sdate", string),("as_edate", string))  sort="diary_date D work_name A user_name A cqty D " )
