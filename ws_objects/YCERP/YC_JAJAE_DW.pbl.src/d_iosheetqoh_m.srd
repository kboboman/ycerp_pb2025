$PBExportHeader$d_iosheetqoh_m.srd
$PBExportComments$SHEET재고현황(2002/03/30,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=76 color="536870912" )
summary(height=0 color="12639424" )
footer(height=80 color="8421504" )
detail(height=68 color="536870912" )
table(column=(type=char(20) update=yes updatewhereclause=yes key=yes name=sheetmst_sheet_no dbname="sheetmst.sheet_no" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=sheetmst_loc_no dbname="sheetmst.loc_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=sheetmst_item_no dbname="sheetmst.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=sheetmst_qa dbname="sheetmst.qa" )
 column=(type=datetime update=yes updatewhereclause=yes name=sheetmst_rcpt_date dbname="sheetmst.rcpt_date" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=sheetmst_unit_qty dbname="sheetmst.unit_qty" )
 column=(type=long update=yes updatewhereclause=yes name=sheetmst_cnt dbname="sheetmst.cnt" )
 column=(type=long update=yes updatewhereclause=yes name=sheetmst_qcnt dbname="sheetmst.qcnt" )
 column=(type=char(4) update=yes updatewhereclause=yes name=sheetmst_color_no dbname="sheetmst.color_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=sheetmst_supp_no dbname="sheetmst.supp_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=sheetmst_flag dbname="sheetmst.flag" )
 column=(type=char(14) update=yes updatewhereclause=yes name=sheetmst_porder_no dbname="sheetmst.porder_no" )
 column=(type=long update=yes updatewhereclause=yes name=sheetmst_pseq_no dbname="sheetmst.pseq_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=sheetmst_open_close dbname="sheetmst.open_close" values="재고	O/계획	M/작업지시	P/외주가공	S/사용완료	C/" )
 column=(type=char(40) update=yes updatewhereclause=yes name=sheetmst_rem dbname="sheetmst.rem" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=sheetmst_rcpt_qty dbname="sheetmst.rcpt_qty" )
 column=(type=char(1) update=yes updatewhereclause=yes name=long_stock_yn dbname="sheetmst.long_stock_yn" values="	Y/	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=use_yn dbname="sheetmst.use_yn" values="	Y/	N" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(30) updatewhereclause=yes name=location_loc_name dbname="location.loc_name" )
 column=(type=char(30) updatewhereclause=yes name=supp_supp_name dbname="supp.supp_name" )
 retrieve="  SELECT sheetmst.sheet_no,   
         sheetmst.loc_no,   
         sheetmst.item_no,   
         sheetmst.qa,   
         sheetmst.rcpt_date,   
         sheetmst.unit_qty,   
         sheetmst.cnt,   
         sheetmst.qcnt,   
         sheetmst.color_no,   
         sheetmst.supp_no,   
         sheetmst.flag,   
         sheetmst.porder_no,   
         sheetmst.pseq_no,   
         sheetmst.open_close,   
         sheetmst.rem,   
         sheetmst.rcpt_qty,  
	    sheetmst.long_stock_yn,
	    sheetmst.use_yn,
         groupitem.item_name,   
         location.loc_name,   
         supp.supp_name  
    FROM sheetmst LEFT OUTER JOIN location ON sheetmst.loc_no = location.loc_no LEFT OUTER JOIN supp ON sheetmst.supp_no = supp.supp_no,   
         groupitem  
   WHERE ( sheetmst.item_no = groupitem.item_no ) and  
         ( ( sheetmst.loc_no like :as_loc ) AND  
         ( sheetmst.open_close in ( :as_oc ) ) AND  
         ( groupitem.item_name like :as_item ) )    
" update="sheetmst" updatewhere=0 updatekeyinplace=no arguments=(("as_loc", string),("as_item", string),("as_oc", stringlist))  sort="sheetmst_item_no A sheetmst_qa A " )
