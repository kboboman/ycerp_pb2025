 column=(type=char(10) update=yes updatewhereclause=yes name=order_no dbname="order_no" initial=" " )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=seq_no dbname="seq_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="item_no" initial=" " )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="qa" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=order_qty dbname="order_qty" initial="0 " )
 column=(type=char(20) update=yes updatewhereclause=yes name=rcpt_loc dbname="rcpt_loc" )
 column=(type=char(30) updatewhereclause=yes name=loc_name dbname="loc_name" )
 column=(type=char(1) update=yes updatewhereclause=yes name=pur_type dbname="pur_type" )
 column=(type=char(20) update=yes updatewhereclause=yes name=coil_no dbname="coil_no" )
 column=(type=long update=yes updatewhereclause=yes name=purdet_serial_no dbname="serial_no" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=com_qty dbname="com_qty" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=unit_qty dbname="unit_qty" )
 column=(type=datetime update=yes updatewhereclause=yes name=rlse_date dbname="rlse_date" initial=" " )
 retrieve="  SELECT product_no  = a.product_no  
       , coilorder   = b.coilorder_order  
       , order_no    = a.order_no    
       , seq_no      = a.seq_no      
       , item_no     = a.item_no     
       , qa          = a.qa          
       , order_qty   = a.order_qty   
       , rcpt_loc    = a.rcpt_loc    
       , loc_name    = c.loc_name
       , pur_type    = a.pur_type    
       , coil_no     = a.coil_no     
       , serial_no   = a.serial_no   
       , com_qty     = a.com_qty     
       , unit_qty    = a.unit_qty    
       , rlse_date   = a.rlse_date   
    FROM purdet a
         LEFT OUTER JOIN coilorderdet b ON a.coil_no = b.coil_no
         LEFT OUTER JOIN location     c ON a.rcpt_loc = c.loc_no
   WHERE a.product_no = :as_productno
   ORDER BY order_no, seq_no
" arguments=(("as_productno", string)) )
