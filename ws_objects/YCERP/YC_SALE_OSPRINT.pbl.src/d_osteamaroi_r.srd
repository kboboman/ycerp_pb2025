table(column=(type=char(5) updatewhereclause=yes name=login_team_code dbname="team_code" )
 column=(type=char(30) updatewhereclause=yes name=team_team_name dbname="team_name" )
 column=(type=char(13) updatewhereclause=yes name=login_user_name dbname="user_name" )
 column=(type=char(10) updatewhereclause=yes name=login_rank_no dbname="rank_no" )
 column=(type=char(20) updatewhereclause=yes name=login_rank dbname="rank" )
 column=(type=long updatewhereclause=yes name=cyear dbname="cyear" )
 column=(type=long updatewhereclause=yes name=cmon dbname="cmon" )
 column=(type=decimal(6) updatewhereclause=yes name=pre_yinv dbname="pre_yinv" )
 column=(type=decimal(6) updatewhereclause=yes name=cur_ayinv dbname="cur_ayinv" )
 column=(type=decimal(6) updatewhereclause=yes name=cur_amninv dbname="cur_amninv" )
 column=(type=decimal(6) updatewhereclause=yes name=cur_inv dbname="cur_inv" )
 column=(type=decimal(6) updatewhereclause=yes name=cur_aminv dbname="cur_aminv" )
 column=(type=decimal(6) updatewhereclause=yes name=cur_minv dbname="cur_minv" )
 column=(type=decimal(6) updatewhereclause=yes name=cur_amcoll dbname="cur_amcoll" )
 column=(type=decimal(6) updatewhereclause=yes name=cur_mcoll dbname="cur_mcoll" )
 retrieve="  SELECT team_code = UT.team_code,   
         team_name = UT.team_name,   
         user_name = UT.user_name,
			rank_no = UT.rank_no,
			rank = UT.rank,
			cyear = :ai_year,
			cmon = :ai_mon,
			pre_yinv = sum((opeom_a.inv_01 + opeom_a.inv_02 + opeom_a.inv_03 + opeom_a.inv_04 + opeom_a.inv_05 + opeom_a.inv_06 + 
						opeom_a.inv_07 + opeom_a.inv_08 + opeom_a.inv_09 + opeom_a.inv_10 + opeom_a.inv_11 + opeom_a.inv_12  )/1.1)/1000,
			cur_ayinv = sum((cust_aim.inv_01 + cust_aim.inv_02 + cust_aim.inv_03 + cust_aim.inv_04 + cust_aim.inv_05 + cust_aim.inv_06 + 
						cust_aim.inv_07 + cust_aim.inv_08 + cust_aim.inv_09 + cust_aim.inv_10 + cust_aim.inv_11 + cust_aim.inv_12 )/1.1)/1000, 
			cur_amninv = sum((case :ai_mon 
								when 01 then
									 cust_aim.inv_01
								when 02 then
									 cust_aim.inv_01 + cust_aim.inv_02
								when 03 then
									 cust_aim.inv_01 + cust_aim.inv_02 + cust_aim.inv_03
								when 04 then
									 cust_aim.inv_01 + cust_aim.inv_02 + cust_aim.inv_03 + cust_aim.inv_04
								when 05 then
									 cust_aim.inv_01 + cust_aim.inv_02 + cust_aim.inv_03 + cust_aim.inv_04 + cust_aim.inv_05
								when 06 then
									 cust_aim.inv_01 + cust_aim.inv_02 + cust_aim.inv_03 + cust_aim.inv_04 + cust_aim.inv_05 + cust_aim.inv_06
								when 07 then
									 cust_aim.inv_01 + cust_aim.inv_02 + cust_aim.inv_03 + cust_aim.inv_04 + cust_aim.inv_05 + cust_aim.inv_06 +
									cust_aim.inv_07
								when 08 then
									 cust_aim.inv_01 + cust_aim.inv_02 + cust_aim.inv_03 + cust_aim.inv_04 + cust_aim.inv_05 + cust_aim.inv_06 +
									cust_aim.inv_07 + cust_aim.inv_08
								when 09 then
									 cust_aim.inv_01 + cust_aim.inv_02 + cust_aim.inv_03 + cust_aim.inv_04 + cust_aim.inv_05 + cust_aim.inv_06 +
									cust_aim.inv_07 + cust_aim.inv_08 + cust_aim.inv_09
								when 10 then
									 cust_aim.inv_01 + cust_aim.inv_02 + cust_aim.inv_03 + cust_aim.inv_04 + cust_aim.inv_05 + cust_aim.inv_06 +
									cust_aim.inv_07 + cust_aim.inv_08 + cust_aim.inv_09 + cust_aim.inv_10
								when 11 then
									 cust_aim.inv_01 + cust_aim.inv_02 + cust_aim.inv_03 + cust_aim.inv_04 + cust_aim.inv_05 + cust_aim.inv_06 +
									cust_aim.inv_07 + cust_aim.inv_08 + cust_aim.inv_09 + cust_aim.inv_10 + cust_aim.inv_11
								when 12 then
									 cust_aim.inv_01 + cust_aim.inv_02 + cust_aim.inv_03 + cust_aim.inv_04 + cust_aim.inv_05 + cust_aim.inv_06 +
									cust_aim.inv_07 + cust_aim.inv_08 + cust_aim.inv_09 + cust_aim.inv_10 + cust_aim.inv_11 + cust_aim.inv_12 
							end)/1.1)/1000,
			cur_inv = sum((case :ai_mon  
								when 01 then
									 opeom_b.inv_01
								when 02 then
									 opeom_b.inv_01 + opeom_b.inv_02
								when 03 then
									 opeom_b.inv_01 + opeom_b.inv_02 + opeom_b.inv_03
								when 04 then
									 opeom_b.inv_01 + opeom_b.inv_02 + opeom_b.inv_03 + opeom_b.inv_04
								when 05 then
									 opeom_b.inv_01 + opeom_b.inv_02 + opeom_b.inv_03 + opeom_b.inv_04 + opeom_b.inv_05
								when 06 then
									 opeom_b.inv_01 + opeom_b.inv_02 + opeom_b.inv_03 + opeom_b.inv_04 + opeom_b.inv_05 + opeom_b.inv_06
								when 07 then
									 opeom_b.inv_01 + opeom_b.inv_02 + opeom_b.inv_03 + opeom_b.inv_04 + opeom_b.inv_05 + opeom_b.inv_06 +
									opeom_b.inv_07
								when 08 then
									 opeom_b.inv_01 + opeom_b.inv_02 + opeom_b.inv_03 + opeom_b.inv_04 + opeom_b.inv_05 + opeom_b.inv_06 +
									opeom_b.inv_07 + opeom_b.inv_08
								when 09 then
									 opeom_b.inv_01 + opeom_b.inv_02 + opeom_b.inv_03 + opeom_b.inv_04 + opeom_b.inv_05 + opeom_b.inv_06 +
									opeom_b.inv_07 + opeom_b.inv_08 + opeom_b.inv_09
								when 10 then
									 opeom_b.inv_01 + opeom_b.inv_02 + opeom_b.inv_03 + opeom_b.inv_04 + opeom_b.inv_05 + opeom_b.inv_06 +
									opeom_b.inv_07 + opeom_b.inv_08 + opeom_b.inv_09 + opeom_b.inv_10
								when 11 then
									 opeom_b.inv_01 + opeom_b.inv_02 + opeom_b.inv_03 + opeom_b.inv_04 + opeom_b.inv_05 + opeom_b.inv_06 +
									opeom_b.inv_07 + opeom_b.inv_08 + opeom_b.inv_09 + opeom_b.inv_10 + opeom_b.inv_11
								when 12 then
									 opeom_b.inv_01 + opeom_b.inv_02 + opeom_b.inv_03 + opeom_b.inv_04 + opeom_b.inv_05 + opeom_b.inv_06 +
									opeom_b.inv_07 + opeom_b.inv_08 + opeom_b.inv_09 + opeom_b.inv_10 + opeom_b.inv_11 + opeom_b.inv_12 
							end)/1.1)/1000,
			cur_aminv = sum((case :ai_mon  
								when 01 then
									 cust_aim.inv_01
								when 02 then
									 cust_aim.inv_02
								when 03 then
									 cust_aim.inv_03
								when 04 then
									 cust_aim.inv_04
								when 05 then
									 cust_aim.inv_05
								when 06 then
									 cust_aim.inv_06
								when 07 then
									 cust_aim.inv_07
								when 08 then
									 cust_aim.inv_08
								when 09 then
