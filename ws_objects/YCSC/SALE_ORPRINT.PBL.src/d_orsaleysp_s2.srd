 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"saledet~" )  TABLE(NAME=~"groupitem~" ) COLUMN(NAME=~"saledet.order_no~") COLUMN(NAME=~"saledet.seq_no~") COLUMN(NAME=~"saledet.item_no~") COLUMN(NAME=~"saledet.qa~") COLUMN(NAME=~"saledet.uom~") COLUMN(NAME=~"saledet.order_qty~") COLUMN(NAME=~"saledet.price~") COLUMN(NAME=~"saledet.acc_qty~") COLUMN(NAME=~"saledet.saledet_text~") COLUMN(NAME=~"saledet.rlse_date~") COLUMN(NAME=~"saledet.rlse_qty~") COLUMN(NAME=~"saledet.rem~") COLUMN(NAME=~"saledet.plan_close~") COLUMN(NAME=~"saledet.sol_qty~") COLUMN(NAME=~"saledet.issue_qty~") COLUMN(NAME=~"saledet.plan_qty~") COMPUTE(NAME=~"999999999999999 amt~") COLUMN(NAME=~"saledet.color~") COLUMN(NAME=~"saledet.price_be~") COLUMN(NAME=~"saledet.do_rem~") COLUMN(NAME=~"groupitem.item_name~")    JOIN (LEFT=~"saledet.item_no~"    OP =~"=~"RIGHT=~"groupitem.item_no~"    OUTER1 =~"saledet.item_no~" )WHERE(    EXP1 =~"saledet.order_no~"   OP =~"=~"    EXP2 =~":as_order_no~" ) ) ARG(NAME = ~"as_order_no~" TYPE = string) " arguments=(("as_order_no", string))  sort="seq_no A " )
