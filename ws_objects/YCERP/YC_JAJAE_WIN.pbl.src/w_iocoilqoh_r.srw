type dw_10 from datawindow within tabpage_7
integer x = 14
integer y = 108
integer width = 3456
integer height = 1140
integer taborder = 40
boolean bringtotop = true
string title = "로트추적기"
string dataobject = "d_lot_trace"
boolean hscrollbar = true
boolean vscrollbar = true
string icon = "Form!"
boolean hsplitscroll = true
boolean livescroll = true
borderstyle borderstyle = stylelowered!
end type

event clicked;// 로트 추적기
//////////////////////////////////////////////////////
/* 코일업무 1, 2, 3, 4, 5 (1차 스리팅:금강철강) ->  */
/*          1, 2, 3, 4, 5 (2차 스리팅:동원철강) ->  */
/*          코일이동 (협신금속) ->                  */
/*          작업일보 사용자재 처리                  */
//////////////////////////////////////////////////////
// dw4  = tab_1.tabpage_1.dw_4  스리팅계획
// dw5  = tab_1.tabpage_2.dw_5  스리팅지시
// dw6  = tab_1.tabpage_3.dw_6  발주서
// dw7  = tab_1.tabpage_4.dw_7  발주입고
// dw8  = tab_1.tabpage_5.dw_8  코일이동
// dw9  = tab_1.tabpage_6.dw_9  작업일보등록
// dw10 = tab_1.tabpage_7.dw_10 전체보기

string ls_pcoilno, ls_coilno, ls_coilorder, ls_productno, ls_orderno, ls_inspno
int    li_selectedtab

if cbx_14.checked = true then		// 탭메뉴 이동
	choose case dwo.name
		case "coil_no"			// 스리팅계획
			li_selectedtab = 1
			ls_coilno    = this.object.coil_no[row]
	
			dw4.reset()
			dw4.retrieve( ls_coilno )		
			dw8.retrieve( ls_coilno )		// 코일이동
			dw9.retrieve( ls_coilno )		// 작업일보등록
	
		case "coilorder"		// 스리팅지시
			li_selectedtab = 2
			ls_coilno    = this.object.coil_no[row]
			ls_coilorder = this.object.coilorder[row]
	
			dw5.reset()
			dw5.retrieve( ls_coilno, ls_coilorder )
			
		case "product_no"		// 발주서
			li_selectedtab = 3
			ls_orderno = this.object.order_no[row]
	
			dw6.reset()
			dw6.retrieve( ls_orderno )
			
		case "order_no"		// 발주입고
			li_selectedtab = 4
			ls_productno = this.object.product_no[row]
			ls_orderno   = this.object.order_no[row]
	
			dw7.reset()
			dw7.retrieve( ls_productno, ls_orderno )		
	end choose
	
	tab_1.selectedtab = li_selectedtab
	tab_1.postevent( selectionchanged! )

else		// 스리팅계획 조회
	if this.rowcount() < 1 then RETURN
	
	ls_coilno = this.object.lot_no[row]
	// 이전코일 조회
	SELECT top 1 pcoil_no INTO :ls_pcoilno FROM coilmst WHERE coil_no = :ls_coilno;
	tab_1.tabpage_1.sle_pcoil.text   = ls_pcoilno
	tab_1.tabpage_1.sle_lotno.text   = ls_coilno
	
   dw4.reset()		
	dw4.retrieve( ls_coilno )   // 스리팅계획

	tab_1.selectedtab = 1
	tab_1.postevent( selectionchanged! )
end if

end event

