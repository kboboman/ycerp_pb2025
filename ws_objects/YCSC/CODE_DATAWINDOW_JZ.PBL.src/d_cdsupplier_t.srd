 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"supp~" ) COLUMN(NAME=~"supp.supp_no~") COLUMN(NAME=~"supp.register_no~") COLUMN(NAME=~"supp.supp_name~") COLUMN(NAME=~"supp.captain_name~") COLUMN(NAME=~"supp.addr~") COLUMN(NAME=~"supp.contact~") COLUMN(NAME=~"supp.position~") COLUMN(NAME=~"supp.tel_no~") COLUMN(NAME=~"supp.rem~") COLUMN(NAME=~"supp.buyer~") COLUMN(NAME=~"supp.industry_type~") COLUMN(NAME=~"supp.industry_code~") COLUMN(NAME=~"supp.credit_limit~") COLUMN(NAME=~"supp.terms~") COLUMN(NAME=~"supp.fob~") COLUMN(NAME=~"supp.last_tran_date~") COLUMN(NAME=~"supp.currency_type~") COLUMN(NAME=~"supp.fax_no~") COLUMN(NAME=~"supp.subcon~")WHERE(    EXP1 =~"supp.supp_no~"   OP =~"=~"    EXP2 =~":as_str~" ) ) ARG(NAME = ~"as_str~" TYPE = string) " arguments=(("as_str", string)) )
