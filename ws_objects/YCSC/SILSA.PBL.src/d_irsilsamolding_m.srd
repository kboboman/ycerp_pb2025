table(column=(type=datetime update=yes updatewhereclause=yes key=yes name=checktime dbname="itemMOLDING.checktime" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=groupitem dbname="itemMOLDING.groupitem" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=qa dbname="itemMOLDING.qa" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=color dbname="itemMOLDING.color" )
 column=(type=long update=yes updatewhereclause=yes name=qty dbname="itemMOLDING.qty" )
 column=(type=char(50) update=yes updatewhereclause=yes name=bigo dbname="itemMOLDING.bigo" )
 retrieve="  SELECT itemMOLDING.checktime,   
         itemMOLDING.groupitem,   
         itemMOLDING.qa,   
         itemMOLDING.color,   
         itemMOLDING.qty,   
         itemMOLDING.bigo  
    FROM itemMOLDING   
   WHERE CONVERT(CHAR(25), itemMOLDING.checktime, 121) >= :as_datetime
" update="itemMOLDING" updatewhere=1 updatekeyinplace=no arguments=(("as_datetime", string))  sort="checktime D groupitem A qa A color A " )
