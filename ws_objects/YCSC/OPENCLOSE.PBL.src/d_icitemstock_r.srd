footer(height=0 color="536870912" )
detail(height=72 color="536870912"  height.autosize=yes)
table(column=(type=char(10) updatewhereclause=yes name=itemstock_loc_no dbname="itemstock.loc_no" )
 column=(type=char(10) updatewhereclause=yes name=itemstock_item_no dbname="itemstock.item_no" )
 column=(type=char(20) updatewhereclause=yes name=itemstock_qa dbname="itemstock.qa" )
 column=(type=decimal(0) updatewhereclause=yes name=itemstock_qty dbname="itemstock.qty" )
 column=(type=char(60) updatewhereclause=yes name=reason1 dbname="itemstock.reason1" )
 column=(type=char(60) updatewhereclause=yes name=reason2 dbname="itemstock.reason2" )
 column=(type=char(60) updatewhereclause=yes name=reason3 dbname="itemstock.reason3" )
 column=(type=char(10) updatewhereclause=yes name=chk1_user dbname="itemstock.chk1_user" )
 column=(type=char(10) updatewhereclause=yes name=chk2_user dbname="itemstock.chk2_user" )
 column=(type=datetime updatewhereclause=yes name=itemstock_user_date dbname="itemstock.user_date" )
 column=(type=char(1) updatewhereclause=yes name=itemstock_reason_code dbname="itemstock.reason_code" )
 column=(type=decimal(4) updatewhereclause=yes name=loc_qoh dbname="loc_qoh" )
 column=(type=char(184) updatewhereclause=yes name=reason dbname="reason" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(30) updatewhereclause=yes name=location_loc_name dbname="location.loc_name" )
 retrieve="  SELECT itemstock.loc_no,   
         itemstock.item_no,   
         itemstock.qa,   
         itemstock.qty,   
         itemstock.reason1,   
         itemstock.reason2,   
         itemstock.reason3,   
         itemstock.chk1_user,   
         itemstock.chk2_user,   
         itemstock.user_date,   
         itemstock.reason_code,   
         loc_qoh = isnull(itemloc.qoh, 0),   
         reason =  rtrim(itemstock.reason1) 
						+ case when itemstock.reason1 is null or rtrim(itemstock.reason1) = '' then '' else char(13) + char(10) end
         			+ rtrim(itemstock.reason2) 
						+ case when itemstock.reason2 is null or rtrim(itemstock.reason2) = '' then '' else char(13) + char(10) end
         			+ rtrim(itemstock.reason3),
         groupitem.item_name,   
         location.loc_name 
   FROM itemstock inner join groupitem on  itemstock.item_no = groupitem.item_no
                                 inner join location on itemstock.loc_no = location.loc_no
                                 left outer join itemloc on itemstock.loc_no = itemloc.loc_no 
                                                                  and itemstock.item_no = itemloc.item_no 
                                                                  and itemstock.qa = itemloc.qa			
   WHERE itemstock.loc_no = :as_loc
" arguments=(("as_loc", string))  sort="groupitem_item_name A itemstock_qa A " )
group(level=1 header.height=0 trailer.height=4 by=("itemstock_loc_no" , "itemstock_item_no" ) header.color="536870912" trailer.color="536870912" )
