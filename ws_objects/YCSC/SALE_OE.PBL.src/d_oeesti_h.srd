 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"basis_det~" )  TABLE(NAME=~"groupitem~" ) COLUMN(NAME=~"basis_det.asc_item~") COLUMN(NAME=~"basis_det.asc_qa~") COLUMN(NAME=~"basis_det.uom~") COLUMN(NAME=~"basis_det.asc_qty~") COLUMN(NAME=~"basis_det.std_cost~") COLUMN(NAME=~"basis_det.std_amount~") COLUMN(NAME=~"basis_det.rem~") COLUMN(NAME=~"groupitem.item_name~")    JOIN (LEFT=~"basis_det.asc_item~"    OP =~"=~"RIGHT=~"groupitem.item_no~"    OUTER1 =~"basis_det.asc_item~" )WHERE(    EXP1 =~"basis_det.item_no~"   OP =~"like~"    EXP2 =~":as_item~" ) ) ARG(NAME = ~"as_item~" TYPE = string) " arguments=(("as_item", string)) )
