 column=(type=char(100) update=yes updatewhereclause=yes name=cpu dbname="yc_com_resource.cpu" )
 column=(type=char(100) update=yes updatewhereclause=yes name=ram dbname="yc_com_resource.ram" )
 column=(type=char(100) update=yes updatewhereclause=yes name=vga dbname="yc_com_resource.vga" )
 column=(type=char(100) update=yes updatewhereclause=yes name=ssd dbname="yc_com_resource.ssd" )
 column=(type=char(100) update=yes updatewhereclause=yes name=hdd dbname="yc_com_resource.hdd" )
 column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" values="	Y/	N" )
 retrieve="select
	 a.management_no	management_no 
	,a.affiliate_type	affiliate_type     
	,a.device_nm		device_nm        
	,a.maker_nm			maker_nm         
	,a.maker_no			maker_no          
	,a.model_nm			model_nm         
	,a.os_type			os_type            
	,a.license_type	license_type      
	,a.maker_date		maker_date       
	,a.db_info			db_info             
	,a.ip_info			ip_info              
	,b.user_nm			user_nm           
	,b.dept_nm			dept_nm           
	,a.state_m			state_m    
	,a.state_d			state_d    
	,b.enter_date		enter_date            
	,b.delivery_date	delivery_date     
	,b.return_date		return_date       
	,a.disposal_date	disposal_date    
	,a.bigo				bigo                 
	,a.input_date		input_date        
	,a.input_user		input_user         
	,a.update_date		update_date      
	,a.update_user		update_user
	,a.area				area
	,a.cpu				cpu
	,a.ram				ram
	,a.vga				vga
	,a.ssd				ssd
	,a.hdd				hdd
	,'N'      			chk
from
	yc_com_resource a inner join yc_com_resource_user b on a.management_no = b.management_no
where
	a.input_date between :as_dt_fr and :as_dt_to
and
	isnull(a.affiliate_type,'%')	like :as_affiliate_type 
and
	isnull(a.device_nm,'%')			like :as_device_nm
and
	isnull(a.maker_nm,'%')     	like :as_maker_nm
and
	isnull(b.user_nm,'%') 			like :as_user_nm
and
	isnull(a.state_m,'%')         like :as_state_m
and
	isnull(a.state_d,'%')         like :as_state_d
and
	isnull(a.area,'%')				like :as_area
order by
	a.management_no desc" update="yc_com_resource" updatewhere=0 updatekeyinplace=no arguments=(("as_dt_fr", string),("as_dt_to", string),("as_affiliate_type", string),("as_device_nm", string),("as_maker_nm", string),("as_user_nm", string),("as_state_m", string),("as_state_d", string),("as_area", string)) )
