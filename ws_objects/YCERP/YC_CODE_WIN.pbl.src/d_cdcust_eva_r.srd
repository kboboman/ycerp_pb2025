 retrieve="select item_no,
           item_name,
           qa,
		paint_no,
		paint_name,
		paint_company,
		glossy_yn,
		rem
from item
where item_no = :as_item_no
and qa = :as_qa
" update="item" updatewhere=1 updatekeyinplace=no arguments=(("as_item_no", string),("as_qa", string))  sort="qa A " )
