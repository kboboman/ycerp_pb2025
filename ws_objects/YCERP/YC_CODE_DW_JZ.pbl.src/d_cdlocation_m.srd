table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=loc_no dbname="location.loc_no" )
 column=(type=char(30) update=yes updatewhereclause=yes name=loc_name dbname="location.loc_name" )
 column=(type=char(30) update=yes updatewhereclause=yes name=position dbname="location.position" )
 column=(type=char(15) update=yes updatewhereclause=yes name=tel_no dbname="location.tel_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=loc_manager dbname="location.loc_manager" )
 column=(type=char(1) update=yes updatewhereclause=yes name=loc_type dbname="location.loc_type" values="사외	Y/사내	N/작업장	W/" )
 column=(type=char(30) update=yes updatewhereclause=yes name=rem dbname="location.rem" )
 column=(type=char(10) update=yes updatewhereclause=yes name=area_no dbname="location.area_no" )
 column=(type=datetime update=yes updatewhereclause=yes name=count_date dbname="location.count_date" )
 column=(type=char(1) update=yes updatewhereclause=yes name=use_yn dbname="location.use_yn" values="사용	Y/불가	N/" )
 retrieve="  SELECT location.loc_no,   
         location.loc_name,   
         location.position,   
         location.tel_no,   
         location.loc_manager,   
         location.loc_type,   
         location.rem,   
         location.area_no,   
         location.count_date,
         location.use_yn  
    FROM location   
" update="location" updatewhere=0 updatekeyinplace=no  sort="use_yn D loc_no A " )
