$PBExportHeader$d_oicustdo_pivot.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no  crosstab.dynamic = yes grid.lines=0 grid.columnmove=no selected.mouse=no )
header[1](height=0 color="536870912" )
header[2](height=152 color="536870912" )
summary(height=0 color="553648127" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=number updatewhereclause=yes name=amt dbname="amt" )
 retrieve="  SELECT cust_name    = d.cust_name   
       , item_no      = a.item_no  
       , item_name    = (case when not g.item_name is null then g.item_name
                              else (SELECT item_name FROM groupitem WHERE item_no = a.item_no)
                         end)
       , category     = (case when :as_etcyn = 'Y' and substring(g.category,1,7) = 'TOP1016'
                                   then (case when g.type is null then '99) 미분류' else g.type end)
                              else (case when g.category  is null then '99) 미분류' else cm.item_nm end)
                         end)
       , amt          = round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty) * a.price,2,1) + a.rate_cash
    FROM dodet  A      
         LEFT OUTER JOIN do        B  ON a.do_no     = b.do_no
         LEFT OUTER JOIN customer  D  ON b.cust_no   = d.cust_no
         LEFT OUTER JOIN itemtop10 G  ON a.item_no   = g.item_no  
         LEFT OUTER JOIN (
              SELECT item_cd, item_nm FROM codemst WHERE type ='ITEMTOP10' AND use_yn = 'Y'
         ) CM ON g.category = cm.item_cd  
   WHERE ( convert(char(10),b.do_date,111) BETWEEN :as_sdate AND :as_edate )
     AND ( b.do_no     LIKE :as_area )
     AND ((:as_etcyn    = 'Y' and  g.category LIKE 'TOP1016%') OR
          (:as_etcyn   <> 'Y' and (g.category LIKE '%' OR g.category is null) )
         ) 
" arguments=(("as_area", string),("as_sdate", string),("as_edate", string),("as_etcyn", string))  sort="cust_name A " )
text(band=header[1] alignment="0" text="Sum Of Amt" border="0" color="33554432" x="9" y="4" height="60" width="1024" html.valueishtml="0"  name=t_1 visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
