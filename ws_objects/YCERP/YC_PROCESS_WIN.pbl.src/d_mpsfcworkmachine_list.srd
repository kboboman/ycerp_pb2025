$PBExportHeader$d_mpsfcworkmachine_list.srd
$PBExportComments$생산성분석(비가동시간)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=88 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=long update=yes updatewhereclause=yes identity=yes name=id dbname="id" )
 column=(type=char(2) update=yes updatewhereclause=yes name=cat1 dbname="cat1" values="비가동	AA/준가동	BB/" )
 column=(type=char(50) update=yes updatewhereclause=yes name=cat2 dbname="cat2" )
 column=(type=char(50) updatewhereclause=yes name=cat2_nm dbname="cat2_nm" )
 column=(type=datetime update=yes updatewhereclause=yes name=work_day dbname="work_day" )
 column=(type=char(10) update=yes updatewhereclause=yes name=wc_no dbname="wc_no" )
 column=(type=char(255) updatewhereclause=yes name=work_name dbname="work_name" )
 column=(type=char(10) update=yes updatewhereclause=yes name=area_no dbname="area_no" )
 column=(type=datetime update=yes updatewhereclause=yes name=work_stime dbname="work_stime" )
 column=(type=datetime update=yes updatewhereclause=yes name=work_etime dbname="work_etime" )
 column=(type=long update=yes updatewhereclause=yes name=work_man dbname="work_man" )
 column=(type=decimal(6) updatewhereclause=yes name=calc_time dbname="calc_time" )
 column=(type=char(50) update=yes updatewhereclause=yes name=bigo dbname="bigo" )
 column=(type=char(10) update=yes updatewhereclause=yes name=user_id dbname="user_id" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=datetime update=yes updatewhereclause=yes name=sys_date dbname="sys_date" )
 retrieve="  SELECT id         = a.id   
       , cat1       = a.cat1
       , cat2       = a.cat2
       , cat2_nm    = rtrim(c.item_nm)
       , work_day   = a.work_day   
       , wc_no      = a.wc_no   
       , work_name  = replace(replace(wc.work_name,'[',''),']','')
       , area_no    = a.area_no   
       , work_stime = a.work_stime   
       , work_etime = a.work_etime   
       , work_man   = a.work_man
       , calc_time  = (datepart(hh,work_etime)*60 + datepart(mi,work_etime)) * work_man / 60.0
       , bigo       = a.bigo
       , user_id    = a.user_id   
       , user_name  = l.user_name
       , sys_date   = a.sys_date   
    FROM sfcworkmachine A
         LEFT OUTER JOIN wc        ON a.wc_no   = wc.work_no
         LEFT OUTER JOIN login   L ON a.user_id = l.user_id
         LEFT OUTER JOIN (
              SELECT item_cd, item_nm, bigo, type 
                FROM codemst 
               WHERE type IN ('비가동시간', '준가동시간') AND use_yn = 'Y'
         ) C ON a.cat2 = c.item_cd AND a.wc_no = c.bigo
   WHERE ((:as_area  = '%' AND a.area_no LIKE :as_area ) OR  
          (:as_area <> '%' AND a.area_no   IN ('S0001','B0001') ) 
         )
     AND ((:as_wcno  = '%' AND a.wc_no   LIKE :as_wcno ) OR
          (:as_wcno <> '%' AND a.wc_no   LIKE :as_wcno + '%')
         )
     AND ( a.work_day  between :as_sdate AND :as_edate )
 " arguments=(("as_area", string),("as_wcno", string),("as_sdate", string),("as_edate", string))  sort="work_name A work_day A cat1 A cat2 A work_stime A work_etime A " )
