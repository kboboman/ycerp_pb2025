event clicked;long ll_row, ll_count

dw_4.accepttext()
ll_count = 0
for ll_row = 1 to dw_4.rowcount()
	if dw_4.isselected(ll_row) then
      ll_count ++
	end if
next
if ll_count < 1 then return

if messagebox("확인", "선택하신 자료를 마감 하시겠습니까?", &
			Exclamation!, OKCancel!, 2) = 2 then
	return
end if
for ll_row = 1 to dw_4.rowcount()
	if dw_4.isselected(ll_row) then
		dw_4.object.sudo_type[ll_row]	='C'
	end if
next
wf_update1(dw_4,"Y")
dw_4.retrieve()

end event

