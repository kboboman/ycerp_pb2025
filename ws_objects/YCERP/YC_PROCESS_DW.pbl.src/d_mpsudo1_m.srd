table(column=(type=char(17) update=yes updatewhereclause=yes key=yes name=order_no dbname="sudodet1.order_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=wc_no dbname="sudodet1.wc_no" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="sudodet1.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=qa dbname="sudodet1.qa" )
 column=(type=datetime update=yes updatewhereclause=yes name=due_date dbname="sudodet1.due_date" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=plan_qty dbname="sudodet1.plan_qty" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=rcpt_qty dbname="sudodet1.rcpt_qty" initial="0" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(1) update=yes updatewhereclause=yes name=sudo_type dbname="sudodet1.sudo_type" initial="A" )
 column=(type=char(2) updatewhereclause=yes name=groupitem_uom dbname="groupitem.uom" )
 column=(type=long update=yes updatewhereclause=yes name=operation dbname="sudodet1.operation" )
 column=(type=char(14) update=yes updatewhereclause=yes name=sale_no dbname="sudodet1.sale_no" )
 column=(type=long update=yes updatewhereclause=yes name=seq_no dbname="sudodet1.seq_no" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(50) update=yes updatewhereclause=yes name=rem dbname="sudodet1.rem" )
 column=(type=char(4) update=yes updatewhereclause=yes name=color dbname="sudodet1.color" )
 column=(type=char(10) update=yes updatewhereclause=yes name=area_no dbname="sudodet1.area_no" )
 retrieve="  SELECT sudodet1.order_no,   
         sudodet1.wc_no,   
         sudodet1.item_no,   
         sudodet1.qa,   
         sudodet1.due_date,   
         sudodet1.plan_qty,   
         sudodet1.rcpt_qty,   
         groupitem.item_name,   
         sudodet1.sudo_type,   
         groupitem.uom,   
         sudodet1.operation,   
         sudodet1.sale_no,   
         sudodet1.seq_no,   
         customer.cust_name,   
         sudodet1.rem,   
         sudodet1.color,   
         sudodet1.area_no  
    FROM sudodet1 LEFT OUTER JOIN groupitem ON sudodet1.item_no = groupitem.item_no, routtempnew LEFT OUTER JOIN customer ON routtempnew.cust_no = customer.cust_no  
   WHERE ( sudodet1.operation = routtempnew.operation ) and  
         ( sudodet1.sale_no = routtempnew.sale_no ) and  
         ( sudodet1.seq_no = routtempnew.seq_no ) and  
         ( sudodet1.area_no = routtempnew.area_no ) and  
         ( ( sudodet1.sudo_type in ('A','B') ) AND  
         ( sudodet1.sale_no like :as_sale ) AND  
         ( sudodet1.area_no = :as_area ) )    
" update="sudodet1" updatewhere=1 updatekeyinplace=no arguments=(("as_sale", string),("as_area", string))  sort="order_no A sale_no A seq_no A item_no A qa A " )
