event clicked;
if wf_dw3chk() = false then return
long ll_row
date ld_date
string ls_order,ls_subcon, ls_supp

ll_row = dw3.insertrow(0)
ls_order = trim(dw_1.object.order_no[1])
ls_subcon = trim(dw_1.object.subcon[1])

dw3.scrolltorow(ll_row)
dw3.object.seq_no[ll_row] = ll_row
dw3.object.order_no[ll_row] = ls_order
dw3.object.rlse_date[ll_row] = wf_today()
dw3.object.purdet_serial_no[ll_row] = 0
dw3.object.pur_type[ll_row]   =  ls_subcon
if ll_row > 1 then
	dw3.object.item_no[ll_row] = dw3.object.item_no[ll_row - 1]
	dw3.object.qa[ll_row]   = dw3.object.qa[ll_row - 1]
	dw3.object.item_item_name[ll_row] = dw3.object.item_item_name[ll_row - 1]
	dw3.object.due_date[ll_row] = dw3.object.due_date[ll_row - 1]
//	dw3.object.rcpt_loc[ll_row] = dw3.object.rcpt_loc[ll_row - 1]
	dw3.object.uom[ll_row]  = dw3.object.uom[ll_row - 1]
	dw3.object.price[ll_row] = dw3.object.price[ll_row - 1]
	dw3.object.com_uom[ll_row] = dw3.object.com_uom[ll_row - 1]
ELSE
	ld_date = DATE(dw_1.object.order_date[1])
	dw3.object.due_date[ll_row] = RelativeDate(ld_date ,dw_1.object.termS[1])
end if
dw_1.object.subcon.protect = true
dw3.setcolumn('order_qty')
dw3.setfocus()
end event

