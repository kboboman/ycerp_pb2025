compute(band=detail alignment="2" expression="string( sfc_yy, '####') +'/' + string(sfc_mm ,'00')"border="0" color="0" x="9" y="4" height="60" width="384" format="[general]"  name=yymm  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="553648127" )
compute(band=detail alignment="1" expression="if(left(  sfcday_item_no ,1) = 'P' and mid( sfcday_item_no , 3,1) = 'Y' and (mid( sfcday_item_no , 7,1) = 'A' or mid( sfcday_item_no , 7,1) = 'B' or mid( sfcday_item_no , 7,1) = 'C' or mid( sfcday_item_no , 7,1) = 'D'),   sum_qty , if(  sfcday_uom = 'M2' or sfcday_uom = 'SS',truncate( long(mid(   sfcday_qa ,5,4)) * long(mid(  sfcday_qa ,10,4)) *     sum_qty / 1000000 + 0.00001, 2), if( sfcday_uom = 'M',if ( sum_qty < 0 , truncate(long(mid( sfcday_qa , 15,5)) *  sum_qty / 1000 - 0.00001,2), truncate(long(mid( sfcday_qa , 15,5)) * sum_qty / 1000 + 0.00001,2)) ,    sum_qty )))"border="0" color="0" x="3090" y="4" height="60" width="293" format="#,##0"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="16777215" )
