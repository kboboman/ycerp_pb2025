 column=(type=char(60) updatewhereclause=yes name=출고비고 dbname="출고비고" )
 retrieve="
  SELECT AA.ORDER_NO        AS '수주번호'
       , AA.SEQ_NO          AS '순번'
       , AA.ITEM_NO         AS '품목'
       , AA.ITEM_NAME       AS '품명'
       , AA.QA              AS '규격'
       , AA.UOM             AS '단위'
       , AA.ORDER_QTY       AS '주문수량'
       , AA.ACC_QTY         AS '환산수량'
       , AA.PRICE           AS '주문단가'
       , AA.STOCK_QTY       AS '장기재고출고'
       , AA.RLSE_DATE       AS '출고일자'
       , AA.RLSE_QTY        AS '출고수량'
       , AA.JAN             AS '잔량'
       , (CASE AA.SHIP_CASE
               WHEN 'J' THEN '정기화물'
               WHEN 'T' THEN '택배'
               WHEN 'A' THEN '오토바이'
               WHEN 'S' THEN '선박'
               WHEN 'P' THEN '항공'
               WHEN 'E' THEN '기타'
               ELSE          ''
           END)             AS '운송수단'
       , (SELECT NAME FROM SHIPFLAG WHERE FLAG = AA.SHIP_FLAG) AS '운송방법'
       , CC.QOH             AS '현재고'
       , AA.PLAN_CLOSE      AS '생산완료'
       , AA.SALEDET_TEXT    AS '상태'
       , AA.REM             AS '비고'
       , AA.SOL_QTY         AS '가용량'
       , AA.ISSUE_QTY       AS '선정수량'
       , AA.PLAN_QTY        AS '생산계획수량'
       , AA.AMT             AS '수주금액'
       , (SELECT COLOR_NAME FROM COLOR WHERE COLOR_CODE = AA.COLOR)        AS '색상'
       , (SELECT USER_NAME  FROM LOGIN WHERE USER_ID    = AA.SALESMAN)     AS '영업담당'
       , (SELECT USER_NAME  FROM LOGIN WHERE USER_ID    = AA.LOGIN_ID)     AS '입력자'
       , AA.CUST_NAME       AS '거래처'
       , AA.SCENE_DESC      AS '현장명'
       , AA.REM             AS '수주비고'
       
       , (CASE BB.ISSUE_FLAG
               WHEN 'A' THEN '전량'
               WHEN 'P' THEN '부분'
               WHEN 'R' THEN '잔여분'
               ELSE          ''
          END)              AS '수량'
       , (CASE BB.ISSUE_SCHEDULE
               WHEN 'A' THEN '직출'
               WHEN 'B' THEN '통화대기'
               WHEN 'C' THEN '통화후'
               WHEN 'D' THEN '방문'
               ELSE           ''
          END)              AS '출고예정'
       , (SELECT USER_NAME FROM LOGIN WHERE USER_ID = BB.SALESMAN)        AS '출고의뢰'
       , BB.REQ_SEQ         AS '순차'  
       , (SELECT USER_NAME FROM LOGIN WHERE USER_ID = BB.ACCEPT_USER)     AS '출고확정'
       , (CASE BB.CONFIRM_FLAG
               WHEN 'Y' THEN '확정'
               WHEN 'N' THEN '미확정'
               ELSE          ''
          END)              AS '확정유무'  
       , BB.OREM            AS '출고비고'

  FROM (
       SELECT A.ORDER_NO        AS ORDER_NO  
            , A.SEQ_NO          AS SEQ_NO    
            , A.ITEM_NO         AS ITEM_NO   
            , D.ITEM_NAME       AS ITEM_NAME 
            , A.QA              AS QA        
            , A.ORDER_QTY       AS ORDER_QTY 
            , A.ACC_QTY         AS ACC_QTY   
            , A.UOM             AS UOM       
            , A.PRICE           AS PRICE     
            , A.STOCK_QTY       AS STOCK_QTY 
            , A.RLSE_DATE       AS RLSE_DATE 
            , A.RLSE_QTY        AS RLSE_QTY  
            , (A.ORDER_QTY - A.STOCK_QTY - A.RLSE_QTY) AS JAN
            , A.PLAN_CLOSE      AS PLAN_CLOSE
            , CASE A.SALEDET_TEXT 
                   WHEN 'X' THEN '가능' 
                   WHEN 'N' THEN '불가' 
                   ELSE CASE WHEN A.SOL_QTY > 0 THEN '부분' ELSE '생산' END
              END               AS SALEDET_TEXT
            , ISNULL(A.REM,'')  AS REM      
            , A.SOL_QTY         AS SOL_QTY  
            , A.ISSUE_QTY       AS ISSUE_QTY
            , A.PLAN_QTY        AS PLAN_QTY 
            , (ACC_QTY * A.PRICE)  AS 'AMT'
            , A.COLOR           AS COLOR     
            , C.SALESMAN        AS SALESMAN  
            , B.LOGIN_ID        AS LOGIN_ID  
            , B.SHIP_FLAG       AS SHIP_FLAG
            , B.SHIP_CASE       AS SHIP_CASE
            , C.CUST_NAME       AS CUST_NAME 
            , DBO.UF_GETSCENENAME(A.ORDER_NO) AS SCENE_DESC
         FROM SALEDET    A, 
              SALE       B, 
              CUSTOMER   C, 
              GROUPITEM  D
        WHERE ( A.ITEM_NO      = D.ITEM_NO ) 
          AND ( A.ORDER_NO     = B.ORDER_NO ) 
          AND ( B.CUST_NO      = C.CUST_NO ) 
       ) AA

        LEFT OUTER JOIN 
       (
        SELECT A.REQ_DATE
             , A.SALESMAN
             , A.REQ_SEQ
             , B.SALE_NO
             , B.ISSUE_FLAG
             , B.ISSUE_SCHEDULE
             , A.ACCEPT_USER
             , A.CONFIRM_FLAG
             , A.REQ_TEXT
             , ISNULL(A.REM,'')  AS REM
             , B.REM             AS OREM
          FROM ISSUEREQ   A
               LEFT OUTER JOIN ISSUEREQDET   B
                 ON A.REQ_DATE  = B.REQ_DATE
                AND A.SALESMAN  = B.SALESMAN
                AND A.REQ_SEQ   = B.REQ_SEQ
         WHERE A.REQ_DATE       = :ad_date
       ) BB
           ON AA.ORDER_NO  =  BB.SALE_NO
           
        LEFT OUTER JOIN ITEMLOC  CC
           ON AA.ITEM_NO   =  CC.ITEM_NO
          AND AA.QA        =  CC.QA
          AND CC.LOC_NO    =  :as_location

  WHERE BB.REQ_DATE        = :ad_date
  ORDER BY BB.SALESMAN, BB.REQ_SEQ, AA.ORDER_NO, AA.SEQ_NO
" arguments=(("ad_date", date),("as_location", string)) )
