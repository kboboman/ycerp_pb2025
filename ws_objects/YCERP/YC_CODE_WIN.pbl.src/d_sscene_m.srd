$PBExportHeader$d_sscene_m.srd
$PBExportComments$선행영업 현장목록
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=88 color="536870912" )
summary(height=0 color="536870912" )
footer(height=88 color="8421504" )
detail(height=88 color="536870912"  height.autosize=yes)
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=scene_code dbname="SSceneHIS.scene_code" )
 column=(type=datetime update=yes updatewhereclause=yes key=yes name=make_date dbname="SSceneHIS.make_date" )
 column=(type=char(4099) update=yes updatewhereclause=no name=contents dbname="SSceneHIS.contents" )
 column=(type=char(10) update=yes updatewhereclause=yes name=make_user dbname="SSceneHIS.make_user" )
 column=(type=char(10) updatewhereclause=yes name=username dbname="UserName" )
 column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" )
 retrieve="  SELECT SSceneHIS.scene_code   
       , SSceneHIS.make_date   
       , SSceneHIS.contents
       , SSceneHIS.make_user
       , UserName = login.user_name
       , chk      = 'N'  
    FROM SSceneHIS
         LEFT OUTER JOIN login ON SSceneHIS.make_user = login.user_id
   WHERE (SSceneHIS.scene_code  = :as_scene)
     AND (SSceneHIS.make_date  >= :ad_makedate)
" update="SSceneHIS" updatewhere=0 updatekeyinplace=no arguments=(("as_scene", string),("ad_makedate", date))  sort="scene_code A make_date D " )
