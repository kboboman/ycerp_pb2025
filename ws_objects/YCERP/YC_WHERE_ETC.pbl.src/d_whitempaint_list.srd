$PBExportHeader$d_whitempaint_list.srd
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=customer_cust_no dbname="customer.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=char(11) update=yes updatewhereclause=yes name=scene_code dbname="item_paint.scene_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_name dbname="SCENE.scene_name" )
 column=(type=char(1) updatewhereclause=yes name=item_glossy_yn dbname="item.glossy_yn" values="유광	1/무광	2/반광	3/" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="item_paint.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="item_paint.qa" )
 column=(type=char(50) updatewhereclause=yes name=item_paint_company dbname="item.paint_company" )
 column=(type=char(50) updatewhereclause=yes name=item_paint_no dbname="item.paint_no" )
 column=(type=char(50) updatewhereclause=yes name=item_paint_name dbname="item.paint_name" )
 column=(type=char(40) update=yes updatewhereclause=yes name=item_gubun dbname="item_paint.item_gubun" )
 column=(type=char(50) update=yes updatewhereclause=yes name=order_paint_name dbname="item_paint.order_paint_name" )
 column=(type=char(50) update=yes updatewhereclause=yes name=order_paint_company dbname="item_paint.order_paint_company" )
 column=(type=char(50) updatewhereclause=yes name=item_paint_alter_paint_name dbname="item_paint.alter_paint_name" )
 column=(type=char(50) updatewhereclause=yes name=item_paint_alter_paint_company dbname="item_paint.alter_paint_company" )
 column=(type=char(50) update=yes updatewhereclause=yes name=rem dbname="item_paint.rem" )
 retrieve="select  	   customer.cust_no, 
		        customer.cust_name,
		        item_paint.scene_code,
	             scene.scene_desc scene_name,
                  item.glossy_yn,            
		       item_paint.item_no,
     		       item_paint.qa,
                  item.paint_company,
                  item.paint_no,
                  item.paint_name,
		        item_paint.item_gubun,
		        item_paint.order_paint_name,
		        item_paint.order_paint_company,
		        item_paint.paint_name alter_paint_name,
		        item_paint.paint_company alter_paint_company,            
		        item_paint.rem
from item  left outer join item_paint on item.item_no = item_paint.item_no and item.qa = item_paint.qa
                  left outer join scene on item_paint.scene_code = scene.scene_code
                  left outer join customer on scene.cust_no = customer.cust_no
                  inner join groupitem on item.item_no = groupitem.item_no
where groupitem.p4 = '0'
    and item.use_flag = 'Y'   
    and (  item.paint_company is not null or item.paint_no is not null or  item.paint_name is not null )
    and  rtrim(ltrim(item_paint.scene_code)) like :as_scene_code
" arguments=(("as_scene_code", string))  sort="item_paint_company A item_paint_no A item_paint_name A qa A item_glossy_yn A cust_name A scene_scene_name A order_paint_company A order_paint_name A item_paint_alter_paint_name A item_paint_alter_paint_company A " )
