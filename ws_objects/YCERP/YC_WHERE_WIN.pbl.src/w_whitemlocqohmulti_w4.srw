type dw_8 from datawindow within tabpage_3
event mousemove pbm_dwnmousemove
integer x = 9
integer y = 156
integer width = 3410
integer height = 1024
integer taborder = 220
string title = "none"
string dataobject = "d_whdomulti_w"
boolean hscrollbar = true
boolean vscrollbar = true
boolean hsplitscroll = true
boolean livescroll = true
borderstyle borderstyle = stylelowered!
end type

event mousemove;// mousemove() [pbm_dwnmousemove]
if row < 1 then return
this.scrolltorow(row)
end event

event clicked;//
string ls_item, ls_qa, ls_use

if row < 1 then return

ls_item = this.object.item_no[row]
ls_qa   = this.object.qa[row]

setnull(ls_use)
SELECT use_flag INTO :ls_use FROM item WHERE item_no = :ls_item AND qa = :ls_qa;
if ls_use = 'C' then
	this.SelectRow( row, false )
	cbx_2.checked = false	// 전체선택
	MessageBox("확인", "선택하신품목은 사용불가인 품목입니다 ~r~n" + &
							 "물품RELOAD 를 하신후에 다시 작업하여 주시기바랍니다")
	RETURN
else
	this.SelectRow(row,  NOT this.IsSelected(row))
	this.scrolltorow(row)
	
	cb_6.postevent( clicked! )	// 추가
end if


end event

