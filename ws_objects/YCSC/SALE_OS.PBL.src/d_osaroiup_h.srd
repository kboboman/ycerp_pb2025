$PBExportComments$판매매출수정 및 취소 DODET UPDATE용 DATAWINDOW(1998/04/16, 정재수)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=68 color="536870912" )
table(column=(type=long updatewhereclause=yes name=seq_no dbname="aroi.seq_no" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=ship_qty dbname="dodet.ship_qty" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=aroi_qty dbname="dodet.aroi_qty" )
 column=(type=char(14) update=yes updatewhereclause=yes key=yes name=do_no dbname="dodet.do_no" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=oi_no dbname="dodet.oi_no" )
 retrieve="  SELECT aroi.seq_no,   
         dodet.ship_qty,   
         dodet.aroi_qty,   
         dodet.do_no,   
         dodet.oi_no  
    FROM aroi,   
         dodet  
   WHERE ( aroi.oi_no = dodet.oi_no ) and  
         ( aroi.do_no = dodet.do_no ) and  
         ( ( aroi.aroiinv_no = :as_aroiinv_no ) )    
" update="dodet" updatewhere=1 updatekeyinplace=yes arguments=(("as_aroiinv_no", string))  sort="seq_no A " )
