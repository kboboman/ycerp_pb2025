                   , cmon     = :ai_month    
from customer d with(nolock) left outer join cust_aim a with(nolock) on d.cust_no = a.cust_code and CONVERT(CHAR(4), a.tar_year, 112) = substring(:as_sdate,1,4)
                                                  left outer join (                               
															SELECT b.cust_no, sum(b.do_total) / 1.1/1000 do_total
																FROM do B with(nolock)
															WHERE convert(char(8),(case when 'ISSUE' = :as_flag then ( case when b.do_date > b.issue_date then b.issue_date else b.do_date end  ) else b.do_date end),112) between substring(:as_sdate,1,4)+substring(:as_sdate,6,2)+substring(:as_sdate,9,2) and  substring(:as_edate,1,4)+substring(:as_edate,6,2)+substring(:as_edate,9,2)
																	 group by b.cust_no
                                                                        ) b on d.cust_no = b.cust_no
                                                 left outer join (         
                                                                               SELECT b.cust_no
                                                                      				    , TOP01 = sum( case when g.category = 'TOP1001' then (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) else 0 end )/1000
                                                                                            , TOP02 = sum( case when g.category = 'TOP1002' then (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) else 0 end )/1000
                                                                                            , TOP03 = sum( case when g.category = 'TOP1003' then (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) else 0 end )/1000
                                                                                            , TOP04 = sum( case when g.category = 'TOP1004' then (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) else 0 end )/1000
                                                                                            , TOP05 = sum( case when g.category = 'TOP1019' then (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) else 0 end )/1000
                                                                                            , TOP06 = sum( case when g.category = 'TOP1005' then (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) else 0 end )/1000            
                                                                                            , TOP07 = sum( case when g.category = 'TOP1006' then (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) else 0 end )/1000
                                                                                            , TOP08 = sum( case when g.category = 'TOP1007' then (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) else 0 end )/1000
                                                                                            , TOP09 = sum( case when g.category = 'TOP1008' then (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) else 0 end )/1000
                                                                                            , TOP10 = sum( case when g.category = 'TOP1009' then (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) else 0 end )/1000
                                                                                            , TOP11 = sum( case when g.category = 'TOP1010' then (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) else 0 end )/1000
                                                                                            , TOP12 = sum( case when g.category = 'TOP1011' then (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) else 0 end )/1000
                                                                                            , TOP13 = sum( case when g.category = 'TOP1012' then (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) else 0 end )/1000
                                                                                            , TOP17 = sum( case when g.category = 'TOP1017' then (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) else 0 end )/1000
                                                                                            , TOP18 = sum( case when g.category = 'TOP1018' then (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) else 0 end )/1000
                                                                                            , TOPSUM = sum( (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) )/1000
                                                                      									  FROM dodet A with(nolock) inner join do B with(nolock) ON a.do_no = b.do_no
                                                                      																		                							 inner  join itemtop10 g with(nolock) on a.item_no   = g.item_no  and g.category in (select item_cd  from codemst where type = 'ITEMTOP10' and prt_yn = 'Y')
                                                                      										WHERE convert(char(8),(case when 'ISSUE' = :as_flag then ( case when b.do_date > b.issue_date then b.issue_date else b.do_date end  ) else b.do_date end),112) between substring(:as_sdate,1,4)+substring(:as_sdate,6,2)+substring(:as_sdate,9,2) and  substring(:as_edate,1,4)+substring(:as_edate,6,2)+substring(:as_edate,9,2)
                                                                                          group by b.cust_no
                                                                       ) c on d.cust_no = c.cust_no
LEFT OUTER JOIN codemst   M  with(nolock) ON d.cust_no  = m.item_cd  AND m.type = '내부업체' AND m.use_yn ='Y'                          
left outer join (
                                  SELECT DISTINCT  seq              = a.seq          /* 순서       */
                                                                 , area              = a.area         /* 권역       */
                                                                 , sector           = a.sector       /* 본부       */
                                                                 , team             = a.team         /* 팀         */
                                                                 , user_id         = a.user_id      /* 담당자     */
                                                                 , user_name   = a.user_name    /* 담당자명   */
                                                                 , rank              = a.rank         /* 직책       */
                                    FROM (
                                                     SELECT seq         = a.seq          /* 순서       */
                                                          , area        = a.area         /* 권역       */
                                                          , sector      = a.sector       /* 본부       */
                                                          , team        = a.team         /* 팀         */
                                                          , user_id     = a.user_id      /* 담당자     */
                                                          , user_name   = a.user_name    /* 담당자명   */
                                                          , rank        = a.rank         /* 직책       */                                                         
                                                       FROM UF_MyMembers( '%' ) M 
                                                            LEFT OUTER JOIN opeom_org A with(nolock) ON m.user_id = a.user_id                                                         
                                                     UNION ALL
                                                     /* 내부업체(insite) */
                                                     SELECT seq         = a.seq          /* 순서       */
                                                          , area        = a.area         /* 권역       */
                                                          , sector      = a.sector       /* 본부       */
                                                          , team        = a.team         /* 팀         */
                                                          , user_id     = a.user_id      /* 담당자     */
                                                          , user_name   = a.user_name    /* 담당자명   */
                                                          , rank        = a.rank         /* 직책       */
                                                       FROM opeom_org A  with(nolock)
                                                      WHERE (a.user_id     = 'insite')
                                                ) A
                      ) O  ON o.user_id = (case when m.item_cd IS NOT NULL then 'insite' else d.imwon_user_id end)
 WHERE d.cust_flag   = 'N'
      AND  d.cust_type <> 'E'
      AND o.seq  IS NOT NULL
group by o.seq
              , o.area
              , o.sector
              , o.team
              , o.user_id 
              , o.user_name
              , o.rank" arguments=(("ai_year", number),("ai_month", number),("as_sdate", string),("as_edate", string),("as_flag", string))  sort="seq A user_id A " )
