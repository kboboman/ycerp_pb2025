$PBExportHeader$d_cdsuppetc.srd
$PBExportComments$자재구매처관리 특기사항(2007-04-30,정갑용)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=supp_no dbname="suppetc.supp_no" )
 column=(type=datetime update=yes updatewhereclause=yes key=yes name=i_date dbname="suppetc.i_date" )
 column=(type=char(255) update=yes updatewhereclause=yes name=memo dbname="suppetc.memo" )
 retrieve="  SELECT supp_no,   
         i_date,   
         memo  
    FROM suppetc   
   where supp_no = :as_supp_no" update="suppetc" updatewhere=1 updatekeyinplace=yes arguments=(("as_supp_no", string)) )
text(band=header alignment="0" text="                 특기사항 메모" border="6" color="33554432" x="9" y="8" height="60" width="3570" html.valueishtml="0"  name=memo_t visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="15780518" )
text(band=header alignment="2" text="입력일자" border="6" color="33554432" x="3589" y="8" height="60" width="315" html.valueishtml="0"  name=i_date_t visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="15780518" )
column(band=detail id=2 alignment="2" tabsequence=20 border="0" color="33554432" x="3589" y="8" height="64" width="315" format="yyyy/mm/dd" html.valueishtml="0"  name=i_date visible="1" edit.limit=0 edit.case=any edit.focusrectangle=no edit.autoselect=yes edit.autohscroll=yes edit.imemode=2  font.face="굴림체" font.height="-8" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="0" background.color="536870912~tif (isrownew(), if(getrow() = currentrow(), RGB(254,252,175), 1087434968), if(getrow() = currentrow(), RGB(254,252,175), 1087434968))" )
column(band=detail id=3 alignment="0" tabsequence=10 border="0" color="33554432" x="9" y="8" height="64" width="3570" format="[general]" html.valueishtml="0"  name=memo visible="1" edit.limit=255 edit.case=any edit.autoselect=yes edit.autohscroll=yes edit.imemode=2  font.face="굴림체" font.height="-8" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="0" background.color="536870912~tif (isrownew(), if(getrow() = currentrow(), RGB(254,252,175), 1087434968), if(getrow() = currentrow(), RGB(254,252,175), 1087434968))" )
