$PBExportHeader$d_cdscenecust_list.srd
$PBExportComments$현장별 표준단가관리 거래처선택(1998/05/08, 정재수)
release 8;
datawindow(units=0 timer_interval=0 color=67108864 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(11) updatewhereclause=yes name=scene_code dbname="scene_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=long updatewhereclause=yes name=cnt dbname="cnt" )
 retrieve="SELECT a.cust_no, b.cust_name, a.scene_code, a.scene_desc, cnt = isnull(c.cnt, 0)
  FROM scene a
       LEFT OUTER JOIN customer b   ON a.cust_no    = b.cust_no
       LEFT OUTER JOIN (
            SELECT cust_no, scene_code, cnt = count(scene_code) FROM custscene  GROUP BY cust_no, scene_code
       ) c  ON a.cust_no    = c.cust_no AND a.scene_code = c.scene_code
 WHERE a.cust_no = :as_custno

" arguments=(("as_custno", string))  sort="scene_code D " )
text(band=header alignment="2" text="품목" border="6" color="33554432" x="1280" y="8" height="60" width="160" html.valueishtml="0"  name=cnt_t visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="2" background.color="15780518" )
