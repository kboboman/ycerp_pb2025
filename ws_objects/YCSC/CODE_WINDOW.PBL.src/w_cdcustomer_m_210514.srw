event mousemove pbm_mousemove
integer x = 2857
integer y = 52
integer width = 338
integer height = 88
integer taborder = 40
boolean bringtotop = true
integer textsize = -9
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "엑셀출력"
end type

event clicked;string ls_Docname, ls_Named, ls_ExpandName
integer ls_Value, li_Pos, li_value

tab_1.tabpage_3.dw_23.retrieve(tab_1.tabpage_3.st_5.text, integer(tab_1.tabpage_3.em_1.text))
if tab_1.tabpage_3.dw_23.rowcount() > 0 then
	ls_value = GetFileSaveName("Select File",  & 
		ls_Docname, ls_Named, "XLS",  &
		"엑셀 (*.XLS), *.XLS," + &
		"CSV(쉽표로 분리), *.CSV,")
	li_Pos = PosA(ls_Named, ".")
	ls_ExpandName = MidA(ls_Named, li_Pos + 1, LenA(ls_Named)- li_Pos)
	if ls_Value = 1 then
			if ls_ExpandName = "xls" OR ls_ExpandName = "XLS" then
					tab_1.tabpage_3.dw_23.SaveAsascii(ls_DocName)
			elseif ls_ExpandName = "csv" OR ls_ExpandName = "CSV" then
						tab_1.tabpage_3.dw_23.SaveAs(ls_DocName, CSV!, TRUE)
			end if
	end if
end if	

end event

