detail(height=148 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes key=yes name=order_no dbname="saledet.order_no" )
 column=(type=long updatewhereclause=yes key=yes name=seq_no dbname="saledet.seq_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="saledet.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="saledet.qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="saledet.uom" )
 column=(type=decimal(2) updatewhereclause=yes name=order_qty dbname="saledet.order_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=price dbname="saledet.price" )
 column=(type=decimal(2) updatewhereclause=yes name=acc_qty dbname="saledet.acc_qty" )
 column=(type=char(1) update=yes updatewhereclause=yes name=saledet_text dbname="saledet.saledet_text" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=sol_qty dbname="saledet.sol_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=issue_qty dbname="saledet.issue_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=rlse_qty dbname="saledet.rlse_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=planqty dbname="saledet.plan_qty" )
 column=(type=datetime updatewhereclause=yes name=sale_due_date dbname="sale.due_date" initial=" " )
 column=(type=char(4) updatewhereclause=yes name=sale_cust_no dbname="sale.cust_no" initial=" " )
 column=(type=char(11) updatewhereclause=yes name=sale_scene_code dbname="sale.scene_code" initial=" " )
 column=(type=char(1) updatewhereclause=yes name=groupitem_source dbname="groupitem.source" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"saledet~" )  TABLE(NAME=~"sale~" )  TABLE(NAME=~"groupitem~" ) COLUMN(NAME=~"saledet.order_no~") COLUMN(NAME=~"saledet.seq_no~") COLUMN(NAME=~"saledet.item_no~") COLUMN(NAME=~"saledet.qa~") COLUMN(NAME=~"saledet.uom~") COLUMN(NAME=~"saledet.order_qty~") COLUMN(NAME=~"saledet.price~") COLUMN(NAME=~"saledet.acc_qty~") COLUMN(NAME=~"saledet.saledet_text~") COLUMN(NAME=~"saledet.sol_qty~") COLUMN(NAME=~"saledet.issue_qty~") COLUMN(NAME=~"saledet.rlse_qty~") COLUMN(NAME=~"saledet.plan_qty~") COLUMN(NAME=~"sale.due_date~") COLUMN(NAME=~"sale.cust_no~") COLUMN(NAME=~"sale.scene_code~") COLUMN(NAME=~"groupitem.source~") COLUMN(NAME=~"groupitem.item_name~")    JOIN (LEFT=~"saledet.order_no~"    OP =~"=~"RIGHT=~"sale.order_no~" )    JOIN (LEFT=~"saledet.item_no~"    OP =~"=~"RIGHT=~"groupitem.item_no~" )WHERE(    EXP1 =~"sale.order_no~"   OP =~"like~"    EXP2 =~":as_order~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"groupitem.item_name~"   OP =~"like~"    EXP2 =~":as_name~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"groupitem.item_no~"   OP =~"like~"    EXP2 =~":as_item~" ) ) ARG(NAME = ~"as_order~" TYPE = string)  ARG(NAME = ~"as_name~" TYPE = string)  ARG(NAME = ~"as_item~" TYPE = string) " update="saledet" updatewhere=1 updatekeyinplace=yes arguments=(("as_order", string),("as_name", string),("as_item", string)) )
