table(column=(type=char(20) updatewhereclause=yes name=coil_no dbname="coilmst.coil_no" )
 column=(type=decimal(1) updatewhereclause=yes name=wid dbname="coilmst.wid" )
 column=(type=long updatewhereclause=yes name=unit_qty dbname="coilmst.unit_qty" )
 column=(type=long updatewhereclause=yes name=qcnt dbname="coilmst.qcnt" )
 column=(type=char(30) updatewhereclause=yes name=location_loc_name dbname="location.loc_name" )
 column=(type=decimal(2) updatewhereclause=yes name=thin dbname="thin" )
 column=(type=char(10) updatewhereclause=yes name=loc_no dbname="coilmst.loc_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="coilmst.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="coilmst.qa" )
 column=(type=long updatewhereclause=yes name=length dbname="coilmst.length" )
 column=(type=char(1) updatewhereclause=yes name=flag dbname="coilmst.flag" )
 column=(type=char(2) updatewhereclause=yes name=coilmst_etc_no dbname="coilmst.etc_no" )
 column=(type=datetime updatewhereclause=yes name=rcpt_date dbname="coilmst.rcpt_date" )
 column=(type=char(10) updatewhereclause=yes name=coilmst_supp_no dbname="coilmst.supp_no" )
 column=(type=char(30) updatewhereclause=yes name=supp_name dbname="supp.supp_name" )
 retrieve="  SELECT coilmst.coil_no     
       , coilmst.wid         
       , coilmst.unit_qty    
       , coilmst.qcnt        
       , location.loc_name   
       , thin   = convert (decimal (3,2) , substring(qa,1,1) + ~".~" + substring(qa, 2,2))
       , coilmst.loc_no    
       , coilmst.item_no   
       , coilmst.qa        
       , coilmst.length    
       , coilmst.flag      
       , coilmst.etc_no
	  , coilmst.rcpt_date
       , coilmst.supp_no  
       , supp.supp_name
    FROM coilmst with(nolock) inner join location with(nolock)  on  coilmst.loc_no     = location.loc_no
                                                  left outer join supp with(nolock) on coilmst.supp_no = supp.supp_no
   WHERE ( coilmst.open_close = ~"O~"             )    
"  sort="thin A wid A unit_qty A coil_no A supp_name A rcpt_date A " )
