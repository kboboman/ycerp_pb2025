$PBExportHeader$d_ocglbillen_r.srd
$PBExportComments$어음번호별 배서자현황DISPLAY(1998/07/06, 성삼지)
release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(12) updatewhereclause=yes name=glbill_bill_no dbname="glbill.bill_no" )
 column=(type=datetime updatewhereclause=yes name=glbill_close_date dbname="glbill.close_date" )
 column=(type=datetime updatewhereclause=yes name=glbill_start_date dbname="glbill.start_date" )
 column=(type=decimal(0) updatewhereclause=yes name=glbill_bill_amount dbname="glbill.bill_amount" )
 column=(type=char(20) updatewhereclause=yes name=glbill_draft dbname="glbill.draft" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(12) updatewhereclause=yes name=glbill_vc_no dbname="glbill.vc_no" )
 column=(type=long updatewhereclause=yes name=glbillen_seq dbname="glbillen.seq" )
 column=(type=char(20) updatewhereclause=yes name=glbillen_endorser dbname="glbillen.endorser" )
 retrieve="  SELECT glbill.bill_no,   
         glbill.close_date,   
         glbill.start_date,   
         glbill.bill_amount,   
         glbill.draft,   
         customer.cust_name,   
         glbill.vc_no,   
         glbillen.seq,   
         glbillen.endorser  
    FROM customer,   
         glbill,   
         glbillen  
   WHERE ( customer.cust_no = glbill.cust_no ) and  
         ( glbill.bill_no = glbillen.bill_no ) and  
         ( ( glbill.set_flag <> 'Y' ) )    
"  sort="glbill_bill_no A glbill_vc_no A glbillen_seq A " )
