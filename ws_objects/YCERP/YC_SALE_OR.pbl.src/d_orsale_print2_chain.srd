$PBExportComments$수주상황접수부(1999/11/15,이인호)
release 8;
datawindow(units=0 timer_interval=60000 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=988 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=104 color="536870912" )
table(column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="cust_name" )
 column=(type=char(14) updatewhereclause=yes name=sale_order_no dbname="order_no" )
 column=(type=char(14) updatewhereclause=yes name=order_no2 dbname="order_no2" )
 column=(type=datetime updatewhereclause=yes name=sale_due_date dbname="due_date" )
 column=(type=char(80) updatewhereclause=yes name=sale_shipto_addr dbname="shipto_addr" )
 column=(type=long updatewhereclause=yes name=saledet_seq_no dbname="seq_no" )
 column=(type=char(20) updatewhereclause=yes name=saledet_qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=saledet_uom dbname="uom" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_order_qty dbname="order_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_acc_qty dbname="acc_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=saledet_price dbname="price" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=char(1) updatewhereclause=yes name=yumu dbname="yumu" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_rlse_qty dbname="rlse_qty" )
 column=(type=char(30) updatewhereclause=yes name=sale_ship_flag dbname="ship_flag" )
 column=(type=datetime updatewhereclause=yes name=sale_cust_po_date dbname="cust_po_date" )
 column=(type=char(50) updatewhereclause=yes name=saledet_rem dbname="rem" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene_desc" )
 column=(type=char(10) updatewhereclause=yes name=scene_scene_charge dbname="scene_charge" )
 column=(type=char(20) updatewhereclause=yes name=scene_scene_tel dbname="scene_tel" )
 column=(type=char(20) updatewhereclause=yes name=sale_telno_cap dbname="telno_cap" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name dbname="user_name" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name dbname="user_name" )
 column=(type=char(10) updatewhereclause=yes name=con_text dbname="con_text" )
 column=(type=char(80) updatewhereclause=yes name=sale_rem dbname="rem" )
 column=(type=char(10) updatewhereclause=yes name=color_color_name dbname="color_name" )
 column=(type=char(1) updatewhereclause=yes name=sale_ship_case dbname="ship_case" values="정기화물	J/택배	T/오토바이	A/선박	S/항공	P/기타	E/ 	 /" )
 column=(type=char(80) updatewhereclause=yes name=sale_rem1 dbname="rem1" )
 column=(type=char(80) updatewhereclause=yes name=sale_rem2 dbname="rem2" )
 column=(type=datetime updatewhereclause=yes name=sale_plan_date dbname="plan_date" )
 column=(type=char(10) updatewhereclause=yes name=sale_area_no dbname="area_no" )
 column=(type=char(10) updatewhereclause=yes name=saledet_item_no dbname="item_no" )
 column=(type=decimal(3) updatewhereclause=yes name=danjung dbname="danjung" )
 column=(type=decimal(3) updatewhereclause=yes name=jungrang dbname="jungrang" )
 column=(type=decimal(2) updatewhereclause=yes name=jan_qty dbname="jan_qty" )
 column=(type=long updatewhereclause=yes name=gonjung dbname="gonjung" )
 column=(type=char(1) updatewhereclause=yes name=utong_yn dbname="utong_yn" )
 column=(type=long updatewhereclause=yes name=top_level_star dbname="top_level_star" )
 column=(type=decimal(0) updatewhereclause=yes name=issuereq_qty dbname="issuereq_qty" )
 retrieve="  SELECT customer.cust_name    
       , sale.order_no         
       , order_no2  = substring(sale.order_no,7,8)
       , sale.due_date         
       , sale.shipto_addr     
       , saledet.seq_no        
       , saledet.qa            
       , saledet.uom           
       , saledet.order_qty     
       , saledet.acc_qty       
       , saledet.price         
       , groupitem.item_name   
       , yumu    = (case when groupitem.item_name LIKE '%유공%' then 'O' else '' end)
       , saledet.rlse_qty      
       , ship_flag = dbo.uf_getshipflag(sale.ship_flag)
       , sale.cust_po_date     
       , saledet.rem           
       , scene.scene_desc      
       , scene.scene_charge    
       , scene_tel = ( case when :as_scenehp = 'Y' then scene.scene_tel else sale.tel_no end)
       , sale.telno_cap
       , login_a.user_name     
       , login_b.user_name     
       , con_text = ( case when  sale.confirm_flag = 'Y' then login_c.user_name else '미확정' end)
       , sale.rem           
       , color.color_name   
       , sale.ship_case     
       , sale.rem1          
       , sale.rem2          
       , sale.plan_date  
       , sale.area_no    
       , saledet.item_no 
       , saledet.danjung 
       , jungrang = round(saledet.jungrang,0,1) 
       , jan_qty  = saledet.order_qty - saledet.rlse_qty
	  , ( SELECT R.OPERATION FROM ROUT R with(nolock) WHERE R.OPERATION = 1 AND R.ITEM_NO LIKE 'P%' AND R.ITEM_NO = SALEDET.ITEM_NO AND R.QA =  SUBSTRING(SALEDET.QA,1,14)+'00000' ) gonjung
	  , isnull(scene.utong_yn, 'N') utong_yn
	  , (CASE WHEN customer.top_level = 'A大' then 1
				 WHEN customer.top_level = 'B大'  then 2 
				 ELSE 3
				 END ) top_level_star
	  , dbo.uf_sale_issuereq_qty(saledet.order_no, saledet.seq_no) issuereq_qty
    FROM sale with(nolock) INNER JOIN saledet with(nolock) ON SALE.ORDER_NO = SALEDET.ORDER_NO
              INNER JOIN GROUPITEM with(nolock) ON saledet.item_no = groupitem.item_no
              INNER JOIN CUSTOMER with(nolock) ON sale.cust_no = customer.cust_no
				  LEFT OUTER JOIN SCENE with(nolock) ON sale.scene_code = scene.scene_code
				  LEFT OUTER JOIN color with(nolock) ON saledet.color = color.color_code
				  LEFT OUTER JOIN LOGIN LOGIN_A with(nolock) ON sale.login_id = login_a.user_id
				  LEFT OUTER JOIN LOGIN LOGIN_B with(nolock) ON sale.SALESMAN = login_b.user_id
				  LEFT OUTER JOIN LOGIN LOGIN_C with(nolock) ON sale.CONFIRM_USER = login_c.user_id
				  LEFT OUTER JOIN (
										  SELECT ITEM_NO, QA, OPERATION FROM ROUT with(nolock) WHERE OPERATION = 1 
										) R ON SALEDET.ITEM_NO = R.ITEM_NO AND SUBSTRING(SALEDET.QA,1,14)+'00000' = R.QA
   where sale.order_no between :arg_f_order_no and :arg_t_order_no
     and sale.confirm_flag like :arg_confirm_flag" arguments=(("as_scenehp", string),("arg_f_order_no", string),("arg_t_order_no", string),("arg_confirm_flag", string))  sort="sale_order_no A saledet_seq_no A " )
group(level=1 header.height=0 trailer.height=96 by=("sale_order_no" ) newpage=yes resetpagecount=yes header.color="553648127" trailer.color="536870912" )
