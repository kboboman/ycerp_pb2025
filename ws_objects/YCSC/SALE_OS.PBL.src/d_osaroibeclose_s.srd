 column=(type=char(12) update=yes updatewhereclause=yes key=yes name=aroiinv_no dbname="aroiinv.aroiinv_no" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"aroiinv~" ) COLUMN(NAME=~"aroiinv.oi_date~") COLUMN(NAME=~"aroiinv.aroiinv_no~")WHERE(    EXP1 =~"aroiinv.cust_no~"   OP =~"=~"    EXP2 =~":as_cust_no~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"aroiinv.open_close~"   OP =~"=~"    EXP2 =~"'O'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"aroiinv.delete_flag~"   OP =~"=~"    EXP2 =~"'N'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"aroiinv.inv_type~"   OP =~"=~"    EXP2 =~"'N'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"aroiinv.rem_amt~"   OP =~">~"    EXP2 =~"0~" ) ) ARG(NAME = ~"as_cust_no~" TYPE = string) " update="aroiinv" updatewhere=1 updatekeyinplace=no arguments=(("as_cust_no", string))  sort="aroiinv_no D oi_date D " )
column(band=detail id=1 alignment="2" tabsequence=32766 border="2" color="0" x="411" y="4" height="60" width="352" format="[shortdate] [time]"  name=oi_date editmask.mask="yyyy/mm/dd" editmask.focusrectangle=no  font.face="굴림체" font.height="-10" font.weight="400"  font.family="2" font.pitch="2" font.charset="129" background.mode="0" background.color="79219928~tif (getrow() = currentrow(), RGB(254,252,175), 78682240)" )
