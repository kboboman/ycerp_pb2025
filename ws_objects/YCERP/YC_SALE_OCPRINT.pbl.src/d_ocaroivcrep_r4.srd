$PBExportHeader$d_ocaroivcrep_r4.srd
$PBExportComments$일별 수금내역 출력(1999/01/23, 조현춘)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 1 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=528 color="536870912" )
summary(height=108 color="536870912" )
footer(height=0 color="536870912" )
detail(height=84 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=aroivc_oi_date dbname="aroivc.oi_date" )
 column=(type=char(1) updatewhereclause=yes name=aroivc_vc_type dbname="aroivc.vc_type" values="수금	R/지불	P/" )
 column=(type=char(1) updatewhereclause=yes name=aroivc_rcpt_type dbname="aroivc.rcpt_type" values="현금	C/어음	B/예금	A/D//C	D/상계	S/잡이익	E/하자보수비	F/기타	Z/" )
 column=(type=char(10) updatewhereclause=yes name=money_curr_name dbname="money.curr_name" )
 column=(type=decimal(4) updatewhereclause=yes name=aroivc_amount dbname="aroivc.amount" )
 column=(type=char(12) updatewhereclause=yes name=aroivc_cheque_no dbname="aroivc.cheque_no" )
 column=(type=datetime updatewhereclause=yes name=aroivc_cheque_end dbname="aroivc.cheque_end" )
 column=(type=char(20) updatewhereclause=yes name=bank_bank_name dbname="bank.bank_name" )
 column=(type=char(20) updatewhereclause=yes name=aroivc_branch dbname="aroivc.branch" )
 column=(type=char(20) updatewhereclause=yes name=aroivc_large dbname="aroivc.large" )
 column=(type=char(50) updatewhereclause=yes name=aroivc_rem dbname="aroivc.rem" )
 column=(type=char(4) updatewhereclause=yes name=aroivc_cust_no dbname="aroivc.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(3) updatewhereclause=yes name=aroivc_curr_code dbname="aroivc.curr_code" )
 column=(type=char(12) updatewhereclause=yes name=aroivc_vc_no dbname="aroivc.vc_no" )
 column=(type=char(10) updatewhereclause=yes name=salesman dbname="customer.salesman" )
 retrieve="  SELECT aroivc.oi_date,   
         aroivc.vc_type,   
         aroivc.rcpt_type,   
         money.curr_name,   
         aroivc.amount,   
         aroivc.cheque_no,   
         aroivc.cheque_end,   
         bank.bank_name,   
         aroivc.branch,   
         aroivc.large,   
         aroivc.rem,   
         aroivc.cust_no,   
         customer.cust_name,   
         aroivc.curr_code,   
         aroivc.vc_no,
	   customer.salesman
    FROM aroivc left outer join bank on aroivc.bank_code = bank.bank_code
         				 inner join money on aroivc.curr_code = money.curr_type
					 inner join customer on aroivc.cust_no = customer.cust_no
   WHERE
          ( aroivc.curr_code = :as_curr_code ) AND  
          ( ( aroivc.oi_date = :ad_start  ) AND  
           ( aroivc.delete_key = 'N' ) and
           ( ( ( '%' = :as_cust_no ) and ( aroivc.cust_no like '%' ) ) or
             ( ( 'L%' = :as_cust_no ) and ( aroivc.cust_no like 'L%' ) ) or
             ( ( 'A%' = :as_cust_no ) and ( aroivc.cust_no NOT like 'L%' ) ) ) )

/*
    FROM aroivc,   
         bank,   
         money,   
         customer  
   WHERE ( aroivc.bank_code *= bank.bank_code) and  
         ( aroivc.curr_code = money.curr_type ) and  
         ( aroivc.cust_no = customer.cust_no ) and  
         ( ( aroivc.curr_code = :as_curr_code ) AND  
           ( aroivc.oi_date = :ad_start  ) AND  
           ( aroivc.delete_key = 'N' ) and
           ( ( ( '%' = :as_cust_no ) and ( aroivc.cust_no like '%' ) ) or
             ( ( 'L%' = :as_cust_no ) and ( aroivc.cust_no like 'L%' ) ) or
             ( ( 'A%' = :as_cust_no ) and ( aroivc.cust_no NOT like 'L%' ) ) ) )

*/" arguments=(("as_curr_code", string),("ad_start", date),("as_cust_no", string))  sort="aroivc_oi_date D aroivc_vc_no A " )
