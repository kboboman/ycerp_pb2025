compute(band=detail alignment="1" expression="if( ship_flag2 = 'D' and do_shipamt_case = 'R' , if( do_do_rate <> 0, do_ship_amount  * 1.1, do_ship_amount),0)"border="0" color="0" x="5275" y="4" height="60" width="430" format="#,##0" html.valueishtml="0"  name=ship_total visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
