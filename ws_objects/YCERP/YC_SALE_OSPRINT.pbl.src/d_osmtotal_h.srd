 column=(type=decimal(2) update=yes updatewhereclause=yes name=coll_12 dbname="opeom.coll_12" )
 column=(type=char(10) updatewhereclause=yes name=customer_salesman dbname="customer.salesman" )
 column=(type=char(1) updatewhereclause=yes name=credit_level dbname="customer.credit_level" )
 column=(type=char(1) updatewhereclause=yes name=level_grade dbname="customer.level_grade" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="login.user_name" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=char(12) updatewhereclause=yes name=register_no dbname="customer.register_no" )
 column=(type=char(20) updatewhereclause=yes name=captain_name dbname="customer.captain_name" )
 column=(type=char(20) updatewhereclause=yes name=resident_card dbname="customer.resident_card" )
 column=(type=char(15) updatewhereclause=yes name=tel_no dbname="customer.tel_no" )
 column=(type=char(15) updatewhereclause=yes name=fax_no dbname="customer.fax_no" )
 column=(type=char(80) updatewhereclause=yes name=customer_addr dbname="customer.addr" )
 column=(type=char(15) updatewhereclause=yes name=icube_no dbname="customer.icube_no" )
 column=(type=char(50) updatewhereclause=yes name=mgr_type dbname="mgr_type" )
 column=(type=long updatewhereclause=yes name=mgr_sort dbname="mgr_sort" )
 column=(type=char(10) updatewhereclause=yes name=price_level dbname="customer.price_level" )
 column=(type=char(1) updatewhereclause=yes name=customer_open_close dbname="customer.open_close" )
 column=(type=char(255) updatewhereclause=yes name=custname_sort dbname="custname_sort" )
 column=(type=char(3) updatewhereclause=yes name=customer_class dbname="customer.class" )
 column=(type=char(10) updatewhereclause=yes name=top_level dbname="top_level" )
 column=(type=long updatewhereclause=yes name=toplevel dbname="toplevel" )
 column=(type=char(50) updatewhereclause=yes name=sale_address dbname="sale_address" )
 column=(type=decimal(1) updatewhereclause=yes name=rotate dbname="rotate" )
 column=(type=long updatewhereclause=yes name=cs_cust_idx dbname="opeom.cust_idx" )
 retrieve="  SELECT opeom.cust_no            
       , opeom.balbf_amount       
       , opeom.inv_01             
       , opeom.inv_02             
       , opeom.inv_03             
       , opeom.inv_04             
       , opeom.inv_05             
       , opeom.inv_06             
       , opeom.inv_07             
       , opeom.inv_08             
       , opeom.inv_09             
       , opeom.inv_10             
       , opeom.inv_11             
       , opeom.inv_12             
       , opeom.coll_01            
       , opeom.coll_02            
       , opeom.coll_03            
       , opeom.coll_04            
       , opeom.coll_05            
       , opeom.coll_06            
       , opeom.coll_07            
       , opeom.coll_08            
       , opeom.coll_09            
       , opeom.coll_10            
       , opeom.coll_11            
       , opeom.coll_12            
       , customer.salesman        
       , customer.credit_level 
       , customer.level_grade  
       , login.user_name             
       , customer.cust_name       
       , customer.register_no   
       , customer.captain_name 
       , customer.resident_card 
       , customer.tel_no       
       , customer.fax_no        
       , customer.addr         
       , customer.icube_no   
       , mgr_type    = (SELECT item_nm FROM codemst WHERE type = 'MGR_TYPE' and use_yn = 'Y' and item_cd = customer.mgr_type)
       , mgr_sort    = isnull((SELECT sort FROM codemst WHERE type = 'MGR_TYPE' and use_yn = 'Y' and item_cd = customer.mgr_type),99)
       , customer.price_level
       , customer.open_close
       , custname_sort = replace(replace(replace(customer.cust_name,'(주)',''),'(재)',''),'(사)','')
       , customer.class
       , top_level   = customer.top_level
/*
       , toplevel    = (case substring(customer.top_level,1,2)
                           when 'A+' then '1'
								   when 'A'  then '2'
								   when 'B+' then '3'
								   when 'B'  then '4'
								   when 'C'  then '5'
								   when '채' then '6'
								   else '7'
                        end)
*/
	  , convert(int, dbo.uf_toplevel_sort(customer.top_level)) toplevel
       , sale_address = isnull(customer.sale_address,'')
       , rotate
       , cs.cust_idx
    FROM opeom with (nolock)     
         LEFT OUTER JOIN customer with (nolock) ON opeom.cust_no = customer.cust_no
         LEFT OUTER JOIN login    with (nolock) ON customer.salesman = login.user_id
         LEFT OUTER JOIN customer_sort CS with(nolock)  ON opeom.cust_no = cs.cust_no
   WHERE ( datepart(year, opeom.eom_year) = :an_year   )
     AND ( customer.salesman           LIKE :as_userid )
     AND ((:as_chkout <> '%' AND (customer.cust_flag <> 'Y' OR customer.cust_flag IS NULL) ) OR
          (:as_chkout  = '%') /* 매출제외 포함 */
         )
" arguments=(("an_year", number),("as_userid", string),("as_chkout", string))  sort="cs_cust_idx A user_name A toplevel A mgr_sort A cust_name A " )
