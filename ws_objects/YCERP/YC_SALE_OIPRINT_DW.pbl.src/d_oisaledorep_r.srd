$PBExportComments$영업사원별 출고현황 DISPLAY(1999/07/13, 이종탁)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=532 color="16777215" )
summary(height=68 color="536870912" )
footer(height=0 color="536870912" )
detail(height=68 color="536870912" )
table(column=(type=char(11) updatewhereclause=yes name=do_spot_code dbname="do.spot_code" )
 column=(type=char(14) updatewhereclause=yes name=do_do_no dbname="do.do_no" )
 column=(type=long updatewhereclause=yes name=dodet_oi_no dbname="dodet.oi_no" )
 column=(type=char(10) updatewhereclause=yes name=dodet_item_no dbname="dodet.item_no" )
 column=(type=char(20) updatewhereclause=yes name=dodet_qa dbname="dodet.qa" )
 column=(type=char(2) updatewhereclause=yes name=dodet_uom dbname="dodet.uom" )
 column=(type=decimal(2) updatewhereclause=yes name=dodet_ship_qty dbname="dodet.ship_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=com_qty dbname="com_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=dodet_price dbname="price" )
 column=(type=decimal(8) updatewhereclause=yes name=amount dbname="amount" )
 column=(type=decimal(4) updatewhereclause=yes name=dodet_rate_cash dbname="dodet.rate_cash" )
 column=(type=datetime updatewhereclause=yes name=do_do_date dbname="do.do_date" )
 column=(type=char(10) updatewhereclause=yes name=do_fob dbname="do.fob" )
 column=(type=char(1) updatewhereclause=yes name=do_ship_flag dbname="do.ship_flag" )
 column=(type=decimal(0) updatewhereclause=yes name=do_ship_amount dbname="do.ship_amount" )
 column=(type=char(4) updatewhereclause=yes name=do_cust_no dbname="do.cust_no" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_rate dbname="do.do_rate" )
 column=(type=char(3) updatewhereclause=yes name=do_curr_code dbname="do.curr_code" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_cash dbname="do.do_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_total dbname="do.do_total" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name dbname="login.user_name" )
 column=(type=char(10) updatewhereclause=yes name=c_start dbname="c_start" )
 column=(type=char(10) updatewhereclause=yes name=c_end dbname="c_end" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 retrieve="    SELECT do.spot_code,   
         do.do_no,   
         dodet.oi_no,   
         dodet.item_no,   
         dodet.qa,   
         dodet.uom,   
         dodet.ship_qty,
			com_qty = dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty),
         price   = (case when :as_team <> 'P' then dodet.price else 0 end),  
			amount =  ( case when customer.round = 'Y' then round(dodet.price * dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty), 0,0)
							else round(dodet.price * dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty), 0,1) end ),
         dodet.rate_cash,   
         do.do_date,   
         do.fob,   
         do.ship_flag,   
         do.ship_amount,   
         do.cust_no,   
         do.do_rate,   
         do.curr_code,   
         do.do_cash,   
         do.do_total,   
         groupitem.item_name,   
         login.user_name,   
         c_start = (case when :as_start = '' then '          ' else :as_start end),   
         c_end   = (case when :as_end   = '' then '          ' else :as_end   end),   
         customer.cust_name,   
         scene.scene_desc  

FROM  do with(nolock) inner join dodet with(nolock) on do.do_no = dodet.do_no 
					          	   inner join groupitem with(nolock)  on dodet.item_no = groupitem.item_no
						        inner join customer with(nolock)  on do.cust_no = customer.cust_no
                                       inner join login with(nolock) on  customer.salesman = login.user_id
                                       left outer join scene  with(nolock) on do.cust_no = scene.cust_no and do.spot_code = scene.scene_code
where   ( ( convert(char(10),do.do_date,111) between :as_start and :as_end ) AND  
           ( do.sale_flag in ( :as_saleflag ) ) AND  
           ( customer.salesman like :as_salesman or 
			  ( :as_team = 'T' and customer.salesman 
										in ( select login.user_id from login,team 
												where login.team_code = team.team_code
			  									and team_manager = :as_salesman))) and
			  ( do.area_no like :as_area ) )    
/*
    FROM do,   
         dodet,   
         groupitem,   
         customer,   
         login,   
         scene  
   WHERE ( do.spot_code *= scene.scene_code) and  
         ( do.do_no = dodet.do_no ) and  
         ( dodet.item_no = groupitem.item_no ) and  
         ( do.cust_no = customer.cust_no ) and  
         ( customer.salesman = login.user_id ) and  
         ( ( convert(char(10),do.do_date,111) between :as_start and :as_end ) AND  
           ( do.sale_flag in ( :as_saleflag ) ) AND  
           ( customer.salesman like :as_salesman or 
			  ( :as_team = 'T' and customer.salesman 
										in ( select login.user_id from login,team 
												where login.team_code = team.team_code
			  									and team_manager = :as_salesman))) and
			  ( do.area_no like :as_area ) )    

*/" arguments=(("as_saleflag", stringlist),("as_start", string),("as_end", string),("as_salesman", string),("as_area", string),("as_team", string))  sort="login_user_name A dodet_item_no A do_cust_no A do_spot_code A do_do_no A dodet_oi_no A " )
