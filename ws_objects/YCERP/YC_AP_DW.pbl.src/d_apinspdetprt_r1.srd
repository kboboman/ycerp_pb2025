$PBExportHeader$d_apinspdetprt_r1.srd
$PBExportComments$입고라벨 출력
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=88 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" values="	Y/	N" )
 column=(type=char(14) updatewhereclause=yes name=inspdet_insp_no dbname="inspdet.insp_no" )
 column=(type=long updatewhereclause=yes name=oi_no dbname="inspdet.oi_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="inspdet.item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item.item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="inspdet.qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="inspdet.uom" )
 column=(type=char(1) updatewhereclause=yes name=item_source dbname="item.source" )
 column=(type=char(14) updatewhereclause=yes name=inspdet_pur_no dbname="inspdet.pur_no" )
 column=(type=long updatewhereclause=yes name=inspdet_seq_no dbname="inspdet.seq_no" )
 column=(type=char(10) updatewhereclause=yes name=inspdet_loc_no dbname="inspdet.loc_no" )
 column=(type=char(30) updatewhereclause=yes name=location_loc_name dbname="location.loc_name" )
 column=(type=char(1) updatewhereclause=yes name=loc_type dbname="location.loc_type" values="사내	N/작업장	W/사외	Y/" )
 column=(type=long updatewhereclause=yes name=inspdet_cnt dbname="inspdet.cnt" )
 column=(type=decimal(4) updatewhereclause=yes name=inspdet_comqty dbname="inspdet.comqty" )
 column=(type=decimal(2) updatewhereclause=yes name=rcpt_qty dbname="inspdet.rcpt_qty" )
 column=(type=char(1) updatewhereclause=yes name=pur_subcon dbname="pur.subcon" )
 column=(type=char(1) updatewhereclause=yes name=work_type dbname="purdet.work_type" )
 column=(type=decimal(4) updatewhereclause=yes name=inspdet_unit_qty dbname="inspdet.unit_qty" )
 column=(type=char(17) updatewhereclause=yes name=purdet_product_no dbname="purdet.product_no" )
 column=(type=char(20) updatewhereclause=yes name=inspdet_coil_no dbname="inspdet.coil_no" )
 column=(type=char(2) updatewhereclause=yes name=coilmst_etc_no dbname="coilmst.etc_no" )
 column=(type=char(14) updatewhereclause=yes name=sale_no dbname="purdet.sale_no" )
 column=(type=long updatewhereclause=yes name=sale_seq dbname="purdet.sale_seq" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_name dbname="SCENE.scene_name" )
 column=(type=char(10) updatewhereclause=yes name=insp_date dbname="insp_date" )
 retrieve="  SELECT chk   = 'N'
       , inspdet.insp_no     
       , inspdet.oi_no       
       , inspdet.item_no     
       , item.item_name      
       , inspdet.qa          
       , inspdet.uom         
       , item.source         
       , inspdet.pur_no      
       , inspdet.seq_no      
       , inspdet.loc_no      
       , location.loc_name   
       , location.loc_type   
       , inspdet.cnt         
       , inspdet.comqty      
       , inspdet.rcpt_qty
       , pur.subcon          
       , purdet.work_type    
       , inspdet.unit_qty    
       , purdet.product_no   
       , inspdet.coil_no     
       , coilmst.etc_no
       , purdet.sale_no
       , purdet.sale_seq
       , customer.cust_name
       , scene.scene_desc scene_name
       , convert(char(10), insp.insp_date, 121) insp_date
    FROM  inspdet with(nolock) inner join insp with(nolock) on inspdet.insp_no = insp.insp_no
                                      inner join item with(nolock) on  inspdet.item_no    = item.item_no and inspdet.qa         = item.qa    
                                      left outer join  pur with(nolock) on inspdet.pur_no    = pur.order_no
                                      left outer join  purdet  with(nolock) on  inspdet.pur_no  = purdet.order_no and inspdet.seq_no  = purdet.seq_no 
                                      left outer join  supp with(nolock) on insp.supp_no       = supp.supp_no   
                                      left outer join location with(nolock) on inspdet.loc_no = location.loc_no
                                      left outer join coilmst with(nolock) on inspdet.coil_no = coilmst.coil_no and inspdet.loc_no = coilmst.loc_no
                                      left outer join sale with(nolock) on purdet.sale_no = sale.order_no
                                      left outer join customer with(nolock) on sale.cust_no = customer.cust_no
                                      left outer join scene with(nolock) on sale.scene_code = scene.scene_code
where ( insp.insp_no    LIKE :as_inspno )" arguments=(("as_inspno", string))  sort="sale_no A sale_seq A " )
