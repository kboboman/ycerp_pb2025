 column=(type=char(50) updatewhereclause=yes name=tr_remh dbname="tr_remh" )
 retrieve="  SELECT a.trans_no
       , a.tr_type
       , a.tr_date
       , a.team_code
       , t.team_name

       , rank1   = l1.rank
       , rank2   = (case when a.tr_app2 = 'kjcworld' or a.tr_app2 = '19921209' then '팀장' else l2.rank end)
       , rank3   = l3.rank
       , rank4   = l4.rank
       , rank5   = '승인' /* l5.rank */
       , rankh   = '협조' /* l6.rank */
       , rankh1   = '협조1' /* l7.rank */

       , user1   = substring(rtrim(l1.user_name),1,2) + char(13) + substring(rtrim(l1.user_name),3,2) + (case when l1.user_name is null or l1.user_name = '' then '' else '인' end)
       , user2   = substring(rtrim(l2.user_name),1,2) + char(13) + substring(rtrim(l2.user_name),3,2) + (case when l2.user_name is null or l2.user_name = '' then '' else '인' end)
       , user3   = substring(rtrim(l3.user_name),1,2) + char(13) + substring(rtrim(l3.user_name),3,2) + (case when l3.user_name is null or l3.user_name = '' then '' else '인' end)
       , user4   = substring(rtrim(l4.user_name),1,2) + char(13) + substring(rtrim(l4.user_name),3,2) + (case when l4.user_name is null or l4.user_name = '' then '' else '인' end)
       , user5   = substring(rtrim(l5.user_name),1,2) + char(13) + substring(rtrim(l5.user_name),3,2) + (case when l5.user_name is null or l5.user_name = '' then '' else '인' end)
       , userh   = substring(rtrim(l6.user_name),1,2) + char(13) + substring(rtrim(l6.user_name),3,2) + (case when l6.user_name is null or l6.user_name = '' then '' else ''   end)
       , userh1   = substring(rtrim(l7.user_name),1,2) + char(13) + substring(rtrim(l7.user_name),3,2) + (case when l7.user_name is null or l7.user_name = '' then '' else ''   end)

       , a.user_id
       , l.user_name
       , a.tr_balteam
       , a.tr_hyupteam
       , a.tr_transamt
       , a.tr_ewolfix

       , a.tr_app1
       , a.tr_appdt1
       , a.tr_app2
       , a.tr_appdt2
       , a.tr_app3
       , a.tr_appdt3
       , a.tr_app4
       , a.tr_appdt4
       , a.tr_app5
       , a.tr_appdt5

       , a.tr_return

       , a.tr_apph
       , a.tr_appdth

       , a.tr_apph1
       , a.tr_appdth1

       , a.fcust_no
       , fcust_nm    = c1.cust_name
       , a.fspot_code
       , fscene_desc = (case when a.fspot_code = '%' then '전체현장' else s1.scene_desc end)
       , fsalesman   = fl.user_name
       , a.fregister_no
       , a.fcredit_level
       , a.flevel_grade
       , a.fprice_level
       , a.fcaptain_name
       , a.funpaid_amt
       , fcollect_day = cast(a.fcollect_day as varchar(25))

       , a.tcust_no
       , tcust_nm    = c2.cust_name
       , a.tspot_code
       , tscene_desc = s2.scene_desc
       , tsalesman   = tl.user_name
       , a.tregister_no
       , a.tcredit_level
       , a.tlevel_grade
       , a.tprice_level
       , a.tcaptain_name
       , a.tunpaid_amt
       , tcollect_day = cast(a.tcollect_day as varchar(25))

       , a.tr_content
       
       , b.seq_no
       , b.do_no
       , b.trans_amt
       , c3.cust_name
       , s3.scene_desc
       , b.bigo

       , a.tr_rem1
       , a.tr_rem2
       , a.tr_rem3
       , a.tr_rem4
       , a.tr_rem5
       , a.tr_remh
    FROM dotrans a
         LEFT OUTER JOIN dotransdet b  ON a.trans_no   = b.trans_no
         LEFT OUTER JOIN customer   c1 ON a.fcust_no   = c1.cust_no
         LEFT OUTER JOIN customer   c2 ON a.tcust_no   = c2.cust_no
         LEFT OUTER JOIN customer   c3 ON b.cust_no    = c3.cust_no
         LEFT OUTER JOIN scene      s1 ON a.fspot_code = s1.scene_code
         LEFT OUTER JOIN scene      s2 ON a.tspot_code = s2.scene_code
         LEFT OUTER JOIN scene      s3 ON b.scene_code = s3.scene_code

         LEFT OUTER JOIN login      l  ON a.user_id  = l.user_id
         LEFT OUTER JOIN team       t  ON a.team_code= t.team_code
         LEFT OUTER JOIN login      fl ON a.fsalesman= fl.user_id
         LEFT OUTER JOIN login      tl ON a.tsalesman= tl.user_id

         LEFT OUTER JOIN login      l1 ON a.tr_app1  = l1.user_id
         LEFT OUTER JOIN login      l2 ON a.tr_app2  = l2.user_id
         LEFT OUTER JOIN login      l3 ON a.tr_app3  = l3.user_id
         LEFT OUTER JOIN login      l4 ON a.tr_app4  = l4.user_id
         LEFT OUTER JOIN login      l5 ON a.tr_app5  = l5.user_id
         LEFT OUTER JOIN login      l6 ON a.tr_apph  = l6.user_id
         LEFT OUTER JOIN login      l7 ON a.tr_apph1 = l7.user_id
   WHERE a.trans_no = :as_transno
" arguments=(("as_transno", string)) )
