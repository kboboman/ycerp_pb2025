 column=(type=char(1) update=yes updatewhereclause=yes name=qa_standard dbname="qa_standard" values="	Y/	N" )
 column=(type=char(60) update=yes updatewhereclause=yes name=rout_desc dbname="rout_desc" )
 retrieve="  SELECT chk        = 'N'
       , item_no    = a.item_no
       , item_name  = g.item_name
       , qa         = a.qa
       , uom        = a.uom
       , rout_no1   = a.rout_no1   
       , rout_no2   = a.rout_no2
       , qa_standard= a.qa_standard
       , rout_desc  = a.rout_desc  
    FROM rout_b A
         LEFT OUTER JOIN groupitem G ON a.item_no = g.item_no
" update="rout_b" updatewhere=0 updatekeyinplace=no )
