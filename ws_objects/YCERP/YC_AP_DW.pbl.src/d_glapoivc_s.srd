table(column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" values="	Y/	N" )
 column=(type=char(10) updatewhereclause=yes name=insp_flag dbname="insp_flag" )
 column=(type=char(15) updatewhereclause=yes name=icube_no dbname="icube_no" )
 column=(type=char(10) updatewhereclause=yes name=supp_no dbname="supp_no" )
 column=(type=char(30) updatewhereclause=yes name=supp_name dbname="supp_name" )
 column=(type=char(1) updatewhereclause=yes name=supp_round dbname="round" )
 column=(type=char(1) updatewhereclause=yes name=prepayment dbname="prepayment" )
 column=(type=char(1) updatewhereclause=yes name=weight dbname="weight" )
 column=(type=char(6) updatewhereclause=yes name=login_id dbname="login_id" )
 column=(type=char(4) updatewhereclause=yes name=team_name dbname="team_name" )
 column=(type=char(10) updatewhereclause=yes name=user_name1 dbname="user_name1" )
 column=(type=char(30) updatewhereclause=yes name=team_name1 dbname="team_name1" )
 column=(type=char(62) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=decimal(2) updatewhereclause=yes name=rcpt_qty dbname="rcpt_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=comqty dbname="comqty" )
 column=(type=decimal(0) updatewhereclause=yes name=ship_amount dbname="ship_amount" )
 column=(type=decimal(4) updatewhereclause=yes name=insp_cash dbname="insp_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=insp_rate dbname="insp_rate" )
 column=(type=decimal(4) updatewhereclause=yes name=insp_total dbname="insp_total" )
 column=(type=long updatewhereclause=yes name=keysort dbname="keysort" )
 column=(type=char(1) updatewhereclause=yes name=keycolor dbname="keycolor" )
 retrieve="  SELECT chk         = 'N'            
       , insp_flag   = a.insp_flag    
       , icube_no    = a.icube_no     
       , supp_no     = a.supp_no      
       , supp_name   = a.supp_name    
       , round       = a.round        
       , prepayment  = a.prepayment   
       , weight      = a.weight       
       , login_id    = a.login_id     
       , team_name   = a.team_name    
       , user_name1  = a.user_name1   
       , team_name1  = a.team_name1   
       , item_name   = b.item_name+'外'
       , rcpt_qty    = b.rcpt_qty     
       , comqty      = b.comqty       
       , ship_amount = a.ship_amount  
       , insp_cash   = a.insp_cash    
       , insp_rate   = a.insp_rate    
       , insp_total  = a.insp_total   
       , keysort     = 0              
       , keycolor    = 'N'            
    FROM (
         SELECT insp_flag   = a.insp_flag 
              , icube_no    = a.icube_no
              , supp_no     = a.supp_no      
              , supp_name   = a.supp_name     
              , round       = a.round               
              , prepayment  = a.prepayment
              , weight      = a.weight
              , login_id    = a.login_id               
              , team_name   = a.team_name
              , user_name1  = a.user_name1
              , team_name1  = a.team_name1
              , ship_amount = sum(a.ship_amount)
              , insp_cash   = sum(a.insp_cash)
              , insp_rate   = sum(a.insp_rate)
              , insp_total  = sum(a.insp_total)
           FROM (
                SELECT insp_flag   = (case insp.insp_flag 
                                           when 'W' then '1.원자재'  when 'B' then '2.부자재' 
                                           when 'S' then '3.상품'    when 'Y' then '4.외주가공'
                                           else '5.' + insp.insp_flag
                                      end)
                     , icube_no    = supp.icube_no
                     , supp_no     = insp.supp_no      
                     , supp_name   = supp.supp_name     
                     , round       = supp.round
                     , prepayment  = supp.prepayment
                     , weight      = supp.weight
                     , log_date    = insp.log_date
                     , login_id    = login.duzon_sabun
                     , team_name   = login.duzon_dept
                     , user_name1  = login.user_name
                     , team_name1  = team.team_name
                     , ship_amount = isnull(insp.ship_amount,0)
                     , insp_cash   = isnull(insp.insp_cash,0)
                     , insp_rate   = isnull(insp.insp_rate,0)
                     , insp_total  = isnull(insp.insp_total,0)
                  FROM insp
                       LEFT OUTER JOIN supp    ON insp.supp_no    = supp.supp_no
                       LEFT OUTER JOIN login   ON supp.salesman   = login.user_id
                       LEFT OUTER JOIN team    ON login.team_code = team.team_code
                 WHERE ( insp.insp_date   BETWEEN :ad_sdate AND :ad_edate )
                   AND ((:as_salesman  = '%' ) OR
                        (:as_salesman <> '%' AND supp.salesman = :as_salesman )
                       )
                ) A
          GROUP BY a.insp_flag, a.icube_no, a.supp_no, a.supp_name
                 , a.round, a.prepayment, a.weight, a.login_id, a.team_name, a.user_name1, a.team_name1
         ) A
         LEFT OUTER JOIN (
              SELECT insp_flag  = a.insp_flag
                   , supp_no    = a.supp_no
                   , item_name  = b.item_name
                   , rcpt_qty   = a.rcpt_qty
                   , comqty     = a.comqty
                   , amount     = b.amount
                FROM ( /* 입고수량, 환산수량 */
                          SELECT insp_flag   = (case insp.insp_flag 
                                                     when 'W' then '1.원자재'  when 'B' then '2.부자재' 
                                                     when 'S' then '3.상품'    when 'Y' then '4.외주가공'
                                                     else '5.' + insp.insp_flag
                                                end)
                               , supp_no     = insp.supp_no      
                               , rcpt_qty    = sum(inspdet.rcpt_qty)
                               , comqty      = sum(inspdet.comqty)
                            FROM inspdet
                                 LEFT OUTER JOIN insp ON inspdet.insp_no = insp.insp_no
                           WHERE ( insp.insp_date   BETWEEN :ad_sdate AND :ad_edate )
                           GROUP BY insp.insp_flag, insp.supp_no
                     ) A         
                     LEFT OUTER JOIN ( /* 입고금액 기준으로 품명 가져오기 */
                          SELECT insp_flag = a.insp_flag
                               , supp_no   = a.supp_no
                               , item_name = b.item_name
                               , comqty    = a.comqty
                               , amount    = a.amount
                            FROM (
                                 SELECT insp_flag = a.insp_flag
                                      , supp_no   = a.supp_no
                                      , comqty    = sum(a.comqty)
                                      , amount    = max(a.amount)
                                   FROM (
                                        SELECT insp_flag = a.insp_flag 
                                             , supp_no   = a.supp_no
                                             , item_name = a.item_name
                                             , comqty    = sum(a.comqty)
                                             , amount    = sum(a.amount)
                                          FROM (
                                               SELECT insp_flag = (case insp.insp_flag 
                                                                        when 'W' then '1.원자재'  when 'B' then '2.부자재' 
                                                                        when 'S' then '3.상품'    when 'Y' then '4.외주가공'
                                                                        else '5.' + insp.insp_flag
                                                                   end)
                                                    , supp_no   = insp.supp_no
                                                    , item_no   = inspdet.item_no
                                                    , item_name = g.item_name
                                                    , comqty    = inspdet.comqty
                                                    , amount    = (inspdet.comqty * price)
                                                 FROM inspdet (NOLOCK)
                                                      LEFT OUTER JOIN insp        (NOLOCK) ON inspdet.insp_no = insp.insp_no
                                                      LEFT OUTER JOIN groupitem G (NOLOCK) ON inspdet.item_no = g.item_no
                                                WHERE ( insp.insp_date   BETWEEN :ad_sdate AND :ad_edate )
                                                ) A
                                          GROUP BY a.insp_flag, a.supp_no, a.item_name
                                        ) A
                                  GROUP BY a.insp_flag, a.supp_no
                                  ) A
                                  
                                  LEFT OUTER JOIN (
                                        SELECT insp_flag = a.insp_flag
                                             , supp_no   = a.supp_no
                                             , item_name = a.item_name
                                             , amount    = max(a.amount)
                                          FROM (
                                               SELECT insp_flag = a.insp_flag
                                                    , supp_no   = a.supp_no
                                                    , item_name = a.item_name
                                                    , amount    = sum(a.amount)
                                                 FROM (
                                                      SELECT insp_flag   = (case insp.insp_flag 
                                                                                 when 'W' then '1.원자재'  when 'B' then '2.부자재' 
                                                                                 when 'S' then '3.상품'    when 'Y' then '4.외주가공'
                                                                                 else '5.' + insp.insp_flag
                                                                            end)
                                                           , supp_no   = insp.supp_no
                                                           , item_no   = inspdet.item_no
                                                           , item_name = g.item_name
                                                           , amount    = (inspdet.comqty * price)
                                                        FROM inspdet  (NOLOCK)
                                                             LEFT OUTER JOIN insp        (NOLOCK) ON inspdet.insp_no = insp.insp_no
                                                             LEFT OUTER JOIN groupitem G (NOLOCK) ON inspdet.item_no = g.item_no
                                                       WHERE ( insp.insp_date   BETWEEN :ad_sdate AND :ad_edate )
                                                       ) A
                                                 GROUP BY a.insp_flag, a.supp_no, a.item_name
                                               ) A
                                         GROUP BY a.insp_flag, a.supp_no, a.item_name
                                  ) B ON a.insp_flag = b.insp_flag AND a.supp_no = b.supp_no AND a.amount = b.amount
                     ) B ON a.insp_flag = b.insp_flag AND a.supp_no = b.supp_no
             ) B ON a.insp_flag = b.insp_flag AND a.supp_no = b.supp_no
" arguments=(("as_salesman", string),("ad_sdate", date),("ad_edate", date))  sort="insp_flag A supp_name A " )
