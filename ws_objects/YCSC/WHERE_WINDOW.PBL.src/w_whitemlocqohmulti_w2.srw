type dw_orstand from datawindow within tabpage_4
string tag = "d_orstand_dddw"
integer x = 347
integer y = 44
integer width = 1138
integer height = 92
integer taborder = 210
string title = "d_orstandno_s"
string dataobject = "d_orstand_s"
boolean border = false
boolean livescroll = true
end type

event itemchanged;// 시스템 가져오기(일위대가/YSP그룹)
long    ll_row, ll_cnt, ll_front
decimal ld_qoh
string  ls_system, ls_locno, ls_itemno, ls_qa

dw_orstand.accepttext()
if dw_orstand.rowcount() < 1 then RETURN

ls_system = trim(dw_orstand.object.item_no[row])
if trim(ls_system) = '' or isnull(ls_system) then
	MessageBox("확인","시스템를 선택하십시요")
	RETURN
end if

if cbx_ysp.checked = true then
	dw10.retrieve( ls_system, "N" )		// YSPGRP 그룹
else
	dw10.retrieve( ls_system, "Y" )		// 일위대가
end if
if dw10.rowcount() < 1 then 
	MessageBox("확인","해당하는 시스템의 상세 데이터가 존재하지 않습니다.")
	RETURN
end if

debugbreak()

dw9.reset()
dw9.setredraw(false)
for ll_row = 1 to dw10.rowcount()				
	ll_cnt = dw9.insertrow(0)
	if ll_cnt > 1 then
		ll_front = dw9.object.seq_no[ll_cnt - 1] + 1
	else
		ll_front = 1
	end if

	ls_itemno = dw10.object.asc_item[ll_row]   
	ls_qa     = dw10.object.asc_qa[ll_row]  

	SELECT isnull(qoh,0) INTO :ld_qoh 
	  FROM itemloc 
	 WHERE loc_no = :is_loc AND item_no = :ls_itemno AND qa = :ls_qa;

	dw9.object.seq_no[ll_cnt]    = ll_front   
	dw9.object.item_name[ll_cnt] = dw10.object.groupitem_item_name[ll_row]   
	dw9.object.item_no[ll_cnt]   = ls_itemno   
	dw9.object.qa[ll_cnt]        = ls_qa   
	dw9.object.uom[ll_cnt]       = dw10.object.uom[ll_row]   	
	dw9.object.qoh[ll_cnt]       = ld_qoh   

	if dw10.object.uom[ll_row] = 'M' then
		dec{3} ld_temp, ld_order_qty, ld_sum
		
		ld_order_qty = dec(dw10.object.asc_qty[ll_row])
		ld_temp      = dec(RightA(dw10.object.asc_qa[ll_row], 5)) * 0.001  /* 단위가 M 인 품목에서 규격에서 길이부분 */
		if ls_itemno = "GCYZREZZZB" then	// 고무메지(반달,흑색)
			ld_sum    = 0
		else
			ld_sum    = Truncate(ld_order_qty / ld_temp + 0.0000001, 2 )
		end if
	
		dw9.object.order_qty[ll_cnt] = ld_sum
//		MessageBox(string(ll_row), string(ld_temp) + ' : ' + string(ld_order_qty / ld_temp) + ' : ' + string(ld_sum) )
		dw9.object.acc_qty[ll_cnt]   = gf_m2calc(trim(dw10.object.asc_qa[ll_row]), &
												  			  trim(dw10.object.uom[ll_row]), &
															  ld_sum)
	else
		dw9.object.order_qty[ll_cnt] = dw10.object.asc_qty[ll_row]   		
		dw9.object.acc_qty[ll_cnt]   = gf_m2calc(trim(dw10.object.asc_qa[ll_row]), &
															  trim(dw10.object.uom[ll_row]), &
															  dw10.object.asc_qty[ll_row])
	end if

	dw9.object.unit_cost[ll_cnt] = dw10.object.std_cost[ll_row]   
	dw9.object.item_amt[ll_cnt]  = dw10.object.std_amount[ll_row]   
	dw9.object.rem[ll_cnt]       = dw10.object.rem[ll_row]
next
dw9.setredraw(true)

end event

