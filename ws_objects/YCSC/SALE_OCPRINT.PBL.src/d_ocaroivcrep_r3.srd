detail(height=68 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=aroivc_cust_no dbname="aroivc.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(12) updatewhereclause=yes name=aroivc_vc_no dbname="aroivc.vc_no" )
 column=(type=char(1) updatewhereclause=yes name=aroivc_rcpt_type dbname="aroivc.rcpt_type" values="현금	C/어음	B/예금	A/상계	S/잡이익	E/기타	Z/D//C	D/처리어음	P/하자보수비	F/" )
 column=(type=char(1) updatewhereclause=yes name=aroivc_vc_type dbname="aroivc.vc_type" values="수금	R/지불	P/" )
 column=(type=decimal(4) updatewhereclause=yes name=aroivc_amount dbname="aroivc.amount" )
 column=(type=char(3) updatewhereclause=yes name=aroivc_curr_code dbname="aroivc.curr_code" )
 column=(type=char(50) updatewhereclause=yes name=aroivc_rem dbname="aroivc.rem" )
 column=(type=char(10) updatewhereclause=yes name=money_curr_name dbname="money.curr_name" )
 column=(type=datetime updatewhereclause=yes name=aroivc_oi_date dbname="aroivc.oi_date" )
 column=(type=char(20) updatewhereclause=yes name=bank_bank_name dbname="bank.bank_name" )
 column=(type=char(20) updatewhereclause=yes name=aroivc_branch dbname="aroivc.branch" )
 column=(type=datetime updatewhereclause=yes name=aroivc_cheque_end dbname="aroivc.cheque_end" )
 column=(type=char(20) updatewhereclause=yes name=aroivc_large dbname="aroivc.large" )
 column=(type=char(12) updatewhereclause=yes name=aroivc_cheque_no dbname="aroivc.cheque_no" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"aroivc~" )  TABLE(NAME=~"customer~" )  TABLE(NAME=~"money~" )  TABLE(NAME=~"bank~" ) COLUMN(NAME=~"aroivc.cust_no~") COLUMN(NAME=~"customer.cust_name~") COLUMN(NAME=~"aroivc.vc_no~") COLUMN(NAME=~"aroivc.rcpt_type~") COLUMN(NAME=~"aroivc.vc_type~") COLUMN(NAME=~"aroivc.amount~") COLUMN(NAME=~"aroivc.curr_code~") COLUMN(NAME=~"aroivc.rem~") COLUMN(NAME=~"money.curr_name~") COLUMN(NAME=~"aroivc.oi_date~") COLUMN(NAME=~"bank.bank_name~") COLUMN(NAME=~"aroivc.branch~") COLUMN(NAME=~"aroivc.cheque_end~") COLUMN(NAME=~"aroivc.large~") COLUMN(NAME=~"aroivc.cheque_no~")    JOIN (LEFT=~"aroivc.cust_no~"    OP =~"=~"RIGHT=~"customer.cust_no~" )    JOIN (LEFT=~"aroivc.curr_code~"    OP =~"=~"RIGHT=~"money.curr_type~" )    JOIN (LEFT=~"aroivc.bank_code~"    OP =~"=~"RIGHT=~"bank.bank_code~" )WHERE(    EXP1 =~"aroivc.oi_date~"   OP =~"=~"    EXP2 =~":ad_date~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"aroivc.curr_code~"   OP =~"=~"    EXP2 =~":as_curr~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"aroivc.delete_key~"   OP =~"=~"    EXP2 =~"'N'~" ) ) ARG(NAME = ~"ad_date~" TYPE = date)  ARG(NAME = ~"as_curr~" TYPE = string) " arguments=(("ad_date", date),("as_curr", string))  sort="customer_cust_name A aroivc_vc_no A aroivc_vc_type D " )
group(level=1 header.height=0 trailer.height=80 by=("aroivc_cust_no" ) header.color="536870912" trailer.color="536870912" )
