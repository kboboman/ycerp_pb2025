 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 retrieve="PBSELECT( VERSION(400) DISTINCT ()TABLE(NAME=~"customer~" )  TABLE(NAME=~"aroiinv~" ) COLUMN(NAME=~"customer.cust_no~") COLUMN(NAME=~"customer.cust_name~")    JOIN (LEFT=~"customer.cust_no~"    OP =~"=~"RIGHT=~"aroiinv.cust_no~" )WHERE(    EXP1 =~"aroiinv.open_close~"   OP =~"in~"    EXP2 =~"('O', 'T')~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"aroiinv.delete_flag~"   OP =~"=~"    EXP2 =~"'N'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"aroiinv.inv_type~"   OP =~"=~"    EXP2 =~"'Y'~" ) ) "  sort="cust_name A " )
column(band=detail id=2 alignment="0" tabsequence=32766 border="0" color="0" x="215" y="4" height="60" width="795" format="[general]"  name=cust_name  tag="상호" edit.limit=30 edit.case=any edit.autoselect=yes edit.autohscroll=yes  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
