$PBExportComments$수주마스터 현황 DISPLAY(1998/05/12, 정재수)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="79741120" )
summary(height=72 color="536870912" )
footer(height=0 color="536870912" )
detail(height=68 color="536870912" )
table(column=(type=char(4) update=yes updatewhereclause=yes name=cust_no dbname="sale.cust_no" initial=" " )
 column=(type=char(11) update=yes updatewhereclause=yes name=scene_code dbname="sale.scene_code" initial=" " )
 column=(type=char(14) update=yes updatewhereclause=yes name=order_no dbname="sale.order_no" initial=" " )
 column=(type=datetime update=yes updatewhereclause=yes name=order_date dbname="sale.order_date" initial=" " )
 column=(type=datetime update=yes updatewhereclause=yes name=due_date dbname="sale.due_date" initial=" " )
 column=(type=char(1) update=yes updatewhereclause=yes name=sale_flag dbname="sale.sale_flag" initial=" " values="내수	D/수출	E/L//C	L/" )
 column=(type=char(3) update=yes updatewhereclause=yes name=curr_code dbname="sale.curr_code" initial=" " )
 column=(type=char(30) update=yes updatewhereclause=yes name=ship_flag dbname="ship_flag" )
 column=(type=char(10) update=yes updatewhereclause=yes name=fob dbname="sale.fob" initial=" " )
 column=(type=char(10) update=yes updatewhereclause=yes name=salesman dbname="sale.salesman" initial=" " )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=sale_amount dbname="sale.sale_amount" initial=" " )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=sale_tax dbname="sale.sale_tax" initial=" " )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 column=(type=datetime updatewhereclause=yes name=c_start dbname="c_start" )
 column=(type=datetime updatewhereclause=yes name=c_end dbname="c_end" )
 column=(type=char(8) updatewhereclause=yes name=c_text dbname="c_text" )
 retrieve="  SELECT sale.cust_no,   
         sale.scene_code,   
         sale.order_no,   
         sale.order_date,   
         sale.due_date,   
         sale.sale_flag,   
         sale.curr_code,   
         ship_flag = dbo.uf_getshipflag(sale.ship_flag),   
         sale.fob,   
         sale.salesman,   
         sale.sale_amount,   
         sale.sale_tax,   
         customer.cust_name,   
         scene.scene_desc,   
         c_start = convert(smalldatetime, :ad_start, 111),   
         c_end = convert(smalldatetime, :ad_end, 111),   
         '        ' c_text  
    FROM sale inner join customer on sale.cust_no = customer.cust_no
                        left outer join  scene on sale.scene_code = scene.scene_code
   WHERE ( sale.open_close not in('X','C')) and  
         ( ( sale.sale_flag in ( :asa_sale_flag ) ) AND  
         ( sale.order_date between :ad_start and :ad_end ) AND  
			( sale.salesman like :as_userid) AND
         ( sale.confirm_flag in ( :asa_confirm_flag ) ) )    
" arguments=(("asa_sale_flag", stringlist),("ad_start", date),("ad_end", date),("asa_confirm_flag", stringlist),("as_userid", string))  sort="customer_cust_name A scene_code A order_date A order_no A " )
group(level=1 header.height=0 trailer.height=72 by=("cust_no" ) header.color="536870912" trailer.color="536870912" )
group(level=2 header.height=0 trailer.height=72 by=("scene_code" ) header.color="536870912" trailer.color="536870912" )
