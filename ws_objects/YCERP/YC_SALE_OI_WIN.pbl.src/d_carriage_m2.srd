table(column=(type=char(8) update=yes updatewhereclause=yes key=yes name=cardate dbname="car_carriage.cardate" )
 column=(type=char(11) update=yes updatewhereclause=yes key=yes name=scene_code dbname="car_carriage.scene_code" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=car_seq dbname="car_carriage.car_seq" )
 column=(type=char(12) update=yes updatewhereclause=yes name=car_no dbname="car_carriage.car_no" )
 column=(type=char(2) update=yes updatewhereclause=yes name=car_gbn dbname="car_carriage.car_gbn" )
 column=(type=char(20) update=yes updatewhereclause=yes name=driver_name dbname="car_carriage.driver_name" )
 column=(type=char(20) update=yes updatewhereclause=yes name=driver_tel dbname="car_carriage.driver_tel" )
 column=(type=datetime update=yes updatewhereclause=yes name=carriage_time dbname="car_carriage.carriage_time" )
 column=(type=char(60) update=yes updatewhereclause=yes name=car_order dbname="car_carriage.car_order" )
 column=(type=char(2) update=yes updatewhereclause=yes name=car_status dbname="car_carriage.car_status" values="반영전	01/송장작성	03/엑셀작성	04/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=ship_flag dbname="car_carriage.ship_flag" )
 column=(type=char(1) update=yes updatewhereclause=yes name=shipamt_case dbname="car_carriage.shipamt_case" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=st_car_amt dbname="car_carriage.st_car_amt" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=ship_amount dbname="car_carriage.ship_amount" )
 column=(type=char(14) update=yes updatewhereclause=yes name=do_no dbname="car_carriage.do_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=car_company dbname="car_carriage.car_company" values="유창	유창/유로직스	유로직스/기타	기타/" )
 column=(type=char(10) update=yes updatewhereclause=yes name=carriage_length dbname="car_carriage.carriage_length" )
 retrieve="select cardate, 
           scene_code, 
           car_seq, 
           car_no, 
           car_gbn, 
           driver_name, 
           driver_tel, 
           carriage_time,  
           car_order, 
           car_status, 
           ship_flag, 
           shipamt_case,
           st_car_amt,
           ship_amount,
           do_no,
           car_company,
           carriage_length
from car_carriage
where cardate = :as_date
and scene_code = :as_scene_code" update="car_carriage" updatewhere=0 updatekeyinplace=no arguments=(("as_date", string),("as_scene_code", string)) )
