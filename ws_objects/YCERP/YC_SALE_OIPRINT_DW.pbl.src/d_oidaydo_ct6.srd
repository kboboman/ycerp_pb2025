$PBExportHeader$d_oidaydo_ct6.srd
$PBExportComments$출고집계(수주일)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no  crosstab.dynamic = yes grid.lines=0 grid.columnmove=no selected.mouse=no )
header[1](height=0 color="536870912" )
header[2](height=80 color="536870912" )
header[3](height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=number updatewhereclause=yes name=cqty dbname="cqty" )
 column=(type=number updatewhereclause=yes name=cprice dbname="cprice" )
 retrieve="  SELECT user_name    = a.user_name
       , cat          = a.category
       , category     = cm.item_nm   
       , gtype        = a.gtype
       , due_date     = a.due_date + (case when :as_yymm = 'Y' then a.due_days else '(' + a.due_days + ')' end)
       , item_name    = a.item_name  
       , qa           = a.qa
       , cqty         = a.cqty       
       , cprice       = a.cprice / 1000
    FROM (
         SELECT user_name    = l.user_name
              , category     = isnull(i.category, 'TOP1999')
              , gtype        = i.type
              , due_date     = (case when :as_yymm = 'Y' then convert(char(04),b.do_date,111)
                                     else convert(char(08),b.do_date,11)
                                end)
              , due_days     = replace((case when :as_yymm = 'Y'
                                             then '.' + (case when datepart(month,b.do_date) < 10 
                                                              then '0'+cast(datepart(month,b.do_date) as char(2))
                                                              else cast(datepart(month,b.do_date) as char(2))
                                                         end)+'월'
                                             else (case when datepart(dw,b.do_date) = 1 then '일'
                                                        when datepart(dw,b.do_date) = 2 then '월'
                                                        when datepart(dw,b.do_date) = 3 then '화'
                                                        when datepart(dw,b.do_date) = 4 then '수'
                                                        when datepart(dw,b.do_date) = 5 then '목'
                                                        when datepart(dw,b.do_date) = 6 then '금'
                                                        when datepart(dw,b.do_date) = 7 then '토'
                                                   end)
                                        end),' ','')
              , item_name    = g.item_name
              , qa           = substring(a.qa,1,13)
              , cqty         = dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty)
              , cprice       = a.price * dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty)
           FROM  customer  C with (nolock) inner join v_team d ON c.salesman = d.user_id
			 INNER JOIN do   b       with (nolock) ON c.cust_no   = b.cust_no
			 INNER JOIN dodet   a with (nolock) on b.do_no = a.do_no
                 INNER JOIN login      L with (nolock) ON c.salesman = l.user_id
                 LEFT OUTER JOIN groupitem  G with (nolock) ON a.item_no  = g.item_no
                 LEFT OUTER JOIN itemtop10  I with (nolock) ON a.item_no  = i.item_no  
          WHERE ( b.do_date   BETWEEN :ad_sdate AND :ad_edate )
            AND ((:as_works  = 'A%' AND a.item_no  IN (SELECT DISTINCT rout.item_no                           
                                                         FROM rout
                                                              LEFT OUTER JOIN groupitem G ON rout.item_no = g.item_no
                                                        WHERE ( wc_no  between 'F01' AND 'F25' )
                                                           OR ( wc_no  between 'T01' AND 'T15' )
                                                      ) ) OR
                 (:as_works <> 'A%' AND a.item_no  IN (SELECT DISTINCT rout.item_no                           
                                                         FROM rout
                                                              LEFT OUTER JOIN groupitem G ON rout.item_no = g.item_no
                                                        WHERE ( wc_no  LIKE :as_works )
                                                      ) ) 
                )
            AND ((:as_area     = '%' and b.area_no  LIKE :as_area) OR
                 (:as_area    <> '%' and b.area_no     = :as_area)
                )
            AND ((:as_inside   = '%' ) OR
                 (:as_inside  <> '%' and b.cust_no NOT IN (SELECT cust_no FROM V_CUST_INSIDE))
                )
		AND rtrim(ltrim(d.team)) like :as_team
		AND rtrim(ltrim(d.user_id)) like :as_salesman
         ) A
         LEFT OUTER JOIN (
              SELECT item_cd, item_nm FROM codemst with (nolock) WHERE type = 'ITEMTOP10' AND use_yn = 'Y'
         ) CM ON a.category = cm.item_cd
     WHERE ( (:as_itemtop10  = '%' AND a.category LIKE '%'           ) OR
             (:as_itemtop10 <> '%' AND a.category    = :as_itemtop10 )
           )" arguments=(("as_area", string),("ad_sdate", date),("ad_edate", date),("as_yymm", string),("as_salesman", string),("as_team", string),("as_itemtop10", string),("as_inside", string),("as_works", string))  sort="item_name A user_name A " )
group(level=1 header.height=0 trailer.height=80 by=("item_name" ) header.color="536870912" trailer.color="536870912" )
