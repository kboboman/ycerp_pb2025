table(column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=datetime updatewhereclause=yes name=order_date dbname="order_date" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=decimal(2) updatewhereclause=yes name=order_qty dbname="order_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=acc_qty dbname="acc_qty" )
 column=(type=decimal(6) updatewhereclause=yes name=amt dbname="amt" )
 column=(type=decimal(4) updatewhereclause=yes name=sale_amount dbname="sale_amount" )
 column=(type=char(14) updatewhereclause=yes name=order_no dbname="order_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="seq_no" )
 retrieve="  SELECT distinct l.user_name
       , m.cust_no   
       , c.cust_name   
       , sc.scene_desc   
       , s.order_date   
       , g.item_name
       , sd.qa
       , sd.uom
       , sd.order_qty
       , sd.acc_qty
       , amt = sd.acc_qty * sd.price 
       , s.sale_amount  
       , sd.order_no
       , sd.seq_no 
    FROM UF_MyCustomers( '%' ) M
         LEFT OUTER JOIN customer   C ON m.cust_no     = c.cust_no
/*         LEFT OUTER JOIN sale       S ON m.cust_no     = s.cust_no AND s.open_close NOT IN ('X','C')	한도초과 */
         LEFT OUTER JOIN sale       S ON m.cust_no     = s.cust_no AND s.open_close  = 'O'
         LEFT OUTER JOIN saledet   SD ON s.order_no    = sd.order_no 
         LEFT OUTER JOIN groupitem  G ON sd.item_no    = g.item_no
         LEFT OUTER JOIN scene     SC ON s.scene_code  = sc.scene_code
         LEFT OUTER JOIN login      L ON c.salesman    = l.user_id
   WHERE ( sd.order_qty - sd.rlse_qty > 0 )  /*출고분 제외*/
     AND ((:as_custno  = '%'   AND m.cust_no   LIKE '%'  ) OR 
          (:as_custno  = 'ALL' AND m.cust_no   LIKE '%'  ) OR 
          (:as_custno <> 'ALL' AND m.cust_no      = :as_custno )
         )
     AND ( s.scene_code  = :as_scene  )
     AND ( s.order_date  = :adt_date  ) 
" arguments=(("as_custno", string),("as_scene", string),("adt_date", datetime))  sort="order_no A seq_no A " )
