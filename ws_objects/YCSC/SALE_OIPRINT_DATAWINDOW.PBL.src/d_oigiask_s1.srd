table(column=(type=char(12) updatewhereclause=yes name=ask_det_ask_no dbname="ask_det.ask_no" )
 column=(type=long updatewhereclause=yes name=ask_det_seq_no dbname="ask_det.seq_no" )
 column=(type=char(10) updatewhereclause=yes name=ask_det_item_no dbname="ask_det.item_no" )
 column=(type=char(20) updatewhereclause=yes name=ask_det_qa dbname="ask_det.qa" )
 column=(type=decimal(2) updatewhereclause=yes name=ask_det_ask_qty dbname="ask_det.ask_qty" )
 column=(type=char(10) updatewhereclause=yes name=ask_det_loc_no dbname="ask_det.loc_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(30) updatewhereclause=yes name=location_loc_name dbname="location_loc_name" )
 column=(type=decimal(2) updatewhereclause=yes name=ask_det_issue_qty dbname="ask_det.issue_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=ask_det_rlse_qty dbname="ask_det.rlse_qty" )
 column=(type=char(14) updatewhereclause=yes name=ask_det_sale_no dbname="ask_det.sale_no" )
 column=(type=char(50) updatewhereclause=yes name=ask_det_rem dbname="ask_det.rem" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(1) updatewhereclause=yes name=ask_head_proc_flag dbname="ask_det.rlse_flag" values="완료	Y/진행	N/" )
 column=(type=datetime updatewhereclause=yes name=ask_det_rlse_date dbname="ask_det.rlse_date" )
 column=(type=datetime updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=datetime updatewhereclause=yes name=edate dbname="edate" )
 column=(type=char(20) updatewhereclause=yes name=t_area_name dbname="t_area_name" )
 column=(type=char(30) updatewhereclause=yes name=r_area_name dbname="r_area_name" )
 column=(type=char(1) updatewhereclause=yes name=as_chk dbname="as_chk" )
 column=(type=char(10) updatewhereclause=yes name=ask_name dbname="ask_name" )
 column=(type=char(10) updatewhereclause=yes name=act_name dbname="act_name" )
 retrieve="  SELECT ask_det.ask_no,
			ask_det.seq_no,   
         ask_det.item_no,   
         ask_det.qa,   
         ask_det.ask_qty,   
         ask_det.loc_no,   
         groupitem.item_name,   
         location_loc_name = loc_1.loc_name,   
         ask_det.issue_qty,   
         ask_det.rlse_qty,   
         ask_det.sale_no,   
         ask_det.rem,   
         cust_name = dbo.uf_getcustname(ask_det.sale_no),   
         ask_det.rlse_flag,
			ask_det.rlse_date,
         sdate = convert(smalldatetime, :as_start, 111),   
         edate = convert(smalldatetime, :as_end, 111),
			t_area_name = area.area_name,
			r_area_name = loc_2.loc_name,
			as_chk = :as_chk,
			ask_name = login_1.user_name,
			act_name = login_2.user_name
FROM ask_det with(nolock) inner join ask_head with(nolock) on ask_det.ask_no = ask_head.ask_no
									 inner join groupitem with(nolock)  on ask_det.item_no = groupitem.item_no
									 inner join  location loc_1  with(nolock) on  ask_det.loc_no = loc_1.loc_no
									 left outer join  location loc_2  with(nolock) on  ask_head.ask_loc = loc_2.loc_no 
									 left outer join  login login_1  with(nolock) on  ask_head.ask_user = login_1.user_id 
									 left outer join  login login_2  with(nolock) on  ask_head.act_user  = login_2.user_id
									 inner join area on  ( 
																  case when :as_chk =  'A' THEN  ask_head.t_area
																		 when :as_chk =  'B' THEN  ask_head.F_area 
																		  END
													 		) = area.area_no
     WHERE ( ask_det.rlse_qty > 0  ) 
     AND ( ask_det.item_no LIKE :as_item_no ) 
     AND (( ( :as_chk = 'A' ) and ( ask_head.t_area = :as_area ) and
			      ( ask_head.ask_date between :as_start + ' 00:00:00.000' and :as_end + ' 23:59:59.999' )
          ) OR
          ( ( :as_chk = 'B' ) and ( ask_head.f_area = :as_area ) and 
			      ( ask_head.act_date between :as_start + ' 00:00:00.000' and :as_end + ' 23:59:59.999' )
          ) 
         ) 

" arguments=(("as_start", string),("as_end", string),("as_area", string),("as_item_no", string),("as_chk", string))  sort="ask_det_ask_no A ask_det_seq_no A ask_det_item_no A ask_det_rlse_date A " )
