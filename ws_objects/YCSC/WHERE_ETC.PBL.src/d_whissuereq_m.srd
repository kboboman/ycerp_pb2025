$PBExportHeader$d_whissuereq_m.srd
$PBExportComments$출고의뢰서헤더(2003/09/22, 이인호)
release 8;
datawindow(units=0 timer_interval=0 color=67108864 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=928 color="536870912" )
table(column=(type=datetime update=yes updatewhereclause=yes key=yes name=req_date dbname="issuereq.req_date" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=salesman dbname="issuereq.salesman" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=req_seq dbname="issuereq.req_seq" )
 column=(type=char(10) update=yes updatewhereclause=yes name=accept_user dbname="issuereq.accept_user" )
 column=(type=char(60) update=yes updatewhereclause=yes name=rem dbname="issuereq.rem" )
 column=(type=char(255) update=yes updatewhereclause=yes name=req_text dbname="issuereq.req_text" )
 column=(type=char(10) update=yes updatewhereclause=yes name=accept_area dbname="issuereq.accept_area" )
 column=(type=char(1) update=yes updatewhereclause=yes name=confirm_flag dbname="issuereq.confirm_flag" initial="N" values="확정	Y/미확정	N/" )
 column=(type=datetime update=yes updatewhereclause=yes name=sys_date dbname="issuereq.sys_date" )
 retrieve="  SELECT issuereq.req_date,   
         issuereq.salesman,   
         issuereq.req_seq,   
         issuereq.accept_user,   
         issuereq.rem,   
         issuereq.req_text,   
         issuereq.accept_area,   
         issuereq.confirm_flag,
         issuereq.sys_date
    FROM issuereq  
   WHERE ( issuereq.req_date = :ad_date ) AND  
         ( issuereq.salesman = :as_user ) AND  
         ( issuereq.req_seq  = :ai_seq )    
" update="issuereq" updatewhere=0 updatekeyinplace=no arguments=(("ad_date", date),("as_user", string),("ai_seq", number)) )
