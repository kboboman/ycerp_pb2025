$PBExportHeader$d_bdplanresults_r.srd
$PBExportComments$계획대비실적현황-월간[2001/01/22,서재복]
release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=72 color="536870912" )
summary(height=76 color="536870912" )
footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(3) updatewhereclause=yes name=plan_div dbname="bdplan.plan_div" )
 column=(type=char(3) updatewhereclause=yes name=plan_spec dbname="bdplan.plan_spec" )
 column=(type=char(6) updatewhereclause=yes name=p_date dbname="p_date" )
 column=(type=decimal(0) updatewhereclause=yes name=qty dbname="qty" )
 column=(type=decimal(0) updatewhereclause=yes name=quantity dbname="quantity" )
 retrieve="select p.plan_div, p.plan_spec
     , substring( convert( char(6), p.plan_date, 112), 1, 6) p_date
     , sum(p.plan_qty) qty
     , sum(d.quantity) quantity
from bdplan p,
     v_bdinfodet_monthqty d
where p.plan_div = d.div
  and p.plan_spec = d.spec
  and ( substring( convert( char(6), p.plan_date, 112), 1, 6)
    = substring( convert( char(6), d.fixeddate, 112), 1, 6) )
  and substring( convert( char(6), p.plan_date, 112), 1, 6) = :as_month
group by p.plan_div, p.plan_spec
       , substring( convert( char(6), p.plan_date, 112), 1, 6)
" arguments=(("as_month", string)) )
