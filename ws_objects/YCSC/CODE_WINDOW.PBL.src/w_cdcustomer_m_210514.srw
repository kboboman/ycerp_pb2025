event selectionchanged;choose case index
	case 1
		is_tab5ddlb1_chk = 'A'
		tab_1.tabpage_5.cb_retrieve.enabled = false
		tab_1.tabpage_5.cb_edit.enabled = true
		tab_1.tabpage_5.cb_cancel.enabled = true
		tab_1.tabpage_5.cb_save.enabled = true
	case 2
		is_tab5ddlb1_chk = 'Y'
		tab_1.tabpage_5.cb_retrieve.enabled = false
		tab_1.tabpage_5.cb_edit.enabled = true
		tab_1.tabpage_5.cb_cancel.enabled = true
		tab_1.tabpage_5.cb_save.enabled = true
	case 3
		is_tab5ddlb1_chk = 'N'
		tab_1.tabpage_5.cb_retrieve.enabled = false
		tab_1.tabpage_5.cb_edit.enabled = true
		tab_1.tabpage_5.cb_cancel.enabled = true
		tab_1.tabpage_5.cb_save.enabled = true
	case 4
		is_tab5ddlb1_chk = 'N'
		tab_1.tabpage_5.cb_retrieve.enabled = true
		tab_1.tabpage_5.cb_edit.enabled = false
		tab_1.tabpage_5.cb_cancel.enabled = true
		tab_1.tabpage_5.cb_save.enabled = false
end choose


end event

