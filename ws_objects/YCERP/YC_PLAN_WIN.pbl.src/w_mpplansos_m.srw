type cbx_col from checkbox within tabpage_2
integer x = 274
integer y = 584
integer width = 603
integer height = 60
integer textsize = -9
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
long textcolor = 16711680
long backcolor = 67108864
string text = "채우기(프로그램)"
end type

event clicked;// 컬럼 채우기
string ls_value, ls_col, ls_chk, ls_type, ls_coltype, ls_colname
long   ll_row, ll_width, ll_height, ll_cnt

if this.checked = false then RETURN

ls_value  = trim(em_value.text)
ls_col    = is_colname

ls_coltype = dw6.Describe(ls_col+".ColType")
ls_coltype = is_coltype
if PosA(ls_coltype,"char") > 0 then
	ls_type = "char"
elseif PosA(ls_coltype,"long") > 0 then
	ls_type = "long"
elseif PosA(ls_coltype,"date") > 0 then
	ls_type = "date"
else
	ls_type = ""
end if

dw6.setredraw( false )
for ll_row = 1 to dw6.rowcount()
	ls_chk =	dw6.object.chk[ll_row]

	if ls_chk = "Y" then
		ll_cnt = ll_cnt + 1
		
		choose case ls_type
			case "char"
				dw6.SetItem(ll_row, ls_col, ls_value)
				
			case "date"
				if lower(ls_coltype) = "datetime" then
					dw6.SetItem(ll_row, ls_col, datetime(date(ls_value), time("00:00:00")) )
				else
					dw6.SetItem(ll_row, ls_col, date(ls_value) )
				end if
				
			case "deci"
				dw6.SetItem(ll_row, ls_col, dec(ls_value) )
				
			case "int ", "number"
				dw6.SetItem(ll_row, ls_col, integer(ls_value) )
				
			case "long"
				dw6.SetItem(ll_row, ls_col, long(ls_value) )
				
			case "real"
				dw6.SetItem(ll_row, ls_col, real(ls_value) )
				
			case "time"	
				if lower(ls_coltype) = "timestamp" then
					dw6.SetItem(ll_row, ls_col, ls_value)
				else
					dw6.SetItem(ll_row, ls_col, time(ls_value) )
				end if
				
			case "ulon"
				dw6.SetItem(ll_row, ls_col, long(ls_value) )
		end choose
		
		choose case is_colname
			case "elong_w", "w1", "w2", "w3"
				ll_width  = dw6.object.w1[ll_row] + dw6.object.w2[ll_row] + dw6.object.w3[ll_row] + long(ls_value)
				dw6.object.width[ll_row]  = ll_width
				
			case "elong_h", "h1", "h2"
				ll_height = dw6.object.h1[ll_row] + dw6.object.h2[ll_row] + long(ls_value)
				dw6.object.height[ll_row] = ll_height				
		end choose
	end if
next
dw6.setredraw( true )
this.checked = false

if ll_cnt < 1 then
	MessageBox("확인","채우기할 대상을 먼저 선택하시기 바랍니다.")
end if

end event

type cb_paste from commandbutton within tabpage_2
integer x = 686
integer width = 489
integer height = 76
integer taborder = 20
integer textsize = -9
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "엑셀 붙혀넣기"
end type

event clicked;// 엑셀 붙혀넣기
string	ls_saleno, ls_year, ls_custno, ls_scenecode, ls_cust, ls_scene, ls_itemno, ls_itemnm
string   ls_qa, ls_qa3, ls_color, ls_metrial
long		ll_row, ll_rc, ll_cnt, ll_seqno
integer  iRet
boolean  lb_chk = false, lb_msgchk = false

//dw6.dataobject = "d_mpplansosdet_excel"

if dw6.rowcount() = 1 then
	dw6.deleterow(1)
end if

ll_rc = dw6.ImportClipBoard()		// 1번 라인 SKIP
if ll_rc > 0 then
	// Long. Returns the number of rows that were imported 
	//     if it succeeds and returns the following values if an error occurs:
	//  0  End of file, too many rows
	// -2  Not enough columns
	// -3  Invalid argument
	// -4  Invalid input
	
	dw6.groupcalc()
	
	//ClipBoard("")	
	MessageBox("확인","엑셀 붙혀넣기 완료" )
end if

// 소재체크, 수주번호 체크 
ls_year = LeftA(em_2.text,4)

dw6.setredraw( false )
for ll_row = 1 to dw6.rowcount()
	ls_saleno    = dw6.object.sale_no[ll_row]
	ls_custno    = dw6.object.cust_no[ll_row]
	ls_scenecode = dw6.object.scene_code[ll_row]
	ls_itemno    = dw6.object.item_no[ll_row]
	ls_qa3       = LeftA(dw6.object.qa[ll_row],3)
	
	// 소재체크
	if cbx_metrial.checked = true then
		SELECT TOP 1 metrial INTO :ls_metrial 
		  FROM itemsosdet 
       WHERE item_no = :ls_itemno AND left(qa,3) = :ls_qa3;
		if isnull(ls_metrial) OR ls_metrial = "" then
		else
			dw6.object.metrial[ll_row] = ls_metrial
		end if
	end if
	
	// 수주번호체크
	if LenA(ls_saleno) <> 14 then
		ll_cnt = ll_cnt + 1
		
		dw6.scrolltorow( ll_row )
		
		SELECT cust_no, scene_code INTO :ls_cust, :ls_scene
		  FROM sale
		 WHERE order_no = :ls_saleno;
		 
		if lb_chk = false then
			if lb_msgchk = false then
				if MessageBox("확인", "수주번호를 기본값으로 수정하시겠습니까?", Exclamation!, OKCancel!, 2) = 1 then
					lb_chk = true
					dw6.object.sale_no[ll_row] = "HD" + ls_year + ls_saleno
				else
					lb_msgchk = true
				end if
			end if
		else
			if ls_custno <> ls_cust OR ls_scenecode <> ls_scene then
				MessageBox("확인", "[" + string(ll_row) + "]행 수주번호 기본값(HD)이 존재하지 않습니다.")
			end if
			dw6.object.sale_no[ll_row] = "HD" + ls_year + ls_saleno
		end if
	end if
next

// 엑셀작업일 경우 품목확인
for ll_row = 1 to dw6.rowcount()
	ls_saleno = dw6.object.sale_no[ll_row]
	ll_seqno  = dw6.object.seq_no[ll_row]
	
	SELECT saledet.item_no, g.item_name, saledet.qa, saledet.color 
	  INTO :ls_itemno, :ls_itemnm, :ls_qa, :ls_color
	  FROM saledet
	       LEFT OUTER JOIN groupitem G ON saledet.item_no = g.item_no
	 WHERE order_no = :ls_saleno AND seq_no = :ll_seqno;

	dw_6.object.item_no[ll_row]   = ls_itemno
	dw_6.object.item_name[ll_row] = ls_itemnm
	dw_6.object.qa[ll_row]        = ls_qa
	dw_6.object.color[ll_row]     = ls_color
next
dw6.setredraw( true )

end event

type cb_export from commandbutton within tabpage_2
integer x = 1184
integer width = 489
integer height = 76
integer taborder = 340
boolean bringtotop = true
integer textsize = -9
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "엑셀 내보내기"
end type

event clicked;//
string  ls_excel
Long    ll_row, ll_status, ll_max, iCol, iRow
String  ls_Sheet, ls_filename, named
Integer iRet, ii, iSheetCount, rownbr

if FileExists(".\생산관리_소재신청.xlsx") = false then
	MessageBox("확인","생산관리_소재신청.xlsx 원본파일이 존재하지 않습니다.~n~n" + &
	           "재 접속 후 실행하시기 바랍니다.")
	RETURN
end if

if MessageBox("확인","현재 목록을 엑셀양식으로 저장 하시겠습니까?", Exclamation!, OKCancel!, 1) = 2 then RETURN


OLEObject OleXLS
OleXLS = CREATE OLEObject 
iret = OleXLS.ConnectToNewObject( "Excel.Application" ) 
if iret <> 0 then DESTROY OleXLS 

// Visible = True의 경우 엑셀 프로그램이 띄워지며 False인 경우 아이콘화된다. 
OleXLS.Application.Visible = true

// 엑셀을 로드한 후 Empty Sheet를 연다. 
ls_filename = ".\생산관리_소재신청.xlsx"
OleXLS.WorkBooks.Open(ls_filename) 

if OleXLS.Application.Sheets.Count < 2 then
	MessageBox("확인","생산관리_소재신청.xlsx 원본파일이 훼손 되었습니다.~n~n" + &
	           "자동 UPDATE 후 실행하시기 바랍니다.")
	RETURN
end if

OleXLS.Worksheets("절곡반").Select
OleXLS.Application.ScreenUpdating = False

ll_max = dw6.rowcount()
if ll_max > 20 then
	// 행 추가하기
	for iRow = 1 to ll_max - 20
		OleXLS.Worksheets("절곡반").Rows("25:25").Insert
		OleXLS.Worksheets("도장반").Rows("25:25").Insert
	next
else
	// 행 값 지우기
	for iRow = ll_max to 20
		for iCol = 1 to 17
			OleXLS.Worksheets("절곡반").Cells[iRow, iCol].Value = ""
			OleXLS.Worksheets("도장반").Cells[iRow, iCol].Value = ""
		next
	next
end if

iRow   = 6
for ll_row = 1 to dw6.rowcount()
	OleXLS.Worksheets("절곡반").Cells[iRow,  1].Value  = dw6.object.seq_no[ll_row]    // 순번
	OleXLS.Worksheets("절곡반").Cells[iRow,  2].Value  = dw6.object.b1_drawno[ll_row] // 도면번호
	OleXLS.Worksheets("절곡반").Cells[iRow,  3].Value  = dw6.object.b1_pgmno[ll_row]  // 프로그램
	OleXLS.Worksheets("절곡반").Cells[iRow,  4].Value  = dw6.object.b1_type[ll_row]   // TYPE
	OleXLS.Worksheets("절곡반").Cells[iRow,  5].Value  = dw6.object.b1_qa1[ll_row]    // 판넬규격/폭1
	OleXLS.Worksheets("절곡반").Cells[iRow,  6].Value  = dw6.object.b1_qa2[ll_row]    //         /폭2
	OleXLS.Worksheets("절곡반").Cells[iRow,  7].Value  = dw6.object.b1_qa3[ll_row]    //         /길이1
	OleXLS.Worksheets("절곡반").Cells[iRow,  8].Value  = dw6.object.b1_qa4[ll_row]    //         /길이2
	OleXLS.Worksheets("절곡반").Cells[iRow,  9].Value  = dw6.object.qty[ll_row]       // 수량
	OleXLS.Worksheets("절곡반").Cells[iRow, 10].Value  = dw6.object.b1_qa5[ll_row]    // 샤링규격/폭
	OleXLS.Worksheets("절곡반").Cells[iRow, 11].Value  = dw6.object.b1_qa6[ll_row]    //         /길이
	OleXLS.Worksheets("절곡반").Cells[iRow, 12].Value  = dw6.object.b1_qa7[ll_row]    // 신청규격/레퍼런스1
	OleXLS.Worksheets("절곡반").Cells[iRow, 13].Value  = dw6.object.b1_qa8[ll_row]    //         /레퍼런스2
	OleXLS.Worksheets("절곡반").Cells[iRow, 14].Value  = dw6.object.b1_cuts[ll_row]   // 칼수
	OleXLS.Worksheets("절곡반").Cells[iRow, 15].Value  = dw6.object.b1_rem[ll_row]    // 비고
	OleXLS.Worksheets("절곡반").Cells[iRow, 16].Value  = dw6.object.sale_no[ll_row]   // 수주번호
	OleXLS.Worksheets("절곡반").Cells[iRow, 17].Value  = dw6.object.seq[ll_row]       // 수주순번

	OleXLS.Worksheets("도장반").Cells[iRow,  1].Value  = dw6.object.seq_no[ll_row]      // 순번
	OleXLS.Worksheets("도장반").Cells[iRow,  2].Value  = dw6.object.b1_qa1[ll_row]      // 판넬규격/폭1
	OleXLS.Worksheets("도장반").Cells[iRow,  3].Value  = dw6.object.b1_qa2[ll_row]      //         /폭2
	OleXLS.Worksheets("도장반").Cells[iRow,  4].Value  = dw6.object.b1_qa3[ll_row]      //         /길이1
	OleXLS.Worksheets("도장반").Cells[iRow,  5].Value  = dw6.object.b1_qa4[ll_row]      //         /길이2
	OleXLS.Worksheets("도장반").Cells[iRow,  6].Value  = dw6.object.qty[ll_row]         // 수량
	OleXLS.Worksheets("도장반").Cells[iRow,  7].Value  = dw6.object.p1_qa1[ll_row]      // 도장(폭)
	OleXLS.Worksheets("도장반").Cells[iRow,  8].Value  = dw6.object.p1_qa2[ll_row]      // 도장(길이)
	OleXLS.Worksheets("도장반").Cells[iRow,  9].Value  = dw6.object.p1_face[ll_row]     // 도장(면)
	OleXLS.Worksheets("도장반").Cells[iRow, 10].Value  = dw6.object.p1_rem[ll_row]      // 도장(비고)
	OleXLS.Worksheets("도장반").Cells[iRow, 12].Value  = dw6.object.p1_refcolor[ll_row] // 대체색상
	OleXLS.Worksheets("도장반").Cells[iRow, 14].Value  = dw6.object.p1_keyno[ll_row]    // 도장(번호)
	OleXLS.Worksheets("도장반").Cells[iRow, 16].Value  = dw6.object.sale_no[ll_row]     // 수주번호
	OleXLS.Worksheets("도장반").Cells[iRow, 17].Value  = dw6.object.seq[ll_row]         // 수주순번
	
	iRow = iRow + 1
next

//		ls_scene_code = this.object.scene_code[1]
//		SELECT scene_desc INTO :ls_scene_name FROM scene WHERE scene_code = :ls_scene_code;
//idwc_wc, idwc_cust, idwc_scene

string  ls_custnm, ls_scenenm, ls_itemnm, ls_teamnm

dw5.getchild( "cust_no", idwc_cust )
ls_custnm = idwc_cust.getitemstring(idwc_cust.getrow(), "cust_name")

dw5.getchild( "scene_code", idwc_scene )
ls_scenenm = idwc_scene.getitemstring(idwc_scene.getrow(), "scene_desc")

dw5.getchild( "item_no", idwc_item )
ls_itemnm = idwc_item.getitemstring(idwc_item.getrow(), "item_nm")

SELECT TEAM_NAME INTO :ls_teamnm   FROM TEAM WHERE TEAM_CODE  = :gs_team;

OleXLS.Worksheets("절곡반").Cells[1,  9].Value  = dw5.object.subject[1]  // 제목
OleXLS.Worksheets("절곡반").Cells[2,  4].Value  = ls_custnm              // 거래처
OleXLS.Worksheets("절곡반").Cells[2,  9].Value  = ls_scenenm             // 현장명
OleXLS.Worksheets("절곡반").Cells[2, 16].Value  = ls_itemnm              // 신청소재
OleXLS.Worksheets("절곡반").Cells[3,  4].Value  = dw5.object.sos_no[1]   // 신청번호
OleXLS.Worksheets("절곡반").Cells[3,  9].Value  = ls_teamnm              // 작성부서
OleXLS.Worksheets("절곡반").Cells[3, 12].Value  = dw5.object.user_nm[1]  // 담당자
OleXLS.Worksheets("절곡반").Cells[3, 16].Value  = dw5.object.sysdate[1]  // 작성일자

OleXLS.Worksheets("도장반").Cells[1,  9].Value  = dw5.object.subject[1]  // 제목
OleXLS.Worksheets("도장반").Cells[2,  4].Value  = ls_custnm              // 거래처
OleXLS.Worksheets("도장반").Cells[2,  9].Value  = ls_scenenm             // 현장명
OleXLS.Worksheets("도장반").Cells[2, 16].Value  = ls_itemnm              // 신청소재
OleXLS.Worksheets("도장반").Cells[3,  4].Value  = dw5.object.sos_no[1]   // 신청번호
OleXLS.Worksheets("도장반").Cells[3,  9].Value  = ls_teamnm              // 작성부서
OleXLS.Worksheets("도장반").Cells[3, 12].Value  = dw5.object.user_nm[1]  // 담당자
OleXLS.Worksheets("도장반").Cells[3, 16].Value  = dw5.object.sysdate[1]  // 작성일자
OleXLS.Application.ScreenUpdating = true

//다른이름으로 저장 
ls_filename = "C:\생산관리_소재신청_" + string(now(), "yymmdd") + ".xlsx"
OleXLS.Application.Workbooks(1).SaveAs( ls_filename )

// Quits Excel
OleXLS.Application.Quit()

iRet = OleXLS.DisconnectObject()       
If iRet < 0 then
	MessageBox("ERROR","DisconnectObject Failed")
End If

Destroy OleXLS
MessageBox("확인", ls_filename + "~n~n 저장 하였습니다.")

end event

