table(column=(type=char(8) updatewhereclause=yes name=gubun dbname="gubun" )
 column=(type=datetime updatewhereclause=yes name=req_date dbname="req_date" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=long updatewhereclause=yes name=req_seq dbname="req_seq" )
 column=(type=char(10) updatewhereclause=yes name=accept_user_name dbname="issuereqdet.accept_user_name" )
 column=(type=char(8) updatewhereclause=yes name=confirm_name dbname="confirm_name" )
 column=(type=char(11) updatewhereclause=yes name=issue_schedule dbname="issue_schedule" )
 column=(type=char(8) updatewhereclause=yes name=ship_case dbname="ship_case" )
 retrieve="  SELECT '출고의뢰' gubun,
         req_date   = r.req_date
       , user_name  = l.user_name
       , req_seq    = r.req_seq
       , e.user_name accept_user_name
       , (case when isnull(a.confirm_flag, 'N') = 'N' then '미확정' else '확정' end ) confirm_name
       , issue_schedule = (case when r.issue_schedule = 'A' then '직출' 
                                when r.issue_schedule = 'B' then '생산후 직출'
                                when r.issue_schedule = 'J' then '저녁상차'
                                when r.issue_schedule = 'K' then '택배/정기'
                                when r.issue_schedule = 'D' then '방문'
                                when r.issue_schedule = 'I' then '야간도착'
                                when r.issue_schedule = 'E' then '외주(시화)'
                                when r.issue_schedule = 'F' then '외주(본사)'
                                when r.issue_schedule = 'G' then '유창강건'
                                when r.issue_schedule = 'H' then '지점이송'
                                when r.issue_schedule = 'C' then '자동작성'
                                else r.issue_schedule
                           end)
       , ship_case      = (case when r.ship_case = 'J' then '정기화물'
                                when r.ship_case = 'T' then '택배'
                                when r.ship_case = 'A' then '오토바이'
                                when r.ship_case = 'S' then '선박'
                                when r.ship_case = 'P' then '항공'
                                when r.ship_case = 'E' then '기타'
                                else r.ship_case
                           end)
    FROM issuereqdet R with(nolock) INNER JOIN issuereq A with(nolock) ON r.req_date = a.req_date and r.salesman = a.salesman and r.req_seq = a.req_seq
         LEFT OUTER JOIN login L with(nolock) ON r.salesman = l.user_id
         LEFT OUTER JOIN login e  with(nolock) on a.accept_user = e.user_id
   WHERE ( r.sale_no  = :as_orderno )
     AND ( r.req_flag = 'A' )
   union all           
   select  distinct '물품요청' gubun,
               b.ask_date req_date, 
               c.user_name user_name,               
               null req_seq, 
               d.user_name accept_user_name,
              (case when  b.proc_flag = 'Y' THEN '처리완료' 
                       when b.proc_flag = 'N' THEN '접수중' 
                       when b.proc_flag = 'P' THEN '부분'  END) confirm_name,      
              null issue_schedule,
              null ship_case
   from  ask_det a left outer join ask_head b with (nolock) ON a.ask_no  = b.ask_no
                               left outer join login c with (nolock) ON b.ask_user  = c.user_id
                               left outer join login d with (nolock) ON b.act_user  = d.user_id
   where a.sale_no = :as_orderno

  " arguments=(("as_orderno", string))  sort="gubun D req_date A " )
