event selectionchanged;// 품목, 수주품목, 출고품목, 일위대가, 물품요청, 견적서
choose case newindex
	case 2
		if tabpage_2.rb_sale.checked = true then
			tabpage_2.em_5.SelectText(9, 2)
			tabpage_2.em_5.setfocus()
