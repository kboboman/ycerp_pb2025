column(band=detail id=4 alignment="1" tabsequence=32766 border="0" color="33554432" x="2857" y="4" height="72" width="594" format="#,##0.00" html.valueishtml="0"  name=calc_qty visible="1" edit.limit=0 edit.case=any edit.focusrectangle=no edit.autoselect=yes edit.autohscroll=yes edit.imemode=0  font.face="굴림체" font.height="-11" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="0" background.color="536870912~tif ( getrow() = currentrow(), rgb(254, 252, 175), if ( item_name = ~"소계~",  rgb(198, 224, 180), if ( work_name = ~"총합계~", rgb(128, 128, 128), rgb(255, 255, 255) ) ) )" )
