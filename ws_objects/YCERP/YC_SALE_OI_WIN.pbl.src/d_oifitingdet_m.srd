 column=(type=char(10) updatewhereclause=yes name=get_fitting dbname="get_fitting" )
 retrieve="  SELECT chk  = 'N'
       , fitdet.fit_no           
       , fitdet.fit_seq          
       , fitdet.req_date         
       , fitdet.salesman         
       , f.user_name
       , fitdet.req_seq          
       , fitdet.req_flag         
       , fitdet.cust_no          
       , c.cust_name
       , fitdet.scene_code       
       , d.scene_desc       
       , fitdet.item_no        
       , e.item_name
       , qa   = fitdet.qa              
       , qa1  = fitdet.qa
       , fitdet.uom
       , order_qty   = fitdet.order_qty
       , rlse_qty    = fitdet.rlse_qty
       , ship_qty    = fitdet.ship_qty
       , fitdet.sale_no          
       , fitdet.seq_no              
       , fitdet.do_no          
       , fitdet.oi_no              
       , fitdet.issue_flag       
       , fitdet.issue_schedule   
       , fitdet.ship_flag        
       , fitdet.ship_case        
       , fitdet.tel              
       , fitdet.rem              
       , fitdet.sys_date  
       , get_fitting = space(10)
    FROM fitdet
         LEFT OUTER JOIN customer  c  ON fitdet.cust_no    = c.cust_no   
         LEFT OUTER JOIN scene     d  ON fitdet.scene_code = d.scene_code
         LEFT OUTER JOIN groupitem e  ON fitdet.item_no    = e.item_no
         LEFT OUTER JOIN login     f  ON fitdet.salesman   = f.user_id
   WHERE fit_no   = :as_fitno
" update="fitdet" updatewhere=0 updatekeyinplace=no arguments=(("as_fitno", string))  sort="fit_seq A " )
