table(column=(type=char(10) updatewhereclause=yes name=user_id dbname="user_id" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(30) updatewhereclause=yes name=loc_name dbname="loc_name" )
 column=(type=char(10) updatewhereclause=yes name=area_no dbname="area_no" )
 column=(type=char(20) updatewhereclause=yes name=area_area_name dbname="area_name" )
 retrieve="  SELECT DISTINCT user_id = login.user_id
       , user_name = login.user_name
       , loc_name  = location.loc_name
       , area_no   = area.area_no
       , area_name = area.area_name  
    FROM location
       , login
       , area  
   WHERE ( location.loc_manager = login.user_id )    
     AND ( location.area_no     = area.area_no  )    
"  sort="user_name A " )
