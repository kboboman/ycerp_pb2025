 column=(type=char(255) updatewhereclause=yes name=custinfo_rem5 dbname="custinfo.rem5" )
 retrieve="SELECT a.cust_no   
		,a.cust_name   
		,a.register_no   
		,a.captain_name   
		,a.resident_card   
		,a.addr   
      ,cap_birthday = datediff(year,a.cap_birthday, getdate())
		,a.business   
		,a.bus_cord   
		,a.bus_rep  
		,a.bus_addr   
		,a.bus_tel   
		,a.tel_no   
		,a.fax_no   
		,a.industry_type   
		,a.industry_code   
		,a.cust_type   
		,a.shipto_addr   
		,a.terms   
		,a.price_level   
		,a.credit_level   
		,a.credit_limit   
		,a.curr_code   
		,a.balance_amt   
		,a.bill_amount   
		,a.start_date   
		,a.buyer1   
		,a.buyer2   
		,a.pre_salesman   
		,a.salesman   
		,a.last_tn_date   
		,a.open_close  
		,a.level_grade   
		,a.cust_flag   
		,a.round   
		,a.buyer1_hp   
		,a.credit_day   
		,a.addr1   
		,a.addr2   
		,a.addr3   
		,a.bus_addr1   
		,a.bus_addr2   
		,a.bus_addr3   
		,a.shipto_addr1   
		,a.shipto_addr2   
		,a.shipto_addr3   
		,a.sale_control   
		,a.uid   
		,a.pw   
		,a.use_flag   
		,a.force_update   
		,a.vat_email   
		,a.vat_user   
		,a.vat_phone   
		,a.collect_ymd   
		,a.icube_no   
		,a.contract_day   
		,a.contract_yn   
		,a.joint_head   
		,a.jointor   
		,a.joint_amt   
		,a.dambo_rem   
		,a.dambo_ymd   
		,a.dambo_amt   
		,a.dambo_bigo   
		,a.scene_phone

		,b.main_co
		,b.license_name
		,b.rem5
FROM customer a, custinfo b
WHERE a.cust_no = b.cust_no AND
		a.cust_no = :as_cust_no
" arguments=(("as_cust_no", string)) )
