 column=(type=char(50) update=yes updatewhereclause=yes name=fspot_desc dbname="DoTrans.fspot_desc" )
 retrieve="  SELECT dotrans.trans_no
       , dotrans.trans_amt
       , dotrans.bigo
       , dotrans.fcust_no
       , dotrans.fspot_code
       , dotrans.fregister_no
       , dotrans.flevel_grade
       , dotrans.fcaptain_name
       , dotrans.funpaid_amt
       , fcollect_day = cast(dotrans.fcollect_day as varchar(25))
       , dotrans.tcust_no
       , dotrans.tspot_code
       , dotrans.tregister_no
       , dotrans.tlevel_grade
       , dotrans.tcaptain_name
       , dotrans.tunpaid_amt
       , tcollect_day = cast(dotrans.tcollect_day as varchar(25))
		 , dotrans.fspot_desc
    FROM dotrans
   WHERE dotrans.trans_no = :as_trans_no

" update="dotrans" updatewhere=0 updatekeyinplace=no arguments=(("as_trans_no", string)) )
