table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="basis_head.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="basis_head.qa" initial="0000X0000" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="basis_head.uom" )
 column=(type=datetime update=yes updatewhereclause=yes name=make_date dbname="basis_head.make_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=make_user dbname="basis_head.make_user" )
 column=(type=char(40) update=yes updatewhereclause=yes name=rem dbname="basis_head.rem" )
 column=(type=char(40) update=yes updatewhereclause=yes name=rem2 dbname="basis_head.rem2" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=amount dbname="basis_head.amount" initial="0" )
 column=(type=char(30) update=yes updatewhereclause=yes name=item_name dbname="basis_head.item_name" )
 column=(type=char(4) updatewhereclause=yes name=l1 dbname="l1" initial="0000" )
 column=(type=char(4) updatewhereclause=yes name=l2 dbname="l2" initial="0000" )
 column=(type=char(1) update=yes updatewhereclause=yes name=use_flag dbname="basis_head.use_flag" initial="N" values="사용	Y/불가	N/" )
 retrieve="  SELECT basis_head.item_no,   
         basis_head.qa,   
         basis_head.uom,   
         basis_head.make_date,   
         basis_head.make_user,   
         basis_head.rem,   
         basis_head.rem2,   
         basis_head.amount,   
         basis_head.item_name,   
         '    'l1,   
         '    'l2,   
         basis_head.use_flag  
    FROM basis_head  
   WHERE basis_head.item_no = :aa    
" update="basis_head" updatewhere=1 updatekeyinplace=no arguments=(("aa", string)) )
