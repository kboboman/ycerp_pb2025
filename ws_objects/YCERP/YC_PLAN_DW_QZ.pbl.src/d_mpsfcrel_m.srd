 column=(type=char(10) updatewhereclause=yes name=color_color_name dbname="color.color_name" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(10) updatewhereclause=yes name=wc_work_manager dbname="wc.work_manager" )
 column=(type=decimal(2) updatewhereclause=yes name=rlse_qty dbname="rlse_qty" )
 column=(type=char(1) updatewhereclause=yes name=utong_yn dbname="utong_yn" )
 column=(type=char(1) update=yes updatewhereclause=yes name=pop_status dbname="pop_status" values="pop반영전	1/pop반영완료	2/pop반송	3/" )
 column=(type=char(1) updatewhereclause=yes name=pop_status_protect dbname="mpsdet.pop_status_protect" )
 column=(type=char(10) update=yes updatewhereclause=yes name=paint_item dbname="mpsdet.paint_item" )
 column=(type=char(20) update=yes updatewhereclause=yes name=paint_qa dbname="mpsdet.paint_qa" )
 column=(type=char(50) update=yes updatewhereclause=yes name=paint_name dbname="mpsdet.paint_name" )
 column=(type=char(50) update=yes updatewhereclause=yes name=paint_company dbname="mpsdet.paint_company" )
 column=(type=char(4) update=yes updatewhereclause=yes name=cmplt_dt dbname="mpsdet.cmplt_dt" )
 column=(type=char(40) update=yes updatewhereclause=yes name=etc01 dbname="mpsdet.etc01" values="코일투입	코일투입/코일색상교체	코일색상교체/오일투입및 청소(칼라)	오일투입및 청소(칼라)/오일투입및 청소(무도장)	오일투입및 청소(무도장)/금형교체	금형교체/타공(펀칭) 	타공(펀칭) /" )
 column=(type=char(40) update=yes updatewhereclause=yes name=etc02 dbname="mpsdet.etc02" values="30초	30초/5분	5분/15분	15분/20분	20분/30분	30분/" )
 retrieve="SELECT 
	  mpsdet.plan_no   
	, mpsdet.order_no   
	, mpsdet.wc_no   
	, mpsdet.sale_no   
	, mpsdet.seq_no   
	, mpsdet.item_no   
	, mpsdet.qa   
	, mpsdet.due_date   
	, mpsdet.uom   
	, mpsdet.order_qty   
	, mpsdet.priority   
	, mpsdet.suju_type   
	, mpsdet.rcpt_type   
	, mpsdet.rcpt_qty   
	, mpsdet.napgi_date   
	, mpsdet.cust_no   
	, mpsdet.scene_code   
	, mpsdet.item_color   
	, mpsdet.mpsorder_order   
	, mpsdet.order_seq   
	, mpsdet.rem  
	, mpsorder.order_date
	, wc.work_name
	, customer.cust_name   
	, scene.scene_desc   
	, color.color_name   
	, groupitem.item_name   
	, wc.work_manager
	, rlse_qty   = (saledet.order_qty - saledet.rlse_qty)
	, isnull(scene.utong_yn, 'N') utong_yn
	, pop_status		/* 2019.05.02 jowonsuk pop_status 체크  */
	, pop_status pop_status_protect
	, mpsdet.paint_item
	, mpsdet.paint_qa
	, mpsdet.paint_name
	, mpsdet.paint_company
	, mpsdet.cmplt_dt		cmplt_dt
	, mpsdet.etc01			etc01
	, mpsdet.etc02			etc02
FROM 
	mpsdet with(nolock)  
         LEFT OUTER JOIN mpsorder with(nolock)  ON mpsorder.order_no = mpsdet.mpsorder_order
         LEFT OUTER JOIN wc   with(nolock)     ON mpsdet.wc_no      = wc.work_no
         LEFT OUTER JOIN customer with(nolock)  ON mpsdet.cust_no    = customer.cust_no
         LEFT OUTER JOIN scene with(nolock)    ON mpsdet.scene_code = scene.scene_code
         LEFT OUTER JOIN color with(nolock)     ON mpsdet.item_color = color.color_code
         LEFT OUTER JOIN groupitem with(nolock) ON mpsdet.item_no    = groupitem.item_no
         LEFT OUTER JOIN saledet with(nolock)  ON mpsdet.sale_no = saledet.order_no AND mpsdet.seq_no = saledet.seq_no
WHERE ( mpsorder.order_no = :as_order )    
" update="mpsdet" updatewhere=0 updatekeyinplace=no arguments=(("as_order", string))  sort="order_seq A plan_no A priority A " )
