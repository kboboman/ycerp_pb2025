$PBExportHeader$d_cdscene_m.srd
$PBExportComments$현장코드관리(1998/03/14, 정재수)
release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=228 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=236 color="536870912" )
table(column=(type=char(4) update=yes updatewhereclause=yes name=cust_no dbname="scene.cust_no" )
 column=(type=char(11) update=yes updatewhereclause=yes key=yes name=scene_code dbname="scene.scene_code" )
 column=(type=char(40) update=yes updatewhereclause=yes name=scene_desc dbname="scene.scene_desc" )
 column=(type=char(10) update=yes updatewhereclause=yes name=scene_charge dbname="scene.scene_charge" )
 column=(type=char(10) update=yes updatewhereclause=yes name=area_nm dbname="scene.area_nm" )
 column=(type=char(20) update=yes updatewhereclause=yes name=project_nm dbname="scene.project_nm" )
 column=(type=char(3) update=yes updatewhereclause=yes name=gubun dbname="scene.gubun" )
 column=(type=char(20) update=yes updatewhereclause=yes name=owner dbname="scene.owner" )
 column=(type=datetime update=yes updatewhereclause=yes name=start_date dbname="scene.start_date" )
 column=(type=datetime update=yes updatewhereclause=yes name=end_date dbname="scene.end_date" )
 column=(type=char(15) update=yes updatewhereclause=yes name=scene_tel dbname="scene.scene_tel" )
 column=(type=char(15) update=yes updatewhereclause=yes name=scene_telcap dbname="scene.scene_telcap" )
 column=(type=char(40) update=yes updatewhereclause=yes name=scene_scale dbname="scene.scene_scale" )
 column=(type=char(80) update=yes updatewhereclause=yes name=scene_addr dbname="scene.scene_addr" )
 column=(type=char(80) update=yes updatewhereclause=yes name=rem dbname="scene.rem" )
 column=(type=char(10) update=yes updatewhereclause=yes name=input_date dbname="input_date" )
 column=(type=datetime update=yes updatewhereclause=yes name=gen_date dbname="scene.gen_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=user_id dbname="scene.user_id" )
 column=(type=char(1) update=yes updatewhereclause=yes name=utong_yn dbname="scene.utong_yn" values="유통업체	Y/유통업체외	N/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=approval_yn dbname="approval_yn" initial="N" values="	Y/	N" )
 retrieve="SELECT 
	  scene.cust_no   
	, scene.scene_code   
	, scene.scene_desc   
	, scene.scene_charge   
	, scene.area_nm   
	, scene.project_nm   
	, scene.gubun
	, scene.owner   
	, scene.start_date   
	, scene.end_date   
	, scene.scene_tel   
	, scene.scene_telcap
	, scene.scene_scale   
	, scene.scene_addr   
	, scene.rem
	, input_date  = convert(char(10), scene.input_date, 111)
	, scene.gen_date
	, scene.user_id
	, scene.utong_yn
	, isnull(scene.approval_yn,'Y') approval_yn
FROM 
	scene  
WHERE 
	scene.cust_no = :as_custno
ORDER BY 
	SUBSTRING(SCENE.SCENE_CODE, 6,4), SUBSTRING(SCENE.SCENE_CODE, 10,1), SUBSTRING(SCENE.SCENE_CODE, 11,1), SUBSTRING(SCENE.SCENE_CODE, 12,1), SUBSTRING(SCENE.SCENE_CODE, 13,1)" update="scene" updatewhere=0 updatekeyinplace=no arguments=(("as_custno", string))  sort="gen_date A scene_code A " )
