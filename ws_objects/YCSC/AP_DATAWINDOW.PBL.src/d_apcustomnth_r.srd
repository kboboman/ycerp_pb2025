 column=(type=long updatewhereclause=yes name=appeom_oi_no dbname="appeom.oi_no" )
 retrieve="PBSELECT( VERSION(400) DISTINCT ()TABLE(NAME=~"appeom~" )  TABLE(NAME=~"inspdet~" ) COMPUTE(NAME=~"'xxxxxxxxxxxxxxxx' eom_date~") COLUMN(NAME=~"appeom.supp_name~") COLUMN(NAME=~"appeom.apoi_date~") COLUMN(NAME=~"appeom.inspap_no~") COLUMN(NAME=~"appeom.insp_flag~") COLUMN(NAME=~"appeom.item_name~") COLUMN(NAME=~"appeom.qa~") COLUMN(NAME=~"appeom.uom~") COLUMN(NAME=~"appeom.insp_qty~") COLUMN(NAME=~"appeom.price~") COLUMN(NAME=~"appeom.amount~") COLUMN(NAME=~"appeom.vat~") COLUMN(NAME=~"appeom.tot_amount~") COLUMN(NAME=~"appeom.vc_amount~") COLUMN(NAME=~"appeom.seq_no~") COLUMN(NAME=~"appeom.supp_no~") COLUMN(NAME=~"appeom.bal_amount~") COLUMN(NAME=~"inspdet.rem~") COLUMN(NAME=~"inspdet.rcpt_qty~") COLUMN(NAME=~"appeom.oi_no~")    JOIN (LEFT=~"appeom.qa~"    OP =~"=~"RIGHT=~"inspdet.qa~"    OUTER1 =~"appeom.qa~" )    JOIN (LEFT=~"appeom.inspap_no~"    OP =~"=~"RIGHT=~"inspdet.insp_no~"    OUTER1 =~"appeom.inspap_no~" )    JOIN (LEFT=~"appeom.oi_no~"    OP =~"=~"RIGHT=~"inspdet.oi_no~"    OUTER1 =~"appeom.oi_no~" )) "  sort="supp_name A apoi_date A inspap_no A appeom_oi_no A insp_flag A " )
