$PBExportHeader$d_ocaroivcrep_r2_imsi.srd
$PBExportComments$수금현황 REPORT1(1998/05/12, 정재수)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=508 color="536870912" )
summary(height=80 color="536870912" )
footer(height=0 color="536870912" )
detail(height=68 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=aroivc_oi_date dbname="aroivc.oi_date" )
 column=(type=char(12) updatewhereclause=yes name=aroivc_vc_no dbname="aroivc.vc_no" )
 column=(type=char(1) updatewhereclause=yes name=aroivc_vc_type dbname="aroivc.vc_type" values="지불	P/수금	R/" )
 column=(type=char(1) updatewhereclause=yes name=aroivc_rcpt_type dbname="aroivc.rcpt_type" values="현금	C/어음	B/예금	A/D//C	D/상계	S/잡이익	E/하자보수비	F/기타	Z/" )
 column=(type=char(10) updatewhereclause=yes name=money_curr_name dbname="money.curr_name" )
 column=(type=decimal(4) updatewhereclause=yes name=aroivc_amount dbname="aroivc.amount" )
 column=(type=char(12) updatewhereclause=yes name=aroivc_cheque_no dbname="aroivc.cheque_no" )
 column=(type=datetime updatewhereclause=yes name=aroivc_cheque_end dbname="aroivc.cheque_end" )
 column=(type=char(20) updatewhereclause=yes name=bank_bank_name dbname="bank.bank_name" )
 column=(type=char(20) updatewhereclause=yes name=aroivc_branch dbname="aroivc.branch" )
 column=(type=char(20) updatewhereclause=yes name=aroivc_large dbname="aroivc.large" )
 column=(type=char(50) updatewhereclause=yes name=aroivc_rem dbname="aroivc.rem" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(10) updatewhereclause=yes name=c_start dbname="c_start" )
 column=(type=char(10) updatewhereclause=yes name=c_end dbname="c_end" )
 column=(type=char(4) updatewhereclause=yes name=aroivc_cust_no dbname="aroivc.cust_no" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name_a dbname="login_user_name_a" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name_b dbname="login_user_name_b" )
 retrieve="  SELECT aroivc.oi_date,   
         aroivc.vc_no,   
         aroivc.vc_type,   
         aroivc.rcpt_type,   
         money.curr_name,   
         aroivc.amount,   
         aroivc.cheque_no,   
         aroivc.cheque_end,   
         bank.bank_name,   
         aroivc.branch,   
         aroivc.large,   
         aroivc.rem,   
         customer.cust_name,   
         '          ' c_start,   
         '          ' c_end,   
         aroivc.cust_no ,   
         login_user_name_a = login_a.user_name,   
         login_user_name_b = login_b.user_name    
    FROM aroivc WITH(nolock) LEFT OUTER JOIN bank ON aroivc.bank_code = bank.bank_code
         			      INNER JOIN money on aroivc.curr_code = money.curr_type
					 INNER JOIN CUSTOMER ON aroivc.cust_no = customer.cust_no
         				 LEFT OUTER JOIN login login_a ON customer.salesman = login_a.user_id   
         				 LEFT OUTER JOIN login login_b ON customer.pre_salesman = login_b.user_id 
   WHERE
         ( ( aroivc.cust_no = :as_cust_no ) AND  
         ( aroivc.oi_date between :ad_start and :ad_end  ) AND  
         ( aroivc.delete_key = 'N' ) )    

/*
    FROM aroivc,   
         bank,   
         money,   
         customer,   
         login login_a,   
         login login_b  
   WHERE ( customer.salesman *= login_a.user_id) and  
         ( customer.pre_salesman *= login_b.user_id) and  
         ( aroivc.bank_code *= bank.bank_code) and  
         ( aroivc.curr_code = money.curr_type ) and  
         ( aroivc.cust_no = customer.cust_no ) and  
         ( ( aroivc.cust_no = :as_cust_no ) AND  
         ( aroivc.oi_date between :ad_start and :ad_end  ) AND  
         ( aroivc.delete_key = ~"N~" ) )    
*/
" arguments=(("as_cust_no", string),("ad_start", date),("ad_end", date))  sort="aroivc_oi_date D aroivc_vc_no A customer_cust_name A " )
