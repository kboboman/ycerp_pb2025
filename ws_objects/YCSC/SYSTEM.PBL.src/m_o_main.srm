event clicked;//IF NOT IsValid( w_youchang2 ) THEN
//	Open( w_youchang2 )
//END IF

if upper(gs_userid) = "TOP" then
	if Not IsValid( w_youchang2 ) then
		Open( w_youchang2 )
	else
		w_youchang2.show()
	end if
end if

close(parentwindow)
end event

