table(column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=datetime updatewhereclause=yes name=order_date dbname="order_date" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=decimal(2) updatewhereclause=yes name=order_qty dbname="order_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=acc_qty dbname="acc_qty" )
 column=(type=decimal(8) updatewhereclause=yes name=amt dbname="amt" )
 column=(type=char(14) updatewhereclause=yes name=order_no dbname="order_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="seq_no" )
 retrieve="  SELECT distinct user_name = m.user_name/*user_name     = l.user_name*/
       , cust_no       = m.cust_no   
       , cust_name     = c.cust_name   
       , scene_desc    = sc.scene_desc   
       , order_date    = s.do_date   
       , item_name     = g.item_name
       , qa            = sd.qa
       , uom           = sd.uom
       , order_qty     = sd.ship_qty
       , acc_qty       = dbo.UF_GetQTY(sd.item_no, sd.qa, sd.uom, sd.ship_qty)
       , amt           = dbo.UF_GetQTY(sd.item_no, sd.qa, sd.uom, sd.ship_qty) * sd.price 
       , order_no      = sd.do_no
       , seq_no        = sd.oi_no 
    FROM UF_MyCustomers( '%' ) M
         LEFT OUTER JOIN customer   C ON m.cust_no     = c.cust_no
         LEFT OUTER JOIN do         S ON m.cust_no     = s.cust_no
         LEFT OUTER JOIN dodet     SD ON s.do_no       = sd.do_no 
         LEFT OUTER JOIN groupitem  G ON sd.item_no    = g.item_no
         LEFT OUTER JOIN scene     SC ON s.spot_code   = sc.scene_code
         LEFT OUTER JOIN login      L ON c.salesman    = l.user_id
   WHERE ((:as_custno  = '%'   ) OR 
          (:as_custno  = 'ALL' AND m.cust_no   LIKE '%'  ) OR 
          (:as_custno <> 'ALL' AND m.cust_no      = :as_custno )
         )
     AND ( s.spot_code  = :as_scene  )
     AND ( s.do_date    = :adt_date  ) 
" arguments=(("as_custno", string),("as_scene", string),("adt_date", datetime))  sort="order_no A seq_no A " )
