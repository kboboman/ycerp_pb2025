event pb_compute::clicked;dwItemStatus l_status

dw_1.accepttext()
if dw_1.rowcount() < 1 then return

l_status = dw_1.GetItemStatus(1,0, Primary!)
if l_status = new! or l_status = newModified! or &		
	 dw_1.object.order_no[1] = '' or isnull(dw_1.object.order_no[1]) then
	MessageBox("경고", "발주서를 저장한 후에 확정을 하십시요.", Exclamation!)
	return
end if
if trim(dw_1.object.po_print[1]) = 'Y' then
	MessageBox("경고", "[pb_compute][dw_1] 벌써, 확정되었습니다.", Exclamation!)
	return
end if

dw_1.object.po_print[1] = 'Y'

if wf_update1(dw_1,"Y") = false then
	dw_1.object.po_print[1] = 'N'
end if

end event

