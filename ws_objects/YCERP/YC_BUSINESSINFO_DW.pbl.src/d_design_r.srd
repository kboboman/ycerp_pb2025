$PBExportHeader$d_design_r.srd
$PBExportComments$설계사 리스트
release 8;
datawindow(units=0 timer_interval=0 color=134217750 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=80 color="553648127" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=code dbname="code" )
 column=(type=char(50) updatewhereclause=yes name=code_name dbname="code_name" )
 column=(type=char(10) updatewhereclause=yes name=salesman1 dbname="salesman1" )
 column=(type=char(10) updatewhereclause=yes name=salesman1_name dbname="salesman1_name" )
 column=(type=char(10) updatewhereclause=yes name=salesman2 dbname="salesman2" )
 column=(type=char(8) updatewhereclause=yes name=msale_construction_write_date dbname="write_date" )
 column=(type=char(10) updatewhereclause=yes name=msale_construction_write_user_id dbname="write_user_id" )
 column=(type=long updatewhereclause=yes name=yc_count dbname="yc_count" )
 retrieve="select  a.code,
           a.code_name, 
           a.salesman1, 
           b.user_name salesman1_name,
           a.salesman2, 
           a.write_date, 
           a.write_user_id,
           c.yc_count
from sale_bogo_code a left outer join V_PRESALE_ALL_USER b on a.salesman1  = b.user_id
							   left outer join (
													  select a.company_code, count(*) yc_count
													  from 
													  (
																			  select distinct company_code, name, tel
																			  from bogo_PERSONAL_CONNECTION with(nolock)
													  ) a group by a.company_code
												) c  on a.code = c.company_code
where a.gubun = :as_gubun
   and a.end_yn like :as_yn" arguments=(("as_yn", string),("as_gubun", string))  sort="code_name A " )
text(band=header alignment="2" text="순번" border="0" color="0" x="9" y="4" height="84" width="293" html.valueishtml="0"  name=t_1 visible="1"  font.face="굴림체" font.height="-11" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="15780518" )
