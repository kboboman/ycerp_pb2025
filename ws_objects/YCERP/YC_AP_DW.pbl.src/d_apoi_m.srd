 column=(type=decimal(4) update=yes updatewhereclause=yes name=apoiinv_rate dbname="apoiinv.apoiinv_rate" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=ship_cost dbname="apoiinv.ship_cost" initial="0" )
 column=(type=char(1) update=yes updatewhereclause=yes name=printed dbname="apoiinv.printed" initial="N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=open_close dbname="apoiinv.open_close" initial="O" )
