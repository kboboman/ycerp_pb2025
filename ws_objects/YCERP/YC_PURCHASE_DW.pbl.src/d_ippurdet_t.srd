table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=order_no dbname="purdet.order_no" initial=" " )
 column=(type=decimal(0) update=yes updatewhereclause=yes key=yes name=seq_no dbname="purdet.seq_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="purdet.item_no" initial=" " )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="purdet.qa" )
 column=(type=datetime updatewhereclause=yes name=due_date dbname="purdet.due_date" initial=" " )
 column=(type=decimal(4) updatewhereclause=yes name=order_qty dbname="purdet.order_qty" initial="0 " )
 column=(type=datetime updatewhereclause=yes name=rlse_date dbname="purdet.rlse_date" initial=" " )
 column=(type=decimal(4) updatewhereclause=yes name=price dbname="purdet.price" initial="0 " )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="purdet.uom" initial=" " )
 column=(type=decimal(4) updatewhereclause=yes name=rlse_qty dbname="purdet.rlse_qty" initial="0 " )
 column=(type=char(30) updatewhereclause=yes name=rem dbname="purdet.rem" initial=" " )
 column=(type=char(60) updatewhereclause=yes name=item_item_name dbname="item.item_name" )
 column=(type=char(20) updatewhereclause=yes name=rcpt_loc dbname="purdet.rcpt_loc" )
 column=(type=char(1) update=yes updatewhereclause=yes name=pur_type dbname="purdet.pur_type" )
 column=(type=char(17) updatewhereclause=yes name=product_no dbname="purdet.product_no" initial=" " )
 column=(type=char(1) updatewhereclause=yes name=pur_subcon dbname="pur.subcon" )
 column=(type=char(20) updatewhereclause=yes name=coil_no dbname="purdet.coil_no" )
 column=(type=char(14) updatewhereclause=yes name=purdet_sale_no dbname="purdet.sale_no" )
 column=(type=long updatewhereclause=yes name=purdet_sale_seq dbname="purdet.sale_seq" )
 retrieve="  SELECT purdet.order_no,   
         purdet.seq_no,   
         purdet.item_no,   
         purdet.qa,   
         purdet.due_date,   
         purdet.order_qty,   
         purdet.rlse_date,   
         purdet.price,   
         purdet.uom,   
         purdet.rlse_qty,   
         purdet.rem,   
         item.item_name,   
         purdet.rcpt_loc,   
         purdet.pur_type,   
         purdet.product_no,   
         pur.subcon,   
         purdet.coil_no,   
         purdet.sale_no,   
         purdet.sale_seq  
    FROM purdet,   
         item,   
         pur  
   WHERE ( purdet.item_no = item.item_no ) and  
         ( purdet.qa = item.qa ) and  
         ( purdet.order_no = pur.order_no ) and  
         ( ( purdet.order_no = :as_order ) )   
ORDER BY purdet.seq_no ASC   
" update="purdet" updatewhere=0 updatekeyinplace=no arguments=(("as_order", string)) )
