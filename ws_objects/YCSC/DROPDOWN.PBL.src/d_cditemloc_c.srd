release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=item_no dbname="itemloc.item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="groupitem.item_name" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="groupitem.uom" )
 retrieve="PBSELECT( VERSION(400) DISTINCT ()TABLE(NAME=~"groupitem~" )  TABLE(NAME=~"itemloc~" ) COLUMN(NAME=~"itemloc.item_no~") COLUMN(NAME=~"groupitem.item_name~") COLUMN(NAME=~"groupitem.uom~")    JOIN (LEFT=~"groupitem.item_no~"    OP =~"=~"RIGHT=~"itemloc.item_no~" )WHERE(    EXP1 =~"itemloc.loc_no~"   OP =~"=~"    EXP2 =~":as_loc~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"groupitem.use_flag~"   OP =~"<>~"    EXP2 =~"~~~"C~~~"~" ) ) ORDER(NAME=~"itemloc.item_no~" ASC=yes ) ARG(NAME = ~"as_loc~" TYPE = string) " arguments=(("as_loc", string)) )
column(band=detail id=1 alignment="0" tabsequence=32766 border="0" color="0" x="5" y="4" height="64" width="352" format="[general]"  name=item_no  tag="물품번호" edit.limit=10 edit.case=any edit.autoselect=yes edit.autohscroll=yes  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
column(band=detail id=2 alignment="0" tabsequence=32766 border="0" color="0" x="361" y="4" height="64" width="1952" format="[general]"  name=item_name  tag="품명" edit.limit=60 edit.case=any edit.autoselect=yes edit.autohscroll=yes  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
