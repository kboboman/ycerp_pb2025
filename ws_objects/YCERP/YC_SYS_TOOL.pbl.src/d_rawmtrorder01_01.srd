 column=(type=char(200) update=yes updatewhereclause=yes name=ordr_rsn dbname="rawmtrorder.ordr_rsn" )
 column=(type=char(10) update=yes updatewhereclause=yes name=approval_id dbname="rawmtrorder.approval_id" )
 column=(type=char(1) update=yes updatewhereclause=yes name=approval_status dbname="rawmtrorder.approval_status" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=acc_qty dbname="rawmtrorder.acc_qty" )
 column=(type=char(3) update=yes updatewhereclause=yes name=acc_uom dbname="rawmtrorder.acc_uom" )
 column=(type=char(8) update=yes updatewhereclause=yes name=order_dt dbname="rawmtrorder.order_dt" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=order_qty dbname="rawmtrorder.order_qty" )
 column=(type=char(3) update=yes updatewhereclause=yes name=order_uom dbname="rawmtrorder.order_uom" )
 column=(type=char(8) update=yes updatewhereclause=yes name=entry_dt dbname="rawmtrorder.entry_dt" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=used_qty dbname="rawmtrorder.used_qty" )
 column=(type=char(3) update=yes updatewhereclause=yes name=used_uom dbname="rawmtrorder.used_uom" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=invnt_qty dbname="rawmtrorder.invnt_qty" )
 column=(type=char(3) update=yes updatewhereclause=yes name=invnt_uom dbname="rawmtrorder.invnt_uom" )
 column=(type=char(200) update=yes updatewhereclause=yes name=rmrk dbname="rawmtrorder.rmrk" )
 retrieve="select
	 a.rqs_no				rqs_no              
	,a.input_dt				input_dt           
	,c.team_name			mngr_dept        
	,a.mngr_id				mngr_id            
	,a.prjct_name			prjct_name        
	,a.item_name			item_name        
	,a.rqr_qty				rqr_qty             
	,a.rqr_uom				rqr_uom            
	,a.rqst_dlvr_dt		rqst_dlvr_dt      
	,a.prchmngr_id			prchmngr_id      
	,a.ordr_rsn				ordr_rsn            
	,a.approval_id			approval_id       
	,a.approval_status	approval_status 
	,a.acc_qty				acc_qty             
	,a.acc_uom				acc_uom           
	,a.order_dt				order_dt           
	,a.order_qty			order_qty          
	,a.order_uom			order_uom        
	,a.entry_dt				entry_dt           
	,a.used_qty				used_qty          
	,a.used_uom				used_uom         
	,a.invnt_qty			invnt_qty          
	,a.invnt_uom			invnt_uom         
	,a.rmrk					rmrk                 
from
	rawmtrorder a inner join login b on a.mngr_id 	= b.user_id
                 inner join team  c on b.team_code = c.team_code
where
	a.input_dt between :as_fr_dt and :as_to_dt
and
	(a.mngr_id like :as_id or a.prchmngr_id like :as_id)
and 
	a.approval_status like :as_status
order by
	a.rqs_no desc" arguments=(("as_fr_dt", string),("as_to_dt", string),("as_id", string),("as_status", string)) )
