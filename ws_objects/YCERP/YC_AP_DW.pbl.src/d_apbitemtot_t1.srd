$PBExportComments$조업자재 집계표(거래처)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=152 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(3) updatewhereclause=yes name=supp_no dbname="supp_no" )
 column=(type=char(12) updatewhereclause=yes name=register_no dbname="register_no" )
 column=(type=char(30) updatewhereclause=yes name=supp_name dbname="supp_name" )
 column=(type=char(10) updatewhereclause=yes name=cstart dbname="cstart" )
 column=(type=char(10) updatewhereclause=yes name=cend dbname="cend" )
 column=(type=decimal(4) updatewhereclause=yes name=c_amt dbname="c_amt" )
 column=(type=decimal(5) updatewhereclause=yes name=c_rate dbname="c_rate" )
 column=(type=decimal(5) updatewhereclause=yes name=c_tot dbname="c_tot" )
 retrieve="  SELECT supp_no     = c.supp_no
       , register_no = c.register_no
       , supp_name   = c.supp_name
       , cstart      = (case when :as_start = ''  then '          ' else :as_start   end)
       , cend        = (case when :as_end   = ''  then '          ' else :as_end     end)
       , c_amt       = sum(a.amount)
       , c_rate      = sum(a.amount * 0.1)
       , c_tot       = sum(a.amount + (a.amount * 0.1) )
    FROM binitem A
         LEFT OUTER JOIN bitem B ON a.item_no = b.item_no 
         LEFT OUTER JOIN bsupp C ON a.supp_no = c.supp_no  
   WHERE ( convert(char(10),a.in_date,111)  BETWEEN :as_start AND :as_end )
     AND ( a.supp_no           LIKE :as_supp      )
   GROUP BY c.supp_no
          , c.register_no
          , c.supp_name
" arguments=(("as_start", string),("as_end", string),("as_supp", string))  sort="supp_name A " )
