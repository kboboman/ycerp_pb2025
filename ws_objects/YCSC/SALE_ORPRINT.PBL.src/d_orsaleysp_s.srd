table(column=(type=char(14) updatewhereclause=yes name=order_no dbname="sale.order_no" initial=" " )
 column=(type=datetime updatewhereclause=yes name=due_date dbname="sale.due_date" initial=" " )
 column=(type=datetime updatewhereclause=yes name=order_date dbname="sale.order_date" initial=" " )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"sale~" ) COLUMN(NAME=~"sale.order_no~") COLUMN(NAME=~"sale.due_date~") COLUMN(NAME=~"sale.order_date~")WHERE(    EXP1 =~"sale.order_date~"   OP =~"between~"    EXP2 =~":ad_sorder_date and :ad_eorder_date~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"sale.area_no~"   OP =~"=~"    EXP2 =~"'B0001'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"sale.confirm_flag~"   OP =~"=~"    EXP2 =~":as_flag~" ) ) ORDER(NAME=~"sale.order_date~" ASC=no) ARG(NAME = ~"ad_sorder_date~" TYPE = date)  ARG(NAME = ~"ad_eorder_date~" TYPE = date)  ARG(NAME = ~"as_flag~" TYPE = string) " arguments=(("ad_sorder_date", date),("ad_eorder_date", date),("as_flag", string))  sort="order_no D " )
