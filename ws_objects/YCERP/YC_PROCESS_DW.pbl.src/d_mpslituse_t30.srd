table(column=(type=char(60) updatewhereclause=yes name=item_name dbname="GroupItem.item_name" )
 column=(type=datetime updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=datetime updatewhereclause=yes name=edate dbname="edate" )
 column=(type=datetime updatewhereclause=yes name=do_date dbname="do.do_date" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="dodet.qa" )
 column=(type=char(20) updatewhereclause=yes name=coil_no dbname="dodet.coil_no" )
 column=(type=long updatewhereclause=yes name=cnt dbname="cnt" )
 column=(type=decimal(2) updatewhereclause=yes name=ship_qty dbname="ship_qty" )
 column=(type=char(14) updatewhereclause=yes name=do_no dbname="dodet.do_no" )
 column=(type=long updatewhereclause=yes name=oi_no dbname="dodet.oi_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=decimal(4) updatewhereclause=yes name=unit_qty dbname="dodet.unit_qty" )
 column=(type=char(2) updatewhereclause=yes name=etc_no dbname="dodet.etc_no" )
 column=(type=char(1) updatewhereclause=yes name=as_flag dbname="as_flag" )
 retrieve="  SELECT groupitem.item_name                              
       , sdate    = convert(smalldatetime, :ad_start, 111)   
       , edate    = convert(smalldatetime, :ad_end, 111)     
       , do.do_date                                       
       , dodet.qa                                         
       , dodet.coil_no                                    
       , cnt      = dodet.cnt
       , ship_qty = dodet.ship_qty
       , dodet.do_no
       , dodet.oi_no
       , customer.cust_name                            
       , coilsheet.unit_qty                                 
       , coilsheet.etc_no  
       , as_flag  = :as_flag
 FROM dodet    inner join groupitem on dodet.item_no = groupitem.item_no
                           inner join do on dodet.do_no           = do.do_no
                           inner join customer  on do.cust_no            = customer.cust_no                           
                           inner join (
									select     loc_no = coilmst.loc_no
													 , coil_no= coilmst.coil_no
													 , unit_qty = (case when coilmst.loc_no = 'WS00000000'
																					 then isnull( inspdet.unit_qty , coilmst.unit_qty ) 
																			  else coilmst.unit_qty 
																		end ) /* 스리팅 판매분의 단중은 시화저장소일 경우만 입고단중으로 표기 */
													 , etc_no   = coilmst.etc_no
													 , flag     = coilmst.flag  
									from coilmst with(nolock) inner join 
											  (
													SELECT unit_qty, coil_no
													FROM inspdet with(nolock)
													group by unit_qty, coil_no
													having count(insp_no) = 1
											  ) inspdet
									on coilmst.coil_no = inspdet.coil_no

                                              UNION
                                              SELECT loc_no, sheet_no, unit_qty, '',     flag  FROM sheetmst         
                                           ) coilsheet on dodet.coil_no = coilsheet.coil_no
                                                          AND dodet.loc_no = coilsheet.loc_no
   WHERE  ((:as_area    = '%'   AND do.area_no   LIKE '%' ) or 
                     (:as_area   <> '%'   AND do.area_no      = :as_area )
                    )
           AND ( ( do.do_date    BETWEEN :ad_start AND :ad_end ) AND  
                      ( coilsheet.flag      = :as_flag              ) AND  
                      ( dodet.coil_no  IS NOT NULL                  ) 
                    )    
/*
    FROM groupitem   
       , dodet       
       , do          
       , customer  
       , (
            SELECT loc_no = coilmst.loc_no
                 , coil_no= coilmst.coil_no
                 , unit_qty = (case when coilmst.loc_no = 'WS00000000'
                                         then isnull( (SELECT unit_qty FROM inspdet WHERE coil_no = coilmst.coil_no) , coilmst.unit_qty ) 
                                    else coilmst.unit_qty 
                               end ) /* 스리팅 판매분의 단중은 시화저장소일 경우만 입고단중으로 표기 */
                 , etc_no   = coilmst.etc_no
                 , flag     = coilmst.flag  
              FROM coilmst

            UNION
            SELECT loc_no, sheet_no, unit_qty, '',     flag  FROM sheetmst         
         ) coilsheet
   WHERE ( dodet.item_no        *= groupitem.item_no )   
     AND ( dodet.do_no           = do.do_no          )   
     AND ( dodet.coil_no         = coilsheet.coil_no )   
     AND ( dodet.loc_no          = coilsheet.loc_no  )   
     AND ( do.cust_no            = customer.cust_no  )   
     AND ((:as_area    = '%'   AND do.area_no   LIKE '%' ) or 
          (:as_area   <> '%'   AND do.area_no      = :as_area )
         )
     AND ( ( do.do_date    BETWEEN :ad_start AND :ad_end ) AND  
           ( coilsheet.flag      = :as_flag              ) AND  
           ( dodet.coil_no  IS NOT NULL                  ) 
         )    
*/" arguments=(("as_area", string),("ad_start", date),("ad_end", date),("as_flag", string))  sort="do_date A item_name A mid( qa, 5, 6 ) A qa A oi_no A " )
group(level=1 header.height=80 trailer.height=68 by=("do_date" ) header.color="15780518" trailer.color="67108864" )
