type cb_import from commandbutton within tabpage_7
integer x = 1984
integer y = 8
integer width = 503
integer height = 80
integer taborder = 260
integer textsize = -10
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "엑셀 가져오기"
end type

event clicked;// 엑셀파일 필드명 전체 가져오기
string  ls_chk, ls_cols, ls_colname, ls_field, ls_rows  // CHK
long    ll_seq_no        // 순번
string  ls_custno        // 거래처코드

string  ls_Sheet, ls_value
Integer iRet, li_int, li_Change
long    ll_row, ll_status, ll_max, ll_cnt, ll_xlsRows, ll_xlsCols
long    iCol, iRow, iCols, ll_id

Boolean SWExit

Pointer oldpointer // Declares a pointer variable
oldpointer = SetPointer(HourGlass!)

OleExcel = CREATE OLEObject

iRet = OleExcel.ConnectToObject("", "excel.application") 
if iRet <> 0 then DESTROY OleExcel 

OleExcel.Application.Visible = true

if IsValid(xlSheet) then DESTROY xlSheet
if ii_Sheet < 1 then return
xlSheet = OleExcel.Application.Sheets(ii_Sheet)

/////////////////////////////////////////////////////////////////////////
// 데이터 실행범위 설정
/////////////////////////////////////////////////////////////////////////
// ll_xlsRows = xlSheet.Application.WorksheetFunction.COUNTA(oRng,"")-2
// string oRng = "A:A"
/////////////////////////////////////////////////////////////////////////
iCol   = 1
SWExit = true
Do While SWExit
	ll_xlsCols = ll_xlsCols + 1

	iCol = iCol + 1
	if IsNull(xlSheet.Cells[1, iCol].Value) then SWExit = false
Loop		// 컬럼MAX
for iCol = 1 to ll_xlsCols
	for iRow = 1 to dw_26.rowcount()
		ls_cols = dw_26.object.cols[iRow]
		if string(xlSheet.Cells[1, iCol].Value) = ls_cols then
			dw_26.object.id[iRow] = iCol
		end if
	next
next		// xls 컬럼과 로우데이터 MATCH

SWExit = true
Do While SWExit
	ll_xlsRows = ll_xlsRows + 1

	iRow = iRow + 1
	if IsNull(xlSheet.Cells[iRow, 1].Value) then SWExit = false
Loop		// 로우MAX
if ll_xlsRows > 500 then
	MessageBox("확인","총 레코드 수: " + string(ll_xlsRows) + " 건~n~n한번 작업할 수 있는 레코드 처리건 수를 500개로 제한 합니다.")
	ll_xlsRows = 500
end if
/////////////////////////////////////////////////////////////////////////

// 엑셀가져오기
date    ldate_value
decimal ldec_value

iRow   = 2
ll_cnt = 0
dw_27.SetRedraw( false )
hpb_1.position = 0
hpb_1.visible  = true
xlsImport      = true
Do While xlsImport
	ll_cnt = ll_cnt + 1
   hpb_1.position = (ll_cnt / ll_xlsRows) * 100

   ls_custno  = trim(string(xlSheet.Cells[iRow,  1].Value))   // 거래처코드       
	if isnull(ls_custno) or ls_custno = "" or LenA(ls_custno) <> 4 then
	else
		ll_row = dw_27.insertrow(0)

		dw_27.object.chk[ll_row]       = "N"                                     // 선택                              
		dw_27.object.cust_no[ll_row]   = string(xlSheet.Cells[iRow,  1].Value)   // 코드                              
		dw_27.object.cust_name[ll_row] = string(xlSheet.Cells[iRow,  2].Value)   // 거래처                            
		for iCol = 1 to dw_26.rowcount()
			ll_id      = dw_26.object.id[iCol]
			ls_rows    = dw_26.object.cols[iCol]
			ls_field   = dw_26.object.field[iCol]
         ls_colname = dw_27.Describe(ls_field + "_t.Name")
			
			if isnull(ll_id) then
			else
				choose case ls_rows
					case "여신일자", "계약일", "담보일자", "채권관리", "대표자생년"
						ldate_value = Date(xlSheet.Cells[iRow, ll_id].Value)
						dw_27.SetItem(ll_row, ls_field, ldate_value)
						
					case "신용한도액", "보증금액", "담보금액"
						ldec_value  = long(xlSheet.Cells[iRow, ll_id].Value)
						dw_27.SetItem(ll_row, ls_field, ldec_value)
						
					case else
						ls_value    = string(xlSheet.Cells[iRow, ll_id].Value)
						dw_27.SetItem(ll_row, ls_field, ls_value)
				end choose
			end if
		next

		dw_27.ScrollToRow(ll_row)
	end if
	
	iRow = iRow + 1
	tab_1.tabpage_7.st_row.text = "Row: " + string(ll_cnt)

	if iRow > 501 then xlsImport = false
	if IsNull(xlSheet.Cells[iRow, 1].Value) then xlsImport = false
	// "가져오기 STOP"
Loop

cb_import.text    = "엑셀 가져오기"
cb_import.enabled = false
dw_27.SetRedraw( true )

ddlb_sheet.reset()
ddlb_sheet.enabled  = false
hpb_1.position = 0
hpb_1.visible  = true
//tab_1.tabpage_7.st_row.text = "Row: "

// Quits Excel
OleExcel.Application.Quit()

iRet = OleExcel.DisconnectObject()       
If iRet < 0 then
	MessageBox("ERROR","DisconnectObject Failed")
End If

Destroy xlSheet
Destroy OleExcel

SetPointer(oldpointer)
dw_26.enabled      = true
cb_excute.enabled  = true

end event

