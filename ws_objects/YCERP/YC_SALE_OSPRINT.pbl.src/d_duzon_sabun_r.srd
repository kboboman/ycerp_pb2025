table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=user_id dbname="login.user_id" )
 column=(type=char(10) update=yes updatewhereclause=yes name=user_name dbname="login.user_name" )
 column=(type=char(6) update=yes updatewhereclause=yes name=duzon_sabun dbname="login.duzon_sabun" )
 column=(type=char(10) update=yes updatewhereclause=yes name=duzon_dept dbname="login.duzon_dept" )
 retrieve="SELECT 
	user_id
 , user_name
 , duzon_sabun
 , duzon_dept
FROM login
WHERE team_code >= '70000'
AND ( user_name  = :as_username )


" update="login" updatewhere=1 updatekeyinplace=no arguments=(("as_username", string)) )
