text(band=header alignment="2" text="" border="6" color="0" x="3205" y="8" height="160" width="279" html.valueishtml="0"  name=t_43 visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="67108864" )
