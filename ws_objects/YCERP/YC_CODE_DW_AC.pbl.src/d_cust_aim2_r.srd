 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 retrieve="  SELECT login.user_name,
         cust_aim.cust_code,   
         cust_aim.tar_year,   
         cust_aim.inv_01,   
         cust_aim.inv_02,   
         cust_aim.inv_03,   
         cust_aim.inv_04,   
         cust_aim.inv_05,   
         cust_aim.inv_06,   
         cust_aim.inv_07,   
         cust_aim.inv_08,   
         cust_aim.inv_09,   
         cust_aim.inv_10,   
         cust_aim.inv_11,   
         cust_aim.inv_12,   
         cust_aim.coll_01,   
         cust_aim.coll_02,   
         cust_aim.coll_03,   
         cust_aim.coll_04,   
         cust_aim.coll_05,   
         cust_aim.coll_06,   
         cust_aim.coll_07,   
         cust_aim.coll_08,   
         cust_aim.coll_09,   
         cust_aim.coll_10,   
         cust_aim.coll_11,   
         cust_aim.coll_12,   
         opeom.inv_01,   
         opeom.inv_02,   
         opeom.inv_03,   
         opeom.inv_04,   
         opeom.inv_05,   
         opeom.inv_06,   
         opeom.inv_07,   
         opeom.inv_08,   
         opeom.inv_09,   
         opeom.inv_10,   
         opeom.inv_11,   
         opeom.inv_12,   
         opeom.coll_01,   
         opeom.coll_02,   
         opeom.coll_03,   
         opeom.coll_04,   
         opeom.coll_05,   
         opeom.coll_06,   
         opeom.coll_07,   
         opeom.coll_08,   
         opeom.coll_09,   
         opeom.coll_10,   
         opeom.coll_11,   
         opeom.coll_12,   
         opeom.balbf_amount,   
         cust_aim.mod_01,   
         cust_aim.mod_02,   
         cust_aim.mod_03,   
         cust_aim.mod_04,   
         cust_aim.mod_05,   
         cust_aim.mod_06,   
         cust_aim.mod_07,   
         cust_aim.mod_08,   
         cust_aim.mod_09,   
         cust_aim.mod_10,   
         cust_aim.mod_11,   
         cust_aim.mod_12,   
         cust_aim.del_01,   
         cust_aim.del_02,   
         cust_aim.del_03,   
         cust_aim.del_04,   
         cust_aim.del_05,   
         cust_aim.del_06,   
         cust_aim.del_07,   
         cust_aim.del_08,   
         cust_aim.del_09,   
         cust_aim.del_10,   
         cust_aim.del_11,   
         cust_aim.del_12,
	    customer.cust_name
FROM customer with(nolock) inner join cust_aim  with(nolock) on customer.cust_no = cust_aim.cust_code 
					   left outer join opeom with(nolock) on customer.cust_no = opeom.cust_no and datepart(year, opeom.eom_year) = :ad_date
					   inner join login with(nolock) on customer.salesman  = login.user_id
   WHERE (customer.salesman like :as_salesman) 
	    and datepart(year,cust_aim.tar_year) = :ad_date
ORDER BY login.user_name, customer.cust_name
/*
    FROM cust_aim,   
         opeom,
			customer,
         login
   WHERE (customer.cust_no       = cust_aim.cust_code) and  
			(customer.cust_no       = opeom.cust_no     ) and
			(cust_aim.cust_code     = opeom.cust_no     ) and
			(customer.salesman      = login.user_id     ) and
			(customer.salesman   like :as_salesman      ) and
			(datepart(year,cust_aim.tar_year) = :ad_date) AND  
			(datepart(year,cust_aim.tar_year) = datepart(year, opeom.eom_year))
			/* and(customer.open_close <> 'C' or  customer.open_close is  null) */    
   ORDER BY login.user_name, customer.cust_name
*/" arguments=(("as_salesman", string),("ad_date", number)) )
