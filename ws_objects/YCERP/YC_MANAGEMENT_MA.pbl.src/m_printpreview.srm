global type m_printpreview from menu
m_file m_file
m_display m_display
end type
global m_printpreview m_printpreview

on m_printpreview.create
m_printpreview=this
call super::create
this.m_file=create m_file
this.m_display=create m_display
this.Item[UpperBound(this.Item)+1]=this.m_file
this.Item[UpperBound(this.Item)+1]=this.m_display
end on

on m_printpreview.destroy
call super::destroy
destroy(this.m_file)
destroy(this.m_display)
end on

type m_file from menu within m_printpreview
m_toprint m_toprint
m_setupprint m_setupprint
m_tofile m_tofile
m_-1 m_-1
m_close m_close
end type

on m_file.create
call super::create
this.text = "화일"
this.m_toprint=create m_toprint
this.m_setupprint=create m_setupprint
this.m_tofile=create m_tofile
this.m_-1=create m_-1
this.m_close=create m_close
this.Item[UpperBound(this.Item)+1]=this.m_toprint
this.Item[UpperBound(this.Item)+1]=this.m_setupprint
this.Item[UpperBound(this.Item)+1]=this.m_tofile
this.Item[UpperBound(this.Item)+1]=this.m_-1
this.Item[UpperBound(this.Item)+1]=this.m_close
end on

on m_file.destroy
call super::destroy
destroy(this.m_toprint)
destroy(this.m_setupprint)
destroy(this.m_tofile)
destroy(this.m_-1)
destroy(this.m_close)
end on

type m_toprint from menu within m_file
end type

on m_toprint.create
call super::create
this.text = "프린트출력"
this.toolbaritemname = "Print!"
this.toolbaritemtext = "프린트출력"
this.toolbaritemorder = 1
end on

event clicked;////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// Print the active report
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

window	lw_frame, lw_sheet

lw_frame = ParentWindow.ParentWindow()
if IsValid (lw_frame) then
	lw_sheet = lw_frame.GetActiveSheet()	
	if IsValid (lw_sheet) then
		lw_sheet.TriggerEvent ("ue_print")
	end if
end if
end event

on m_toprint.destroy
call super::destroy
end on

type m_setupprint from menu within m_file
end type

on m_setupprint.create
call super::create
this.text = "프린트셋업"
this.toolbaritemname = "RunReport5!"
this.toolbaritemtext = "프린트셋업"
this.toolbaritemorder = 1
end on

event clicked;////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// Print setup
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

window	lw_frame, lw_sheet

lw_frame = ParentWindow.ParentWindow()
if IsValid (lw_frame) then
	lw_sheet = lw_frame.GetActiveSheet()	
	if IsValid (lw_sheet) then
		lw_sheet.TriggerEvent ("ue_print_setup")
		lw_sheet.TriggerEvent ("ue_ruler")
	end if
end if
//lw_sheet.object.datawindow.print.preview = true
end event

on m_setupprint.destroy
call super::destroy
end on

