$PBExportHeader$d_mpslitsfc_r.srd
$PBExportComments$스리팅입고내역(전체)(2001/05/08,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=400 color="536870912" )
summary(height=84 color="536870912" )
footer(height=0 color="536870912" )
detail(height=68 color="536870912" )
table(column=(type=char(1) updatewhereclause=yes name=flag dbname="flag" values="사	I/외	O/" )
 column=(type=datetime updatewhereclause=yes name=in_date dbname="in_date" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(20) updatewhereclause=yes name=coilsfcday_qa dbname="qa" )
 column=(type=decimal(4) updatewhereclause=yes name=coilsfcday_unit_qty dbname="unit_qty" )
 column=(type=long updatewhereclause=yes name=coilsfcday_cnt dbname="cnt" )
 column=(type=datetime updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=datetime updatewhereclause=yes name=edate dbname="edate" )
 column=(type=char(20) updatewhereclause=yes name=lot_no dbname="lot_no" )
 column=(type=char(30) updatewhereclause=yes name=des dbname="des" )
 retrieve="  SELECT flag = 'I',
			in_date = coilsfcday.sfc_date,   
         groupitem.item_name,   
         qa = coilsfcday.qa,   
         unit_qty = coilsfcday.unit_qty,   
         cnt = coilsfcday.cnt,   
         sdate = convert(smalldatetime, :ad_start, 111),   
         edate = convert(smalldatetime, :ad_end, 111),   
         lot_no = coilsfcday.coil_no,   
         des = location.loc_name  
    FROM   
         coilsfcday inner join groupitem on  coilsfcday.item_no = groupitem.item_no 
                          left outer join location on coilsfcday.loc_no = location.loc_no
   WHERE ( coilsfcday.sfc_date between :ad_start and :ad_end )
union all
  SELECT DISTINCT flag = 'O',
			insp.insp_date,   
         groupitem.item_name,   
         inspdet.qa,   
         inspdet.unit_qty,   
         inspdet.cnt,   
         sdate = convert(smalldatetime, :ad_start, 111),   
         edate = convert(smalldatetime, :ad_end, 111),   
         inspdet.coil_no,   
         supp.supp_name 
    FROM insp inner join inspdet on  insp.insp_no = inspdet.insp_no
                        inner join supp on  insp.supp_no = supp.supp_no
                        inner join coilmst on inspdet.coil_no = coilmst.coil_no and  inspdet.item_no = coilmst.item_no
                        inner join groupitem on inspdet.item_no = groupitem.item_no
        			          inner join pur on inspdet.pur_no = pur.order_no
   WHERE ( insp.insp_date between :ad_start and :ad_end  ) AND  
                   ( pur.subcon = 'N' ) AND     
                   ( coilmst.flag = 'S' )   
union all
  SELECT flag = 'O',
			in_date = insp.insp_date,   
         groupitem.item_name,   
         qa = inspdet.qa,   
         unit_qty = inspdet.unit_qty,   
         cnt = inspdet.cnt,   
         sdate = convert(smalldatetime, :ad_start, 111),   
         edate = convert(smalldatetime, :ad_end, 111),   
         lot_no = inspdet.coil_no,   
         des = supp.supp_name 
    FROM 
         insp inner join inspdet on insp.insp_no = inspdet.insp_no
                 inner join groupitem on inspdet.item_no = groupitem.item_no
                 inner join supp on insp.supp_no = supp.supp_no
                 inner join pur on inspdet.pur_no = pur.order_no
   WHERE ( ( insp.insp_date between :ad_start and :ad_end ) AND  
                  ( pur.subcon = 'C' ) )    " arguments=(("ad_start", date),("ad_end", date))  sort="in_date A groupitem_item_name A mid(coilsfcday_qa, 5,6) A coilsfcday_qa A coilsfcday_unit_qty A " )
group(level=1 header.height=72 trailer.height=72 by=("in_date" ) header.color="536870912" trailer.color="536870912" )
