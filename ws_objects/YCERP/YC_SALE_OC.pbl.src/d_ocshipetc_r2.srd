table(column=(type=datetime updatewhereclause=yes name=doshipetc_etc_date dbname="doshipetc.etc_date" )
 column=(type=char(1) updatewhereclause=yes name=doshipetc_shipamt_case dbname="doshipetc.shipamt_case" values="외상	R/현금	C/" )
 column=(type=decimal(0) updatewhereclause=yes name=doshipetc_ship_amount dbname="doshipetc.ship_amount" )
 column=(type=char(12) updatewhereclause=yes name=doshipetc_driver dbname="doshipetc.driver" )
 column=(type=char(10) updatewhereclause=yes name=doshipetc_drv_name dbname="doshipetc.drv_name" )
 column=(type=char(40) updatewhereclause=yes name=doshipetc_cargo_name dbname="doshipetc.cargo_name" )
 column=(type=char(14) updatewhereclause=yes name=sale_no dbname="doshipetc.sale_no" )
 column=(type=char(14) updatewhereclause=yes name=doshipetc_do_no dbname="doshipetc.do_no" )
 column=(type=char(60) updatewhereclause=yes name=doshipetc_rem dbname="doshipetc.rem" )
 column=(type=char(1) updatewhereclause=yes name=doshipetc_ship_close dbname="doshipetc.ship_close" )
 column=(type=char(60) updatewhereclause=yes name=doshipetc_rem2 dbname="rem2" )
 column=(type=char(60) updatewhereclause=yes name=doshipetc_rem3 dbname="rem3" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene.scene_desc" )
 column=(type=char(20) updatewhereclause=yes name=area_area_name dbname="area.area_name" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name_a dbname="login.user_name" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name_b dbname="login.user_name" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name_c dbname="login.user_name" )
 column=(type=char(1) updatewhereclause=yes name=doshipetc_etc_flag dbname="doshipetc.etc_flag" values="결재요청	O/결재완료	Y/담당전결	A/" )
 column=(type=char(1) updatewhereclause=yes name=doshipetc_ship_flag dbname="doshipetc.ship_flag" values="대여	D/부담	B/공사원가	A/재료원가	R/" )
 column=(type=char(4) updatewhereclause=yes name=doshipetc_cust_no dbname="doshipetc.cust_no" )
 column=(type=char(11) updatewhereclause=yes name=doshipetc_scene_code dbname="doshipetc.scene_code" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"customer~" )  TABLE(NAME=~"scene~" )  TABLE(NAME=~"login~" ALIAS=~"login_a~" )  TABLE(NAME=~"area~" )  TABLE(NAME=~"doshipetc~" )  TABLE(NAME=~"login~" ALIAS=~"login_b~" )  TABLE(NAME=~"login~" ALIAS=~"login_c~" ) COLUMN(NAME=~"doshipetc.etc_date~") COLUMN(NAME=~"doshipetc.shipamt_case~") COLUMN(NAME=~"doshipetc.ship_amount~") COLUMN(NAME=~"doshipetc.driver~") COLUMN(NAME=~"doshipetc.drv_name~") COLUMN(NAME=~"doshipetc.cargo_name~") COLUMN(NAME=~"doshipetc.sale_no~") COLUMN(NAME=~"doshipetc.do_no~") COLUMN(NAME=~"doshipetc.rem~") COLUMN(NAME=~"doshipetc.ship_close~") COLUMN(NAME=~"doshipetc.rem2~") COLUMN(NAME=~"doshipetc.rem3~") COLUMN(NAME=~"customer.cust_name~") COLUMN(NAME=~"scene.scene_desc~") COLUMN(NAME=~"area.area_name~") COLUMN(NAME=~"login_a.user_name~") COLUMN(NAME=~"login_b.user_name~") COLUMN(NAME=~"login_c.user_name~") COLUMN(NAME=~"doshipetc.etc_flag~") COLUMN(NAME=~"doshipetc.ship_flag~") COLUMN(NAME=~"doshipetc.cust_no~") COLUMN(NAME=~"doshipetc.scene_code~")    JOIN (LEFT=~"doshipetc.cust_no~"    OP =~"=~"RIGHT=~"customer.cust_no~"    OUTER1 =~"doshipetc.cust_no~" )    JOIN (LEFT=~"doshipetc.scene_code~"    OP =~"=~"RIGHT=~"scene.scene_code~"    OUTER1 =~"doshipetc.scene_code~" )    JOIN (LEFT=~"doshipetc.approve_team~"    OP =~"=~"RIGHT=~"login_b.user_id~"    OUTER1 =~"doshipetc.approve_team~" )    JOIN (LEFT=~"doshipetc.approve_top~"    OP =~"=~"RIGHT=~"login_c.user_id~"    OUTER1 =~"doshipetc.approve_top~" )    JOIN (LEFT=~"doshipetc.user_id~"    OP =~"=~"RIGHT=~"login_a.user_id~"    OUTER1 =~"doshipetc.user_id~" )    JOIN (LEFT=~"doshipetc.etc_area~"    OP =~"=~"RIGHT=~"area.area_no~"    OUTER1 =~"doshipetc.etc_area~" )WHERE(    EXP1 =~"doshipetc.etc_serial~"   OP =~"in~"    EXP2 =~":ai_etc~" ) ) ARG(NAME = ~"ai_etc~" TYPE = numberlist) " arguments=(("ai_etc", numberlist)) )
