$PBExportHeader$d_oicustbaldo_r.srd
$PBExportComments$판매거래처별 제품출고및 미출고조회(1998/5/14,성삼지)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=84 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(50) updatewhereclause=yes name=category dbname="category" )
 column=(type=char(10) updatewhereclause=yes name=gtype dbname="gtype" )
 column=(type=char(14) updatewhereclause=yes name=order_no dbname="order_no" initial=" " )
 column=(type=datetime updatewhereclause=yes name=due_date dbname="due_date" initial=" " )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" initial=" " )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="seq_no" )
 column=(type=decimal(2) updatewhereclause=yes name=order_qty dbname="order_qty" )
 column=(type=datetime updatewhereclause=yes name=rlse_date dbname="rlse_date" )
 column=(type=decimal(2) updatewhereclause=yes name=rlse_qty dbname="rlse_qty" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(20) updatewhereclause=yes name=customer_bus_cord dbname="bus_cord" )
 column=(type=char(20) updatewhereclause=yes name=customer_bus_rep dbname="bus_rep" )
 column=(type=char(30) updatewhereclause=yes name=customer_industry_code dbname="industry_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=decimal(4) updatewhereclause=yes name=price dbname="price" )
 column=(type=decimal(4) updatewhereclause=yes name=rang_qty dbname="rang_qty" )
 column=(type=char(2) updatewhereclause=yes name=uom_name dbname="uom_name" )
 retrieve="  SELECT distinct category      = isnull(cm.item_nm, '미분류')
       , gtype         = i.type
       , order_no      = sale.order_no   
       , due_date      = sale.due_date   
       , cust_no       = sale.cust_no   
       , item_no       = saledet.item_no   
       , qa            = saledet.qa   
       , uom           = saledet.uom   
       , seq_no        = saledet.seq_no   
       , order_qty     = saledet.order_qty   
       , rlse_date     = saledet.rlse_date   
       , rlse_qty      = saledet.rlse_qty   
       , cust_name     = c.cust_name   
       , bus_cord      = c.bus_cord   
       , bus_rep       = c.bus_rep   
       , industry_code = c.industry_code 
       , scene_desc    = scene.scene_desc   
       , item_name     = g.item_name
       , price         = (case when :as_price = 'Y' then 0  else saledet.price end)
       , dbo.uf_getqty(saledet.item_no, saledet.qa, saledet.uom, saledet.order_qty - saledet.rlse_qty) rang_qty
	  , (case when saledet.uom ='M2' or rtrim(ltrim( saledet.uom )) = 'M' then 'EA' else saledet.uom end ) uom_name
    FROM customer  C with (nolock) inner join OPEOM_ORG O with(nolock) on c.salesman  = o.user_id
         INNER JOIN sale with (nolock) ON c.cust_no = sale.cust_no  AND sale.open_close = 'O'
         INNER JOIN saledet     with (nolock) ON sale.order_no   = saledet.order_no 
         INNER JOIN scene       with (nolock) ON sale.scene_code = scene.scene_code 
         INNER JOIN groupitem G with (nolock) ON saledet.item_no = g.item_no
         LEFT OUTER JOIN itemtop10 I with (nolock) ON saledet.item_no = i.item_no  
	    LEFT OUTER JOIN codemst cm with (nolock) ON  i.category = cm.item_cd and cm.type = 'ITEMTOP10' AND cm.use_yn = 'Y'
   WHERE ( sale.order_date   BETWEEN :as_sdate AND :as_edate ) 
     AND ((:as_area  = '%' AND sale.order_no   LIKE '%'  ) OR 
          (:as_area <> '%' AND sale.order_no   LIKE :as_area )
         )
     AND ((:as_custno  = '%'   AND c.cust_no   LIKE '%'  ) OR 
          (:as_custno  = 'ALL' AND c.cust_no   LIKE '%'  ) OR 
          (:as_custno <> 'ALL' AND c.cust_no      = :as_custno )
         )
     AND ((:as_team  = '%' AND c.cust_no   LIKE '%'  ) OR 
          (:as_team <> '%' AND c.salesman     = :as_salesman )
         )
     AND ( saledet.order_qty  > saledet.rlse_qty )
" arguments=(("as_area", string),("as_custno", string),("as_sdate", string),("as_edate", string),("as_salesman", string),("as_team", string),("as_price", string))  sort="cust_name A scene_desc A due_date A order_no A seq_no A " )
