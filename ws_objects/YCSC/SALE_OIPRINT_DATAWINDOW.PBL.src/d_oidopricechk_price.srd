$PBExportHeader$d_oidopricechk_price.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=88 color="536870912" )
table(column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=decimal(4) updatewhereclause=yes name=calc_qty dbname="calc_qty" )
 column=(type=decimal(8) updatewhereclause=yes name=calc_amt dbname="calc_amt" )
 column=(type=decimal(6) updatewhereclause=yes name=std_cost dbname="std_cost" )
 retrieve="  SELECT a.item_name
       , a.item_no
       , a.qa
       , a.uom
       , calc_qty  = sum(a.calc_qty)
       , calc_amt  = sum(a.calc_amt)
       , std_cost  = sum(a.calc_amt) / sum(a.calc_qty)
    FROM (
         SELECT item_name = g.item_name
              , dodet.item_no
              , qa        = (case when dodet.uom = 'M' then substring(dodet.qa,1,13) else dodet.qa end)
              , g.uom
              , calc_qty  = dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty)
              , calc_amt  = dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty) * dodet.price
           FROM do
                LEFT OUTER JOIN dodet       ON do.do_no      = dodet.do_no
                LEFT OUTER JOIN customer  C ON do.cust_no    = c.cust_no
                LEFT OUTER JOIN groupitem G ON dodet.item_no = g.item_no
          WHERE ( do.do_date BETWEEN :ad_sdate AND :ad_edate )
            AND ((:as_itemname  = '%' AND g.item_name LIKE :as_itemname) OR
                 (:as_itemname <> '%' AND g.item_name    = :as_itemname) 
                )
            AND ((:as_inside    = '%' ) OR
                 (:as_inside   <> '%' AND c.cust_flag <> 'Y')
                )
         ) A
   GROUP BY a.item_name
          , a.item_no
          , a.qa
          , a.uom

" arguments=(("as_itemname", string),("ad_sdate", datetime),("ad_edate", datetime),("as_inside", string)) )
