detail(height=76 color="536870912"  height.autosize=yes)
table(column=(type=long update=yes updatewhereclause=yes key=yes identity=yes name=id dbname="itemstockdet.id" )
 column=(type=char(10) update=yes updatewhereclause=yes name=loc_no dbname="itemstockdet.loc_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="itemstockdet.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="itemstockdet.qa" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=qty dbname="itemstockdet.qty" )
 column=(type=char(60) update=yes updatewhereclause=yes name=reason1 dbname="itemstockdet.reason1" )
 column=(type=char(60) update=yes updatewhereclause=yes name=reason2 dbname="itemstockdet.reason2" )
 column=(type=char(60) update=yes updatewhereclause=yes name=reason3 dbname="itemstockdet.reason3" )
 column=(type=char(10) update=yes updatewhereclause=yes name=chk1_user dbname="itemstockdet.chk1_user" )
 column=(type=char(10) update=yes updatewhereclause=yes name=chk2_user dbname="itemstockdet.chk2_user" )
 column=(type=datetime update=yes updatewhereclause=yes name=user_date dbname="itemstockdet.user_date" )
 column=(type=char(1) update=yes updatewhereclause=yes name=reason_code dbname="itemstockdet.reason_code" initial="Z" )
 column=(type=char(16) update=yes updatewhereclause=yes name=order_no dbname="itemstockdet.order_no" )
 column=(type=long update=yes updatewhereclause=yes name=seq dbname="itemstockdet.seq" )
 column=(type=char(14) update=yes updatewhereclause=yes name=sale_no dbname="itemstockdet.sale_no" )
 column=(type=long update=yes updatewhereclause=yes name=sale_seq dbname="itemstockdet.sale_seq" )
 column=(type=char(1) update=yes updatewhereclause=yes name=itemstockdet_close_yn dbname="itemstockdet.close_yn" )
 column=(type=char(1) update=yes updatewhereclause=yes name=itemstockdet_kind dbname="itemstockdet.kind" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=in_qty dbname="itemstockdet.in_qty" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=out_qty dbname="itemstockdet.out_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=loc_qoh dbname="loc_qoh" )
 column=(type=char(186) updatewhereclause=yes name=reason dbname="reason" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(30) updatewhereclause=yes name=location_loc_name dbname="location.loc_name" )
 column=(type=char(4) updatewhereclause=yes name=sale_cust_no dbname="sale.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="SCENE.scene_desc" )
 retrieve="  SELECT itemstockdet.id
	  , itemstockdet.loc_no   
       , itemstockdet.item_no   
       , itemstockdet.qa   
       , itemstockdet.qty   
       , itemstockdet.reason1   
       , itemstockdet.reason2   
       , itemstockdet.reason3   
       , itemstockdet.chk1_user   
       , itemstockdet.chk2_user   
       , itemstockdet.user_date   
       , itemstockdet.reason_code   
       , itemstockdet.order_no
	  , itemstockdet.seq
	  , itemstockdet.sale_no
	  , itemstockdet.sale_seq
	  , itemstockdet.close_yn
	  , itemstockdet.kind
       , itemstockdet.in_qty
       , itemstockdet.out_qty
       , loc_qoh  = isnull(itemloc.qoh, 0)   
       , reason   = rtrim(itemstockdet.reason1) 
                  + (case when itemstockdet.reason1 is null or rtrim(itemstockdet.reason1) = '' then '' else ' | ' end)
                  + rtrim(itemstockdet.reason2) 
                  + (case when itemstockdet.reason2 is null or rtrim(itemstockdet.reason2) = '' then '' else ' | ' end)
                  + rtrim(itemstockdet.reason3)
       , groupitem.item_name   
       , location.loc_name 
       , sale.cust_no
       , customer.cust_name
       , scene.scene_desc
    FROM itemstockdet left outer join sale on itemstockdet.sale_no = sale.order_no
					            left outer join scene ON sale.scene_code = scene.scene_code
					            left outer join customer ON sale.cust_no = customer.cust_no
							  inner join groupitem on  itemstockdet.item_no = groupitem.item_no
						       inner join location on itemstockdet.loc_no = location.loc_no
						       left outer join itemloc on itemstockdet.loc_no = itemloc.loc_no and itemstockdet.item_no = itemloc.item_no and itemstockdet.qa = itemloc.qa			
   WHERE  ( itemstockdet.loc_no      = :as_loc ) 
		and itemstockdet.item_no = :as_item_no
          and itemstockdet.qa = :as_qa
" update="itemstockdet" updatewhere=0 updatekeyinplace=no arguments=(("as_loc", string),("as_item_no", string),("as_qa", string))  sort="groupitem_item_name A qa A user_date A " )
