release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=68 color="8421504" )
detail(height=68 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes key=yes name=item_no dbname="groupitem.item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="groupitem.item_name" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="groupitem.uom" )
 column=(type=char(1) updatewhereclause=yes name=cat dbname="cat" )
 retrieve="  SELECT DISTINCT groupitem.item_no
       , groupitem.item_name
       , groupitem.uom
       , cat     = (case when substring(groupitem.item_no,2,1) = '1' then 'W' else 'S' end)
    FROM groupitem  
   WHERE ( substring(groupitem.item_no, 4, 1) in ( '1', '2') ) 
     AND ( groupitem.use_flag   <> 'C' )    
" update="groupitem" updatewhere=0 updatekeyinplace=no  sort="item_name A " )
column(band=detail id=4 alignment="2" tabsequence=32766 border="0" color="0" x="1719" y="4" height="60" width="64" format="[general]" html.valueishtml="0"  name=cat visible="1" edit.limit=0 edit.case=any edit.focusrectangle=no edit.autoselect=no edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="2" font.pitch="2" font.charset="129" background.mode="2" background.color="16777215" )
compute(band=detail alignment="0" expression=" item_no  +  ~"  ~"  +  item_name "border="0" color="0" x="9" y="4" height="60" width="1696" format="[general]" html.valueishtml="0"  name=concat visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="16777215" )
compute(band=footer alignment="2" expression="rowcount()"border="0" color="0" x="9" y="4" height="60" width="1696" format="[GENERAL]" html.valueishtml="0"  name=compute_1 visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="553648127" )
htmltable(border="1" )
htmlgen(clientevents="1" clientvalidation="1" clientcomputedfields="1" clientformatting="0" clientscriptable="0" generatejavascript="1" netscapelayers="0" )
