$PBExportComments$물품요청선정번호조회(1998/10/30,성삼지)
release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=84 color="536870912" )
summary(height=0 color="536870912" )
footer(height=84 color="8421504" )
detail(height=84 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=ask_date dbname="ask_head.ask_date" )
 column=(type=char(4) updatewhereclause=yes name=ask_head_proc_flag dbname="ASK_HEAD_PROC_FLAG" )
 column=(type=char(8) updatewhereclause=yes name=proc_flag dbname="proc_flag" )
 column=(type=char(12) updatewhereclause=yes name=ask_no dbname="ask_head.ask_no" )
 column=(type=char(10) updatewhereclause=yes name=user_name1 dbname="user_name1" )
 column=(type=char(10) updatewhereclause=yes name=user_name2 dbname="user_name2" )
 retrieve="              SELECT distinct ask_head.ask_date
                     ,  ( CASE WHEN ask_head.proc_flag = 'N' THEN '요청'
                                         WHEN ask_head.proc_flag = 'Y' THEN '완료'
                                         WHEN ask_head.proc_flag = 'P' THEN '부분'
                        END )  ASK_HEAD_PROC_FLAG
                     ,  ( CASE WHEN ask_head.proc_flag = 'N' THEN '접수중'
                                         WHEN ask_head.proc_flag = 'Y' THEN '처리완료'
                                         WHEN ask_head.proc_flag = 'P' THEN '부분'
                        END )  proc_flag
                     , ask_head.ask_no
                     , user_name1 = l1.user_name
                     , user_name2 = l2.user_name
                  FROM ask_head with(nolock) INNER JOIN ask_det  with (nolock) ON ask_head.ask_no = ask_det.ask_no
                       LEFT OUTER JOIN login l1 with(nolock) ON ask_head.ask_user = l1.user_id
                       LEFT OUTER JOIN login l2 with(nolock) ON ask_head.act_user = l2.user_id
                WHERE ( ask_head.ask_date between CONVERT(DATETIME, :as_sdate + ' 00:00:00.000' ) and CONVERT(DATETIME, :as_edate + ' 23:59:59.999' ) ) 
              	AND ( ask_head.f_area         = :as_area ) 
              	AND ( ask_head.proc_flag     <> 'Y'      )
		     AND ( isnull(ask_det.sale_no,'%') like :as_sale_no )

" arguments=(("as_area", string),("as_sdate", string),("as_edate", string),("as_sale_no", string))  sort="ask_date D " )
