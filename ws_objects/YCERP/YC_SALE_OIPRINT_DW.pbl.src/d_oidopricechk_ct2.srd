table(column=(type=char(20) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=number updatewhereclause=yes name=avg_price dbname="avg_price" )
 column=(type=number updatewhereclause=yes name=calc_qty dbname="calc_qty" )
 column=(type=number updatewhereclause=yes name=calc_amt dbname="calc_amt" )
 retrieve="         SELECT a.item_no
              , a.item_name
              , a.do_date   
              , calc_qty  = sum(a.calc_qty)
              , calc_amt  = sum(a.calc_amt)
              , avg_price = sum(a.calc_amt) / sum(a.calc_qty)
           FROM (
                SELECT do.cust_no
                     , c.cust_name
                     , do.spot_code
                     , dodet.item_no
                     , g.item_name
                     , qa        = (case when g.uom = 'M' then substring(dodet.qa,1,13) else dodet.qa end)
                     , g.uom
                     , calc_qty  = dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty)
                     , calc_amt  = dodet.price * dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty)
                     , do_date   = convert(char(8), do.do_date,111) + '01'
                  FROM do
                       LEFT OUTER JOIN dodet        ON do.do_no      = dodet.do_no
                       LEFT OUTER JOIN customer  C  ON do.cust_no    = c.cust_no
                       LEFT OUTER JOIN groupitem G  ON dodet.item_no = g.item_no
                 WHERE do.do_date BETWEEN :ad_sdate + ' 00:00:00' AND :ad_edate + ' 23:59:59'
                   AND ((:as_salesman  = '%' AND c.salesman LIKE :as_salesman) OR
                        (:as_salesman <> '%' AND c.salesman    = :as_salesman) 
                       )
                   AND ((:as_custno    = '%' AND do.cust_no LIKE :as_custno) OR
                        (:as_custno   <> '%' AND do.cust_no    = :as_custno) 
                       )
                   AND ((:as_inside    = '%' ) OR
                        (:as_inside   <> '%' AND c.cust_flag <> 'Y')
                       )
                   AND (g.item_name   IN ('CARRYING CHANEL KS', 'M-BAR KS (DOUBLE)', 'APT M-BAR', 'APT CARRIER', 'C-STUD 50형 KS', 'C-STUD 65형 KS', 'BOLT(전산도금,9mm) 500이상') )
                ) A
          GROUP BY a.item_no
                 , a.item_name
                 , a.do_date
" arguments=(("as_salesman", string),("as_custno", string),("ad_sdate", date),("ad_edate", date),("as_inside", string))  sort="item_name A " )
