table(column=(type=datetime update=yes updatewhereclause=yes name=ask_date dbname="ask_head.ask_date" initial="today()" )
 column=(type=char(10) update=yes updatewhereclause=yes name=ask_loc dbname="ask_head.ask_loc" )
 column=(type=char(10) update=yes updatewhereclause=yes name=ask_user dbname="ask_head.ask_user" )
 column=(type=char(50) update=yes updatewhereclause=yes name=rem dbname="ask_head.rem" )
 column=(type=char(12) update=yes updatewhereclause=yes key=yes name=ask_no dbname="ask_head.ask_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=proc_flag dbname="ask_head.proc_flag" initial="N" values="처리완료	Y/접수중	N/부분	P/" )
 column=(type=char(10) update=yes updatewhereclause=yes name=act_user dbname="ask_head.act_user" )
