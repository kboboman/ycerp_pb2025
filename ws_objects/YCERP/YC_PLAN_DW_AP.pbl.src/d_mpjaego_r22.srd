 column=(type=decimal(2) updatewhereclause=yes name=saledet_rlse_qty dbname="rlse_qty" )
 column=(type=char(50) updatewhereclause=yes name=saledet_rem dbname="saledet_rem" )
 column=(type=datetime updatewhereclause=yes name=sale_order_date dbname="order_date" )
 column=(type=char(6) updatewhereclause=yes name=io_chk dbname="io_chk" )
 column=(type=char(10) updatewhereclause=yes name=pur_no dbname="pur_no" )
 column=(type=char(1) updatewhereclause=yes name=chk_memo dbname="chk_memo" )
 column=(type=char(1) updatewhereclause=yes name=en_datenull dbname="en_datenull" )
 column=(type=datetime updatewhereclause=yes name=en_date dbname="sale_jaego.en_date" )
 column=(type=char(255) updatewhereclause=yes name=bigo dbname="sale_jaego.bigo" )
 column=(type=char(4099) updatewhereclause=no name=sale_jaego_rem dbname="sale_jaego.rem" )
 retrieve="  SELECT chk  = ''
       , sale_jaego.order_no
       , seq_no       = null
       , acct_no      = null
       , sale_jaego.item_no
       , item_name    = null
       , sale_jaego.qa
       , uom          = null
       , sale_jaego.order_qty
       , acc_qty      = 0
       , sale_jaego.qoh
       , sale_jaego.loc_no
       , cust_no      = null
       , cust_name    = null
       , scene_desc   = null
       , shipto_addr  = null
       , scene_charge = null
       , scene_tel    = null
       , shipflag     = null
       , ship_case    = null
       , cust_po_date = null
       , due_date     = null
       , rem          = null
       , rem1         = null
       , rem2         = null
       , user_name    = null
       , confirm_flag = null
       , salesman     = null
       , rlse_qty     = 0
       , saledet_rem  = null
       , order_date   = null
       , io_chk       = null
       , pur_no       = null
       , chk_memo     = null
       , en_datenull  = null
       , sale_jaego.en_date
       , sale_jaego.bigo
       , sale_jaego.rem
    FROM sale_jaego
   WHERE (loc_no      = :as_locno   )         /* 저장소   */
     AND (order_no    = ''          )

  UNION All

  SELECT chk  = ''
       , order_no    = sale.order_no
       , seq_no      = saledet.seq_no
       , acct_no     = g.acct_no
       , item_no     = saledet.item_no        
       , item_name   = g.item_name         
       , qa          = saledet.qa
       , uom         = g.uom               
       , order_qty   = saledet.order_qty      
       , acc_qty     = saledet.acc_qty        
       , qoh         = isnull(itemloc.qoh, 0)
       , loc_no      = itemloc.loc_no
       , cust_no     = sale.cust_no           
       , cust_name   = customer.cust_name     
       , scene_desc  = scene.scene_desc       
       , shipto_addr = sale.shipto_addr
       , scene_charge= scene.scene_charge
       , scene_tel   = scene.scene_tel
       , shipflag.name
       , ship_case   = (case sale.ship_case 
                             when 'J' then '정기화물' 
                             when 'T' then '택배' 
                             when 'A' then '오토바이' 
                             when 'S' then '선박' 
                             when 'P' then '항공' 
                             else '기타' 
                        end)
       , cust_po_date= sale.cust_po_date
       , due_date    = sale.due_date
       , rem         = sale.rem
       , rem1        = sale.rem1
       , rem2        = sale.rem2
       , login.user_name
       , confirm_flag = (case sale.confirm_flag  when 'Y' then '확정' else '미확정' end)
       , salesman     = b.user_name
       , saledet.rlse_qty
       , saledet.rem
       , sale.order_date
       , io_chk       = (case when saledet.order_qty - rlse_qty > 0 then '미출고' else '출고' end)
       , pur_no       = (SELECT top 1 order_no FROM purdet WHERE sale_no = saledet.order_no AND sale_seq = saledet.seq_no)
       , chk_memo     = (case when (SELECT count(*) FROM sale_jaego
                                     WHERE order_no = saledet.order_no
                                       AND item_no  = saledet.item_no  AND qa = saledet.qa  AND order_qty = saledet.order_qty
                                   ) > 0 then 'Y'
                              else ''
                         end)
       , en_datenull  = (case when sale_jaego.en_date is null then 'Y' else 'N' end)
       , en_date      = sale_jaego.en_date
       , sale_jaego.bigo
       , jaego_rem    = convert(varchar(4055),sale_jaego.rem)
    FROM saledet       (nolock)
         LEFT OUTER JOIN sale        (nolock) ON saledet.order_no= sale.order_no 
         LEFT OUTER JOIN groupitem g (nolock) ON saledet.item_no = g.item_no
         LEFT OUTER JOIN itemloc     (nolock) ON saledet.item_no = itemloc.item_no AND saledet.qa = itemloc.qa       
                                             AND itemloc.loc_no  = :as_locno
         LEFT OUTER JOIN customer    (nolock) ON sale.cust_no    = customer.cust_no 
         LEFT OUTER JOIN scene       (nolock) ON sale.scene_code = scene.scene_code 
         LEFT OUTER JOIN shipflag    (nolock) ON sale.sale_flag  = shipflag.flag    
         LEFT OUTER JOIN login       (nolock) ON sale.login_id   = login.user_id    
         LEFT OUTER JOIN login     b (nolock) ON sale.salesman   = b.user_id        
         LEFT OUTER JOIN sale_jaego  (nolock) ON sale.order_no   = sale_jaego.order_no 
                                             AND saledet.item_no = sale_jaego.item_no AND saledet.order_qty = sale_jaego.order_qty
/*   WHERE sale.open_close        <> 'C'         	한도초과 */         
      WHERE sale.open_close       = 'O'         	
     AND (sale.order_date  BETWEEN :as_sdate AND :as_edate) /* 수주일자 */
     AND ((:as_custno   = '%')  OR
          (:as_custno  <> '%'  AND sale.cust_no      = :as_custno   )         /* 거래처   */
         )
     AND ((:as_scene    = '%')  OR
          (:as_scene   <> '%'  AND sale.scene_code   = :as_scene    )         /* 현장     */
         )
     AND ((:as_confirm  = '%')  OR
          (:as_confirm <> '%'  AND sale.confirm_flag IN (:as_confirm))        /* 수주확정 */
         )
     AND ((:as_outtype  = '%')  OR
          (:as_outtype  = '1'  AND saledet.order_qty - saledet.rlse_qty <= 0) OR   /* 출고   */
          (:as_outtype  = '2'  AND saledet.order_qty - saledet.rlse_qty  > 0)      /* 미출고 */
         )
" update="sale_jaego" updatewhere=0 updatekeyinplace=no arguments=(("as_locno", string),("as_sdate", string),("as_edate", string),("as_custno", string),("as_scene", string),("as_confirm", string),("as_outtype", string))  sort="item_no A qa A order_qty A " )
group(level=1 header.height=0 trailer.height=76 by=("item_no" , "qa" , "order_qty" ) header.color="536870912" trailer.color="536870912" )
