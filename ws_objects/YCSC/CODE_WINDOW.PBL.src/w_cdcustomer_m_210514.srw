event selectionchanged;choose case newindex
	case 5
		pb_1.enabled       = false
		pb_insert.enabled  = false
		pb_print.enabled   = false
		pb_print_part.enabled = false
		pb_compute.enabled = false
		pb_save.enabled    = false
		dw_1.enabled       = false
		tab_1.tabpage_5.dw_19.retrieve()
		tab_1.tabpage_5.dw_18.retrieve()
		
	case 6
		pb_1.enabled       = false
		pb_insert.enabled  = false
		pb_print.enabled   = false
		pb_print_part.enabled = false
		pb_compute.enabled = false
		pb_save.enabled    = false
		dw_1.enabled       = true 
		tab_1.tabpage_6.cb_5.triggerevent(clicked!)
		
	case 7
		wf_codemst()
		
	case else
		pb_1.enabled       = true
		pb_insert.enabled  = true
		pb_print.enabled   = true
		pb_print_part.enabled = true
		pb_compute.enabled = true
		pb_save.enabled    = true
		dw_1.enabled       = true
end choose		


end event

