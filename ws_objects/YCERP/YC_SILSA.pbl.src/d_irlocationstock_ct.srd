release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no  crosstab.dynamic = yes grid.lines=0 grid.columnmove=no selected.mouse=no )
header[1](height=0 color="536870912" )
header[2](height=72 color="536870912" )
header[3](height=72 color="536870912" )
summary(height=0 color="553648127" )
footer(height=88 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=number updatewhereclause=yes name=bf_qty dbname="bf_qty" )
 column=(type=number updatewhereclause=yes name=qoh dbname="qoh" )
 retrieve="  SELECT loc_no    = a.loc_no
       , item_no   = a.item_no
       , item_name = b.item_name
       , qa        = a.qa
       , cdate     = convert(char(10),dateadd(day, 0, a.cdate),111)
       , bf_qty    = a.before_qty
       , qoh       = a.before_qty + a.rcpt_qty - a.issue_qty
    FROM ineoday_loc A
         LEFT OUTER JOIN groupitem B ON a.item_no = b.item_no
   WHERE a.loc_no   = :as_locno
     AND a.cdate   >= replace(convert(char(10),dateadd(day, 0, :as_sdate),111), '/','')
     AND (:as_top15 = 'Y' AND a.item_no    IN ('PACSMBDK00','PACSMBDB00','PACSCACK00','PACSCACB00','PACSCLIB00'
                                              ,'PAWSSTDK00','PAWSSTDK10','PAWSSTDB00','PAWSSTDB10','PAWSRUNB00'
                                              ,'PAWSRUNK00','PACSMTBK00','PACSC2FK00','GBMZSMSZ0Z','PBCATL0K0S')
          OR
          :as_top15 = 'N' AND a.item_no  LIKE '%'
         )
" arguments=(("as_sdate", string),("as_locno", string),("as_top15", string))  sort="item_name A qa A " )
group(level=1 header.height=0 trailer.height=0 by=("item_name" ) header.color="536870912" trailer.color="536870912" )
