tabpage_1 tabpage_1
tabpage_2 tabpage_2
tabpage_3 tabpage_3
end type

on tab_1.create
this.tabpage_1=create tabpage_1
this.tabpage_2=create tabpage_2
this.tabpage_3=create tabpage_3
this.Control[]={this.tabpage_1,&
this.tabpage_2,&
this.tabpage_3}
end on

on tab_1.destroy
destroy(this.tabpage_1)
destroy(this.tabpage_2)
destroy(this.tabpage_3)
end on

event selectionchanged;// 품목, 수주품목, 출고품목
choose case newindex
	case 2
		if tabpage_2.rb_sale.checked = true then
			tabpage_2.em_5.SelectText(9, 2)
			tabpage_2.em_5.setfocus()
		end if

	case 3
		tabpage_3.em_8.SelectText(9, 2)
		tabpage_3.em_8.setfocus()
end choose

end event

