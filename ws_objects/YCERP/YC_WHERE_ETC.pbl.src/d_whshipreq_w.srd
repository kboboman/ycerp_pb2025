$PBExportHeader$d_whshipreq_w.srd
$PBExportComments$운반비변경요청관리 (2002/08/28,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=do_do_no dbname="do.do_no" )
 column=(type=datetime updatewhereclause=yes name=do_do_date dbname="do.do_date" )
 column=(type=char(30) updatewhereclause=yes name=do_ship_flag dbname="ship_flag" )
 column=(type=decimal(0) updatewhereclause=yes name=do_ship_amount dbname="do.ship_amount" )
 column=(type=char(12) updatewhereclause=yes name=do_driver dbname="do.driver" )
 column=(type=char(1) updatewhereclause=yes name=do_shipamt_case dbname="do.shipamt_case" values="현금	C/외상	R/" )
 column=(type=char(10) updatewhereclause=yes name=docar_name dbname="docar.name" )
 column=(type=char(40) updatewhereclause=yes name=docar_cargo_name dbname="docar.cargo_name" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 retrieve="  SELECT do.do_no,   
         do.do_date,   
         ship_flag = dbo.uf_getshipflag(do.ship_flag),   
         do.ship_amount,   
         do.driver,   
         do.shipamt_case,   
         docar.name,   
         docar.cargo_name,   
         customer.cust_name,   
         scene.scene_desc  
    FROM customer with(nolock) inner join do with(nolock) on customer.cust_no = do.cust_no
										  left outer join scene with(nolock) on do.spot_code = scene.scene_code
										  left outer join docar with(nolock)  on do.driver = docar.driver
   WHERE ( ( do.do_date between :ad_start and :ad_end ) AND  
         ( do.cust_no like :as_cust ) AND  
         ( do.invoice_print = 'N' ) )    
/*
    FROM customer,   
         do,   
         scene,   
         docar  
   WHERE ( do.spot_code *= scene.scene_code) and  
         ( do.driver *= docar.driver) and  
         ( do.cust_no = customer.cust_no ) and  
         ( ( do.do_date between :ad_start and :ad_end ) AND  
         ( do.cust_no like :as_cust ) AND  
         ( do.invoice_print = 'N' ) )    
*/" arguments=(("ad_start", date),("ad_end", date),("as_cust", string))  sort="do_do_no A " )
