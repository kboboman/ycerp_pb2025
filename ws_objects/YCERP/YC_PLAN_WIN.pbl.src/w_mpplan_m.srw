dw7.accepttext()
ls_wcno = dw7.object.wc_no[1]
if isnull(ls_wcno) OR ls_wcno = "" then ls_wcno = "%"
if RightA(ls_wcno,2) = "00" then ls_wcno = LeftA(ls_wcno,1) + "%"

debugbreak()

