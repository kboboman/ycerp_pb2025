table(column=(type=char(10) updatewhereclause=yes key=yes name=order_no dbname="order_no" initial=" " )
 column=(type=decimal(0) updatewhereclause=yes key=yes name=seq_no dbname="seq_no" initial=" " )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" initial=" " )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" initial=" " )
 column=(type=datetime updatewhereclause=yes name=due_date dbname="due_date" initial=" " )
 column=(type=decimal(4) updatewhereclause=yes name=order_qty dbname="order_qty" initial=" " )
 column=(type=datetime update=yes updatewhereclause=yes name=rlse_date dbname="rlse_date" initial=" " )
 column=(type=decimal(4) updatewhereclause=yes name=price dbname="price" initial=" " )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="uom" initial=" " )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=rlse_qty dbname="rlse_qty" initial=" " )
 column=(type=char(17) updatewhereclause=yes name=product_no dbname="product_no" initial=" " )
 column=(type=char(20) update=yes updatewhereclause=yes name=loc_no dbname="rcpt_loc" initial=" " )
