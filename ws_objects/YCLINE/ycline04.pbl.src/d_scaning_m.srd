 column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" values="	Y/	N" )
 column=(type=char(1) updatewhereclause=yes name=updateqty dbname="updateqty" )
 column=(type=char(10) updatewhereclause=yes name=work_name dbname="work_name" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 retrieve="  SELECT work_no    = routscan.work_no
       , scan_date  = routscan.scan_date
       , scan_no    = routscan.scan_no
       , scan_qty   = routscan.scan_qty
       , sale_no    = routscan.sale_no
       , seq_no     = routscan.seq_no
       , cust_no    = routscan.cust_no
       , scene_code = routscan.scene_code
       , item_no    = routscan.item_no
       , qa         = routscan.qa
       , user_id    = routscan.user_id
       , order_qty  = (SELECT order_qty FROM saledet WHERE order_no = routscan.sale_no AND seq_no = routscan.seq_no )
       , chk        = 'N'
       , updateqty  = 'Y'
       , work_name  = wc.work_name
       , user_name  = l.user_name
       , cust_name  = c.cust_name
       , scene_desc = s.scene_desc
       , item_name  = g.item_name
    FROM routscan
         LEFT OUTER JOIN (
              SELECT work_no, work_name FROM wc
              UNION ALL
              SELECT 'NCT1', 'PEGA'
              UNION ALL
              SELECT 'NCT2', 'EM'
         ) wc ON routscan.work_no  = wc.work_no     
         LEFT OUTER JOIN customer  C  ON routscan.cust_no    = c.cust_no
         LEFT OUTER JOIN scene     S  ON routscan.scene_code = s.scene_code
         LEFT OUTER JOIN groupitem G  ON routscan.item_no    = g.item_no
         LEFT OUTER JOIN login     L  ON routscan.user_id    = l.user_id
   WHERE routscan.scan_date between :adt_sdate AND :adt_edate
     AND routscan.work_no   = :as_wcno
" update="routscan" updatewhere=1 updatekeyinplace=no arguments=(("as_wcno", string),("adt_sdate", datetime),("adt_edate", datetime))  sort="scan_date A " )
