$PBExportHeader$d_cditemgroup_list.srd
release 8;
datawindow(units=0 timer_interval=0 color=67108864 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="groupitem.item_no" )
 column=(type=char(60) update=yes updatewhereclause=yes name=item_name dbname="groupitem.item_name" )
 column=(type=char(1) updatewhereclause=yes name=use_flag dbname="groupitem.use_flag" initial="Y" values="사용	Y/불가	C/" )
 retrieve="  SELECT groupitem.item_no
       , groupitem.item_name  
       , groupitem.use_flag
    FROM groupitem   
   WHERE ((:as_p1   = '%' AND groupitem.P1 LIKE :as_p1) OR
          (:as_p1  <> '%' AND groupitem.P1    = :as_p1)
         )
" update="groupitem" updatewhere=1 updatekeyinplace=no arguments=(("as_p1", string))  sort="item_no A " )
text(band=header alignment="2" text="품명" border="6" color="33554432" x="571" y="8" height="60" width="946" html.valueishtml="0"  name=item_name_t visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="67108864" )
