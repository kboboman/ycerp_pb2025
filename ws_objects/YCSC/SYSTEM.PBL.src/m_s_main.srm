type m_window from menu within m_s_main
m_system m_system
m_plock m_plock
m_-0 m_-0
m_layered m_layered
m_cascade m_cascade
end type

on m_window.create
call super::create
this.text = "윈도우(&Window)"
this.m_system=create m_system
this.m_plock=create m_plock
this.m_-0=create m_-0
this.m_layered=create m_layered
this.m_cascade=create m_cascade
this.Item[UpperBound(this.Item)+1]=this.m_system
this.Item[UpperBound(this.Item)+1]=this.m_plock
this.Item[UpperBound(this.Item)+1]=this.m_-0
this.Item[UpperBound(this.Item)+1]=this.m_layered
this.Item[UpperBound(this.Item)+1]=this.m_cascade
end on

on m_window.destroy
call super::destroy
destroy(this.m_system)
destroy(this.m_plock)
destroy(this.m_-0)
destroy(this.m_layered)
destroy(this.m_cascade)
end on

