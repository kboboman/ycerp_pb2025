 column=(type=char(10) updatewhereclause=yes name=top_level dbname="top_level" )
 retrieve="  SELECT CHK              = 'N'                                      
		 , cust_no          = a.cust_no                                /* 거래처코드    */
		 , cust_name        = a.cust_name                              /* 상호          */
		 , register_no      = a.register_no                            /* 사업자번호    */
		 , captain_name     = a.captain_name                           /* 대표자명      */
		 , cap_birthday     = a.cap_birthday                           /* 대표자생년    */
		 , resident_card    = a.resident_card                          /* 법인주민번호  */
		 , team_name        = c.team_name                              /* 부서명        */
		 , salesman         = a.salesman                               /* 판매자ID      */
		 , credit_day       = convert(char(10),a.credit_day,111)       /* 여신일자      */
		 , addr1            = a.addr1                                  /* 거래처우편    */
		 , addr2            = a.addr2                                  /* 거래처주소1   */
		 , addr3            = a.addr3                                  /* 거래처주소2   */
		 , bus_addr1        = a.bus_addr1                              /* 실채무자우편  */
		 , bus_addr2        = a.bus_addr2                              /* 실채무자주소1 */
		 , bus_addr3        = a.bus_addr3                              /* 실채무자주소2 */
		 , terms            = a.terms                                  /* 결재기간      */
		 , price_level      = a.price_level                            /* 단가등급      */
		 , credit_level     = a.credit_level                           /* 신용등급      */
		 , level_grade      = a.level_grade                            /* 매출등급      */
		 , credit_limit     = a.credit_limit                           /* 신용한도액    */
		 , shipto_addr1     = a.shipto_addr1                           /* 운송처우편    */
		 , shipto_addr2     = a.shipto_addr2                           /* 운송처주소1   */
		 , shipto_addr3     = a.shipto_addr3                           /* 운송처주소2   */
		 , contract_day     = a.contract_day                           /* 계약일        */
		 , contract_yn      = a.contract_yn                            /* 계약서        */
		 , joint_head       = a.joint_head                             /* 대표자보증    */
		 , jointor          = a.jointor                                /* 유한연대보증인*/
		 , joint_amt        = a.joint_amt                              /* 보증금액      */
		 , dambo_rem        = a.dambo_rem                              /* 담보내역내용  */
		 , dambo_ymd        = a.dambo_ymd                              /* 담보일자      */
		 , dambo_ymde       = a.dambo_ymde                             /* 담보만기      */
		 , dambo_amt        = a.dambo_amt                              /* 담보금액      */
		 , dambo_bigo       = a.dambo_bigo                             /* 담보비고      */
		 , captain_relation = a.captain_relation                       /* 대표자관계    */
		 , vat_user         = a.vat_user                               /* VAT담당자     */
		 , vat_phone        = a.vat_phone                              /* VAT연락처     */
		 , vat_email        = a.vat_email                              /* VAT메일       */
		 , collect_ymd      = a.collect_ymd                            /* 채권관리      */
		 , icube_no         = a.icube_no                               /* 더존          */
		 , custmain         = d.main_co                                /* 주거래건설사  */
		 , licensenm        = d.license_name                           /* 면허명        */
		 , rotate           = a.rotate                                 /* 회전월        */
		 , addr             = a.addr                                   /* 주소 */
		 , salesman_bu = a.cap_birthday			  /*담당자(부)*/
		 , sale_address = a.sale_address			  /**/
		 , top_level = a.top_level			  			  /*종합등급*/

	 FROM customer  a                                                                     
			LEFT OUTER JOIN login    b  ON a.salesman  = b.user_id                             
			LEFT OUTER JOIN team     c  ON b.team_code = c.team_code                           
			LEFT OUTER JOIN custinfo d  ON a.cust_no   = d.cust_no
	ORDER BY a.cust_name                                                                  
" )
