table(column=(type=char(14) updatewhereclause=yes key=yes name=dc_groupno dbname="dc_groupno" )
 column=(type=char(4) updatewhereclause=yes key=yes name=cust_no dbname="cust_No" )
 column=(type=char(11) updatewhereclause=yes key=yes name=scene_code dbname="scene_code" )
 column=(type=long updatewhereclause=yes key=yes name=seq_no dbname="seq_no" )
 column=(type=decimal(4) updatewhereclause=yes name=price dbname="price" )
 column=(type=char(50) updatewhereclause=yes name=rem dbname="rem" )
 column=(type=char(14) update=yes updatewhereclause=yes name=do_no dbname="do_no" )
 retrieve="  SELECT dc_groupno   = b.dc_groupno
       , cust_No      = b.cust_no
       , scene_code   = b.scene_code
       , seq_no       = b.seq_no
       , price        = b.price
       , rem          = b.rem
       , do_no        = b.do_no
    FROM dc_groupdet b
   WHERE ( b.dc_groupno      = :as_groupno )
" update="dc_groupdet" updatewhere=1 updatekeyinplace=no arguments=(("as_groupno", string)) )
