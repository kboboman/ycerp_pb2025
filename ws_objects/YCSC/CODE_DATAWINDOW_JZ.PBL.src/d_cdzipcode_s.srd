$PBExportHeader$d_cdzipcode_s.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=88 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=우편번호 dbname="zipcode.우편번호" )
 column=(type=char(255) updatewhereclause=yes name=주소 dbname="zipcode.주소" )
 column=(type=char(255) updatewhereclause=yes name=검색주소 dbname="compute_0003" )
 retrieve="  SELECT 우편번호
       , 주소
       , CASE WHEN [아파트건물명] IS NULL OR RTRIM([아파트건물명]) = ''
                   THEN [시도] + ' ' + [시군구] +
                        CASE WHEN [읍면동]  IS NULL OR RTRIM([읍면동])       = '' THEN '' ELSE ' ' + [읍면동]        END +
                        CASE WHEN [리]      IS NULL OR RTRIM([리])           = '' THEN '' ELSE ' ' + [리]            END +
                        CASE WHEN [도서]    IS NULL OR RTRIM([도서])         = '' THEN '' ELSE ' ' + [도서]          END +
                        CASE WHEN [산번지]  IS NULL OR RTRIM([산번지])       = '' THEN '' ELSE ' ' + LTRIM([산번지]) END
              ELSE [시도] + ' ' + [시군구] +
                   CASE WHEN [읍면동]       IS NULL OR RTRIM([읍면동])       = '' THEN '' ELSE ' ' + [읍면동]        END +
                   CASE WHEN [리]           IS NULL OR RTRIM([리])           = '' THEN '' ELSE ' ' + [리]            END +
                   CASE WHEN [도서]         IS NULL OR RTRIM([도서])         = '' THEN '' ELSE ' ' + [도서]          END +
                   CASE WHEN [산번지]       IS NULL OR RTRIM([산번지])       = '' THEN '' ELSE ' ' + LTRIM([산번지]) END +
                   CASE WHEN [아파트건물명] IS NULL OR RTRIM([아파트건물명]) = '' THEN '' ELSE ' ' + [아파트건물명]  END 
         END
    FROM ZIPCODE
   WHERE [읍면동] LIKE :as_string

/*
  select 우편번호, 주소,
			case when 아파트건물명 is null or rtrim(아파트건물명) = ''
				then
					시도 + ' ' + 시군구 +
					case when 읍면동 is null or rtrim(읍면동) = '' then '' else ' ' + 읍면동 end +
					case when 리 is null or rtrim(리) = '' then '' else ' ' + 리 end +
					case when 도서 is null or rtrim(도서) = '' then '' else ' ' + 도서 end +
					case when 산번지 is null or rtrim(산번지) = '' then '' else ' ' + ltrim(산번지) end
				else
					시도 + ' ' + 시군구 +
					case when 읍면동 is null or rtrim(읍면동) = '' then '' else ' ' + 읍면동 end +
					case when 리 is null or rtrim(리) = '' then '' else ' ' + 리 end +
					case when 도서 is null or rtrim(도서) = '' then '' else ' ' + 도서 end +
					case when 산번지 is null or rtrim(산번지) = '' then '' else ' ' + ltrim(산번지) end +
					case when 아파트건물명 is null or rtrim(아파트건물명) = '' then '' else ' ' + 아파트건물명 end 
			end
from zipcode
where 읍면동 like :as_string
*/" arguments=(("as_string", string))  sort="우편번호 A 주소 A " )
