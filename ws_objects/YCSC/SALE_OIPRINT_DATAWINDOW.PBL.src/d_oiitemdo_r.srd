$PBExportHeader$d_oiitemdo_r.srd
$PBExportComments$제품별 제품출고보고서(1998/5/14,성삼지)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=408 color="536870912" )
summary(height=76 color="536870912" )
footer(height=0 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=do_do_no dbname="do.do_no" )
 column=(type=datetime updatewhereclause=yes name=do_do_date dbname="do.do_date" )
 column=(type=char(11) updatewhereclause=yes name=do_spot_code dbname="do.spot_code" )
 column=(type=char(3) updatewhereclause=yes name=do_curr_code dbname="do.curr_code" )
 column=(type=char(10) updatewhereclause=yes name=dodet_item_no dbname="dodet.item_no" )
 column=(type=char(20) updatewhereclause=yes name=dodet_qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=dodet_uom dbname="dodet.uom" )
 column=(type=char(14) updatewhereclause=yes name=dodet_sale_no dbname="dodet.sale_no" )
 column=(type=long updatewhereclause=yes name=dodet_oi_no dbname="dodet.oi_no" )
 column=(type=decimal(2) updatewhereclause=yes name=dodet_ship_qty dbname="dodet.ship_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=com_qty dbname="com_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=dodet_price dbname="price" )
 column=(type=decimal(8) updatewhereclause=yes name=amount dbname="amount" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(20) updatewhereclause=yes name=customer_bus_cord dbname="customer.bus_cord" )
 column=(type=char(20) updatewhereclause=yes name=customer_bus_rep dbname="customer.bus_rep" )
 column=(type=char(30) updatewhereclause=yes name=customer_industry_code dbname="customer.industry_code" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene.scene_desc" )
 retrieve="  SELECT do.do_no         
       , do.do_date       
       , do.spot_code     
       , do.curr_code     
       , dodet.item_no    
       , qa        = (case when :as_request = 'Y' and dodet.qa_cust is not null then dodet.qa_cust else dodet.qa end)       
       , dodet.uom        
       , dodet.sale_no    
       , dodet.oi_no      
       , dodet.ship_qty
       , com_qty   = dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom,dodet.ship_qty )
       , price     = (case when :as_price = 'N' then dodet.price else 0 end)
       , amount    = (case when :as_price = 'N' then 
                                (case when customer.round = 'Y' then
                                           round(dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom,dodet.ship_qty ) * dodet.price, 0,0)
                                      else round(dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom,dodet.ship_qty ) * dodet.price, 0,1) 
                                 end)
                           else 0
                      end)
       , customer.cust_name       
       , customer.bus_cord        
       , customer.bus_rep         
       , customer.industry_code   
       , groupitem.item_name      
       , scene.scene_desc  
    FROM do          
         LEFT OUTER JOIN dodet     ON do.do_no      = dodet.do_no
         LEFT OUTER JOIN customer  ON do.cust_no    = customer.cust_no
         LEFT OUTER JOIN groupitem ON dodet.item_no = groupitem.item_no
         LEFT OUTER JOIN scene     ON do.spot_code  = scene.scene_code
   WHERE ( do.do_date  between :ad_sdate and :ad_edate )
     AND ((:as_custno   = '%' ) OR
          (:as_custno  <> '%' AND do.cust_no = :as_custno)
         )
     AND ((:as_salesman = '%' ) OR
          (customer.salesman  LIKE :as_salesman )
         )
     AND ((:as_itemno   = '%' ) OR
          (:as_itemno  <> '%' AND dodet.item_no = :as_itemno)
         )
" arguments=(("as_custno", string),("ad_sdate", date),("ad_edate", date),("as_salesman", string),("as_itemno", string),("as_price", string),("as_request", string))  sort="dodet_item_no A dodet_qa A do_do_date A customer_cust_name A do_spot_code A do_do_no A dodet_sale_no A dodet_oi_no A " )
