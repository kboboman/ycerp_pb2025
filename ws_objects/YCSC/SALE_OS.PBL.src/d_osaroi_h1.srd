$PBExportComments$판매매출관리 DO TABLE UPDATE용 DATAWINDOW(1998/04/15, 정재수)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=68 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes key=yes name=do_no dbname="do.do_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=invoice_print dbname="do.invoice_print" )
 retrieve="  SELECT DISTINCT do.do_no,   
         do.invoice_print  
    FROM do,   
         dodet  
   WHERE ( do.do_no = dodet.do_no ) and  
         ( ( do.cust_no = :as_cust ) AND  
         ( do.do_date >= :ad_sdate ) AND  
         ( do.do_date <= :ad_edate ) AND  
         ( dodet.ship_qty <> dodet.aroi_qty ) AND  
         ( do.sale_flag = :as_sale_flag ) )    
" update="do" updatewhere=0 updatekeyinplace=yes arguments=(("as_cust", string),("ad_sdate", date),("ad_edate", date),("as_sale_flag", string)) )
column(band=detail id=1 alignment="0" tabsequence=32766 border="2" color="0" x="9" y="4" height="60" width="480" format="[general]" html.valueishtml="0"  name=do_no  tag="출고번호" visible="1" edit.limit=14 edit.case=any edit.autoselect=yes edit.autohscroll=yes edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
column(band=detail id=2 alignment="0" tabsequence=32766 border="2" color="0" x="503" y="4" height="60" width="384" format="[general]" html.valueishtml="0"  name=invoice_print  tag="매출유무" visible="1" edit.limit=1 edit.case=any edit.autoselect=yes edit.autohscroll=yes edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
