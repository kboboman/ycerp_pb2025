type cb_workdate from commandbutton within w_mpplan_m
integer x = 3831
integer y = 248
integer width = 489
integer height = 84
integer taborder = 50
boolean bringtotop = true
integer textsize = -9
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
boolean enabled = false
string text = "예정일자변경"
end type

event clicked;// 예정일변경
datetime ldt_workdate
string   ls_wcno, ls_message
long     ll_row

dw7.accepttext()
dw6.accepttext()

ls_wcno      = dw7.object.wc_no[1]
if isnull(ls_wcno) OR ls_wcno = "" then RETURN

ll_row       = dw6.getrow()
if isnull(ll_row) OR ll_row < 1 OR ll_row > dw6.rowcount() then RETURN

ldt_workdate = dw6.object.work_date[ll_row]
ls_message   = "현재 데이터 예정일자를 [" + string(ldt_workdate,"yyyy/mm/dd") + "] 자로 일괄변경 합니다."

if MessageBox("확인", ls_message, Exclamation!, OKCancel!, 2) = 2 then
	RETURN
end if

for ll_row = 1 to dw6.rowcount()
	dw6.object.work_date[ll_row] = ldt_workdate
next

if MessageBox("확인","예정일자를 변경완료 저장하시겠습니까?", Exclamation!, OKCancel!, 2) = 1 then
	tab_1.tabpage_4.pb_3.triggerevent( clicked! )
end if

end event

