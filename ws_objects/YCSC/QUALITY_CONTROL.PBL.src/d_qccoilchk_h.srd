$PBExportComments$설비점검 체크 리스트(스리팅)(2005/05/23, 이인호)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=88 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=ddate dbname="ddate" )
 column=(type=char(1) updatewhereclause=yes name=eos dbname="EOS" )
 column=(type=char(1) updatewhereclause=yes name=gr dbname="GR" )
 column=(type=char(1) updatewhereclause=yes name=cb dbname="CB" )
 column=(type=char(1) updatewhereclause=yes name=br dbname="BR" )
 column=(type=char(1) updatewhereclause=yes name=sm dbname="SM" )
 column=(type=char(10) updatewhereclause=yes name=wname dbname="wname" )
 retrieve="  SELECT Cmonth.ddate,
			qccoilchk.EOS,   
			qccoilchk.GR,   
			qccoilchk.CB,   
			qccoilchk.BR,   
			qccoilchk.SM,   
			qccoilchk.wname  
    FROM dbo.uf_getdaytbl(:ad_start, :ad_end) Cmonth left outer join  qccoilchk on Cmonth.ddate =  qccoilchk.sfc_date
                                                                                                         and qccoilchk.area_no = :as_area
	                                                                                                    and qccoilchk.wc_no = :as_wc " arguments=(("as_area", string),("as_wc", string),("ad_start", date),("ad_end", date)) )
