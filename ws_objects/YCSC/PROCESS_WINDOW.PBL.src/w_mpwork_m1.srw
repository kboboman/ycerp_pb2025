string facename = "굴림체"
string text = "자재반납-->"
end type

event clicked;long ll_rowcount, ll_row, ll_found, ll_row2
int li_pos
string ls_plan, ls_coil, ls_chkcoil, ls_maxcoil
dec {1} ld_wid

is_wc = trim(dw_2.object.wc_no[1])

dw6.setredraw(false)

ll_rowcount = dw5.rowcount()
for ll_row = 1 to ll_rowcount
	if dw5.isselected(ll_row) then
		ls_plan = trim(dw5.object.order_no[ll_row])
		dw6.accepttext()
		if dw6.rowcount() > 0 then
			ll_found = dw6.find("order_no = '" + ls_plan + "'",1,dw6.rowcount())
			if ll_found > 0 then
				if MessageBox("확인",string(ll_found, "000") + " 번째 자료는 이미 이동되었습니다~r~n" + &
										"재이동 하시겠습니까", Exclamation!, OKCancel!, 2) = 1 then
					ll_found = 0
				end if
			end if
		else
			ll_found = 0
		end if
		if ll_found = 0 then
			IF dw6.rowcount() < 1 then
				dw6.retrieve(id_date,is_wc)
			end if
			ll_row2 = dw6.insertrow(0)
		   dw6.object.ret_date[ll_row2]       = id_date
		   dw6.object.wc_no[ll_row2]          = trim(dw_2.object.wc_no[1])
		   dw6.object.seq_no[ll_row2]          = 0
			dw6.object.item_no[ll_row2]        = dw5.object.item_no[ll_row]
			dw6.object.qa[ll_row2]             = dw5.object.qa[ll_row]
			dw6.object.uom[ll_row2]            = dw5.object.uom[ll_row]
			dw6.object.color[ll_row2]          = dw5.object.color[ll_row]
			dw6.object.color_type[ll_row2]     = dw5.object.color_type[ll_row]
			dw6.object.wcoil_no[ll_row2] = dw5.object.coil_no[ll_row]
		   dw6.object.loc_no[ll_row2] 		  = dw5.object.loc_no[ll_row]
			ld_wid = dw5.object.sfcuse_wid[ll_row]
			if isnull(dw6.object.coil_no[ll_row2]) or trim(dw6.object.coil_no[ll_row2]) = '' then
			else
				dw6.object.coil_no[ll_row2] = wf_coil(ll_row)
			end if
//			dw6.object.coil_no[ll_row2]        = dw5.object.coil_no[ll_row]
			dw6.object.wunit_qty[ll_row2] 		  = dw5.object.sfcuse_unit_qty[ll_row]
			dw6.object.wlen[ll_row2] 			  = dw5.object.sfcuse_mod_len[ll_row] 
			dw6.object.wid[ll_row2]            = dw5.object.sfcuse_wid[ll_row]
			dw6.object.unit_qty[ll_row2]       = dw5.object.sfcuse_unit_qty[ll_row]
			dw6.object.cnt[ll_row2]            = 1
			dw6.object.ret_qty[ll_row2]        = dw5.object.sfcuse_unit_qty[ll_row]
			dw6.object.length[ll_row2]         = dw5.object.sfcuse_mod_len[ll_row]
			dw6.object.coil_type[ll_row2]      = dw5.object.coil_type[ll_row]
			dw6.object.order_no[ll_row2]       = dw5.object.order_no[ll_row]
			dw6.object.rem[ll_row2]            = ''
			dw6.object.item_item_name[ll_row2] = dw5.object.item_item_name[ll_row]
		end if
	end if
next

if ll_row2 > 0  then
	dw6.triggerevent(rowfocuschanged!)
	tab_1.selecttab(4)
else
	MessageBox("확인","이동할 자료를 선택하십시요")
end if
dw6.setredraw(true)
dw5.selectrow(0,false)
end event

