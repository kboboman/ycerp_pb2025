type cb_batch from commandbutton within w_mpplan_m
integer x = 1993
integer y = 400
integer width = 192
integer height = 72
integer taborder = 110
boolean bringtotop = true
integer textsize = -9
integer weight = 400
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "적용"
end type

event clicked;// 적용
string ls_batch, ls_wcno, ls_chk, ls_message, ls_work_name, ls_area_no
long   ll_row, ll_year, ll_cnt
date   ld_date, ld_getdate
datetime ldt_workdate

dw_work.accepttext()
ls_wcno    = dw_work.object.wc_no[1]

ls_batch   = ddlb_batch.text
ld_date    = date(em_batch.text)
ld_getdate = date(GF_Today())

//ll_cnt     = dw6.object.tchk[1]
//if ll_cnt < 1 then
//	MessageBox("확인","작업할 대상을 선택하시기 바랍니다.")
//	RETURN
//end if


ll_row       = dw6.getrow()
if isnull(ll_row) OR ll_row < 1 OR ll_row > dw6.rowcount() then RETURN

choose case ls_batch
	case "생산납기일자"
		
		ls_message   = "현재 데이터 " + ls_batch + "를 [" + string(ld_date,"yyyy/mm/dd") + "] 자로 일괄변경 합니다."
		
		if MessageBox("확인", ls_message, Exclamation!, OKCancel!, 2) = 2 then
			RETURN
		end if

		if isnull(ld_date) OR ld_date < ld_getdate then
			//
		else
			for ll_row = 1 to dw6.rowcount()
//				ls_chk  = dw6.object.chk[ll_row]
//				if ls_chk = "Y" then

				if dw6.isselected(ll_row) then
					dw6.object.make_napgi_date[ll_row] = datetime(ld_date, time("00:00:00"))
				end if
//				end if
			next
		end if		
	case "예정일자"
		
		ls_message   = "현재 데이터 " + ls_batch + "를 [" + string(ld_date,"yyyy/mm/dd") + "] 자로 일괄변경 합니다."
		
		if MessageBox("확인", ls_message, Exclamation!, OKCancel!, 2) = 2 then
			RETURN
		end if

		if isnull(ld_date) OR ld_date < ld_getdate then
			//
		else
			for ll_row = 1 to dw6.rowcount()
//				ls_chk  = dw6.object.chk[ll_row]
//				if ls_chk = "Y" then
				if dw6.isselected(ll_row) then
					dw6.object.work_date[ll_row] = datetime(ld_date, time("00:00:00"))
				end if
//				end if
			next
		end if
	
	case "작업장"
		
		select work_name, area_no
		  into :ls_work_name, :ls_area_no
		from wc
		where work_no = :ls_wcno;
		
		ls_message   = "현재 데이터 " + ls_batch + "을 [" + ls_work_name + "] 로 일괄변경 합니다."
		
		if MessageBox("확인", ls_message, Exclamation!, OKCancel!, 2) = 2 then
			RETURN
		end if

		if isnull(ls_wcno) OR ls_wcno = "" then
			//
		else
			for ll_row = 1 to dw6.rowcount()
//				ls_chk  = dw6.object.chk[ll_row]
//				if ls_chk = "Y" then
				if dw6.isselected(ll_row) then
					dw6.object.wc_no[ll_row] = ls_wcno
					dw6.object.routtempnew_area_no[ll_row] = ls_area_no
				end if					
//				end if
			next
		end if
end choose


if MessageBox("확인","변경완료 저장하시겠습니까?", Exclamation!, OKCancel!, 2) = 1 then
	tab_1.tabpage_4.pb_3.triggerevent( clicked! )
end if

end event

