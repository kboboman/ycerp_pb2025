//				return false
//			end if
//	 elseif mid(ls_item,4,1) = '2' then
//			//sheet분할
//			if mid(ls_item, 3,1 ) = "A" then
//				ld_yrate = 2.72
//			else
//				ld_yrate = 8.12
//			end if // sheet 단중 = 두께 * 폭 * 길이 * 요율(스틸 = 8.12, 알미늄 = 2.72)
//			lr_sheet_unitqty = truncate(dec(left(ls_qa,1) + "." + mid(ls_qa,2,2)) &
//													* dec( mid(ls_qa ,  5,4 )) &
//													* dec( mid(ls_qa , 10,4 )) &
//													* ld_yrate / 1000000 + 0.000000001,  3)
