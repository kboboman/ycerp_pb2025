$PBExportHeader$d_mpslituse_t11.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no  crosstab.dynamic = yes grid.lines=0 grid.columnmove=no selected.mouse=no )
header[1](height=68 color="536870912" )
header[2](height=72 color="536870912" )
summary(height=84 color="8421504" )
footer(height=0 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=number updatewhereclause=yes name=real_qty dbname="real_qty" )
 retrieve="  SELECT item_no   = aa.item_no  
       , item_name = aa.item_name   
       , use_date  = aa.use_date    
       , qa        = aa.qa          
       , coil_no   = aa.coil_no     
       , unit_qty  = aa.unit_qty    
       , mod_len   = aa.mod_len     
       , cnt       = aa.cnt         
       , sdate     = aa.sdate       
       , edate     = aa.edate       
       , work_name = aa.work_name
       , sc_flag   = aa.sc_flag  
       , rem_qty   = aa.rem_qty  
       , al_flag   = aa.al_flag  
       , real_qty  = (case when (aa.unit_qty * aa.cnt - rem_qty) = 0
                                then /* SHEET코일 사용량 */
                                     (case when ((aa.unit_qty * aa.cnt) = 0 ) and (aa.al_flag = 'A') 
                                                then CONVERT(INT, (CAST(REPLACE(SUBSTRING(AA.QA,1,3),'X','')  AS DECIMAL) / 100) *
                                                                  (CAST(REPLACE(SUBSTRING(AA.QA,5,4),'X','')  AS INT)) * 
                                                                  (CAST(REPLACE(SUBSTRING(AA.QA,10,4),'X','') AS INT)) / 1000000 * 2.72 * aa.cnt)
                                           when ((aa.unit_qty * aa.cnt) = 0 ) and (aa.al_flag = 'S') 
                                                then CONVERT(INT, (CAST(REPLACE(SUBSTRING(AA.QA,1,3),'X','')  AS DECIMAL) / 100) *
                                                                  (CAST(REPLACE(SUBSTRING(AA.QA,5,4),'X','')  AS INT)) * 
                                                                  (CAST(REPLACE(SUBSTRING(AA.QA,10,4),'X','') AS INT)) / 1000000 * 8.12 * aa.cnt)                                          
                                                else (aa.unit_qty * aa.cnt)
                                      end)
                           else (aa.unit_qty * aa.cnt - rem_qty)
                      end)                     
       , area_name = (SELECT area_name FROM area WHERE area_no = aa.area_no)
    FROM (
         SELECT      sfcuse.item_no                                   
					  , groupitem.item_name                                 
					  , sfcuse.use_date                                     
					  , sfcuse.qa                                           
					  , sfcuse.coil_no                                      
					  , sfcuse.unit_qty                                     
					  , sfcuse.mod_len                                      
					  , sfcuse.cnt                                          
					  , sdate    = convert(smalldatetime, :ad_start, 111)   
					  , edate    = convert(smalldatetime, :ad_end,   111)    
					  , wc.work_name                                     
					  , sc_flag  = substring( groupitem.item_no, 4,1)
					  , rem_qty  = (case when sfcret.unit_qty * sfcret.cnt is not null then sfcret.unit_qty * sfcret.cnt else 0 end)
									 + (case when sfcuse.rem_qty               is not null then sfcuse.rem_qty               else 0 end)
					  , al_flag  = substring(sfcuse.item_no, 3,1) 
					  , sfcuse.area_no
			FROM sfcuse               inner join groupitem on sfcuse.item_no = groupitem.item_no
										  inner join wc on sfcuse.wc_no  = wc.work_no
										  left outer join sfcret on sfcuse.use_date = sfcret.ret_date
																			  AND   sfcuse.coil_no   = sfcret.wcoil_no
																			  AND   sfcuse.loc_no    = sfcret.loc_no                                                                              
			WHERE  ( wc.work_name           LIKE :as_wc                ) 
							AND ( SFCUSE.USE_DATE BETWEEN convert(datetime,  :ad_start +' 00:00:00' ) and convert(datetime,  :ad_end + ' 23:59:59' ) )                     
							AND ( ((sfcuse.coil_no     IS NOT NULL                  )) OR
									((sfcuse.coil_no         IS NULL                  ) and
									 (substring(sfcuse.item_no,1,4) IN ( 'M1A1', 'M1A2', 'M1S1', 'M1S2', 'M1Z1', 'M1Z2', 
																					 'M3A1', 'M3A2', 'M3S1', 'M3S2', 'M3Z1', 'M3Z2', 'MZZZ' )     
									 )
									)          
								 ) 
							AND ( sfcuse.area_no = :as_area  or :as_area = '%'      )
/*
           FROM groupitem   
              , sfcuse      
              , wc       
              , sfcret
          WHERE ( sfcuse.item_no           *= groupitem.item_no     ) 
            AND ( sfcuse.wc_no              = wc.work_no            ) 
            AND ( wc.work_name           LIKE :as_wc                ) 
/*            AND ( sfcuse.use_date     BETWEEN :ad_start and :ad_end )*/
		 AND ( SFCUSE.USE_DATE BETWEEN convert(datetime,  :ad_start +' 00:00:00' ) and convert(datetime,  :ad_end + ' 23:59:59' ) )
            AND ( sfcuse.use_date          *= sfcret.ret_date       ) 
            AND ( sfcuse.coil_no           *= sfcret.wcoil_no       ) 
            AND ( sfcuse.loc_no            *= sfcret.loc_no         )                        
            AND ( ((sfcuse.coil_no     IS NOT NULL                  )) OR
                  ((sfcuse.coil_no         IS NULL                  ) and
                   (substring(sfcuse.item_no,1,4) IN ( 'M1A1', 'M1A2', 'M1S1', 'M1S2', 'M1Z1', 'M1Z2', 
                                                       'M3A1', 'M3A2', 'M3S1', 'M3S2', 'M3Z1', 'M3Z2', 'MZZZ' )     
                   )
                  )          
                ) 
            AND ( sfcuse.area_no = :as_area  or :as_area = '%'      )
*/
         ) AA
" arguments=(("ad_start", date),("ad_end", date),("as_wc", string),("as_area", string))  sort="item_name A qa A " )
group(level=1 header.height=0 trailer.height=80 by=("item_name" ) header.color="536870912" trailer.color="12639424" )
