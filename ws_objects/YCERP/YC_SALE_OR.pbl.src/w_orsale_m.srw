event clicked;// 출고의뢰작성
string   ls_reqdate, ls_salesman, ls_rem, ls_reqtext, ls_confirm, ls_auser, ls_aarea, ls_schedule, ls_shipflag, ls_area_no
string   ls_saleno, ls_addscene, ls_custno, ls_scene, ls_itemno, ls_itemnm, ls_qa,    ls_uom,  ls_locno,   ls_telno, ls_acceptuser, ls_ship_case
string   ls_null,   ls_SQLErrText
integer  li_reqseq, li_seq
long     ll_row,    ll_seqno, ll_selrow
decimal  ld_issueqty
datetime ld_reqdate

dw_2.accepttext()
dw_3.accepttext()

ls_custno   = dw_2.object.cust_no[1]
ls_scene    = dw_2.object.scene_code[1]
ls_shipflag = dw_2.object.ship_flag[1]
ls_telno    = dw_2.object.tel_no[1]
ls_area_no   = dw_2.object.area_no[1]

setnull( ls_null )
if dw_2.rowcount() < 1 then RETURN
ls_reqdate = string(GF_TODAY(),"yyyy/mm/dd")

// 의뢰자별 마지막 차수
SELECT max(req_seq) INTO :li_reqseq 
FROM issuereq 
WHERE convert(char(10),req_date,111) = :ls_reqdate
AND salesman   = :gs_userid;
 
if isnull(li_reqseq) OR li_reqseq = 0 then
	li_reqseq = 1
else
	li_reqseq = li_reqseq + 1
end if

select a.def_loc, b.loc_manager
into :ls_locno, :ls_acceptuser
from area a with(nolock) inner join location b with(nolock) on a.def_loc = b.loc_no
where a.area_no = :ls_area_no;

gs_where lstr_where

lstr_where.str1 = ls_reqdate
lstr_where.str2 = gs_userid
lstr_where.str3 = string(li_reqseq)
lstr_where.str5 = dw_2.object.ship_case[1]
lstr_where.name = ls_acceptuser
lstr_where.chk  = 'Y'

OpenWithParm( w_whissuereqauto_m, lstr_where )
lstr_where = Message.PowerObjectParm

// 출고예정
ls_schedule = lstr_where.str4
ls_ship_case = dw_2.object.ship_case[1]
ls_reqdate = lstr_where.str1
li_reqseq = integer(lstr_where.str3)

if isnull(ls_locno) OR ls_locno = "" then
	MessageBox("확인",string(ll_selrow) + " 번 출고품목의 저장소를 확인하시기 바랍니다.",exclamation!)
	RETURN
end if

ls_saleno  = dw_3.object.order_no[1]
ls_itemnm  = dw_3.object.item_item_name[1] + ' 外'
ls_uom     = dw_3.object.uom[1]

ld_reqdate = datetime(date(ls_reqdate), time("00:00:00")) // 의뢰일자
ls_salesman= gs_userid						// 의뢰자

ls_reqtext = dw_2.object.rem[1]

if lstr_where.chk = 'Y' then
	// 출고상세
	INSERT INTO issuereqdet (req_date, salesman, req_seq, req_flag, seq, cust_no, scene_code, add_scene, sale_no
			 , item_name, uom, issue_flag, issue_schedule, ship_flag, ship_case, tel, sys_date, rem)
	VALUES (:ld_reqdate, :ls_salesman, :li_reqseq, 'A', 1, :ls_custno, :ls_scene, :ls_null, :ls_saleno
			 , :ls_itemnm, :ls_uom, 'A', :ls_schedule, :ls_shipflag, :ls_ship_case, :ls_telno, getdate(), :ls_reqtext);
			 
	if sqlca.sqlcode = 0 then
		// 출고상세선정수량
		for ll_row = 1 to dw_3.rowcount()
			ll_seqno    = dw_3.object.seq_no[ll_row]
			ls_itemno   = dw_3.object.item_no[ll_row]
			ls_qa       = dw_3.object.qa[ll_row]
			ld_issueqty = dw_3.object.order_qty[ll_row]
			
			INSERT INTO issuereqdet_sale (req_date, salesman, req_seq, seq, order_no, seq_no, item_no, qa, issue_qty, sys_date)
			VALUES (:ld_reqdate, :ls_salesman, :li_reqseq, 1, :ls_saleno, :ll_seqno, :ls_itemno, :ls_qa, :ld_issueqty, getdate());
			if sqlca.sqlcode = 0 then
				COMMIT;	
			else
				ls_SQLErrText = sqlca.SQLErrText
				MessageBox("저장","issuereqdet_sale INSERT중 오류가 발생하였습니다!~n~n"+ls_SQLErrText,exclamation!)
				RETURN
			end if
		next
	else
		ls_SQLErrText = sqlca.SQLErrText
		MessageBox("저장","issuereqdet INSERT중 오류가 발생하였습니다!~n~n"+ls_SQLErrText,exclamation!)
		RETURN
	end if		

	MessageBox("저장","출고의뢰서 작성완료")
else
	MessageBox("취소","출고의뢰서 작성을 취소하였습니다.")	
end if

end event

type pb_16 from picturebutton within w_orsale_m
integer x = 4974
integer y = 1452
integer width = 325
integer height = 112
integer taborder = 330
boolean bringtotop = true
integer textsize = -9
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "돋움체"
string text = "일정복사"
vtextalign vtextalign = vcenter!
end type

event clicked;string	ls_order_no, ls_cust_no, ls_sale_make_rem, ls_copy
long		ll_grow

ll_grow = dw_2.getrow()
if ll_grow = 0 then return

ls_order_no			= dw_2.getitemstring(ll_grow, 'order_no')		
if gf_null_chk(ls_order_no) then
	messagebox("확인","수주 번호가 존재하지 않습니다.")
	return
end if
	
ls_cust_no			= dw_2.Describe("Evaluate('LookUpDisplay(cust_no) ', " + string(ll_grow) + ")")
if gf_null_chk(ls_cust_no) then ls_cust_no = ""

ls_sale_make_rem	= dw_2.getitemstring(ll_grow, 'sale_make_rem')		
if gf_null_chk(ls_sale_make_rem) then ls_sale_make_rem = ""


ls_copy = ls_order_no + ' ' + ls_cust_no + ' ' + ls_sale_make_rem

clipboard(ls_copy)

end event

