 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"apbill~" ) COLUMN(NAME=~"apbill.vc_no~") COLUMN(NAME=~"apbill.bill_no~") COLUMN(NAME=~"apbill.bill_class~") COLUMN(NAME=~"apbill.supp_no~") COLUMN(NAME=~"apbill.close_date~") COLUMN(NAME=~"apbill.start_date~") COLUMN(NAME=~"apbill.bank_code~") COLUMN(NAME=~"apbill.bill_area~") COLUMN(NAME=~"apbill.bill_amount~") COLUMN(NAME=~"apbill.set_flag~") COLUMN(NAME=~"apbill.set_date~") COLUMN(NAME=~"apbill.draft~") COLUMN(NAME=~"apbill.rem~") COLUMN(NAME=~"apbill.set_user~")WHERE(    EXP1 =~"( apbill.vc_no~"   OP =~"=~"    EXP2 =~":as_vc_no )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( apbill.bill_no~"   OP =~"=~"    EXP2 =~":as_bill_no )~" ) ) ARG(NAME = ~"as_vc_no~" TYPE = string)  ARG(NAME = ~"as_bill_no~" TYPE = string) " update="apbill" updatewhere=1 updatekeyinplace=yes arguments=(("as_vc_no", string),("as_bill_no", string)) )
