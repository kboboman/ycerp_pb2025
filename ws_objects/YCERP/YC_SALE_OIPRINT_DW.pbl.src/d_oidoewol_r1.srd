release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=452 color="536870912" )
summary(height=116 color="536870912" )
footer(height=0 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(12) updatewhereclause=yes name=reg_no dbname="reg_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(10) updatewhereclause=yes name=area_name dbname="area_name" )
 column=(type=char(6) updatewhereclause=yes name=cat_name dbname="cat_name" )
 column=(type=char(10) updatewhereclause=yes name=cstart dbname="cstart" )
 column=(type=char(10) updatewhereclause=yes name=cend dbname="cend" )
 column=(type=decimal(1) updatewhereclause=yes name=ship_total dbname="ship_total" )
 column=(type=decimal(2) updatewhereclause=yes name=ship_qty dbname="ship_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=c_qty dbname="c_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=c_price dbname="c_price" )
 column=(type=decimal(8) updatewhereclause=yes name=c_amt dbname="c_amt" )
 column=(type=decimal(4) updatewhereclause=yes name=c_rate dbname="c_rate" )
 column=(type=decimal(8) updatewhereclause=yes name=c_tot dbname="c_tot" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_rate dbname="do_rate" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_cash dbname="do_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_total dbname="do_total" )
 retrieve="   SELECT reg_no      = a.reg_no                                                                                                       
        , cust_name   = a.cust_name                                                                                                    
        , area_name   = a.area_name                                                                                                    
        , cat_name    = a.cat_name                                                                                                     
        , cstart      = a.cstart                                                                                                       
        , cend        = a.cend                                                                                                         
        , ship_total  = SUM(a.ship_total  )                                                                                            
        , ship_qty    = SUM(a.ship_qty    )                                                                                            
        , c_qty       = SUM(a.c_qty       )                                                                                            
        , c_price     = SUM(a.c_price     )                                                                                            
        , c_amt       = SUM(a.c_amt       )                                                                                            
        , c_rate      = SUM(a.c_rate      )                                                                                            
        , c_tot       = SUM(a.c_tot       )                                                                                            
        , do_rate     = SUM(a.do_rate     )                                                                                            
        , do_cash     = SUM(a.do_cash     )                                                                                            
        , do_total    = SUM(a.do_total    )                                                                                            
     FROM (                                                                                                                            
          SELECT cust_no     = aa.cust_no                                                                                              
               , reg_no      = aa.reg_no                                                                                               
               , item_name   = aa.item_name                                                                                            
               , item_no     = aa.item_no                                                                                              
               , qa          = aa.qa                                                                                                   
               , uom         = aa.uom                                                                                                  
               , cust_name   = aa.cust_name                                                                                            
               , area_name   = aa.area_name                                                                                            
               , cat_name    = aa.cat_name                                                                                             
               , cstart      = aa.cstart                                                                                               
               , cend        = aa.cend                                                                                                 
               , do_rate     = isnull(bb.do_rate, 0)                                                                                   
               , do_cash     = isnull(bb.do_cash, 0)                                                                                   
               , do_total    = isnull(bb.do_total,0)                                                                                   
               , ship_total  = aa.ship_total                                                                                           
               , ship_qty    = aa.ship_qty                                                                                             
               , c_qty       = aa.c_qty                                                                                                
               , c_price     = aa.c_price                                                                                              
               , c_amt       = aa.c_amt                                                                                                
               , c_rate      = aa.c_rate                                                                                               
               , c_tot       = aa.c_tot                                                                                                
            FROM (  /* 출고HEAD의 공급가와 출고상세 집계금액 단수차이 발생함 */                                                        
                 SELECT cust_no     = a.cust_no                                                                                        
                      , reg_no      = c.register_no                                                                                    
                      , item_name   = d.item_name                                                                                      
                      , item_no     = b.item_no                                                                                        
                      , qa          = b.qa                                                                                             
                      , uom         = b.uom                                                                                            
                      , do_no       = a.do_no                                                                                          
                      , oi_no       = b.oi_no                                                                                          
                      , cust_name   = c.cust_name                                                                                      
                      , area_name   = (case when :as_area = '%'     then '전체사업장'                                                  
                                            when :as_area = 'Z0001' then '대전사업장'                                                  
                                            when :as_area = 'S0001' then '시화사업장'                                                  
                                            when :as_area = 'B0001' then 'YSP사업장'                                                   
                                            when :as_area = 'H0001' then '화곡사업장'                                                  
                                            when :as_area = 'T0001' then '화성사업장'                                                  
                                            else :as_area                                                                              
                                       end)                                                                                            
                      , cat_name    = (case when :as_category = '%'  then '전체'                                                       
                                            when :as_category = 'P%' then '제품'                                                       
                                            when :as_category = 'G%' then '상품'                                                       
                                            when :as_category = 'M%' then '원재료'                                                     
                                            else substring(b.item_no,1,1)                                                              
                                       end)                                                                                            
                      , cstart      = (case when :as_start    = ''  then '          ' else :as_start          end)                     
                      , cend        = (case when :as_end      = ''  then '          ' else :as_end            end)                     
                      , do_rate      = a.do_rate                                                                                       
                      , do_cash      = a.do_cash                                                                                       
                      , do_total     = a.do_total                                                                                      
                      , ship_total  = (case when a.ship_flag = 'D' and a.shipamt_case = 'R' and b.oi_no = 1 then /* 대여, 부담 */      
                                                 (case when a.do_rate <> 0 then /* 영세율이 아닌것 */                                  
                                                            a.ship_amount * 1.1                                                        
                                                       else a.ship_amount                                                              
                                                  end)                                                                                 
                                            else 0                                                                                     
                                       end)                                                                                            
                      , ship_qty    = b.ship_qty                                                                                       
                      , c_qty       = round(dbo.uf_getqty(b.item_no, b.qa, b.uom, b.ship_qty),2,1)                                     
                      , c_price     = b.price                                                                                          
                      , c_amt       = (case when c.round = 'Y' then                                                                    
                                                 round((b.price * round(dbo.uf_getqty(b.item_no, b.qa, b.uom, b.ship_qty),2,1) ), 0,0) 
                                            else round((b.price * round(dbo.uf_getqty(b.item_no, b.qa, b.uom, b.ship_qty),2,1) ), 0,1) 
                                       end )                                                                                           
                      , c_rate      = b.rate_cash                                                                                      
                      , c_tot       = (case when c.round = 'Y' then                                                                    
                                                 round((b.price * round(dbo.uf_getqty(b.item_no, b.qa, b.uom, b.ship_qty),2,1) ), 0,0) 
                                            else round((b.price * round(dbo.uf_getqty(b.item_no, b.qa, b.uom, b.ship_qty),2,1) ), 0,1) 
                                       end) + b.rate_cash                                                                              
                   FROM do_ewol    a                                                                                                   
                      , dodet_ewol b                                                                                                   
                      , customer   c                                                                                                   
                      , groupitem  d                                                                                                   
                  WHERE ( a.do_no                = b.do_no       )                                                                     
                    AND ( b.item_no              = d.item_no )                                                                         
                    AND ( a.cust_no              = c.cust_no  )                                                                        
                    AND ( a.area_no           LIKE :as_area          )                                                                 
                    AND ( convert(char(10),a.do_date,111)  BETWEEN :as_start AND :as_end )                                             
                    AND ( a.cust_no           LIKE :as_cust          )                                                                 
                    AND ( b.item_no           LIKE :as_category      )                                                                 
               /* ORDER BY d.item_name, b.qa */                                                                                        
               ) AA                                                                                                                    
               LEFT OUTER JOIN (  /* 출고상세 삭제시 순번 재정의 안됨 */                                                               
                  SELECT do_no    = a.do_no                                                                                            
                       , oi_no    = min(a.oi_no)                                                                                       
                       , do_rate  = max(a.do_rate)                                                                                     
                       , do_cash  = max(a.do_cash)                                                                                     
                       , do_total = max(a.do_total)                                                                                    
                    FROM (                                                                                                             
                          SELECT do_no        = a.do_no                                                                                
                               , oi_no        = b.oi_no                                                                                
                               , do_rate      = a.do_rate                                                                              
                               , do_cash      = a.do_cash                                                                              
                               , do_total     = a.do_total                                                                             
                            FROM do_ewol    a                                                                                          
                               , dodet_ewol b                                                                                          
                               , customer   c                                                                                          
                               , groupitem  d                                                                                          
                           WHERE ( a.do_no                = b.do_no    )                                                               
                             AND ( b.item_no              = d.item_no  )                                                               
                             AND ( a.cust_no              = c.cust_no  )                                                               
                             AND ( a.area_no           LIKE :as_area          )                                                        
                             AND ( convert(char(10),a.do_date,111)  BETWEEN :as_start AND :as_end )                                    
                             AND ( a.cust_no           LIKE :as_cust          )                                                        
                             AND ( b.item_no           LIKE :as_category      )                                                        
                        /* order by 1, 2 */                                                                                            
                        ) a                                                                                                            
                    GROUP BY a.do_no                                                                                                   
               ) BB  ON aa.do_no  = bb.do_no  AND aa.oi_no  = bb.oi_no                                                                 
          ) A                                                                                                                          
      GROUP BY a.reg_no                                                                                                                
             , a.cust_name                                                                                                             
             , a.area_name                                                                                                             
             , a.cat_name                                                                                                              
             , a.cstart                                                                                                                
             , a.cend                                                                                                                  " arguments=(("as_area", string),("as_start", string),("as_end", string),("as_cust", string),("as_category", string)) )
