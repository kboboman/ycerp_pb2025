 column=(type=char(50) updatewhereclause=yes name=mgr_type1 dbname="mgr_type1" )
 column=(type=long update=yes updatewhereclause=yes name=nrow dbname="customer_grp.nrow" )
 column=(type=char(4) update=yes updatewhereclause=yes key=yes name=customer_grp_rcust_no dbname="customer_grp.rcust_no" )
 column=(type=char(50) updatewhereclause=yes name=customer_rcust_name dbname="customer.cust_name" )
 column=(type=char(10) updatewhereclause=yes name=user_name2 dbname="login.user_name" )
 column=(type=char(10) updatewhereclause=yes name=top_level2 dbname="top_level2" )
 column=(type=long updatewhereclause=yes name=mgr_sort2 dbname="mgr_sort2" )
 column=(type=char(50) updatewhereclause=yes name=mgr_type2 dbname="mgr_type2" )
 retrieve="SELECT chk          = (case when l1.user_name = l2.user_name then 'Y'
                            when c1.mgr_type  = c2.mgr_type  then 'Y'
                            else 'N' 
                       end)
     , cg.cust_no
     , c1.cust_name
     , l1.user_name
     , top_level1   = c1.top_level
     , mgr_sort1    = isnull((SELECT sort FROM codemst WHERE type = 'MGR_TYPE' and use_yn = 'Y' and item_cd = c1.mgr_type),99)
     , mgr_type1    = (SELECT item_nm FROM codemst WHERE type = 'MGR_TYPE' and use_yn = 'Y' and item_cd = c1.mgr_type)
     , cg.nrow
     , cg.rcust_no
     , c2.cust_name
     , l2.user_name
     , top_level2   = c2.top_level
     , mgr_sort2    = isnull((SELECT sort FROM codemst WHERE type = 'MGR_TYPE' and use_yn = 'Y' and item_cd = c2.mgr_type),99)
     , mgr_type2    = (SELECT item_nm FROM codemst WHERE type = 'MGR_TYPE' and use_yn = 'Y' and item_cd = c2.mgr_type)
  FROM customer_grp CG
       LEFT OUTER JOIN customer C1 ON cg.cust_no  = c1.cust_no
       LEFT OUTER JOIN customer C2 ON cg.rcust_no = c2.cust_no
       LEFT OUTER JOIN login    L1 ON c1.salesman = l1.user_id
       LEFT OUTER JOIN login    L2 ON c2.salesman = l2.user_id
" update="customer_grp" updatewhere=0 updatekeyinplace=no  sort="nrow A " )
