$PBExportHeader$d_iractio_new_excel.srd
$PBExportComments$실사목록갱신(2000/09/02)
release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=244 color="536870912" )
summary(height=92 color="536870912" )
footer(height=0 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=char(30) updatewhereclause=yes name=저장소 dbname="silsa_itemstock.저장소" )
 column=(type=char(10) updatewhereclause=yes name=담당자 dbname="login.담당자" )
 column=(type=char(60) updatewhereclause=yes name=재무팀기준물품명 dbname="재무팀기준물품명" )
 column=(type=char(60) updatewhereclause=yes name=시스템제품명 dbname="silsa_itemstock.시스템제품명" )
 column=(type=char(20) updatewhereclause=yes name=코드 dbname="silsa_itemstock.코드" )
 column=(type=char(20) updatewhereclause=yes name=규격 dbname="silsa_itemstock.규격" )
 column=(type=char(2) updatewhereclause=yes name=단위 dbname="silsa_itemstock.단위" )
 column=(type=decimal(2) updatewhereclause=yes name=실사수량 dbname="실사수량" )
 column=(type=decimal(2) updatewhereclause=yes name=차이량 dbname="차이량" )
 column=(type=decimal(6) updatewhereclause=yes name=환산차이량 dbname="환산차이량" )
 column=(type=decimal(6) updatewhereclause=yes name=환산실사수량 dbname="환산실사수량" )
 column=(type=char(40) updatewhereclause=yes name=사유 dbname="silsa_itemstock.사유" )
 column=(type=char(1) updatewhereclause=yes name=비고 dbname="비고" )
 retrieve="SELECT d.loc_name 저장소,
                login.user_name  담당자,
			dbo.uf_get_item_acct_name(a.item_no, a.qa) 재무팀기준물품명,
		     b.item_name 시스템제품명,     
               a.item_no  코드,     
               a.qa 규격,             
		     b.uom 단위,             
        	     sum(isnull(erp.stock_qty,0)) 실사수량 ,             
			sum(isnull(erp_plus_qty,0) - isnull(erp_minus_qty,0)) 차이량,
 			sum( 
                        			case when substring(a.item_no, 1,1 ) = 'M' and substring(a.item_no, 4,1 )  = '2' and b.uom = 'SH' and substring(a.item_no, 3,1 ) = 'A' then     convert(numeric, SUBSTRING(a.QA,1,3) )/100*convert(numeric, SUBSTRING(a.QA,5,4) )/1000 *convert(numeric,  SUBSTRING(a.QA,10,4) )/1000*(isnull(erp_plus_qty,0) - isnull(erp_minus_qty,0))*2.72			/* 수량 * 2.72*/
                         				    when substring(a.item_no, 1,1 ) = 'M' and substring(a.item_no, 4,1 )  = '2' and b.uom = 'SH' and substring(a.item_no, 3,1 ) = 'S' then     convert(numeric, SUBSTRING(a.QA,1,3) )/100*convert(numeric, SUBSTRING(a.QA,5,4) )/1000 *convert(numeric,  SUBSTRING(a.QA,10,4) )/1000*(isnull(erp_plus_qty,0) - isnull(erp_minus_qty,0))*8 	          /*두께*폭*길이*8*/
                        			else 
                        				        dbo.uf_getqty(  a.item_no, a.qa, b.uom,  (isnull(erp_plus_qty,0) - isnull(erp_minus_qty,0)) )  
         			                end   
                          )	 환산차이량,
 			sum( 
                        			case when substring(a.item_no, 1,1 ) = 'M' and substring(a.item_no, 4,1 )  = '2' and b.uom = 'SH' and substring(a.item_no, 3,1 ) = 'A' then     convert(numeric, SUBSTRING(a.QA,1,3) )/100*convert(numeric, SUBSTRING(a.QA,5,4) )/1000 *convert(numeric,  SUBSTRING(a.QA,10,4) )/1000*isnull(erp.stock_qty,0)*2.72			/* 수량 * 2.72*/
                         				    when substring(a.item_no, 1,1 ) = 'M' and substring(a.item_no, 4,1 )  = '2' and b.uom = 'SH' and substring(a.item_no, 3,1 ) = 'S' then     convert(numeric, SUBSTRING(a.QA,1,3) )/100*convert(numeric, SUBSTRING(a.QA,5,4) )/1000 *convert(numeric,  SUBSTRING(a.QA,10,4) )/1000*isnull(erp.stock_qty,0)*8 	          /*두께*폭*길이*8*/
                        			else 
                        				        dbo.uf_getqty(  a.item_no, a.qa, b.uom,  isnull(erp.stock_qty,0) )  
         			                end   
                          )	 환산실사수량,
			a.comment 사유,
                '' 비고
FROM silsa_itemstock a inner join groupitem b with(nolock) on a.item_no = b.item_no
								inner join location d with(nolock)  on a.loc_no = d.loc_no				
								left outer join financial_location c on a.loc_no = c.loc_no
							     left outer join login with(nolock) on a.user_id = login.user_id
/*                                          left outer join item_acct with(nolock) on a.item_no = item_acct.item_no and a.qa = item_acct.qa												*/
								left outer join (
														select 	 a.yyyymm, 
																	 a.loc_no,
																	 a.item_no,
																	 a.qa,
																	sum(a.pre_qty) erp_pre_qty,
																	sum(a.plus_qty) erp_plus_qty,
																	sum(a.minus_qty) erp_minus_qty,
																	sum(a.pre_qty) + sum(a.in_qty) - sum(a.out_qty) stock_qty
																from 
																(
								  
																			select :as_yyyymm yyyymm, 
																					inaudit.loc_no, 
																					inaudit.inaudit_item item_no, 
																					inaudit.qa, 
																					(isnull(inaudit.rcpt_qty,0)) IN_QTY, 
																					(isnull(inaudit.issue_qty,0)) OUT_QTY,
																					(case when inaudit.inaudit_type = 'RX' then isnull(inaudit.rcpt_qty,0) else 0 end) plus_qty, 
																					(case when inaudit.inaudit_type = 'IX' then isnull(inaudit.issue_qty,0) else 0 end) minus_qty,
																					0 pre_qty
/*																			from inaudit with(nolock, index(inaudit_pk))*/
																			from inaudit with(nolock)
																			  where inaudit.inaudit_date  BETWEEN convert(datetime, :as_yyyymm +'01 00:00:00' ) and   dateadd(day, -1, dateadd(month, 1, convert(datetime, :as_yyyymm +'01 23:59:59') ))                                                                                            
																				union all
																				select  :as_yyyymm yyyymm,
																						  item_stock.loc_no,                                 
																						  item_stock.item_no,
																						  item_stock.qa,
																						  0 in_qty,
																						  0 out_qty,
																						  0 plus_qty,
																						  0 minus_qty,            
																							 item_stock.stock_qty pre_qty
																				from item_stock with(nolock)
																				where item_stock.stock_date = convert(char(8), dateadd(day, -1, convert(datetime, :as_yyyymm+'01') ),112)					                                                   
															  ) a 
															group by  a.yyyymm, 
																		 a.loc_no,
																		 a.item_no,
																		 a.qa       
												) erp on a.yyyymm = erp.yyyymm and a.loc_no = erp.loc_no and a.item_no = erp.item_no and a.qa = erp.qa				

where a.yyyymm = :as_yyyymm
    and ( ( b.p4 not in ('1','2') and '2' = :as_gubun ) or ( b.p4 in ('1','2') and '1' = :as_gubun ) or  ( '%' = :as_gubun )  )
    and c.area_name = :as_loc_no
    and b.cost_yn <> 'Y'
    and a.item_no not in ('PZZZPA9ZZZ', 'PZZZPP7ZZZ') 

    and not exists (
							select b.item_no
							from
							  (
									 SELECT  item_no
									  FROM groupitem
									  WHERE groupitem.ITEM_NAME LIKE '%샘플%' or groupitem.item_name like '%LOSS%'
									  union all
									  select item_no
										from item_cost
							 ) b 
							 where  b.item_no = a.item_no
                            )

group by  d.loc_name,
			login.user_name,
		     b.item_name,     
               a.item_no,     
               a.qa,             
		     b.uom,
			a.comment
having  sum(isnull(erp.stock_qty,0)) <> 0
" arguments=(("as_loc_no", string),("as_yyyymm", string),("as_gubun", string))  sort="저장소 A 담당자 A 재무팀기준물품명 A " )
