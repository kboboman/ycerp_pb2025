$PBExportHeader$d_iocoilqoh2_s2.srd
$PBExportComments$품목별 코일재고 현황(YSP사업부)(2004/02/24,정갑용)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="536870912" )
detail(height=88 color="536870912" )
table(column=(type=char(255) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=char(7) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=long updatewhereclause=yes name=q_cnt_1 dbname="q_cnt_1" )
 column=(type=long updatewhereclause=yes name=q_cnt_3 dbname="q_cnt_3" )
 column=(type=long updatewhereclause=yes name=t_cnt_3 dbname="t_cnt_3" )
 column=(type=char(2) updatewhereclause=yes name=sort1 dbname="sort1" )
 column=(type=char(1) updatewhereclause=yes name=gb dbname="gb" )
 retrieve="SELECT item_name = REPLACE(A.item_name,'스리팅 ',''), 
		qa,
		q_cnt_1 = sum(q_cnt_1),
		q_cnt_3 = sum(q_cnt_3),
		t_cnt_3 = sum(q_cnt_1) + sum(q_cnt_3),
		sort1,
		gb
from 			
(
	  SELECT sort1 = substring(coilmst.item_no, 3, 1),
				item_name = groupitem.item_name,
				qa = substring(qa,1,1) + '.' + substring(qa,2,2),
				q_cnt_1 = sum(coilmst.unit_qty * coilmst.qcnt),
				q_cnt_3 = 0,
				gb = dbo.uf_getcoilsort(coilmst.item_no)
		 FROM coilmst,   
				groupitem, location
		WHERE ( coilmst.item_no = groupitem.item_no) and  
				( coilmst.loc_no = location.loc_no) and  
				( ( coilmst.loc_no = 'WS00000006' or  coilmst.loc_no = 'WW04' ) AND  
				  ( coilmst.flag = 'W' ) AND  
				  ( coilmst.open_close <> 'C' ) AND
				  ( substring(coilmst.item_no, 3, 1) in ('S', 'A') ) ) and
				not exists ( select * from lossitem where loss_item = coilmst.item_no)
	group by substring(coilmst.item_no, 3, 1),dbo.uf_getcoilsort(coilmst.item_no), groupitem.item_name, substring(qa,1,1) + '.' + substring(qa,2,2)
	
	union all
	
	  SELECT sort1 = substring(coilmst.item_no, 3, 1),
				item_name = groupitem.item_name,
				qa = substring(qa,1,1) + '.' + substring(qa,2,2),
				q_cnt_1 = 0,
				q_cnt_3 = sum(coilmst.unit_qty * coilmst.qcnt),
				gb = dbo.uf_getcoilsort(coilmst.item_no)
		 FROM coilmst,   
				groupitem, location
		WHERE ( coilmst.item_no = groupitem.item_no) and  
				( coilmst.loc_no = location.loc_no) and  
				( ( coilmst.loc_no = 'WS00000006' or  coilmst.loc_no = 'WW04') AND  
				  ( coilmst.flag = 'S' ) AND  
				  ( coilmst.open_close <> 'C' ) AND
				  ( substring(coilmst.item_no, 3, 1) in ('S', 'A') ) ) and
				not exists ( select * from lossitem where loss_item = coilmst.item_no)
	group by substring(coilmst.item_no, 3, 1),dbo.uf_getcoilsort(coilmst.item_no), groupitem.item_name, substring(qa,1,1) + '.' + substring(qa,2,2)
	
) A

GROUP BY sort1, gb , REPLACE(A.item_name,'스리팅 ',''),qa
"  sort="sort1 D gb A groupitem_item_name A " )
group(level=1 header.height=0 trailer.height=80 by=("sort1" ) header.color="536870912" trailer.color="536870912" )
group(level=2 header.height=0 trailer.height=88 by=("gb" ) header.color="536870912" trailer.color="553648127" )
