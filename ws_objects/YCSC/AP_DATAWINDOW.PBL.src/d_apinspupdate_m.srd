table(column=(type=char(14) update=yes updatewhereclause=yes key=yes name=insp_no dbname="insp.insp_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=supp_no dbname="insp.supp_no" )
 column=(type=datetime update=yes updatewhereclause=yes name=insp_date dbname="insp.insp_date" )
 column=(type=char(1) update=yes updatewhereclause=yes name=pur_flag dbname="insp.pur_flag" )
 column=(type=char(1) update=yes updatewhereclause=yes name=insp_flag dbname="insp.insp_flag" values="상품	S/원자재	W/부자재	B/외주가공	Y/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=invoice_print dbname="insp.invoice_print" )
 column=(type=char(3) update=yes updatewhereclause=yes name=curr_code dbname="insp.curr_code" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=curr_rate dbname="insp.curr_rate" )
 column=(type=char(10) update=yes updatewhereclause=yes name=fob dbname="insp.fob" values="현금	현금/어음	어음/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=ship_flag dbname="insp.ship_flag" values="착불	C/대여	D/부담	B/방문	M/" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=ship_amount dbname="insp.ship_amount" )
 column=(type=char(80) update=yes updatewhereclause=yes name=shipto_addr dbname="insp.shipto_addr" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=insp_cash dbname="insp.insp_cash" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=insp_rate dbname="insp.insp_rate" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=insp_total dbname="insp.insp_total" )
 column=(type=char(50) update=yes updatewhereclause=yes name=rem dbname="insp.rem" )
 column=(type=char(20) update=yes updatewhereclause=yes name=tel_no dbname="insp.tel_no" )
 column=(type=char(12) update=yes updatewhereclause=yes name=inv_no dbname="insp.inv_no" )
 column=(type=char(30) updatewhereclause=yes name=supp_supp_name dbname="supp.supp_name" )
 column=(type=datetime update=yes updatewhereclause=yes name=insp_log_date dbname="insp.log_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=insp_login_id dbname="insp.login_id" )
 column=(type=char(10) update=yes updatewhereclause=yes name=insp_area_no dbname="insp.area_no" )
 column=(type=datetime update=yes updatewhereclause=yes name=user_date dbname="insp.user_date" )
 column=(type=char(1) update=yes updatewhereclause=yes name=insp_insp_case dbname="insp.insp_case" values="미수불	C/미수불	A" )
 retrieve="  SELECT insp.insp_no,   
         insp.supp_no,   
         insp.insp_date,   
         insp.pur_flag,   
         insp.insp_flag,   
         insp.invoice_print,   
         insp.curr_code,   
         insp.curr_rate,   
         insp.fob,   
         insp.ship_flag,   
         insp.ship_amount,   
         insp.shipto_addr,   
         insp.insp_cash,   
         insp.insp_rate,   
         insp.insp_total,   
         insp.rem,   
         insp.tel_no,   
         insp.inv_no,   
         supp.supp_name,   
         insp.log_date,   
         insp.login_id,   
         insp.area_no,   
         insp.user_date,   
         insp.insp_case  
    FROM insp,   
         supp  
   WHERE ( insp.supp_no = supp.supp_no ) and  
         ( ( insp.insp_no = :aa ) )    
" update="insp" updatewhere=0 updatekeyinplace=no arguments=(("aa", string)) )
