 column=(type=char(100) update=yes updatewhereclause=yes name=maker_no dbname="yc_com_resource.maker_no" )
 column=(type=char(100) update=yes updatewhereclause=yes name=model_nm dbname="yc_com_resource.model_nm" )
 column=(type=char(4) update=yes updatewhereclause=yes name=os_type dbname="yc_com_resource.os_type" )
 column=(type=char(4) update=yes updatewhereclause=yes name=license_type dbname="yc_com_resource.license_type" )
 column=(type=char(8) update=yes updatewhereclause=yes name=maker_date dbname="yc_com_resource.maker_date" )
 column=(type=char(4) update=yes updatewhereclause=yes name=db_info dbname="yc_com_resource.db_info" )
 column=(type=char(20) update=yes updatewhereclause=yes name=ip_info dbname="yc_com_resource.ip_info" )
 column=(type=char(20) update=yes updatewhereclause=yes name=user_nm dbname="yc_com_resource.user_nm" )
 column=(type=char(40) update=yes updatewhereclause=yes name=dept_nm dbname="yc_com_resource.dept_nm" )
 column=(type=char(4) update=yes updatewhereclause=yes name=state_m dbname="yc_com_resource.state_m" )
 column=(type=char(4) update=yes updatewhereclause=yes name=state_d dbname="yc_com_resource.state_d" )
 column=(type=char(8) update=yes updatewhereclause=yes name=enter_date dbname="yc_com_resource.enter_date" )
 column=(type=char(8) update=yes updatewhereclause=yes name=delivery_date dbname="yc_com_resource.delivery_date" )
 column=(type=char(8) update=yes updatewhereclause=yes name=return_date dbname="yc_com_resource.return_date" )
 column=(type=char(8) update=yes updatewhereclause=yes name=disposal_date dbname="yc_com_resource.disposal_date" )
 column=(type=char(255) update=yes updatewhereclause=yes name=bigo dbname="yc_com_resource.bigo" )
 column=(type=char(8) update=yes updatewhereclause=yes name=input_date dbname="yc_com_resource.input_date" )
 column=(type=char(12) update=yes updatewhereclause=yes name=input_user dbname="yc_com_resource.input_user" )
 column=(type=char(8) update=yes updatewhereclause=yes name=update_date dbname="yc_com_resource.update_date" )
 column=(type=char(12) update=yes updatewhereclause=yes name=update_user dbname="yc_com_resource.update_user" )
 retrieve="select
	 a.management_no
	,a.affiliate_type
	,a.device_nm
	,a.maker_nm
	,a.maker_no
	,a.model_nm
	,a.os_type
	,a.license_type
	,a.maker_date
	,a.db_info
	,a.ip_info
	,a.user_nm
	,a.dept_nm
	,a.state_m
	,a.state_d
	,a.enter_date
	,a.delivery_date
	,a.return_date
	,a.disposal_date
	,a.bigo
	,a.input_date
	,a.input_user
	,a.update_date
	,a.update_user
from
	yc_com_resource a
where
	left(a.delivery_date,6) = :as_yyyymm or left(a.return_date,6) = :as_yyyymm
order by
	a.management_no" update="yc_com_resource" updatewhere=1 updatekeyinplace=no arguments=(("as_yyyymm", string)) )
