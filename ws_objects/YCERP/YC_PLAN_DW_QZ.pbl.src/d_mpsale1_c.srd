$PBExportComments$수주현황리스트(1998/03/28,곽용덕)
release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=72 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=68 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=order_no dbname="saledet.order_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="saledet.seq_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="saledet.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="saledet.qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="saledet.uom" )
 column=(type=decimal(2) updatewhereclause=yes name=order_qty dbname="saledet.order_qty" )
 column=(type=char(1) updatewhereclause=yes name=sale_confirm_flag dbname="sale.confirm_flag" initial=" " )
 column=(type=decimal(2) updatewhereclause=yes name=notqty dbname="notqty" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"saledet~" )  TABLE(NAME=~"sale~" )  TABLE(NAME=~"groupitem~" ) COLUMN(NAME=~"saledet.order_no~") COLUMN(NAME=~"saledet.seq_no~") COLUMN(NAME=~"saledet.item_no~") COLUMN(NAME=~"saledet.qa~") COLUMN(NAME=~"saledet.uom~") COLUMN(NAME=~"saledet.order_qty~") COLUMN(NAME=~"sale.confirm_flag~") COMPUTE(NAME=~"saledet.order_qty - (saledet.plan_qty + saledet.sol_qty + saledet.rlse_qty)  notqty~") COLUMN(NAME=~"groupitem.item_name~")    JOIN (LEFT=~"saledet.item_no~"    OP =~"=~"RIGHT=~"groupitem.item_no~"    OUTER1 =~"saledet.item_no~" )   JOIN (LEFT=~"saledet.order_no~"    OP =~"=~"RIGHT=~"sale.order_no~" ) ) " )
