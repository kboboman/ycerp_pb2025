$PBExportHeader$d_qcaudit_h1.srd
$PBExportComments$성형 중간검사 성적서(성형)(2005/05/23, 이인호)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(12) updatewhereclause=yes name=cdate dbname="cdate" )
 column=(type=char(2) updatewhereclause=yes name=flag dbname="sfcday.flag" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="groupitem.item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="sfcday.assembly_qa" )
 column=(type=decimal(4) updatewhereclause=yes name=qty dbname="qty" )
 retrieve="  SELECT cdate = convert(char(12),sfcday.sfc_date, 111),   
         flag ,
			item_no = assembly,   
         groupitem.item_name,   
         sfcday.assembly_qa,   
         qty = sum(sfcday.make_qty  )
    FROM sfcday,   
         groupitem,
			qcitemstd  
   WHERE ( sfcday.assembly = groupitem.item_no ) and  
         ( sfcday.area_no = qcitemstd.area_no ) and  
         ( sfcday.assembly like qcitemstd.item_no ) and  
         ( ( sfcday.area_no = :as_area ) AND  
         ( sfcday.wc_no = :as_wc ) AND  
         ( sfcday.sfc_date between :ad_start and :ad_end + ~" 23:59:59:999~"  ) )    
	group by convert(char(12),sfcday.sfc_date, 111),   
         flag,
			groupitem.item_name,   
         sfcday.assembly,   
         sfcday.assembly_qa " arguments=(("as_area", string),("as_wc", string),("ad_start", date),("ad_end", date))  sort="flag A cdate A item_name A qa A " )
group(level=1 header.height=0 trailer.height=76 by=("flag" , "cdate" , "item_name" , "left( qa ,14)" ) header.color="536870912" trailer.color="15780518" )
