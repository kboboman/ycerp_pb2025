 column=(type=char(60) updatewhereclause=yes name=ret_ret_reason1 dbname="ret.ret_reason1" )
 column=(type=char(60) updatewhereclause=yes name=ret_ret_reason2 dbname="ret.ret_reason2" )
 column=(type=char(60) updatewhereclause=yes name=ret_ret_reason3 dbname="ret.ret_reason3" )
