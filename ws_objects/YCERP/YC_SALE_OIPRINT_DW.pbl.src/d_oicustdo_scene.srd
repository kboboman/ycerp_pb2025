table(column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(11) updatewhereclause=yes name=scene_code dbname="scene_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=char(10) updatewhereclause=yes name=scene_charge dbname="scene_charge" )
 column=(type=char(10) updatewhereclause=yes name=area_nm dbname="area_nm" )
 column=(type=char(20) updatewhereclause=yes name=project_nm dbname="project_nm" )
 column=(type=char(20) updatewhereclause=yes name=owner dbname="owner" )
 column=(type=char(15) updatewhereclause=yes name=tel dbname="scene_tel" )
 column=(type=char(40) updatewhereclause=yes name=scene_scale dbname="scene_scale" )
 column=(type=char(80) updatewhereclause=yes name=addr dbname="scene_addr" )
 column=(type=char(80) updatewhereclause=yes name=rem dbname="rem" )
 column=(type=char(10) updatewhereclause=yes name=input_date dbname="input_date" )
 column=(type=char(10) updatewhereclause=yes name=do_date dbname="do_date" )
 column=(type=decimal(3) updatewhereclause=yes name=c_amt dbname="c_amt" )
 retrieve="  SELECT user_name   = l.user_name
       , cust_no     = a.cust_no        
       , cust_name   = c.cust_name      
       , scene_code  = a.scene_code      
       , scene_desc  = a.scene_desc     
       , scene_charge= a.scene_charge   
       , area_nm     = a.area_nm        
       , project_nm  = a.project_nm     
       , owner       = a.owner          
       , scene_tel   = isnull(a.scene_tel   , '')
       , scene_scale = isnull(a.scene_scale , '')
       , scene_addr  = isnull(a.scene_addr  , '')
       , rem         = isnull(a.rem         , '')
       , input_date  = convert(char(10),a.input_date,111)
       , do_date     = convert(char(10),d.do_date,   111)
       , c_amt       = b.c_amt
    FROM scene  A 
         INNER JOIN (
              SELECT cust_no     = c.cust_no         
                   , spot_code   = c.spot_code       
                   , c_amt       = sum(c.c_amt)
                FROM (
                     SELECT a.cust_no                                                                              
                          , a.spot_code                                                                            
                          , a.do_date    
                          , a.sale_no                                                                           
                          , a.do_no                                                                                
                          , a.oi_no                                                                             
                          , a.item_no                                                                           
                          , a.qa                                                                                
                          , a.uom                                                                               
                          , a.ship_amount                                                                          
                          , a.do_rate                                                                              
                          , a.do_cash                                                                              
                          , a.do_total                                                                             
                          , a.ship_qty                                                                          
                          , a.c_acc_qty
                          , a.price                                                                             
                          , a.rate_cash                                                                         
                          , c_amt = (case when b.round = 'Y' then 
                                               (case when a.curr_code = 'WON' then 
                                                          (case when a.c_acc_qty < 0 then round(a.price * a.c_acc_qty, 0)
                                                                else round(a.price * a.c_acc_qty, 0)
                                                           end)
                                                     else round(a.price  *  a.c_acc_qty, 2)
                                                end)
                                          else (case when a.curr_code = 'WON' then 
                                                          (case when a.c_acc_qty < 0 then floor(a.price * a.c_acc_qty)
                                                                else floor(a.price * a.c_acc_qty + 0.000001)
                                                           end)
                                                     else floor(a.price  *  a.c_acc_qty)
                                                end)
                                     end) + a.rate_cash
                                   + (case when a.ship_flag2 = 'D' and a.shipamt_case = 'R' then
                                                (case when a.do_rate <> 0 then a.ship_amount * 1.1
                                                      else a.ship_amount
                                                 end)
                                           else 0
                                      end) /* 운반비 */
                       FROM (
                            SELECT do.cust_no                                    
                                 , do.spot_code                                  
                                 , do_date    = convert(char(10),do.do_date,111)
                                 , ship_flag  = dbo.uf_getshipflag(do.ship_flag) 
                                 , ship_flag2 = do.ship_flag                     
                                 , dodet.sale_no                                 
                                 , do.curr_code                                  
                                 , do.shipamt_case                               
                                 , do.do_no                                      
                                 , dodet.oi_no                                   
                                 , dodet.item_no                                 
                                 , dodet.qa                                      
                                 , dodet.uom                                     
                                 , do.ship_amount                                
                                 , do.do_rate                                    
                                 , do.do_cash                                    
                                 , do.do_total                                   
                                 , dodet.ship_qty                                
                                 , dodet.price                                   
                                 , dodet.rate_cash                               
                                 , c_acc_qty = round(dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty),2,1)
                              FROM do
                                   INNER JOIN  dodet      ON do.do_no   = dodet.do_no
                             WHERE do_date     between :ad_sdate and :ad_edate
                               AND do.area_no     LIKE :as_area
                            ) A
                            INNER JOIN customer B  ON a.cust_no = b.cust_no
                     ) C
                 GROUP BY c.cust_no, c.spot_code
         ) B  ON a.scene_code = b.spot_code

         LEFT OUTER JOIN (
              SELECT do.cust_no                                    
                   , do.spot_code                                  
                   , do_date    = convert(char(10),max(do.do_date),111)
                FROM do
               WHERE do_date     between :ad_sdate and :ad_edate 
                 AND do.area_no     LIKE :as_area
               GROUP BY do.cust_no                                    
                   , do.spot_code                                  
         ) D  ON a.cust_no = d.cust_no  AND a.scene_code = d.spot_code

         LEFT OUTER JOIN customer C  ON a.cust_no  = c.cust_no
         LEFT OUTER JOIN login    L  ON c.salesman = l.user_id
   WHERE ((:as_custno    = '%'  ) OR 
          (:as_custno    = 'ALL') OR 
          (:as_custno   <> 'ALL' AND a.cust_no  = :as_custno)
         )
     AND ((:as_salesman  = '%'  ) OR
          (:as_salesman <> '%'   AND c.salesman = :as_salesman)
         )
" arguments=(("as_area", string),("as_custno", string),("as_salesman", string),("ad_sdate", date),("ad_edate", date))  sort="cust_name A scene_code D " )
