table(column=(type=char(17) updatewhereclause=yes name=mpsdet_plan_no dbname="mpsdet.plan_no" )
 column=(type=char(17) updatewhereclause=yes name=mpsdet_order_no dbname="mpsdet.order_no" initial=" " )
 column=(type=char(10) updatewhereclause=yes name=mpsdet_item_no dbname="mpsdet.item_no" initial=" " )
 column=(type=char(20) updatewhereclause=yes name=mpsdet_qa dbname="mpsdet.qa" )
 column=(type=long updatewhereclause=yes name=mpsdet_division dbname="mpsdet.division" )
 column=(type=char(1) updatewhereclause=yes name=mps_open_close dbname="mps.open_close" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"mpsdet~" )  TABLE(NAME=~"mps~" ) COLUMN(NAME=~"mpsdet.plan_no~") COLUMN(NAME=~"mpsdet.order_no~") COLUMN(NAME=~"mpsdet.item_no~") COLUMN(NAME=~"mpsdet.qa~") COLUMN(NAME=~"mpsdet.division~") COLUMN(NAME=~"mps.open_close~")    JOIN (LEFT=~"mpsdet.order_no~"    OP =~"=~"RIGHT=~"mps.order_no~" )WHERE(    EXP1 =~"mpsdet.sale_no~"   OP =~"=~"    EXP2 =~":arg_sale~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"mpsdet.seq_no~"   OP =~"=~"    EXP2 =~":arg_seq~" ) ) ARG(NAME = ~"arg_sale~" TYPE = string)  ARG(NAME = ~"arg_seq~" TYPE = number) " arguments=(("arg_sale", string),("arg_seq", number)) )
