$PBExportComments$거래처별 그룹물품관리
release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=1 selected.mouse=no )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=supp_no dbname="suppgroupdet.supp_no" )
 column=(type=char(2) update=yes updatewhereclause=yes key=yes name=group_no dbname="suppgroupdet.group_no" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="suppgroupdet.item_no" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=price dbname="suppgroupdet.price" initial="0" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="groupitem.item_name" )
 retrieve="  SELECT suppgroupdet.supp_no,   
         suppgroupdet.group_no,   
         suppgroupdet.item_no,   
         suppgroupdet.price,   
         groupitem.item_name  
    FROM suppgroupdet,   
         groupitem  
   WHERE ( suppgroupdet.item_no = groupitem.item_no ) and  
         ( ( suppgroupdet.supp_no = :as_supp ) AND  
         ( suppgroupdet.group_no = :as_group ) )    
" update="suppgroupdet" updatewhere=0 updatekeyinplace=no arguments=(("as_supp", string),("as_group", string)) )
