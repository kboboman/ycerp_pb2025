table(column=(type=char(8) updatewhereclause=yes name=cust_sale_lot_no dbname="cust_sale.lot_no" )
 column=(type=char(6) updatewhereclause=yes name=cust_sale_yyyymm dbname="cust_sale.yyyymm" )
