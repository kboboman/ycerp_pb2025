$PBExportHeader$d_whitemret_s4.srd
$PBExportComments$품목별 재고현황(상세수불현황)(2003/07/21,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=496 color="536870912" )
summary(height=72 color="536870912" )
footer(height=148 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(30) updatewhereclause=yes name=loc_name dbname="loc_name" )
 column=(type=char(30) updatewhereclause=yes name=dt dbname="dt" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_nm dbname="item_nm" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=datetime updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=datetime updatewhereclause=yes name=edate dbname="edate" )
 column=(type=decimal(4) updatewhereclause=yes name=m_iqty dbname="m_iqty" )
 column=(type=decimal(4) updatewhereclause=yes name=a_iqty dbname="a_iqty" )
 column=(type=decimal(2) updatewhereclause=yes name=v_iqty dbname="v_iqty" )
 column=(type=decimal(2) updatewhereclause=yes name=r_iqty dbname="r_iqty" )
 column=(type=decimal(2) updatewhereclause=yes name=n_iqty dbname="n_iqty" )
 column=(type=decimal(2) updatewhereclause=yes name=w_iqty dbname="w_iqty" )
 column=(type=decimal(2) updatewhereclause=yes name=d_oqty dbname="d_oqty" )
 column=(type=decimal(4) updatewhereclause=yes name=a_oqty dbname="a_oqty" )
 column=(type=decimal(2) updatewhereclause=yes name=v_oqty dbname="v_oqty" )
 column=(type=decimal(4) updatewhereclause=yes name=p_oqty dbname="p_oqty" )
 column=(type=decimal(4) updatewhereclause=yes name=w_oqty dbname="w_oqty" )
 column=(type=decimal(4) updatewhereclause=yes name=u_oqty dbname="u_oqty" )
 column=(type=decimal(4) updatewhereclause=yes name=j_oqty dbname="j_oqty" )
 retrieve="SELECT loc_name    = l.loc_name
     , dt          = convert(varchar, s.dt, 112)
     , item_no     = y.item_no
     , item_nm     = y.item_nm
     , qa          = y.qa
     , uom         = y.uom
     , sdate       = convert(smalldatetime, :as_sdate, 111)
     , edate       = convert(smalldatetime, :as_edate, 111)
     , m_iqty      = s.m_iqty  /*(생산)입고*/
     , a_iqty      = s.a_iqty  /*대체(입고)*/
     , v_iqty      = s.v_iqty  /*저장소이동(입고)*/
     , r_iqty      = s.r_iqty  /*반품(입고)*/
     , n_iqty      = s.n_iqty  /*무상(입고)*/
     , w_iqty      = s.w_iqty  /*가공(입고)*/
                       
     , d_oqty      = s.d_oqty  /*정상(출고)*/
     , a_oqty      = s.a_oqty  /*대체(출고)*/
     , v_oqty      = s.v_oqty  /*저장소이동(출고)*/
     , p_oqty      = s.p_oqty  /*폐기*/
     , w_oqty      = s.w_oqty  /*가공(출고)*/
     , u_oqty      = s.u_oqty  /*작업일보사용*/
     , j_oqty      = s.j_oqty  /*(재고생산)출고*/
  FROM (
         SELECT dt       = convert(varchar, d.sfc_date, 112) 
              , item_no  = d.assembly                        
              , qa       = d.assembly_qa                     
              , m_iqty   = d.make_qty                        /*(생산)입고*/
              , a_iqty   = 0                                 
              , v_iqty   = 0                                 
              , r_iqty   = 0                                 
              , n_iqty   = 0                                 
              , w_iqty   = 0                                 
              , d_oqty   = 0                                 
              , a_oqty   = 0                                 
              , v_oqty   = 0                                 
              , p_oqty   = 0                                 
              , w_oqty   = 0                                 
              , u_oqty   = 0                                 
              , j_oqty   = 0                                 
              , qoh      = 0                                 
           FROM sfcday d
          WHERE convert(char(10),d.sfc_date,111)  between :as_sdate and :as_edate
            AND d.loc_no         = :as_loc_no
            AND d.assembly       = :as_item_no
            AND d.assembly_qa    = :as_qa
            
         UNION ALL
         SELECT dt       = convert(varchar, d.alter_date, 112)
              , item_no  = d.tar_item                         
              , qa       = d.tar_qa                           
              , m_iqty   = 0                                  
              , a_iqty   = d.tar_qty                          /*대체입고*/
              , v_iqty   = 0                                  
              , r_iqty   = 0                                  
              , n_iqty   = 0                                  
              , w_iqty   = 0                                  
              , d_oqty   = 0                                  
              , a_oqty   = 0                                  
              , v_oqty   = 0                                  
              , p_oqty   = 0                                  
              , w_oqty   = 0                                  
              , u_oqty   = 0                                  
              , j_oqty   = 0                                  
              , qoh      = 0                                  
           FROM itemalter d
          WHERE convert(char(10),d.alter_date,111) between :as_sdate and :as_edate
            AND d.tar_loc  = :as_loc_no
            AND d.tar_item = :as_item_no
            AND d.tar_qa   = :as_qa
            
         UNION ALL
         SELECT dt       = convert(varchar, d.rlse_date, 112) 
              , item_no  = d.item_no                          
              , qa       = d.qa                               
              , m_iqty   = 0                                  
              , a_iqty   = 0                                  
              , v_iqty   = d.rlse_qty                         /*저장소이동(입고)*/
              , r_iqty   = 0                                  
              , n_iqty   = 0                                  
              , w_iqty   = 0                                  
              , d_oqty   = 0                                  
              , a_oqty   = 0                                  
              , v_oqty   = 0                                  
              , p_oqty   = 0                                  
              , w_oqty   = 0                                  
              , u_oqty   = 0                                  
              , j_oqty   = 0                                  
              , qoh      = 0                                  
           FROM ask_head h,
                ask_det  d
          WHERE h.ask_no   = d.ask_no
            AND convert(char(10),d.rlse_date,111) between :as_sdate and :as_edate
            AND h.ask_loc  = :as_loc_no
            AND d.item_no  = :as_item_no
            AND d.qa       = :as_qa
            
         UNION ALL
         SELECT dt       = convert(varchar, h.issue_date, 112)
              , item_no  = d.item_no                          
              , qa       = d.qa                               
              , m_iqty   = 0                                  
              , a_iqty   = 0                                  
              , v_iqty   = 0                                  
              , r_iqty   = d.ship_qty                         /*반품(입고)*/
              , n_iqty   = 0                                  
              , w_iqty   = 0                                  
              , d_oqty   = 0                                  
              , a_oqty   = 0                                  
              , v_oqty   = 0                                  
              , p_oqty   = 0                                  
              , w_oqty   = 0                                  
              , u_oqty   = 0                                  
              , j_oqty   = 0                                  
              , qoh      = 0                                  
           FROM do h,
                dodet d
          WHERE convert(char(10),h.issue_date,111) between :as_sdate and :as_edate
            AND h.do_no   = d.do_no
            AND h.do_case = 'd'
            AND d.loc_no  = :as_loc_no
            AND d.item_no = :as_item_no
            AND d.qa      = :as_qa
            
         UNION ALL
         SELECT dt       = convert(varchar, h.ret_date, 112)
              , item_no  = d.item_no                        
              , qa       = d.qa                             
              , m_iqty   = 0                                
              , a_iqty   = 0                                
              , v_iqty   = 0                                
              , r_iqty   = 0                                
              , n_iqty   = d.free_qty                       /*무상(입고)*/
              , w_iqty   = 0                                
              , d_oqty   = 0                                
              , a_oqty   = 0                                
              , v_oqty   = 0                                
              , p_oqty   = 0                                
              , w_oqty   = 0                                
              , u_oqty   = 0                                
              , j_oqty   = 0                                
              , qoh      = 0                                
           FROM ret    h,
                retdet d
          WHERE convert(char(10),h.ret_date,111)    between :as_sdate and :as_edate
            AND h.ret_no  = d.ret_no
            AND h.process_flag not in ('o', 'y')
            AND d.loc_no  = :as_loc_no
            AND d.item_no = :as_item_no
            AND d.qa      = :as_qa
            
         UNION ALL
         SELECT dt       = convert(varchar, h.insp_date, 112)
              , item_no  = d.item_no                         
              , qa       = d.qa                              
              , m_iqty   = 0                                 
              , a_iqty   = 0                                 
              , v_iqty   = 0                                 
              , r_iqty   = 0                                 
              , n_iqty   = 0                                 
              , w_iqty   = d.rcpt_qty                        /*가공입고*/
              , d_oqty   = 0                                 
              , a_oqty   = 0                                 
              , v_oqty   = 0                                 
              , p_oqty   = 0                                 
              , w_oqty   = 0                                 
              , u_oqty   = 0                                 
              , j_oqty   = 0                                 
              , qoh      = 0                                 
           FROM insp h,
                inspdet d
          WHERE convert(char(10),h.insp_date,111) between :as_sdate and :as_edate
            AND h.insp_no = d.insp_no
            AND d.loc_no  = :as_loc_no
            AND d.item_no = :as_item_no
            AND d.qa      = :as_qa
            
         UNION ALL
         SELECT dt       = convert(varchar, h.issue_date, 112)
              , item_no  = d.item_no                          
              , qa       = d.qa                               
              , m_iqty   = 0                                  
              , a_iqty   = 0                                  
              , v_iqty   = 0                                  
              , r_iqty   = 0                                  
              , n_iqty   = 0                                  
              , w_iqty   = 0                                  
              , d_oqty   = d.ship_qty                         /*출고(정상)*/
              , a_oqty   = 0                                  
              , v_oqty   = 0                                  
              , p_oqty   = 0                                  
              , w_oqty   = 0                                  
              , u_oqty   = 0                                  
              , j_oqty   = 0                                  
              , qoh      = 0                                  
           FROM do h,
                dodet d
          WHERE convert(char(10),h.issue_date,111) between :as_sdate and :as_edate
            AND h.do_no    = d.do_no
            AND h.do_case IN ('A', 'B')
            AND d.loc_no   = :as_loc_no
            AND d.item_no  = :as_item_no
            AND d.qa       = :as_qa
            
         UNION ALL
         SELECT dt       = convert(varchar, d.alter_date, 112)
              , item_no  = d.src_item                         
              , qa       = d.src_qa                           
              , m_iqty   = 0                                  
              , a_iqty   = 0                                  
              , v_iqty   = 0                                  
              , r_iqty   = 0                                  
              , n_iqty   = 0                                  
              , w_iqty   = 0                                  
              , d_oqty   = 0                                  
              , a_oqty   = d.src_qty                          /*대체출고*/
              , v_oqty   = 0                                  
              , p_oqty   = 0                                  
              , w_oqty   = 0                                  
              , u_oqty   = 0                                  
              , j_oqty   = 0                                  
              , qoh      = 0                                  
           FROM itemalter d
          WHERE convert(char(10),d.alter_date,111) between :as_sdate and :as_edate
            AND d.src_loc  = :as_loc_no
            AND d.src_item = :as_item_no
            AND d.src_qa   = :as_qa
            
         UNION ALL
         SELECT dt       = convert(varchar, d.rlse_date, 112)
              , item_no  = d.item_no                         
              , qa       = d.qa                              
              , m_iqty   = 0                                 
              , a_iqty   = 0                                 
              , v_iqty   = 0                                 
              , r_iqty   = 0                                 
              , n_iqty   = 0                                 
              , w_iqty   = 0                                 
              , d_oqty   = 0                                 
              , a_oqty   = 0                                 
              , v_oqty   = d.rlse_qty                        /*저장소이동(출고)*/
              , p_oqty   = 0                                 
              , w_oqty   = 0                                 
              , u_oqty   = 0                                 
              , j_oqty   = 0                                 
              , qoh      = 0                                 
           FROM ask_head h,
                ask_det d
          WHERE h.ask_no = d.ask_no
            AND convert(char(10),d.rlse_date,111) between :as_sdate and :as_edate
            AND d.loc_no  = :as_loc_no
            AND d.item_no = :as_item_no
            AND d.qa      = :as_qa
            
         UNION ALL
         SELECT dt       = h.aban_date 
              , item_no  = d.item_no   
              , qa       = d.qa        
              , m_iqty   = 0           
              , a_iqty   = 0           
              , v_iqty   = 0           
              , r_iqty   = 0           
              , n_iqty   = 0           
              , w_iqty   = 0           
              , d_oqty   = 0           
              , a_oqty   = 0           
              , v_oqty   = 0           
              , p_oqty   = d.qty       /*폐기*/
              , w_oqty   = 0           
              , u_oqty   = 0           
              , j_oqty   = 0           
              , qoh      = 0           
           FROM itemaban h
              , itemabandet d
          WHERE convert(char(10),h.aban_date,111) between :as_sdate and :as_edate
            AND h.loc_no   = :as_loc_no
            AND d.item_no  = :as_item_no
            AND d.qa       = :as_qa
            AND h.aban_no  = d.aban_no
                
         UNION ALL
         SELECT dt       = convert(varchar, d.issue_date, 112)
              , item_no  = d.component                        
              , qa       = d.component_qa                     
              , m_iqty   = 0                                  
              , a_iqty   = 0                                  
              , v_iqty   = 0                                  
              , r_iqty   = 0                                  
              , n_iqty   = 0                                  
              , w_iqty   = 0                                  
              , d_oqty   = 0                                  
              , a_oqty   = 0                                  
              , v_oqty   = 0                                  
              , p_oqty   = 0                                  
              , w_oqty   = d.issue_qty                        /*가공출고*/
              , u_oqty   = 0                                  
              , j_oqty   = 0                                  
              , qoh      = 0                                  
           FROM sudodet d
          WHERE convert(char(10),d.issue_date,111) between :as_sdate and :as_edate
            AND d.issue_loc     = :as_loc_no
            AND d.component     = :as_item_no
            AND d.component_qa  = :as_qa
            
         UNION ALL
         SELECT dt       = convert(varchar, d.use_date, 112)
              , item_no  = d.item_no                        
              , qa       = d.qa                             
              , m_iqty   = 0                                
              , a_iqty   = 0                                
              , v_iqty   = 0                                
              , r_iqty   = 0                                
              , n_iqty   = 0                                
              , w_iqty   = 0                                
              , d_oqty   = 0                                
              , a_oqty   = 0                                
              , v_oqty   = 0                                
              , p_oqty   = 0                                
              , w_oqty   = 0                                
              , u_oqty   = d.use_qty                        /*작업일보사용*/
              , j_oqty   = 0                                
              , qoh      = 0                                
           FROM sfcuse d
          WHERE convert(char(10),d.use_date,111) between :as_sdate and :as_edate
            AND d.loc_no  = :as_loc_no
            AND d.item_no = :as_item_no
            AND d.qa      = :as_qa
            
         UNION ALL
         SELECT dt       = convert(varchar, d.order_dt, 112)
              , item_no  = d.assy_item                      
              , qa       = d.assy_qa                        
              , m_iqty   = 0                                
              , a_iqty   = 0                                
              , v_iqty   = 0                                
              , r_iqty   = 0                                
              , n_iqty   = 0                                
              , w_iqty   = 0                                
              , d_oqty   = 0                                
              , a_oqty   = 0                                
              , v_oqty   = 0                                
              , p_oqty   = 0                                
              , w_oqty   = 0                                
              , u_oqty   = 0                                
              , j_oqty   = d.out_qty                        /*(재고생산)출고*/
              , qoh      = 0                                
           FROM jajaesudo d
          WHERE convert(char(10),d.order_dt,111)  between :as_sdate and :as_edate
            AND d.issue_loc  = :as_loc_no
            AND d.assy_item  = :as_item_no
            AND d.assy_qa    = :as_qa
       ) S,
       (
         SELECT item_no  = i.item_no   
              , qa       = i.qa        
              , item_nm  = i.item_name 
              , uom      = i.uom       
           FROM item i
          WHERE i.item_no = :as_item_no
            AND i.qa      = :as_qa
       ) Y,
       (
         SELECT loc_no, loc_name
           FROM location
          WHERE location.loc_no = :as_loc_no
       ) L       
 WHERE y.item_no       = s.item_no
   AND y.qa            = s.qa
   AND l.loc_no        = :as_loc_no
 ORDER BY l.loc_name, y.item_no, y.qa, convert(varchar, s.dt, 112)
" arguments=(("as_sdate", string),("as_edate", string),("as_loc_no", string),("as_item_no", string),("as_qa", string)) )
text(band=header alignment="1" text="대체" border="0" color="33554432" x="2848" y="424" height="60" width="370" html.valueishtml="0"  name=t_14 visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
