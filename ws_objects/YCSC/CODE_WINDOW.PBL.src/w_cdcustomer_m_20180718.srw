	if wf_nullchk(tab_1.tabpage_4.dw_17) = false then
		return
	end if	
	wf_update2(tab_1.tabpage_4.dw_17, tab_1.tabpage_4.dw_8, "Y")
else
	messagebox("오류","입력된 정보가 없습니다.")
	return
end if	

