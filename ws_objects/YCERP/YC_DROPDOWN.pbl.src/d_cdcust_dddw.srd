$PBExportComments$거래처dropdowndatawindow(1998/03/16, 정재수)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=68 color="8421504" )
detail(height=68 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=cust_no dbname="customer.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=decimal(2) updatewhereclause=yes name=opeomamt dbname="opeomamt" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="login.user_name" )
 retrieve="  SELECT customer.cust_no
       , customer.cust_name
       , opeomamt   = d.balbf_amount + 
                    ( d.inv_01  + d.inv_02  + d.inv_03  + d.inv_04  + d.inv_05  + d.inv_06    + 
                      d.inv_07  + d.inv_08  + d.inv_09  + d.inv_10  + d.inv_11  + d.inv_12  ) - 
                    ( d.coll_01 + d.coll_02 + d.coll_03 + d.coll_04 + d.coll_05 + d.coll_06   + 
                      d.coll_07 + d.coll_08 + d.coll_09 + d.coll_10 + d.coll_11 + d.coll_12 )
       , login.user_name  
    FROM customer (nolock) 
         LEFT OUTER JOIN login   (nolock) ON customer.salesman = login.user_id 
         LEFT OUTER JOIN opeom D (nolock) ON customer.cust_no  = d.cust_no AND ( datepart(year,d.eom_year) = year(getdate()) )
   WHERE customer.open_close <> 'C'   
   ORDER BY customer.cust_name ASC,   
            customer.cust_no   ASC   
"  sort="cust_name A " )
