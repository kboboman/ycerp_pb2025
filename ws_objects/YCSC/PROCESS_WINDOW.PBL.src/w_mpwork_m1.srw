DateTime ld_time

SELECT TOP 1 convert(char(23),getdate(), 121) INTO :ls_time FROM LOGIN;

ll_row = dw8.rowcount()
for lY = 1 to ll_row
	if dw8.object.chk[ly] = "1" then
		ll_dw9row = dw9.insertrow(0)

		ls_sfcdate = string( dw_2.object.work_date[1], "yyyy/mm/dd")
		if dw_2.object.wc_no[1] <> dw8.object.team_code[lY] then
			ls_teamcode    = dw8.object.team_code[lY]
			SELECT team_name INTO :ls_teamname FROM TEAM WHERE team_code = :ls_teamcode;
			ls_bigo = "지원[" + ls_teamname + "]"
