$PBExportComments$저장소규격(1998/10/08,곽용덕)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=68 color="536870912" )
table(column=(type=decimal(4) updatewhereclause=yes name=qoh dbname="qoh" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="item.qa" )
 retrieve="  SELECT qoh = isnull(itemloc.qoh, 0),   
                  item.qa  
    FROM item LEFT OUTER JOIN itemloc ON  item.item_no = itemloc.item_no AND item.qa = itemloc.qa
   WHERE  itemloc.loc_no = :as_loc
         AND  item.item_no = :as_item 
		and item.use_flag = 'Y'" arguments=(("as_loc", string),("as_item", string))  sort="qa A " )
column(band=detail id=1 alignment="1" tabsequence=32766 border="0" color="0" x="658" y="4" height="60" width="384" format="#,##0.00" html.valueishtml="0"  name=qoh visible="1" edit.limit=0 edit.case=any edit.autoselect=yes edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="0" background.color="536870912~tif(getrow()=currentrow(), rgb(254, 252, 175), 1087434968)" )
column(band=detail id=2 alignment="2" tabsequence=32766 border="0" color="0" x="5" y="4" height="60" width="640" format="[general]" html.valueishtml="0"  name=qa visible="1" edit.limit=0 edit.case=any edit.autoselect=yes edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="0" background.color="536870912~tif(getrow()=currentrow(), rgb(254, 252, 175), 1087434968)" )
htmltable(border="1" )
