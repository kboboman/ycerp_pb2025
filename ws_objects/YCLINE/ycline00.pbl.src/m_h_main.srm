$PBExportComments$생산현장 메인메뉴
forward
global type m_h_main from menu
end type
type m_manage from menu within m_h_main
end type
type m_line from menu within m_manage
end type
type m_sliting from menu within m_manage
end type
type m_coilmove from menu within m_manage
end type
type m_- from menu within m_manage
end type
type m_scaning from menu within m_manage
end type
type m_-44 from menu within m_manage
end type
type m_exit1 from menu within m_manage
end type
type m_manage from menu within m_h_main
m_line m_line
m_sliting m_sliting
m_coilmove m_coilmove
m_- m_-
m_scaning m_scaning
m_-44 m_-44
m_exit1 m_exit1
end type
type m_utility from menu within m_h_main
end type
type m_ezhelp from menu within m_utility
end type
type m_winvnc from menu within m_utility
end type
type m_librarys from menu within m_utility
end type
type m_utility from menu within m_h_main
m_ezhelp m_ezhelp
m_winvnc m_winvnc
m_librarys m_librarys
end type
type m_window from menu within m_h_main
end type
type m_leftmenu from menu within m_window
end type
type m_layered from menu within m_window
end type
type m_cascade from menu within m_window
end type
type m_window from menu within m_h_main
m_leftmenu m_leftmenu
m_layered m_layered
m_cascade m_cascade
end type
global type m_h_main from menu
m_manage m_manage
m_utility m_utility
m_window m_window
end type
end forward

global type m_h_main from menu
m_manage m_manage
m_utility m_utility
m_window m_window
end type
global m_h_main m_h_main

on m_h_main.create
m_h_main=this
call super::create
this.m_manage=create m_manage
this.m_utility=create m_utility
this.m_window=create m_window
this.Item[UpperBound(this.Item)+1]=this.m_manage
this.Item[UpperBound(this.Item)+1]=this.m_utility
this.Item[UpperBound(this.Item)+1]=this.m_window
end on

on m_h_main.destroy
call super::destroy
destroy(this.m_manage)
destroy(this.m_utility)
destroy(this.m_window)
end on

type m_manage from menu within m_h_main
m_line m_line
m_sliting m_sliting
m_coilmove m_coilmove
m_- m_-
m_scaning m_scaning
m_-44 m_-44
m_exit1 m_exit1
end type

on m_manage.create
call super::create
this.text = "생산현장(&Manage)"
this.m_line=create m_line
this.m_sliting=create m_sliting
this.m_coilmove=create m_coilmove
this.m_-=create m_-
this.m_scaning=create m_scaning
this.m_-44=create m_-44
this.m_exit1=create m_exit1
this.Item[UpperBound(this.Item)+1]=this.m_line
this.Item[UpperBound(this.Item)+1]=this.m_sliting
this.Item[UpperBound(this.Item)+1]=this.m_coilmove
this.Item[UpperBound(this.Item)+1]=this.m_-
this.Item[UpperBound(this.Item)+1]=this.m_scaning
this.Item[UpperBound(this.Item)+1]=this.m_-44
this.Item[UpperBound(this.Item)+1]=this.m_exit1
end on

on m_manage.destroy
call super::destroy
destroy(this.m_line)
destroy(this.m_sliting)
destroy(this.m_coilmove)
destroy(this.m_-)
destroy(this.m_scaning)
destroy(this.m_-44)
destroy(this.m_exit1)
end on

type m_line from menu within m_manage
end type

event clicked;// 다른 윈도우는 모두 닫고 실행함
DO UNTIL Not IsValid( w_h_main.GetActiveSheet() )
	close( w_h_main.GetActiveSheet() )	
LOOP

//
OpenSheetWithParm(w_line, This.Text + '[w_line]', ParentWindow, 6, Layered!)

end event

on m_line.create
call super::create
this.text = "생산라인"
end on

on m_line.destroy
call super::destroy
end on

