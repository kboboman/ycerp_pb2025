detail(height=484 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=loc_no dbname="itemstock.loc_no" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="itemstock.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=qa dbname="itemstock.qa" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=qty dbname="itemstock.qty" )
 column=(type=char(60) update=yes updatewhereclause=yes name=reason1 dbname="itemstock.reason1" )
 column=(type=char(60) update=yes updatewhereclause=yes name=reason2 dbname="itemstock.reason2" )
 column=(type=char(60) update=yes updatewhereclause=yes name=reason3 dbname="itemstock.reason3" )
 column=(type=char(10) update=yes updatewhereclause=yes name=chk1_user dbname="itemstock.chk1_user" )
 column=(type=char(10) update=yes updatewhereclause=yes name=chk2_user dbname="itemstock.chk2_user" )
 column=(type=datetime update=yes updatewhereclause=yes name=user_date dbname="itemstock.user_date" )
 column=(type=char(1) update=yes updatewhereclause=yes name=reason_code dbname="itemstock.reason_code" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="GroupItem.uom" )
 column=(type=decimal(4) updatewhereclause=yes name=loc_qoh dbname="loc_qoh" )
 retrieve="  SELECT itemstock.loc_no,   
         itemstock.item_no,   
         itemstock.qa,   
         itemstock.qty,   
         itemstock.reason1,   
         itemstock.reason2,   
         itemstock.reason3,   
         itemstock.chk1_user,   
         itemstock.chk2_user,   
         itemstock.user_date,   
         itemstock.reason_code,   
         groupitem.item_name,
			groupitem.uom,
			loc_qoh = itemloc.qoh 
    FROM itemstock inner join groupitem on  itemstock.item_no = groupitem.item_no
                                 left outer join  itemloc on itemstock.loc_no = itemloc.loc_no and itemstock.item_no = itemloc.item_no and itemstock.qa = itemloc.qa
   WHERE ( 
                    ( itemstock.loc_no = :as_loc ) AND  
                    ( itemstock.item_no = :as_item ) AND  
                    ( itemstock.qa = :as_qa )
                  )
" update="itemstock" updatewhere=0 updatekeyinplace=no arguments=(("as_loc", string),("as_item", string),("as_qa", string)) )
