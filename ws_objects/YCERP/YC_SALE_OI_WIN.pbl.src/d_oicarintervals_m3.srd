$PBExportHeader$d_oicarintervals_m3.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 grid.columnmove=no selected.mouse=no )
header(height=164 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=char(12) updatewhereclause=yes name=username dbname="username" )
 column=(type=char(10) updatewhereclause=yes name=salesman_name dbname="salesman_name" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(11) updatewhereclause=yes name=scene_code dbname="scene_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=char(60) updatewhereclause=yes name=rem dbname="rem" )
 column=(type=char(14) updatewhereclause=yes name=sale_no dbname="issuereqdet.sale_no" )
 column=(type=char(11) updatewhereclause=yes name=issue_schedule dbname="issue_schedule" )
 column=(type=char(8) updatewhereclause=yes name=ship_case dbname="ship_case" )
 column=(type=datetime updatewhereclause=yes name=req_date dbname="issuereqdet.req_date" )
 column=(type=char(10) updatewhereclause=yes name=salesman dbname="issuereqdet.salesman" )
 column=(type=long updatewhereclause=yes name=req_seq dbname="issuereqdet.req_seq" )
 column=(type=char(80) updatewhereclause=yes name=sale_shipto_addr dbname="sale.shipto_addr" )
 retrieve="  SELECT DISTINCT     username = rtrim(login_a.user_name) + cast(issuereqdet.req_seq as char(2))
						      , rtrim(login_a.user_name) salesman_name 
							 , cust_no  = issuereqdet.cust_no
							 , cust_name   = c.cust_name
							 , scene_code  = issuereqdet.scene_code      
							 , scene_desc  = s.scene_desc
							 , rem = issuereqdet.rem
							 , issuereqdet.sale_no
							 , issue_schedule = (case when issuereqdet.issue_schedule = 'A' then '직출' 
														  when issuereqdet.issue_schedule = 'B' then '생산후 직출'
														  when issuereqdet.issue_schedule = 'J' then '저녁상차'
														  when issuereqdet.issue_schedule = 'K' then '택배/정기'
														  when issuereqdet.issue_schedule = 'D' then '방문'
														  when issuereqdet.issue_schedule = 'I' then '야간도착'
														  when issuereqdet.issue_schedule = 'E' then '외주(시화)'
														  when issuereqdet.issue_schedule = 'F' then '외주(본사)'
														  when issuereqdet.issue_schedule = 'G' then '유창강건'
														  when issuereqdet.issue_schedule = 'H' then '지점이송'
														  when issuereqdet.issue_schedule = 'C' then '자동작성'
																	  else issuereqdet.issue_schedule
																 end)
							, ship_case      = (case when issuereqdet.ship_case = 'J' then '정기화물'
													when issuereqdet.ship_case = 'T' then '택배'
													when issuereqdet.ship_case = 'A' then '오토바이'
													when issuereqdet.ship_case = 'S' then '선박'
													when issuereqdet.ship_case = 'P' then '항공'
													when issuereqdet.ship_case = 'E' then '기타'
																else issuereqdet.ship_case
												  end)
						     , issuereqdet.req_date 
							, issuereqdet.salesman 
						     , issuereqdet.req_seq
                                     , sale.shipto_addr
    FROM issuereq with(nolock)    
         LEFT OUTER JOIN issuereqdet with(nolock)  ON issuereq.req_date = issuereqdet.req_date AND issuereq.salesman = issuereqdet.salesman AND issuereq.req_seq = issuereqdet.req_seq
         LEFT OUTER JOIN sale with(nolock) ON issuereqdet.sale_no = sale.order_no
         LEFT OUTER JOIN login login_a  with(nolock)  ON issuereq.salesman    = login_a.user_id 
         LEFT OUTER JOIN customer C with(nolock) ON issuereqdet.cust_no = c.cust_no
         LEFT OUTER JOIN scene    S with(nolock) ON s.scene_code = issuereqdet.scene_code
   WHERE ( issuereq.confirm_flag  = 'Y' )
     AND ( issuereq.req_date = :ad_date )   
     AND (issuereq.accept_area = :as_area )
     AND (issuereqdet.scene_code    = :as_scene_code)" arguments=(("as_area", string),("ad_date", datetime),("as_scene_code", string))  sort="salesman_name A req_seq A cust_name A scene_desc A sale_no A issue_schedule A " )
