footer(height=76 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=inaudit_date dbname="inaudit_date" )
 column=(type=datetime updatewhereclause=yes name=inaudit_inaudit_time dbname="inaudit_time" )
 column=(type=char(2) updatewhereclause=yes name=inaudit_inaudit_type dbname="inaudit_type" )
 column=(type=char(20) updatewhereclause=yes name=iotype_remarks dbname="remarks" )
 column=(type=char(10) updatewhereclause=yes name=inaudit_inaudit_item dbname="inaudit_item" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=item_uom dbname="uom" )
 column=(type=char(10) updatewhereclause=yes name=inaudit_loc_no dbname="loc_no" )
 column=(type=char(30) updatewhereclause=yes name=location_loc_name dbname="loc_name" )
 column=(type=char(10) updatewhereclause=yes name=inaudit_destination dbname="destination" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=decimal(4) updatewhereclause=yes name=ewol_qty dbname="ewol_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=inaudit_rcpt_qty dbname="rcpt_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=issue_qty dbname="issue_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=item_qoh dbname="qoh" )
 column=(type=char(1) updatewhereclause=yes name=item_source dbname="source" values="구매품	B/재공품	M/완제품	W/" )
 column=(type=decimal(2) updatewhereclause=yes name=unit_qty dbname="unit_qty" )
 column=(type=long updatewhereclause=yes name=cnt dbname="cnt" )
 column=(type=decimal(4) updatewhereclause=yes name=cost dbname="cost" )
 column=(type=char(17) updatewhereclause=yes name=order_no dbname="order_no" )
 column=(type=char(20) updatewhereclause=yes name=serial_id dbname="serial_id" )
 column=(type=char(30) updatewhereclause=yes name=rem dbname="rem" )
 retrieve="  SELECT inaudit_date = convert(char(10), inaudit.inaudit_date, 111)
       , inaudit.inaudit_time   
       , inaudit.inaudit_type   
       , iotype.remarks         
       , inaudit.inaudit_item   
       , item.item_name         
       , inaudit.qa             
       , item.uom               
       , inaudit.loc_no         
       , location.loc_name      
       , inaudit.destination    
       , e.cust_name         
       , ewol_qty = isnull((case when eoy.qoh    is not null then eoy.qoh    else 0 end ),0)
                  + isnull((case when eoday.eqoh is not null then eoday.eqoh else 0 end ),0)
       , inaudit.rcpt_qty       
       , inaudit.issue_qty       
       , item.qoh               
       , item.source            
       , inaudit.unit_qty       
       , inaudit.cnt            
       , inaudit.cost           
       , inaudit.order_no       
       , inaudit.serial_id      
       , inaudit.rem            
FROM inaudit inner join item on  inaudit.qa = item.qa and inaudit.inaudit_item = item.item_no
                            inner join iotype   on inaudit.inaudit_type     = iotype.inaudit_type
                            inner join location on inaudit.loc_no           = location.loc_no 
                            inner join (
                                        				 SELECT cust_no, cust_name FROM customer
                                        				 UNION
                                        				 SELECT loc_no,  loc_name  FROM location
                                             ) e on inaudit.destination      = e.cust_no
                            left outer join (
                                                        select item_no, qa, loc_no, qoh  
                                                          from ineoym  
                                                         WHERE cyear = convert(char(4), datepart(year, :as_from))
                                                           and cmon  = right('00' + convert(char(2),dateadd(month, -1, :as_from)),2)
                                                        union
                                                        select item_no = '', qa = '', loc_no = '', qoh = 0 
                                                   ) eoy   on  inaudit.loc_no = eoy.loc_no
                                                             and  inaudit.inaudit_item = eoy.item_no
                                                             and  inaudit.qa = eoy.qa              
                            left outer join (
                                                        select item_no, qa, loc_no, eqoh = (sum(rcpt_qty) - sum(issue_qty))
                                                          from ineoday
                                                         WHERE cdate = replace(:as_from,'/','')
                                                         group by item_no, qa, loc_no
                                                        union
                                                        select item_no = '', qa = '', loc_no = '', eqoh = 0 
                                                   ) eoday on inaudit.loc_no = eoday.loc_no
                                                               and inaudit.inaudit_item = eoday.item_no
                                                               and inaudit.qa = RTRIM(eoday.qa )
   WHERE ( ( inaudit.inaudit_item    like :as_itemno ) AND  
                     ( inaudit.qa              like :as_qa     ) AND  
                     ( item.source             like :as_source ) AND  
                     ( location.loc_name       like :as_loc    ) AND  
                     ( convert(char(10),inaudit.inaudit_date,111) between :as_from and :as_to ) 
                   )  AND
                  not ( inaudit.inaudit_item      like 'PZZZ%' )
   ORDER BY location.loc_name, item.item_name, inaudit.inaudit_date         
/*         
   WHERE ( inaudit.qa               = item.qa             ) 
     and ( inaudit.inaudit_item     = item.item_no        ) 
     and ( inaudit.inaudit_type     = iotype.inaudit_type ) 
     and ( inaudit.loc_no           = location.loc_no     ) 
     and ( inaudit.destination      = e.cust_no           ) 
     and ( inaudit.loc_no          *= eoy.loc_no          )
     and ( inaudit.inaudit_item    *= eoy.item_no         )
     and ( inaudit.qa              *= eoy.qa              )
     and ( inaudit.loc_no          *= eoday.loc_no        )
     and ( inaudit.inaudit_item    *= eoday.item_no       )
     and ( inaudit.qa              *= RTRIM(eoday.qa )    )
     and ( ( inaudit.inaudit_item    like :as_itemno ) AND  
           ( inaudit.qa              like :as_qa     ) AND  
           ( item.source             like :as_source ) AND  
           ( location.loc_name       like :as_loc    ) AND  
           ( convert(char(10),inaudit.inaudit_date,111) between :as_from and :as_to ) 
         )    
     and not ( inaudit.inaudit_item      like 'PZZZ%' )
   ORDER BY location.loc_name, item.item_name, inaudit.inaudit_date
*/   
" arguments=(("as_itemno", string),("as_qa", string),("as_source", string),("as_loc", string),("as_from", string),("as_to", string)) )
