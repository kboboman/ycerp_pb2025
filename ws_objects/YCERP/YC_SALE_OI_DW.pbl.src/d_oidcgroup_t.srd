 column=(type=char(50) updatewhereclause=yes name=dc_rem2 dbname="dc_rem2" )
 column=(type=char(50) updatewhereclause=yes name=dc_rem3 dbname="dc_rem3" )
 column=(type=char(50) updatewhereclause=yes name=dc_rem4 dbname="dc_rem4" )
 column=(type=char(50) updatewhereclause=yes name=dc_rem5 dbname="dc_rem5" )
 retrieve="  SELECT dc_groupno, dc_date, user_id, user_name   
       , team_code, team_name, cust_no, cust_name   

       , dc_balteam, dc_hyupteam, dc_hyupuser, dc_hyupdt   

       , dc_type, totprice    

       , dc_app1, dc_appdt1   
       , dc_app2, dc_appdt2   
       , dc_app3, dc_appdt3   
       , dc_app4, dc_appdt4   
       , dc_app5, dc_appdt5   
       , dc_apph, dc_appdth   
       , dc_return

       , dc_rem1, dc_rem2, dc_rem3, dc_rem4, dc_rem5
    FROM (
         SELECT dc_groupno   = a.dc_groupno       
              , dc_date      = a.dc_date
              , user_id      = a.user_id     
              , user_name    = d.user_name
              , team_code    = a.team_code   
              , team_name    = f.team_name
              , cust_no      = a.cust_no     
              , cust_name    = c.cust_name
              , dc_balteam   = a.dc_balteam  
              , dc_hyupteam  = a.dc_hyupteam 
              , dc_hyupuser  = a.dc_hyupuser
              , dc_hyupdt    = a.dc_hyupdt
       
              , dc_type      = a.dc_type
              , totprice     = a.totprice    
       
              , dc_app1      = a.dc_app1     
              , dc_appdt1    = a.dc_appdt1
              , dc_app2      = a.dc_app2     
              , dc_appdt2    = a.dc_appdt2
              , dc_app3      = a.dc_app3     
              , dc_appdt3    = a.dc_appdt3
              , dc_app4      = a.dc_app4     
              , dc_appdt4    = a.dc_appdt4
              , dc_app5      = a.dc_app5     
              , dc_appdt5    = a.dc_appdt5
              , dc_apph      = a.dc_apph     
              , dc_appdth    = a.dc_appdth
              , dc_return    = a.dc_return
       
              , dc_rem1      = a.dc_rem1
              , dc_rem2      = a.dc_rem2
              , dc_rem3      = a.dc_rem3
              , dc_rem4      = a.dc_rem4
              , dc_rem5      = a.dc_rem5
              , dc_remh      = a.dc_remh
           FROM dc_group  a
                LEFT OUTER JOIN customer  c ON a.cust_no    = c.cust_no
                LEFT OUTER JOIN login     d ON a.user_id    = d.user_id
                LEFT OUTER JOIN team      f ON a.team_code  = f.team_code
          WHERE ( convert(char(10),a.dc_date,111)     BETWEEN :as_sdate AND :as_edate )
            AND ( (a.user_id  LIKE :as_userid                   ) OR
			 (a.dc_app1  LIKE :as_userid                       ) OR
                 (a.dc_app2  LIKE :as_userid                       ) OR
                 (a.dc_app3  LIKE :as_userid                       ) OR
                 (a.dc_app4  LIKE :as_userid                       ) OR
                 (a.dc_app5  LIKE :as_userid                       ) OR
                 (a.dc_apph  LIKE :as_userid                       ) 
                )
         ) A
     WHERE ( :as_dctype  = '%'    AND a.dc_type LIKE :as_dctype OR
             :as_dctype  = 'DC11' AND a.dc_type    = :as_dctype OR
             :as_dctype  = 'DC10' AND a.dc_type    = :as_dctype OR
             :as_dctype  = 'DC09' AND a.dc_type   <= :as_dctype
           )
" arguments=(("as_dctype", string),("as_sdate", string),("as_edate", string),("as_userid", string))  sort="dc_date D cust_name A " )
