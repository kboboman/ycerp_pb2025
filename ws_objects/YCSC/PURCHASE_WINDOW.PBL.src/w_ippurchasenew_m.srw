//End If		
//If gs_userid = 'ybs' Then
//	dw_1.setredraw(false)
//	dw_1.setfilter("supp_no not like 'T%'")
//	dw_1.filter()
//	dw_1.setredraw(true)
//End If
/*
	<-- 소스추가끝 -->
*/

end event

