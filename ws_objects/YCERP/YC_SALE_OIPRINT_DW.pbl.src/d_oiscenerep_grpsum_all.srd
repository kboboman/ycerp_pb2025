summary(height=0 color="16777215" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(30) updatewhereclause=yes name=project_name dbname="project_name" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(11) updatewhereclause=yes name=do_spot_code dbname="spot_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_total dbname="do_total" )
 retrieve="  SELECT project_name = a.project_name
       , user_name    = a.user_name
       , cust_no      = a.cust_no
       , cust_name    = a.cust_name
       , spot_code    = a.spot_code    
       , scene_desc   = a.scene_desc    
       , do_total     = SUM(a.do_cash)      
    FROM (
         SELECT project_name = scene_grp.project_name
              , user_name  = login.user_name
              , cust_no    = do.cust_no
              , cust_name  = customer.cust_name
              , spot_code  = do.spot_code   
              , scene_desc = scene.scene_desc   
              , do_no      = do.do_no   
              , do_cash    = do.do_cash
           FROM scene_grpdtl
              , scene_grp
              , do      
              , scene   
              , customer  
              , login
          WHERE ((:as_project   = '%') OR
                 (:as_project  <> '%' AND scene_grpdtl.project = :as_project)
                )
            AND ( scene_grpdtl.project    = scene_grp.project )
            AND ( scene_grpdtl.scene_code = do.spot_code )
            AND ( do.cust_no    = scene.cust_no     )   
            AND ( do.spot_code  = scene.scene_code  )   
            AND ( do.cust_no    = customer.cust_no  )   
            AND ( customer.salesman = login.user_id )
            AND ( do.spot_code IS NOT NULL          )    
            AND ( do.do_date       BETWEEN :ad_sdate AND :ad_edate )
            AND ( customer.salesman   LIKE :as_salesman )
        ) A
  GROUP BY a.project_name
         , a.user_name
         , a.cust_no
         , a.cust_name
         , a.spot_code    
         , a.scene_desc    
" arguments=(("as_project", string),("ad_sdate", date),("ad_edate", date),("as_salesman", string))  sort="project_name A user_name A cust_name A scene_desc A " )
