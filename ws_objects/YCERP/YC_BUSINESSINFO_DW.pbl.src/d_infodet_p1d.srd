 column=(type=char(3) updatewhereclause=yes name=bdinfodet_sale_prog dbname="bdinfodet.sale_prog" )
 column=(type=decimal(0) updatewhereclause=yes name=bdinfodet_buildquantity dbname="bdinfodet.buildquantity" )
