 column=(type=char(10) update=yes updatewhereclause=yes name=owner_name dbname="docar.owner_name" )
 column=(type=char(13) update=yes updatewhereclause=yes name=owner_tel dbname="docar.owner_tel" )
 column=(type=char(60) update=yes updatewhereclause=yes name=owner_addr dbname="docar.owner_addr" )
 column=(type=char(50) update=yes updatewhereclause=yes name=owner_email dbname="docar.owner_email" )
 column=(type=char(20) update=yes updatewhereclause=yes name=owner_reg dbname="docar.owner_reg" )
 column=(type=char(20) update=yes updatewhereclause=yes name=business dbname="docar.business" )
 column=(type=char(20) update=yes updatewhereclause=yes name=jongmok dbname="docar.jongmok" values="개별화물	개별화물/트럭	트럭/화물운송	화물운송/화물	화물/개별용달	개별용달/" )
 column=(type=char(20) update=yes updatewhereclause=yes name=owner_bank_master dbname="docar.owner_bank_master" )
 column=(type=char(20) update=yes updatewhereclause=yes name=owner_bank_name dbname="docar.owner_bank_name" )
 column=(type=char(20) update=yes updatewhereclause=yes name=owner_bank_no dbname="docar.owner_bank_no" )
 column=(type=char(50) update=yes updatewhereclause=yes name=car_cust_name dbname="docar.car_cust_name" )
 column=(type=datetime update=yes updatewhereclause=yes name=sys_date dbname="docar.sys_date" )
 retrieve="  SELECT docar.driver
       , docar.name
       , docar.cargo_name
       , docar.inout
       , docar.rem
       , docar.hp
       , docar.open_close
       , docar.icube_no  
       , docar.car_company
       , docar.car_kind
       , docar.owner_name
       , docar.owner_tel
       , docar.owner_addr
       , docar.owner_email
       , docar.owner_reg
       , docar.business
       , docar.jongmok
       , docar.owner_bank_master
       , docar.owner_bank_name
       , docar.owner_bank_no
       , docar.car_cust_name
       , docar.sys_date
    FROM docar   
" update="docar" updatewhere=1 updatekeyinplace=no  sort="open_close D driver A " )
