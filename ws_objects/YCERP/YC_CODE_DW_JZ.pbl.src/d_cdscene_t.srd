table(column=(type=char(4) updatewhereclause=yes key=yes name=cust_no dbname="customer.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=char(20) updatewhereclause=yes name=captain_name dbname="customer.captain_name" )
 column=(type=char(80) updatewhereclause=yes name=addr dbname="customer.addr" )
 column=(type=char(15) updatewhereclause=yes name=tel_no dbname="customer.tel_no" )
 column=(type=char(20) updatewhereclause=yes name=buyer1 dbname="customer.buyer1" )
 column=(type=char(10) updatewhereclause=yes name=salesman dbname="customer.salesman" )
 column=(type=char(30) updatewhereclause=yes name=industry_type dbname="customer.industry_type" )
 column=(type=char(30) updatewhereclause=yes name=industry_code dbname="customer.industry_code" )
 column=(type=char(20) updatewhereclause=yes name=buyer2 dbname="customer.buyer2" )
 column=(type=char(10) updatewhereclause=yes name=pre_salesman dbname="customer.pre_salesman" )
 column=(type=char(1) updatewhereclause=yes name=scene_approval_yn dbname="customer.scene_approval_yn" values="	Y/	N" )
 retrieve="SELECT 
	customer.cust_no,   
	customer.cust_name,   
	customer.captain_name,   
	customer.addr,   
	customer.tel_no,   
	customer.buyer1,   
	customer.salesman,   
	customer.industry_type,   
	customer.industry_code,   
	customer.buyer2,   
	customer.pre_salesman,  
	customer.scene_approval_yn
FROM 
	customer  
WHERE 
	customer.cust_no = :as_custno   " update="customer" updatewhere=0 updatekeyinplace=no arguments=(("as_custno", string)) )
