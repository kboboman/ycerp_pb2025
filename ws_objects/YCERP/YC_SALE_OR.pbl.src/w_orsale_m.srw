type pb_magam from picturebutton within w_orsale_m
integer x = 2802
integer y = 32
integer width = 315
integer height = 84
integer taborder = 490
boolean bringtotop = true
integer textsize = -9
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "수주마감"
boolean originalsize = true
vtextalign vtextalign = vcenter!
end type

event clicked;// 수주마감
gs_codere_str  lst_code
string ls_reqchk, ls_orderno, ls_openclose, ls_custno, ls_scenecode
string ls_recvid, ls_recvname, ls_phone, ls_bigo, ls_message
long   ll_row

// 요청취소
if dw_4.rowcount() > 0 then
	ls_reqchk   = dw_4.object.reqchk[dw_4.getrow()]
else
	MessageBox("확인","해당하는 거래처를 조회한 후 선택하시기 바랍니다.")
	RETURN
end if

if ls_reqchk = "요청" then
	ls_orderno  = dw_4.object.order_no[dw_4.getrow()]

	if isnull(ls_orderno) OR ls_orderno = "" then RETURN
	
	if MessageBox("확인","수주번호:" + ls_orderno + "~n~r수주마감 요청을" + &
	              "~n~n취소 하시겠습니까?",question!,okcancel!,1) = 2 then
		RETURN
	else
		DELETE sale_close WHERE order_no = :ls_orderno;
		if SQLCA.SQLCode = 0 then
			COMMIT;
			MessageBox("확인","요청취소 완료")
		else
			MessageBox("확인","마감요청 오류~n~n" + SQLCA.SQLErrText)
		end if
		
		dw_4.object.reqchk[dw_4.getrow()] = ""
		RETURN
	end if
end if

// 마감요청
if dw_2.rowcount() < 1 then RETURN

ls_orderno   = dw_2.object.order_no[1]
ls_openclose = dw_2.object.open_close[1]
ls_custno    = dw_2.object.cust_no[1]
ls_scenecode = dw_2.object.scene_code[1]

if isnull(ls_orderno) OR ls_orderno = "" then RETURN

if ls_openclose = "C" then
	MessageBox("확인", "마감된 수주입니다.")
	RETURN
end if

SELECT count(*) INTO :ll_row FROM sale_close WHERE order_no = :ls_orderno;
if isnull(ll_row) OR ll_row = 0 then
else	
	MessageBox("확인", "이미 수주마감이 등록된 상태입니다.")
	RETURN
end if

OpenWithParm(w_magam_w, lst_code)
lst_code = Message.PowerObjectParm
if lst_code.okcancel = 'N' then RETURN

ls_recvid   = lst_code.start_no
ls_recvname = lst_code.end_no
ls_phone    = lst_code.flag
ls_bigo     = string(lst_code.sel)

if MessageBox("확인","이 수주내용을 마감요청 하시겠습니까?",question!,okcancel!,1) = 2 then RETURN

INSERT INTO sale_close ( order_no, cust_no, scene_code, user_id, input_date, recv_id, bigo )
VALUES ( :ls_orderno, :ls_custno, :ls_scenecode, :gs_userid, getdate(), :ls_recvid, :ls_bigo );
if SQLCA.SQLCode = 0 then
	COMMIT;
	
	if isnull(ls_phone) OR ls_phone = "" then
		MessageBox("확인","마감요청 등록완료(문자전송 안함)")
	else
		ls_message = "[" + gs_username + "]수주번호: " + ls_orderno + " 번 수주마감을 요청 합니다."
		GF_MMSSEND( gs_userid, "0226481998", ls_phone, ls_recvname, ls_message )	// 수주마감 문자
		MessageBox("확인","마감요청 등록완료(문자전송)")
	end if
else
	MessageBox("확인","마감요청 오류~n~n" + SQLCA.SQLErrText)
end if

end event

type pb_12 from picturebutton within w_orsale_m
integer x = 9
integer y = 96
integer width = 123
integer height = 84
integer taborder = 50
boolean bringtotop = true
integer textsize = -10
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "수주라벨"
boolean originalsize = true
vtextalign vtextalign = multiline!
end type

event clicked;// 수주라벨
string ls_qa, ls_rem, ls_val[]
long   ll_row, ll_prt

PrintSetup()

dw_12.Modify('DataWindow.Print.Orientation = 2')

ll_row = 0 ; ll_prt = 0
do while ll_row <= dw_3.rowcount()
	ll_row = ll_row + 1
	ll_prt = ll_prt + 1
	
	ls_qa = "" ; ls_rem = ""
	if ll_row <= dw_3.rowcount() then
		ls_qa  = dw_3.object.qa[ll_row]
		GF_Split(ls_qa, "X", ls_val)
		
		ls_qa  = string(integer(ls_val[1])) + " X " + string(integer(ls_val[2])) + " X " + string(integer(ls_val[3])) + " X " + string(integer(ls_val[4]))
		ls_rem = dw_3.object.rem[ll_row]
	end if

	if ll_prt = 1 then
		dw_12.object.qa1[1]  = ls_qa
		dw_12.object.rem1[1] = ls_rem
	else
		dw_12.object.qa2[1]  = ls_qa
		dw_12.object.rem2[1] = ls_rem
	end if

	if ll_prt = 2 then
		ll_prt = 0
		dw_12.print()
	end if
loop
if ll_prt = 1 then 
	dw_12.print()
end if

end event

