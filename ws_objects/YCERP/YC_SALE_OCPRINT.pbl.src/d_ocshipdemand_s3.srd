$PBExportHeader$d_ocshipdemand_s3.srd
$PBExportComments$운반비청구내역서 (2002/08/28,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=68 color="10789024" )
detail(height=76 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=do_do_no dbname="do_carry.do_do_no" )
 column=(type=char(1) updatewhereclause=yes name=do_ship_flag dbname="do_carry.ship_flag" values="착불	C/부담	B/대여	D/시화방문	M/화곡방문	H/반월방문	Y/공사원가	A/재료원가	R/" )
 column=(type=decimal(0) updatewhereclause=yes name=ship_amount dbname="do_carry.ship_amount" )
 column=(type=char(60) updatewhereclause=yes name=do_driver dbname="do_carry.driver" )
 column=(type=char(1) updatewhereclause=yes name=do_shipamt_case dbname="do_carry.shipamt_case" values="현금	C/외상	R/" )
 column=(type=char(10) updatewhereclause=yes name=docar_name dbname="do_carry.docar_name" )
 column=(type=char(40) updatewhereclause=yes name=docar_cargo_name dbname="do_carry.cargo_name" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="do_carry.customer_cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="do_carry.scene_desc" )
 column=(type=char(1) updatewhereclause=yes name=ship_close dbname="do_carry.ship_close" values="	C/	O" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_cash dbname="do_carry.do_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_rate dbname="do_carry.do_rate" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_total dbname="do_carry.do_total" )
 column=(type=datetime updatewhereclause=yes name=do_ship_date dbname="do_carry.do_ship_date" )
 column=(type=datetime updatewhereclause=yes name=log_date dbname="do_carry.log_date" )
 column=(type=char(10) updatewhereclause=yes name=close_user dbname="do_carry.close_user" )
 column=(type=char(180) updatewhereclause=yes name=sale_no dbname="do_carry.sale_no" )
 column=(type=char(20) updatewhereclause=yes name=sdate dbname="do_carry.sdate" )
 column=(type=char(20) updatewhereclause=yes name=edate dbname="do_carry.edate" )
 retrieve="  select do_carry.do_no do_do_no,
              do_carry.ship_flag ship_flag,
              do_carry.ship_amount,
               do_carry.driver,
               do_carry.shipamt_case,
               do_carry.name docar_name,
               do_carry.cargo_name,
               do_carry.cust_name customer_cust_name,
               do_carry.scene_desc,
               do_carry.ship_close,
               do_carry.do_cash,
               do_carry.do_rate,
               do_carry.do_total,
               do_carry.ship_date do_ship_date,
               do_carry.log_date,
               do_carry.close_user,
               do_carry.sale_no,
               do_carry.sdate,
               do_carry.edate
from do_carry with(nolock)	LEFT OUTER JOIN do_scan with(nolock) ON do_carry.do_no = do_scan.do_no
where ( 
                      ( do_carry.area_no  LIKE :as_area + '%'        ) AND
                      ( do_carry.yyyymm = :as_yyyymm) and
                      (do_carry.seq = :as_seq) and
				( do_carry.ship_close like :as_flag ) 
           )
" arguments=(("as_area", string),("as_yyyymm", string),("as_seq", string),("as_flag", string))  sort="do_ship_date A docar_name A do_do_no A " )
