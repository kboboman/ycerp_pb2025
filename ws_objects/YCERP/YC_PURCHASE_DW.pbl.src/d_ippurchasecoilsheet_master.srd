 retrieve="  SELECT order_coilsheet.order_no,   
         order_coilsheet.supp_no,   
	    supp.supp_name,
         order_coilsheet.order_date,   
         order_coilsheet.limit_date,   
         order_coilsheet.buyer,   
         order_coilsheet.fob,   
         order_coilsheet.curr_code,   
         order_coilsheet.subcon,   
         order_coilsheet.open_close,   
         order_coilsheet.supply_addr,     
         order_coilsheet.supply_tel, 
         order_coilsheet.rem,   
         order_coilsheet.modify_date,   
         order_coilsheet.modify_user_id  
    FROM order_coilsheet  inner join supp ON   order_coilsheet.supp_no = supp.supp_no
 where order_coilsheet.order_no = :as_order_no
" update="order_coilsheet" updatewhere=0 updatekeyinplace=no arguments=(("as_order_no", string)) )
