end type

event clicked;close(parentwindow)

close(w_printsetup)

end event

on m_close.create
call super::create
this.text = "닫기"
this.toolbaritemname = "Continue!"
this.toolbaritemtext = "닫기"
this.toolbaritemorder = 12
end on

on m_close.destroy
call super::destroy
end on

type m_display from menu within m_printpreview
m_firstpage m_firstpage
m_priorpage m_priorpage
m_nextpage m_nextpage
m_lastpage m_lastpage
m_- m_-
m_zoom m_zoom
m_zoomdown m_zoomdown
m_zoomup m_zoomup
m_-2 m_-2
m_rulers m_rulers
end type

on m_display.create
call super::create
this.text = "화면"
this.m_firstpage=create m_firstpage
this.m_priorpage=create m_priorpage
this.m_nextpage=create m_nextpage
this.m_lastpage=create m_lastpage
this.m_-=create m_-
this.m_zoom=create m_zoom
this.m_zoomdown=create m_zoomdown
this.m_zoomup=create m_zoomup
this.m_-2=create m_-2
this.m_rulers=create m_rulers
this.Item[UpperBound(this.Item)+1]=this.m_firstpage
this.Item[UpperBound(this.Item)+1]=this.m_priorpage
this.Item[UpperBound(this.Item)+1]=this.m_nextpage
this.Item[UpperBound(this.Item)+1]=this.m_lastpage
this.Item[UpperBound(this.Item)+1]=this.m_-
this.Item[UpperBound(this.Item)+1]=this.m_zoom
this.Item[UpperBound(this.Item)+1]=this.m_zoomdown
this.Item[UpperBound(this.Item)+1]=this.m_zoomup
this.Item[UpperBound(this.Item)+1]=this.m_-2
this.Item[UpperBound(this.Item)+1]=this.m_rulers
end on

on m_display.destroy
call super::destroy
destroy(this.m_firstpage)
destroy(this.m_priorpage)
destroy(this.m_nextpage)
destroy(this.m_lastpage)
destroy(this.m_-)
destroy(this.m_zoom)
destroy(this.m_zoomdown)
destroy(this.m_zoomup)
destroy(this.m_-2)
destroy(this.m_rulers)
end on

type m_firstpage from menu within m_display
end type

on m_firstpage.create
call super::create
this.text = "첫페이지"
this.toolbaritemname = "VCRFirst!"
this.toolbaritemtext = "첫페이지"
this.toolbaritemorder = 4
end on

event clicked;////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// Go to the first page of the active report
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

window	lw_frame, &
		lw_sheet

lw_frame = ParentWindow.ParentWindow()
if IsValid (lw_frame) then
	lw_sheet = lw_frame.GetActiveSheet()	
	if IsValid (lw_sheet) then
		lw_sheet.TriggerEvent ("ue_first")
	end if
end if
end event

on m_firstpage.destroy
call super::destroy
end on

