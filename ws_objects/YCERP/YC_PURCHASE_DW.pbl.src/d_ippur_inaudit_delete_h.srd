 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"inaudit~" ) COLUMN(NAME=~"inaudit.inaudit_time~") COLUMN(NAME=~"inaudit.inaudit_date~") COLUMN(NAME=~"inaudit.inaudit_item~") COLUMN(NAME=~"inaudit.qa~") COLUMN(NAME=~"inaudit.loc_no~") COLUMN(NAME=~"inaudit.inaudit_type~") COLUMN(NAME=~"inaudit.order_no~") COLUMN(NAME=~"inaudit.rcpt_qty~") COLUMN(NAME=~"inaudit.issue_qty~") COLUMN(NAME=~"inaudit.cost~") COLUMN(NAME=~"inaudit.destination~") COLUMN(NAME=~"inaudit.serial_id~") COLUMN(NAME=~"inaudit.rem~") COLUMN(NAME=~"inaudit.unit_qty~") COLUMN(NAME=~"inaudit.cnt~") COLUMN(NAME=~"inaudit.com_qty~")WHERE(    EXP1 =~"inaudit.order_no~"   OP =~"=~"    EXP2 =~":as_order~" ) ) ARG(NAME = ~"as_order~" TYPE = string) " update="inaudit" updatewhere=1 updatekeyinplace=no arguments=(("as_order", string)) )
