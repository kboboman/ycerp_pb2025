table(column=(type=char(14) updatewhereclause=yes key=yes name=order_no dbname="ret.ret_no" )
 column=(type=datetime updatewhereclause=yes name=preret_date dbname="ret.preret_date" )
 column=(type=char(14) updatewhereclause=yes name=sale_no dbname="ret.sale_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=process_flag dbname="ret.process_flag" values="	Y/	O" )
 column=(type=char(10) update=yes updatewhereclause=yes name=approve_team dbname="ret.approve_team" )
 column=(type=char(10) update=yes updatewhereclause=yes name=approve_center dbname="ret.approve_center" )
 column=(type=char(10) update=yes updatewhereclause=yes name=approve_top dbname="ret.approve_top" )
 column=(type=char(1) updatewhereclause=yes name=chk_team dbname="chk_team" values="	Y/	N" )
 column=(type=char(1) updatewhereclause=yes name=chk_center dbname="chk_center" values="	Y/	N" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene.scene_desc" )
 retrieve="  SELECT ret.ret_no
       , ret.preret_date
       , ret.sale_no
       , ret.process_flag
       , ret.approve_team
       , ret.approve_center
       , ret.approve_top
       , chk_team   = ( case when ( ret.approve_team is null ) OR ( ret.approve_team = '') then 'N' else 'Y' end )
       , chk_center = (case when ret.approve_center is null then 'N' else 'Y' end)
       , cust_name  = customer.cust_name
       , scene.scene_desc 
    FROM ret  
         left outer join sale     on ret.sale_no  = sale.order_no
         left outer join customer on sale.cust_no = customer.cust_no
         left outer join scene    on sale.cust_no = scene.cust_no  and sale.scene_code = scene.scene_code 
   WHERE ret.process_flag    = :as_flag    
     AND ret.rcpt_area    LIKE :as_area
" update="ret" updatewhere=0 updatekeyinplace=no arguments=(("as_flag", string),("as_area", string))  sort="order_no A " )
