detail(height=80 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=coilmst_item_no dbname="coilmst.item_no" )
 column=(type=long updatewhereclause=yes name=unit_qty dbname="unit_qty" )
 column=(type=long updatewhereclause=yes name=coilmst_qcnt dbname="qcnt" )
 column=(type=char(14) update=yes updatewhereclause=yes key=yes name=order_no dbname="coilordersum.order_no" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=coil_no dbname="coilordersum.coil_no" )
 column=(type=decimal(1) update=yes updatewhereclause=yes name=wid dbname="coilordersum.wid" )
 column=(type=long update=yes updatewhereclause=yes name=cnt dbname="cnt" )
 column=(type=char(30) update=yes updatewhereclause=yes name=rem dbname="coilordersum.rem" )
 column=(type=char(10) update=yes updatewhereclause=yes name=loc_no dbname="coilordersum.loc_no" )
 column=(type=char(10) updatewhereclause=yes name=coilmst_loc_no dbname="coilmst.loc_no" )
 column=(type=char(2) updatewhereclause=yes name=coilmst_etc_no dbname="coilmst.etc_no" )
 column=(type=long updatewhereclause=yes name=coilmst_length dbname="coilmst.length" )
 retrieve="  SELECT coilmst.item_no         
       , coilmst.unit_qty       /* 재고단중 */ 
       , coilmst.qcnt           /* 재고수량 */ 
       , coilordersum.order_no   
       , coilordersum.coil_no    
       , coilordersum.wid        
       , coilordersum.cnt       /* 수량 */ 
       , coilordersum.rem        
       , coilordersum.loc_no     
       , coilmst.loc_no          
       , coilmst.etc_no
	  , coilmst.length  
    FROM coilordersum   
       , coilmst  
   WHERE ( coilordersum.coil_no  = coilmst.coil_no )   
     and ( coilordersum.loc_no   = coilmst.loc_no  )   
     and ( ( coilordersum.order_no = :as_order ) )    
" update="coilordersum" updatewhere=0 updatekeyinplace=no arguments=(("as_order", string)) )
