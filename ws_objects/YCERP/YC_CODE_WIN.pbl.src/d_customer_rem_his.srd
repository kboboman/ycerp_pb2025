 column=(type=datetime update=yes updatewhereclause=yes name=idate dbname="customer_rem_his.idate" )
 column=(type=long update=yes updatewhereclause=yes key=yes identity=yes name=seq dbname="customer_rem_his.seq" )
 column=(type=char(255) update=yes updatewhereclause=yes key=yes name=rem dbname="customer_rem_his.rem" )
 column=(type=char(10) update=yes updatewhereclause=yes name=iuser dbname="customer_rem_his.iuser" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name dbname="login.user_name" )
 retrieve="  SELECT customer_rem_his.cust_no,   
         customer_rem_his.idate,   
         customer_rem_his.seq,   
         customer_rem_his.rem,   
         customer_rem_his.iuser,
         login.user_name  
    FROM customer_rem_his
         LEFT OUTER JOIN login ON customer_rem_his.iuser = login.user_id
   WHERE customer_rem_his.cust_no = :as_custno;
" update="customer_rem_his" updatewhere=1 updatekeyinplace=no arguments=(("as_custno", string))  sort="cust_no A idate D seq D " )
