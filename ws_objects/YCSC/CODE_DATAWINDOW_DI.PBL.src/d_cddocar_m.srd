table(column=(type=char(12) update=yes updatewhereclause=yes key=yes name=driver dbname="driver" )
 column=(type=char(10) update=yes updatewhereclause=yes name=name dbname="name" )
 column=(type=char(40) update=yes updatewhereclause=yes name=cargo_name dbname="cargo_name" )
 column=(type=char(60) update=yes updatewhereclause=yes name=rem dbname="rem" )
 column=(type=char(13) update=yes updatewhereclause=yes name=hp dbname="hp" )
 column=(type=char(1) update=yes updatewhereclause=yes name=open_close dbname="open_close" initial="O" values="사용	O/폐기	C/" )
 column=(type=char(10) update=yes updatewhereclause=yes name=icube_no dbname="icube_no" )
 retrieve="  SELECT docar.driver,   
         docar.name,   
         docar.cargo_name,   
         docar.rem,   
         docar.hp,   
         docar.open_close,
         docar.icube_no  
    FROM docar   
" update="docar" updatewhere=1 updatekeyinplace=no )
