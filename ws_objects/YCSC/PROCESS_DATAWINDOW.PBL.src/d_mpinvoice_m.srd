table(column=(type=datetime updatewhereclause=yes name=work_date dbname="routtempnew.work_date" )
 column=(type=long updatewhereclause=yes key=yes name=division dbname="routtempnew.division" )
 column=(type=char(10) updatewhereclause=yes key=yes name=wc_no dbname="routtempnew.wc_no" )
 column=(type=long updatewhereclause=yes key=yes name=operation dbname="routtempnew.operation" )
 column=(type=char(1) updatewhereclause=yes name=process_flag dbname="routtempnew.process_flag" )
 column=(type=long updatewhereclause=yes name=work_per dbname="routtempnew.work_per" )
 column=(type=char(14) updatewhereclause=yes key=yes name=sale_no dbname="routtempnew.sale_no" )
 column=(type=long updatewhereclause=yes key=yes name=seq_no dbname="routtempnew.seq_no" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="routtempnew.cust_no" )
 column=(type=char(11) updatewhereclause=yes name=scene_code dbname="routtempnew.scene_code" )
 column=(type=datetime updatewhereclause=yes name=napgi_date dbname="routtempnew.napgi_date" )
 column=(type=char(1) updatewhereclause=yes name=suju_type dbname="routtempnew.suju_type" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="routtempnew.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="routtempnew.qa" )
 column=(type=char(4) updatewhereclause=yes name=item_color dbname="routtempnew.item_color" )
 column=(type=decimal(4) updatewhereclause=yes name=order_qty dbname="routtempnew.order_qty" )
 column=(type=char(10) update=yes updatewhereclause=yes name=assy_item dbname="routtempnew.assy_item" )
 column=(type=char(20) update=yes updatewhereclause=yes name=assy_qa dbname="routtempnew.assy_qa" )
 column=(type=long updatewhereclause=yes name=bom_no dbname="routtempnew.bom_no" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="routtempnew.uom" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=plan_qty dbname="routtempnew.plan_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=setup_time dbname="routtempnew.setup_time" )
 column=(type=decimal(4) updatewhereclause=yes name=work_time dbname="routtempnew.work_time" )
 column=(type=decimal(4) updatewhereclause=yes name=make_qty dbname="routtempnew.make_qty" )
 column=(type=char(1) updatewhereclause=yes name=plan_flag dbname="routtempnew.plan_flag" )
 column=(type=decimal(4) updatewhereclause=yes name=qpa dbname="routtempnew.qpa" )
 column=(type=char(20) updatewhereclause=yes name=wc_work_name dbname="wc.work_name" initial=" " )
 column=(type=char(17) updatewhereclause=yes name=mpsdet_plan_no dbname="mpsdet.plan_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name1 dbname="groupitem.item_name" )
 column=(type=char(50) updatewhereclause=yes name=rem dbname="routtempnew.rem" )
 column=(type=char(10) updatewhereclause=yes name=area_no dbname="routtempnew.area_no" )
 retrieve="  SELECT routtempnew.work_date,   
         routtempnew.division,   
         routtempnew.wc_no,   
         routtempnew.operation,   
         routtempnew.process_flag,   
         routtempnew.work_per,   
         routtempnew.sale_no,   
         routtempnew.seq_no,   
         routtempnew.cust_no,   
         routtempnew.scene_code,   
         routtempnew.napgi_date,   
         routtempnew.suju_type,   
         routtempnew.item_no,   
         routtempnew.qa,   
         routtempnew.item_color,   
         routtempnew.order_qty,   
         routtempnew.assy_item,   
         routtempnew.assy_qa,   
         routtempnew.bom_no,   
         routtempnew.uom,   
         routtempnew.plan_qty,   
         routtempnew.setup_time,   
         routtempnew.work_time,   
         routtempnew.make_qty,   
         routtempnew.plan_flag,   
         routtempnew.qpa,   
         wc.work_name,   
         mpsdet.plan_no,   
         groupitem_a.item_name,   
         groupitem_b.item_name,   
         routtempnew.rem  ,   
         routtempnew.area_no  
    FROM routtempnew,   
         wc,   
         mps  ,   
         mpsdet,   
         groupitem groupitem_a,   
         groupitem groupitem_b
   WHERE ( mps.open_close = 'P' ) AND  
			( mpsdet.order_no = mps.order_no ) and  
         ( mpsdet.rcpt_type = 'N' ) and
         ( mpsdet.wc_no = wc.work_no ) and  
         ( routtempnew.area_no = mps.area_no ) and  
         ( routtempnew.assy_item = mpsdet.item_no ) and  
         ( routtempnew.assy_qa = mpsdet.qa ) and  
         ( routtempnew.sale_no = mpsdet.sale_no ) and  
         ( routtempnew.seq_no = mpsdet.seq_no ) and  
         ( routtempnew.division = mpsdet.division ) and  
         ( routtempnew.operation = mpsdet.operation ) and  
         ( ( substring(mpsdet.wc_no,1,1) in ('M','O') ) AND  
         ( routtempnew.process_flag in ('Y','P') ) ) and  
			( routtempnew.assy_item = groupitem_b.item_no) and  
         ( routtempnew.item_no = groupitem_a.item_no) and  
         ( routtempnew.area_no = :as_area)
         " update="routtempnew" updatewhere=1 updatekeyinplace=yes filter=" make_qty <  plan_qty " arguments=(("as_area", string)) )
