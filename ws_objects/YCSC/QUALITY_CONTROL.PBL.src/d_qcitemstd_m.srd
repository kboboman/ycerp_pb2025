 retrieve="  SELECT qcitemstd.area_no,   
         qcitemstd.item_no,   
         qcitemstd.rem,   
         qcitemstd.lenf,   
         qcitemstd.lent,   
         qcitemstd.sidef,   
         qcitemstd.sidet,   
         qcitemstd.ribf,   
         qcitemstd.ribt,   
         qcitemstd.wid1f,   
         qcitemstd.wid1t,   
         qcitemstd.wid2f,   
         qcitemstd.wid2t,   
         qcitemstd.hig1f,   
         qcitemstd.hig1t,   
         qcitemstd.hig2f,   
         qcitemstd.hig2t,   
         qcitemstd.flag  
    FROM qcitemstd  
   WHERE qcitemstd.area_no = :as_area     
" update="qcitemstd" updatewhere=1 updatekeyinplace=no arguments=(("as_area", string)) )
