$PBExportComments$조업자재 거래처별구매월보(상세)(1999/07/03, 이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=108 color="536870912" )
table(column=(type=char(30) updatewhereclause=yes name=bsupp_supp_name dbname="bsupp.supp_name" )
 column=(type=datetime updatewhereclause=yes name=binitem_in_date dbname="binitem.in_date" )
 column=(type=char(30) updatewhereclause=yes name=bitem_item_name dbname="bitem.item_name" )
 column=(type=char(30) updatewhereclause=yes name=binitem_qa dbname="binitem.qa" )
 column=(type=char(4) updatewhereclause=yes name=binitem_uom dbname="binitem.uom" )
 column=(type=decimal(2) updatewhereclause=yes name=binitem_qty dbname="binitem.qty" )
 column=(type=decimal(2) updatewhereclause=yes name=binitem_cost dbname="binitem.cost" )
 column=(type=decimal(4) updatewhereclause=yes name=binitem_amount dbname="binitem.amount" )
 column=(type=char(60) updatewhereclause=yes name=binitem_rem dbname="binitem.rem" )
 column=(type=char(10) updatewhereclause=yes name=bpart_part_name dbname="bpart.part_name" )
 column=(type=long updatewhereclause=yes name=yy dbname="yy" )
 column=(type=long updatewhereclause=yes name=mm dbname="mm" )
 column=(type=long updatewhereclause=yes name=binitem_seq dbname="binitem.seq" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"binitem~" )  TABLE(NAME=~"bitem~" )  TABLE(NAME=~"bsupp~" )  TABLE(NAME=~"bpart~" ) COLUMN(NAME=~"bsupp.supp_name~") COLUMN(NAME=~"binitem.in_date~") COLUMN(NAME=~"bitem.item_name~") COLUMN(NAME=~"binitem.qa~") COLUMN(NAME=~"binitem.uom~") COLUMN(NAME=~"binitem.qty~") COLUMN(NAME=~"binitem.cost~") COLUMN(NAME=~"binitem.amount~") COLUMN(NAME=~"binitem.rem~") COLUMN(NAME=~"bpart.part_name~") COMPUTE(NAME=~"yy = :ai_yy~") COMPUTE(NAME=~"mm = :ai_mm~") COLUMN(NAME=~"binitem.seq~")    JOIN (LEFT=~"binitem.item_no~"    OP =~"=~"RIGHT=~"bitem.item_no~"    OUTER1 =~"binitem.item_no~" )    JOIN (LEFT=~"binitem.supp_no~"    OP =~"=~"RIGHT=~"bsupp.supp_no~"    OUTER1 =~"binitem.supp_no~" )    JOIN (LEFT=~"binitem.part_code~"    OP =~"=~"RIGHT=~"bpart.part_no~"    OUTER1 =~"binitem.part_code~" )WHERE(    EXP1 =~"datepart(year, binitem.in_date)~"   OP =~"=~"    EXP2 =~":ai_yy~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"datepart(month, binitem.in_date)~"   OP =~"=~"    EXP2 =~":ai_mm~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"binitem.area_no~"   OP =~"=~"    EXP2 =~":as_area~" ) ) ARG(NAME = ~"ai_yy~" TYPE = number)  ARG(NAME = ~"ai_mm~" TYPE = number)  ARG(NAME = ~"as_area~" TYPE = string) " arguments=(("ai_yy", number),("ai_mm", number),("as_area", string))  sort="bsupp_supp_name A binitem_in_date A binitem_seq A bitem_item_name A binitem_qa A " )
