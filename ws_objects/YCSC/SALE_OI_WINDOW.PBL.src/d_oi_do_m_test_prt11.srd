 column=(type=char(60) updatewhereclause=yes name=do_rem dbname="do.rem" )
 column=(type=char(20) updatewhereclause=yes name=do_tel_no dbname="do.tel_no" )
 column=(type=char(3) updatewhereclause=yes name=do_curr_code dbname="do.curr_code" )
 column=(type=char(1) updatewhereclause=yes name=round dbname="customer.round" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="dodet.item_no" )
 column=(type=decimal(0) updatewhereclause=yes name=ship_amount dbname="do.ship_amount" )
 column=(type=char(1) updatewhereclause=yes name=ship_flag dbname="do.ship_flag" )
 column=(type=char(1) updatewhereclause=yes name=shipamt_case dbname="do.shipamt_case" )
 column=(type=char(14) updatewhereclause=yes name=dodet_sale_no dbname="dodet.sale_no" )
 column=(type=long updatewhereclause=yes name=dodet_seq_no dbname="dodet.seq_no" )
 column=(type=char(32) updatewhereclause=yes name=c_rem dbname="c_rem" )
 column=(type=char(1) updatewhereclause=yes name=c_chk dbname="c_chk" )
 column=(type=char(30) updatewhereclause=yes name=c_sno dbname="c_sno" )
 column=(type=char(30) updatewhereclause=yes name=c_sh dbname="c_sh" )
 column=(type=char(20) updatewhereclause=yes name=c_nm dbname="c_nm" )
 column=(type=char(40) updatewhereclause=yes name=c_js dbname="c_js" )
 column=(type=char(13) updatewhereclause=yes name=do_dr_hp dbname="do.dr_hp" )
 retrieve="  SELECT do.do_no,   
         do.do_date,   
         do.shipto_addr,   
         do.do_cash,   
         do.do_rate,   
         do.do_total,   
         do.dr_hp,   
         dodet.oi_no,   
         dodet.qa,   
         dodet.ship_qty,   
         dodet.price,   
         dodet.uom,   
         dodet.rate_cash,   
         groupitem.item_name,   
         scene.scene_desc,   
         customer.cust_name,   
         customer.captain_name,   
         do.rem,   
         do.tel_no,   
         do.curr_code,   
         customer.round,   
         dodet.item_no,   
         do.ship_amount,   
         do.ship_flag,   
         do.shipamt_case,
         dodet.sale_no,
         dodet.seq_no,
         rtrim(isnull(dodet.do_rem,'') + isnull(dodet.coil_no,'')) as c_rem,
			c_chk = :as_c_chk,
         c_sno = :as_sno,
         c_sh = :as_sh,
         c_nm = :as_nm,
         c_js = :as_js,
			do.dr_hp
    FROM do,   
         dodet,   
         customer,   
         scene,
         groupitem
   WHERE ( do.do_no = dodet.do_no ) and  
         ( do.cust_no = customer.cust_no) and  
         ( do.cust_no *= scene.cust_no) and  
         ( do.spot_code *= scene.scene_code ) and  
         ( dodet.item_no = groupitem.item_no ) and  
         ( ( do.do_no = :as_do_no ) )     
" arguments=(("as_do_no", string),("as_c_chk", string),("as_sno", string),("as_sh", string),("as_nm", string),("as_js", string))  sort="do_do_no A dodet_oi_no A " )
