event pb_insert::clicked;//
long   ll_row
string ls_null

if GF_PERMISSION('판매거래처관리edit', gs_userid) = 'N' then
	messagebox('확인', '판매거래처관리 권한이 없습니다.')
	return
end if

// 이전주소 지우기
is_addr1     = ""
is_addr2     = ""
is_addr3     = ""
is_busaddr1  = ""
is_busaddr2  = ""
is_busaddr3  = ""
is_shipaddr1 = ""
is_shipaddr2 = ""
is_shipaddr3 = ""

pb_insert.enabled = false
dw_1.object.cust_no[dw_1.getrow()]   = ""
dw_1.object.cust_name[dw_1.getrow()] = ""

tab_1.tabpage_1.dw_5.object.cust_no.protect = false
tab_1.tabpage_1.dw_5.reset()
tab_1.tabpage_1.dw_20.reset()
tab_1.tabpage_1.dw_rem_i.reset()
tab_1.tabpage_2.dw_4.reset()
tab_1.tabpage_3.dw_6.reset()
tab_1.tabpage_3.dw_7.reset()
tab_1.tabpage_4.dw_17.reset()
tab_1.tabpage_4.dw_8.reset()

setnull(ls_null)
tab_1.tabpage_4.st_2.text = ls_null
tab_1.tabpage_4.st_3.text = ls_null
tab_1.tabpage_3.st_5.text = ls_null
tab_1.tabpage_3.st_6.text = ls_null
tab_1.tabpage_3.em_1.text = '0000'

ll_row = tab_1.tabpage_1.dw_5.insertrow(0)
tab_1.tabpage_1.dw_rem_i.insertrow(0)
tab_1.tabpage_1.dw_20.reset()
tab_1.tabpage_1.dw_5.object.last_tn_date[tab_1.tabpage_1.dw_5.getrow()] = wf_today()
tab_1.tabpage_2.dw_4.insertrow(0)

///////////////////////////////////////////
// 관리분류
///////////////////////////////////////////
tab_1.tabpage_1.dw_5.getchild("mgr_type", idwc_mgrtype)
idwc_mgrtype.settransobject(sqlca)
idwc_mgrtype.retrieve("MGR_TYPE")


tab_1.tabpage_1.dw_5.scrolltorow(ll_row)
tab_1.tabpage_1.dw_5.setcolumn('cust_no')
tab_1.tabpage_1.dw_5.setfocus()

MessageBox("확인","거래처 코드를 등록한 후 주소를 등록하시기 바랍니다.")

end event

