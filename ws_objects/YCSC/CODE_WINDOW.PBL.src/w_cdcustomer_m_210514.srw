event clicked;if this.isselected(row) then
	this.selectrow(row,false)
else
	this.selectrow(row,true)
end if

integer li_i, li_dw19cnt
string ls_filterstr

ls_filterstr = ''
li_dw19cnt   = this.rowcount()

for li_i = 1 to li_dw19cnt
	if this.isselected(li_i) then
		ls_filterstr += "'" + this.getitemstring(li_i, 'credit_level_' + string(li_i)) + "',"
	end if
next
ls_filterstr = LeftA(ls_filterstr, LenA(ls_filterstr) - 1)

if LenA(ls_filterstr) < 1 then 
	tab_1.tabpage_5.dw_18.setfilter("")
else
	tab_1.tabpage_5.dw_18.setfilter("credit_level in (" + ls_filterstr + ")")
end if
tab_1.tabpage_5.dw_18.filter()

end event

