$PBExportHeader$d_ioitemloc_t.srd
$PBExportComments$저장소별재고현황(1998/05/13,곽용덕)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(3) updatewhereclause=yes name=top15 dbname="top15" )
 column=(type=char(30) updatewhereclause=yes name=location_loc_name dbname="loc_name" )
 column=(type=char(10) updatewhereclause=yes name=itemloc_loc_no dbname="loc_no" initial=" " )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" initial=" " )
 column=(type=char(20) updatewhereclause=yes name=itemloc_qa dbname="qa" )
 column=(type=decimal(4) updatewhereclause=yes name=itemloc_qoh dbname="qoh" initial=" " )
 column=(type=char(10) updatewhereclause=yes name=c_date dbname="c_date" )
 retrieve="  SELECT top15     = (CASE WHEN itemloc.item_no IN ('PACSMBDK00','PACSMBDB00','PACSCACK00','PACSCACB00','PACSCLIB00'
                                        ,'PAWSSTDK00','PAWSSTDK10','PAWSSTDB00','PAWSSTDB10','PAWSRUNB00'
                                        ,'PAWSRUNK00','PACSMTBK00','PACSC2FK00','GBMZSMSZ0Z','PBCATL0K0S')
                           THEN 'TOP' ELSE '' 
                      END)
       , loc_name  = location.loc_name
       , loc_no    = itemloc.loc_no
       , item_name = groupitem.item_name
       , item_no   = itemloc.item_no
       , qa        = itemloc.qa
       , qoh       = isnull(itemloc.qoh, 0) - isnull(H.rcptqty, 0) + isnull(H.issueqty, 0)
       , c_date    = convert(char(10),:as_date)
    FROM itemloc inner join  groupitem on  itemloc.item_no     = groupitem.item_no
                                     inner join  location on itemloc.loc_no      = location.loc_no
                                     left outer join  (
                                                                                SELECT ineoday.item_no
                                                                                                 , ineoday.qa
                                                                                                 , rcptqty  = isnull(sum(ineoday.rcpt_qty), 0)
                                                                                                 , issueqty = isnull(sum(ineoday.issue_qty), 0)
                                                                                              FROM ineoday
                                                                                             WHERE ( ineoday.loc_no     = :arg_loc )   
                                                                                               AND ( :arg_source = 'A' or ( ineoday.item_no LIKE :arg_source ) ) 
                                                                                               AND NOT ( ineoday.item_no >= 'PZZZFZ' or ( ineoday.item_no LIKE 'M%' AND ineoday.item_no LIKE 'M[13]_[12]%') ) 
                                                                                                         /* 비용품목 이거나, 원재료 품목코드중에서 M13, M12로 시작하는 것 */
                                                                                               AND cdate         > :as_date
                                                                                             GROUP BY ineoday.item_no, ineoday.qa
                                                                      ) H on itemloc.item_no =  h.item_no and itemloc.qa  = h.qa
   WHERE ( NOT ( groupitem.uom  = 'M2' AND groupitem.item_no LIKE 'PCY%')   ) 
                        AND ( 
                                          ( itemloc.loc_no    = :arg_loc                                  )
                                              AND  ( :arg_source   = 'A' or ( groupitem.item_no LIKE :arg_source ) )
                                              AND   NOT ( groupitem.item_no >= 'PZZZFZ' or ( groupitem.item_no LIKE 'M%' AND groupitem.item_no LIKE 'M[13]_[12]%') ) 
                                      )
/*
    FROM itemloc
       , groupitem
       , location
       , (SELECT ineoday.item_no
               , ineoday.qa
               , rcptqty  = isnull(sum(ineoday.rcpt_qty), 0)
               , issueqty = isnull(sum(ineoday.issue_qty), 0)
            FROM ineoday
           WHERE ( ineoday.loc_no     = :arg_loc )   
             AND ( :arg_source = 'A' or ( ineoday.item_no LIKE :arg_source ) ) 
             AND NOT ( ineoday.item_no >= 'PZZZFZ' or ( ineoday.item_no LIKE 'M%' AND ineoday.item_no LIKE 'M[13]_[12]%') ) 
                       /* 비용품목 이거나, 원재료 품목코드중에서 M13, M12로 시작하는 것 */
             AND cdate         > :as_date
           GROUP BY ineoday.item_no, ineoday.qa
         ) H
   WHERE ( itemloc.loc_no      = location.loc_no   ) 
     AND ( itemloc.item_no     = groupitem.item_no ) 
     AND ( itemloc.item_no    *= h.item_no         ) 
     AND ( itemloc.qa         *= h.qa              )
     AND ( NOT (groupitem.uom  = 'M2' AND groupitem.item_no LIKE 'PCY%')   ) 
     AND ( ( itemloc.loc_no    = :arg_loc                                  ) AND  
           ( :arg_source   = 'A' or ( groupitem.item_no LIKE :arg_source ) ) AND  
           NOT ( groupitem.item_no >= 'PZZZFZ' or ( groupitem.item_no LIKE 'M%' AND groupitem.item_no LIKE 'M[13]_[12]%') ) 
         )
*/
/* 비용품목들 SUBSTRING(ITEM_NO,1,6) >= 'PZZZFZ' AND SUBSTRING(ITEM_NO,1,6) < 'PZZZVR' */" arguments=(("arg_loc", string),("arg_source", string),("as_date", string))  sort="groupitem_item_name A itemloc_qa A " )
