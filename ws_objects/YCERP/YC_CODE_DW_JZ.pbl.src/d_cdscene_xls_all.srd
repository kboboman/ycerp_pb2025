 column=(type=datetime updatewhereclause=yes name=scene_입력일자 dbname="SCENE.입력일자" )
 column=(type=datetime updatewhereclause=yes name=scene_등록일자 dbname="SCENE.등록일자" )
 column=(type=char(10) updatewhereclause=yes name=scene_등록자 dbname="SCENE.등록자" )
 column=(type=char(1) updatewhereclause=yes name=scene_유통업체유무 dbname="SCENE.유통업체유무" )
 column=(type=char(1) updatewhereclause=yes name=scene_승인여부 dbname="SCENE.승인여부" )
 retrieve="select 
	 a.cust_no			거래처코드					
	,c.cust_name  		거래처명
	,a.scene_code		현장코드			
	,a.scene_desc		현장명	
	,a.scene_charge	현장관리자
	,a.area_nm			지역명		
	,a.project_nm		공사명
	,a.owner				건설사명직발주		
	,a.gubun				현장구분
	,b.item_nm			현장구분명
	,a.start_date		공사시작일
	,a.end_date			공사마감일	
	,a.scene_tel		핸드폰		
	,a.scene_telcap	보조연락처
	,a.scene_scale		공사규모
	,a.scene_addr		현장주소
	,a.rem				특기사항			
	,a.input_date		입력일자
	,a.gen_date			등록일자	
	,a.user_id			등록자		
	,a.utong_yn			유통업체유무	
	,a.approval_yn		승인여부
from 
	scene a left outer join codemst b on  b.type = '현장구분' and a.gubun = b.item_cd
	        inner join customer c on c.open_close <> 'C' and a.cust_no = c.cust_no
order by
	a.input_date desc
" )
