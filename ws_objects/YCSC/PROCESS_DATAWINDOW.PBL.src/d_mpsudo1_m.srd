 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"sudodet1~" )  TABLE(NAME=~"groupitem~" )  TABLE(NAME=~"routtempnew~" )  TABLE(NAME=~"customer~" ) COLUMN(NAME=~"sudodet1.order_no~") COLUMN(NAME=~"sudodet1.wc_no~") COLUMN(NAME=~"sudodet1.item_no~") COLUMN(NAME=~"sudodet1.qa~") COLUMN(NAME=~"sudodet1.due_date~") COLUMN(NAME=~"sudodet1.plan_qty~") COLUMN(NAME=~"sudodet1.rcpt_qty~") COLUMN(NAME=~"groupitem.item_name~") COLUMN(NAME=~"sudodet1.sudo_type~") COLUMN(NAME=~"groupitem.uom~") COLUMN(NAME=~"sudodet1.operation~") COLUMN(NAME=~"sudodet1.sale_no~") COLUMN(NAME=~"sudodet1.seq_no~") COLUMN(NAME=~"customer.cust_name~") COLUMN(NAME=~"sudodet1.rem~") COLUMN(NAME=~"sudodet1.color~") COLUMN(NAME=~"sudodet1.area_no~")    JOIN (LEFT=~"sudodet1.item_no~"    OP =~"=~"RIGHT=~"groupitem.item_no~"    OUTER1 =~"sudodet1.item_no~" )    JOIN (LEFT=~"routtempnew.cust_no~"    OP =~"=~"RIGHT=~"customer.cust_no~"    OUTER1 =~"routtempnew.cust_no~" )    JOIN (LEFT=~"sudodet1.operation~"    OP =~"=~"RIGHT=~"routtempnew.operation~" )    JOIN (LEFT=~"sudodet1.sale_no~"    OP =~"=~"RIGHT=~"routtempnew.sale_no~" )    JOIN (LEFT=~"sudodet1.seq_no~"    OP =~"=~"RIGHT=~"routtempnew.seq_no~" )    JOIN (LEFT=~"sudodet1.area_no~"    OP =~"=~"RIGHT=~"routtempnew.area_no~" )WHERE(    EXP1 =~"sudodet1.sudo_type~"   OP =~"in~"    EXP2 =~"('A','B')~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"sudodet1.sale_no~"   OP =~"like~"    EXP2 =~":as_sale~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"sudodet1.area_no~"   OP =~"=~"    EXP2 =~":as_area~" ) ) ARG(NAME = ~"as_sale~" TYPE = string)  ARG(NAME = ~"as_area~" TYPE = string) " update="sudodet1" updatewhere=1 updatekeyinplace=no arguments=(("as_sale", string),("as_area", string))  sort="order_no A sale_no A seq_no A item_no A qa A " )
