cb_19 cb_19
st_16 st_16
st_15 st_15
cb_18 cb_18
cb_17 cb_17
dw_7 dw_7
end type

on tabpage_3.create
this.cb_19=create cb_19
this.st_16=create st_16
this.st_15=create st_15
this.cb_18=create cb_18
this.cb_17=create cb_17
this.dw_7=create dw_7
this.Control[]={this.cb_19,&
this.st_16,&
this.st_15,&
this.cb_18,&
this.cb_17,&
this.dw_7}
end on

on tabpage_3.destroy
destroy(this.cb_19)
destroy(this.st_16)
destroy(this.st_15)
destroy(this.cb_18)
destroy(this.cb_17)
destroy(this.dw_7)
end on

