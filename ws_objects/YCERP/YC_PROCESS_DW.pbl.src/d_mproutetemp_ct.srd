release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no  crosstab.dynamic = yes grid.lines=0 grid.columnmove=no selected.mouse=no )
header[1](height=128 color="536870912" )
header[2](height=128 color="536870912" )
summary(height=108 color="536870912" )
footer(height=0 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=작업장명 dbname="작업장명" )
 column=(type=number updatewhereclause=yes name=환산수량 dbname="환산수량" )
 retrieve="  SELECT '사업장'     = i.area_name                                                      
       , '작업장'     = h.work_no
       , '작업장명'   = h.work_name                                                      
       , '작업위치'   = h.work_pos                                                       
       , '작업장타입' = (case when h.work_type = 'D' then '사내' else '외주' end)
       , '사용'       = h.use_yn                                                      
       , '작업예정'   = a.work_date                                                      
       , '분할'       = a.division                                                       
       , '작업순위'   = a.operation                                                      
       , '작업진행'   = ( case when a.process_flag = 'Y' then '가능'                     
                               when a.process_flag = 'N' then '불가'                     
                               when a.process_flag = 'E' then '완료'                     
                               when a.process_flag = 'P' then '진행'                     
                          end )                                                          
       , '수주번호'   = a.sale_no                                                        
       , '순번'       = a.seq_no                                                         
       , '거래처'     = isnull(c.cust_name,'')                                           
       , '현장명'     = isnull(f.scene_desc,'')                                          
       , '납기일자'   = a.napgi_date                                                     
       , '수주유형'   = a.suju_type                                                      
       , '물품번호'   = ( case when a.item_no = 'no_item' then '' else a.item_no   end ) 
       , '물품명'     = d.item_name                                                      
       , '수주물품'   = ( case when a.item_no = 'no_item' then '' else e.item_name end ) 
       , '수주규격'   = ( case when a.item_no = 'no_item' then '' else a.qa        end ) 
       , '색상코드'   = isnull(a.item_color,'')                                          
       , '색상'       = isnull(g.color_name,'')                                          
       , '환산수량'   = (case when datalength(rtrim(a.qa)) <> 19 then 0                  
                              else round(dbo.uf_getqty(a.assy_item, a.assy_qa, a.uom, a.order_qty),2,1) 
                         end)                                                            
       , '주문량'     = a.order_qty                                                      
       , '출고량'     = isnull(dbo.uf_getdosumqty(a.sale_no, a.seq_no),0)                
       , '계획량'     = a.plan_qty                                                       
       , '제조량'     = a.make_qty                                                       
       , '제조물품'   = a.assy_item                                                      
       , '제조규격'   = a.assy_qa                                                        
       , '제조단위'   = a.uom                                                            
       , '계획유무'   = a.plan_flag                                                      
       , '캐파'       = a.qpa                                                            
       , '비고'       = isnull(a.rem,'')                                                 
       , '수주마감'   = isnull(b.open_close,'')                                          
    FROM routtempnew A
         LEFT OUTER JOIN sale      B ON a.sale_no    = b.order_no
         LEFT OUTER JOIN customer  C ON a.cust_no    = c.cust_no
         LEFT OUTER JOIN groupitem D ON a.assy_item  = d.item_no   
         LEFT OUTER JOIN groupitem E ON a.item_no    = e.item_no
         LEFT OUTER JOIN scene     F ON a.scene_code = f.scene_code
         LEFT OUTER JOIN color     G ON a.item_color = g.color_code                                                                
         INNER JOIN wc             H ON a.wc_no      = h.work_no   
         INNER JOIN area           I ON a.area_no    = i.area_no   
   WHERE ( b.open_close     = 'O'                          )                      
     AND ( a.process_flag  <> 'C'                          )                      
     AND ( a.work_date     >= dateadd(month,-2, getdate()) )      
     AND ( b.order_date    >= dateadd(month,-3, getdate()) )         
     AND ( a.plan_flag        = 'N'            ) -- 계획유무                           
   ORDER BY h.work_type, h.area_no, h.work_no, h.use_yn"  sort="작업장명 A " )
