 column=(type=char(2) updatewhereclause=yes name=inspdet_com_uom dbname="inspdet.com_uom" )
 retrieve="select b.* from inspdet b, insp a
where b.apoi_qty > 0 and b.insp_no not in( select insp_no from apoi )
and a.insp_no = b.insp_no
and a.insp_date between '2007-04-26' and '2007-05-25'
and a.supp_no = 'P0067'" update="inspdet" updatewhere=0 updatekeyinplace=yes )
