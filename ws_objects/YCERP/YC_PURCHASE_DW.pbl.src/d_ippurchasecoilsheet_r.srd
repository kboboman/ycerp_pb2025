$PBExportHeader$d_ippurchasecoilsheet_r.srd
$PBExportComments$발주번호선택(1998/02/10,곽용덕)
release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(12) updatewhereclause=yes name=order_no dbname="order_no" initial=" " )
 column=(type=char(8) updatewhereclause=yes name=order_date dbname="order_coilsheet.order_date" )
 column=(type=char(1) updatewhereclause=yes name=order_coilsheet_subcon dbname="order_coilsheet.subcon" )
 column=(type=char(40) updatewhereclause=yes name=order_coilsheet_buyer dbname="order_coilsheet.buyer" )
 column=(type=char(30) updatewhereclause=yes name=supp_supp_name dbname="supp.supp_name" )
 retrieve="  SELECT order_no  = rtrim(order_coilsheet.order_no)
			 , order_coilsheet.order_date  order_date  
			 , order_coilsheet.subcon subcon      
			 , order_coilsheet.buyer
			 , supp.supp_name supp_name			
    FROM order_coilsheet with(nolock)
         LEFT OUTER JOIN supp  with(nolock) ON order_coilsheet.supp_no = supp.supp_no
   WHERE ( order_coilsheet.order_date BETWEEN :ad_start and :ad_end ) 

" arguments=(("as_supp", string),("as_open", string),("ad_start", string),("ad_end", string))  sort="order_no A " )
