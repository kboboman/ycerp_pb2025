fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
long textcolor = 16711680
long backcolor = 67108864
string text = "로트추적"
end type

event clicked;// 로트 추적기
//////////////////////////////////////////////////////
/* 코일업무 1, 2, 3, 4, 5 (1차 스리팅:금강철강) ->  */
/*          1, 2, 3, 4, 5 (2차 스리팅:동원철강) ->  */
/*          코일이동 (협신금속) ->                  */
/*          작업일보 사용자재 처리                  */
//////////////////////////////////////////////////////
// dw4  = tab_1.tabpage_1.dw_4  스리팅계획
// dw5  = tab_1.tabpage_2.dw_5  스리팅지시
// dw6  = tab_1.tabpage_3.dw_6  발주서
// dw7  = tab_1.tabpage_4.dw_7  발주입고
// dw8  = tab_1.tabpage_5.dw_8  코일이동
// dw9  = tab_1.tabpage_6.dw_9  작업일보등록
// dw10 = tab_1.tabpage_7.dw_10 전체보기

string ls_lotno, ls_colx

tab_1.width  = dw_1.width  * 0.7
tab_1.height = dw_1.height * 0.7
tab_1.x      = ( dw_1.width  - tab_1.width  ) / 2
tab_1.y      = ( dw_1.height - tab_1.height ) / 2 + dw_1.y

tab_1.visible = this.checked
if this.checked = false then RETURN

dw4.reset()		// 스리팅계획
dw5.reset()		// 스리팅지시
dw6.reset()		// 발주서
dw7.reset()		// 발주입고
dw8.reset()		// 코일이동
dw9.reset()		// 작업일보등록
dw10.reset()	// 전체보기

ls_lotno     = dw_1.object.coilmst_coil_no[dw_1.getrow()]

tab_1.selectedtab = 1
tab_1.postevent( selectionchanged! )
tab_1.tabpage_1.sle_lotno.text   = ls_lotno
dw4.retrieve( ls_lotno )   	// 스리팅계획

tab_1.tabpage_7.tabtextcolor = rgb(0, 0, 0)
if MidA(ls_lotno,2,1) = "C" then
	dw10.retrieve( ls_lotno )
	if dw10.rowcount() > 0 then
		tab_1.tabpage_7.tabtextcolor = rgb(255, 0, 0)
	end if	
end if

end event

