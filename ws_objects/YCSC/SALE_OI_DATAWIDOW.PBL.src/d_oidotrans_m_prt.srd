 retrieve="SELECT DoTrans.trans_no
		, DoTrans.trans_amt
		, DoTrans.bigo
		, DoTrans.fcust_no
		, DoTrans.fspot_code
		, DoTrans.fregister_no
		, DoTrans.flevel_grade
		, DoTrans.fcaptain_name
		, DoTrans.funpaid_amt
		, DoTrans.fcollect_day
		, DoTrans.tcust_no
		, DoTrans.tspot_code
		, DoTrans.tregister_no
		, DoTrans.tlevel_grade
		, DoTrans.tcaptain_name
		, DoTrans.tunpaid_amt
		, DoTrans.tcollect_day
		, DoTrans.fspot_desc
FROM DoTrans
WHERE DoTrans.trans_no = :as_trans_no
" update="DoTrans" updatewhere=0 updatekeyinplace=no arguments=(("as_trans_no", string)) )
