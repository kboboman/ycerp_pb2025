$PBExportHeader$d_sliting_h.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=88 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=92 color="536870912" )
table(column=(type=char(1) updatewhereclause=yes name=save_chk dbname="save_chk" values="대	M/완	C/" )
 column=(type=char(14) updatewhereclause=yes name=order_no dbname="coilorder.order_no" )
 column=(type=char(14) updatewhereclause=yes key=yes name=coilorderdet_order_no dbname="coilorderdet.order_no" )
 column=(type=long updatewhereclause=yes name=order_seq dbname="coilorderdet.order_seq" )
 column=(type=char(20) updatewhereclause=yes name=coil_no dbname="coilorderdet.coil_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="GroupItem.item_name" )
 column=(type=decimal(2) updatewhereclause=yes name=thin dbname="thin" )
 column=(type=decimal(1) updatewhereclause=yes name=wid dbname="coilorderdet.wid" )
 column=(type=long updatewhereclause=yes name=wlen dbname="wlen" )
 column=(type=long update=yes updatewhereclause=yes name=length dbname="length" initial="0" )
 column=(type=long updatewhereclause=yes name=pri dbname="pri" )
 column=(type=char(1) updatewhereclause=yes name=coilorderdet_work_type dbname="coilorderdet.work_type" values="합체	S/" )
 column=(type=long updatewhereclause=yes name=coilorderdet_div dbname="coilorderdet.div" initial="0" )
 column=(type=decimal(0) updatewhereclause=yes name=coilmst_length dbname="coilmst_length" )
 retrieve="SELECT distinct save_chk = coilorderdet.proc_flag
	, coilorder.order_no                           
     , coilorderdet.order_no                        
     , coilorderdet.order_seq                       
     , coilorderdet.coil_no                         
     , groupitem.item_name                          
     , thin   = convert (decimal (3,2), substring(coilmst.qa,1,1) + '.' + substring(coilmst.qa, 2,2))
     , coilorderdet.wid   
     , wlen   = coilmst.unit_qty * coilmst.qcnt   
     , length = isnull(coilorderdet.length,0) /* 2019.02.08  jowonsuk */ /*(case when isnull(coilmst.length,0) = 0 then coilorderdet.length else  isnull(coilmst.length,0) end )*/ /* 2018-06-18  jowonsuk */
	, pri    = 0
	, coilorderdet.work_type
     , coilorderdet.div
	, round(convert(decimal,  coilmst.unit_qty /  coilmst.bi_qty / coilmst.thin / coilmst.wid * 1000 ),0) coilmst_length 
  FROM (
							SELECT coilmst.coil_no,   /*코일번호*/
									coilmst.loc_no,
									 coilmst.item_no,
									 coilmst.qa,
									 coilmst.qcnt,
									 coilmst.wid,               /*폭*/ 
									 coilmst.unit_qty,        /*단중*/  
									 thin = convert (decimal (3,2) , substring(qa,1,1) + '.' + substring(qa, 2,2)),   /*두께*/   
									(CASE WHEN groupitem.COIL_GRP = 'A10' THEN 2.72  /*AL*/
														  WHEN groupitem.COIL_GRP = 'A11' THEN 2.72 /*AL*/
														  WHEN groupitem.COIL_GRP = 'A50' THEN 8.12 /*GI*/
														  WHEN groupitem.COIL_GRP = 'A51' THEN 8.12 /*GI*/
														  WHEN groupitem.COIL_GRP = 'A60' THEN 1 /*GL*/
														  WHEN groupitem.COIL_GRP = 'A61' THEN 1 /*GL*/
										 END ) bi_qty
							  FROM coilmst INNER JOIN groupitem WITH(NOLOCK) ON coilmst.item_no = groupitem.item_no 

		   ) coilmst        
     , coilorder      
     , coilorderdet   
     , coilsliting    
     , groupitem  
 WHERE ( coilorderdet.order_no = coilsliting.order_no         )   
   and ( coilorder.order_no    = coilorderdet.coilorder_order )   
   and ( coilorderdet.coil_no  = coilmst.coil_no              )   
   and ( coilmst.item_no       = groupitem.item_no            )   
   and ( coilorderdet.loc_no   = coilmst.loc_no               )   
   and ( ( coilorderdet.proc_flag in ( 'M','C' ) ) AND  
         ( coilorder.wc_place      = 'I'         ) AND  
         ( coilorder.order_date    = :ad_start   ) 
       )    
" update="coilorderdet" updatewhere=0 updatekeyinplace=no arguments=(("ad_start", date))  sort="order_no A order_seq A " )
