$PBExportHeader$d_ioinsliting_r.srd
$PBExportComments$코일입고확인서(2004/03/19,이인호) 코일전용
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no rows_per_detail = 15 )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=4288 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=insp_insp_date dbname="insp.insp_date" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=decimal(2) updatewhereclause=yes name=thin dbname="thin" )
 column=(type=decimal(1) updatewhereclause=yes name=wid dbname="wid" )
 column=(type=decimal(4) updatewhereclause=yes name=inspdet_unit_qty dbname="inspdet.unit_qty" )
 column=(type=long updatewhereclause=yes name=inspdet_cnt dbname="inspdet.cnt" )
 column=(type=char(20) updatewhereclause=yes name=inspdet_coil_no dbname="inspdet.coil_no" )
 column=(type=long updatewhereclause=yes name=coilw_unit_qty dbname="insp.unit_qty" )
 retrieve="  SELECT insp.insp_date
       , groupitem.item_name
       , thin  = convert (decimal (3,2) , substring(inspdet.qa,1,1) + '.' + substring(inspdet.qa, 2,2))
       , wid   = convert (decimal (5,1) , substring(inspdet.qa,5,4) + '.' + substring(inspdet.qa,10,1))
       , inspdet.unit_qty
       , inspdet.cnt
       , inspdet.coil_no
       , coilW.unit_qty
    FROM insp with(nolock) inner join  inspdet with(nolock) on insp.insp_no     = inspdet.insp_no
                        inner join purdet with(nolock) on inspdet.pur_no   = purdet.order_no and inspdet.seq_no   = purdet.seq_no
                        inner join  groupitem with(nolock) on inspdet.item_no  = groupitem.item_no
                        left outer join coilmst coilW with(nolock) on purdet.coil_no  = coilW.coil_no  and purdet.rcpt_loc = coilW.loc_no
   WHERE insp.insp_no     = :as_insp
/*
    FROM insp
       , inspdet
       , groupitem
       , coilmst coilW
       , purdet
   WHERE ( insp.insp_no     = inspdet.insp_no   ) 
     AND ( inspdet.pur_no   = purdet.order_no   )
     AND ( inspdet.seq_no   = purdet.seq_no     )
     AND ( purdet.coil_no  *= coilW.coil_no     )
     AND ( purdet.rcpt_loc *= coilW.loc_no      )
     AND ( inspdet.item_no  = groupitem.item_no ) 
     AND ( insp.insp_no     = :as_insp          )
*/" arguments=(("as_insp", string)) )
