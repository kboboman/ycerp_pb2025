 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"ret~" )  TABLE(NAME=~"customer~" )  TABLE(NAME=~"scene~" ) COLUMN(NAME=~"ret.ret_no~") COLUMN(NAME=~"ret.cust_no~") COLUMN(NAME=~"ret.spot_code~") COLUMN(NAME=~"ret.ship_flag~") COLUMN(NAME=~"ret.ship_case~") COLUMN(NAME=~"ret.preret_date~") COLUMN(NAME=~"ret.ret_date~") COLUMN(NAME=~"ret.sale_no~") COLUMN(NAME=~"ret.do_no~") COLUMN(NAME=~"ret.ret_agree~") COLUMN(NAME=~"ret.agree_desc~") COLUMN(NAME=~"ret.approve_top~") COLUMN(NAME=~"ret.approve_team~") COLUMN(NAME=~"ret.create_login~") COLUMN(NAME=~"ret.process_flag~") COLUMN(NAME=~"ret.ret_reason1~") COLUMN(NAME=~"ret.ret_reason2~") COLUMN(NAME=~"ret.ret_reason3~") COLUMN(NAME=~"ret.sale_flag~") COLUMN(NAME=~"ret.rcpt_area~") COLUMN(NAME=~"customer.cust_name~") COLUMN(NAME=~"scene.scene_desc~")    JOIN (LEFT=~"ret.cust_no~"    OP =~"=~"RIGHT=~"customer.cust_no~"    OUTER1 =~"ret.cust_no~" )    JOIN (LEFT=~"ret.spot_code~"    OP =~"=~"RIGHT=~"scene.scene_code~"    OUTER1 =~"ret.spot_code~" )WHERE(    EXP1 =~"ret.ret_no~"   OP =~"=~"    EXP2 =~":as_ret_no~" ) ) ARG(NAME = ~"as_ret_no~" TYPE = string) " update="ret" updatewhere=0 updatekeyinplace=no arguments=(("as_ret_no", string)) )
