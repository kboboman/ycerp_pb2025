table(column=(type=char(14) updatewhereclause=yes name=dodet_do_no dbname="dodet.do_no" )
 column=(type=long updatewhereclause=yes name=dodet_oi_no dbname="dodet.oi_no" )
 column=(type=char(10) updatewhereclause=yes name=dodet_item_no dbname="dodet.item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="groupitem.item_name" )
 column=(type=char(20) updatewhereclause=yes name=dodet_qa dbname="dodet.qa" )
 column=(type=char(20) updatewhereclause=yes name=dodet_qa_cust dbname="dodet.qa_cust" )
 column=(type=decimal(2) updatewhereclause=yes name=dodet_ship_qty dbname="dodet.ship_qty" )
 column=(type=char(14) updatewhereclause=yes name=dodet_sale_no dbname="dodet.sale_no" )
 column=(type=long updatewhereclause=yes name=dodet_seq_no dbname="dodet.seq_no" )
 column=(type=char(30) updatewhereclause=yes name=loc_name dbname="loc_name" )
 retrieve="  SELECT dodet.do_no   
       , dodet.oi_no   
       , dodet.item_no   
       , G.item_name   
       , dodet.qa   
       , dodet.qa_cust   
       , dodet.ship_qty   
       , dodet.sale_no  
       , dodet.seq_no
       , loc_name   = l.loc_name
    FROM dodet 
         LEFT OUTER JOIN groupitem G ON dodet.item_no = G.item_no  
         LEFT OUTER JOIN location  L ON dodet.loc_no  = L.loc_no  
   WHERE dodet.sale_no = :as_orderno    
" arguments=(("as_orderno", string))  sort="dodet_sale_no A dodet_seq_no A " )
