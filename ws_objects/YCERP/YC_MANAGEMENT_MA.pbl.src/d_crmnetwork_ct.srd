 retrieve="  SELECT crm_network.name,   
         crm_network.phone,   
         crm_network.worker,   
         crm_network.institute,   
         crm_network.rank,   
         crm_network.duty,   
         crm_network.comment,   
         crm_network.intimate,   
         crm_network.special,   
         crm_network.emp_name,   
         crm_network.emp_company,   
         crm_network.emp_rank,
         crm_network.sys_date  
    FROM crm_network   
"  sort="name A phone A " )
