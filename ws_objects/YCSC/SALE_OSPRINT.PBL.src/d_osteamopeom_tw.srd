table(column=(type=long updatewhereclause=yes name=seq dbname="seq" )
 column=(type=char(20) updatewhereclause=yes name=area dbname="area" )
 column=(type=char(20) updatewhereclause=yes name=sector dbname="sector" )
 column=(type=char(20) updatewhereclause=yes name=team dbname="team" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="user_id" )
 column=(type=char(20) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(10) updatewhereclause=yes name=rank dbname="rank" )
 column=(type=decimal(6) updatewhereclause=yes name=mod_mm dbname="mod_mm" )
 column=(type=decimal(6) updatewhereclause=yes name=coll1 dbname="coll1" )
 column=(type=decimal(6) updatewhereclause=yes name=week1 dbname="week1" )
 column=(type=decimal(6) updatewhereclause=yes name=per1 dbname="per1" )
 column=(type=decimal(6) updatewhereclause=yes name=coll2 dbname="coll2" )
 column=(type=decimal(6) updatewhereclause=yes name=week2 dbname="week2" )
 column=(type=decimal(6) updatewhereclause=yes name=per2 dbname="per2" )
 column=(type=decimal(6) updatewhereclause=yes name=coll3 dbname="coll3" )
 column=(type=decimal(6) updatewhereclause=yes name=week3 dbname="week3" )
 column=(type=decimal(6) updatewhereclause=yes name=per3 dbname="per3" )
 column=(type=decimal(6) updatewhereclause=yes name=coll4 dbname="coll4" )
 column=(type=decimal(6) updatewhereclause=yes name=week4 dbname="week4" )
 column=(type=decimal(6) updatewhereclause=yes name=per4 dbname="per4" )
 column=(type=decimal(6) updatewhereclause=yes name=coll5 dbname="coll5" )
 column=(type=decimal(6) updatewhereclause=yes name=week5 dbname="week5" )
 column=(type=decimal(6) updatewhereclause=yes name=per5 dbname="per5" )
 column=(type=decimal(6) updatewhereclause=yes name=collt dbname="collt" )
 column=(type=decimal(6) updatewhereclause=yes name=weekt dbname="weekt" )
 column=(type=decimal(6) updatewhereclause=yes name=pert dbname="pert" )
 column=(type=long updatewhereclause=yes name=cyear dbname="cyear" )
 column=(type=long updatewhereclause=yes name=cmon dbname="cmon" )
 retrieve="  SELECT seq       = o.seq
       , area      = o.area
       , sector    = o.sector
       , team      = o.team
       , user_id   = o.user_id
       , user_name = o.user_name
       , rank      = o.rank
       , mod_mm    = a.mod_mm
       , coll1     = a.coll1
       , week1     = a.week1
       , per1      = (case when a.coll1 = 0 then 0 else a.week1 / a.coll1 end)
       , coll2     = a.coll2
       , week2     = a.week2
       , per2      = (case when a.coll2 = 0 then 0 else a.week2 / a.coll2 end)
       , coll3     = a.coll3
       , week3     = a.week3
       , per3      = (case when a.coll3 = 0 then 0 else a.week3 / a.coll3 end)
       , coll4     = a.coll4
       , week4     = a.week4
       , per4      = (case when a.coll4 = 0 then 0 else a.week4 / a.coll4 end)
       , coll5     = a.coll5
       , week5     = a.week5
       , per5      = (case when a.coll5 = 0 then 0 else a.week5 / a.coll5 end)
       , collt     = a.collt
       , weekt     = a.weekt
       , pert      = (case when a.collt = 0 then 0 else a.weekt / a.collt end)
       , cyear     = :ai_year
       , cmon      = :ai_month
    FROM (
         SELECT salesman  = (case when substring(x.insite,1,1) = 'O' then 'insite'   else x.salesman  end)
              , user_name = (case when substring(x.insite,1,1) = 'O' then '내부업체' else x.user_name end)
              , mod_mm    = sum(x.mod_mm)
              , coll1     = sum(x.coll1 ), week1     = sum(x.week1 )
              , coll2     = sum(x.coll2 ), week2     = sum(x.week2 )
              , coll3     = sum(x.coll3 ), week3     = sum(x.week3 )
              , coll4     = sum(x.coll4 ), week4     = sum(x.week4 )
              , coll5     = sum(x.coll5 ), week5     = sum(x.week5 )
              , collt     = sum(x.collt ), weekt     = sum(x.weekt )
           FROM (
                SELECT salesman  = c.salesman
                     , user_name = l.user_name
                     , insite    = (case when m.item_cd is not null then 'O' else '' end)
                     , mod_mm    = w.mod_mm
                     , coll1     = w.coll1, week1     = w.week1, coll2     = w.coll2, week2     = w.week2
                     , coll3     = w.coll3, week3     = w.week3, coll4     = w.coll4, week4     = w.week4
                     , coll5     = w.coll5, week5     = w.week5, collt     = w.collt, weekt     = w.weekt
                  FROM (                                               
                       SELECT cust_no   = (case when a.cust_no is not null then a.cust_no  
                                                else (case when b.cust_no is not null then b.cust_no else c.cust_no end)
                                           end)
                            , mod_mm    = isnull(c.mod_mm,0)
                            , coll1     = isnull(b.coll1,0), week1     = isnull(a.week1,0)
                            , coll2     = isnull(b.coll2,0), week2     = isnull(a.week2,0)
                            , coll3     = isnull(b.coll3,0), week3     = isnull(a.week3,0)
                            , coll4     = isnull(b.coll4,0), week4     = isnull(a.week4,0)
                            , coll5     = isnull(b.coll5,0), week5     = isnull(a.week5,0)
                            , collt     = isnull(b.coll1,0) + isnull(b.coll2,0) + isnull(b.coll3,0) + isnull(b.coll4,0) + isnull(b.coll5,0)  
                            , weekt     = isnull(a.week1,0) + isnull(a.week2,0) + isnull(a.week3,0) + isnull(a.week4,0) + isnull(a.week5,0)  
                         FROM (
                              SELECT cust_no = a.cust_no
                                   , week1   = max(a.week1), week2   = max(a.week2), week3   = max(a.week3)
                                   , week4   = max(a.week4), week5   = max(a.week5)
                                FROM (
                                     SELECT cust_no   = a.cust_no
                                          , week1     = (case when a.weeks = 1 then a.do_total else 0 end)
                                          , week2     = (case when a.weeks = 2 then a.do_total else 0 end)
                                          , week3     = (case when a.weeks = 3 then a.do_total else 0 end)
                                          , week4     = (case when a.weeks = 4 then a.do_total else 0 end)
                                          , week5     = (case when a.weeks = 5 then a.do_total else 0 end)
                                       FROM (
                                            SELECT cust_no   = a.cust_no
                                                 , weeks     = dbo.UF_MonthWEEK(a.do_date, 1)
                                                 , do_total  = sum(a.do_total) / 1.1 / 1000
                                              FROM do a
                                                   LEFT OUTER JOIN customer b  ON a.cust_no  = b.cust_no
                                             WHERE CONVERT(CHAR(10), a.do_date, 111) BETWEEN :as_sdate AND :as_edate
                                               AND ( b.cust_flag         = 'N' )
                                               AND ( b.cust_type        <> 'E' )
                                             /*AND ( b.credit_level     <> 'Z' )*/
                                             GROUP BY a.cust_no, dbo.UF_MonthWEEK(a.do_date, 1)
                                            ) a
                                     ) a
                               GROUP BY a.cust_no
                              ) A

                              FULL OUTER JOIN ( /* 수정목표 */
                                   SELECT cust_no   = a.cust_code
                                        , mod_mm    = sum((case :ai_month
                                                              when  1 then isnull(a.mod_01,0) 
                                                              when  2 then isnull(a.mod_02,0) 
                                                              when  3 then isnull(a.mod_03,0) 
                                                              when  4 then isnull(a.mod_04,0) 
                                                              when  5 then isnull(a.mod_05,0) 
                                                              when  6 then isnull(a.mod_06,0) 
                                                              when  7 then isnull(a.mod_07,0) 
                                                              when  8 then isnull(a.mod_08,0) 
                                                              when  9 then isnull(a.mod_09,0) 
                                                              when 10 then isnull(a.mod_10,0) 
                                                              when 11 then isnull(a.mod_11,0) 
                                                              when 12 then isnull(a.mod_12,0) 
                                                           end)) / 1.1 / 1000
                                    FROM cust_aim a                                      
                                   WHERE datepart(year, a.tar_year) = :ai_year
                                   GROUP BY a.cust_code
                              ) C   ON a.cust_no  = c.cust_no 
                              
                              FULL OUTER JOIN ( /* 매출목표 */
                                   SELECT cust_no   = a.cust_no
                                        , coll1     = sum(a.coll1) / 1.1 / 1000
                                        , coll2     = sum(a.coll2) / 1.1 / 1000
                                        , coll3     = sum(a.coll3) / 1.1 / 1000
                                        , coll4     = sum(a.coll4) / 1.1 / 1000
                                        , coll5     = sum(a.coll5) / 1.1 / 1000
                                     FROM (
                                          SELECT cust_no   = a.cust_no
                                               , coll1     = max(a.coll1)
                                               , coll2     = max(a.coll2)
                                               , coll3     = max(a.coll3)
                                               , coll4     = max(a.coll4)
                                               , coll5     = max(a.coll5)
                                            FROM (
                                                 SELECT cust_no   = a.cust_no                                               
                                                      , coll1     = (case when a.weeks = 1 then isnull(a.coll,0) else 0 end)
                                                      , coll2     = (case when a.weeks = 2 then isnull(a.coll,0) else 0 end)
                                                      , coll3     = (case when a.weeks = 3 then isnull(a.coll,0) else 0 end)
                                                      , coll4     = (case when a.weeks = 4 then isnull(a.coll,0) else 0 end)
                                                      , coll5     = (case when a.weeks = 5 then isnull(a.coll,0) else 0 end)
                                                   FROM cust_aimdet a
                                                  WHERE CONVERT(CHAR(7),a.tar_year,111) = :as_yyyymm
                                                 ) a
                                           GROUP BY a.cust_no
                                          ) a
                                    GROUP BY a.cust_no
                              ) B   ON a.cust_no  = b.cust_no
                       ) W
                       LEFT OUTER JOIN customer  C  ON w.cust_no  = c.cust_no
                       LEFT OUTER JOIN codemst   M  ON c.cust_no  = m.item_cd  AND m.type = '내부업체' AND m.use_yn ='Y'
                       LEFT OUTER JOIN login     L  ON c.salesman = l.user_id
                ) X
            GROUP BY salesman, user_name, x.insite
         ) A
         FULL JOIN opeom_org O  ON o.user_id = a.salesman
   WHERE o.seq  IS NOT NULL
   ORDER BY o.seq
" arguments=(("ai_year", number),("ai_month", number),("as_yyyymm", string),("as_sdate", string),("as_edate", string))  sort="seq A " )
