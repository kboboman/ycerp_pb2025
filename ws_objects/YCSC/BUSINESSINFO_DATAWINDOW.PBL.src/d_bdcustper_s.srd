$PBExportComments$고객정보관리(1998/4/23,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=68 color="536870912" )
table(column=(type=long updatewhereclause=yes name=cust_idno dbname="bdcustper.cust_idno" )
 column=(type=char(20) updatewhereclause=yes name=cust_hname dbname="bdcustper.cust_hname" )
 column=(type=char(30) updatewhereclause=yes name=bdcom_comname dbname="bdcom.comname" )
 column=(type=char(4) updatewhereclause=yes name=bdcom_comcode dbname="bdcom.comcode" )
 column=(type=decimal(0) updatewhereclause=yes name=seq_no dbname="bdcustper.seq_no" )
 column=(type=char(20) updatewhereclause=yes name=project dbname="bdinfodet.project" )
 retrieve="  SELECT DISTINCT bdcustper.cust_idno,   
         bdcustper.cust_hname,   
         bdcom.comname,   
         bdcom.comcode,   
         bdcustper.seq_no,
			bdinfodet.project
    FROM bdcustper,   
         bdcom,   
         bdinfodet  
   WHERE ( bdcustper.cust_no *= bdcom.comcode) and  
         ( bdcustper.seq_no *= bdinfodet.seq ) and  
         ( ( bdcustper.cust_idno is not null ) )    
" )
