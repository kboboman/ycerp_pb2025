table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=order_no dbname="purdet.order_no" initial=" " )
 column=(type=decimal(0) update=yes updatewhereclause=yes key=yes name=seq_no dbname="purdet.seq_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="purdet.item_no" initial=" " )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="purdet.qa" )
 column=(type=datetime update=yes updatewhereclause=yes name=due_date dbname="purdet.due_date" initial=" " )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=order_qty dbname="purdet.order_qty" initial="0 " )
 column=(type=datetime update=yes updatewhereclause=yes name=rlse_date dbname="purdet.rlse_date" initial=" " )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=price dbname="purdet.price" initial="0 " )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="purdet.uom" initial=" " )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=rlse_qty dbname="purdet.rlse_qty" initial="0 " )
 column=(type=char(17) update=yes updatewhereclause=yes name=product_no dbname="purdet.product_no" initial=" " )
 column=(type=char(20) update=yes updatewhereclause=yes name=rcpt_loc dbname="purdet.rcpt_loc" )
 column=(type=char(1) update=yes updatewhereclause=yes name=pur_type dbname="purdet.pur_type" )
 column=(type=char(30) update=yes updatewhereclause=yes name=rem dbname="purdet.rem" initial=" " )
 column=(type=char(20) update=yes updatewhereclause=yes name=coil_no dbname="purdet.coil_no" )
 column=(type=long update=yes updatewhereclause=yes name=purdet_serial_no dbname="purdet.serial_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=work_type dbname="purdet.work_type" )
 column=(type=long update=yes updatewhereclause=yes name=cnt dbname="purdet.cnt" )
 column=(type=char(1) update=yes updatewhereclause=yes name=result_type dbname="purdet.result_type" initial="N" values="생성	N/완료	E/부분	P/입고전취소	Z/입고후취소	C/" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=com_qty dbname="purdet.com_qty" initial="0" )
 column=(type=char(14) update=yes updatewhereclause=yes name=sale_no dbname="purdet.sale_no" )
 column=(type=long update=yes updatewhereclause=yes name=sale_seq dbname="purdet.sale_seq" )
 column=(type=char(50) update=yes updatewhereclause=yes name=cust_name dbname="purdet.cust_name" )
 column=(type=char(50) update=yes updatewhereclause=yes name=sale_rem dbname="purdet.sale_rem" )
 column=(type=char(4) update=yes updatewhereclause=yes name=color dbname="purdet.color" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=unit_qty dbname="purdet.unit_qty" )
 column=(type=char(20) update=yes updatewhereclause=yes name=draw_no dbname="purdet.draw_no" )
 column=(type=char(2) update=yes updatewhereclause=yes name=com_uom dbname="purdet.com_uom" )
 column=(type=char(60) updatewhereclause=yes name=item_item_name dbname="groupitem.item_name" initial=" " )
 column=(type=decimal(4) updatewhereclause=yes name=cprice dbname="cprice" )
 column=(type=decimal(6) updatewhereclause=yes name=yrate dbname="yrate" )
 column=(type=decimal(8) updatewhereclause=yes name=amt dbname="amt" )
 column=(type=char(1) updatewhereclause=yes name=po_print dbname="pur.po_print" )
 retrieve="  SELECT purdet.order_no,   
         purdet.seq_no,   
         purdet.item_no,   
         purdet.qa,   
         purdet.due_date,   
         purdet.order_qty,   
         purdet.rlse_date,   
         purdet.price,   
         purdet.uom,   
         purdet.rlse_qty,   
         purdet.product_no,   
         purdet.rcpt_loc,   
         purdet.pur_type,   
         purdet.rem,   
         purdet.coil_no,   
         purdet.serial_no,   
         purdet.work_type,   
         purdet.cnt,   
         purdet.result_type,   
         purdet.com_qty,   
         purdet.sale_no,   
         purdet.sale_seq,   
         purdet.cust_name,   
         purdet.sale_rem,   
         purdet.color,   
         purdet.unit_qty,   
         purdet.draw_no,   
         purdet.com_uom,   
         groupitem.item_name,   
         cprice = 00000000.0000,   
         yrate = 00.000000,   
         amt = case when supp.round = 'Y' then round(purdet.com_qty * purdet.price, 0) else round(purdet.com_qty * purdet.price, 0, 1) end,   
         pur.po_print  
    FROM purdet,   
         groupitem,   
         pur,   
         supp  
   WHERE ( purdet.item_no = groupitem.item_no ) and  
         ( purdet.order_no = pur.order_no ) and  
         ( pur.supp_no = supp.supp_no ) and  
         ( ( purdet.order_no = :as_order ) )    
" update="purdet" updatewhere=0 updatekeyinplace=no arguments=(("as_order", string))  sort="seq_no A " )
