table(column=(type=char(14) update=yes updatewhereclause=yes key=yes name=insp_no dbname="inspdet.insp_no" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=oi_no dbname="inspdet.oi_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="inspdet.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="inspdet.qa" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=rcpt_qty dbname="inspdet.rcpt_qty" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="inspdet.uom" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=price dbname="inspdet.price" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=apoi_qty dbname="inspdet.apoi_qty" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=rate_cash dbname="inspdet.rate_cash" )
 column=(type=char(14) update=yes updatewhereclause=yes name=pur_no dbname="inspdet.pur_no" )
 column=(type=long update=yes updatewhereclause=yes name=seq_no dbname="inspdet.seq_no" )
 column=(type=char(50) update=yes updatewhereclause=yes name=rem dbname="inspdet.rem" )
 column=(type=char(10) update=yes updatewhereclause=yes name=loc_no dbname="inspdet.loc_no" )
 column=(type=long update=yes updatewhereclause=yes name=cnt dbname="inspdet.cnt" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=comqty dbname="inspdet.comqty" )
 column=(type=char(60) updatewhereclause=yes name=item_item_name dbname="item.item_name" )
 column=(type=decimal(4) updatewhereclause=yes name=item_price_a dbname="item.price_a" )
 column=(type=char(3) updatewhereclause=yes name=insp_curr_code dbname="insp.curr_code" )
 column=(type=decimal(2) updatewhereclause=yes name=a_qty dbname="inspdet.a_qty" )
 column=(type=char(1) updatewhereclause=yes name=pick dbname="pick" initial="N" values="	Y/	N" )
 column=(type=decimal(3) updatewhereclause=yes name=a_price dbname="inspdet.a_price" )
 column=(type=long updatewhereclause=yes name=c_an dbname="inspdet.c_an" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"inspdet~" )  TABLE(NAME=~"insp~" )  TABLE(NAME=~"item~" ) COLUMN(NAME=~"inspdet.insp_no~") COLUMN(NAME=~"inspdet.oi_no~") COLUMN(NAME=~"inspdet.item_no~") COLUMN(NAME=~"inspdet.qa~") COLUMN(NAME=~"inspdet.rcpt_qty~") COLUMN(NAME=~"inspdet.uom~") COLUMN(NAME=~"inspdet.price~") COLUMN(NAME=~"inspdet.apoi_qty~") COLUMN(NAME=~"inspdet.rate_cash~") COLUMN(NAME=~"inspdet.pur_no~") COLUMN(NAME=~"inspdet.seq_no~") COLUMN(NAME=~"inspdet.rem~") COLUMN(NAME=~"inspdet.loc_no~") COLUMN(NAME=~"inspdet.cnt~") COLUMN(NAME=~"inspdet.comqty~") COLUMN(NAME=~"item.item_name~") COLUMN(NAME=~"item.price_a~") COLUMN(NAME=~"insp.curr_code~") COMPUTE(NAME=~"0000000.00 a_qty~") COMPUTE(NAME=~"'N' pick~") COMPUTE(NAME=~"0000000.000a_price~") COMPUTE(NAME=~"00 c_an~")    JOIN (LEFT=~"inspdet.insp_no~"    OP =~"=~"RIGHT=~"insp.insp_no~" )    JOIN (LEFT=~"inspdet.item_no~"    OP =~"=~"RIGHT=~"item.item_no~" )    JOIN (LEFT=~"inspdet.qa~"    OP =~"=~"RIGHT=~"item.qa~" )WHERE(    EXP1 =~"insp.supp_no~"   OP =~"=~"    EXP2 =~":as_supp_no~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"insp.insp_date~"   OP =~">=~"    EXP2 =~":ad_sdate~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"insp.insp_date~"   OP =~"<=~"    EXP2 =~":ad_edate~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"inspdet.rcpt_qty~"   OP =~"<>~"    EXP2 =~"inspdet.apoi_qty~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"insp.pur_flag~"   OP =~"=~"    EXP2 =~":as_pur_flag~" ) ) ARG(NAME = ~"as_supp_no~" TYPE = string)  ARG(NAME = ~"ad_sdate~" TYPE = date)  ARG(NAME = ~"ad_edate~" TYPE = date)  ARG(NAME = ~"as_pur_flag~" TYPE = string) " update="inspdet" updatewhere=0 updatekeyinplace=no arguments=(("as_supp_no", string),("ad_sdate", date),("ad_edate", date),("as_pur_flag", string))  sort="oi_no A " )
