table(column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(11) updatewhereclause=yes name=do_spot_code dbname="spot_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene_desc" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=decimal(8) updatewhereclause=yes name=calc_amt dbname="calc_amt" )
 retrieve="  SELECT cust_no      = a.cust_no
       , cust_name    = a.cust_name
       , spot_code    = a.spot_code    
       , scene_desc   = a.scene_desc    
       , item_name    = a.item_name        
       , calc_amt     = sum(a.calc_amt) /*SUM((case when a.round = 'Y' then 
                                   (case when a.calc_qty < 0 then 
                                              round(a.price * a.calc_qty, 0)
                                         else round(a.price * a.calc_qty + 0.000001, 0) 
                                    end)
                              else (case when a.calc_qty < 0 then 
                                              round(a.price * a.calc_qty, 0, 1)
                                         else round(a.price * a.calc_qty + 0.000001, 0, 1) 
                                    end)                                   
                         end))*/
    FROM (
         SELECT cust_no    = do.cust_no
              , cust_name  = customer.cust_name
              , spot_code  = do.spot_code   
              , scene_desc = scene.scene_desc   
              , item_no    = dodet.item_no
              , item_name  = g.item_name
              , ship_amount= (case when do.ship_flag = 'D' and do.shipamt_case = 'R' then do.ship_amount else 0 end) 
              , calc_qty   = dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty)             
              , calc_amt   = dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty) * dodet.price
              , price      = dodet.price
              , do_total   = do.do_total
              , round      = customer.round
           FROM scene_grpdtl
              , do      
              , dodet
              , scene   
              , customer  
              , groupitem G
          WHERE ((:as_project   = '%') OR
                 (:as_project  <> '%' AND scene_grpdtl.project = :as_project)
                )
            AND ( scene_grpdtl.scene_code = do.spot_code )
            AND ( do.cust_no    = scene.cust_no     )   
            AND ( do.spot_code  = scene.scene_code  )   
            AND ( do.cust_no    = customer.cust_no  )   
            AND ( do.do_no      = dodet.do_no       )   
            AND ( dodet.item_no = G.item_no         )
            AND ( do.spot_code IS NOT NULL          )    
            AND ( do.do_date       BETWEEN :ad_sdate AND :ad_edate )
            AND ( customer.salesman   LIKE :as_salesman )
        ) A
  GROUP BY a.cust_no
         , a.cust_name
         , a.spot_code    
         , a.scene_desc    
         , a.item_name
" arguments=(("as_project", string),("ad_sdate", date),("ad_edate", date),("as_salesman", string))  sort="cust_name A scene_scene_desc A item_name A " )
