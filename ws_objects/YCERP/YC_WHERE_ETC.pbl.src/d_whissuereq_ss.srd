table(column=(type=datetime updatewhereclause=yes name=req_date dbname="req_date" )
 column=(type=char(10) updatewhereclause=yes name=req_salesman dbname="salesman" )
 column=(type=long updatewhereclause=yes name=req_seq dbname="req_seq" )
 column=(type=long updatewhereclause=yes name=cnt dbname="cnt" )
 column=(type=long updatewhereclause=yes name=nocnt dbname="nocnt" )
 column=(type=char(1) updatewhereclause=yes name=confirm_flag dbname="confirm_flag" values="확정	A/" )
 column=(type=char(10) updatewhereclause=yes name=accept_user dbname="accept_user" )
 column=(type=char(10) updatewhereclause=yes name=accept1 dbname="accept1" )
 column=(type=char(10) updatewhereclause=yes name=accept2 dbname="accept2" )
 column=(type=char(10) updatewhereclause=yes name=accept3 dbname="accept3" )
 column=(type=char(10) updatewhereclause=yes name=accept4 dbname="accept4" )
 column=(type=char(10) updatewhereclause=yes name=accept5 dbname="accept5" )
 column=(type=char(1) updatewhereclause=yes name=chk0 dbname="chk0" )
 column=(type=char(1) updatewhereclause=yes name=chk1 dbname="chk1" )
 column=(type=char(1) updatewhereclause=yes name=chk2 dbname="chk2" )
 column=(type=char(1) updatewhereclause=yes name=chk3 dbname="chk3" )
 column=(type=char(1) updatewhereclause=yes name=chk4 dbname="chk4" )
 column=(type=char(1) updatewhereclause=yes name=chk5 dbname="chk5" )
 column=(type=char(1) updatewhereclause=yes name=chkfont dbname="chkfont" )
 column=(type=char(10) updatewhereclause=yes name=accept_name dbname="accept_name" )
 column=(type=char(12) updatewhereclause=yes name=cuser_name dbname="cuser_name" )
 column=(type=datetime updatewhereclause=yes name=sys_date dbname="sys_date" )
 column=(type=long updatewhereclause=yes name=issue_schedule dbname="issue_schedule" )
 column=(type=char(1) updatewhereclause=yes name=print_yn dbname="print_yn" )
 retrieve="  SELECT req_date     = i.req_date  
       , salesman     = i.salesman  
       , req_seq      = i.req_seq   
       , cnt          = isnull(d.cnt,0)
       , nocnt        = isnull(e.cnt,0)
       , confirm_flag = i.confirm_flag
       , accept_user  = i.accept_user
       , accept1      = i.accept1
       , accept2      = i.accept2
       , accept3      = i.accept3
       , accept4      = i.accept4
       , accept5      = i.accept5
       , chk0         = ISNULL(i.chk0,'N')
       , chk1         = i.chk1
       , chk2         = i.chk2
       , chk3         = i.chk3
       , chk4         = i.chk4
       , chk5         = i.chk5
       , chkfont      = 'N'
       , accept_name  = b.user_name
       , cuser_name   = rtrim(a.user_name) + convert(char(2), i.req_seq) 
       , sys_date     = i.sys_date
	  , isnull(f.issue_schedule,0) issue_schedule
	  , isnull(print_yn, 'N') print_yn
    FROM    
	   issuereq i 
         LEFT OUTER JOIN login a ON i.salesman    = a.user_id
         LEFT OUTER JOIN login b ON i.accept_user = b.user_id
         LEFT OUTER JOIN (
									  SELECT a.req_date, a.salesman, a.req_seq, cnt = count(*)
										 FROM issuereqdet a
										WHERE a.req_date     = :ad_date
										  AND a.req_flag     = 'A'
										GROUP BY a.req_date, a.salesman, a.req_seq
       								  ) d ON i.req_date = d.req_date AND i.salesman = d.salesman AND i.req_seq = d.req_seq
         LEFT OUTER JOIN (
									  SELECT a.req_date, a.salesman, a.req_seq, cnt = count(*)
										 FROM issuereqdet a
										WHERE a.req_date     = :ad_date
										  AND a.req_flag     = 'A'
										  AND a.do_date     is not null
										GROUP BY a.req_date, a.salesman, a.req_seq
							      ) e ON i.req_date = e.req_date AND i.salesman = e.salesman AND i.req_seq = e.req_seq	
	 LEFT OUTER JOIN (

									select req_date, salesman, req_seq, COUNT(*) issue_schedule			/*직출체크를 위한 */
									from issuereqdet
									where issue_schedule IN ( 'A', 'B' )
											  and req_date     = :ad_date
									GROUP BY req_date, salesman, req_seq
							  ) F ON i.req_date = F.req_date AND i.salesman = F.salesman AND i.req_seq = F.req_seq
   WHERE ( i.req_date         = :ad_date       ) 
     AND ( i.accept_area   LIKE :as_area       ) 
     AND ( i.confirm_flag  LIKE :as_flag       ) 
     AND ( dbo.uf_accept_user(i.accept_user)  LIKE :as_acceptuser )
     AND ((:as_salesman  = '%' AND i.salesman LIKE :as_salesman) OR
          (:as_salesman <> '%' AND i.salesman    = :as_salesman)
         )
" arguments=(("as_area", string),("ad_date", date),("as_flag", string),("as_salesman", string),("as_acceptuser", string))  sort="sys_date D " )
