$PBExportHeader$d_incounu_m.srd
$PBExportComments$담당자별실사품목(2001/09/11,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=72 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=user_id dbname="incounu.user_id" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="incounu.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=qa dbname="incounu.qa" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=loc_no dbname="incounu.loc_no" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name dbname="login.user_name" )
 column=(type=char(30) updatewhereclause=yes name=location_loc_name dbname="location.loc_name" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="groupitem.item_name" )
 column=(type=long update=yes updatewhereclause=yes name=save_qty dbname="incounu.save_qty" )
 retrieve="  SELECT incounu.user_id,   
         incounu.item_no,   
         incounu.qa,   
         incounu.loc_no,   
         login.user_name,   
         location.loc_name,   
         groupitem.item_name,   
         incounu.save_qty  
    FROM incounu,   
         login,   
         location,   
         groupitem  
   WHERE ( incounu.user_id = login.user_id ) and  
         ( incounu.loc_no = location.loc_no ) and  
         ( incounu.item_no = groupitem.item_no ) and  
         ( incounu.user_id = :as_user ) AND  
         incounu.loc_no = :as_loc    
" update="incounu" updatewhere=0 updatekeyinplace=no arguments=(("as_user", string),("as_loc", string))  sort="item_name A qa A " )
