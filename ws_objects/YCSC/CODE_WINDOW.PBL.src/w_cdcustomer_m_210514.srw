type cb_save from commandbutton within tabpage_5
integer x = 4279
integer y = 36
integer width = 233
integer height = 100
integer taborder = 72
integer textsize = -10
integer weight = 400
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
boolean enabled = false
string text = "저장"
end type

event clicked;dwitemstatus l_status, l_status_rem
boolean lb_update_chk = false

if GF_PERMISSION('판매거래처관리edit', gs_userid) = 'N' then
	MessageBox('확인', '판매거래처관리 권한이 없습니다.')
	return
end if

if MessageBox("저장","저장하시겠습니까?",information!,okcancel!,2) = 2 then
	return
end if

//==GF_USEPROGRAM(프로그램 사용현황)===========================================================
GF_USEPROGRAM( gs_userid, Parent.ClassName(), "S", string(gf_today(),'yyyy/mm/dd'), "판매거래처관리(w_cdcustomer_m)" )
//=============================================================================================

tab_1.tabpage_5.dw_18.accepttext()
if tab_1.tabpage_5.dw_18.rowcount() < 1 then 
	MessageBox('오류', '거래처선택 오류, 거래처를 다시 조회후 작업하세요. ')
	return
end if

setpointer(hourglass!)
lb_update_chk = wf_update1(tab_1.tabpage_5.dw_18, "Y")

if lb_update_chk = true then
	string ls_sale_control, ls_cust_no, ls_text
	
	ls_sale_control = tab_1.tabpage_5.dw_18.object.sale_control[1]
	ls_cust_no = tab_1.tabpage_5.dw_18.object.cust_no[1]
	if isnull(ls_sale_control) then ls_sale_control = 'N'

	string ls_s_sms_yn, ls_s_area_no, ls_s_tel
	ls_s_tel = 'chulha_t_0'	// 본사

	if is_sale_control <> ls_sale_control then
		if ls_sale_control = 'A' or ls_sale_control = 'Y' then
			ls_text = '매출 통제대상으로 선정되었습니다.'
		else
			ls_text = '매출 통제대상에서 해제되었습니다.'
		end if

		string ls_s_cust_name, ls_s_scene_desc, ls_s_do_date, ls_s_hp_no, ls_s_scene_tel, ls_s_cust_tel, ls_s_msg, ls_s_stel
		SELECT top 1 b.cust_name, replace(substring(ltrim(rtrim(isnull(d.hp_no,''))),1,13), '-', '')
		  INTO :ls_s_cust_name, :ls_s_hp_no				
		  FROM customer b, salehp d
		 WHERE b.salesman = d.user_id AND b.cust_no = :ls_cust_no;

		ls_s_msg = '[유창]' + ls_s_cust_name + '는 ' + ls_text 

		SELECT top 1 replace(substring(ltrim(rtrim(isnull(d.hp_no,''))),1,13), '-', '') 
		  INTO :ls_s_stel
		  FROM salehp d
		 WHERE user_id = :ls_s_tel;
		
		choose case LeftA(ls_s_hp_no,3)
			case '010','011','016','017','018','019'
			case else
				ls_s_hp_no = ''
		end choose
		
		if ls_s_hp_no = '' or isnull(ls_s_hp_no) then
		else
      	// GF_MMSSEND( as_userid, as_sendhp, as_recvhp, as_recvname, as_message )
				GF_MMSSEND( gs_userid, ls_s_stel, ls_s_hp_no,  '거래처관리', ls_s_msg )
		end if

		is_sale_control = ls_sale_control		
	end if
end if

end event

