$PBExportComments$운반비청구내역서 (2002/08/28,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=68 color="10789024" )
detail(height=76 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=do_do_no dbname="do_no" )
 column=(type=char(1) updatewhereclause=yes name=do_ship_flag dbname="ship_flag" values="착불	C/부담	B/대여	D/시화방문	M/화곡방문	H/반월방문	Y/공사원가	A/재료원가	R/" )
 column=(type=decimal(0) updatewhereclause=yes name=ship_amount dbname="ship_amount" )
 column=(type=char(60) updatewhereclause=yes name=do_driver dbname="driver" )
 column=(type=char(1) updatewhereclause=yes name=do_shipamt_case dbname="shipamt_case" values="현금	C/외상	R/" )
 column=(type=char(10) updatewhereclause=yes name=docar_name dbname="name" )
 column=(type=char(40) updatewhereclause=yes name=docar_cargo_name dbname="cargo_name" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene_desc" )
 column=(type=char(1) updatewhereclause=yes name=ship_close dbname="ship_close" values="	C/	O" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_cash dbname="do_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_rate dbname="do_rate" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_total dbname="do_total" )
 column=(type=datetime updatewhereclause=yes name=do_ship_date dbname="ship_date" )
 column=(type=datetime updatewhereclause=yes name=log_date dbname="log_date" )
 column=(type=char(10) updatewhereclause=yes name=close_user dbname="close_user" )
 column=(type=char(180) updatewhereclause=yes name=sale_no dbname="sale_no" )
 column=(type=char(10) updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=char(10) updatewhereclause=yes name=edate dbname="edate" )
 column=(type=char(5) updatewhereclause=yes name=budam_desc dbname="budam_desc" )
 column=(type=char(50) updatewhereclause=yes name=car_gbn dbname="car_gbn" )
 column=(type=char(10) updatewhereclause=yes name=salesman dbname="salesman" )
 column=(type=char(10) updatewhereclause=yes name=area dbname="area" )
 column=(type=char(12) updatewhereclause=yes name=customer_register_no dbname="register_no" )
 column=(type=char(10) updatewhereclause=yes name=docar_icube_no dbname="icube_no" )
 column=(type=char(60) updatewhereclause=yes name=rem dbname="rem" )
 column=(type=char(13) updatewhereclause=yes name=dr_hp dbname="dr_hp" )
 column=(type=char(80) updatewhereclause=yes name=shipto_addr dbname="shipto_addr" )
 retrieve="  SELECT do.do_no                                         
       , do.ship_flag                                     
       , do.ship_amount                                   
       , isnull(do.driver,'') driver
       , do.shipamt_case                                  
       , docar.name                                       
       , docar.cargo_name                                 
       , customer.cust_name                               
       , scene.scene_desc                                 
       , do.ship_close                                    
       , do.do_cash                                       
       , do.do_rate                                       
       , do.do_total                                      
       , do.ship_date                                     
       , log_date   = do.log_date                        
       , do.close_user                                 
       , sale_no    = dbo.uf_getdosaleno(do.do_no)        
       , sdate      = (case when :as_sdate = '' then '          ' else :as_sdate end)
       , edate      = (case when :as_edate = '' then '          ' else :as_edate end)
       , budam_desc = do.budam_desc                    
       , car_gbn    = (select item_nm from codemst where type = 'car_gbn' and item_cd = do.car_gbn)
       , salesman   = login.user_name
       , area       = do.area_no
       , customer.register_no                               
       , docar.icube_no                  
		 , do.rem			rem
		 , do.dr_hp			dr_hp
		 , do.shipto_addr	shipto_addr
     FROM  do with(nolock) inner join customer with(nolock) on do.cust_no = customer.cust_no
                                              left outer  join scene with(nolock) on do.spot_code  = scene.scene_code
                                              left outer  join docar with(nolock) on do.driver  = docar.driver 
                                              left outer  join login with(nolock) on customer.salesman   = login.user_id
     
     WHERE  ( ( do.do_no           LIKE :as_area + '%'        ) AND  
           ( convert(char(10),do.ship_date,111)    BETWEEN :as_sdate and :as_edate ) AND  
/*           ( do.ship_flag         IN ('D' , 'B', 'A', 'R') ) AND  */
           ( do.ship_close  LIKE :as_flag ) 
         )    
/*
  FROM customer   
       , do         
       , scene      
       , docar   
       , login  
   WHERE ( do.spot_code           *= scene.scene_code )  
     AND ( do.driver              *= docar.driver     )  
     AND ( do.cust_no              = customer.cust_no )  
     AND ( customer.salesman      *= login.user_id    )  
     AND ( ( do.do_no           LIKE :as_area + '%'        ) AND  
           ( convert(char(10),do.ship_date,111)    BETWEEN :as_sdate and :as_edate ) AND  
           ( do.ship_flag         IN ('D' , 'B', 'A', 'R') ) AND  
           ( do.ship_close      LIKE :as_flag ) 
         )   
*/

  UNION ALL
  SELECT ask_head.ask_no                                  
       , ship_flag     = 'B'                               
       , ask_head.ship_amount                             
       , isnull(ask_head.driver,'') driver
       , shipamt_case  = ''                             
       , docar.name                                       
       , docar.cargo_name                                 
       , cust_name     = '(주)유창'                        
       , scene_desc    = '시화사업장'                     
       , ask_head.ship_close                           
       , 0                                                
       , 0                                                
       , 0                                                
       , ask_head.ship_date                               
       , log_date      = ask_head.ship_date                    
       , ask_head.close_user                           
       , ''                                            
       , sdate      = :as_sdate
       , edate      = :as_edate
       , budam_desc = ''                               
       , car_gbn    = ''  
       , salesman   = ''
       , area       = ''
       , register_no= ''
       , docar.icube_no                                 
		 , ''			rem
		 , ''			dr_hp
		 , ''			shipto_addr
     FROM ask_head with(nolock) left outer join docar with(nolock) on ask_head.driver  = docar.driver     
     WHERE  ( 
                       ( :as_area                  = 'S'                   ) and  
                       ( convert(char(10),ask_head.ship_date,111)  BETWEEN :as_sdate and :as_edate ) and  
                       (  ask_head.ship_close    LIKE :as_flag              ) 
                    )    
/*
    FROM ask_head
       , docar
   WHERE ( ask_head.driver            *= docar.driver  ) 
     AND ( ( :as_area                  = 'S'                   ) and  
           ( convert(char(10),ask_head.ship_date,111)  BETWEEN :as_sdate and :as_edate ) and  
           ( ask_head.ship_close    LIKE :as_flag              ) 
         )    
*/
  UNION ALL
  SELECT case when do_no is not null then do_no else dbo.uf_getdatestring(doshipetc.etc_date) end   
       , doshipetc.ship_flag                              
       , doshipetc.ship_amount                            
       , isnull(doshipetc.driver,'') driver
       , doshipetc.shipamt_case                           
       , doshipetc.drv_name                               
       , doshipetc.cargo_name                             
       , customer.cust_name                               
       , scene.scene_desc                                 
       , doshipetc.ship_close                             
       , 0                                                
       , 0                                                
       , 0                                                
       , doshipetc.etc_date                               
       , log_date   = doshipetc.etc_date                    
       , doshipetc.user_id                             
       , doshipetc.sale_no                             
       , sdate      = :as_sdate
       , edate      = :as_edate
       , budam_desc = ''                               
       , car_gbn    = ''
       , salesman   = login.user_name
       , area       = doshipetc.etc_area
       , customer.register_no                               
       , docar.icube_no      
		 , ''			rem
		 , ''			dr_hp
		 , ''			shipto_addr  
from doshipetc with(nolock) inner join customer with(nolock) on doshipetc.cust_no          = customer.cust_no
                                left outer join scene with(nolock) on doshipetc.scene_code   = scene.scene_code
                                left outer join docar with(nolock) on doshipetc.driver            = docar.driver
                                left outer join login with(nolock) on customer.salesman       = login.user_id
WHERE 
      ( ( doshipetc.etc_area      LIKE :as_area + '%'        ) and  
           ( convert(char(10),doshipetc.etc_date,111)   BETWEEN :as_sdate and :as_edate ) and  
           ( doshipetc.ship_close    LIKE :as_flag              ) and
           ( doshipetc.doship_req       = 'Y'                   )
         )  
/*
 FROM customer    
       , doshipetc   
       , scene  
       , login
       , docar
   WHERE ( doshipetc.driver            *= docar.driver     ) 
     and ( doshipetc.scene_code        *= scene.scene_code )  
     and ( doshipetc.cust_no            = customer.cust_no )  
     and ( customer.salesman           *= login.user_id    )  
     and ( ( doshipetc.etc_area      LIKE :as_area + '%'        ) and  
           ( convert(char(10),doshipetc.etc_date,111)   BETWEEN :as_sdate and :as_edate ) and  
           ( doshipetc.ship_close    LIKE :as_flag              ) and
           ( doshipetc.doship_req       = 'Y'                   )
         )  

*/
" arguments=(("as_area", string),("as_sdate", string),("as_edate", string),("as_flag", string))  sort="docar_name A do_ship_flag A customer_cust_name A do_do_no A " )
group(level=1 header.height=0 trailer.height=68 by=("docar_name" ) header.color="79741120" trailer.color="15780518" )
