 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"pur~" )  TABLE(NAME=~"supp~" ) COLUMN(NAME=~"pur.order_no~") COLUMN(NAME=~"pur.supp_no~") COLUMN(NAME=~"pur.shipto_addr~") COLUMN(NAME=~"pur.curr_code~") COLUMN(NAME=~"pur.order_date~") COLUMN(NAME=~"pur.buyer~") COLUMN(NAME=~"pur.terms~") COLUMN(NAME=~"pur.fob~") COLUMN(NAME=~"pur.revision_no~") COLUMN(NAME=~"pur.revision_date~") COLUMN(NAME=~"pur.po_print~") COLUMN(NAME=~"pur.open_close~") COLUMN(NAME=~"pur.close_date~") COLUMN(NAME=~"pur.close_type~") COLUMN(NAME=~"pur.subcon~") COLUMN(NAME=~"supp.supp_name~") COLUMN(NAME=~"pur.rem~")    JOIN (LEFT=~"pur.supp_no~"    OP =~"=~"RIGHT=~"supp.supp_no~"    OUTER1 =~"pur.supp_no~" )WHERE(    EXP1 =~"pur.order_no~"   OP =~"=~"    EXP2 =~":as_order~" ) ) ARG(NAME = ~"as_order~" TYPE = string) " update="pur" updatewhere=0 updatekeyinplace=no arguments=(("as_order", string)) )
