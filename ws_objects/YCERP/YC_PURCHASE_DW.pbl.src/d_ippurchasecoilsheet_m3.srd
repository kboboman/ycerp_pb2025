table(column=(type=char(12) update=yes updatewhereclause=yes key=yes name=order_no dbname="order_coilsheet_det.order_no" initial=" " )
 column=(type=long update=yes updatewhereclause=yes key=yes name=round dbname="order_coilsheet_det.round" )
 column=(type=char(6) update=yes updatewhereclause=yes key=yes name=order_seq dbname="order_coilsheet_det.order_seq" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="order_coilsheet_det.item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="GroupItem.item_name" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="order_coilsheet_det.qa" )
 column=(type=char(20) update=yes updatewhereclause=yes name=coilsheet_no dbname="order_coilsheet_det.coilsheet_no" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="order_coilsheet_det.uom" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=qty dbname="order_coilsheet_det.qty" )
 column=(type=decimal(1) update=yes updatewhereclause=yes name=wid dbname="order_coilsheet_det.wid" )
 column=(type=long update=yes updatewhereclause=yes name=cnt dbname="order_coilsheet_det.cnt" )
 column=(type=long update=yes updatewhereclause=yes name=div dbname="order_coilsheet_det.div" )
 column=(type=char(1) update=yes updatewhereclause=yes name=result_type dbname="order_coilsheet_det.result_type" )
 retrieve="  SELECT   order_coilsheet_det.order_no order_no
                 , order_coilsheet_det.round
                 , order_coilsheet_det.order_seq
                 , order_coilsheet_det.item_no
			 , groupitem.item_name
                 , order_coilsheet_det.qa
                 , order_coilsheet_det.coilsheet_no
                 , order_coilsheet_det.uom
                 , order_coilsheet_det.qty
                 , order_coilsheet_det.wid
                 , order_coilsheet_det.cnt
                 , order_coilsheet_det.div             
                 , order_coilsheet_det.result_type
    FROM order_coilsheet_det inner join groupitem on order_coilsheet_det.item_no = groupitem.item_no
   WHERE ( order_coilsheet_det.order_no = :as_order_no ) 
/*     AND ( order_coilsheet_det.order_seq like :as_seq+'%'  ) */
     AND ( order_coilsheet_det.round = 2 )
" update="order_coilsheet_det" updatewhere=0 updatekeyinplace=no arguments=(("as_order_no", string),("as_seq", string))  sort="order_seq A " )
