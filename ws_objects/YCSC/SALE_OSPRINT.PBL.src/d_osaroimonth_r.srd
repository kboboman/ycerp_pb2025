$PBExportComments$물품별 월 매출집계 DISPLAY(1998/05/15, 정재수)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=72 color="79416533" )
summary(height=0 color="536870912" )
footer(height=72 color="15780518" )
detail(height=0 color="553648127" )
table(column=(type=char(10) updatewhereclause=yes name=item_no dbname="aroi.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="aroi.qa" )
 column=(type=decimal(2) updatewhereclause=yes name=ship_qty dbname="aroi.ship_qty" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="aroi.uom" )
 column=(type=decimal(4) updatewhereclause=yes name=rate_cash dbname="aroi.rate_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=ori_amount dbname="aroi.ori_amount" )
 column=(type=decimal(4) updatewhereclause=yes name=aroiinv_gl_cur_rate dbname="aroiinv.gl_cur_rate" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=long updatewhereclause=yes name=aroi_dc_rate dbname="aroi.dc_rate" )
 column=(type=char(3) updatewhereclause=yes name=aroiinv_curr_code dbname="aroiinv.curr_code" )
 column=(type=long updatewhereclause=yes name=cc_year dbname="c_year" )
 column=(type=long updatewhereclause=yes name=cc_month dbname="c_month" )
 retrieve="  SELECT aroi.item_no,   
         aroi.qa,   
         aroi.ship_qty,   
         aroi.uom,   
         aroi.rate_cash,   
         aroi.ori_amount,   
         aroiinv.gl_cur_rate,   
         groupitem.item_name,   
         aroi.dc_rate,   
         aroiinv.curr_code,   
         datepart(year, aroiinv.oi_date) c_year,   
         datepart(month, aroiinv.oi_date) c_month  
    FROM aroi,   
         aroiinv,
         customer,   
         groupitem  
   WHERE ( aroiinv.aroiinv_no = aroi.aroiinv_no ) and  
         ( aroi.item_no = groupitem.item_no ) and 
         ( aroiinv.cust_no = customer.cust_no ) and 
         ( ( aroiinv.inv_area like :as_area ) AND  
         ( aroiinv.sale_flag in ( :asa_flag ) )AND  
         ( datepart(year, aroiinv.oi_date) = :al_year ) AND  
         ( datepart(month, aroiinv.oi_date) = :al_month ) AND  
         ( aroiinv.delete_flag = 'N' ) ) AND
         ( customer.salesman like :as_userid )    
" arguments=(("as_area", string),("asa_flag", stringlist),("al_year", number),("al_month", number),("as_userid", string))  sort="item_no A qa A " )
group(level=1 header.height=0 trailer.height=68 by=("item_no" ) header.color="536870912" trailer.color="536870912" )
group(level=2 header.height=0 trailer.height=68 by=("c_qa" ) header.color="553648127" trailer.color="536870912" )
