detail(height=88 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes name=scene_code dbname="SScene.scene_code" )
 column=(type=char(40) update=yes updatewhereclause=yes name=scene_desc dbname="SScene.scene_desc" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="SSceneSALES.user_id" )
 column=(type=char(50) update=yes updatewhereclause=yes name=scene_use dbname="scene_use" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 retrieve="  SELECT SScene.scene_code   
       , SScene.scene_desc   
       , SSceneSALES.user_id
       , scene_use = a.item_nm   
       , user_name = login.user_name
    FROM SScene
         LEFT OUTER JOIN (
              SELECT item_cd, item_nm FROM codemst WHERE type = '선행영업_용도' AND use_yn = 'Y'
         ) A ON SScene.scene_use = A.item_cd

         LEFT OUTER JOIN SSceneSALES ON SScene.scene_code   = SSceneSALES.scene_code
         LEFT OUTER JOIN login       ON SSceneSALES.user_id = login.user_id
   WHERE ( SScene.scene_code  = :as_scenecode )
     AND ((:as_salesman   = '%') OR
          (:as_salesman  <> '%' AND SSceneSALES.user_id   = :as_salesman)
         )
" arguments=(("as_scenecode", string),("as_salesman", string))  sort="scene_code D " )
