 column=(type=char(50) updatewhereclause=yes name=saledet_rem dbname="saledet.rem" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"customer~" )  TABLE(NAME=~"sale~" )  TABLE(NAME=~"saledet~" )  TABLE(NAME=~"groupitem~" ) COLUMN(NAME=~"sale.cust_no~") COLUMN(NAME=~"customer.cust_name~") COLUMN(NAME=~"sale.scene_code~") COLUMN(NAME=~"sale.order_no~") COLUMN(NAME=~"sale.sale_flag~") COLUMN(NAME=~"sale.curr_code~") COLUMN(NAME=~"sale.order_date~") COLUMN(NAME=~"sale.due_date~") COLUMN(NAME=~"saledet.seq_no~") COLUMN(NAME=~"saledet.item_no~") COLUMN(NAME=~"saledet.qa~") COLUMN(NAME=~"saledet.uom~") COLUMN(NAME=~"saledet.order_qty~") COLUMN(NAME=~"saledet.acc_qty~") COLUMN(NAME=~"saledet.price~") COLUMN(NAME=~"groupitem.item_name~") COLUMN(NAME=~"saledet.rlse_qty~") COLUMN(NAME=~"sale.ship_flag~") COLUMN(NAME=~"sale.cust_po_no~") COLUMN(NAME=~"sale.cust_po_date~") COLUMN(NAME=~"saledet.rem~")    JOIN (LEFT=~"sale.order_no~"    OP =~"=~"RIGHT=~"saledet.order_no~" )    JOIN (LEFT=~"sale.cust_no~"    OP =~"=~"RIGHT=~"customer.cust_no~" )    JOIN (LEFT=~"saledet.item_no~"    OP =~"=~"RIGHT=~"groupitem.item_no~" )WHERE(    EXP1 =~"sale.order_no~"   OP =~"like~"    EXP2 =~":aa~" ) ) ARG(NAME = ~"aa~" TYPE = string) " arguments=(("aa", string)) )
