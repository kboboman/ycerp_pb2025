detail(height=68 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes key=yes name=item_no dbname="item.item_no" )
 column=(type=char(20) updatewhereclause=yes key=yes name=qa dbname="item.qa" )
 column=(type=char(60) updatewhereclause=yes name=item_item_name dbname="item.item_name" )
 retrieve="  SELECT item.item_no,   
         item.qa,   
         item.item_name  
    FROM item  
   WHERE item.source like :as_source    
" update="item" updatewhere=0 updatekeyinplace=no arguments=(("as_source", string)) )
