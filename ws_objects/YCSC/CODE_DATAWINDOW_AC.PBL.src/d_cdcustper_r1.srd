$PBExportComments$고객정보관리리스트1(2002/02/15,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=96 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=cdate dbname="cdate" )
 column=(type=char(1) updatewhereclause=yes name=flag dbname="flag" values="생일	B/결혼기념일	M/창립기념일	O/" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(20) updatewhereclause=yes name=cust_hname dbname="cust_hname" )
 column=(type=char(1) updatewhereclause=yes name=bir_class dbname="bir_class" values="양	1/음	0/" )
 retrieve="SELECT ccust.cdate,   
		 ccust.flag ,   
		 cust_name = ccust.cust_name,   
		 cust_hname = ccust.cust_hname,   
		 bir_class = ccust.bir_class 
    FROM ( select distinct B.sday from (select sday = DATEPART(DAY,birthday)   FROM custper 
														where datepart(month, birthday)  = :ai_mon
													 union all 
													 select sdate =  marriage_date   FROM custper 
														where datepart(month, marriage_date)  = :ai_mon
													 union all 
													 select sdate =  set_date   FROM custinfo 
														where datepart(month, set_date)  = :ai_mon ) B ) A,

				(SELECT  cust_hname = custbir.cust_hname,   
							bir_class = custbir.bir_class,   
							cust_name = custbir.cust_name,   
							cdate = custbir.birthday,   
							flag = 'B'   
					 FROM custper custbir
					where datepart(month, birthday)  = :ai_mon
				UNION ALL
				  SELECT cust_hname = custmarr.cust_hname,   
							bir_class = custmarr.bir_class,   
							cust_name = custmarr.cust_name,   
							cdate = custmarr.marriage_date,
							flag = 'M'   
					 FROM custper custmarr
					where datepart(month, marriage_date)  = :ai_mon
				UNION ALL
				  SELECT cust_hname = customer.captain_name,   
							'1',   
							cust_name = customer.cust_name,   
							cdate = custinfo.set_date,
							flag = 'O'   
					 FROM custinfo, customer
					where datepart(month, set_date)  = :ai_mon
					  and custinfo.cust_no = customer.cust_no ) ccust
 where A.sday = DATEPART(DAY,ccust.cdate)

" arguments=(("ai_mon", number))  sort="month(cdate) +day(cdate) A flag A cust_name A " )
