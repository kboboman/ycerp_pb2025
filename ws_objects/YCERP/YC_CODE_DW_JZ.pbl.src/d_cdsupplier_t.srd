table(column=(type=char(10) updatewhereclause=yes name=supp_no dbname="supp.supp_no" )
 column=(type=char(12) updatewhereclause=yes name=register_no dbname="supp.register_no" )
 column=(type=char(30) updatewhereclause=yes name=supp_name dbname="supp.supp_name" )
 column=(type=char(10) updatewhereclause=yes name=captain_name dbname="supp.captain_name" )
 column=(type=char(80) updatewhereclause=yes name=addr dbname="supp.addr" )
 column=(type=char(10) updatewhereclause=yes name=contact dbname="supp.contact" )
 column=(type=char(10) updatewhereclause=yes name=position dbname="supp.position" )
 column=(type=char(15) updatewhereclause=yes name=tel_no dbname="supp.tel_no" )
 column=(type=char(30) updatewhereclause=yes name=rem dbname="supp.rem" )
 column=(type=char(10) updatewhereclause=yes name=buyer dbname="supp.buyer" )
 column=(type=char(20) updatewhereclause=yes name=industry_type dbname="supp.industry_type" )
 column=(type=char(20) updatewhereclause=yes name=industry_code dbname="supp.industry_code" )
 column=(type=decimal(4) updatewhereclause=yes name=credit_limit dbname="supp.credit_limit" )
 column=(type=long updatewhereclause=yes name=terms dbname="supp.terms" )
 column=(type=char(20) updatewhereclause=yes name=fob dbname="supp.fob" )
 column=(type=datetime updatewhereclause=yes name=last_tran_date dbname="supp.last_tran_date" )
 column=(type=char(3) updatewhereclause=yes name=currency_type dbname="supp.currency_type" )
 column=(type=char(15) updatewhereclause=yes name=fax_no dbname="supp.fax_no" )
 column=(type=char(1) updatewhereclause=yes name=subcon dbname="supp.subcon" )
 retrieve="  SELECT supp.supp_no,   
         supp.register_no,   
         supp.supp_name,   
         supp.captain_name,   
         supp.addr,   
         supp.contact,   
         supp.position,   
         supp.tel_no,   
         supp.rem,   
         supp.buyer,   
         supp.industry_type,   
         supp.industry_code,   
         supp.credit_limit,   
         supp.terms,   
         supp.fob,   
         supp.last_tran_date,   
         supp.currency_type,   
         supp.fax_no,   
         supp.subcon  
    FROM supp  
   WHERE supp.supp_no = :as_str    
" arguments=(("as_str", string)) )
