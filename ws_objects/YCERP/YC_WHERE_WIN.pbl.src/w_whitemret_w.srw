event pb_print::clicked;w_repsuper w_print

choose case tab_1.SelectedTab
	case 1	// 재고현황
		if dw4.rowcount() < 1 then return
		i_print.st_datawindow = dw_2
		i_print.st_print_sheet = " 프린트용지 : A4"
		i_print.st_print_desc = " 이 프로그램은 품목별 재고내역를 출력합니다." 
		gs_print_control = 'DataWindow.Print.Orientation=2 DataWindow.Print.Paper.Size=9 Datawindow.Zoom=89'
		
	case 2	// 생산계획
		if tab_1.tabpage_2.rb_6.checked = true then
			MessageBox("확인","작업지시에 관한 출력은 작업지시서 프로그램에서 하시기 바랍니다.")
			RETURN
		end if
		
		i_print.st_datawindow = dw5
		i_print.st_print_sheet = " 프린트용지 : A4"
		i_print.st_print_desc = " 이 프로그램은 생산계획내역를 출력합니다." 
		gs_print_control = 'DataWindow.Print.Orientation=1 DataWindow.Print.Paper.Size=9 Datawindow.Zoom=100'
		
	case 3	// 재고이력검색
		i_print.st_datawindow = dw9
		i_print.st_print_sheet = " 프린트용지 : A4"
		i_print.st_print_desc = " 이 재고이력을 출력합니다." 
		gs_print_control = 'DataWindow.Print.Orientation=1 DataWindow.Print.Paper.Size=9 Datawindow.Zoom=100'
		
	case 4	// 수불부
		if tab_1.tabpage_4.rb_3.checked = true then
			if dw7.rowcount() < 1 then return
			i_print.st_datawindow = dw7
			gs_print_control = 'DataWindow.Print.Orientation=1 DataWindow.Print.Paper.Size=9 Datawindow.Zoom=57'
		else
			if dw10.rowcount() < 1 then return
			i_print.st_datawindow = dw10
			gs_print_control = 'DataWindow.Print.Orientation=1 DataWindow.Print.Paper.Size=9 Datawindow.Zoom=62'
		end if
		i_print.st_print_sheet = " 프린트용지 : A4"
		i_print.st_print_desc = " 이 프로그램은 수불부를 출력합니다." 
		
	case 5	// 장기재고
		if dw11.rowcount() < 1 then return
		i_print.st_datawindow = dw_12
		i_print.st_print_sheet = " 프린트용지 : A4"
		i_print.st_print_desc = " 이 프로그램은 장기재고 현황을 출력합니다." 
		gs_print_control = 'DataWindow.Print.Orientation=2 DataWindow.Print.Paper.Size=9 Datawindow.Zoom=93'
		
	case 6	// 발주현황
		if dw13.rowcount() < 1 then return
		i_print.st_datawindow = dw_14
		i_print.st_print_sheet = " 프린트용지 : A4"
		i_print.st_print_desc = " 이 프로그램은 발주 현황을 출력합니다." 
		gs_print_control = 'DataWindow.Print.Orientation=2 DataWindow.Print.Paper.Size=9 Datawindow.Zoom=93'
end choose

//===============사용자별 프로그램 사용현황=================================
gf_usecount(gs_userid,parent.classname(),"P",string(today(),'yyyy/mm/dd'))
//==========================================================================
opensheetwithparm(w_print, i_print,parentwindow(), 1, Original!)

end event

