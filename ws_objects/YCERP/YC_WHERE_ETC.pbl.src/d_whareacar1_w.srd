$PBExportComments$권역운반비관리(2020/03/13,조원석)
release 8;
datawindow(units=0 timer_interval=0 color=134217750 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=a_area_code dbname="car_country.area_code" )
 column=(type=char(40) updatewhereclause=yes name=b_area_name dbname="car_country.area_name" )
 column=(type=char(4) updatewhereclause=yes name=a_country_code dbname="car_country.country_code" )
 column=(type=char(40) updatewhereclause=yes name=c_country_name dbname="car_country.country_name" )
 retrieve="select 
	 distinct a.area_code
	,b.area_name
	,a.country_code
	,c.country_name
from 
	car_country a with(nolock) inner join car_area b with(nolock)	on a.area_code = b.area_code and b.country_code = '0000'
										inner join car_area c with(nolock)	on a.area_code = c.area_code and a.country_code = c.country_code and c.country_code <> '0000'
										inner join codemst d with(nolock) 	on a.car_kind = d.item_cd and d.type = 'car_gbn' and d.use_yn = 'Y'
where 
	a.area_code like :as_area_code
and
	c.country_name like :as_name
order by 
	 a.area_code
	,a.country_code" arguments=(("as_area_code", string),("as_name", string)) )
text(band=header alignment="2" text="권역" border="6" color="0" x="9" y="4" height="68" width="672" html.valueishtml="0"  name=b_area_name_t visible="1"  font.face="굴림체" font.height="-11" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="12639424" )
text(band=header alignment="2" text="지역" border="6" color="0" x="690" y="4" height="68" width="1189" html.valueishtml="0"  name=c_country_name_t visible="1"  font.face="굴림체" font.height="-11" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="12639424" )
column(band=detail id=2 alignment="2" tabsequence=32766 border="0" color="0" x="9" y="4" height="64" width="672" format="[general]" html.valueishtml="0"  name=b_area_name visible="1" edit.limit=0 edit.case=any edit.focusrectangle=no edit.autoselect=no edit.imemode=0  font.face="굴림체" font.height="-11" font.weight="400"  font.family="2" font.pitch="2" font.charset="129" background.mode="1" background.color="553648127" )
column(band=detail id=4 alignment="2" tabsequence=32766 border="0" color="0" x="690" y="4" height="64" width="1189" format="[general]" html.valueishtml="0"  name=c_country_name visible="1" edit.limit=0 edit.case=any edit.focusrectangle=no edit.autoselect=no edit.imemode=0  font.face="굴림체" font.height="-11" font.weight="400"  font.family="2" font.pitch="2" font.charset="129" background.mode="1" background.color="553648127" )

sparse(names="b_area_name	c_country_name")htmltable(border="1" )
