release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=68 color="8421504" )
detail(height=68 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=user_id dbname="user_id" )
 column=(type=char(50) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(30) updatewhereclause=yes name=loc_name dbname="loc_name" )
 column=(type=char(20) updatewhereclause=yes name=area_area_name dbname="area_name" )
 retrieve="  SELECT DISTINCT user_id = login.user_id
       , user_name = login.user_name
       , loc_name  = location.loc_name
       , area_name = area.area_name  
    FROM location
       , login
       , area  
   WHERE ( location.area_no     = area.area_no  )
     AND ( location.loc_manager = login.user_id )    
	UNION ALL 
/* 2017.11.13 조원석
출고의뢰서에서 외주 의뢰자 때문에 추가된 쿼리 */    
	SELECT ITEM_CD USER_ID, 
					  ITEM_NM USER_NAME,
					'시화저장소' LOC_NAME,
					'시화사업장' AREA_NAME              
	  FROM  CODEMST
	WHERE TYPE LIKE '출고의뢰서_보조자(시화)'
		 AND  USE_YN = 'Y'
		 AND  ITEM_CD <> 'bestvic' /*2018.04.30 jowonsuk 추가 최성욱차장 ysp로만 */
"  sort="area_area_name A loc_name A user_name A " )
