forward prototypes
public subroutine wf_filter (string as_word, string as_first, string as_second)
public subroutine wf_filitem (string as_item)
public subroutine wf_filter1 (string as_flag)
public subroutine wf_ret (string as_flag)
public function boolean wf_item_no_check (string arg_item_no)
public function integer wf_fav_insert ()
end prototypes

public subroutine wf_filter (string as_word, string as_first, string as_second);//
string ls_result
string ls_item, ls_locno

dw2.setredraw(false)

ls_result = "mid(item_name,1,2) = '" + as_word + "'or (mid(item_name,1,2) >= '" + as_first + "' and mid(item_name,1,2) < '" + as_second + "')"

dw2.SelectRow(0,  false)
dw2.setfilter(ls_result)
dw2.filter()
dw2.setredraw(true)
dw2.sort()

if dw2.getrow() < 1 then return

ls_item = dw2.object.item_no[dw2.getrow()]
dw3.setredraw(false)
dw3.reset()

//if is_loc = 'WS00000011' THEN
//	ls_locno =  'WS00000011'
//ELSE
//	ls_locno =  '%'
//END IF

dw3.retrieve(is_loc, ls_item )
//dw3.retrieve(ls_locno, ls_item )

dw3.setredraw(true)
tab_1.tabpage_1.rb_code.checked = true
dw4.object.cust_no[1] = ''

end subroutine

public subroutine wf_filitem (string as_item);//
tab_1.tabpage_1.rb_code.checked = true
tab_1.tabpage_1.rb_code.triggerevent(clicked!)
dw4.object.cust_no[1] = as_item
tab_1.tabpage_1.cb_4.postevent(clicked!)


end subroutine

public subroutine wf_filter1 (string as_flag);
dw4.object.cust_no[1] = ''
if as_flag = '' then
	dw2.setfilter("")
else
	dw2.setfilter(" source = '" + as_flag + "' ")
end if
dw2.Filter( )

if dw2.rowcount() > 1 then
		dw2.ScrollToRow(1)
end if

end subroutine

public subroutine wf_ret (string as_flag);//
date   ld_start, ld_end
string ls_item,  ls_qa, ls_cust_yn

if il_dw3row < 1 then return

ld_start = date(tab_2.tabpage_8.em_6.text)
ld_end   = date(tab_2.tabpage_8.em_7.text)
ls_item  = trim(dw2.object.item_no[dw2.getrow()])
ls_qa    = trim(dw3.object.qa[il_dw3row])
tab_2.tabpage_8.st_item.text = trim(dw2.object.item_name[dw2.getrow()])
tab_2.tabpage_8.st_qa.text   = lower(ls_qa)

if as_flag = "sale" then
	
	tab_2.tabpage_8.dw_7.retrieve( '%', ld_start, ld_end, ls_item, ls_qa )
	
	if tab_2.tabpage_8.cbx_5.checked = true then
		tab_2.tabpage_8.dw_7.setfilter("corder <> 0 and cust_no <> "+ "'N012'" )		
	ELSE
		tab_2.tabpage_8.dw_7.setfilter("corder <> 0" )				
	end if	
		
	tab_2.tabpage_8.dw_7.filter() 
end if

end subroutine

public function boolean wf_item_no_check (string arg_item_no);
//YSP 수주통제 ITEM 목록(w_orsale_m 내용에도 병행 수정)

String	ls_Item_no[], ls_val = 'NO'
long		ll_cnt

ls_Item_No[1]  = 'PCYSSPPZZL' ; ls_Item_No[2]  = 'PCYSSPPZZH' ; ls_Item_No[3]  = 'PCYSSPPZZI' ; ls_Item_No[4]  = 'PCYSSPPZZZ'
ls_Item_No[5]  = 'PCYSBP5ZZZ' ; ls_Item_No[6]  = 'PCYSBPCZZZ' ; ls_Item_No[7]  = 'PCYSSPPZZ4' ; ls_Item_No[8]  = 'PCYSSC3ZZZ'
ls_Item_No[9]  = 'PCYSSC4ZZZ' ; ls_Item_No[10] = 'PCYSSC5ZZZ' ; ls_Item_No[11] = 'PCYSSPEZZL' ; ls_Item_No[12] = 'PCYSSPEZZH'
ls_Item_No[13] = 'PCYSSPEZZI' ; ls_Item_No[14] = 'PCYSSPEZZZ' ; ls_Item_No[15] = 'PCYSSPEZZJ' ; ls_Item_No[16] = 'PCYSSPEZZ4'
ls_Item_No[17] = 'PCYSSPVZZZ' ; ls_Item_No[18] = 'PCYSSC1ZZZ' ; ls_Item_No[19] = 'PCYSSC2ZZZ' ; ls_Item_No[20] = 'PCYSSPAZZZ'
ls_Item_No[21] = 'PCYSSPUZZL' ; ls_Item_No[22] = 'PCYSSPUZZH' ; ls_Item_No[23] = 'PCYSSPUZZI' ; ls_Item_No[24] = 'PCYSSPUZZZ'
ls_Item_No[25] = 'PCYSSPUZZ4'

for ll_cnt = 1 to 25
	if ls_Item_No[ll_cnt] = arg_Item_No then
		ls_val = 'OK'
		exit
	end if
next

if ls_val = 'OK' then
	return true
else
	return false
end if


end function

public function integer wf_fav_insert ();long    ll_row, ll_cnt, ll_dw1rowcount, ll_dw2row, ll_dw3row
long    l_count = 0, ll_dw13row = 1
string  ls_exist, ls_use, ls_item, ls_qa


ll_row = 1

ll_dw2row = dw2.getrow()


dw13.accepttext()

if dw13.rowcount() = 0 then
	l_count = 0
else		
	
		for ll_dw13row = 1 to dw13.rowcount()
		
				if dw13.object.itemfav_item_no[ll_dw13row] = i_item_no and dw13.object.itemfav_qa[ll_dw13row] = i_qa	and dw13.object.itemfav_user_id[ll_dw13row] = gs_userid then
					l_count = l_count + 1
				else
					l_count = l_count
				end if
		
		next
	
end if 
		

if l_count = 0 then

	ll_cnt  = dw13.insertrow(0)
	
	dw13.object.itemfav_user_id[ll_cnt]   = gs_userid
	dw13.object.itemfav_item_no[ll_cnt]   = i_item_no
	dw13.object.item_no[ll_cnt]			  = i_item_no	
	dw13.object.itemfav_qa[ll_cnt]        = i_qa
	dw13.object.qa[ll_cnt] 			        = i_qa	
	dw13.object.uom[ll_cnt]       		  = dw2.object.uom[ll_dw2row]
	dw13.object.item_name[ll_cnt] 		  = dw2.object.item_name[ll_dw2row]

end if

		
dw3.SelectRow(0, false)		// 선택해제

return 1
end function

on w_whitemlocqohmulti_w2.create
this.st_13=create st_13
this.st_3=create st_3
this.tab_2=create tab_2
this.cb_30=create cb_30
this.tab_1=create tab_1
this.cb_9=create cb_9
this.cbx_2=create cbx_2
this.cb_8=create cb_8
this.cb_6=create cb_6
this.cb_2=create cb_2
this.cb_1=create cb_1
this.dw_1=create dw_1
this.gb_4=create gb_4
this.dw_loc=create dw_loc
this.ln_1=create ln_1
this.Control[]={this.st_13,&
this.st_3,&
this.tab_2,&
this.cb_30,&
this.tab_1,&
this.cb_9,&
this.cbx_2,&
this.cb_8,&
this.cb_6,&
this.cb_2,&
this.cb_1,&
this.dw_1,&
this.gb_4,&
this.dw_loc,&
this.ln_1}
end on

on w_whitemlocqohmulti_w2.destroy
destroy(this.st_13)
destroy(this.st_3)
destroy(this.tab_2)
destroy(this.cb_30)
destroy(this.tab_1)
destroy(this.cb_9)
destroy(this.cbx_2)
destroy(this.cb_8)
destroy(this.cb_6)
destroy(this.cb_2)
destroy(this.cb_1)
destroy(this.dw_1)
destroy(this.gb_4)
destroy(this.dw_loc)
destroy(this.ln_1)
end on

event open;//
DataWindowChild ldwc_stand

long   ll_row, ll_found
string ls_newitem, ls_locno

dw2 = tab_1.tabpage_1.dw_2
dw3 = tab_1.tabpage_1.dw_3
dw4 = tab_1.tabpage_1.dw_4
dw5 = tab_1.tabpage_2.dw_5
dw6 = tab_1.tabpage_2.dw_6
dw8 = tab_1.tabpage_3.dw_8
dw9 = tab_1.tabpage_4.dw_9
dw10= tab_1.tabpage_4.dw_10
dw11= tab_1.tabpage_5.dw_11
dw12= tab_1.tabpage_6.dw_12
dw13= tab_2.tabpage_7.dw_13 /*2017.11.14 조원석 */
dw7 = tab_2.tabpage_8.dw_7  /*2017.11.14 조원석 */


dw2.settransobject(sqlca)											/*2018/03/13 조원석 추가 */
dw3.settransobject(sqlca)
dw5.SetTransObject(SQLCA)
dw6.SetTransObject(SQLCA)
dw8.SetTransObject(SQLCA)
dw9.SetTransObject(SQLCA)
dw10.SetTransObject(SQLCA)
dw11.SetTransObject(SQLCA)
dw12.SetTransObject(SQLCA)
dw13.SetTransObject(SQLCA) /*2017.11.14 조원석 */
dw7.SetTransObject(SQLCA) /*2017.11.14 조원석 */

dw10.visible = false

// 저장소
dw_loc.SetTransObject(sqlca)
dw_loc.insertrow(1)

// 사용자
dw6.insertrow(1)
dw6.visible = false
dw6.object.user_id[1] = gs_userid
istr_where = Message.PowerObjectParm

//date ld_date, ld_date_from
//ld_date      = date(gdt_today)
//ld_date_from = RelativeDate(ld_date, -61)
//em_6.text    = string(ld_date_from, 'yyyy/mm/dd')
//em_7.text    = string(ld_date, 'yyyy/mm/dd')

string ls_date, ls_date_from
SELECT top 1 convert(varchar(10), getdate(), 121),  convert(varchar(10), dateadd(month, -1, getdate()), 121)
  INTO :ls_date, :ls_date_from
  FROM login;
  
tab_2.tabpage_8.em_6.text  = ls_date_from
tab_2.tabpage_8.em_7.text  = ls_date
tab_1.tabpage_5.em_9.text  = LeftA(gs_area,1) + gf_replaceall(ls_date,"-","")
tab_1.tabpage_6.em_10.text = "KD" + gf_replaceall(ls_date,"-","")

/////////////////////////////////////
if GS_DS_ItemAll.RowCount() < 1 then
	MessageBox("확인","다중추가 작업불가[도구 -> 품목/거래처 RELOAD!] 후 재 실행하시기 바랍니다.")
	return
end if
/////////////////////////////////////
//GS_DS_ItemAll.ShareData(dw2)                 								 /*2018/03/13 조원석 주석처리 */
/////////////////////////////////////

tab_2.tabpage_8.st_help1.visible = true
tab_2.tabpage_8.st_item.visible  = false
tab_2.tabpage_8.st_qa.visible    = false

if istr_where.chk = 'S' then
	dw_1.enabled  = false
	cbx_2.enabled = false
	cb_6.enabled  = false
	cb_8.enabled  = false
	cb_9.enabled  = false
end if

//ls_locno = istr_where.chk1
is_loc = istr_where.chk1

if isnull(is_loc) or trim(is_loc) = "" then
	SELECT def_loc INTO :ls_locno FROM area WHERE area_no = :gs_area;
	dw_loc.object.loc_no[1] = ls_locno
else
	dw_loc.object.loc_no[1] = is_loc
end if

//if left(GS_IPAddress,9) = "192.168.1" then ls_locno = "WS00000000"

//ls_locno = "WS00000000"

//is_loc = ls_locno


dw_loc.accepttext()

///////////////////////////////////////////
// 사용불가 제외
///////////////////////////////////////////
tab_1.tabpage_4.dw_orstand.settransobject(sqlca)
tab_1.tabpage_4.dw_orstand.insertrow(1)
tab_1.tabpage_4.dw_orstand.object.item_no[1] = ""

tab_1.tabpage_4.cbx_useyn.checked = true
tab_1.tabpage_4.cbx_useyn.triggerevent( clicked! )

//dw9.object.item_no.TabSequence = 0

dw2.retrieve()												/*2018/03/13 조원석 추가 */

dw4.insertrow(1)
if UpperBound(istr_where.str1) > 0 then
	if not isnull(istr_where.str1[1]) and trim(istr_where.str1[1]) <> '' then
		dw2.setsort('item_no A')
		dw2.sort()
		
		tab_1.tabpage_1.rb_code.checked = true
		tab_1.tabpage_1.rb_name.checked = false
		dw4.object.cust_no[1] = istr_where.str1[1]
		tab_1.tabpage_1.cb_4.triggerevent( clicked! )	// 조회
		
		dw2.SelectRow(1, true)
		if isnull(istr_where.str2[1]) or trim(istr_where.str2[1]) = '' then
		else
			ll_found = dw3.Find("qa = '" + istr_where.str2[1] + "'", 1, dw3.RowCount())
			if ll_found > 0 then
				dw3.scrolltorow(ll_found)
				dw3.SelectRow(ll_found, true)
			end if
		end if
	else
		dw2.setsort('item_name A')
		dw2.sort()
		dw2.SelectRow(1,  true)
	end if
else
	dw2.setsort('item_name A')
	dw2.sort()
	dw2.SelectRow(1, true)
end if

//////////////////////////////////////////////////////////
// 현재고(장기)가 0 이 아닌 규격만 조회
//////////////////////////////////////////////////////////
//tab_1.tabpage_1.cbx_4.checked = true
tab_1.tabpage_1.cbx_4.triggerevent(clicked!)	
//////////////////////////////////////////////////////////
//
//tab_1.tabpage_1.dw_4.setcolumn( "cust_no" )
//tab_1.tabpage_1.dw_4.setfocus()

/*2017.11.14 조원석 */
dw13.retrieve(gs_userid)

end event

event closequery;dw2.setfilter("")
dw2.Filter( )

end event

