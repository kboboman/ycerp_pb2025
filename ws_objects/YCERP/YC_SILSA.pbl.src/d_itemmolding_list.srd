$PBExportHeader$d_itemmolding_list.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no  crosstab.dynamic = yes grid.lines=0 grid.columnmove=no selected.mouse=no )
header[1](height=0 color="536870912" )
header[2](height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=84 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=checktime dbname="checktime" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(20) updatewhereclause=yes name=bigo dbname="bigo" )
 column=(type=char(20) updatewhereclause=yes name=color dbname="color" )
 column=(type=number updatewhereclause=yes name=qty dbname="qty" )
 retrieve="  SELECT CHECKTIME  = A.CHECKTIME   
       , GROUPITEM  = B.ITEM_NM
       , QA         = A.QA   
       , COLOR      = C.ITEM_NM
       , QTY        = A.QTY  
       , BIGO       = A.BIGO  
    FROM ITEMMOLDING A
         LEFT OUTER JOIN CODEMST B  ON A.GROUPITEM  = B.ITEM_CD  AND B.TYPE = 'ITEMMOLDING'
         LEFT OUTER JOIN CODEMST C  ON A.COLOR      = C.ITEM_CD  AND C.TYPE = 'ITEMMOLDINGCOLOR'
   WHERE CONVERT(CHAR(25), A.CHECKTIME, 121) >= :as_datetime
" arguments=(("as_datetime", string))  sort="checktime D qa A bigo A color A " )
group(level=1 header.height=0 trailer.height=0 by=("checktime" ) header.color="536870912" trailer.color="536870912" )
group(level=2 header.height=0 trailer.height=0 by=("qa" ) header.color="536870912" trailer.color="536870912" )
group(level=3 header.height=0 trailer.height=0 by=("bigo" ) header.color="536870912" trailer.color="536870912" )
