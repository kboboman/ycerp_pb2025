$PBExportComments$조업자재 집계표(원본)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=0 HTMLDW=no print.documentname="" print.orientation = 1 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=88 color="536870912" )
summary(height=0 color="536870912" )
footer(height=260 color="8421504" )
detail(height=284 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=part_name dbname="part_name" )
 column=(type=char(20) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_1 dbname="in_month_1" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_2 dbname="in_month_2" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_3 dbname="in_month_3" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_4 dbname="in_month_4" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_5 dbname="in_month_5" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_6 dbname="in_month_6" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_7 dbname="in_month_7" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_8 dbname="in_month_8" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_9 dbname="in_month_9" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_10 dbname="in_month_10" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_11 dbname="in_month_11" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_12 dbname="in_month_12" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_21 dbname="in_month_21" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_22 dbname="in_month_22" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_23 dbname="in_month_23" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_24 dbname="in_month_24" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_25 dbname="in_month_25" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_26 dbname="in_month_26" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_27 dbname="in_month_27" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_28 dbname="in_month_28" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_29 dbname="in_month_29" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_30 dbname="in_month_30" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_31 dbname="in_month_31" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_32 dbname="in_month_32" )
 column=(type=long updatewhereclause=yes name=ship_qty dbname="ship_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=c_qty dbname="c_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=c_amt dbname="c_amt" )
 column=(type=long updatewhereclause=yes name=cnt dbname="cnt" )
 column=(type=long updatewhereclause=yes name=ship_qty_2 dbname="ship_qty_2" )
 column=(type=decimal(2) updatewhereclause=yes name=c_qty_2 dbname="c_qty_2" )
 column=(type=decimal(4) updatewhereclause=yes name=c_amt_2 dbname="c_amt_2" )
 column=(type=long updatewhereclause=yes name=cnt_2 dbname="cnt_2" )
 column=(type=char(10) updatewhereclause=yes name=cstart dbname="cstart" )
 column=(type=char(10) updatewhereclause=yes name=cend dbname="cend" )
 column=(type=long updatewhereclause=yes name=sort dbname="sort" )
 column=(type=long updatewhereclause=yes name=sort2 dbname="sort2" )
 retrieve="  SELECT part_name   = tmp_main.part_name
       , item_name   = tmp_main.item_name
       , in_month_1  = max(in_month_1)
       , in_month_2  = max(in_month_2)
       , in_month_3  = max(in_month_3)
       , in_month_4  = max(in_month_4)
       , in_month_5  = max(in_month_5)
       , in_month_6  = max(in_month_6)
       , in_month_7  = max(in_month_7)
       , in_month_8  = max(in_month_8)
       , in_month_9  = max(in_month_9)
       , in_month_10 = max(in_month_10)
       , in_month_11 = max(in_month_11)
       , in_month_12 = max(in_month_12)

       , in_month_21 = max(in_month_21)
       , in_month_22 = max(in_month_22)
       , in_month_23 = max(in_month_23)
       , in_month_24 = max(in_month_24)
       , in_month_25 = max(in_month_25)
       , in_month_26 = max(in_month_26)
       , in_month_27 = max(in_month_27)
       , in_month_28 = max(in_month_28)
       , in_month_29 = max(in_month_29)
       , in_month_30 = max(in_month_30)
       , in_month_31 = max(in_month_31)
       , in_month_32 = max(in_month_32)

       , ship_qty    = sum(ship_qty)
       , c_qty       = sum(c_qty)
       , c_amt       = sum(c_amt)
       , cnt         = sum(cnt)

       , ship_qty_2  = sum(ship_qty_2)
       , c_qty_2     = sum(c_qty_2)
       , c_amt_2     = sum(c_amt_2)
       , cnt_2       = sum(cnt_2)

       , cstart      = (case when :as_start = ''  then '          ' else :as_start   end)
       , cend        = (case when :as_end   = ''  then '          ' else :as_end     end)
       , sort        = max(sort)
       , sort2       = max(sort2)
    FROM (
         SELECT part_name
              , item_name   = tmp_01.catgroup
              , in_month_1  = (case when in_month = 1  then sum(c_amt) else 0 end)
              , in_month_2  = (case when in_month = 2  then sum(c_amt) else 0 end)
              , in_month_3  = (case when in_month = 3  then sum(c_amt) else 0 end)
              , in_month_4  = (case when in_month = 4  then sum(c_amt) else 0 end)
              , in_month_5  = (case when in_month = 5  then sum(c_amt) else 0 end)
              , in_month_6  = (case when in_month = 6  then sum(c_amt) else 0 end)
              , in_month_7  = (case when in_month = 7  then sum(c_amt) else 0 end)
              , in_month_8  = (case when in_month = 8  then sum(c_amt) else 0 end)
              , in_month_9  = (case when in_month = 9  then sum(c_amt) else 0 end)
              , in_month_10 = (case when in_month = 10 then sum(c_amt) else 0 end)
              , in_month_11 = (case when in_month = 11 then sum(c_amt) else 0 end)
              , in_month_12 = (case when in_month = 12 then sum(c_amt) else 0 end)
         
              , in_month_21 = (case when in_month = 21 then sum(c_amt) else 0 end)
              , in_month_22 = (case when in_month = 22 then sum(c_amt) else 0 end)
              , in_month_23 = (case when in_month = 23 then sum(c_amt) else 0 end)
              , in_month_24 = (case when in_month = 24 then sum(c_amt) else 0 end)
              , in_month_25 = (case when in_month = 25 then sum(c_amt) else 0 end)
              , in_month_26 = (case when in_month = 26 then sum(c_amt) else 0 end)
              , in_month_27 = (case when in_month = 27 then sum(c_amt) else 0 end)
              , in_month_28 = (case when in_month = 28 then sum(c_amt) else 0 end)
              , in_month_29 = (case when in_month = 29 then sum(c_amt) else 0 end)
              , in_month_30 = (case when in_month = 30 then sum(c_amt) else 0 end)
              , in_month_31 = (case when in_month = 31 then sum(c_amt) else 0 end)
              , in_month_32 = (case when in_month = 32 then sum(c_amt) else 0 end)
         
              , ship_qty    = (case when in_year = convert(int, left(:as_bstart,4)) then sum(ship_qty) else 0 end)
              , c_qty       = (case when in_year = convert(int, left(:as_bstart,4)) then sum(c_qty)    else 0 end)
              , c_amt       = (case when in_year = convert(int, left(:as_bstart,4)) then sum(c_amt)    else 0 end)
              , cnt         = (case when in_year = convert(int, left(:as_bstart,4)) then sum(cnt)      else 0 end)
         
              , ship_qty_2  = (case when in_year = convert(int, left(:as_start,4))  then sum(ship_qty) else 0 end)
              , c_qty_2     = (case when in_year = convert(int, left(:as_start,4))  then sum(c_qty)    else 0 end)
              , c_amt_2     = (case when in_year = convert(int, left(:as_start,4))  then sum(c_amt)    else 0 end)
              , cnt_2       = (case when in_year = convert(int, left(:as_start,4))  then sum(cnt)      else 0 end)
         
              , sort        = max(tmp_01.sort)
              , sort2       = e.sort
         FROM ( /*전년도*/
              SELECT d.part_name
                   , a.item_no
                   , in_year   = year(a.in_date)
                   , in_month  = (case when month(a.in_date) = 1  then 1
                                       when month(a.in_date) = 2  then 2
                                       when month(a.in_date) = 3  then 3
                                       when month(a.in_date) = 4  then 4
                                       when month(a.in_date) = 5  then 5
                                       when month(a.in_date) = 6  then 6
                                       when month(a.in_date) = 7  then 7
                                       when month(a.in_date) = 8  then 8
                                       when month(a.in_date) = 9  then 9
                                       when month(a.in_date) = 10 then 10
                                       when month(a.in_date) = 11 then 11
                                       when month(a.in_date) = 12 then 12
                                  end)
                   , ship_qty  = isNULL(count(a.qa),0)
                   , c_qty     = sum(isNULL(a.qty,0))
                   , c_amt     = sum(isNULL(a.amount,0))
                   , cnt       = isNULL(count(a.qa),0)
                   , sort      = max(isnull(d.sort,999))
                   , b.catgroup
                FROM binitem A
                     LEFT OUTER JOIN bitem B ON a.item_no   = b.item_no 
                     LEFT OUTER JOIN bsupp C ON a.supp_no   = c.supp_no
                     LEFT OUTER JOIN bpart D ON a.part_code = d.part_no
               WHERE ( convert(char(10),a.in_date,111)  BETWEEN :as_bstart AND :as_bend )
                 AND ( a.supp_no           LIKE :as_supp      )
                 AND ( a.part_code         LIKE :as_part_code )
                 AND ( :as_etc    = '%' and b.catgroup  like :as_etc  OR
                       :as_etc   <> '%' and b.catgroup    <> '기타'        
                     )
               GROUP BY d.part_name
                      , a.in_date
                      , a.supp_no
                      , a.item_no      
                      , a.uom  
                      , b.catgroup
                     
               UNION ALL
               
               /*당해년도*/
               SELECT d.part_name
                    , a.item_no
                    , in_year   = year(a.in_date)
                    , in_month  = case when month(a.in_date) = 1  then 21
                                       when month(a.in_date) = 2  then 22
                                       when month(a.in_date) = 3  then 23
                                       when month(a.in_date) = 4  then 24
                                       when month(a.in_date) = 5  then 25
                                       when month(a.in_date) = 6  then 26
                                       when month(a.in_date) = 7  then 27
                                       when month(a.in_date) = 8  then 28
                                       when month(a.in_date) = 9  then 29
                                       when month(a.in_date) = 10 then 30
                                       when month(a.in_date) = 11 then 31
                                       when month(a.in_date) = 12 then 32
                                  end
                    , ship_qty  = isNULL(count(a.qa),0)
                    , c_qty     = sum(isNULL(a.qty,0))
                    , c_amt     = sum(isNULL(a.amount,0))
                    , cnt       = isNULL(count(a.qa),0)
                    , sort      = max(isnull(d.sort,999))
                    , b.catgroup
                 FROM binitem A
                      LEFT OUTER JOIN bitem B ON a.item_no = b.item_no 
                      LEFT OUTER JOIN bsupp C ON a.supp_no = c.supp_no
                      LEFT OUTER JOIN bpart D ON a.part_code = d.part_no
                WHERE ( convert(char(10),a.in_date,111)  BETWEEN :as_start AND :as_end )
                  AND ( a.supp_no           LIKE :as_supp      )
                  AND ( a.part_code         LIKE :as_part_code )
                  AND ( :as_etc    = '%' and b.catgroup  like :as_etc  OR
                        :as_etc   <> '%' and b.catgroup    <> '기타'        
                      )
                GROUP BY d.part_name
                       , a.in_date
                       , a.supp_no  
                       , a.item_no      
                       , a.uom  
                       , b.catgroup
              ) tmp_01
                
              LEFT OUTER JOIN (
                   SELECT item_cd, sort FROM codemst WHERE type = '조업자재_대중분류' AND use_yn = 'Y'
              ) E  ON tmp_01.catgroup = e.item_cd
          GROUP BY part_name
                 , tmp_01.catgroup
                 , in_year
                 , in_month
                 , e.sort
         ) tmp_main
     GROUP BY part_name
            , item_name
     ORDER BY sort, sort2


/*
SELECT part_name = TMP_MAIN.part_name
		 , item_name = TMP_MAIN.item_name
		 , in_month_1 = IsNull(max(in_month_1),0)
		 , in_month_2 = IsNull(max(in_month_2),0)
		 , in_month_3 = IsNull(max(in_month_3),0)
		 , in_month_4 = IsNull(max(in_month_4),0)
		 , in_month_5 = IsNull(max(in_month_5),0)
		 , in_month_6 = IsNull(max(in_month_6),0)
		 , in_month_7 = IsNull(max(in_month_7),0)
		 , in_month_8 = IsNull(max(in_month_8),0)
		 , in_month_9 = IsNull(max(in_month_9),0)
		 , in_month_10 = IsNull(max(in_month_10),0)
		 , in_month_11 = IsNull(max(in_month_11),0)
		 , in_month_12 = IsNull(max(in_month_12),0)

		 , in_month_21 = IsNull(max(in_month_21),0)
		 , in_month_22 = IsNull(max(in_month_22),0)
		 , in_month_23 = IsNull(max(in_month_23),0)
		 , in_month_24 = IsNull(max(in_month_24),0)
		 , in_month_25 = IsNull(max(in_month_25),0)
		 , in_month_26 = IsNull(max(in_month_26),0)
		 , in_month_27 = IsNull(max(in_month_27),0)
		 , in_month_28 = IsNull(max(in_month_28),0)
		 , in_month_29 = IsNull(max(in_month_29),0)
		 , in_month_30 = IsNull(max(in_month_30),0)
		 , in_month_31 = IsNull(max(in_month_31),0)
		 , in_month_32 = IsNull(max(in_month_32),0)

		 , ship_qty = IsNull(sum(ship_qty),0)
		 , c_qty = IsNull(sum(c_qty),0)
		 , c_amt = IsNull(sum(c_amt),0)
		 , cnt = IsNull(sum(cnt),0)

		 , ship_qty_2 = IsNull(sum(ship_qty_2),0)
		 , c_qty_2 = IsNull(sum(c_qty_2),0)
		 , c_amt_2 = IsNull(sum(c_amt_2),0)
		 , cnt_2 = IsNull(sum(cnt_2),0)

		 , cstart    = (case when :as_start = ''  then '          ' else :as_start   end)
		 , cend      = (case when :as_end   = ''  then '          ' else :as_end     end)
		 , sort = max(sort)
		 , sort2 = max(sort2)
FROM (
	SELECT part_name
			 , item_name = TMP_01.catgroup
			 , in_month_1 = case when in_month = 1 then sum(c_amt) end
			 , in_month_2 = case when in_month = 2 then sum(c_amt) end
			 , in_month_3 = case when in_month = 3 then sum(c_amt) end
			 , in_month_4 = case when in_month = 4 then sum(c_amt) end
			 , in_month_5 = case when in_month = 5 then sum(c_amt) end
			 , in_month_6 = case when in_month = 6 then sum(c_amt) end
			 , in_month_7 = case when in_month = 7 then sum(c_amt) end
			 , in_month_8 = case when in_month = 8 then sum(c_amt) end
			 , in_month_9 = case when in_month = 9 then sum(c_amt) end
			 , in_month_10 = case when in_month = 10 then sum(c_amt) end
			 , in_month_11 = case when in_month = 11 then sum(c_amt) end
			 , in_month_12 = case when in_month = 12 then sum(c_amt) end

			 , in_month_21 = case when in_month = 21 then sum(c_amt) end
			 , in_month_22 = case when in_month = 22 then sum(c_amt) end
			 , in_month_23 = case when in_month = 23 then sum(c_amt) end
			 , in_month_24 = case when in_month = 24 then sum(c_amt) end
			 , in_month_25 = case when in_month = 25 then sum(c_amt) end
			 , in_month_26 = case when in_month = 26 then sum(c_amt) end
			 , in_month_27 = case when in_month = 27 then sum(c_amt) end
			 , in_month_28 = case when in_month = 28 then sum(c_amt) end
			 , in_month_29 = case when in_month = 29 then sum(c_amt) end
			 , in_month_30 = case when in_month = 30 then sum(c_amt) end
			 , in_month_31 = case when in_month = 31 then sum(c_amt) end
			 , in_month_32 = case when in_month = 32 then sum(c_amt) end

			 , ship_qty = case when in_year = CONVERT(int, left(:as_bstart,4)) then sum(ship_qty) end
			 , c_qty    = case when in_year = CONVERT(int, left(:as_bstart,4)) then sum(c_qty) end
			 , c_amt    = case when in_year = CONVERT(int, left(:as_bstart,4)) then sum(c_amt) end
			 , cnt      = case when in_year = CONVERT(int, left(:as_bstart,4)) then sum(cnt) end

			 , ship_qty_2 = case when in_year = CONVERT(int, left(:as_start,4)) then sum(ship_qty) end
			 , c_qty_2    = case when in_year = CONVERT(int, left(:as_start,4)) then sum(c_qty) end
			 , c_amt_2    = case when in_year = CONVERT(int, left(:as_start,4)) then sum(c_amt) end
			 , cnt_2      = case when in_year = CONVERT(int, left(:as_start,4)) then sum(cnt) end

			 , sort = max(TMP_01.sort)
			 , sort2 = b.sort
	FROM (
		/*전년도*/
		SELECT d.part_name
			 , a.item_no
			 , in_year = year(a.in_date)
			 , in_month  = case when month(a.in_date) = 1 then 1
									  when month(a.in_date) = 2 then 2
									  when month(a.in_date) = 3 then 3
									  when month(a.in_date) = 4 then 4
									  when month(a.in_date) = 5 then 5
									  when month(a.in_date) = 6 then 6
									  when month(a.in_date) = 7 then 7
									  when month(a.in_date) = 8 then 8
									  when month(a.in_date) = 9 then 9
									  when month(a.in_date) = 10 then 10
									  when month(a.in_date) = 11 then 11
									  when month(a.in_date) = 12 then 12
								end
			 , ship_qty  = isNULL(count(a.qa),0)
			 , c_qty     = sum(isNULL(a.qty,0))
			 , c_amt     = sum(isNULL(a.amount,0))
			 , cnt       = isNULL(count(a.qa),0)
			 , sort     = case when d.part_name = '성형'             then 1
											  when d.part_name = '스리타'    then 2
											  when d.part_name = 'YSP'       then 3
											  when d.part_name = '절곡'      then 4
											  when d.part_name = '유압'      then 5
											  when d.part_name = '도장'      then 6
											  when d.part_name = '공무'      then 7
											  when d.part_name = '금형'      then 8
											  when d.part_name = '출고'      then 9
											  when d.part_name = '사무실'    then 10
											  when d.part_name = '공용'      then 11
											  when d.part_name = '모듈러'    then 12
											  when d.part_name = '화성공장'  then 13
											  when d.part_name = '프레스'    then 14
								  end
			 , b.catgroup
		 FROM binitem A
				LEFT OUTER JOIN bitem B ON a.item_no = b.item_no 
				LEFT OUTER JOIN bsupp C ON a.supp_no = c.supp_no
				LEFT OUTER JOIN bpart D ON a.part_code = d.part_no
		WHERE 
					( convert(char(10),a.in_date,111)  BETWEEN :as_bstart AND :as_bend )
					  AND ( a.supp_no           LIKE :as_supp      )
					  AND ( a.part_code         LIKE :as_part_code )
					  AND ( b.catgroup <> '기타' )
		
		  
		GROUP BY d.part_name
				 , a.in_date
				 , a.supp_no
				 , a.item_no      
				 , a.uom  
				 , b.catgroup
				
		  UNION ALL

		/*당해년도*/
		SELECT d.part_name
			 , a.item_no
			 , in_year = year(a.in_date)
			 , in_month  = case when month(a.in_date) = 1 then 21
									  when month(a.in_date) = 2 then 22
									  when month(a.in_date) = 3 then 23
									  when month(a.in_date) = 4 then 24
									  when month(a.in_date) = 5 then 25
									  when month(a.in_date) = 6 then 26
									  when month(a.in_date) = 7 then 27
									  when month(a.in_date) = 8 then 28
									  when month(a.in_date) = 9 then 29
									  when month(a.in_date) = 10 then 30
									  when month(a.in_date) = 11 then 31
									  when month(a.in_date) = 12 then 32
								end
			 , ship_qty  = isNULL(count(a.qa),0)
			 , c_qty     = sum(isNULL(a.qty,0))
			 , c_amt     = sum(isNULL(a.amount,0))
			 , cnt       = isNULL(count(a.qa),0)
			 , sort     = case when d.part_name = '성형'             then 1
											  when d.part_name = '스리타'    then 2
											  when d.part_name = 'YSP'       then 3
											  when d.part_name = '절곡'      then 4
											  when d.part_name = '유압'      then 5
											  when d.part_name = '도장'      then 6
											  when d.part_name = '공무'      then 7
											  when d.part_name = '금형'      then 8
											  when d.part_name = '출고'      then 9
											  when d.part_name = '사무실'    then 10
											  when d.part_name = '공용'      then 11
											  when d.part_name = '모듈러'    then 12
											  when d.part_name = '화성공장'  then 13
											  when d.part_name = '프레스'    then 14
								  end
			 , b.catgroup
		 FROM binitem A
				LEFT OUTER JOIN bitem B ON a.item_no = b.item_no 
				LEFT OUTER JOIN bsupp C ON a.supp_no = c.supp_no
				LEFT OUTER JOIN bpart D ON a.part_code = d.part_no
		WHERE 
					( convert(char(10),a.in_date,111)  BETWEEN :as_start AND :as_end )
					  AND ( a.supp_no           LIKE :as_supp      )
					  AND ( a.part_code         LIKE :as_part_code )
					  AND ( b.catgroup <> '기타' )
		
		  
		GROUP BY d.part_name
				 , a.in_date
				 , a.supp_no  
				 , a.item_no      
				 , a.uom  
				 , b.catgroup
				
	)TMP_01 LEFT OUTER JOIN codemst B ON TMP_01.catgroup = b.item_cd
	
	GROUP BY part_name
			 , TMP_01.catgroup
			 , in_year
			 , in_month
			 , b.sort
)TMP_MAIN

GROUP BY part_name
		 , item_name
ORDER BY sort, sort2
*/
" arguments=(("as_start", string),("as_end", string),("as_supp", string),("as_part_code", string),("as_bstart", string),("as_bend", string),("as_etc", string)) )
