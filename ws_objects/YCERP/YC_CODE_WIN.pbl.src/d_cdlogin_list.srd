table(column=(type=char(10) updatewhereclause=yes name=login_user_id dbname="login.user_id" )
 column=(type=char(8) updatewhereclause=yes name=login_password dbname="login.password" )
 column=(type=char(5) updatewhereclause=yes name=login_team_code dbname="login.team_code" )
 column=(type=char(30) updatewhereclause=yes name=login_rem dbname="login.rem" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name dbname="login.user_name" )
 column=(type=char(20) updatewhereclause=yes name=login_rank dbname="login.rank" )
 column=(type=char(10) updatewhereclause=yes name=login_area_no dbname="login.area_no" )
 column=(type=char(20) updatewhereclause=yes name=login_group_id dbname="login.group_id" )
 column=(type=char(1) updatewhereclause=yes name=login_use_flag dbname="login.use_flag" )
 column=(type=char(1) updatewhereclause=yes name=login_duty_flag dbname="login.duty_flag" )
 column=(type=char(1) updatewhereclause=yes name=update_chk dbname="update_chk" )
 column=(type=char(10) updatewhereclause=yes name=login_force_update dbname="login.force_update" )
 column=(type=char(10) updatewhereclause=yes name=force_old dbname="force_old" )
 column=(type=char(10) updatewhereclause=yes name=login_issuereq_area dbname="login.issuereq_area" )
 column=(type=char(1) updatewhereclause=yes name=login_sale_price dbname="login.sale_price" )
 column=(type=char(1) updatewhereclause=yes name=login_duty_flag2 dbname="login.duty_flag2" )
 column=(type=char(1) updatewhereclause=yes name=login_team_acc dbname="login.team_acc" )
 column=(type=char(10) updatewhereclause=yes name=login_rank_no dbname="login.rank_no" )
 column=(type=char(1) updatewhereclause=yes name=login_user_level dbname="login.user_level" )
 column=(type=char(1) updatewhereclause=yes name=login_ycgl_manager_chk dbname="login.ycgl_manager_chk" )
 column=(type=char(10) updatewhereclause=yes name=login_gw_id dbname="login.gw_id" )
 column=(type=datetime updatewhereclause=yes name=login_logdt dbname="login.logdt" )
 column=(type=char(13) updatewhereclause=yes name=login_phone dbname="login.phone" )
 column=(type=char(30) updatewhereclause=yes name=team_team_name dbname="team.team_name" )
 column=(type=char(20) updatewhereclause=yes name=sysgroup_group_name dbname="sysgroup.group_name" )
 retrieve="  SELECT login.user_id                    
       , login.password                   
       , login.team_code                  
       , login.rem                        
       , login.user_name                  
       , login.rank                       
       , login.area_no                    
       , login.group_id                   
       , login.use_flag                   
       , login.duty_flag                  
       , update_chk = 'N'                 
       , login.force_update               
       , force_old = login.force_update   
       , login.issuereq_area              
       , login.sale_price                 
       , login.duty_flag2                 
       , login.team_acc                   
       , login.rank_no                    
       , login.user_level                 
       , login.ycgl_manager_chk           
       , login.gw_id                      
       , login.logdt                   
       , login.phone
       , team.team_name                
       , sysgroup.group_name           
    FROM login  
         LEFT OUTER JOIN team     ON login.team_code = team.team_code
         LEFT OUTER JOIN sysgroup ON login.group_id  = sysgroup.group_id
   WHERE login.team_code    LIKE :as_team   
   ORDER BY login.use_flag  DESC,
            login.rank_no   ASC,   
            login.user_name ASC,   
            login.user_id   ASC   
" arguments=(("as_team", string)) )
