$PBExportHeader$d_orsale_his.srd
release 8;
datawindow(units=0 timer_interval=0 color=67108864 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=decimal(2) updatewhereclause=yes name=order_qty dbname="order_qty" )
 column=(type=char(14) updatewhereclause=yes name=order_no dbname="order_no" )
 column=(type=char(1) updatewhereclause=yes name=open_close dbname="open_close" values="마감	C/	O/" )
 retrieve="  SELECT item_no    = saledet.item_no
       , item_name  = g.item_name
       , qa         = saledet.qa
       , order_qty  = saledet.order_qty
       , order_no   = saledet.order_no
       , open_close = sale.open_close
    FROM saledet   
         LEFT OUTER JOIN sale        ON saledet.order_no = sale.order_no
         LEFT OUTER JOIN groupitem G ON saledet.item_no  = g.item_no
   WHERE sale.cust_no     = :as_custno
     AND sale.scene_code  = :as_scenecode
     AND sale.order_date between dateadd(month, -3, :ad_sdate) AND dateadd(month, 1, :ad_sdate)
     AND sale.order_no  NOT IN ( :as_orderno )" arguments=(("as_custno", string),("as_scenecode", string),("ad_sdate", date),("as_orderno", string))  sort="item_name A qa A order_no A " )
