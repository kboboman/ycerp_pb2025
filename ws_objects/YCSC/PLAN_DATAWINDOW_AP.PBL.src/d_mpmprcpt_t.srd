 column=(type=datetime updatewhereclause=yes name=inaudit_inaudit_time dbname="inaudit.inaudit_time" )
 retrieve="PBSELECT( VERSION(400) DISTINCT ()TABLE(NAME=~"mpsdet~" )  TABLE(NAME=~"wc~" )  TABLE(NAME=~"customer~" )  TABLE(NAME=~"scene~" )  TABLE(NAME=~"color~" )  TABLE(NAME=~"item~" )  TABLE(NAME=~"mps~" )  TABLE(NAME=~"inaudit~" ) COLUMN(NAME=~"mpsdet.plan_no~") COLUMN(NAME=~"mpsdet.order_no~") COLUMN(NAME=~"mpsdet.wc_no~") COLUMN(NAME=~"mpsdet.sale_no~") COLUMN(NAME=~"mpsdet.seq_no~") COLUMN(NAME=~"mpsdet.item_no~") COLUMN(NAME=~"mpsdet.qa~") COLUMN(NAME=~"mpsdet.due_date~") COLUMN(NAME=~"mpsdet.uom~") COLUMN(NAME=~"mpsdet.order_qty~") COLUMN(NAME=~"mpsdet.priority~") COLUMN(NAME=~"mpsdet.suju_type~") COLUMN(NAME=~"mpsdet.work_time~") COLUMN(NAME=~"mpsdet.setup_time~") COLUMN(NAME=~"mpsdet.rcpt_type~") COLUMN(NAME=~"mpsdet.rcpt_qty~") COLUMN(NAME=~"mpsdet.napgi_date~") COLUMN(NAME=~"mpsdet.cust_no~") COLUMN(NAME=~"mpsdet.scene_code~") COLUMN(NAME=~"mpsdet.item_color~") COLUMN(NAME=~"wc.work_name~") COLUMN(NAME=~"customer.cust_name~") COLUMN(NAME=~"scene.scene_desc~") COLUMN(NAME=~"color.color_name~") COLUMN(NAME=~"item.item_name~") COLUMN(NAME=~"inaudit.rcpt_qty~") COLUMN(NAME=~"inaudit.inaudit_date~") COLUMN(NAME=~"inaudit.inaudit_time~")    JOIN (LEFT=~"mpsdet.scene_code~"    OP =~"=~"RIGHT=~"scene.scene_code~"    OUTER1 =~"mpsdet.scene_code~" )    JOIN (LEFT=~"mpsdet.wc_no~"    OP =~"=~"RIGHT=~"wc.work_no~" )    JOIN (LEFT=~"mpsdet.cust_no~"    OP =~"=~"RIGHT=~"customer.cust_no~" )    JOIN (LEFT=~"mpsdet.item_color~"    OP =~"=~"RIGHT=~"color.color_code~" )    JOIN (LEFT=~"mpsdet.item_no~"    OP =~"=~"RIGHT=~"item.item_no~" )    JOIN (LEFT=~"mpsdet.order_no~"    OP =~"=~"RIGHT=~"mps.order_no~" )    JOIN (LEFT=~"mpsdet.plan_no~"    OP =~"=~"RIGHT=~"inaudit.order_no~" )WHERE(    EXP1 =~"mps.open_close~"   OP =~"<>~"    EXP2 =~"'C'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"mpsdet.order_no~"   OP =~"=~"    EXP2 =~":as_orderno~" ) ) ARG(NAME = ~"as_orderno~" TYPE = string) " arguments=(("as_orderno", string))  sort="inaudit_inaudit_date A inaudit_inaudit_time A " )
