 retrieve="  SELECT SID,   
         SDATE,   
         CAT,   
         SEQ,   
         ITEM_NO,   
         UOM,   
         ITEMNM_Y,   
         QA_Y,   
         QTY,   
         AMT_Y,   
         BIGO  
    FROM NBASIS_DET   
where sid = :as_sid
order by SID,   
         SDATE,   
         CAT,   
         SEQ" arguments=(("as_sid", string)) )
