																						null ceilling5, 
																						null pilotis5,
																				 		null etc5,
                                           														null salesman5,                                            
																						interior_name interior_name6,  
																						wall wall6,
																						ceilling ceilling6, 
																						pilotis pilotis6,
																				 		etc etc6,
                                            														salesman salesman6,                                            
