 retrieve="  SELECT SID,   
         SDATE,   
         CAT,   
         SEQ,   
         ITEM_NO,   
         UOM,   
         ITEMNM_S,   
         QA_S,   
         QTY,   
         AMT_S,   
         BIGO  
    FROM NBASIS_DET   
where sid = :as_sid
order by SID,   
         SDATE,   
         CAT,   
         SEQ" arguments=(("as_sid", string)) )
