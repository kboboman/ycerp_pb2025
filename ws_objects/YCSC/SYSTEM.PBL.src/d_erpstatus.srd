table(column=(type=long updatewhereclause=yes name=spid dbname="SPID" )
 column=(type=long updatewhereclause=yes name=blocked dbname="BLOCKED" )
 column=(type=char(255) updatewhereclause=yes name=program_name dbname="PROGRAM_NAME" )
 column=(type=char(255) updatewhereclause=yes name=loginname dbname="LOGINNAME" )
 column=(type=char(255) updatewhereclause=yes name=hostname dbname="HOSTNAME" )
 column=(type=char(24) updatewhereclause=yes name=macaddr dbname="MACADDR" )
 column=(type=char(30) updatewhereclause=yes name=login_time dbname="LOGIN_TIME" )
 column=(type=char(30) updatewhereclause=yes name=last_batch dbname="LAST_BATCH" )
 column=(type=long updatewhereclause=yes name=use_hour dbname="USE_HOUR" )
 retrieve="SELECT SPID
     , BLOCKED
     , PROGRAM_NAME
     , LOGINNAME = LOGINAME
     , HOSTNAME
     , MACADDR    = NET_ADDRESS
     , LOGIN_TIME = CONVERT(VARCHAR, LOGIN_TIME, 20)
     , LAST_BATCH = CONVERT(VARCHAR, LAST_BATCH, 20)
     , USE_HOUR   = DATEDIFF(hh, LOGIN_TIME, LAST_BATCH)
  FROM MASTER.DBO.SYSPROCESSES
 ORDER BY SPID   
" )
