 column=(type=char(50) update=yes updatewhereclause=yes name=rem2 dbname="ask_head.rem2" )
 column=(type=char(1) update=yes updatewhereclause=yes name=ship_close dbname="ask_head.ship_close" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"ask_head~" ) COLUMN(NAME=~"ask_head.ask_date~") COLUMN(NAME=~"ask_head.ask_loc~") COLUMN(NAME=~"ask_head.ask_user~") COLUMN(NAME=~"ask_head.rem~") COLUMN(NAME=~"ask_head.proc_flag~") COLUMN(NAME=~"ask_head.ask_no~") COLUMN(NAME=~"ask_head.act_user~") COLUMN(NAME=~"ask_head.act_date~") COLUMN(NAME=~"ask_head.f_area~") COLUMN(NAME=~"ask_head.t_area~") COLUMN(NAME=~"ask_head.driver~") COLUMN(NAME=~"ask_head.ship_amount~") COLUMN(NAME=~"ask_head.rem2~") COLUMN(NAME=~"ask_head.ship_close~")WHERE(    EXP1 =~"ask_head.ask_no~"   OP =~"=~"    EXP2 =~":aa~" ) ) ARG(NAME = ~"aa~" TYPE = string) " update="ask_head" updatewhere=1 updatekeyinplace=no arguments=(("aa", string)) )
