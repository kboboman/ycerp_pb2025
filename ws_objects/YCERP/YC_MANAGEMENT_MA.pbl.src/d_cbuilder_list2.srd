 column=(type=char(8) update=yes updatewhereclause=yes name=write_date dbname="make_manager.write_date" )
 column=(type=char(8) updatewhereclause=yes name=fr_date dbname="make_manager.fr_date" )
 column=(type=char(8) updatewhereclause=yes name=to_date dbname="make_manager.to_date" )
 retrieve="select id,
		site_name,
		site_address,
		work_fr_gigan_date,
		work_to_gigan_date,
		salesman,
		company_name,
		builder_name,
		keyman,
		grade,
		kind,
		gubun,
		work_value,
          work_area,
		special_note,
		order_date,
		attend_name,
		attend_company_name,
		tender_date,
		tender_type,
		estimation_amt,
		success_company,
		success_amt,
		rank,
		fail_reason,
		result,
          write_date,
          :arg_fr_date fr_date,
          :arg_to_date to_date
from make_manager
where write_date between :arg_fr_date and :arg_to_date
" update="make_manager" updatewhere=0 updatekeyinplace=no arguments=(("arg_fr_date", string),("arg_to_date", string))  sort="order_date A " )
