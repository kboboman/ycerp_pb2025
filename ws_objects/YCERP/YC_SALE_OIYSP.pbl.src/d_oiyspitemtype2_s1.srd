$PBExportHeader$d_oiyspitemtype2_s1.srd
$PBExportComments$YSP TYPE별 출고집계(월별)(2000/03/06,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no  crosstab.dynamic = yes grid.lines=0 grid.columnmove=no selected.mouse=no )
header[1](height=0 color="536870912" )
header[2](height=76 color="536870912" )
summary(height=76 color="536870912" )
footer(height=76 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa1 dbname="qa1" )
 column=(type=number updatewhereclause=yes name=flag dbname="flag" )
 column=(type=number updatewhereclause=yes name=qty dbname="qty" )
 retrieve="  SELECT groupitem.item_name
       , substring(groupitem.item_no, 1, 6)
       , qa1  = substring(dodet.qa, 1,3)
       , mon  = right('00' + rtrim(convert(char(2), datepart(month, do.do_date))) ,2) +'월'
       , qty  = (case when groupitem.item_no = 'PCYSYSEBZZ' then sum(dodet.ship_qty) / 2 else sum(dodet.ship_qty) end)
       , flag = (case substring(groupitem.item_no, 1, 6) 
                      when 'PCYSZ1' then 1 
                      when 'PCYSZ2' then 2 
							 when 'PCYSZ3' then 3 
                      else 4 
                 end)
    FROM do
       , dodet
       , groupitem	
   WHERE ( do.do_no      = dodet.do_no       ) 
     AND ( dodet.item_no = groupitem.item_no ) 
     AND ( do.do_date between :ad_start and :ad_end ) 
     AND ((dodet.item_no like 'PCYSYS%' ) OR 
          (dodet.item_no like 'GCYSYS%' ) OR 
          (dodet.item_no like 'PCYSZ%'  )
         )
   GROUP BY do.do_date, groupitem.item_no, groupitem.item_name, dodet.qa
   ORDER BY do.do_date, groupitem.item_no, groupitem.item_name, dodet.qa" arguments=(("ad_start", date),("ad_end", date))  sort="item_name A qa1 A flag A " )
group(level=1 header.height=0 trailer.height=76 by=("flag" ) header.color="536870912" trailer.color="536870912" )
group(level=2 header.height=0 trailer.height=76 by=("item_name" ) header.color="536870912" trailer.color="536870912" )
