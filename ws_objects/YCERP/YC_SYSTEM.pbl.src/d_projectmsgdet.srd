$PBExportHeader$d_projectmsgdet.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=84 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=long update=yes updatewhereclause=yes key=yes identity=yes name=id dbname="ID" )
 column=(type=long update=yes updatewhereclause=yes name=pkid dbname="PKID" )
 column=(type=char(10) update=yes updatewhereclause=yes name=tlogin dbname="TLOGIN" )
 column=(type=datetime update=yes updatewhereclause=yes name=msgdate dbname="MSGDATE" )
 column=(type=char(100) update=yes updatewhereclause=yes name=msg dbname="MSG" )
 column=(type=char(100) updatewhereclause=yes name=oldmsg dbname="OLDMSG" )
 column=(type=char(1) update=yes updatewhereclause=yes name=del dbname="DEL" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="USER_NAME" )
 column=(type=long updatewhereclause=yes name=ctime dbname="CTIME" )
 retrieve="SELECT ID         = A.ID
     , PKID       = A.PKID
     , TLOGIN     = A.TLOGIN
     , MSGDATE    = A.MSGDATE
     , MSG        = A.MSG
     , OLDMSG     = A.MSG
     , DEL        = A.DEL
     , USER_NAME  = B.USER_NAME
     , CTIME      = (CASE WHEN A.MSG IS NULL THEN 0 
                          ELSE DATEDIFF( SS, C.MSGDATE, A.MSGDATE ) / 60 END)
  FROM PROJECTMSGDET A
       LEFT OUTER JOIN LOGIN B       ON B.USER_ID = A.TLOGIN
       LEFT OUTER JOIN PROJECTMSG C  ON A.PKID    = C.ID
 WHERE A.PKID     = :ai_pkid
 ORDER BY A.ID
" update="PROJECTMSGDET" updatewhere=0 updatekeyinplace=no arguments=(("ai_pkid", number)) )
