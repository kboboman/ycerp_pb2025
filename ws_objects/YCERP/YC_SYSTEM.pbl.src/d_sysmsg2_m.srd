$PBExportComments$사용자메시지(1999/06/24, 이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=248 color="536870912" )
table(column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" values="	Y/	N" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=flogin dbname="sysmsg.flogin" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=tlogin dbname="sysmsg.tlogin" )
 column=(type=datetime update=yes updatewhereclause=yes key=yes name=msgdate dbname="sysmsg.msgdate" initial="today" )
 column=(type=char(255) update=yes updatewhereclause=yes name=msg dbname="sysmsg.msg" )
 column=(type=char(1) update=yes updatewhereclause=yes name=del dbname="sysmsg.del" initial="N" values="	Y/	N" )
 retrieve="  SELECT chk  = 'N'
       , sysmsg.flogin
       , sysmsg.tlogin
       , sysmsg.msgdate
       , sysmsg.msg
       , sysmsg.del  
    FROM sysmsg  
   WHERE ( sysmsg.flogin   = :as_flogin ) 
     AND ( sysmsg.del      = 'N'        )    
" update="sysmsg" updatewhere=1 updatekeyinplace=no arguments=(("as_flogin", string))  sort="msgdate A flogin A " )
