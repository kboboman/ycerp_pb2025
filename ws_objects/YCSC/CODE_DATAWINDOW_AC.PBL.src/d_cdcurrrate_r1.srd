$PBExportComments$환율관리 REPORT1(1998/05/04, 정재수)
release 5;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no )
header(height=473 color="536870912" )
summary(height=1 color="536870912" )
footer(height=1 color="536870912" )
detail(height=69 color="536870912" )
table(column=(type=char(3) updatewhereclause=yes name=currency_curr_code dbname="currency.curr_code" )
 column=(type=char(10) updatewhereclause=yes name=money_curr_name dbname="money.curr_name" )
 column=(type=datetime updatewhereclause=yes name=currency_curr_date dbname="currency.curr_date" )
 column=(type=decimal(4) updatewhereclause=yes name=currency_exp_rate dbname="currency.exp_rate" )
 column=(type=decimal(4) updatewhereclause=yes name=currency_rev_rate dbname="currency.rev_rate" )
 column=(type=char(30) updatewhereclause=yes name=currency_rem dbname="currency.rem" )
 column=(type=char(10) updatewhereclause=yes name=startdate dbname="startdate" )
 column=(type=char(10) updatewhereclause=yes name=enddate dbname="enddate" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"currency~" )  TABLE(NAME=~"money~" ) COLUMN(NAME=~"currency.curr_code~") COLUMN(NAME=~"money.curr_name~") COLUMN(NAME=~"currency.curr_date~") COLUMN(NAME=~"currency.exp_rate~") COLUMN(NAME=~"currency.rev_rate~") COLUMN(NAME=~"currency.rem~") COMPUTE(NAME=~"'          ' startdate~") COMPUTE(NAME=~"'          ' enddate~")    JOIN (LEFT=~"currency.curr_code~"    OP =~"=~"RIGHT=~"money.curr_type~" )WHERE(    EXP1 =~"currency.curr_code~"   OP =~"=~"    EXP2 =~":as_curr_code~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"currency.curr_date~"   OP =~"between~"    EXP2 =~":ad_start and :ad_end~" ) ) ARG(NAME = ~"as_curr_code~" TYPE = string)  ARG(NAME = ~"ad_start~" TYPE = date)  ARG(NAME = ~"ad_end~" TYPE = date) " arguments=(("as_curr_code", string),("ad_start", date),("ad_end", date))  sort="currency_curr_date D " )
