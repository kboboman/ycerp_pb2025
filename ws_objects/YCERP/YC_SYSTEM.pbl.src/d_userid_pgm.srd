release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=72 color="12632256" )
detail(height=68 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=user_id dbname="user_id" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 retrieve="  SELECT user_id   = a.user_id,   
         user_name = a.user_name  
    FROM login a 
         left outer join team b  on a.team_code = b.team_code
         left outer join team c  on b.parent_code = c.team_code
   WHERE a.use_flag = 'Y'    
/*     AND a.gw_id   is not null */
     and not (c.team_name = '' or c.team_name is null)
     and a.team_code between '70000' and '92999'
   ORDER BY a.user_name
" )
column(band=detail id=2 alignment="0" tabsequence=32766 border="0" color="0" x="407" y="4" height="60" width="352" format="[general]" html.valueishtml="0"  name=user_name visible="1" edit.limit=10 edit.case=any edit.autoselect=yes edit.autohscroll=yes edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="2" font.pitch="2" font.charset="129" background.mode="1" background.color="536870912" )
