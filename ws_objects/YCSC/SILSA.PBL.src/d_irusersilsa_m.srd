table(column=(type=char(4) update=yes updatewhereclause=yes key=yes name=cyear dbname="ineoymu.cyear" )
 column=(type=char(2) update=yes updatewhereclause=yes key=yes name=cmon dbname="ineoymu.cmon" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="ineoymu.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=qa dbname="ineoymu.qa" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=loc_no dbname="ineoymu.loc_no" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=user_id dbname="ineoymu.user_id" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=qoh dbname="ineoymu.qoh" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=stock_qty dbname="ineoymu.stock_qty" initial="0" )
 column=(type=decimal(4) updatewhereclause=yes name=stock dbname="stock" initial="0" )
 column=(type=char(180) updatewhereclause=yes name=reason dbname="reason" )
 column=(type=decimal(4) updatewhereclause=yes name=eom_qoh dbname="eom_qoh" initial="0" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(30) updatewhereclause=yes name=location_loc_name dbname="location.loc_name" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name dbname="login.user_name" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 retrieve="  SELECT ineoymu.cyear       
       , ineoymu.cmon        
       , ineoymu.item_no     
       , ineoymu.qa          
       , ineoymu.loc_no      
       , ineoymu.user_id     
       , ineoymu.qoh         
       , ineoymu.stock_qty   
       , stock   = isnull((case when ineoymu.stock_qty > 0 then stock_qty else itemstock.qty end), 0)
       , reason  = itemstock.reason1 + itemstock.reason2 + itemstock.reason3
       , eom_qoh = isnull(itemloc.qoh, 0) - isnull(cday.rcpt, 0) + isnull(cday.issue, 0)
       , groupitem.item_name
       , location.loc_name  
       , login.user_name    
       , uom     = (case groupitem.uom when 'M'  then 'EA'
                                       when 'M2' then 'EA'
                                       else groupitem.uom
                   end)  
     FROM ineoymu left outer join (SELECT item_no, qa, rcpt = sum(rcpt_qty), issue = sum(issue_qty) 
                                                          FROM ineoday
                                                         WHERE cdate  > rtrim(:as_year) + rtrim(:as_mon) + '99'
                                                           AND loc_no = :as_loc 
                                                         GROUP BY item_no, qa
                                                       ) cday on ineoymu.item_no = cday.item_no and  ineoymu.qa = cday.qa
                                 left outer join itemloc on ineoymu.loc_no = itemloc.loc_no
                                                                 and ineoymu.item_no = itemloc.item_no
                                                                 and ineoymu.qa = itemloc.qa
                               inner join groupitem on ineoymu.item_no     = groupitem.item_no and groupitem.use_flag <> 'C'                  
                               inner join location on ineoymu.loc_no      = location.loc_no
                               inner join login on ineoymu.user_id     = login.user_id        
                               left outer join itemstock on ineoymu.loc_no = itemstock.loc_no
                                                                   and  ineoymu.item_no = itemstock.item_no
                                                                   and ineoymu.qa = itemstock.qa
   WHERE ( ineoymu.cyear     = :as_year         )   
        AND ( ineoymu.cmon      = :as_mon          )   
        AND ( ineoymu.loc_no    = :as_loc          )   
        AND ( ineoymu.user_id   = :as_userid       )   
" update="ineoymu" updatewhere=0 updatekeyinplace=no arguments=(("as_year", string),("as_mon", string),("as_loc", string),("as_userid", string))  sort="groupitem_item_name A qa A " )
