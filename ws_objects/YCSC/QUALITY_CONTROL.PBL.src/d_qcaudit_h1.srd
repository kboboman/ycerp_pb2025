column(band=detail id=1 alignment="0" tabsequence=32766 border="0" color="33554432" x="146" y="8" height="60" width="334" format="[general]" html.valueishtml="0"  name=cdate visible="1" edit.limit=0 edit.case=any edit.autoselect=yes edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
compute(band=detail alignment="0" expression=" IF ( real(LEFT( qa, 1) + ~".~" + MID( qa , 2, 2))<> 0 , STRING(real(LEFT( qa, 1) + ~".~" + MID( qa , 2, 2)),~"0.0#~") + ~"*~", ~"~") + 
IF ( integer(MID(qa , 5, 4))<> 0 ,STRING(integer(MID(qa , 5, 4))) + ~"*~", ~"~") + 
IF ( integer(MID(  qa , 10, 4))<> 0 ,STRING(integer(MID(  qa , 10, 4))) + ~"*~", ~"~") + 
IF ( integer(MID(  qa  , 15, 5))<> 0 ,STRING(integer(MID(  qa  , 15, 5))), ~"~") "border="0" color="33554432" x="2176" y="8" height="60" width="466" format="[GENERAL]" html.valueishtml="0"  name=qa2 visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
column(band=detail id=3 alignment="0" tabsequence=32766 border="0" color="33554432" x="2651" y="8" height="60" width="357" format="[general]" html.valueishtml="0"  name=item_no visible="1" edit.limit=0 edit.case=any edit.autoselect=yes edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
column(band=detail id=2 alignment="0" tabsequence=32766 border="0" color="33554432" x="9" y="8" height="60" width="128" format="[general]" html.valueishtml="0"  name=flag visible="1" edit.limit=0 edit.case=any edit.autoselect=yes edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
compute(band=trailer.1 alignment="1" expression="sum(qty for group 1)"border="0" color="33554432" x="1824" y="4" height="60" width="343" format="[general]" html.valueishtml="0"  name=ctotqty visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
