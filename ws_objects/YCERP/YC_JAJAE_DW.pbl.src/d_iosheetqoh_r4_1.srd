$PBExportHeader$d_iosheetqoh_r4_1.srd
$PBExportComments$원/스리팅 sheet재고 상세현황(2006/01/21,정갑용)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=76 color="536870912" )
summary(height=68 color="536870912" )
footer(height=0 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=sheetmst_sheet_no dbname="sheetmst.sheet_no" )
 column=(type=char(10) updatewhereclause=yes name=sheetmst_item_no dbname="sheetmst.item_no" )
 column=(type=char(20) updatewhereclause=yes name=sheetmst_qa dbname="sheetmst.qa" )
 column=(type=char(10) updatewhereclause=yes name=sheetmst_loc_no dbname="sheetmst.loc_no" )
 column=(type=datetime updatewhereclause=yes name=coilmst_rcpt_date dbname="sheetmst.rcpt_date" )
 column=(type=decimal(4) updatewhereclause=yes name=sheetmst_unit_qty dbname="sheetmst.unit_qty" )
 column=(type=long updatewhereclause=yes name=sheetmst_cnt dbname="sheetmst.cnt" )
 column=(type=long updatewhereclause=yes name=sheetmst_qcnt dbname="sheetmst.qcnt" )
 column=(type=char(4) updatewhereclause=yes name=sheetmst_color_no dbname="sheetmst.color_no" )
 column=(type=char(10) updatewhereclause=yes name=sheetmst_supp_no dbname="sheetmst.supp_no" )
 column=(type=char(1) updatewhereclause=yes name=sheetmst_flag dbname="sheetmst.flag" values="원코일	W/스리팅	S/" )
 column=(type=char(14) updatewhereclause=yes name=sheetmst_porder_no dbname="sheetmst.porder_no" )
 column=(type=long updatewhereclause=yes name=sheetmst_pseq_no dbname="sheetmst.pseq_no" )
 column=(type=char(1) updatewhereclause=yes name=sheetmst_open_close dbname="sheetmst.open_close" values="재고	O/계획	M/작업지시	P/외주가공	S/사용완료	C/" )
 column=(type=char(40) updatewhereclause=yes name=sheetmst_rem dbname="sheetmst.rem" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(30) updatewhereclause=yes name=location_loc_name dbname="location.loc_name" )
 column=(type=char(30) updatewhereclause=yes name=supp_supp_name dbname="supp.supp_name" )
 retrieve="  SELECT sheetmst.sheet_no,
         sheetmst.item_no,   
         sheetmst.qa,   
         sheetmst.loc_no,   
         sheetmst.rcpt_date,   
         sheetmst.unit_qty, 
         sheetmst.cnt,   
         sheetmst.qcnt,   
         sheetmst.color_no,   
         sheetmst.supp_no,   
         sheetmst.flag,   
         sheetmst.porder_no,   
         sheetmst.pseq_no,   
         sheetmst.open_close,   
         sheetmst.rem,   
         groupitem.item_name,   
         location.loc_name,   
         supp.supp_name
FROM sheetmst left outer join  groupitem  on sheetmst.item_no = groupitem.item_no
                                        inner join  location on sheetmst.loc_no = location.loc_no
                                        left outer join supp   on sheetmst.supp_no = supp.supp_no
   WHERE  ( 
                            ( :as_work_chk = 'N' and :as_stock_chk = 'N'  and sheetmst.loc_no in (:asa_loc) )   
  		                          or (
                                               :as_work_chk = 'Y' AND ( 
                                                                                                              ( 'WW01' not in (:asa_loc) and sheetmst.loc_no in (:asa_loc) )
                                                                                                                   or  
                                                                                                              ( 
                                                                                                                      ( 'WW01' in (:asa_loc)) and 
                                                                                                                      ( 
                                                                                                                              sheetmst.loc_no in (:asa_loc) 
                                                                                                                              OR 
                                                                                                                            ( sheetmst.loc_no in ( select loc_no from location where loc_type = 'W' or loc_type = 'Y') ) 
                                                                                                                      ) 
                                                                                                               ) 
                                                                                                      )
                                       ) 
  		                  or ( :as_stock_chk = 'Y' AND ( ( 'WW01' not in (:asa_loc) and sheetmst.loc_no in (:asa_loc) ) 
											 or  ( ( 'WW01' in (:asa_loc) ) 
												and ( sheetmst.loc_no in (:asa_loc) OR sheetmst.loc_no = 'WS00000003' ) ) ) )
			                )
			              and ( sheetmst.item_no in (:asa_item) )
                    and ( sheetmst.flag like :as_flag )
                    and ( sheetmst.open_close in ( :as_oc ) )
 			              and not exists ( select * from lossitem where loss_item = sheetmst.item_no )
		                and ( sheetmst.qa like :as_qa )
/*
    FROM sheetmst,   
         groupitem,   
         location,   
         supp  
   WHERE ( sheetmst.item_no *= groupitem.item_no )
	  and ( sheetmst.loc_no = location.loc_no )
     and ( sheetmst.supp_no *= supp.supp_no )
	  and ( ( :as_work_chk = 'N' and :as_stock_chk = 'N'  and sheetmst.loc_no in (:asa_loc) )   
  		  or ( :as_work_chk = 'Y' AND ( ( 'WW01' not in (:asa_loc) and sheetmst.loc_no in (:asa_loc) ) 
											 or  ( ( 'WW01' in (:asa_loc)) 
												and ( sheetmst.loc_no in (:asa_loc) OR ( sheetmst.loc_no in ( select loc_no from location where loc_type = 'W' or loc_type = 'Y') ) ) ) ) ) 
  		 or ( :as_stock_chk = 'Y' AND ( ( 'WW01' not in (:asa_loc) and sheetmst.loc_no in (:asa_loc) ) 
											 or  ( ( 'WW01' in (:asa_loc) ) 
												and ( sheetmst.loc_no in (:asa_loc) OR sheetmst.loc_no = 'WS00000003' ) ) ) )
			)
			and ( sheetmst.item_no in (:asa_item) )
         and ( sheetmst.flag like :as_flag )
         and ( sheetmst.open_close in ( :as_oc ) )
 			and not exists ( select * from lossitem where loss_item = sheetmst.item_no )
		and ( sheetmst.qa like :as_qa )
*/" arguments=(("asa_loc", stringlist),("asa_item", stringlist),("as_flag", string),("as_oc", stringlist),("as_work_chk", string),("as_stock_chk", string),("as_qa", string))  sort="mid(sheetmst_item_no,3,1) A sheetmst_item_no A sheetmst_qa A sheetmst_unit_qty A sheetmst_sheet_no A sheetmst_loc_no A " )
group(level=1 header.height=0 trailer.height=80 by=("mid(sheetmst_item_no,3,1) + mid(sheetmst_item_no,2,1)" ) header.color="536870912" trailer.color="15780518" )
group(level=2 header.height=0 trailer.height=0 by=("sheetmst_item_no" ) header.color="536870912" trailer.color="553648127" )
