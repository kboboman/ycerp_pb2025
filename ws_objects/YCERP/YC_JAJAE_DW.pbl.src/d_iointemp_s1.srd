table(column=(type=char(14) update=yes updatewhereclause=yes name=intemp_no dbname="intemp_no" )
 column=(type=long update=yes updatewhereclause=yes name=seq dbname="seq" )
 column=(type=datetime update=yes updatewhereclause=yes name=intemp_date dbname="intemp_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="qa" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=qty dbname="qty" )
 column=(type=datetime update=yes updatewhereclause=yes name=user_date dbname="user_date" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=char(50) update=yes updatewhereclause=yes name=rem dbname="rem" )
 column=(type=char(20) update=yes updatewhereclause=yes name=order_no dbname="order_no" )
 column=(type=long update=yes updatewhereclause=yes name=seq_no dbname="seq_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=area_name dbname="area_name" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(20) updatewhereclause=yes name=intempflag_name dbname="name" )
 retrieve="select  distinct  a.intemp_no,   
         a.seq,   
         a.intemp_date,   
         a.item_no,   
         a.qa,   
         a.qty,   
         a.user_date,   
         a.uom,   
         a.rem,   
         a.order_no,   
         a.seq_no,   
         a.item_name,   
         a.area_name,   
         a.user_name,   
         a.name  
  from 
  (
   SELECT intemp.intemp_no,   
         intemp.seq,   
         intemp.intemp_date,   
         intemp.item_no,   
         intemp.qa,   
         intemp.qty,   
         intemp.user_date,   
         groupitem.uom,   
         intemp.rem,   
         intemp.order_no,   
         intemp.seq_no,   
         groupitem.item_name,   
         area.area_name,   
         login.user_name,   
         intempflag.name  
    FROM intemp LEFT OUTER JOIN groupitem ON intemp.item_no = groupitem.item_no LEFT OUTER JOIN intempflag ON intemp.flag = intempflag.flag,   
         area,   
         login  
   WHERE ( intemp.area_no = area.area_no ) and  
         ( intemp.user_id = login.user_id ) and  
         ( ( intemp.intemp_no = :as_intempno ) AND  
         ( intemp.seq = :ai_seq ) )    
     union all
     SELECT intemp_backup.intemp_no,   
         intemp_backup.seq,   
         intemp_backup.intemp_date,   
         intemp_backup.item_no,   
         intemp_backup.qa,   
         intemp_backup.qty,   
         intemp_backup.user_date,   
         groupitem.uom,   
         intemp_backup.rem,   
         intemp_backup.order_no,   
         intemp_backup.seq_no,   
         groupitem.item_name,   
         area.area_name,   
         login.user_name,   
         intempflag.name  
    FROM intemp_backup LEFT OUTER JOIN groupitem ON intemp_backup.item_no = groupitem.item_no
                                            LEFT OUTER JOIN intempflag ON intemp_backup.flag = intempflag.flag,   
         area,   
         login  
   WHERE ( intemp_backup.area_no = area.area_no ) and  
         ( intemp_backup.user_id = login.user_id ) and  
         ( ( intemp_backup.intemp_no = :as_intempno ) AND  
         ( intemp_backup.seq = :ai_seq ) )          
)  a       " arguments=(("as_intempno", string),("ai_seq", number)) )
