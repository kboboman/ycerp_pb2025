$PBExportHeader$d_iocoilinaudit_r.srd
$PBExportComments$코일수불데이터(1998/09/10,곽용덕)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(2) updatewhereclause=yes name=groupitem_uom dbname="groupitem.uom" )
 column=(type=datetime updatewhereclause=yes name=inaudit_inaudit_date dbname="inaudit.inaudit_date" )
 column=(type=char(10) updatewhereclause=yes name=inaudit_inaudit_item dbname="inaudit.inaudit_item" )
 column=(type=char(20) updatewhereclause=yes name=inaudit_qa dbname="inaudit.qa" )
 column=(type=char(30) updatewhereclause=yes name=inaudit_loc_no dbname="loc_no" )
 column=(type=char(20) updatewhereclause=yes name=inaudit_inaudit_type dbname="inaudit_type" )
 column=(type=char(17) updatewhereclause=yes name=inaudit_order_no dbname="inaudit.order_no" )
 column=(type=decimal(2) updatewhereclause=yes name=inaudit_rcpt_qty dbname="inaudit.rcpt_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=inaudit_issue_qty dbname="inaudit.issue_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=inaudit_cost dbname="inaudit.cost" )
 column=(type=char(30) updatewhereclause=yes name=inaudit_destination dbname="destination" )
 column=(type=char(20) updatewhereclause=yes name=inaudit_serial_id dbname="inaudit.serial_id" )
 column=(type=decimal(2) updatewhereclause=yes name=inaudit_unit_qty dbname="inaudit.unit_qty" )
 column=(type=long updatewhereclause=yes name=inaudit_cnt dbname="inaudit.cnt" )
 retrieve="  SELECT groupitem.item_name    
       , groupitem.uom          
       , inaudit.inaudit_date   
       , inaudit.inaudit_item   
       , inaudit.qa             
       , loc_no        = (SELECT loc_name FROM location WHERE loc_no       = inaudit.loc_no      )
       , inaudit_type  = (SELECT remarks  FROM iotype   WHERE inaudit_type = inaudit.inaudit_type)
       , inaudit.order_no       
       , inaudit.rcpt_qty       
       , inaudit.issue_qty      
       , inaudit.cost           
       , destination   = (SELECT loc_name FROM location WHERE loc_no = inaudit.destination )
       , inaudit.serial_id   
       , inaudit.unit_qty    
       , inaudit.cnt  
    FROM inaudit     
       , coilmst  
       , groupitem   
   WHERE ( inaudit.inaudit_item = groupitem.item_no ) 
     AND ( inaudit.serial_id    = coilmst.coil_no   )
     AND ( inaudit.loc_no       = coilmst.loc_no    )
     AND ( inaudit.inaudit_date BETWEEN :ad_sdate and :ad_edate )    
   " arguments=(("ad_sdate", date),("ad_edate", date))  sort="inaudit_inaudit_date A inaudit_inaudit_type A " )
group(level=1 header.height=0 trailer.height=80 by=("inaudit_inaudit_date" , "inaudit_inaudit_type" ) header.color="536870912" trailer.color="536870912" )
