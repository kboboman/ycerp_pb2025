 retrieve="SELECT trans_no,   
		seq_no,   
		do_no,   
		trans_amt,   
		bigo,   
		cust_no,   
		scene_code  
FROM DoTransDET (nolock)
WHERE trans_no = :as_trans_no
" update="DoTransDET" updatewhere=0 updatekeyinplace=no arguments=(("as_trans_no", string)) )
