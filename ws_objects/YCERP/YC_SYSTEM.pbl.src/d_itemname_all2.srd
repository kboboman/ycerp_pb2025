table(column=(type=char(10) updatewhereclause=yes key=yes name=item_no dbname="groupitem.item_no" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="groupitem.uom" )
 column=(type=char(1) updatewhereclause=yes name=source dbname="groupitem.source" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="groupitem.item_name" )
 column=(type=char(1) updatewhereclause=yes name=use_flag dbname="groupitem.use_flag" initial="Y" values="사용	Y/불가	C/" )
 retrieve="  SELECT groupitem.item_no,   
         groupitem.uom,   
         groupitem.source,   
         groupitem.item_name,
         groupitem.use_flag
    FROM groupitem  
   ORDER BY groupitem.item_name" update="groupitem" updatewhere=0 updatekeyinplace=no  sort="use_flag D item_name A " )
