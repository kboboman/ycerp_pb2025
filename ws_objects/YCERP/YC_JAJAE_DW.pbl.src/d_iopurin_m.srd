 column=(type=char(20) update=yes updatewhereclause=yes name=coil_no dbname="coil_no" initial=" " )
 column=(type=long update=yes updatewhereclause=yes name=serial_no dbname="serial_no" initial=" " )
 column=(type=char(1) updatewhereclause=yes name=work_type dbname="work_type" initial=" " )
 column=(type=long update=yes updatewhereclause=yes name=cnt dbname="cnt" initial="1" )
 column=(type=char(1) updatewhereclause=yes name=pur_subcon dbname="subcon" initial=" " values="구매	N/외주가공	P/외주구매	Y/외주스리팅	C/자재가공	J/원코일	W/수입	L/" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" initial=" " )
 column=(type=decimal(4) updatewhereclause=yes name=rcpt_qty dbname="rcpt_qty" )
 column=(type=char(1) update=yes updatewhereclause=yes name=result_type dbname="result_type" values="완료	E/부분	P/취소	C/미입	N/" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=com_qty dbname="com_qty" )
 column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" initial="N" values="	Y/	N" )
 column=(type=char(14) updatewhereclause=yes name=purdet_sale_no dbname="sale_no" )
 column=(type=long updatewhereclause=yes name=purdet_sale_seq dbname="sale_seq" )
 column=(type=char(50) updatewhereclause=yes name=purdet_cust_name dbname="cust_name" )
 column=(type=char(50) updatewhereclause=yes name=purdet_sale_rem dbname="sale_rem" )
 column=(type=char(4) updatewhereclause=yes name=purdet_color dbname="color" )
 column=(type=char(10) updatewhereclause=yes name=pur_fob dbname="fob" )
 column=(type=char(80) updatewhereclause=yes name=pur_shipto_addr dbname="shipto_addr" )
 column=(type=char(3) updatewhereclause=yes name=pur_curr_code dbname="curr_code" )
 column=(type=char(1) updatewhereclause=yes name=pur_tax_sign dbname="tax_sign" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=unit_qty dbname="unit_qty" )
 column=(type=char(20) updatewhereclause=yes name=draw_no dbname="draw_no" )
 column=(type=long update=yes updatewhereclause=yes name=wlen dbname="wlen" )
 column=(type=char(20) update=yes updatewhereclause=yes name=supp_coil_no dbname="supp_coil_no" )
 column=(type=char(2) update=yes updatewhereclause=yes name=com_uom dbname="com_uom" )
 column=(type=char(1) update=yes updatewhereclause=yes name=ingubun dbname="ingubun" values="	Y/	N" )
 column=(type=char(1) updatewhereclause=yes name=round dbname="round" )
 column=(type=char(2) updatewhereclause=yes name=etc dbname="etc" )
 column=(type=char(2) updatewhereclause=yes name=type dbname="TYPE" )
 retrieve="  SELECT purdet.order_no        
       , purdet.seq_no          
       , purdet.item_no         
       , purdet.qa              
       , purdet.due_date        
       , purdet.order_qty       
       , purdet.rlse_date       
       , purdet.price           
       , purdet.uom             
       , purdet.rlse_qty      
       , purdet.product_no      
       , purdet.rcpt_loc        
       , purdet.pur_type        
       , purdet.rem             
       , purdet.coil_no         
       , purdet.serial_no       
       , purdet.work_type       
       , purdet.cnt             
       , pur.subcon             
       , groupitem.item_name    
       , rcpt_qty = convert(decimal(15,4),0)   
       , purdet.result_type     
       , purdet.com_qty         
       , chk      = 'N'         
       , purdet.sale_no         
       , purdet.sale_seq        
       , purdet.cust_name       
       , purdet.sale_rem        
       , purdet.color           
       , pur.fob                
       , pur.shipto_addr        
       , pur.curr_code          
       , pur.tax_sign           
       , purdet.unit_qty        
       , purdet.draw_no   
       , purdet.wlen
	  , purdet.supp_coil_no  
       , purdet.com_uom   
       , purdet.ingubun
       , supp.round             
       , etc      = '  '  
	  , (CASE  WHEN groupitem.COIL_GRP = 'A10' THEN 'AL'
				  WHEN groupitem.COIL_GRP = 'A11' THEN 'AL'
				  WHEN groupitem.COIL_GRP = 'A50' THEN 'GI'
				  WHEN groupitem.COIL_GRP = 'A51' THEN 'GI'
	     END ) TYPE
    FROM purdet   
       , pur      
       , supp  
       , groupitem  
   WHERE ( purdet.order_no    = pur.order_no      )   
     AND ( purdet.item_no     = groupitem.item_no )   
     AND ( pur.supp_no        = supp.supp_no      )   
     AND ( ( pur.supp_no    = :arg_supp          ) AND  
           ( pur.po_print   = 'Y'                ) AND  
           ( pur.open_close = 'O'                ) AND  
           ( purdet.result_type not in ('E','C') ) AND  
           ( pur.subcon    <> 'C'                ) 
         )  
     AND ( ( pur.order_no  LIKE :as_area + '%' ) or
           ( :as_area = 'S' AND pur.order_no LIKE 'PUR%')  
         )
" update="purdet" updatewhere=0 updatekeyinplace=no arguments=(("arg_supp", string),("as_area", string))  sort="order_no A seq_no A " )
