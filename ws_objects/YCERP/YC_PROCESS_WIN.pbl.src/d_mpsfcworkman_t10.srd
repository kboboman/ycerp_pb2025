column(band=detail id=2 alignment="0" tabsequence=32766 border="0" color="33554432" x="265" y="8" height="72" width="338" format="[general]" html.valueishtml="0"  name=work_grp visible="1" edit.limit=255 edit.case=any edit.focusrectangle=no edit.autoselect=yes edit.autohscroll=yes edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="0" background.color="1073741824~tif ( getrow() = currentrow(), rgb(254, 252, 175), rgb(255, 255, 255) )" )
