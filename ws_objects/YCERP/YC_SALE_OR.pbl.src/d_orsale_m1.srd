$PBExportComments$판매수주관리 detail(1998/04/02, 정재수)
release 8;
datawindow(units=0 timer_interval=0 color=79219928 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=156 color="536870912" )
summary(height=0 color="553648127" )
footer(height=72 color="8421504" )
detail(height=176 color="536870912" )
table(column=(type=char(14) update=yes updatewhereclause=yes key=yes name=order_no dbname="order_no" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=seq_no dbname="seq_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="qa" initial="null" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa_cust dbname="qa_cust" initial="null" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="uom" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=order_qty dbname="order_qty" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=price dbname="price" initial="0" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=acc_qty dbname="acc_qty" initial="0" )
 column=(type=char(1) update=yes updatewhereclause=yes name=saledet_text dbname="saledet_text" initial="N" )
 column=(type=datetime update=yes updatewhereclause=yes name=rlse_date dbname="rlse_date" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=rlse_qty dbname="rlse_qty" initial="0" )
 column=(type=char(50) update=yes updatewhereclause=yes name=rem dbname="rem" )
 column=(type=datetime update=yes updatewhereclause=yes name=plan_close dbname="plan_close" )
 column=(type=char(60) updatewhereclause=yes name=item_item_name dbname="item_name" )
 column=(type=char(1) updatewhereclause=yes name=yumu dbname="yumu" )
 column=(type=decimal(4) updatewhereclause=yes name=item_price_a dbname="item_price_a" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=sol_qty dbname="sol_qty" initial="0" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=saledet_issue_qty dbname="issue_qty" initial="0" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_plan_qty dbname="plan_qty" )
 column=(type=decimal(0) updatewhereclause=yes name=saledet_amt dbname="amt" )
 column=(type=char(4) update=yes updatewhereclause=yes name=color dbname="color" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=price_be dbname="price_be" initial="0" )
 column=(type=char(12) update=yes updatewhereclause=yes name=saledet_do_rem dbname="do_rem" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=stock_qty dbname="stock_qty" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=price_last dbname="price_last" )
 column=(type=decimal(3) update=yes updatewhereclause=yes name=danjung dbname="danjung" )
 column=(type=decimal(3) update=yes updatewhereclause=yes name=jungrang dbname="jungrang" )
 column=(type=decimal(2) updatewhereclause=yes name=issue_qty dbname="issue_qty" )
 column=(type=char(1) updatewhereclause=yes name=price_date dbname="price_date" )
 column=(type=char(1) updatewhereclause=yes name=ysp_calctype dbname="ysp_calctype" )
 column=(type=char(1) updatewhereclause=yes name=runcmd dbname="runcmd" )
 column=(type=char(1) updatewhereclause=yes name=overtime dbname="overtime" )
 column=(type=decimal(4) updatewhereclause=yes name=mps_orderqty dbname="mps_orderqty" )
 column=(type=char(100) updatewhereclause=yes name=make_area dbname="make_area" )
 retrieve="  SELECT saledet.order_no            
       , saledet.seq_no              
       , saledet.item_no             
       , saledet.qa                  
       , saledet.qa_cust             
       , saledet.uom                 
       , saledet.order_qty           
       , saledet.price               
       , saledet.acc_qty             
       , saledet.saledet_text        
       , saledet.rlse_date           
       , saledet.rlse_qty            
       , saledet.rem
       , isnull(dbo.uf_mpsdet_plan_date(saledet.order_no, saledet.seq_no ), saledet.plan_close) plan_close
/*       , dbo.UF_GetLASTMAKEDATE(saledet.order_no, saledet.seq_no) PLAN_CLOSE*/ /* 조원석 2018.02.09 생산완료 예정으로 명칭변경과 작업지시에서 지시일자 MAX 값을 가져와서 보여줌 */
       , item.item_name
       , yumu    = (case when item.item_name LIKE '%유공%' then 'O' else '' end)
       , item.price_a item_price_a               
       , saledet.sol_qty             
       , saledet.issue_qty           
       , saledet.plan_qty            
       , amt   = 999999999999999     
       , saledet.color        
       , saledet.price_be     
       , saledet.do_rem       
       , saledet.stock_qty    
       , saledet.price_last   
       , saledet.danjung      
       , saledet.jungrang
       , saledet.issue_qty
       , price_date   = '' 
/*       , ysp_calctype = (SELECT ysp_calctype FROM groupitem WHERE groupitem.item_no = saledet.item_no)	*/  /* LEFT JOIN으로 로직 변경 2018.02.09 조원석 */
	  , groupitem.ysp_calctype
/*       , runcmd       = ''
       , overtime     = ''
       , mps_orderqty = 0
*/
	  , runcmd = ( select (CASE WHEN mpsdet.mpsorder_order IS NULL THEN ''
                                  			    WHEN mpsdet.mpsorder_order IS NOT NULL THEN 'Y'
                                  													     END) 
					    from mpsdet where plan_no = dbo.uf_mpsdet(saledet.order_no, saledet.seq_no) )
	  , overtime = dbo.uf_mpsdet_overtime(saledet.order_no, saledet.seq_no )
	  , mps_orderqty  = ( select mpsdet.order_qty
					    from mpsdet where plan_no = dbo.uf_mpsdet(saledet.order_no, saledet.seq_no) )
       , dbo.uf_item_area(saledet.item_no, saledet.qa) make_area
    FROM saledet left outer join item WITH(NOLOCK) on saledet.item_no = item.item_no and saledet.qa = item.qa
/*                             left outer join (
											  /* 조원석 2018.02.09 생산완료 예정으로 명칭변경과 작업지시에서 지시일자 MAX 값을 가져와서 보여줌 */
											 SELECT A.SALE_NO, A.SEQ_NO, A.ITEM_NO, A.QA, MAX(B.ORDER_DATE) PLAN_CLOSE
											   FROM MPSDET A INNER JOIN MPSORDER B ON A.MPSORDER_ORDER = B.ORDER_NO
												 WHERE  A.SALE_NO = :as_order_no
											 GROUP BY A.SALE_NO, A.SEQ_NO, A.ITEM_NO, A.QA

													      /*B.ORDER_DATE PLAN_CLOSE, */
														/*2020-07-16 JOWONSUK 작업지시가 없으면 이전 생산계획일자를 가져오는걸로 수정*/
		                                                    SELECT  A.SALE_NO, 
                                  													           A.SEQ_NO,  
                                                                       A.OPERATION,
                                  														ISNULL(B.ORDER_DATE, max(C.ORDER_DATE)) PLAN_CLOSE, 
                                  													     (CASE WHEN C.mpsorder_order IS NULL THEN ''
                                  																WHEN C.mpsorder_order IS NOT NULL THEN 'Y'
                                  													     END) runcmd,
                                  													 MAX(B.overtime) overtime,  																		/*2018.3.29 수정 조원석 : 기존 B.overtime -> MAX(B.overtime)*/
                                  													 SUM(ISNULL(A.order_qty,0)) ORDER_QTY
                                  											FROM MPSDET A WITH(NOLOCK)  LEFT OUTER JOIN MPSORDER B WITH(NOLOCK) ON A.mpsorder_order = B.ORDER_NO
                                  																			 INNER JOIN (                                                                                                      
                                                    																									  SELECT A.SALE_NO, A.SEQ_NO, A.mpsorder_order, A.OPERATION, C.START_DATE ORDER_DATE
                                                    																										FROM (
                                                                                                        
                                                                                                                                 SELECT A.SALE_NO, A.SEQ_NO, A.mpsorder_order, A.order_no, A.OPERATION
                                                                                                                                FROM MPSDET A INNER JOIN 
                                                                                                                                                                                         (                                                                                    
                                                                                                                                                                                              select SALE_NO, SEQ_NO, DIVISION, MAX(OPERATION) OPERATION
                                                                                                                                                                                              from MPSDET                                                                                     
                                                                                                                                                                                              where SALE_NO = :as_order_no
                                                                                                                                                                                              GROUP BY  SALE_NO, SEQ_NO, DIVISION
                                                                                                                                                                                         )  B ON A.SALE_NO = B.SALE_NO AND A.SEQ_NO = B.SEQ_NO AND A.DIVISION = B.DIVISION AND A.OPERATION = B.OPERATION                                                                                                        
                                                                                                        
                                                                                                                      ) A LEFT OUTER JOIN MPSORDER B WITH(NOLOCK) ON A.mpsorder_order = B.ORDER_NO
                                                                                                                           INNER JOIN MPS C WITH(NOLOCK) ON A.order_no = c.order_no
                                                    																									  WHERE A.SALE_NO = :as_order_no
                                                    																								  
                                  																			   		                     ) C ON A.SALE_NO = C.SALE_NO AND A.SEQ_NO = C.SEQ_NO AND A.OPERATION= C.OPERATION AND A.mpsorder_order= C.mpsorder_order            
                                                                              where A.SALE_NO = :as_order_no                                                                                                   
                                                          										  GROUP BY A.SALE_NO, 
                                                        														 A.SEQ_NO,  
                                                                                     A.OPERATION,
                                                        														 B.ORDER_DATE, 
                                                        														 (CASE WHEN C.mpsorder_order IS NULL THEN ''
                                                        																WHEN C.mpsorder_order IS NOT NULL THEN 'Y'
                                                        													     END)

									    ) B ON saledet.order_no = B.sale_no and saledet.seq_no = B.seq_no
*/
									  left outer join groupitem WITH(NOLOCK) on groupitem.item_no = saledet.item_no
   WHERE ( saledet.order_no = :as_order_no ) 
" update="saledet" updatewhere=0 updatekeyinplace=no arguments=(("as_order_no", string))  sort="seq_no A " )
