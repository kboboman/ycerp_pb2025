event clicked;// 단위변경(M2) 전체 변환
long   ll_row
string ls_uom

if dw_1.object.po_print[1]	= "Y" then 	// 발주번호 확정
	MessageBox("확인", "발주번호 확정시 작업불가 합니다.(확정취소 요망)")
