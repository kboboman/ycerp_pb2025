$PBExportHeader$d_cdsupplier_r.srd
$PBExportComments$거래처별 자재단가리스트(1998/02/10,곽용덕)
release 6;
datawindow(units=0 timer_interval=60000 color=1090519039 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=424 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=item_no dbname="supplier.item_no" )
 column=(type=char(20) updatewhereclause=yes name=supplier_qa dbname="supplier.qa" )
 column=(type=decimal(4) updatewhereclause=yes name=amount dbname="supplier.amount" )
 column=(type=char(30) updatewhereclause=yes name=rem dbname="supplier.rem" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(2) updatewhereclause=yes name=groupitem_uom dbname="groupitem.uom" )
 column=(type=char(10) updatewhereclause=yes name=supplier_supp_no dbname="supplier.supp_no" )
 column=(type=char(30) updatewhereclause=yes name=supp_supp_name dbname="supp.supp_name" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"supplier~" )  TABLE(NAME=~"groupitem~" )  TABLE(NAME=~"supp~" ) COLUMN(NAME=~"supplier.item_no~") COLUMN(NAME=~"supplier.qa~") COLUMN(NAME=~"supplier.amount~") COLUMN(NAME=~"supplier.rem~") COLUMN(NAME=~"groupitem.item_name~") COLUMN(NAME=~"groupitem.uom~") COLUMN(NAME=~"supplier.supp_no~") COLUMN(NAME=~"supp.supp_name~")    JOIN (LEFT=~"supplier.item_no~"    OP =~"=~"RIGHT=~"groupitem.item_no~"    OUTER1 =~"supplier.item_no~" )    JOIN (LEFT=~"supplier.supp_no~"    OP =~"=~"RIGHT=~"supp.supp_no~" )WHERE(    EXP1 =~"supplier.supp_no~"   OP =~"like~"    EXP2 =~":as_supp~" ) ) ARG(NAME = ~"as_supp~" TYPE = string) " arguments=(("as_supp", string))  sort="supp_supp_name A groupitem_item_name A supplier_qa A " )
