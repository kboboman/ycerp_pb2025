$PBExportHeader$d_routetempnew_paint.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no  crosstab.dynamic = yes grid.lines=0 grid.columnmove=no selected.mouse=no )
header[1](height=72 color="536870912" )
header[2](height=72 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=color_name dbname="color_name" )
 column=(type=char(20) updatewhereclause=yes name=item_name1 dbname="item_name1" )
 column=(type=char(20) updatewhereclause=yes name=rem dbname="rem" )
 column=(type=number updatewhereclause=yes name=plan_qty dbname="plan_qty" )
 retrieve="  SELECT wc_no      = (SELECT work_name FROM wc WHERE work_no = routtempnew.wc_no)
       , routtempnew.operation   
       , routtempnew.sale_no   
       , routtempnew.seq_no   
         
       , routtempnew.work_date   
       , routtempnew.plan_flag   
       , routtempnew.process_flag   
       , routtempnew.cust_no   
       , customer.cust_name   
       , routtempnew.scene_code   
       , scene.scene_desc   
       , routtempnew.napgi_date   
       , routtempnew.item_no   
       , item_name1 = (case when routtempnew.item_no = 'NO_ITEM' then 'NO_ITEM' else G1.item_name end)   
       , routtempnew.qa   
       , routtempnew.item_color   
       , color_name = color.color_name   
       , routtempnew.order_qty   
       , routtempnew.assy_item   
       , groupitem.item_name   
       , routtempnew.assy_qa   
       , routtempnew.uom   
       , routtempnew.plan_qty   
       , routtempnew.make_qty   
       , ship_qty  = dbo.uf_getdosumqty(routtempnew.sale_no, routtempnew.seq_no)
       , routtempnew.qpa   
       , routtempnew.reserved_qty   
       , routtempnew.rem   
       , user_name = (SELECT user_name FROM login WHERE user_id = customer.salesman)
    FROM routtempnew   
         LEFT OUTER JOIN groupitem    ON routtempnew.assy_item  = groupitem.item_no
         LEFT OUTER JOIN groupitem G1 ON routtempnew.item_no    = G1.item_no  
         LEFT OUTER JOIN customer     ON routtempnew.cust_no    = customer.cust_no
         LEFT OUTER JOIN scene        ON routtempnew.scene_code = scene.scene_code
         LEFT OUTER JOIN sale         ON routtempnew.sale_no    = sale.order_no
         LEFT OUTER JOIN salepic      ON routtempnew.sale_no    = salepic.order_no
         LEFT OUTER JOIN color        ON routtempnew.item_color = color.color_code
   WHERE ( routtempnew.napgi_date   >= '2013/04/01' )   
     AND ( sale.open_close           = 'O' ) 
     AND ( routtempnew.process_flag <> 'C' ) 
     AND ( routtempnew.work_date    >= DATEadd(year, -1 ,getdate()) ) 
     AND ( sale.order_date          >= DATEadd(year, -1 ,getdate()) ) 
     AND ( routtempnew.plan_flag = 'N'     )
     AND ( routtempnew.area_no   = :as_area)
     AND ( routtempnew.wc_no between 'P00' AND 'P05' )
" arguments=(("as_area", string))  sort="color_name A item_name1 A rem A " )
group(level=1 header.height=0 trailer.height=72 by=("color_name" ) header.color="536870912" trailer.color="12639424" )
group(level=2 header.height=0 trailer.height=72 by=("item_name1" ) header.color="536870912" trailer.color="536870912" )
