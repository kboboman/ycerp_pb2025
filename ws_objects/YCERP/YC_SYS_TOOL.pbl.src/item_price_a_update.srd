 column=(type=char(20) updatewhereclause=yes name=itemcost_qa dbname="itemcost.qa" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"item~" )  TABLE(NAME=~"itemcost~" ) COLUMN(NAME=~"item.item_no~") COLUMN(NAME=~"item.qa~") COLUMN(NAME=~"item.item_name~") COLUMN(NAME=~"item.price_a~") COLUMN(NAME=~"itemcost.price~") COLUMN(NAME=~"itemcost.item_no~") COLUMN(NAME=~"itemcost.qa~")    JOIN (LEFT=~"item.item_no~"    OP =~"=~"RIGHT=~"itemcost.item_no~" )WHERE(    EXP1 =~"item.qa~"   OP =~"like~"    EXP2 =~"rtrim(itemcost.qa)+~~~"%~~~"~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"item.price_a~"   OP =~"<>~"    EXP2 =~"itemcost.price~" ) ) " update="item" updatewhere=0 updatekeyinplace=no )
