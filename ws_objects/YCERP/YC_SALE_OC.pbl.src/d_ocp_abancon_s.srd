release 8;
datawindow(units=0 timer_interval=0 color=79219928 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes key=yes name=aban_no dbname="itemaban.aban_no" )
 column=(type=datetime updatewhereclause=yes name=aban_date dbname="itemaban.aban_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=approve_team dbname="approve_team" )
 column=(type=char(10) update=yes updatewhereclause=yes name=approve_top dbname="approve_top" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="user_id" )
 column=(type=char(10) update=yes updatewhereclause=yes name=area_no dbname="area_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=process_flag dbname="process_flag" values="	Y/	O" )
 column=(type=char(50) updatewhereclause=yes name=rem dbname="itemaban.rem" )
 column=(type=char(1) updatewhereclause=yes name=chk_team dbname="chk_team" values="	Y/	N" )
 retrieve="  SELECT itemaban.aban_no,   
         itemaban.aban_date,   
         approve_team = itemaban.approve_team,   
         approve_top = itemaban.approve_top,   
         user_id = itemaban.user_id,   
         area_no = itemaban.area_no,   
         process_flag = itemaban.process_flag  ,
         itemaban.rem,   
         chk_team = ( case when ( approve_team is null ) or (approve_team = '') then ~"N~" else ~"Y~" end )
    FROM itemaban  
   WHERE itemaban.process_flag = :as_flag    
	  AND (:as_area  = '%' and itemaban.area_no LIKE :as_area 
          OR
          :as_area <> '%' and itemaban.area_no    = :as_area 
         )
" update="itemaban" updatewhere=0 updatekeyinplace=yes arguments=(("as_area", string),("as_flag", string)) )
