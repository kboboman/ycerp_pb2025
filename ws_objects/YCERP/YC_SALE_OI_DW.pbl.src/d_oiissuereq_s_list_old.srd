 column=(type=char(30) updatewhereclause=yes name=ship_flag dbname="ship_flag" )
 column=(type=datetime updatewhereclause=yes name=plan_close dbname="plan_close" )
 column=(type=char(4) updatewhereclause=yes name=saledet_text dbname="saledet_text" )
 column=(type=decimal(2) updatewhereclause=yes name=sol_qty dbname="sol_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=issue_qty dbname="issue_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=plan_qty dbname="plan_qty" )
 column=(type=decimal(8) updatewhereclause=yes name=issue_amt dbname="issue_amt" )
 column=(type=char(10) updatewhereclause=yes name=color_name dbname="color_name" )
 column=(type=char(10) updatewhereclause=yes name=salesname dbname="salesname" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(10) updatewhereclause=yes name=salesman dbname="salesman" )
 column=(type=long updatewhereclause=yes name=req_seq dbname="req_seq" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=char(11) updatewhereclause=yes name=scene_code dbname="scene_code" )
 column=(type=char(10) updatewhereclause=yes name=accept_user dbname="accept_user" )
 column=(type=long updatewhereclause=yes name=wan dbname="wan" values="지방	1/수도권	0/" )
 column=(type=char(8) updatewhereclause=yes name=wan_nm dbname="wan_nm" )
 column=(type=char(16) updatewhereclause=yes name=cat dbname="cat" )
 column=(type=char(50) updatewhereclause=yes name=sale_rem dbname="sale_rem" )
 column=(type=char(6) updatewhereclause=yes name=issue_flag dbname="issue_flag" )
 column=(type=char(10) updatewhereclause=yes name=accept_name dbname="accept_name" )
 column=(type=char(6) updatewhereclause=yes name=confirm_flag dbname="confirm_flag" )
 column=(type=char(60) updatewhereclause=yes name=do_rem dbname="do_rem" )
 column=(type=char(12) updatewhereclause=yes name=req_count dbname="req_count" )
 column=(type=datetime updatewhereclause=yes name=req_sysdate dbname="req_sysdate" )
 column=(type=datetime updatewhereclause=yes name=reqdet_sysdate dbname="reqdet_sysdate" )
 retrieve="  SELECT DISTINCT
         req_flag        = (case when aa.req_flag = 'A' then '출고의뢰'
                                 when aa.req_flag = 'B' then '생산확인'
                                 when aa.req_flag = 'P' then '출고/생산확인'
                                 else ''
                            end)
       , issue_schedule  = (case aa.issue_schedule                                      
                                 when 'A' then '직출'                                   
                                 when 'B' then '생산후직출'                             
                                 when 'C' then '자동작성'                               
                                 when 'D' then '방문'                                   
                                 when 'E' then '외주(시화)'                             
                                 when 'F' then '외주(본사)'                             
                                 when 'G' then '유창강건'                               
                                 when 'H' then '지점이송'                               
                                 when 'I' then '야각도착'                               
                                 when 'J' then '저녁상차'                               
                                 when 'K' then '택배/정기'                              
                                 else           ''                                      
                            end)                                                        
       , order_no        = bb.order_no                                                  
       , seq_no          = bb.seq_no                                                    
       , fit_no          = ee.loc_no
       , item_no         = bb.item_no                                                   
       , item_name       = bb.item_name                                                 
       , qa              = bb.qa                                                        
       , uom             = bb.uom                                                       
       , order_qty       = bb.order_qty                                                 
       , acc_qty         = bb.acc_qty                                                   
       , price           = bb.price                                                     
       , action          = bb.action                                                 
       , stock_qty       = bb.stock_qty                                                 
       , rlse_date       = bb.rlse_date                                                 
       , rlse_qty        = bb.rlse_qty                                                  
       , ship_qty        = dd.ship_qty
       , jan             = bb.jan                                                       
       , plan_amt        = (case when convert(char(10),bb.rlse_date,111) = :as_reqdate then /* 출고일이 당일이면 상차수량 계산 */
                                      bb.price * dbo.uf_getqty(bb.item_no, bb.qa, bb.uom, dd.ship_qty)
                                 else (case when bb.issue_qty > 0 AND bb.rlse_date is null then    /* 미출고는 선정수량으로 계산 */
                                                 bb.price * dbo.uf_getqty(bb.item_no, bb.qa, bb.uom, bb.issue_qty)
                                            else 0
                                       end)
                            end)
       , qoh             = cc.qoh                                                      
       , ship_case       = (case bb.ship_case                                           
                                 when 'J' then '정기화물'                               
                                 when 'T' then '택배'                                   
                                 when 'A' then '오토바이'                               
                                 when 'S' then '선박'                                   
                                 when 'P' then '항공'                                   
                                 when 'E' then '기타'                                   
                                 else          ''                                       
                            end)                                                        
       , ship_flag       = (SELECT name FROM shipflag WHERE flag = bb.ship_flag)        
       , plan_close      = bb.plan_close                                               
       , saledet_text    = bb.saledet_text                                             
       , sol_qty         = bb.sol_qty                                                  
       , issue_qty       = bb.issue_qty                                                
       , plan_qty        = bb.plan_qty                                                 
       , issue_amt       = dbo.uf_getqty(bb.item_no, bb.qa, bb.uom, bb.issue_qty) * bb.price       
       , color_name      = (SELECT color_name FROM color WHERE color_code = bb.color   )
       , salesname       = (SELECT user_name  FROM login WHERE user_id    = bb.salesman)
       , user_name       = (SELECT user_name  FROM login WHERE user_id    = bb.login_id)
       , salesman        = (SELECT user_name  FROM login WHERE user_id    = aa.salesman)    
       , req_seq         = aa.req_seq                                                   
       , cust_name       = bb.cust_name                                                 
       , scene_desc      = bb.scene_desc                                                
       , scene_code      = bb.scene_code                                                
       , accept_user     = aa.accept_user
       , wan             = (case when substring(bb.scene_desc,1,2) IN ('서울','인천','경기','해외') then 0 else 1 end)

       , wan_nm          = (case when substring(bb.scene_desc,1,2) IN ('서울','인천','경기','해외')
                                      AND aa.issue_schedule IN ('A','B','J','I') then '1.수도권'
                                 when substring(bb.scene_desc,1,2) NOT IN ('서울','인천','경기','해외')
                                      AND aa.issue_schedule IN ('A','B','J','I') then '2.지방'
                                 when aa.issue_schedule     IN ('F','E')         then '3.외주'
                                 when aa.issue_schedule     IN ('K')             then '4.택배'
                                 when aa.issue_schedule     IN ('D')             then '5.방문'
                                 when aa.issue_schedule     IN ('G','C')         then '6.기타'
                            end)
       , cat             = bb.cust_no + bb.scene_code + aa.issue_schedule
       , sale_rem        = bb.rem                                                       
                                                                                        
       , issue_flag      = (case aa.issue_flag                                          
                                 when 'A' then '전량'                                   
                                 when 'P' then '부분'                                   
                                 when 'R' then '잔여분'                                 
                                 else          ''                                       
                            end)                                                        
       , accept_name     = (SELECT user_name FROM login WHERE user_id = aa.accept_user) 
       , confirm_flag    = (case aa.confirm_flag                                        
                                 when 'Y' then '확정'                                   
                                 when 'N' then '미확정'                                 
                                 else          ''                                       
                            end)                                                        
       , do_rem          = aa.orem                                                      
       , req_count       = bb.scene_code + aa.issue_schedule
       , req_sysdate     = aa.req_sysdate                                               
       , reqdet_sysdate  = aa.reqdet_sysdate                                            
  FROM (                                                                                
            SELECT req_date       = a.req_date                                          
                 , salesman       = a.salesman                                          
                 , req_seq        = a.req_seq
                 , accept_area    = a.accept_area                                       
                 , req_flag       = b.req_flag
                 , sale_no        = b.sale_no                                           
                 , issue_flag     = b.issue_flag                                        
                 , issue_schedule = b.issue_schedule                                    
                 , accept_user    = a.accept_user                                       
                 , confirm_flag   = a.confirm_flag                                      
                 , req_text       = a.req_text                                          
                 , rem            = isnull(a.rem,'')                                    
                 , orem           = b.rem                                               
                 , req_sysdate    = a.sys_date                                          
                 , reqdet_sysdate = b.sys_date                                          
              FROM issuereq   A with (nolock)                                           
                   LEFT OUTER JOIN issuereqdet   B with (nolock)
                     ON a.req_date  = b.req_date                                        
                    AND a.salesman  = b.salesman                                        
                    AND a.req_seq   = b.req_seq                                         
             WHERE a.req_date     = :as_reqdate + ' 00:00:00'
       ) AA

       LEFT OUTER JOIN (                                                                
            SELECT order_no     = a.order_no                                            
                 , seq_no       = a.seq_no                                              
                 , item_no      = a.item_no                                             
                 , item_name    = d.item_name                                           
                 , qa           = a.qa                                                  
                 , qa19         = substring(a.qa, 1,13) + 'X00000'                      
                 , order_qty    = a.order_qty                                           
                 , acc_qty      = a.acc_qty                                             
                 , uom          = a.uom                                                 
                 , price        = a.price                                               
                 , stock_qty    = a.stock_qty                                           
                 , rlse_date    = a.rlse_date                                           
                 , rlse_qty     = a.rlse_qty                                            
                 , jan          = (a.order_qty - a.stock_qty - a.rlse_qty)              
                 , plan_close   = a.plan_close                                          
                 , saledet_text = (case a.saledet_text                                  
                                        when 'X' then '가능'                            
                                        when 'N' then '불가'                            
                                        else (case when a.sol_qty > 0 then '부분' else '생산' end)
                                   end)                                                 
                 , rem          = isnull(a.rem,'')                                      
                 , sol_qty      = a.sol_qty                                             
                 , action       = a.action                                              
                 , issue_qty    = a.issue_qty                                           
                 , plan_qty     = a.plan_qty                                            
                 , amt          = (acc_qty * a.price)                                   
                 , color        = a.color                                               
                 , salesman     = c.salesman                                            
                 , login_id     = b.login_id                                            
                 , ship_flag    = b.ship_flag                                           
                 , ship_case    = b.ship_case                                           
                 , cust_no      = c.cust_no                                             
                 , cust_name    = c.cust_name                                           
                 , scene_desc   = e.scene_desc /*dbo.uf_getscenename(a.order_no)*/
                 , scene_code   = b.scene_code
              FROM saledet    A with (nolock)
                   LEFT OUTER JOIN sale      B with (nolock) ON a.order_no = b.order_no
                   LEFT OUTER JOIN groupitem D with (nolock) ON a.item_no  = d.item_no
                   LEFT OUTER JOIN customer  C with (nolock) ON b.cust_no  = c.cust_no
                   LEFT OUTER JOIN scene     E with (nolock) ON b.scene_code = e.scene_code
             WHERE a.order_no IN ( SELECT sale_no        = b.sale_no                                           
                                     FROM issuereq   A with (nolock)                                           
                                          LEFT OUTER JOIN issuereqdet   B with (nolock)
                                            ON a.req_date  = b.req_date AND a.salesman  = b.salesman AND a.req_seq   = b.req_seq                                         
                                    WHERE a.req_date  = :as_reqdate + ' 00:00:00'
                                 )
               AND ((:as_inside  = 'N') OR
                    (:as_inside <> 'N') AND (c.salesman <> 'killby')
                   )
       ) BB ON aa.sale_no = bb.order_no                                                
                                                                                        
       LEFT OUTER JOIN itemloc      CC ON bb.item_no = cc.item_no AND bb.qa   = cc.qa AND cc.loc_no  = :as_location
       LEFT OUTER JOIN (
            SELECT a.do_no, a.sale_no, a.seq_no, a.ship_qty, a.price, b.do_date
              FROM dodet  A
                   LEFT OUTER JOIN do  B ON a.do_no = b.do_no
             WHERE b.do_date  = :as_reqdate + ' 00:00:00.000'
       ) DD  ON bb.order_no = dd.sale_no AND bb.seq_no = dd.seq_no

       LEFT OUTER JOIN item_fitting EE ON bb.item_no = ee.item_no AND bb.qa19 = ee.qa AND ee.area_no = :as_area
  WHERE ((:as_area       = '%' AND aa.accept_area LIKE :as_area    ) OR
         (:as_area      <> '%' AND aa.accept_area    = :as_area    )
        )
    AND ((:as_location   = '%' AND aa.accept_user LIKE :as_location) OR
         (:as_location  <> '%' AND aa.accept_user    = :as_location)
        )
    AND ((:as_salesman   = '%' AND aa.salesman    LIKE :as_salesman) OR
         (:as_salesman  <> '%' AND aa.salesman       = :as_salesman)
        )
    AND ( aa.req_date    = :as_reqdate + ' 00:00:00' )
  ORDER BY aa.salesman, aa.req_seq, bb.order_no, bb.seq_no 
" arguments=(("as_area", string),("as_location", string),("as_salesman", string),("as_reqdate", string),("as_inside", string))  sort="req_flag D wan_nm A salesman A req_seq A order_no A seq_no A " )
group(level=1 header.height=0 trailer.height=72 by=("item_no" , "qa" ) header.color="536870912" trailer.color="536870912" )
