 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"do~" )  TABLE(NAME=~"customer~" )  TABLE(NAME=~"scene~" ) COLUMN(NAME=~"do.do_no~") COLUMN(NAME=~"do.cust_no~") COLUMN(NAME=~"do.spot_code~") COLUMN(NAME=~"do.do_date~") COLUMN(NAME=~"do.invoice_print~") COLUMN(NAME=~"do.curr_code~") COLUMN(NAME=~"do.curr_rate~") COLUMN(NAME=~"do.fob~") COLUMN(NAME=~"do.ship_flag~") COLUMN(NAME=~"do.ship_amount~") COLUMN(NAME=~"do.shipto_addr~") COLUMN(NAME=~"do.do_cash~") COLUMN(NAME=~"do.do_rate~") COLUMN(NAME=~"do.do_total~") COLUMN(NAME=~"do.rem~") COLUMN(NAME=~"do.do_flag~") COLUMN(NAME=~"do.sale_flag~") COMPUTE(NAME=~"' 'do_chk~") COLUMN(NAME=~"do.tel_no~") COLUMN(NAME=~"do.driver~") COLUMN(NAME=~"do.do_case~") COLUMN(NAME=~"customer.cust_name~") COLUMN(NAME=~"scene.scene_desc~") COLUMN(NAME=~"do.user_id~") COLUMN(NAME=~"do.shipamt_case~") COLUMN(NAME=~"do.dr_hp~") COLUMN(NAME=~"do.ship_date~") COLUMN(NAME=~"do.ship_close~") COLUMN(NAME=~"do.area_no~") COLUMN(NAME=~"do.issue_date~")    JOIN (LEFT=~"do.cust_no~"    OP =~"=~"RIGHT=~"customer.cust_no~"    OUTER1 =~"do.cust_no~" )    JOIN (LEFT=~"do.spot_code~"    OP =~"=~"RIGHT=~"scene.scene_code~"    OUTER1 =~"do.spot_code~" )) " update="do" updatewhere=1 updatekeyinplace=no )
