 retrieve="  SELECT cust_aim.cust_code,   
         cust_aim.tar_year,   
         cust_aim.inv_01,   
         cust_aim.inv_02,   
         cust_aim.inv_03,   
         cust_aim.inv_04,   
         cust_aim.inv_05,   
         cust_aim.inv_06,   
         cust_aim.inv_07,   
         cust_aim.inv_08,   
         cust_aim.inv_09,   
         cust_aim.inv_10,   
         cust_aim.inv_11,   
         cust_aim.inv_12,   
         cust_aim.coll_01,   
         cust_aim.coll_02,   
         cust_aim.coll_03,   
         cust_aim.coll_04,   
         cust_aim.coll_05,   
         cust_aim.coll_06,   
         cust_aim.coll_07,   
         cust_aim.coll_08,   
         cust_aim.coll_09,   
         cust_aim.coll_10,   
         cust_aim.coll_11,   
         cust_aim.coll_12,   
         opeom.inv_01,   
         opeom.inv_02,   
         opeom.inv_03,   
         opeom.inv_04,   
         opeom.inv_05,   
         opeom.inv_06,   
         opeom.inv_07,   
         opeom.inv_08,   
         opeom.inv_09,   
         opeom.inv_10,   
         opeom.inv_11,   
         opeom.inv_12,   
         opeom.coll_01,   
         opeom.coll_02,   
         opeom.coll_03,   
         opeom.coll_04,   
         opeom.coll_05,   
         opeom.coll_06,   
         opeom.coll_07,   
         opeom.coll_08,   
         opeom.coll_09,   
         opeom.coll_10,   
         opeom.coll_11,   
         opeom.coll_12,   
         opeom.balbf_amount,   
         cust_aim.mod_01,   
         cust_aim.mod_02,   
         cust_aim.mod_03,   
         cust_aim.mod_04,   
         cust_aim.mod_05,   
         cust_aim.mod_06,   
         cust_aim.mod_07,   
         cust_aim.mod_08,   
         cust_aim.mod_09,   
         cust_aim.mod_10,   
         cust_aim.mod_11,   
         cust_aim.mod_12,   
         cust_aim.del_01,   
         cust_aim.del_02,   
         cust_aim.del_03,   
         cust_aim.del_04,   
         cust_aim.del_05,   
         cust_aim.del_06,   
         cust_aim.del_07,   
         cust_aim.del_08,   
         cust_aim.del_09,   
         cust_aim.del_10,   
         cust_aim.del_11,   
         cust_aim.del_12  
    FROM cust_aim left outer join    
		      opeom  on cust_aim.cust_code = opeom.cust_no and datepart(year,cust_aim.tar_year) = datepart(year, opeom.eom_year)
   WHERE  (cust_aim.cust_code = :cust_no AND  
       			  datepart(year,cust_aim.tar_year) = :ad_date) 
/*
    FROM cust_aim,   
         opeom  
   WHERE ( cust_aim.cust_code *= opeom.cust_no) and  
         (cust_aim.cust_code = :cust_no AND  
         datepart(year,cust_aim.tar_year) = :ad_date) AND  
         datepart(year,cust_aim.tar_year) *= datepart(year, opeom.eom_year)     
*/
" update="cust_aim" updatewhere=0 updatekeyinplace=no arguments=(("cust_no", string),("ad_date", number)) )
