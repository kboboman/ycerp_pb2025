detail(height=360 color="536870912" )
table(column=(type=char(255) updatewhereclause=yes name=outamt dbname="OUTAMT" )
 column=(type=char(255) updatewhereclause=yes name=ceo_his dbname="ceo_his" )
 column=(type=char(255) updatewhereclause=yes name=com_char dbname="com_char" )
 column=(type=char(255) updatewhereclause=yes name=dambo_bigo dbname="customer.dambo_bigo" )
 retrieve="SELECT 
			/* (
						SELECT substring(A.BIGO,1, 2000)
						 FROM CUSTOMER_BASE A INNER JOIN  (
																																	SELECT CUST_NO, ITEM_CD, SORT, MAX(SEQ) SEQ
																																	FROM CUSTOMER_BASE
																																	WHERE CUST_NO = customer.cust_no
																																	GROUP BY CUST_NO, ITEM_CD, SORT
																														 ) B 
																														ON A.CUST_NO = B.CUST_NO AND A.ITEM_CD = B.ITEM_CD AND A.SORT = B.SORT AND A.SEQ = B.SEQ
																						  INNER JOIN CODEMST C ON A.SORT = C.SORT AND C.BIGO LIKE '%(여신관리항목)%'
						  WHERE A.CUST_NO = customer.cust_no
								AND  A.SORT = '116'     
			 ) outamt
			*/
			   CUSTOMER.OUTAMT
     , ceo_his  = /* rtrim(customer.captain_name) + ' ' +  substring(convert(char(6), customer.cap_birthday, 112),1,4)+'.'+substring(convert(char(6), customer.cap_birthday, 112),5,2) +' 만('+  convert(char(2), datediff( month, customer.cap_birthday, getdate()) / 12) + ')세 / '
       +  */
       (
               SELECT replace(replace( substring(A.BIGO,1, 2000), char(13), ' ' ), char(10), ' ')
                FROM CUSTOMER_BASE A INNER JOIN  (
  																							SELECT A.CUST_NO, A.ITEM_CD, A.SORT, A.INPUT_DATE, MAX(SEQ) SEQ
																							 FROM CUSTOMER_BASE A INNER JOIN
																							 (
																								SELECT CUST_NO, ITEM_CD, SORT, MAX(input_date) input_date
																								FROM CUSTOMER_BASE
																								WHERE CUST_NO = customer.cust_no
																								GROUP BY CUST_NO, ITEM_CD, SORT
																							  ) B ON A.CUST_NO = B.CUST_NO AND A.ITEM_CD = B.ITEM_CD AND A.SORT = B.SORT AND A.input_date = B.input_date
																							  GROUP BY A.CUST_NO, A.ITEM_CD, A.SORT, A.INPUT_DATE
                                                                                        ) B 
                                                                                       ON A.CUST_NO = B.CUST_NO AND A.ITEM_CD = B.ITEM_CD AND A.SORT = B.SORT AND A.input_date = B.input_date AND A.SEQ = B.SEQ
                                                                 INNER JOIN CODEMST C ON A.SORT = C.SORT AND C.BIGO LIKE '%(여신관리항목)%'
                 WHERE A.CUST_NO = customer.cust_no
                     AND  A.SORT = '108'     
          ) 
      ,  (
               SELECT substring(A.BIGO,1, 2000)
                FROM CUSTOMER_BASE A INNER JOIN  (
  																							SELECT A.CUST_NO, A.ITEM_CD, A.SORT, A.INPUT_DATE, MAX(SEQ) SEQ
																							 FROM CUSTOMER_BASE A INNER JOIN
																							 (
																								SELECT CUST_NO, ITEM_CD, SORT, MAX(input_date) input_date
																								FROM CUSTOMER_BASE
																								WHERE CUST_NO = customer.cust_no
																								GROUP BY CUST_NO, ITEM_CD, SORT
																							  ) B ON A.CUST_NO = B.CUST_NO AND A.ITEM_CD = B.ITEM_CD AND A.SORT = B.SORT AND A.input_date = B.input_date
																							  GROUP BY A.CUST_NO, A.ITEM_CD, A.SORT, A.INPUT_DATE
                                                                                        ) B 
                                                                                       ON A.CUST_NO = B.CUST_NO AND A.ITEM_CD = B.ITEM_CD AND A.SORT = B.SORT AND A.input_date = B.input_date AND A.SEQ = B.SEQ
                                                                 INNER JOIN CODEMST C ON A.SORT = C.SORT AND C.BIGO LIKE '%(여신관리항목)%'
                 WHERE A.CUST_NO = customer.cust_no
                     AND  A.SORT = '117'     
          ) com_char
        , dambo_bigo
  FROM customer
 WHERE cust_no = :as_cust_no
" arguments=(("as_cust_no", string)) )
