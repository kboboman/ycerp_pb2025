table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=qa dbname="qa" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=seq_no dbname="seq_no" initial="0" )
 column=(type=char(10) update=yes updatewhereclause=yes name=coil_item dbname="coil_item" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=thick dbname="thick" initial="0.00" )
