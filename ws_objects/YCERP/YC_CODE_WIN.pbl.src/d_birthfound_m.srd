detail(height=80 color="536870912" )
table(column=(type=long update=yes updatewhereclause=yes key=yes identity=yes name=id dbname="customer_birthfound.ID" )
 column=(type=char(10) update=yes updatewhereclause=yes name=cust_no dbname="customer_birthfound.cust_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=birthday_yn dbname="customer_birthfound.birthday_yn" values="	Y/	N" )
 column=(type=datetime update=yes updatewhereclause=yes name=birth_found dbname="customer_birthfound.birth_found" )
 column=(type=char(1) update=yes updatewhereclause=yes name=sol_lun dbname="customer_birthfound.sol_lun" values="	Y/	N" )
 column=(type=long update=yes updatewhereclause=yes name=mm dbname="customer_birthfound.mm" )
 column=(type=long update=yes updatewhereclause=yes name=dd dbname="customer_birthfound.dd" )
 column=(type=char(10) update=yes updatewhereclause=yes name=birth_name dbname="customer_birthfound.birth_name" )
 column=(type=char(10) update=yes updatewhereclause=yes name=position_name dbname="customer_birthfound.position_name" )
 column=(type=char(10) updatewhereclause=yes name=login_salesman_name dbname="login.salesman_name" )
 column=(type=char(50) updatewhereclause=yes name=gift dbname="customer_birthfound.gift" )
 column=(type=char(50) updatewhereclause=yes name=bigo dbname="customer_birthfound.bigo" )
 column=(type=datetime updatewhereclause=yes name=lun_date dbname="lun_date" )
 retrieve="  SELECT customer_birthfound.ID   
       , customer_birthfound.cust_no   
       , customer_birthfound.birthday_yn   
       , customer_birthfound.birth_found   
       , customer_birthfound.sol_lun
       , customer_birthfound.mm   
       , customer_birthfound.dd   
       , customer_birthfound.birth_name   
       , customer_birthfound.position_name   
       , login.user_name salesman_name
       , customer_birthfound.gift
       , customer_birthfound.bigo
       , lun_date  = (case when customer_birthfound.sol_lun = 'Y'
                               then (SELECT lunar_date FROM lunar2solar WHERE solar_date = customer_birthfound.birth_found)
                               else customer_birthfound.birth_found
                            end)
    FROM customer_birthfound  left outer join customer on customer_birthfound.cust_no = customer.cust_no  
                                                    left outer join login on customer.salesman = login.user_id
   WHERE customer.salesman like :as_user_id and
        ( (:as_birthday   = '%' AND customer_birthfound.birthday_yn  LIKE :as_birthday) OR
          (:as_birthday  <> '%' AND customer_birthfound.birthday_yn     = :as_birthday)
         )" update="customer_birthfound" updatewhere=0 updatekeyinplace=no arguments=(("as_birthday", string),("as_user_id", string)) )
