$PBExportHeader$d_iractio_r2.srd
$PBExportComments$실사차이보고서(2000/09/02,이인호)
release 8;
datawindow(units=0 timer_interval=60000 color=1090519039 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=320 color="536870912" )
summary(height=88 color="536870912" )
footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=itemloc_item_no dbname="item_no" )
 column=(type=char(20) updatewhereclause=yes name=itemloc_qa dbname="qa" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=char(2) updatewhereclause=yes name=groupitem_uom dbname="uom" )
 column=(type=char(30) updatewhereclause=yes name=itemloc_loc_name dbname="loc_name" )
 column=(type=char(26) updatewhereclause=yes name=title dbname="title" )
 column=(type=decimal(4) updatewhereclause=yes name=ineoym_qoh dbname="qoh" )
 column=(type=decimal(2) updatewhereclause=yes name=eom_qoh dbname="eom_qoh" )
 column=(type=decimal(2) updatewhereclause=yes name=def_qty dbname="def_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=issue dbname="issue" )
 column=(type=decimal(6) updatewhereclause=yes name=irete dbname="irete" )
 retrieve="SELECT item_no,   
		qa,   
		item_name,   
		uom,
		loc_name,
		title,
		qoh = isnull(SUM(qoh),0),   
		eom_qoh = isnull(SUM(cineoym.eom_qoh),0) + (isnull(SUM(cineoym.rcpt_qty),0) - isnull(SUM(cineoym.issue_qty),0)) - isnull(SUM(cineoym.def_qty),0),   
		def_qty = isnull(SUM(cineoym.def_qty),0),
		issue = SUM(cineoym.issue_qty),
		irete = abs(isnull(SUM(cineoym.def_qty),0) / case when SUM(cineoym.issue_qty) is null or SUM(cineoym.issue_qty) = 0 then isnull(SUM(cineoym.def_qty),0) else isnull(SUM(cineoym.issue_qty),0) end)
	FROM
			(  SELECT ineoym.item_no,   
						ineoym.qa,   
						groupitem.item_name,   
						qoh = ineoym.qoh,   
						uom = dbo.uf_getuom(groupitem.uom),   
						rcpt_qty = ineoym.rcpt_qty,
						issue_qty = ineoym.issue_qty,
						eom_qoh = 0,
						def_qty = 0,
						loc_name,
						title =  convert(char(4),:as_year) + ~"년 ~" + convert(char(2), :as_mon) + ~"월 실사차이보고서~"
				 FROM ineoym,   
						groupitem,
						location 
				WHERE ( ineoym.item_no = groupitem.item_no ) and  
						( use_flag <> 'C' ) and 
						( ineoym.loc_no = location.loc_no) and 
						( ( ineoym.loc_no = :as_loc ) AND  
						( ineoym.cyear = :as_year ) AND  
						( ineoym.cmon = :as_mon ) AND 
						( left(ineoym.item_no, 2) <> ~"M1~" AND left(ineoym.item_no, 2) <> ~"M3~") AND
						( ineoym.item_no like :as_item AND  
						groupitem.item_name like :as_name) )    
			union all
			  SELECT ineoym.item_no,   
						ineoym.qa,   
						groupitem.item_name,   
						qoh = 0,   
						uom = dbo.uf_getuom(groupitem.uom),   
						rcpt_qty = 0,
						issue_qty = 0,
						eom_qoh = ineoym.qoh,
						def_qty = 0,
						loc_name,
						title =  convert(char(4),:as_year) + ~"년 ~" + convert(char(2), :as_mon) + ~"월 실사차이보고서~"
				 FROM ineoym,   
						groupitem,
						location 
				WHERE ( ineoym.item_no = groupitem.item_no ) and  
						( use_flag <> 'C' ) and 
						( ineoym.loc_no = location.loc_no) and  
						( ( ineoym.loc_no = :as_loc ) AND  
						( ineoym.cyear = :as_pyear ) AND  
						( ineoym.cmon = :as_pmon ) AND  
						( left(ineoym.item_no, 2) <> ~"M1~" AND left(ineoym.item_no, 2) <> ~"M3~") AND
						( ineoym.item_no like :as_item AND  
						groupitem.item_name like :as_name) )          
			union all
			  SELECT item_no = inaudit.inaudit_item,   
						inaudit.qa,   
						groupitem.item_name,   
						qoh = 0,   
						uom = dbo.uf_getuom(groupitem.uom),   
						rcpt_qty = 0,
						issue_qty = 0,
						eom_qoh = 0,
						def_qty = (inaudit.rcpt_qty - inaudit.issue_qty),
						loc_name,
						title =  convert(char(4),:as_year) + ~"년 ~" + convert(char(2), :as_mon) + ~"월 실사차이보고서~"
				 FROM inaudit,   
						location,
						groupitem  
				WHERE ( ( DATEPART(year, inaudit.inaudit_date) = :as_year ) AND  
						( DATEPART(month, inaudit.inaudit_date) = :as_mon )  ) AND  
						( inaudit.inaudit_type in ('RX', 'IX')  ) AND  
						( left(inaudit.inaudit_item, 2) <> ~"M1~" AND left(inaudit.inaudit_item, 2) <> ~"M3~") AND
						( inaudit.inaudit_item like :as_item ) AND  
						( inaudit.loc_no = :as_loc ) and  
						( inaudit.loc_no = location.loc_no ) and  
						( inaudit.inaudit_item = groupitem.item_no ) and  
						( use_flag <> 'C' ) and 
						( groupitem.item_name like :as_name) ) cineoym 
where item_no < 'PZZZ'
GROUP BY item_no,   
		qa,   
		item_name,   
		uom,
		loc_name,
		title" arguments=(("as_loc", string),("as_year", string),("as_mon", string),("as_item", string),("as_name", string),("as_pyear", string),("as_pmon", string)) )
