 column=(type=decimal(4) update=yes updatewhereclause=yes name=sfcuse_mod_qty dbname="sfcuse.mod_qty" initial="0" )
 column=(type=char(1) update=yes updatewhereclause=yes name=sfcuse_division dbname="sfcuse.division" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=sfcuse_mod_len dbname="sfcuse.mod_len" initial="0" )
 column=(type=long update=yes updatewhereclause=yes name=sfcuse_seq dbname="sfcuse.seq" )
 column=(type=long updatewhereclause=yes name=qcnt dbname="qcnt" )
 column=(type=decimal(1) update=yes updatewhereclause=yes name=sfcuse_wid dbname="sfcuse.wid" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=rem_qty dbname="sfcuse.rem_qty" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=rem_len dbname="sfcuse.rem_len" initial="0" )
 column=(type=char(20) update=yes updatewhereclause=yes name=rem_lot dbname="sfcuse.rem_lot" )
 column=(type=char(20) update=yes updatewhereclause=yes name=rem_qa dbname="sfcuse.rem_qa" )
 column=(type=long update=yes updatewhereclause=yes name=rem_cnt dbname="sfcuse.rem_cnt" )
 column=(type=char(2) updatewhereclause=yes name=etc_no dbname="etc_no" )
 column=(type=long updatewhereclause=yes name=seq dbname="sfcuse.seq" )
 column=(type=char(10) update=yes updatewhereclause=yes name=area_no dbname="sfcuse.area_no" )
 retrieve="  SELECT groupitem.item_name   
       , sfcuse.order_no   
       , sfcuse.wc_no   
       , sfcuse.use_date   
       , sfcuse.item_no   
       , sfcuse.qa   
       , sfcuse.uom   
       , sfcuse.use_qty   
       , sfcuse.coil_no   
       , sfcuse.color   
       , sfcuse.color_type   
       , sfcuse.loc_no   
       , sfcuse.coil_type   
       , sfcuse.cnt   
       , sfcuse.unit_qty   
       , sfcuse.mod_qty   
       , sfcuse.division   
       , sfcuse.mod_len   
       , sfcuse.seq   
       , qcnt   = 0   
       , sfcuse.wid   
       , sfcuse.rem_qty   
       , sfcuse.rem_len   
       , sfcuse.rem_lot   
       , sfcuse.rem_qa   
       , sfcuse.rem_cnt   
       , etc_no = '  '
       , seq
       , area_no  
    FROM sfcuse   
       , groupitem  
/*   WHERE ( sfcuse.item_no    = groupitem.item_no ) 
     AND ( ( sfcuse.wc_no    = :arg_wc   ) AND  
                ( sfcuse.use_date = :arg_date ) )
*/
   WHERE ( sfcuse.item_no    = groupitem.item_no ) 
     AND ( ( sfcuse.wc_no    = :arg_wc   ) AND  
                /*( convert(datetime, convert(char(10),sfcuse.use_date,121) + ' 00:00:00') = :arg_date ) */
			   ( sfcuse.use_date      BETWEEN convert(datetime,  :arg_date +' 00:00:00' ) and convert(datetime,  :arg_date + ' 23:59:59' ) )
              )" update="sfcuse" updatewhere=0 updatekeyinplace=no arguments=(("arg_wc", string),("arg_date", date))  sort="seq A " )
