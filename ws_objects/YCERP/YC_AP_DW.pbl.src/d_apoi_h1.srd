$PBExportHeader$d_apoi_h1.srd
$PBExportComments$자재매입관리 insp TABLE UPDATE용 DATAWINDOW(1999/05/21, 이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=68 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes key=yes name=insp_no dbname="insp.insp_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=invoice_print dbname="insp.invoice_print" )
 column=(type=char(1) update=yes updatewhereclause=yes name=insp_flag dbname="insp.insp_flag" )
 retrieve="  SELECT DISTINCT insp.insp_no,   
         insp.invoice_print,   
         insp.insp_flag  
    FROM insp,   
         inspdet  
   WHERE ( insp.insp_no = inspdet.insp_no ) and  
         ( ( insp.supp_no = :as_supp ) AND  
         ( insp.insp_date >= :ad_sdate ) AND  
         ( insp.insp_date <= :ad_edate ) AND  
         ( inspdet.rcpt_qty <> inspdet.apoi_qty )  AND  
         ( ( insp.area_no like :as_area + ~"%~" ) or
			  ( :as_area = 'S' and inspdet.pur_no like 'PUR%') or
			  ( :as_area = 'B' and insp.area_no like 'C%')))  and
			( insp.insp_flag = :as_flag )    
    
" update="insp" updatewhere=0 updatekeyinplace=yes arguments=(("as_supp", string),("ad_sdate", date),("ad_edate", date),("as_area", string),("as_flag", string)) )
column(band=detail id=1 alignment="0" tabsequence=32766 border="2" color="0" x="9" y="4" height="56" width="448" format="[general]" html.valueishtml="0"  name=insp_no visible="1" edit.limit=0 edit.case=any edit.autoselect=yes edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="2" font.pitch="2" font.charset="129" background.mode="2" background.color="16777215" )
column(band=detail id=2 alignment="0" tabsequence=32766 border="2" color="0" x="471" y="4" height="56" width="133" format="[general]" html.valueishtml="0"  name=invoice_print visible="1" edit.limit=0 edit.case=any edit.autoselect=yes edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="2" font.pitch="2" font.charset="129" background.mode="2" background.color="16777215" )
column(band=detail id=3 alignment="0" tabsequence=32766 border="2" color="0" x="617" y="4" height="56" width="91" format="[general]" html.valueishtml="0"  name=insp_flag visible="1" edit.limit=0 edit.case=any edit.autoselect=yes edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="2" font.pitch="2" font.charset="129" background.mode="2" background.color="16777215" )
htmltable(border="1" )
