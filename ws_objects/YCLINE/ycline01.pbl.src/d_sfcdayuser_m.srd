footer(height=92 color="8421504" )
detail(height=92 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=sfcdayuser_area_no dbname="sfcdayuser.area_no" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=sfcdayuser_wc_no dbname="sfcdayuser.wc_no" )
 column=(type=datetime update=yes updatewhereclause=yes key=yes name=sfcdayuser_sfc_date dbname="sfcdayuser.sfc_date" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=sfcdayuser_user_id dbname="sfcdayuser.user_id" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="login.user_name" )
 column=(type=char(30) updatewhereclause=yes name=team_name dbname="team.team_name" )
 retrieve="  SELECT sfcdayuser.area_no
       , sfcdayuser.wc_no
       , sfcdayuser.sfc_date
       , sfcdayuser.user_id
       , login.user_name  
       , team.team_name
    FROM sfcdayuser
         LEFT OUTER JOIN login  ON sfcdayuser.user_id = login.user_id
         LEFT OUTER JOIN team   ON login.team_code    = team.team_code
   WHERE ( sfcdayuser.area_no  = :as_area ) 
     AND ( sfcdayuser.sfc_date = :ad_date ) 
     AND ((:as_wc   = '%' AND sfcdayuser.wc_no  LIKE :as_wc) OR
          (:as_wc  <> '%' AND sfcdayuser.wc_no     = :as_wc)
         )

" update="sfcdayuser" updatewhere=0 updatekeyinplace=no arguments=(("as_area", string),("as_wc", string),("ad_date", date)) )
