table(column=(type=char(14) updatewhereclause=yes name=order_no dbname="order_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="seq_no" )
 column=(type=char(10) updatewhereclause=yes name=porder_no dbname="porder_no" )
 column=(type=long updatewhereclause=yes name=porder_seq dbname="porder_seq" )
 column=(type=char(14) updatewhereclause=yes name=insp_no dbname="insp_no" )
 column=(type=long updatewhereclause=yes name=oi_no dbname="oi_no" )
 column=(type=datetime updatewhereclause=yes name=insp_date dbname="insp_date" )
 column=(type=decimal(2) updatewhereclause=yes name=rcpt_qty dbname="rcpt_qty" )
 column=(type=datetime updatewhereclause=yes name=log_date dbname="log_date" )
 column=(type=char(30) updatewhereclause=yes name=supp_name dbname="supp_name" )
 column=(type=char(15) updatewhereclause=yes name=shipto_tel dbname="shipto_tel" )
 column=(type=char(255) updatewhereclause=yes name=cham dbname="cham" )
 column=(type=char(1) updatewhereclause=yes name=po_print dbname="po_print" )
 column=(type=datetime updatewhereclause=yes name=sys_date dbname="sys_date" )
 retrieve="  SELECT order_no     = s.order_no    
       , seq_no       = s.seq_no      
       , porder_no    = pd.order_no   
       , porder_seq   = pd.sale_seq   
       , insp_no      = ip.insp_no    
       , oi_no        = ip.oi_no      
       , insp_date    = i.insp_date   
       , rcpt_qty     = ip.rcpt_qty   
       , log_date     = i.log_date    
       , supp_name    = sp.supp_name  
       , shipto_tel   = p.shipto_tel  
       , cham         = p.cham        
       , po_print     = p.po_print  
       , sys_date     = p.sys_date  
    FROM saledet s  ( nolock )
         LEFT OUTER JOIN purdet  pd ( nolock ) ON s.order_no  = pd.sale_no  AND s.seq_no = pd.sale_seq
         LEFT OUTER JOIN pur     p  ( nolock ) ON pd.order_no = p.order_no
         LEFT OUTER JOIN inspdet ip ( nolock ) ON p.order_no  = ip.pur_no   AND pd.item_no = ip.item_no AND pd.qa = ip.qa /*AND pd.order_qty = ip.rcpt_qty*/
         LEFT OUTER JOIN insp    i  ( nolock ) ON i.insp_no   = ip.insp_no 
         LEFT OUTER JOIN supp    sp ( nolock ) ON p.supp_no   = sp.supp_no
   WHERE s.order_no    = :as_orderno
   ORDER BY seq_no, porder_no
" arguments=(("as_orderno", string)) )
