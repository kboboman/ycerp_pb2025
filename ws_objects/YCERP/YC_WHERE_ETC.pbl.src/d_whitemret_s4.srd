text(band=header alignment="1" text="저장소이동" border="0" color="33554432" x="5536" y="424" height="60" width="370" html.valueishtml="0"  name=t_16 visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
