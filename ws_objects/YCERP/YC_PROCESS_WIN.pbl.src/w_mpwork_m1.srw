event pb_delete::clicked;// 삭제
string ls_yyyymm, ls_magamyn
int    li_index

debugbreak()

li_index = tab_1.SelectedTab
choose case li_index
	case 1	// 작업일보대상항목
		
	case 2	// 작업일보등록
		dw4.deleterow(0)

	case 3	// 사용 자재등록
		ls_yyyymm  = string(dw_2.object.work_date[1],'yyyymm')
		SELECT magam_yn INTO :ls_magamyn FROM MMAGAM WHERE YYYYMM = :ls_yyyymm;
		if ls_magamyn = "Y" then
			MessageBox("확인", "해당하는 작업일자는 마감통제 되었습니다.",exclamation!)				
			RETURN 
		else
			dw5.deleterow(0)
			if dw5.getrow() < 1 then RETURN
			dw5.triggerevent(rowfocuschanged!)
		end if		

	case 4	// 자재반납
		dw6.deleterow(0)

	case 5	// 작업자투입
		dw9.deleterow(0)
//		// 작업자 투입현황 저장
//		if wf_update1(dw9,"N") = false then
//			MessageBox("확인","작업자 삭제중 오류가 발생했습니다.",exclamation!)
//		end if		  

	case 6	// 비 가동시간
end choose

end event

type pb_insert from w_inheritance`pb_insert within w_mpwork_m1
integer x = 2551
integer y = 64
integer taborder = 150
end type

event pb_insert::clicked;// 추가
long   ll_row
int    li_index
string ls_str, ls_str1

// 작업일보헤더
dw_2.accepttext() 

li_index = tab_1.SelectedTab
choose case li_index
	case 1, 2		// 작업일보대상항목, 작업일보등록

	case 3			// 사용자재등록
		dw5.setredraw(false)
		ll_row = dw5.insertrow(0)
		dw5.object.area_no[ll_row]  = gs_area
		dw5.object.order_no[ll_row] = LeftA(gs_area,1) + 'NON' + string(dw_2.object.work_date[1],'yyyymmdd') + '-01'
		dw5.object.use_date[ll_row] = datetime(dw_2.object.work_date[1])
		dw5.object.wc_no[ll_row]    = trim(dw_2.object.wc_no[1])
		
		if ll_row > 1 then
			dw5.accepttext() 
			dw5.object.item_item_name[ll_row] = trim(dw5.object.item_item_name[ll_row - 1])	
			dw5.object.item_no[ll_row] = trim(dw5.object.item_no[ll_row - 1])	
			dw5.object.qa[ll_row]      = trim(dw5.object.qa[ll_row - 1])
			dw5.object.uom[ll_row]     = trim(dw5.object.uom[ll_row - 1])
		   dw5.object.loc_no[ll_row]  = trim(dw_2.object.loc_no[1])
		else
		   dw5.object.loc_no[ll_row]  = dw_2.object.loc_no[1]
		end if
		dw5.scrolltorow(ll_row)	
		dw5.setredraw(TRUE)
		
	case 4		// 사용자재반밥
		dw6.accepttext()
		if dw6.rowcount() < 1 then
			dw6.retrieve(id_date,is_wc)
		end if
		
		ll_row = dw6.insertrow(0)
		dw6.object.area_no[ll_row]  = gs_area
		dw6.object.ret_date[ll_row] = datetime(dw_2.object.work_date[1])
		dw6.object.wc_no[ll_row]    = trim(dw_2.object.wc_no[1])
		dw6.object.order_no[ll_row] = LeftA(gs_area,1) + "NON" + string ( ll_row ,"000")
		
		if ll_row > 1 then
		  dw6.accepttext() 
		  dw6.object.item_item_name[ll_row]  = trim(dw6.object.item_item_name[ll_row - 1])	
		  dw6.object.item_no[ll_row] = trim(dw6.object.item_no[ll_row - 1])	
		  dw6.object.qa[ll_row]      = trim(dw6.object.qa[ll_row - 1])
		  dw6.object.uom[ll_row]     = trim(dw6.object.uom[ll_row - 1])
		  dw6.object.loc_no[ll_row]  = trim(dw6.object.loc_no[ll_row - 1])
		else
		  dw6.object.loc_no[ll_row]  = dw_2.object.loc_no[1]
		end if
		dw6.scrolltorow(ll_row)	

	case 5		// 작업자투입
		MessageBox("확인","작업자 투입은 목록창에서 직접 선택하시기 바랍니다.",exclamation!)
end choose

end event

type pb_retrieve from w_inheritance`pb_retrieve within w_mpwork_m1
integer x = 2359
integer y = 64
integer taborder = 140
end type

event pb_retrieve::clicked;//==GF_USEPROGRAM(프로그램 사용현황)==============================================================
GF_USEPROGRAM( gs_userid, Parent.ClassName(), "R", string(gf_today(),"yyyy/mm/dd"), Parent.Title )
//================================================================================================

long     ll_row, l_count
int        li_index
string   ls_area, ls_wcno, ls_date
date     ldt_date
string  ls_sfcday_key

dw_area.accepttext()
dw_2.accepttext()

ls_area  = dw_area.object.area[1]
ls_wcno  = dw_2.object.wc_no[1]
ldt_date = date(dw_2.object.work_date[1])
ls_date = string(dw_2.object.work_date[1]) 
ls_date = LeftA(ls_date,4) + MidA(ls_date,6,2) + MidA(ls_date, 9,2)

if isnull(id_date) then
	MessageBox("확인","작업일자를 입력하십시오.",exclamation!)
	RETURN
end if

if is_wc = "" OR isnull(is_wc) then
	MessageBox("확인","작업장을 입력하십시오.",exclamation!)
	RETURN
end if

li_index = tab_1.SelectedTab
choose case li_index
	case 1	// 작업일보대상항목
		dw3.setfilter("")
		dw3.filter()
		dw3.retrieve( is_wc, ls_area )
		if dw3.rowcount() < 1 then
			MessageBox("확인","해당하는 조건의 데이터가 존재하지 않습니다.")
		else			
			MessageBox("확인","조회완료")
		end if
		
	case 2	// 작업일보등록
		dw4.setfilter("")
		dw4.filter()
		
		dw4.retrieve( id_date, is_wc, ls_area )		// 작업일보
		dw5.retrieve( ls_area, ls_date, is_wc )		// 사용자재 2018-05-23 id_date에서 수정 
		dw7.retrieve( ls_area, ls_wcno, ldt_date )	// 작업자
		if dw7.rowcount() < 1 then dw7.insertrow( 0 )
		if dw4.rowcount() < 1 then
			MessageBox("확인","해당하는 조건의 데이터가 존재하지 않습니다.")
		else			
			MessageBox("확인","조회완료")
		end if
		
		ls_wcno  = dw_2.object.wc_no[1]
		
		if ls_wcno = 'Y07' then
			
			cb_17.visible =true
			cb_23.visible =true
		
			ls_sfcday_key    = trim(dw4.object.sfcday_key[1])
				
			l_count = 0;
			
			SELECT count(*)
				 into :l_count
			from etcout		 
			where qty <> 0
			 and rem like :ls_sfcday_key+'%';		
			 
			 if l_count = 0 then
				cb_17.enabled = true
				cb_23.enabled = false						
			else
				cb_17.enabled = false
				cb_23.enabled = true									
			end if			
			
		else
			cb_17.visible = false
			cb_23.visible = false
		end if		
		
	case 3	// 사용 자재등록
//		dw5.retrieve( ls_area, id_date, is_wc )
		dw5.retrieve( ls_area, ls_date, is_wc )
		
		if dw5.rowcount() < 1 then
			MessageBox("확인","해당하는 조건의 데이터가 존재하지 않습니다.")
		else			
			MessageBox("확인","조회완료")
		end if
		
	case 4	// 자재반납
		dw6.retrieve( id_date, is_wc )
		if dw6.rowcount() < 1 then
			MessageBox("확인","해당하는 조건의 데이터가 존재하지 않습니다.")
		else			
			MessageBox("확인","조회완료")
		end if
		
	case 5	// 작업자투입
		dw8.retrieve()
		dw9.retrieve( ls_area, string(id_date,"yyyy/mm/dd"), ls_wcno )						

	case 6	// 비 가동시간
		dw10.reset()
		dw10.retrieve( string(id_date,"yyyy/mm/dd"), ls_area, ls_wcno )
		
		dw11.reset()
		dw11.retrieve( ls_area, string(id_date,"yyyy/mm/dd"), ls_wcno )
end choose

end event

