datawindow(units=0 timer_interval=0 color=79741120 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=item_no dbname="item.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="item.qa" )
 column=(type=decimal(4) updatewhereclause=yes name=sumreserved dbname="sumreserved" )
 column=(type=decimal(4) updatewhereclause=yes name=sales_reserved dbname="item.sales_reserved" )
 retrieve="PBSELECT( VERSION(400) DISTINCT ()TABLE(NAME=~"item~" )  TABLE(NAME=~"itemloc~" ) COLUMN(NAME=~"item.item_no~") COLUMN(NAME=~"item.qa~") COMPUTE(NAME=~"sum(itemloc.reserved) sumreserved~") COLUMN(NAME=~"item.sales_reserved~")    JOIN (LEFT=~"item.item_no~"    OP =~"=~"RIGHT=~"itemloc.item_no~"    OUTER1 =~"item.item_no~" )    JOIN (LEFT=~"item.qa~"    OP =~"=~"RIGHT=~"itemloc.qa~"    OUTER1 =~"item.qa~" )WHERE(    EXP1 =~"item.item_no~"   OP =~"like~"    EXP2 =~":as_item~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"item.item_name~"   OP =~"like~"    EXP2 =~":as_name~" )  GROUP(NAME=~"item.item_no~") GROUP(NAME=~"item.qa~") GROUP(NAME=~"item.sales_reserved~")   HAVING (   EXP1 =~"item.sales_reserved~"   OP =~"<>~"    EXP2 =~"sum(itemloc.reserved)~" )) ARG(NAME = ~"as_item~" TYPE = string)  ARG(NAME = ~"as_name~" TYPE = string) " arguments=(("as_item", string),("as_name", string)) )
column(band=detail id=1 alignment="0" tabsequence=32766 border="5" color="0" x="1499" y="12" height="60" width="352" format="[general]"  name=item_no  tag="물품코드" edit.limit=10 edit.case=any edit.autoselect=yes edit.autohscroll=yes  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="0" background.color="536870912~tif (getrow() = currentrow(), RGB(254,252,175), 78682240)" )
column(band=detail id=2 alignment="0" tabsequence=32766 border="5" color="0" x="1874" y="12" height="60" width="640" format="[general]"  name=qa edit.limit=0 edit.case=any edit.autoselect=yes  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
column(band=detail id=3 alignment="0" tabsequence=32766 border="0" color="0" x="2514" y="0" height="60" width="1376" format="[general]"  name=sumreserved edit.limit=0 edit.case=any edit.autoselect=yes  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
column(band=detail id=4 alignment="0" tabsequence=32766 border="0" color="0" x="3890" y="0" height="60" width="1376" format="[general]"  name=sales_reserved edit.limit=0 edit.case=any edit.autoselect=yes  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )

sparse(names="item_no")htmltable(border="1" cellpadding="0" cellspacing="0" generatecss="no" nowrap="yes")