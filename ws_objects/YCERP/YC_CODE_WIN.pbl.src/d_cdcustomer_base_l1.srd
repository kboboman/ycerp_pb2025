footer(height=72 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=item_cd dbname="item_cd" values="기본사항	1/거래조건	2/거래동향	3/" )
 column=(type=long updatewhereclause=yes name=sort dbname="sort" )
 column=(type=char(50) updatewhereclause=yes name=item_nm dbname="item_nm" )
 retrieve=" select  item_cd, sort, item_nm
 from codemst where type = :as_type
 and bigo like '%(여신관리항목)%'
 and use_yn = 'Y'
/* order by substring(bigo ,13,2)*/
  order by item_cd" arguments=(("as_type", string),("as_itemcd", string)) )
