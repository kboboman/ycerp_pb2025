$PBExportHeader$d_mpsliting_s4.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=char(6) updatewhereclause=yes name=order_date dbname="order_date" )
 column=(type=char(6) updatewhereclause=yes name=tw dbname="tw" )
 column=(type=decimal(1) updatewhereclause=yes name=swid dbname="swid" )
 column=(type=char(60) updatewhereclause=yes name=r_item_name dbname="r_item_name" )
 column=(type=char(10) updatewhereclause=yes name=r_qa dbname="r_qa" )
 column=(type=decimal(2) updatewhereclause=yes name=length dbname="length" )
 column=(type=long updatewhereclause=yes name=cnt dbname="cnt" )
 column=(type=decimal(4) updatewhereclause=yes name=tot_qty dbname="tot_qty" )
 column=(type=char(1) updatewhereclause=yes name=gbn dbname="gbn" values="	C/Loss	L/" )
 retrieve="  SELECT tb_a.order_date             
       , tb_a.tw                     
       , tb_a.swid                   
       , tb_a.r_item_name            
       , tb_a.r_qa                   
       , tb_a.length                 
       , cnt     = SUM(tb_a.cnt)     
       , tot_qty = SUM(tb_a.tot_qty) 
       , gbn     = tb_a.gbn
    FROM (
         SELECT DISTINCT
                item_name    = ga.item_name           
              , qa           = coilmst.qa             
              , cnt          = coilsliting.cnt        
              , unit_qty     = coilsliting.unit_qty    
              , start_date   = :as_start              
              , end_date     = :as_end                
              , tot_qty      = ( coilsliting.unit_qty * coilsliting.cnt )
              , rate         = ( coilsliting.unit_qty * coilsliting.cnt ) * 100 / coilmst.unit_qty
              , co_order_no  = coilorder.order_no
              , cod_order_no = coilorderdet.order_no
              , tw           = left(coilmst.qa, 3)
              , swid         = (case when sheet = 'C' or sheet = 'L' 
                                          then convert (decimal (5,1) , substring(coilsliting.qa,5,4) + '.' + substring(coilsliting.qa, 10,1)) 
                                     when sheet = 'S' 
                                          then convert (decimal (5,0) , substring(coilsliting.qa,5,4)) 
                                end)                 
              , wc_place     = coilorder.wc_place    
              , seq          = coilsliting.seq       
              , cm_unit_qty  = coilmst.unit_qty      
              , item_no      = coilsliting.item_no
              , order_date   = convert(varchar(6), coilorder.order_date, 112)
              , gbn          = (case when (left(coilsliting.item_no,2) =  'M3' AND substring(coilsliting.item_no, 6,1) = 'L') then 'L' else 'C' end)
              , r_item_name  = gb.item_name               
              , r_qa         = isnull(coilsliting.r_qa,'')
              , length       = coilsliting.length
FROM coilsliting inner join coilorderdet on coilsliting.order_no =  coilorderdet.order_no
                            inner join coilorder on coilorder.order_no = coilorderdet.coilorder_order 
                            inner join coilmst on coilorderdet.coil_no = coilmst.coil_no
                            inner join groupitem ga on coilmst.item_no = ga.item_no
                            left  outer join groupitem gb on coilsliting.r_item_no = gb.item_no              
where       ( ( convert(varchar(6), coilorder.order_date, 112) BETWEEN :as_start AND :as_end) AND
                    ( coilorder.wc_place     LIKE :as_wc_place ) 
                  )                  
/*              
           FROM coilmst        
              , groupitem ga   
              , groupitem gb   
              , coilorder      
              , coilorderdet   
              , coilsliting  
          WHERE ( coilorderdet.order_no           = coilsliting.order_no         )   
            AND ( coilorder.order_no              = coilorderdet.coilorder_order )   
            AND ( coilorderdet.coil_no            = coilmst.coil_no              )   
            AND ( coilmst.item_no                 = ga.item_no                   )   
            AND ( coilsliting.r_item_no          *= gb.item_no                   )   
            AND ( ( convert(varchar(6), coilorder.order_date, 112) BETWEEN :as_start AND :as_end) and
                  ( coilorder.wc_place         LIKE :as_wc_place ) 
                )   
*/                
         ) tb_a
     GROUP BY tb_a.gbn, tb_a.tw, tb_a.swid, tb_a.r_item_name, tb_a.r_qa, tb_a.length, tb_a.order_date
     ORDER BY gbn, order_date, swid,tw, r_item_name, r_qa" arguments=(("as_start", string),("as_end", string),("as_wc_place", string)) )
group(level=1 header.height=0 trailer.height=76 by=("r_item_name" ) header.color="536870912" trailer.color="12639424" )
