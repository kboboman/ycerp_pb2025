$PBExportHeader$d_cdcustscene_r.srd
$PBExportComments$현장별 표준단가관리 REPORT(1998/05/01, 정재수)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 1 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 9 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=532 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=68 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=scene_cust_no dbname="scene.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(11) updatewhereclause=yes name=scene_scene_code dbname="scene.scene_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene.scene_desc" )
 column=(type=char(10) updatewhereclause=yes name=custscene_item_no dbname="custscene.item_no" )
 column=(type=char(20) updatewhereclause=yes name=custscene_qa dbname="custscene.qa" )
 column=(type=char(2) updatewhereclause=yes name=custscene_uom dbname="custscene.uom" )
 column=(type=decimal(0) updatewhereclause=yes name=custscene_pre_cost dbname="custscene.pre_cost" )
 column=(type=decimal(0) updatewhereclause=yes name=custscene_price dbname="custscene.price" )
 column=(type=char(30) updatewhereclause=yes name=custscene_rem dbname="custscene.rem" )
 column=(type=decimal(4) updatewhereclause=yes name=itemcost_price dbname="itemcost.price" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=datetime updatewhereclause=yes name=custscene_sys_date dbname="custscene.sys_date" )
 column=(type=char(10) updatewhereclause=yes name=custscene_user_id dbname="custscene.user_id" )
 retrieve="  SELECT scene.cust_no,   
         customer.cust_name,   
         scene.scene_code,   
         scene.scene_desc,   
         custscene.item_no,   
         custscene.qa,   
         custscene.uom,   
         custscene.pre_cost,   
         custscene.price,   
         custscene.rem,   
         itemcost.price,   
         groupitem.item_name,   
         custscene.sys_date,   
         custscene.user_id  
    FROM customer,   
         scene,   
         custscene,   
         itemcost,   
         groupitem  
   WHERE ( scene.cust_no = customer.cust_no ) and  
         ( scene.cust_no = custscene.cust_no ) and  
         ( scene.scene_code = custscene.scene_code ) and  
         ( custscene.item_no = itemcost.item_no ) and  
         ( custscene.qa = itemcost.qa ) and  
         ( itemcost.item_no = groupitem.item_no ) and  
         ( ( scene.cust_no = :as_cust_no ) AND  
         ( scene.scene_code = :as_scene_code ) and
			( customer.salesman like :as_flag ) )    
" arguments=(("as_cust_no", string),("as_scene_code", string),("as_flag", string)) )
group(level=1 header.height=0 trailer.height=12 by=("custscene_item_no" ) header.color="536870912" trailer.color="536870912"  sort="count(custscene_item_no for group 1) A " )
