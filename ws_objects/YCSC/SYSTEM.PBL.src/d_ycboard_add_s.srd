 column=(type=datetime updatewhereclause=yes name=user_date dbname="ycboard_add.user_date" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="ycboard_add.user_id" )
 column=(type=char(4099) updatewhereclause=no name=board_text dbname="ycboard_add.board_text" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"ycboard_add~" ) COLUMN(NAME=~"ycboard_add.id_seq~") COLUMN(NAME=~"ycboard_add.user_date~") COLUMN(NAME=~"ycboard_add.user_id~") COLUMN(NAME=~"ycboard_add.board_text~")WHERE(    EXP1 =~"ycboard_add.id_seq~"   OP =~"=~"    EXP2 =~":ai_seq~" ) ) ARG(NAME = ~"ai_seq~" TYPE = number) " arguments=(("ai_seq", number))  sort="user_date A " )
