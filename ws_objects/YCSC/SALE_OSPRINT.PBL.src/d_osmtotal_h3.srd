 column=(type=decimal(2) update=yes updatewhereclause=yes name=coll_01 dbname="COLL_01" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=coll_02 dbname="COLL_02" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=coll_03 dbname="COLL_03" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=coll_04 dbname="COLL_04" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=coll_05 dbname="COLL_05" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=coll_06 dbname="COLL_06" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=coll_07 dbname="COLL_07" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=coll_08 dbname="COLL_08" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=coll_09 dbname="COLL_09" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=coll_10 dbname="COLL_10" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=coll_11 dbname="COLL_11" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=coll_12 dbname="COLL_12" )
 retrieve=" SELECT AA.SALESMAN            AS SALESMAN,
        SUM(AA.BALBF_AMOUNT)   AS BALBF_AMOUNT,                       
        SUM(AA.INV_01)         AS INV_01,                             
        SUM(AA.INV_02)         AS INV_02,                             
        SUM(AA.INV_03)         AS INV_03,                             
        SUM(AA.INV_04)         AS INV_04,                             
        SUM(AA.INV_05)         AS INV_05,                             
        SUM(AA.INV_06)         AS INV_06,                             
        SUM(AA.INV_07)         AS INV_07,                             
        SUM(AA.INV_08)         AS INV_08,                             
        SUM(AA.INV_09)         AS INV_09,                             
        SUM(AA.INV_10)         AS INV_10,                             
        SUM(AA.INV_11)         AS INV_11,                             
        SUM(AA.INV_12)         AS INV_12,                             
        SUM(AA.COLL_01)        AS COLL_01,                            
        SUM(AA.COLL_02)        AS COLL_02,                            
        SUM(AA.COLL_03)        AS COLL_03,                            
        SUM(AA.COLL_04)        AS COLL_04,                            
        SUM(AA.COLL_05)        AS COLL_05,                            
        SUM(AA.COLL_06)        AS COLL_06,                            
        SUM(AA.COLL_07)        AS COLL_07,                            
        SUM(AA.COLL_08)        AS COLL_08,                            
        SUM(AA.COLL_09)        AS COLL_09,                            
        SUM(AA.COLL_10)        AS COLL_10,                            
        SUM(AA.COLL_11)        AS COLL_11,                            
        SUM(AA.COLL_12)        AS COLL_12                             
   FROM (                                                             
        SELECT (CASE WHEN CUSTOMER.SALESMAN = 'USE_NO' THEN 'killby' ELSE CUSTOMER.SALESMAN END) AS SALESMAN,         
               SUM(OPEOM.BALBF_AMOUNT)   AS BALBF_AMOUNT,             
               SUM(OPEOM.INV_01)         AS INV_01,                   
               SUM(OPEOM.INV_02)         AS INV_02,                   
               SUM(OPEOM.INV_03)         AS INV_03,                   
               SUM(OPEOM.INV_04)         AS INV_04,                   
               SUM(OPEOM.INV_05)         AS INV_05,                   
               SUM(OPEOM.INV_06)         AS INV_06,                   
               SUM(OPEOM.INV_07)         AS INV_07,                   
               SUM(OPEOM.INV_08)         AS INV_08,                   
               SUM(OPEOM.INV_09)         AS INV_09,                   
               SUM(OPEOM.INV_10)         AS INV_10,                   
               SUM(OPEOM.INV_11)         AS INV_11,                   
               SUM(OPEOM.INV_12)         AS INV_12,                   
               SUM(OPEOM.COLL_01)        AS COLL_01,                  
               SUM(OPEOM.COLL_02)        AS COLL_02,                  
               SUM(OPEOM.COLL_03)        AS COLL_03,                  
               SUM(OPEOM.COLL_04)        AS COLL_04,                  
               SUM(OPEOM.COLL_05)        AS COLL_05,                  
               SUM(OPEOM.COLL_06)        AS COLL_06,                  
               SUM(OPEOM.COLL_07)        AS COLL_07,                  
               SUM(OPEOM.COLL_08)        AS COLL_08,                  
               SUM(OPEOM.COLL_09)        AS COLL_09,                  
               SUM(OPEOM.COLL_10)        AS COLL_10,                  
               SUM(OPEOM.COLL_11)        AS COLL_11,                  
               SUM(OPEOM.COLL_12)        AS COLL_12                   
          FROM OPEOM,                                                 
               CUSTOMER                                               
        WHERE (( OPEOM.CUST_NO = CUSTOMER.CUST_NO ) AND               
                ((DATEPART(YEAR,OPEOM.EOM_YEAR)    = :AN_YEAR) AND 
                 (CUSTOMER.CUST_FLAG <> 'Y' OR CUSTOMER.CUST_FLAG IS NULL)
                )                                                     
               )                                                      
           AND CUSTOMER.CUST_NO           <> 'U580'                      
           AND CUSTOMER.SALESMAN        LIKE '%'                      
           AND CUSTOMER.CREDIT_LEVEL      <> 'Z'                      
        GROUP BY SALESMAN                                             
        ) AA                                                          
    GROUP BY AA.SALESMAN                                              
/*-----------*/                                                       
 UNION                                                                
/*-----------*/                                                       
  SELECT 'YCIN1'                   AS SALESMAN,                       
         SUM(OPEOM.BALBF_AMOUNT)   AS BALBF_AMOUNT,                   
         SUM(OPEOM.INV_01)         AS INV_01,                         
         SUM(OPEOM.INV_02)         AS INV_02,                         
         SUM(OPEOM.INV_03)         AS INV_03,                         
         SUM(OPEOM.INV_04)         AS INV_04,                         
         SUM(OPEOM.INV_05)         AS INV_05,                         
         SUM(OPEOM.INV_06)         AS INV_06,                         
         SUM(OPEOM.INV_07)         AS INV_07,                         
         SUM(OPEOM.INV_08)         AS INV_08,                         
         SUM(OPEOM.INV_09)         AS INV_09,                         
         SUM(OPEOM.INV_10)         AS INV_10,                         
         SUM(OPEOM.INV_11)         AS INV_11,                         
         SUM(OPEOM.INV_12)         AS INV_12,                         
         SUM(OPEOM.COLL_01)        AS COLL_01,                        
         SUM(OPEOM.COLL_02)        AS COLL_02,                        
         SUM(OPEOM.COLL_03)        AS COLL_03,                        
         SUM(OPEOM.COLL_04)        AS COLL_04,                        
         SUM(OPEOM.COLL_05)        AS COLL_05,                        
         SUM(OPEOM.COLL_06)        AS COLL_06,                        
         SUM(OPEOM.COLL_07)        AS COLL_07,                        
         SUM(OPEOM.COLL_08)        AS COLL_08,                        
         SUM(OPEOM.COLL_09)        AS COLL_09,                        
         SUM(OPEOM.COLL_10)        AS COLL_10,                        
         SUM(OPEOM.COLL_11)        AS COLL_11,                        
         SUM(OPEOM.COLL_12)        AS COLL_12                         
    FROM OPEOM,                                                       
         CUSTOMER                                                     
   WHERE ((OPEOM.CUST_NO = CUSTOMER.CUST_NO) AND                      
          ((DATEPART(YEAR,OPEOM.EOM_YEAR) = :AN_YEAR) AND             
           (CUSTOMER.CUST_FLAG <> 'Y' OR CUSTOMER.CUST_FLAG IS NULL)  
          )                                                           
         )                                                            
     AND OPEOM.CUST_NO IN ('S396','N002','K023','H479','N014') /* 계열사 */
   GROUP BY  SALESMAN                                                 

/*-----------*/                                                       
 UNION                                                                
/*-----------*/                                                       
  SELECT 'YCIN1'                   AS SALESMAN,                       
         SUM(OPEOM.BALBF_AMOUNT)   AS BALBF_AMOUNT,                   
         SUM(OPEOM.INV_01)         AS INV_01,                         
         SUM(OPEOM.INV_02)         AS INV_02,                         
         SUM(OPEOM.INV_03)         AS INV_03,                         
         SUM(OPEOM.INV_04)         AS INV_04,                         
         SUM(OPEOM.INV_05)         AS INV_05,                         
         SUM(OPEOM.INV_06)         AS INV_06,                         
         SUM(OPEOM.INV_07)         AS INV_07,                         
         SUM(OPEOM.INV_08)         AS INV_08,                         
         SUM(OPEOM.INV_09)         AS INV_09,                         
         SUM(OPEOM.INV_10)         AS INV_10,                         
         SUM(OPEOM.INV_11)         AS INV_11,                         
         SUM(OPEOM.INV_12)         AS INV_12,                         
         SUM(OPEOM.COLL_01)        AS COLL_01,                        
         SUM(OPEOM.COLL_02)        AS COLL_02,                        
         SUM(OPEOM.COLL_03)        AS COLL_03,                        
         SUM(OPEOM.COLL_04)        AS COLL_04,                        
         SUM(OPEOM.COLL_05)        AS COLL_05,                        
         SUM(OPEOM.COLL_06)        AS COLL_06,                        
         SUM(OPEOM.COLL_07)        AS COLL_07,                        
         SUM(OPEOM.COLL_08)        AS COLL_08,                        
         SUM(OPEOM.COLL_09)        AS COLL_09,                        
         SUM(OPEOM.COLL_10)        AS COLL_10,                        
         SUM(OPEOM.COLL_11)        AS COLL_11,                        
         SUM(OPEOM.COLL_12)        AS COLL_12                         
    FROM OPEOM,                                                       
         CUSTOMER                                                     
   WHERE ((OPEOM.CUST_NO = CUSTOMER.CUST_NO) AND                      
          ((DATEPART(YEAR,OPEOM.EOM_YEAR) = :AN_YEAR) AND             
           (CUSTOMER.CUST_FLAG <> 'Y' OR CUSTOMER.CUST_FLAG IS NULL)  
          )                                                           
         )                                                            
     AND OPEOM.CUST_NO       = 'U580' /* 송천산업 */
   GROUP BY  SALESMAN                                                 
/* USE_NO(사용불가) 담당자를 길병학으로 포함 */                       
" filter="not(balbf_amount = 0 and inv_01 = 0 and inv_02 = 0 and inv_03 = 0 and inv_04 = 0 and inv_05 = 0 and inv_06 = 0 and inv_07 = 0 and inv_08 = 0 and inv_09 = 0 and inv_10 = 0 and inv_11 = 0 and inv_12 = 0 and coll_01 = 0 and coll_02 = 0 and coll_03 = 0 and coll_04 = 0 and coll_05 = 0 and coll_06 = 0 and coll_07 = 0 and coll_08 = 0 and coll_09 = 0 and coll_10 = 0 and coll_11 = 0 and coll_12 = 0)"arguments=(("an_year", number)) )
