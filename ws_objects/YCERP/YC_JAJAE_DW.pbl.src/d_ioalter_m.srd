 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"itemalter~" )  TABLE(NAME=~"groupitem~" ALIAS=~"groupitem_a~" )  TABLE(NAME=~"groupitem~" ALIAS=~"groupitem_b~" ) COLUMN(NAME=~"itemalter.alter_time~") COLUMN(NAME=~"itemalter.alter_date~") COLUMN(NAME=~"itemalter.src_item~") COLUMN(NAME=~"itemalter.src_qa~") COLUMN(NAME=~"itemalter.src_loc~") COLUMN(NAME=~"itemalter.order_no~") COLUMN(NAME=~"itemalter.seq~") COLUMN(NAME=~"itemalter.src_qty~") COLUMN(NAME=~"itemalter.src_lot~") COLUMN(NAME=~"itemalter.tar_item~") COLUMN(NAME=~"itemalter.tar_qa~") COLUMN(NAME=~"itemalter.tar_loc~") COLUMN(NAME=~"itemalter.tar_lot~") COLUMN(NAME=~"itemalter.tar_qty~") COLUMN(NAME=~"itemalter.user_id~") COLUMN(NAME=~"groupitem_a.item_name~") COLUMN(NAME=~"groupitem_a.uom~") COLUMN(NAME=~"groupitem_b.item_name~") COLUMN(NAME=~"groupitem_b.uom~") COLUMN(NAME=~"itemalter.rem~") COMPUTE(NAME=~"qoh = 0.0000~") COLUMN(NAME=~"itemalter.issue_flag~")    JOIN (LEFT=~"itemalter.tar_item~"    OP =~"=~"RIGHT=~"groupitem_a.item_no~" )    JOIN (LEFT=~"itemalter.src_item~"    OP =~"=~"RIGHT=~"groupitem_b.item_no~" )WHERE(    EXP1 =~"itemalter.alter_date~"   OP =~"between~"    EXP2 =~":ad_start and :ad_end~" ) ) ARG(NAME = ~"ad_start~" TYPE = date)  ARG(NAME = ~"ad_end~" TYPE = date) " update="itemalter" updatewhere=0 updatekeyinplace=no arguments=(("ad_start", date),("ad_end", date)) )
