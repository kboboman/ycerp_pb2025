type cb_import from commandbutton within tabpage_4
integer x = 814
integer y = 236
integer width = 750
integer height = 84
integer taborder = 250
integer textsize = -10
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "엑셀 가져오기"
end type

event clicked;//
string ls_chk           // CHK
long   ll_seq_no        // 순번
string ls_b1_drawno     // 도면번호
string ls_b1_pgmno      // 프로그램
string ls_b1_type       // TYPE
long   ll_b1_qa1        // 판넬규격/폭1
long   ll_b1_qa2        //         /폭2
long   ll_b1_qa3        //         /길이1
long   ll_b1_qa4        //         /길이2
long   ll_qty           // 신청수량
long   ll_b1_qa5        // 샤링규격/폭
long   ll_b1_qa6        //         /길이
long   ll_b1_qa7        //         /레퍼런스1
long   ll_b1_qa8        //         /레퍼런스2
long   ll_b1_cuts       // 칼수
string ls_b1_rem        // 절곡(비고)
string ls_sale_no       // 수주번호
long   ll_seq           // 수주순번

String  ls_Sheet
Integer iRet, li_int, li_Change
Long    ll_row, ll_status, ll_max, ll_cnt, ll_xls
Dec     ld_price, ld_comqty
Boolean SWExit = True

OLEObject MyExcel

MyExcel = CREATE OLEObject

iRet = MyExcel.ConnectToObject("", "excel.application") 
if iRet <> 0 then DESTROY MyExcel 

MyExcel.Application.Visible = true

if IsValid(xlSheet) then DESTROY xlSheet
xlSheet = MyExcel.Application.Sheets(ii_Sheet)

this.enabled = false

long numcols, numrows, iCol, iRow

ll_max = dw6.rowcount()
//ll_xls = xlSheet.WorksheetFunction.COUNTA(A:A,"")-6
iRow   = 6
SWExit = true   
Do While SWExit
	ll_xls = ll_xls + 1

	iRow = iRow + 1
	if IsNull(xlSheet.Cells[iRow, 1].Value) then SWExit = false
Loop

iRow   = 6
SWExit = true   
hpb_1.position = 0
hpb_2.position = 0

Do While SWExit
	tab_2.tabpage_4.st_row.text = "Row: " + string(iRow)
	///////////////////////////////////////////////////////////////////////////////////////////////////////////////
	// 엑셀 데이터 포맷
	///////////////////////////////////////////////////////////////////////////////////////////////////////////////
	ll_seq_no    = Long(String(xlSheet.Cells[iRow,  1].Value))   // 순번
	ls_b1_drawno = String(xlSheet.Cells[iRow,  2].Value)         // 도면번호
	ls_b1_pgmno  = String(xlSheet.Cells[iRow,  3].Value)         // 프로그램
	ls_b1_type   = String(xlSheet.Cells[iRow,  4].Value)         // TYPE
	ll_b1_qa1    = Long(String(xlSheet.Cells[iRow,  5].Value))   // 판넬규격/폭1
	ll_b1_qa2    = Long(String(xlSheet.Cells[iRow,  6].Value))   //         /폭2
	ll_b1_qa3    = Long(String(xlSheet.Cells[iRow,  7].Value))   //         /길이1
	ll_b1_qa4    = Long(String(xlSheet.Cells[iRow,  8].Value))   //         /길이2
	ll_qty       = Long(String(xlSheet.Cells[iRow,  9].Value))   // 수량
	ll_b1_qa5    = Long(String(xlSheet.Cells[iRow, 10].Value))   // 샤링규격/폭
	ll_b1_qa6    = Long(String(xlSheet.Cells[iRow, 11].Value))   //         /길이
	ll_b1_qa7    = Long(String(xlSheet.Cells[iRow, 12].Value))   // 신청규격/레퍼런스1
	ll_b1_qa8    = Long(String(xlSheet.Cells[iRow, 13].Value))   //         /레퍼런스2
	ll_b1_cuts   = Long(String(xlSheet.Cells[iRow, 14].Value))   // 칼수
	ls_b1_rem    = String(xlSheet.Cells[iRow, 15].Value)         // 비고
	ls_sale_no   = String(xlSheet.Cells[iRow, 16].Value)         // 수주번호
	ll_seq       = Long(String(xlSheet.Cells[iRow, 17].Value))   // 수주순번

	ll_cnt = ll_cnt + 1
   hpb_1.position = (ll_cnt / ll_xls) * 100

	if (isnull(ls_sale_no) or ls_sale_no = "") Or (isnull(ll_seq) or ll_seq = 0) then
	else
		ll_row = dw6.insertrow(0)
		dw6.object.seq_no[ll_row]    = ll_max + ll_cnt   
		dw6.object.sale_no[ll_row]   = ls_sale_no  
		dw6.object.seq[ll_row]       = ll_seq      
		dw6.object.qty[ll_row]       = ll_qty      
		dw6.object.b1_drawno[ll_row] = ls_b1_drawno  
		dw6.object.b1_qa1[ll_row]    = ll_b1_qa1   
		dw6.object.b1_qa2[ll_row]    = ll_b1_qa2   
		dw6.object.b1_qa3[ll_row]    = ll_b1_qa3   
		dw6.object.b1_qa4[ll_row]    = ll_b1_qa4   
		dw6.object.b1_cuts[ll_row]   = ll_b1_cuts 
		dw6.object.b1_qa5[ll_row]    = ll_b1_qa5   
		dw6.object.b1_qa6[ll_row]    = ll_b1_qa6   
		dw6.object.b1_qa7[ll_row]    = ll_b1_qa7   
		dw6.object.b1_qa8[ll_row]    = ll_b1_qa8   
		dw6.object.b1_rem[ll_row]    = ls_b1_rem   
		dw6.object.b1_pgmno[ll_row]  = ls_b1_pgmno   
		dw6.object.b1_type[ll_row]   = ls_b1_type   
		
		dw6.ScrollToRow(ll_row)
	end if
	
	iRow = iRow + 1
	if IsNull(xlSheet.Cells[iRow, 1].Value) then SWExit = false
Loop
tab_2.tabpage_4.st_row.text = "Row: "

//string ls_itemnm, ls_qa, ls_color       // 품목, 규격, 색상
string ls_orderno, ls_itemno, ls_itemnm, ls_qa, ls_color, ls_bigo // 품목, 규격, 색상

for ll_row = 1 to dw6.rowcount()
	hpb_2.position = (ll_row / dw6.rowcount()) * 100

	ls_sale_no = dw6.object.sale_no[ll_row]
	if isnull(ls_sale_no) or ls_sale_no = "" then
		dw6.deleterow(ll_row)
	else
		ll_seq     = dw6.object.seq[ll_row]    
		ls_itemnm  = dw6.object.item_name[ll_row]    
	
		if isnull(ls_itemnm) or ls_itemnm = "" then
			SELECT A.ITEM_NO, B.ITEM_NAME, A.QA, C.COLOR_NAME, A.REM
			  INTO :ls_itemno, : ls_itemnm, :ls_qa, :ls_color, :ls_bigo
			  FROM SALEDET A
					 LEFT OUTER JOIN GROUPITEM B   ON A.ITEM_NO  = B.ITEM_NO
					 LEFT OUTER JOIN COLOR     C   ON A.COLOR    = C.COLOR_CODE
			 WHERE A.ORDER_NO  = :ls_sale_no
				AND A.SEQ_NO    = :ll_seq;
	
			dw6.object.item_no[ll_row]   = ls_itemno
			dw6.object.item_name[ll_row] = ls_itemnm
			dw6.object.qa[ll_row]        = ls_qa       
			dw6.object.color[ll_row]     = ls_color    
			dw6.object.p1_rem[ll_row]    = ls_bigo    
	
			dw6.ScrollToRow(ll_row)
		end if
	end if
next

// Quits Excel
MyExcel.Application.Quit()

iRet = MyExcel.DisconnectObject()       
If iRet < 0 then
	MessageBox("ERROR","DisconnectObject Failed")
End If

Destroy MyExcel
Destroy xlSheet
Destroy OleExcel
//

end event

