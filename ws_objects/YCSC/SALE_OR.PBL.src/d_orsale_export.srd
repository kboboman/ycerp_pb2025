table(column=(type=long updatewhereclause=yes name=seq_no dbname="saledet.seq_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="saledet.item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=long updatewhereclause=yes name=qa1 dbname="qa1" )
 column=(type=long updatewhereclause=yes name=qa2 dbname="qa2" )
 column=(type=long updatewhereclause=yes name=qa3 dbname="qa3" )
 column=(type=long updatewhereclause=yes name=qa4 dbname="qa4" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="saledet.uom" )
 column=(type=decimal(2) updatewhereclause=yes name=order_qty dbname="saledet.order_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=price dbname="saledet.price" )
 column=(type=char(50) updatewhereclause=yes name=rem dbname="saledet.rem" )
 column=(type=char(4) updatewhereclause=yes name=color dbname="saledet.color" )
 retrieve="  SELECT saledet.seq_no
       , saledet.item_no             
       , item_name = g.item_name
       , qa1   = cast(substring(saledet.qa, 1, 3) as int)
       , qa2   = cast(substring(saledet.qa, 5, 4) as int)
       , qa3   = cast(substring(saledet.qa,10, 4) as int)
       , qa4   = cast(substring(saledet.qa,15, 5) as int)
       , saledet.uom                  
       , saledet.order_qty           
       , saledet.price               
       , saledet.rem                 
       , saledet.color        
    FROM saledet   
         LEFT OUTER JOIN item        ON saledet.item_no = item.item_no AND saledet.qa = item.qa
         LEFT OUTER JOIN groupitem G ON saledet.item_no = g.item_no
   WHERE ( saledet.order_no = :as_order_no ) 
" arguments=(("as_order_no", string)) )
