$PBExportComments$거래처집계
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no  crosstab.dynamic = yes grid.lines=0 grid.columnmove=no selected.mouse=no )
header[1](height=0 color="536870912" )
header[2](height=72 color="536870912" )
header[3](height=72 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(20) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(20) updatewhereclause=yes name=category dbname="category" )
 column=(type=number updatewhereclause=yes name=calc_amt dbname="calc_amt" )
 retrieve="  SELECT user_name   = a.user_name
       , cust_name   = a.cust_name   
       , category    = a.category
       , gtype       = a.gtype
       , due_date    = a.do_date + (case when :as_yymm = 'Y' then a.do_dates else '(' + a.do_dates + ')' end)
       , inside      = a.inside
       , calc_amt    = a.calc_amt / 1000
    FROM (
         SELECT user_name   = l.user_name
              , cust_name   = c.cust_name   
              , item_name   = g.item_name   
              , category    = (SELECT item_nm  FROM codemst with (nolock) WHERE type = 'ITEMTOP10' AND use_yn = 'Y' AND item_cd = i.category)
              , gtype       = i.type       
              , inside      = (case when v.cust_no IS NULL then '1.일반영업' else '2.계열사' end)
              , do_date     = (case when :as_yymm = 'Y' then convert(char(04),do.do_date,111)
                                    else convert(char(08),do.do_date,11)
                               end)
              , do_dates    = replace((case when :as_yymm = 'Y' 
                                            then '.' + (case when datepart(month,do.do_date) < 10 
                                                             then '0'+cast(datepart(month,do.do_date) as char(2))
                                                             else cast(datepart(month,do.do_date) as char(2))
                                                        end)+'월'
                                            else (case when datepart(dw,do.do_date) = 1 then '일'
                                                       when datepart(dw,do.do_date) = 2 then '월'
                                                       when datepart(dw,do.do_date) = 3 then '화'
                                                       when datepart(dw,do.do_date) = 4 then '수'
                                                       when datepart(dw,do.do_date) = 5 then '목'
                                                       when datepart(dw,do.do_date) = 6 then '금'
                                                       when datepart(dw,do.do_date) = 7 then '토'
                                                  end)
                                       end),' ','')
              , c_acc_qty   = dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty)
              , calc_amt    = dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty) * dodet.price
           FROM do   with (nolock)
                INNER JOIN dodet       with (nolock) ON do.do_no      = dodet.do_no 
                LEFT OUTER JOIN groupitem_use GU with (nolock) ON gu.item_no = dodet.item_no
                LEFT OUTER JOIN customer  C with (nolock) ON do.cust_no    = c.cust_no
                LEFT OUTER JOIN login     L with (nolock) ON c.salesman    = l.user_id
                LEFT OUTER JOIN v_cust_inside  V          ON do.cust_no    = v.cust_no
                LEFT OUTER JOIN groupitem G with (nolock) ON dodet.item_no = g.item_no 
                LEFT OUTER JOIN itemtop10 i with (nolock) ON dodet.item_no = i.item_no    
          WHERE ( do.do_date   BETWEEN :ad_sdate AND :ad_edate )
            AND ((:as_usename   = '%') OR
                 (:as_usename  <> '%' AND gu.use_name = :as_usename)
                )
         ) A
" arguments=(("as_usename", string),("ad_sdate", date),("ad_edate", date),("as_yymm", string))  sort="user_name A cust_name A category A " )
group(level=1 header.height=0 trailer.height=80 by=("user_name" ) header.color="536870912" trailer.color="12639424" )
