table(column=(type=char(10) updatewhereclause=yes key=yes name=order_no dbname="purdet.order_no" initial=" " )
 column=(type=decimal(0) updatewhereclause=yes key=yes name=seq_no dbname="purdet.seq_no" initial=" " )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="purdet.item_no" initial=" " )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="purdet.qa" initial=" " )
 column=(type=datetime updatewhereclause=yes name=due_date dbname="purdet.due_date" initial=" " )
 column=(type=decimal(4) updatewhereclause=yes name=order_qty dbname="purdet.order_qty" initial=" " )
 column=(type=datetime update=yes updatewhereclause=yes name=rlse_date dbname="purdet.rlse_date" initial=" " )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=price dbname="purdet.price" initial=" " )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="purdet.uom" initial=" " )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=rlse_qty dbname="purdet.rlse_qty" initial=" " )
 column=(type=char(17) updatewhereclause=yes name=product_no dbname="purdet.product_no" initial=" " )
 column=(type=char(20) update=yes updatewhereclause=yes name=loc_no dbname="purdet.rcpt_loc" initial=" " )
 column=(type=char(1) updatewhereclause=yes name=pur_type dbname="purdet.pur_type" initial=" " )
 column=(type=char(30) updatewhereclause=yes name=rem dbname="purdet.rem" initial=" " )
 column=(type=char(20) update=yes updatewhereclause=yes name=coil_no dbname="purdet.coil_no" initial=" " )
 column=(type=long update=yes updatewhereclause=yes name=serial_no dbname="purdet.serial_no" initial=" " )
 column=(type=char(1) updatewhereclause=yes name=work_type dbname="purdet.work_type" initial=" " )
 column=(type=long update=yes updatewhereclause=yes name=cnt dbname="purdet.cnt" initial="1" )
 column=(type=char(1) updatewhereclause=yes name=pur_subcon dbname="pur.subcon" initial=" " values="구매	N/외주가공	P/외주구매	Y/외주슬리팅	C/자재가공	J/원코일	W/수입	L/" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" initial=" " )
 column=(type=decimal(4) updatewhereclause=yes name=rcpt_qty dbname="rcpt_qty" )
 column=(type=char(1) update=yes updatewhereclause=yes name=result_type dbname="purdet.result_type" values="완료	E/부분	P/취소	C/미입	N/" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=com_qty dbname="purdet.com_qty" )
 column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" initial="N" values="	Y/	N" )
 column=(type=char(14) updatewhereclause=yes name=purdet_sale_no dbname="purdet.sale_no" )
 column=(type=long updatewhereclause=yes name=purdet_sale_seq dbname="purdet.sale_seq" )
 column=(type=char(50) updatewhereclause=yes name=purdet_cust_name dbname="purdet.cust_name" )
 column=(type=char(50) updatewhereclause=yes name=purdet_sale_rem dbname="purdet.sale_rem" )
 column=(type=char(4) updatewhereclause=yes name=purdet_color dbname="purdet.color" )
 column=(type=char(10) updatewhereclause=yes name=pur_fob dbname="pur.fob" )
 column=(type=char(80) updatewhereclause=yes name=pur_shipto_addr dbname="pur.shipto_addr" )
 column=(type=char(3) updatewhereclause=yes name=pur_curr_code dbname="pur.curr_code" )
 column=(type=char(1) updatewhereclause=yes name=pur_tax_sign dbname="pur.tax_sign" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=unit_qty dbname="purdet.unit_qty" )
 column=(type=char(2) update=yes updatewhereclause=yes name=com_uom dbname="purdet.com_uom" )
 column=(type=char(1) updatewhereclause=yes name=round dbname="supp.round" )
 retrieve="  SELECT purdet.order_no,   
         purdet.seq_no,   
         purdet.item_no,   
         purdet.qa,   
         purdet.due_date,   
         purdet.order_qty,   
         purdet.rlse_date,   
         purdet.price,   
         purdet.uom,   
         purdet.rlse_qty,   
         purdet.product_no,   
         purdet.rcpt_loc,   
         purdet.pur_type,   
         purdet.rem,   
         purdet.coil_no,   
         purdet.serial_no,   
         purdet.work_type,   
         purdet.cnt,   
         pur.subcon,   
         groupitem.item_name,   
         convert(decimal(15,4),0) rcpt_qty,   
         purdet.result_type,   
         purdet.com_qty,   
         'N' chk,   
         purdet.sale_no,   
         purdet.sale_seq,   
         purdet.cust_name,   
         purdet.sale_rem,   
         purdet.color,   
         pur.fob,   
         pur.shipto_addr,   
         pur.curr_code,   
         pur.tax_sign,   
         purdet.unit_qty,   
         purdet.com_uom,   
         supp.round  
    FROM purdet,   
         pur,   
         groupitem,   
         supp  
   WHERE ( purdet.order_no = pur.order_no ) and  
         ( purdet.item_no = groupitem.item_no ) and  
         ( pur.supp_no = supp.supp_no ) and  
         ( ( pur.supp_no = :arg_supp ) AND  
           ( pur.po_print = 'Y' ) AND 
         ( pur.open_close = 'O' ) AND  
         ( purdet.result_type not in ('E','C') ) AND  
         ( pur.subcon = 'C' ) )
" update="purdet" updatewhere=0 updatekeyinplace=yes arguments=(("arg_supp", string))  sort="order_no A seq_no A product_no A " )
