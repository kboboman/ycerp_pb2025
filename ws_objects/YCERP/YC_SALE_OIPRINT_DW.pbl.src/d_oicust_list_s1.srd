$PBExportComments$판매거래처 출고관리 현황(2004/03/15,정갑용)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 selected.mouse=no )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=88 color="553648127" )
table(column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 retrieve="select  distinct a.cust_name,
				   a.cust_no
from 
(
	 SELECT  distinct do.area_no,
							customer.cust_name,
							 customer.cust_no
		 from do with(nolock) inner join dodet with(nolock) on do.do_no = dodet.do_no
								  inner join groupitem with(nolock) on dodet.item_no = groupitem.item_no 
								  inner join customer with(nolock) on do.cust_no = customer.cust_no                                                                       
								  left outer join scene with(nolock) on do.cust_no = scene.cust_no 
																							 and  do.spot_code = scene.scene_code
								  left outer join aroivc with(nolock) on do.cust_no = aroivc.cust_no 
																							  and do.do_date = aroivc.oi_date			  
        where   ( do.do_date between :ad_start and :ad_end ) and
					 ( do.do_date between :ad_start and :ad_end ) and
					  ( customer.credit_level = 'E' ) and
					  ( customer.balance_amt <> 0 )
) a
where      ( case when a.area_no = 'B0001' THEN 'B0001' 
                           when  a.area_no = 'T0001' THEN 'T0001' 
                            else '00000'
					END 
			 ) = (
					case when  :as_area = 'B0001' THEN 'B0001' 
								  when   :as_area = 'T0001' THEN 'T0001' 
									  else '00000'
					END
				 )
/*
 SELECT  distinct customer.cust_name,
			customer.cust_no
    FROM do,   
         dodet,   
         scene,   
         groupitem,   
         customer,
			aroivc
   WHERE ( do.do_no = dodet.do_no ) and  
         ( do.cust_no *= scene.cust_no ) and  
         ( do.spot_code *= scene.scene_code ) and  
         ( dodet.item_no = groupitem.item_no ) and  
         ( do.cust_no = customer.cust_no ) and  
         ( do.do_date between :ad_start and :ad_end ) and
			( customer.credit_level = 'E' ) and
			( customer.balance_amt <> 0 ) and
			( ( :as_area = 'B0001' and do.area_no = :as_area ) or
			  ( :as_area = 'T0001' and do.area_no = :as_area ) or
			  ( :as_area <> 'B0001' and :as_area <> 'T0001' and do.area_no <> 'B0001' ) ) and
			( ( do.cust_no *= aroivc.cust_no ) )

*/
" arguments=(("as_area", string),("ad_start", date),("ad_end", date)) )
