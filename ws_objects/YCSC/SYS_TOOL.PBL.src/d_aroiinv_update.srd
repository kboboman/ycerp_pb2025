 column=(type=decimal(0) update=yes updatewhereclause=yes name=dc_rate dbname="aroiinv.dc_rate" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=discount dbname="aroiinv.discount" )
 retrieve="  SELECT aroiinv.aroiinv_no,   
         aroiinv.cust_no,   
         aroiinv.sale_flag,   
         aroiinv.register_no,   
         aroiinv.inv_type,   
         aroiinv.oi_date,   
         aroiinv.curr_code,   
         aroiinv.gl_cur_rate,   
         aroiinv.aroiinv_cash,   
         aroiinv.aroiinv_rate,   
         aroiinv.ship_cost,   
         aroiinv.printed,   
         aroiinv.open_close,   
         aroiinv.close_date,   
         aroiinv.delete_flag,   
         aroiinv.sys_date,   
         aroiinv.login_id,   
         aroiinv.rem,   
         aroiinv.dc,   
         aroiinv.rem_amt,   
         aroiinv.inv_area,   
         aroiinv.dc_rate,   
         aroiinv.discount  
    FROM aroiinv  
   WHERE aroiinv.oi_date between '2004/01/01'  and '2004/07/31'
and datepart(month, aroiinv.oi_date)= :a
            
" update="aroiinv" updatewhere=1 updatekeyinplace=no arguments=(("a", number)) )
