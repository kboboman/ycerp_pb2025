$PBExportHeader$d_oiretreqdet_m2.srd
$PBExportComments$반품요청서관리상세(2000/04/27,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=68 color="8421504" )
detail(height=92 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=sale_no dbname="sale_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="saledet.seq_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="saledet.item_no" )
 column=(type=char(4) updatewhereclause=yes name=color dbname="saledet.color" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="saledet.qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="saledet.uom" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_order_qty dbname="saledet.order_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_rlse_qty dbname="saledet.rlse_qty" )
 column=(type=long updatewhereclause=yes name=ret_seq dbname="ret_seq" )
 column=(type=decimal(1) updatewhereclause=yes name=acc_qty dbname="acc_qty" )
 column=(type=char(40) updatewhereclause=yes name=decision_desc dbname="decision_desc" )
 column=(type=char(40) updatewhereclause=yes name=rem dbname="rem" )
 column=(type=char(14) updatewhereclause=yes name=ret_no dbname="ret_no" )
 column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" values="	Y/	N/	0" )
 column=(type=char(1) updatewhereclause=yes name=acc_degree dbname="acc_degree" values="A	A/B	B/C	C/" )
 column=(type=decimal(2) updatewhereclause=yes name=t_ret_qty dbname="t_ret_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=ret_qty dbname="ret_qty" )
 retrieve="  SELECT DISTINCT sale_no = saledet.order_no
       , saledet.seq_no   
       , saledet.item_no   
       , saledet.color   
       , saledet.qa   
       , saledet.uom   
       , groupitem.item_name   
       , saledet.order_qty   
       , saledet.rlse_qty   
       , ret_seq       = 0   
       , acc_qty       = 0.0   
       , decision_desc = space(40)   
       , rem           = space(40)   
       , ret_no        = space(14)   
       , chk           = ' '   
       , acc_degree    = 'B'   
       , t_ret_qty     = sum(retdet.acc_qty)   
       , ret_qty       = saledet.rlse_qty 
from saledet with(nolock) inner join groupitem with(nolock) on saledet.item_no   = groupitem.item_no 
 							      left outer join retdet with(nolock) on saledet.order_no = retdet.sale_no and saledet.seq_no = retdet.seq_no
where ( saledet.order_no  = :as_sale_no       ) 
     AND ( saledet.rlse_qty  > 0                 )
   GROUP BY saledet.order_no   
          , saledet.seq_no   
          , saledet.item_no   
          , saledet.qa   
          , saledet.uom   
          , saledet.order_qty   
          , saledet.rlse_qty   
          , saledet.color   
          , groupitem.item_name  
/*
    FROM retdet
       , saledet
       , groupitem  
   WHERE ( saledet.order_no *= retdet.sale_no    ) 
     AND ( saledet.seq_no   *= retdet.seq_no     ) 
     AND ( saledet.item_no   = groupitem.item_no ) 
     AND ( saledet.order_no  = :as_sale_no       ) 
     AND ( saledet.rlse_qty  > 0                 )
   GROUP BY saledet.order_no   
          , saledet.seq_no   
          , saledet.item_no   
          , saledet.qa   
          , saledet.uom   
          , saledet.order_qty   
          , saledet.rlse_qty   
          , saledet.color   
          , groupitem.item_name  
*/" arguments=(("as_sale_no", string))  sort="seq_no A " )
