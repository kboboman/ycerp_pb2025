table(column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" values="	Y/	N" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=qa dbname="qa" )
 column=(type=char(2) update=yes updatewhereclause=yes key=yes name=uom dbname="uom" )
 column=(type=char(5) update=yes updatewhereclause=yes name=rout_no1 dbname="rout_no1" )
