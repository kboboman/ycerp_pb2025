table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="groupitem.item_no" )
 column=(type=char(60) update=yes updatewhereclause=yes name=item_name dbname="groupitem.item_name" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"groupitem~" ) COLUMN(NAME=~"groupitem.item_no~") COLUMN(NAME=~"groupitem.item_name~")WHERE(    EXP1 =~"item_no~"   OP =~"like~"    EXP2 =~":as_item~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"use_flag~"   OP =~"=~"    EXP2 =~"'Y'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"item_no~"   OP =~"not in~"    EXP2 =~"(select item_no from lossitem)~" ) ) ARG(NAME = ~"as_item~" TYPE = string) " update="groupitem" updatewhere=1 updatekeyinplace=no arguments=(("as_item", string)) )
text(band=header alignment="2" text="물품번호"border="0" color="0" x="9" y="8" height="60" width="352"  name=item_no_t  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
