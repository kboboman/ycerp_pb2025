//			update coilmst set loc_no = :ls_newloc, open_close = "S" // 외주저장소로이동(외주발주작성)
			update coilmst set open_close = "S" // 외주상태만변경(외주발주작성)
			 where coil_no = :ls_wcoil	and loc_no = :ls_wloc;
			if sqlca.sqlcode <> 0 then
				rollback;
				messagebox('update오류15',"코일마스터[coilmst]UPDATE시 오류가 발생했습니다.~r~n" + sqlca.sqlerrtext,exclamation!)
				return false
			end if
			
			dw_9.retrieve(ls_coilorderdet_order)
			for ll_row = 1 to dw_9.rowcount()
				ls_wcoil = dw_9.object.coil_no[ll_row]
				ls_wloc  = dw_9.object.loc_no[ll_row]
//원코일 이동은 안한다..에의한 스크립 막음
//				ld_w_wid = dw_9.object.wid[ll_row]
