table(column=(type=char(20) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(20) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=char(20) updatewhereclause=yes name=sale_no dbname="sale_no" )
 column=(type=number updatewhereclause=yes name=seq_no dbname="seq_no" )
 column=(type=char(20) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=number updatewhereclause=yes name=order_qty dbname="order_qty" )
 column=(type=number updatewhereclause=yes name=rlse_qty dbname="rlse_qty" )
 column=(type=number updatewhereclause=yes name=scan_qty dbname="scan_qty" )
 retrieve="  SELECT cust_no    = routscan.cust_no
       , cust_name  = c.cust_name
       , scene_code = routscan.scene_code
       , scene_desc = s.scene_desc
       , sale_no    = routscan.sale_no
       , seq_no     = routscan.seq_no
       , item_no    = routscan.item_no
       , item_name  = g.item_name
       , qa         = routscan.qa
       , order_qty  = sd.order_qty
       , rlse_qty   = sd.rlse_qty
       , scan_qty   = routscan.scan_qty
       , salerem    = sd.rem
       , scan_date  = routscan.scan_date
       , scan_no    = routscan.scan_no
       , user_id    = routscan.user_id
       , work_no    = routscan.work_no
       , work_name  = wc.work_name
       , user_name  = l.user_name
    FROM routscan  (nolock)
         LEFT OUTER JOIN (
              SELECT work_no, work_name FROM wc
              UNION ALL
              SELECT work_no, work_name FROM V_WORK
         ) wc ON routscan.work_no   = wc.work_no     
         LEFT OUTER JOIN customer   C (nolock) ON routscan.cust_no    = c.cust_no
         LEFT OUTER JOIN scene      S (nolock) ON routscan.scene_code = s.scene_code
         LEFT OUTER JOIN groupitem  G (nolock) ON routscan.item_no    = g.item_no
         LEFT OUTER JOIN login      L (nolock) ON routscan.user_id    = l.user_id
         LEFT OUTER JOIN saledet   SD (nolock) ON routscan.sale_no = sd.order_no AND routscan.seq_no = sd.seq_no
   WHERE routscan.scan_date between :as_sdate + ' 00:00:00.000' AND :as_edate + ' 23:59:59.999'
" arguments=(("as_sdate", string),("as_edate", string))  sort="cust_name A scene_desc A sale_no A seq_no A item_name A qa A order_qty A rlse_qty A " )
