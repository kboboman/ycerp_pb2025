release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no  crosstab.dynamic = yes grid.lines=0 grid.columnmove=no selected.mouse=no )
header[1](height=80 color="536870912" )
header[2](height=80 color="536870912" )
header[3](height=80 color="536870912" )
summary(height=80 color="536870912" )
footer(height=0 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=품목 dbname="품목" )
 column=(type=number updatewhereclause=yes name=월 dbname="월" )
 column=(type=number updatewhereclause=yes name=수량 dbname="수량" )
 column=(type=number updatewhereclause=yes name=금액 dbname="금액" )
 retrieve="SELECT '년도' = AA.YYYY
     , '월'   = AA.MM
     , '년월' = AA.DO_DATE                                                                                                                  
     , '품목' = AA.ITEM                                                                                                                     
     , '수량' = SUM(AA.CALC_QTY)                                                                                                            
     , '금액' = SUM(AA.AMOUNT)                                                                                                              
  FROM (                                                                                                                                    
       SELECT 'YYYY'    = YEAR(DO.DO_DATE)
            , 'MM'      = MONTH(DO.DO_DATE)
            , 'DO_DATE' = CONVERT(DATETIME, (CONVERT(CHAR(7), DO.DO_DATE, 111) + '/01'), 120)                                               
            , 'ITEM'    = (CASE WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'GACS' THEN 'Y.S.P'                                                     
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'GAZS' THEN 'Y.S.P'                                                     
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'GBMZ' THEN 'S.M.C'                                                     
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'GCYA' THEN 'Y.S.P'                                                     
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'GCYP' THEN 'Y.S.P'                                                     
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'GCYS' THEN 'Y.S.P'                                                     
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'GCYZ' THEN 'Y.S.P'                                                     
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'GZMZ' THEN 'S.M.C'                                                     
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'M1AZ' THEN 'Y.S.P'                                                     
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'M1G8' THEN 'Y.S.P'                                                     
    
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'PACS'  AND SUBSTRING(DODET.ITEM_NO,8,1) = 'B'   THEN 'M-BAR BS'        
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'PACS'  AND SUBSTRING(DODET.ITEM_NO,8,1) = 'K'   THEN 'M-BAR KS'        
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'PACS'  AND SUBSTRING(DODET.ITEM_NO,5,1) = 'O'   THEN 'T-BAR'           
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'PACS'  AND SUBSTRING(DODET.ITEM_NO,5,1) = 'C'   THEN 'T-BAR'           
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'PACS'  AND SUBSTRING(DODET.ITEM_NO,5,1) = 'G'   THEN 'T-BAR'           
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'PACS'  AND SUBSTRING(DODET.ITEM_NO,5,3) = 'MTB' THEN 'T-BAR'           
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'PACS'  AND SUBSTRING(DODET.ITEM_NO,5,3) = 'CAC' THEN 'Y.S.P'           
    
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'PASS'  AND SUBSTRING(DODET.ITEM_NO,5,1) = 'A'   THEN 'APT M-BAR'       
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'PASS'  AND SUBSTRING(DODET.ITEM_NO,5,1) = 'B'   THEN '보강심'          
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'PASS'  AND SUBSTRING(DODET.ITEM_NO,5,1) = 'J'   THEN '주공용 M-BAR'    
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'PAWS'  AND SUBSTRING(DODET.ITEM_NO,5,3) = 'CHS' THEN 'CH-STUD'         
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'PAWS'  AND SUBSTRING(DODET.ITEM_NO,5,3) = 'RUN' THEN 'RUNNER'          
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'PAWS'  AND SUBSTRING(DODET.ITEM_NO,5,3) = 'SQS' THEN 'SQ-STUD'         
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'PAWS'  AND SUBSTRING(DODET.ITEM_NO,5,3) = 'STD' THEN 'STUD'            
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'PAWS' THEN 'Y.S.P'                                                     
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'PAZS' THEN 'Y.S.P'                                                     
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'PBCA'  AND SUBSTRING(DODET.ITEM_NO,5,1) = 'T'   THEN 'AL TILE'         
    
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'PCYA' THEN 'Y.S.P'                                                     
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'PCYS' THEN 'Y.S.P'                                                     
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'PZAA' THEN 'Y.S.P'                                                     
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'PZYS' THEN 'Y.S.P'                                                     
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'PZZS' THEN 'Y.S.P'                                                     
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = 'PZZZ' THEN 'Y.S.P'                                                     
                                /*                                                                                                          
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = ''     THEN '오픈판넬'                                                  
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = ''     THEN '캐링'                                                      
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = ''     THEN '스판드럴'                                                  
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = ''     THEN 'AL 100S'                                                   
                                WHEN SUBSTRING(DODET.ITEM_NO,1,4) = ''     THEN 'AL 몰딩'                                                   
                                */                                                                                                          
                                ELSE             '기타'                                                                                     
                            END)                                                                                                            
            , 'CALC_QTY' = ROUND(DBO.UF_GETQTY(DODET.ITEM_NO, DODET.QA, DODET.UOM, DODET.SHIP_QTY),2,1)                                     
            , 'AMOUNT'   = ROUND(DBO.UF_GETQTY(DODET.ITEM_NO, DODET.QA, DODET.UOM, DODET.SHIP_QTY),2,1) * DODET.PRICE                       
         FROM DO                                                                                                                            
            , DODET                                                                                                                         
            , GROUPITEM                                                                                                                     
        WHERE ( DO.DO_NO               = DODET.DO_NO        )                                                                               
          AND ( DODET.ITEM_NO          = GROUPITEM.ITEM_NO  )                                                                               
          AND ( DO.INVOICE_PRINT       = 'Y'                )                                                                               
          AND ( YEAR(DO.DO_DATE)      IN ( (YEAR(GETDATE()) - 1), YEAR(GETDATE()) ) )                                                       
          AND ( MONTH(DO.DO_DATE)     <= MONTH(GETDATE())   )                                                                               
    
       ) AA                                                                                                                                 
   GROUP BY AA.YYYY, AA.MM, AA.DO_DATE, AA.ITEM                                                                                                             
"  sort="품목 A 월 A " )
group(level=1 header.height=0 trailer.height=104 by=("품목" ) header.color="536870912" trailer.color="536870912" )
