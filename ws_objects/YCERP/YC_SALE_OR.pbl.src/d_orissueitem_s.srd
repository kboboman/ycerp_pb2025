footer(height=88 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(20) updatewhereclause=yes name=iqa dbname="iqa" )
 column=(type=char(10) update=yes updatewhereclause=yes name=user_id dbname="user_id" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 retrieve="  SELECT DISTINCT item_no   = a.item_no
       , item_name = a.item_name
       , qa        = a.qa
       , iqa       = a.iqa
       , user_id   = b.user_id
       , user_name = b.user_name
    FROM ( /* 마스터 기준 */
              SELECT item_no    = i.item_no
                   , item_name  = g.item_name
                   , qa         = isnull(i.qa,'')
                   , user_id    = i.user_id
                   , user_name  = l.user_name
                FROM issue_item I with (nolock) 
                     LEFT OUTER JOIN groupitem G with (nolock) on i.item_no = g.item_no
                     LEFT OUTER JOIN login     L with (nolock) on i.user_id = l.user_id AND l.use_flag = 'Y'
         ) B

         LEFT OUTER JOIN ( /* 수주품목을 마스터 규격으로 변경 */
              SELECT a.item_no, a.item_name
                   , qa        = (case when iqa is null then '' else a.qa end)
                   , iqa       = a.iqa
                   , user_id   = ''
                   , user_name = ''
                FROM ( /* 수주품목, 규격으로 마스터 조회 */
                     SELECT s.order_no, s.seq_no, s.item_no, g.item_name
                          , s.qa
                          , iqa   = (SELECT top 1 qa FROM issue_item WHERE item_no = s.item_no)
                       FROM saledet S with (nolock)
                            LEFT OUTER JOIN groupitem G with (nolock) on s.item_no = g.item_no
                      WHERE s.order_no = :as_orderno
                    ) A
         ) A ON a.item_no = b.item_no
   WHERE a.item_no IS NOT NULL
" arguments=(("as_orderno", string)) )
