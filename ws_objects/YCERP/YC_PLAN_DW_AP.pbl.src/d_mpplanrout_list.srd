table(column=(type=char(10) updatewhereclause=yes name=item_no dbname="ITEM_NO" )
 column=(type=char(60) updatewhereclause=yes name=item_nm dbname="ITEM_NM" )
 column=(type=long updatewhereclause=yes name=op1 dbname="OP1" )
 column=(type=char(10) updatewhereclause=yes name=wc1 dbname="WC1" )
 column=(type=char(10) updatewhereclause=yes name=wcnm1 dbname="WCNM1" )
 column=(type=char(10) updatewhereclause=yes name=assy1 dbname="ASSY1" )
 column=(type=char(60) updatewhereclause=yes name=assynm1 dbname="ASSYNM1" )
 column=(type=long updatewhereclause=yes name=op2 dbname="OP2" )
 column=(type=char(10) updatewhereclause=yes name=wc2 dbname="WC2" )
 column=(type=char(10) updatewhereclause=yes name=wcnm2 dbname="WCNM2" )
 column=(type=char(10) updatewhereclause=yes name=assy2 dbname="ASSY2" )
 column=(type=char(60) updatewhereclause=yes name=assynm2 dbname="ASSYNM2" )
 column=(type=long updatewhereclause=yes name=op3 dbname="OP3" )
 column=(type=char(10) updatewhereclause=yes name=wc3 dbname="WC3" )
 column=(type=char(10) updatewhereclause=yes name=wcnm3 dbname="WCNM3" )
 column=(type=char(10) updatewhereclause=yes name=assy3 dbname="ASSY3" )
 column=(type=char(60) updatewhereclause=yes name=assynm3 dbname="ASSYNM3" )
 column=(type=long updatewhereclause=yes name=op4 dbname="OP4" )
 column=(type=char(10) updatewhereclause=yes name=wc4 dbname="WC4" )
 column=(type=char(10) updatewhereclause=yes name=wcnm4 dbname="WCNM4" )
 column=(type=char(10) updatewhereclause=yes name=assy4 dbname="ASSY4" )
 column=(type=char(60) updatewhereclause=yes name=assynm4 dbname="ASSYNM4" )
 column=(type=long updatewhereclause=yes name=op5 dbname="OP5" )
 column=(type=char(10) updatewhereclause=yes name=wc5 dbname="WC5" )
 column=(type=char(10) updatewhereclause=yes name=wcnm5 dbname="WCNM5" )
 column=(type=char(10) updatewhereclause=yes name=assy5 dbname="ASSY5" )
 column=(type=char(60) updatewhereclause=yes name=assynm5 dbname="ASSYNM5" )
 column=(type=long updatewhereclause=yes name=chk dbname="CHK" )
 retrieve=" SELECT ITEM_NO= MAX(A.ITEM_NO )
      , ITEM_NM= MAX(A.ITEM_NM )
      , OP1    = CONVERT(INT,MAX(A.OP1))
      , WC1    = MAX(A.WC1     )
      , WCNM1  = MAX(A.WCNM1   )
      , ASSY1  = MAX(A.ASSY1   )
      , ASSYNM1= MAX(A.ASSYNM1 )
      
      , OP2    = CONVERT(INT,MAX(A.OP2))
      , WC2    = MAX(A.WC2     )
      , WCNM2  = MAX(A.WCNM2   )
      , ASSY2  = MAX(A.ASSY2   )
      , ASSYNM2= MAX(A.ASSYNM2 )
      
      , OP3    = CONVERT(INT,MAX(A.OP3))
      , WC3    = MAX(A.WC3     )
      , WCNM3  = MAX(A.WCNM3   )
      , ASSY3  = MAX(A.ASSY3   )
      , ASSYNM3= MAX(A.ASSYNM3 )
      
      , OP4    = CONVERT(INT,MAX(A.OP4))
      , WC4    = MAX(A.WC4     )
      , WCNM4  = MAX(A.WCNM4   )
      , ASSY4  = MAX(A.ASSY4   )
      , ASSYNM4= MAX(A.ASSYNM4 )
      
      , OP5    = CONVERT(INT,MAX(A.OP5))
      , WC5    = MAX(A.WC5     )
      , WCNM5  = MAX(A.WCNM5   )
      , ASSY5  = MAX(A.ASSY5   )
      , ASSYNM5= MAX(A.ASSYNM5 )
      , CHK    = 0
   FROM (
        SELECT ITEM_NO= AA.ITEM_NO
             , ITEM_NM= AA.ITEM_NAME
             , OP1    = (CASE WHEN AA.OPERATION = 1 THEN '1'          ELSE '' END)
             , WC1    = (CASE WHEN AA.OPERATION = 1 THEN AA.WC_NO     ELSE '' END)
             , WCNM1  = (CASE WHEN AA.OPERATION = 1 THEN AA.WORK_NAME ELSE '' END)
             , ASSY1  = (CASE WHEN AA.OPERATION = 1 THEN AA.ASSEMBLY  ELSE '' END)
             , ASSYNM1= (CASE WHEN AA.OPERATION = 1 THEN AA.ASSEM_NM  ELSE '' END)
             
             , OP2    = (CASE WHEN AA.OPERATION = 2 THEN '2'          ELSE '' END)
             , WC2    = (CASE WHEN AA.OPERATION = 2 THEN AA.WC_NO     ELSE '' END)
             , WCNM2  = (CASE WHEN AA.OPERATION = 2 THEN AA.WORK_NAME ELSE '' END)
             , ASSY2  = (CASE WHEN AA.OPERATION = 2 THEN AA.ASSEMBLY  ELSE '' END)
             , ASSYNM2= (CASE WHEN AA.OPERATION = 2 THEN AA.ASSEM_NM  ELSE '' END)
             
             , OP3    = (CASE WHEN AA.OPERATION = 3 THEN '3'          ELSE '' END)
             , WC3    = (CASE WHEN AA.OPERATION = 3 THEN AA.WC_NO     ELSE '' END)
             , WCNM3  = (CASE WHEN AA.OPERATION = 3 THEN AA.WORK_NAME ELSE '' END)
             , ASSY3  = (CASE WHEN AA.OPERATION = 3 THEN AA.ASSEMBLY  ELSE '' END)
             , ASSYNM3= (CASE WHEN AA.OPERATION = 3 THEN AA.ASSEM_NM  ELSE '' END)
             
             , OP4    = (CASE WHEN AA.OPERATION = 4 THEN '4'          ELSE '' END)
             , WC4    = (CASE WHEN AA.OPERATION = 4 THEN AA.WC_NO     ELSE '' END)
             , WCNM4  = (CASE WHEN AA.OPERATION = 4 THEN AA.WORK_NAME ELSE '' END)
             , ASSY4  = (CASE WHEN AA.OPERATION = 4 THEN AA.ASSEMBLY  ELSE '' END)
             , ASSYNM4= (CASE WHEN AA.OPERATION = 4 THEN AA.ASSEM_NM  ELSE '' END)
             
             , OP5    = (CASE WHEN AA.OPERATION = 5 THEN '5'          ELSE '' END)
             , WC5    = (CASE WHEN AA.OPERATION = 5 THEN AA.WC_NO     ELSE '' END)
             , WCNM5  = (CASE WHEN AA.OPERATION = 5 THEN AA.WORK_NAME ELSE '' END)
             , ASSY5  = (CASE WHEN AA.OPERATION = 5 THEN AA.ASSEMBLY  ELSE '' END)
             , ASSYNM5= (CASE WHEN AA.OPERATION = 5 THEN AA.ASSEM_NM  ELSE '' END)
          FROM (
               SELECT A.ITEM_NO             
                    , B.ITEM_NAME
                    , A.OPERATION           
                    , A.WC_NO               
                    , D.WORK_NAME
                    , A.ASSEMBLY            
                    , ASSEM_NM = C.ITEM_NAME
                 FROM ROUT A
                      LEFT OUTER JOIN GROUPITEM B  ON A.ITEM_NO  = B.ITEM_NO AND B.USE_FLAG = 'Y'
                      LEFT OUTER JOIN GROUPITEM C  ON A.ASSEMBLY = C.ITEM_NO AND C.USE_FLAG = 'Y'
                      LEFT OUTER JOIN WC        D  ON A.WC_NO    = D.WORK_NO
               ) AA
        ) A
  WHERE A.ITEM_NM  <> ''
  GROUP BY ITEM_NO
  ORDER BY ITEM_NM, OP1
" )
