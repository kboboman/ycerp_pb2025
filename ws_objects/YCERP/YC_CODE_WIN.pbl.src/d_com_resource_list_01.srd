table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=management_no dbname="yc_com_resource.management_no" )
 column=(type=char(4) update=yes updatewhereclause=yes name=affiliate_type dbname="yc_com_resource.affiliate_type" )
