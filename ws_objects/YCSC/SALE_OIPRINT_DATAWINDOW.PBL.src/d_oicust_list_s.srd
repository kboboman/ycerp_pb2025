$PBExportHeader$d_oicust_list_s.srd
$PBExportComments$판매거래처 출고관리 현황(2004/03/15,정갑용)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=80 color="12639424" )
footer(height=0 color="536870912" )
detail(height=84 color="536870912" )
table(column=(type=char(11) updatewhereclause=yes name=do_spot_code dbname="do.spot_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 column=(type=char(14) updatewhereclause=yes name=do_do_no dbname="do.do_no" )
 column=(type=long updatewhereclause=yes name=dodet_oi_no dbname="dodet.oi_no" )
 column=(type=char(10) updatewhereclause=yes name=dodet_item_no dbname="dodet.item_no" )
 column=(type=char(20) updatewhereclause=yes name=dodet_qa dbname="dodet.qa" )
 column=(type=char(2) updatewhereclause=yes name=dodet_uom dbname="dodet.uom" )
 column=(type=decimal(2) updatewhereclause=yes name=dodet_ship_qty dbname="dodet.ship_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=dodet_price dbname="dodet.price" )
 column=(type=decimal(4) updatewhereclause=yes name=dodet_rate_cash dbname="dodet.rate_cash" )
 column=(type=datetime updatewhereclause=yes name=do_do_date dbname="do.do_date" )
 column=(type=char(10) updatewhereclause=yes name=do_fob dbname="do.fob" )
 column=(type=char(30) updatewhereclause=yes name=do_ship_flag dbname="ship_flag" )
 column=(type=decimal(0) updatewhereclause=yes name=do_ship_amount dbname="do.ship_amount" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_rate dbname="do.do_rate" )
 column=(type=char(3) updatewhereclause=yes name=do_curr_code dbname="do.curr_code" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_cash dbname="do.do_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_total dbname="do.do_total" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(1) updatewhereclause=yes name=do_shipamt_case dbname="do.shipamt_case" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=decimal(4) updatewhereclause=yes name=compute_0022 dbname="compute_0022" )
 column=(type=decimal(4) updatewhereclause=yes name=customer_balance_amt dbname="customer.balance_amt" )
 column=(type=datetime updatewhereclause=yes name=c_start dbname="c_start" )
 column=(type=datetime updatewhereclause=yes name=c_end dbname="c_end" )
 column=(type=char(4) updatewhereclause=yes name=do_cust_no dbname="do.cust_no" )
 retrieve=" SELECT  do.spot_code,   
         scene.scene_desc,   
         do.do_no,   
         dodet.oi_no,   
         dodet.item_no,   
         dodet.qa,   
         dodet.uom,   
         dodet.ship_qty,   
         dodet.price,   
         dodet.rate_cash,   
         do.do_date,   
         do.fob,   
         ship_flag = dbo.uf_getshipflag(do.ship_flag),   
         do.ship_amount,   
         do.do_rate,   
         do.curr_code,   
         do.do_cash,   
         do.do_total,   
         groupitem.item_name,   
         do.shipamt_case,
			customer.cust_name,
			sum(aroivc.amount),
			customer.balance_amt,
         c_start = convert(smalldatetime, :ad_start, 111),   
         c_end = convert(smalldatetime, :ad_end, 111),
	    do.cust_no
   FROM do with(nolock) inner join dodet with(nolock) on do.do_no = dodet.do_no         
                                                                                                              and  do.do_date between :ad_start and :ad_end                                                                                                              
                                                          inner join groupitem with(nolock) on dodet.item_no = groupitem.item_no
                                                          inner join customer with(nolock) on  do.cust_no = customer.cust_no
                                                          left outer join scene with(nolock) on do.cust_no = scene.cust_no 
                                                                                                                                    and do.spot_code  = scene.scene_code
                                                           left outer join aroivc with(nolock) on  do.cust_no = aroivc.cust_no 
                                                                                                                                     and do.do_date = aroivc.oi_date
         where ( do.do_date between :ad_start and :ad_end ) and
			   ( customer.credit_level = 'E' ) and
		        ( customer.balance_amt <> 0 ) and
			  (
                    ( :as_area = 'B0001' and do.area_no = :as_area ) or
			    ( :as_area = 'T0001' and do.area_no = :as_area ) or
			    ( :as_area <> 'B0001' and :as_area <> 'T0001' and do.area_no <> 'B0001' ) 
			  ) and
     		      ( aroivc.delete_key = 'N' )
/*
    FROM do,   
         dodet,   
         scene,   
         groupitem,   
         customer,
			aroivc
   WHERE ( do.do_no = dodet.do_no ) and  
         ( do.cust_no *= scene.cust_no ) and  
         ( do.spot_code *= scene.scene_code ) and  
         ( dodet.item_no = groupitem.item_no ) and  
         ( do.cust_no = customer.cust_no ) and  
         ( do.do_date between :ad_start and :ad_end ) and
			( customer.credit_level = 'E' ) and
			( customer.balance_amt <> 0 ) and
			( ( :as_area = 'B0001' and do.area_no = :as_area ) or
			  ( :as_area = 'T0001' and do.area_no = :as_area ) or
			  ( :as_area <> 'B0001' and :as_area <> 'T0001' and do.area_no <> 'B0001' ) ) and
			( ( do.cust_no *= aroivc.cust_no ) and  
           ( do.do_date *= aroivc.oi_date ) and  
           ( aroivc.delete_key = 'N' ) )
*/
group by do.spot_code,   
         scene.scene_desc,   
         do.do_no,   
         dodet.oi_no,   
         dodet.item_no,   
         dodet.qa,   
         dodet.uom,   
         dodet.ship_qty,   
         dodet.price,   
         dodet.rate_cash,   
         do.do_date,   
         do.fob,   
         do.ship_flag,   
         do.ship_amount,   
         do.do_rate,   
         do.curr_code,   
         do.do_cash,   
         do.do_total,   
         groupitem.item_name,   
         do.shipamt_case,
			customer.cust_name,
			customer.balance_amt,
			do.cust_no" arguments=(("as_area", string),("ad_start", date),("ad_end", date))  sort="customer_cust_name A scene_scene_desc A do_do_date A do_do_no A dodet_oi_no A " )
group(level=1 header.height=0 trailer.height=84 by=("customer_cust_name" ) header.color="536870912" trailer.color="15780518" )
