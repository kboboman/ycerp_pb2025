table(column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=datetime updatewhereclause=yes name=order_date dbname="order_date" )
 column=(type=char(14) updatewhereclause=yes name=order_no dbname="saledet.order_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="saledet.seq_no" )
 column=(type=char(10) updatewhereclause=yes name=saledet_item_no dbname="saledet.item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="groupitem.item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="saledet.qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="saledet.uom" )
 column=(type=decimal(2) updatewhereclause=yes name=order_qty dbname="saledet.order_qty" )
 retrieve="SELECT cust_name  = c.cust_name
     , scene_desc = d.scene_desc
     , order_date = b.order_date
     , a.order_no
     , a.seq_no
     , a.item_no
     , g.item_name
     , a.qa 
     , a.uom
     , a.order_qty
  FROM saledet a
       LEFT OUTER JOIN sale b       ON a.order_no = b.order_no
       LEFT OUTER JOIN customer c   ON b.cust_no  = c.cust_no
       LEFT OUTER JOIN scene    d   ON b.scene_code = d.scene_code
       LEFT OUTER JOIN GROUPITEM G  ON a.ITEM_NO  = G.ITEM_NO
 WHERE b.order_date    >= Dateadd(month, -1, getdate()) 
   AND NOT (substring(a.item_no,1,2) IN ('M1','M2','M3'))
   AND a.uom   IN ('EA', 'M2', 'SS', 'M')
   AND login_id               = :as_userid
   AND CHARINDEX('X', a.qa)   > 0
   AND (substring(a.qa, 4,1) <> 'X' OR
        substring(a.qa, 9,1) <> 'X' OR
        substring(a.qa,14,1) <> 'X'
       )
   AND ((b.open_close  = 'O'                    ) OR 
        (b.open_close  = 'C' AND a.rlse_qty <> 0) OR
        (b.open_close  = 'O' AND a.rlse_qty  < 0)
       ) /* 마감된 수주는 출고수량 ZERO인것은 SKIP */
 ORDER BY order_date desc
" arguments=(("as_userid", string)) )
