$PBExportHeader$d_mpsfcdayuser_s.srd
$PBExportComments$일자별 작업장 작업자 추가
release 8;
datawindow(units=0 timer_interval=0 color=67108864 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no rows_per_detail = 10 )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=user_name dbname="sfcdayuser.user_name" )
 column=(type=char(20) updatewhereclause=yes name=team_nm dbname="sfcdayuser.team_nm" )
 column=(type=char(30) updatewhereclause=yes name=team_org dbname="team_org" )
 column=(type=long updatewhereclause=yes name=sortkey dbname="sortkey" )
 column=(type=long updatewhereclause=yes name=sortkey2 dbname="sortkey2" )
 retrieve="  SELECT login.user_name
       , team_nm
       , team_org  = sfcdayuser.team_org
       , sortkey   = (case when team_nm = wc.work_name then 1
                           when team_nm = '일용'       then 3
                           else 2
                      end)
       , sortkey2  = login.cat
    FROM sfcdayuser   
         LEFT OUTER JOIN (
              SELECT user_id, user_name, team_nm = '', cat = 1 FROM login
              UNION ALL
              SELECT user_id = sabun, user_name = name_kor, team_nm, cat = 2
                FROM v_insabase
               WHERE ((:as_area = 'S0001' AND acc_cd = '01') OR
                      (:as_area = 'T0001' AND acc_cd = '06')
                     )
              UNION ALL
              SELECT DISTINCT sfcworkman.user_id, name_kor, team_nm = work_nm, cat = 3
                FROM sfcworkman
               WHERE day_labor = 'Y'
         ) login  on sfcdayuser.user_id  = login.user_id
         LEFT OUTER JOIN wc  ON sfcdayuser.wc_no = wc.work_no
   WHERE ( sfcdayuser.area_no  = :as_area      ) 
     AND ( sfcdayuser.wc_no    = :as_wc        ) 
     AND ( sfcdayuser.sfc_date = :ad_date      ) 
" arguments=(("as_area", string),("as_wc", string),("ad_date", date))  sort="sortkey A sortkey2 A team_nm A user_name A " )
