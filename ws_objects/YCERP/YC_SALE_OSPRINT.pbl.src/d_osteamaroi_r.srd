								when 10 then
									 cust_aim.inv_10
								when 11 then
									 cust_aim.inv_11
								when 12 then
									 cust_aim.inv_12 
							end)/1.1)/1000,
			cur_minv = sum((case :ai_mon  
								when 01 then
									 opeom_b.inv_01
								when 02 then
									 opeom_b.inv_02
								when 03 then
									 opeom_b.inv_03
								when 04 then
									 opeom_b.inv_04
								when 05 then
									 opeom_b.inv_05
								when 06 then
									 opeom_b.inv_06
								when 07 then
									 opeom_b.inv_07
								when 08 then
									 opeom_b.inv_08
								when 09 then
									 opeom_b.inv_09
								when 10 then
									 opeom_b.inv_10
								when 11 then
									 opeom_b.inv_11
								when 12 then
									 opeom_b.inv_12 
							end)/1.1)/1000,
			cur_amcoll = sum((case :ai_mon  
								when 01 then
									 cust_aim.del_01
								when 02 then
									 cust_aim.del_02
								when 03 then
									 cust_aim.del_03
								when 04 then
									 cust_aim.del_04
								when 05 then
									 cust_aim.del_05
								when 06 then
									 cust_aim.del_06
								when 07 then
									 cust_aim.del_07
								when 08 then
									 cust_aim.del_08
								when 09 then
									 cust_aim.del_09
								when 10 then
									 cust_aim.del_10
								when 11 then
									 cust_aim.del_11
								when 12 then
									 cust_aim.del_12 
							end))/1000,
			cur_mcoll = sum((case :ai_mon  
								when 01 then
									 opeom_b.coll_01
								when 02 then
									 opeom_b.coll_02
								when 03 then
									 opeom_b.coll_03
								when 04 then
									 opeom_b.coll_04
								when 05 then
									 opeom_b.coll_05
								when 06 then
									 opeom_b.coll_06
								when 07 then
									 opeom_b.coll_07
								when 08 then
									 opeom_b.coll_08
								when 09 then
									 opeom_b.coll_09
								when 10 then
									 opeom_b.coll_10
								when 11 then
									 opeom_b.coll_11
								when 12 then
									 opeom_b.coll_12 
							end))/1000
    FROM customer with(nolock) inner join   
         (
				select user_id, 
						team_code = (case  when login.team_code = '71000' or login.team_code ='72000' or login.team_code ='73000' or login.team_code ='74000' or
														login.team_code = '75000' or login.team_code ='76000' or login.team_code ='77000' or login.team_code ='78000' or login.team_code ='79000' 
														then login.team_code 
												 else '99000' end),   
						team_name = (case  when login.team_code = '71000' or login.team_code ='72000' or login.team_code ='73000' or login.team_code ='74000' or
														login.team_code = '75000' or login.team_code ='76000'
														then team.team_name 
												 when login.team_code = '77000' or login.team_code ='78000' or login.team_code ='79000' 
														then '서부점' 
												 else '기타' end),   
						user_name = (case  when login.team_code = '71000' or login.team_code ='72000' or login.team_code ='73000' or login.team_code ='74000' or
														login.team_code = '75000' or login.team_code ='76000'
														then login.user_name 
												 when login.team_code = '77000'
														then '서부-매장'
												 when login.team_code = '78000'
														then '서부-영업' 
												 when login.team_code = '79000' 
														then '서부-채권' 
												 else '공장,현금판매' end),
						rank_no   = (case  when login.team_code = '71000' or login.team_code ='72000' or login.team_code ='73000' or login.team_code ='74000' or
														login.team_code = '75000' or login.team_code ='76000' or login.team_code ='77000' or login.team_code ='78000' or login.team_code ='79000' 
														then login.rank_no 
												 else '00' end),
						rank      = (case  when login.team_code = '71000' or login.team_code ='72000' or login.team_code ='73000' or login.team_code ='74000' or
														login.team_code = '75000' or login.team_code ='76000' or login.team_code ='77000' or login.team_code ='78000' or login.team_code ='79000' 
														then login.rank 
												 else '外' end) 
				from login with(nolock) INNER JOIN team with(nolock) ON login.team_code = team.team_code
				where use_flag = 'Y'
		 ) UT on   customer.salesman = UT.user_id and ( customer.salesman like :as_userid )
                        left outer join cust_aim with(nolock) on customer.cust_no = cust_aim.cust_code and ( datepart(year,cust_aim.tar_year) = :ai_year )
                        left outer join opeom opeom_a with(nolock) on customer.cust_no = opeom_a.cust_no and ( datepart(year,opeom_a.eom_year) = :ai_year - 1 ) 
                        left outer join opeom opeom_b with(nolock) on customer.cust_no = opeom_b.cust_no and ( datepart(year,opeom_b.eom_year) = :ai_year )
   WHERE ( customer.cust_flag = 'N' ) and
		   	( customer.cust_type <> 'E' )
	group by UT.team_code,   
         UT.team_name,   
         UT.user_name,
			UT.rank_no,
			UT.rank
			

