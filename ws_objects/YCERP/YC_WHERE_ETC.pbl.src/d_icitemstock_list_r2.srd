table(column=(type=long updatewhereclause=yes identity=yes name=id dbname="itemstockdet.id" )
 column=(type=char(10) updatewhereclause=yes name=loc_no dbname="itemstockdet.loc_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="itemstockdet.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="itemstockdet.qa" )
 column=(type=decimal(0) updatewhereclause=yes name=qty dbname="itemstockdet.qty" )
 column=(type=datetime updatewhereclause=yes name=user_date dbname="itemstockdet.user_date" )
 column=(type=char(1) updatewhereclause=yes name=reason_code dbname="itemstockdet.reason_code" initial="Z" )
 column=(type=char(16) updatewhereclause=yes name=order_no dbname="itemstockdet.order_no" )
 column=(type=long updatewhereclause=yes name=seq dbname="itemstockdet.seq" )
 column=(type=char(14) updatewhereclause=yes name=sale_no dbname="itemstockdet.sale_no" )
 column=(type=long updatewhereclause=yes name=sale_seq dbname="itemstockdet.sale_seq" )
 column=(type=char(1) updatewhereclause=yes name=itemstockdet_close_yn dbname="itemstockdet.close_yn" )
 column=(type=char(1) updatewhereclause=yes name=itemstockdet_kind dbname="itemstockdet.kind" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="GroupItem.item_name" )
 column=(type=char(4) updatewhereclause=yes name=sale_cust_no dbname="sale.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="SCENE.scene_desc" )
 retrieve="  SELECT  itemstockdet.id
		      , itemstockdet.loc_no   
			 , itemstockdet.item_no   
			 , itemstockdet.qa   
			 , itemstockdet.qty   
			 , itemstockdet.user_date   
			 , itemstockdet.reason_code   
			 , itemstockdet.order_no
		      , itemstockdet.seq
		      , itemstockdet.sale_no
		      , itemstockdet.sale_seq
		      , itemstockdet.close_yn
		      , itemstockdet.kind
			 , groupitem.item_name   
			 , sale.cust_no
			 , customer.cust_name
			 , scene.scene_desc
    FROM itemstockdet left outer join sale on itemstockdet.sale_no = sale.order_no
					            left outer join scene on sale.scene_code = scene.scene_code
					            left outer join customer on sale.cust_no = customer.cust_no
							  inner join groupitem on  itemstockdet.item_no = groupitem.item_no
   WHERE itemstockdet.loc_no      = :as_loc
		 and itemstockdet.item_no like :as_item_no
           and itemstockdet.close_yn = 'O'
" arguments=(("as_loc", string),("as_item_no", string))  sort="qa A sale_no A sale_seq A cust_name A scene_desc A " )
