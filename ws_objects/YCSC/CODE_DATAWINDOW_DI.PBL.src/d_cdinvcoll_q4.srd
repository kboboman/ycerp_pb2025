table(column=(type=char(4) update=yes updatewhereclause=yes name=cust_no dbname="customer.cust_no" )
 column=(type=char(50) update=yes updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=char(20) update=yes updatewhereclause=yes name=captain_name dbname="customer.captain_name" )
 column=(type=datetime updatewhereclause=yes name=birthday dbname="birthday" )
 column=(type=long updatewhereclause=yes name=cap_birthday dbname="cap_birthday" )
 column=(type=char(3) updatewhereclause=yes name=class dbname="customer.class" )
 column=(type=char(11) updatewhereclause=yes name=class_bigo dbname="class_bigo" )
 column=(type=char(50) updatewhereclause=yes name=customer_sale_address dbname="customer.sale_address" )
 column=(type=char(1) updatewhereclause=yes name=colllevel dbname="colllevel" )
 column=(type=char(10) updatewhereclause=yes name=top_level dbname="customer.top_level" )
 column=(type=char(10) update=yes updatewhereclause=yes name=price_level dbname="customer.price_level" )
 column=(type=char(1) update=yes updatewhereclause=yes name=credit_level dbname="customer.credit_level" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=credit_limit dbname="customer.credit_limit" )
 column=(type=char(1) update=yes updatewhereclause=yes name=level_grade dbname="customer.level_grade" )
 column=(type=datetime update=yes updatewhereclause=yes name=collect_ymd dbname="customer.collect_ymd" )
 column=(type=char(50) updatewhereclause=yes name=catain_value dbname="customer.catain_value" )
 column=(type=char(10) update=yes updatewhereclause=yes name=joint_head dbname="customer.joint_head" )
 column=(type=char(20) update=yes updatewhereclause=yes name=jointor dbname="customer.jointor" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=joint_amt dbname="customer.joint_amt" )
 column=(type=char(50) updatewhereclause=yes name=joint_value dbname="customer.joint_value" )
 column=(type=char(50) update=yes updatewhereclause=yes name=dambo_rem dbname="customer.dambo_rem" )
 column=(type=datetime update=yes updatewhereclause=yes name=dambo_ymd dbname="customer.dambo_ymd" )
 column=(type=datetime updatewhereclause=yes name=customer_dambo_ymde dbname="customer.dambo_ymde" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=dambo_amt dbname="customer.dambo_amt" )
 column=(type=char(50) updatewhereclause=yes name=dambo_value dbname="customer.dambo_value" )
 column=(type=char(255) update=yes updatewhereclause=yes name=dambo_bigo dbname="customer.dambo_bigo" )
 column=(type=char(30) updatewhereclause=yes name=captain_relation dbname="customer.captain_relation" )
 column=(type=char(50) updatewhereclause=yes name=license_name dbname="custinfo.license_name" )
 column=(type=char(255) updatewhereclause=yes name=custinfo_rem5 dbname="rem5" )
 column=(type=decimal(0) updatewhereclause=yes name=sale_insurance dbname="customer.sale_insurance" )
 column=(type=long updatewhereclause=yes name=sale_insurance_gigan dbname="customer.sale_insurance_gigan" )
 column=(type=char(10) updatewhereclause=yes name=sale_insurance_start_date dbname="customer.sale_insurance_start_date" )
 column=(type=char(10) updatewhereclause=yes name=sale_insurance_end_date dbname="customer.sale_insurance_end_date" )
 column=(type=char(50) updatewhereclause=yes name=sale_insurance_bigo dbname="customer.sale_insurance_bigo" )
 retrieve="  SELECT a.cust_no   
       , a.cust_name   
       , a.captain_name   
       , birthday     = a.cap_birthday
       , cap_birthday = datediff(year,a.cap_birthday, getdate())
       , a.class
       , class_bigo = (case when a.class = 'A1'  then '(사월회)'
                            when a.class = 'A2'  then '(공략업체)'
                            when a.class = 'A3'  then '(우량,중점)'
                            when a.class = 'B1'  then '(유통업체)'
                            when a.class = 'B2'  then '(년간,입찰)'
                            when a.class = 'B3'  then '(생산업체)'
                            when a.class = 'C1'  then '(중간업체)'
                            when a.class = 'C11' then '(중간-채권)'
                            when a.class = 'C2'  then '(소액업체)'
                            when a.class = 'C22' then '(소액-채권)'
                            when a.class = 'D'   then '(장기고액)'
                            when a.class = 'X1'  then '(단발,특수)'
                            when a.class = 'X2'  then '(채권회수)'
                            when a.class = 'X3'  then '(관망,대기)'
                       end)
       , a.sale_address
       , colllevel    = '' /*vc.colllevel*/
       , a.top_level
       , a.price_level   
       , a.credit_level   
       , a.credit_limit   
       , a.level_grade   
       , a.collect_ymd   
       , a.catain_value
       , a.joint_head   
       , a.jointor   
       , a.joint_amt   
       , a.joint_value
       , a.dambo_rem   
       , a.dambo_ymd   
       , a.dambo_ymde   
       , a.dambo_amt   
       , a.dambo_value
       , a.dambo_bigo   
       , a.captain_relation
         
       , b.license_name
       , rem5 = space(255)
	  , a.sale_insurance			
       , a.sale_insurance_gigan			
       , a.sale_insurance_start_date			
       , a.sale_insurance_end_date			
       , a.sale_insurance_bigo	
    FROM customer A
         LEFT OUTER JOIN custinfo B ON a.cust_no = b.cust_no
         /*LEFT OUTER JOIN v_customer VC ON a.cust_no = vc.cid*/
   WHERE ( a.cust_no = :as_custno )
" arguments=(("as_custno", string)) )
