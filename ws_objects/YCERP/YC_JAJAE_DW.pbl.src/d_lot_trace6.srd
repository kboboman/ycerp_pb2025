 column=(type=char(10) update=yes updatewhereclause=yes name=area_no dbname="area_no" )
 retrieve="  SELECT coil_no      = sfcuse.coil_no
       , order_no     = sfcuse.order_no          
       , wc_no        = sfcuse.wc_no             
       , use_date     = sfcuse.use_date          
       , item_name    = groupitem.item_name      
       , item_no      = sfcuse.item_no           
       , qa           = sfcuse.qa                
       , uom          = sfcuse.uom               
       , use_qty      = sfcuse.use_qty           
       , coil_no      = sfcuse.coil_no           
       , rem_lot      = sfcuse.rem_lot           
       , color        = sfcuse.color             
       , color_type   = sfcuse.color_type        
       , loc_no       = sfcuse.loc_no            
       , loc_name     = location.loc_name            
       , coil_type    = sfcuse.coil_type         
       , cnt          = sfcuse.cnt               
       , unit_qty     = sfcuse.unit_qty          
       , mod_qty      = sfcuse.mod_qty           
       , division     = sfcuse.division          
       , mod_len      = sfcuse.mod_len           
       , seq          = sfcuse.seq               
       , wid          = sfcuse.wid               
       , rem_qty      = sfcuse.rem_qty           
       , rem_len      = sfcuse.rem_len           
       , rem_qa       = sfcuse.rem_qa            
       , rem_cnt      = sfcuse.rem_cnt           
       , area_no      = sfcuse.area_no           
    FROM sfcuse   
         LEFT OUTER JOIN location   ON sfcuse.loc_no  = location.loc_no
         LEFT OUTER JOIN groupitem  ON sfcuse.item_no = groupitem.item_no
   WHERE sfcuse.coil_no  = :as_lotno
" arguments=(("as_lotno", string)) )
