 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"doship~" ) COLUMN(NAME=~"doship.doship_no~") COLUMN(NAME=~"doship.doship_date~") COLUMN(NAME=~"doship.approve_team~") COLUMN(NAME=~"doship.approve_top~") COLUMN(NAME=~"doship.user_id~") COLUMN(NAME=~"doship.user_date~") COLUMN(NAME=~"doship.area_no~") COLUMN(NAME=~"doship.rem~") COLUMN(NAME=~"doship.process_flag~") COLUMN(NAME=~"doship.area_chk~")WHERE(    EXP1 =~"doship.doship_no~"   OP =~"=~"    EXP2 =~":as_doship_no~" ) ) ARG(NAME = ~"as_doship_no~" TYPE = string) " update="doship" updatewhere=1 updatekeyinplace=no arguments=(("as_doship_no", string)) )
