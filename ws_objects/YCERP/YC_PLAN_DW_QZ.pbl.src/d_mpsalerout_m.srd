 column=(type=char(10) updatewhereclause=yes name=assy_item dbname="RoutTempNew.assy_item" )
 column=(type=char(20) updatewhereclause=yes name=assy_qa dbname="RoutTempNew.assy_qa" )
 column=(type=long updatewhereclause=yes name=bom_no dbname="RoutTempNew.bom_no" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="RoutTempNew.uom" )
 column=(type=decimal(4) updatewhereclause=yes name=plan_qty dbname="RoutTempNew.plan_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=setup_time dbname="RoutTempNew.setup_time" )
 column=(type=decimal(4) updatewhereclause=yes name=work_time dbname="RoutTempNew.work_time" )
 column=(type=decimal(4) updatewhereclause=yes name=make_qty dbname="RoutTempNew.make_qty" )
 column=(type=char(1) updatewhereclause=yes name=plan_flag dbname="RoutTempNew.plan_flag" )
 column=(type=decimal(4) updatewhereclause=yes name=qpa dbname="RoutTempNew.qpa" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_assy_item_name dbname="GroupItem.assy_item_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 column=(type=decimal(4) updatewhereclause=yes name=routtempnew_reserved_qty dbname="RoutTempNew.reserved_qty" )
 column=(type=char(50) updatewhereclause=yes name=routtempnew_rem dbname="RoutTempNew.rem" )
 column=(type=char(10) updatewhereclause=yes name=routtempnew_area_no dbname="RoutTempNew.area_no" )
 retrieve=" SELECT routtempnew.work_date    
      , routtempnew.division     
      , routtempnew.wc_no        
      , routtempnew.operation    
      , routtempnew.process_flag 
      , routtempnew.work_per     
      , routtempnew.sale_no      
      , routtempnew.seq_no       
      , routtempnew.cust_no      
      , routtempnew.scene_code   
      , routtempnew.napgi_date   
      , routtempnew.suju_type    
      , routtempnew.item_no      
      , routtempnew.qa           
      , routtempnew.item_color   
      , routtempnew.order_qty    
      , routtempnew.assy_item    
      , routtempnew.assy_qa      
      , routtempnew.bom_no       
      , routtempnew.uom          
      , routtempnew.plan_qty     
      , routtempnew.setup_time   
      , routtempnew.work_time    
      , routtempnew.make_qty     
      , routtempnew.plan_flag    
      , routtempnew.qpa          
      , customer.cust_name       
      , groupitem_a.item_name item_name   
      , groupitem_b.item_name assy_item_name   
      , scene.scene_desc         
      , routtempnew.reserved_qty 
      , routtempnew.rem          
      , routtempnew.area_no  
   FROM routtempnew 
        LEFT OUTER JOIN sale     ON routtempnew.sale_no = sale.order_no 
        LEFT OUTER JOIN groupitem groupitem_a ON routtempnew.item_no   = groupitem_a.item_no 
        LEFT OUTER JOIN groupitem groupitem_b ON routtempnew.assy_item = groupitem_b.item_no 
        LEFT OUTER JOIN customer ON routtempnew.cust_no    = customer.cust_no 
        LEFT OUTER JOIN scene    ON routtempnew.scene_code = scene.scene_code     
  WHERE ( ( sale.open_close           = 'O' ) and
          ( routtempnew.process_flag <> 'C' ) and
          ( routtempnew.plan_flag     = 'N' ) and
          ( routtempnew.sale_no       = :arg_sale ) 
        )   
" update="routtempnew" updatewhere=0 updatekeyinplace=yes arguments=(("arg_sale", string))  sort="seq_no A operation A division A " )
