release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=72 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=76 color="553648127"  height.autosize=yes)
table(column=(type=datetime update=yes updatewhereclause=yes name=prog_date dbname="bdinfodetprog.prog_date" initial="today" )
 column=(type=char(1) update=yes updatewhereclause=yes key=yes name=prog_cls dbname="bdinfodetprog.prog_cls" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=build_no dbname="bdinfodetprog.build_no" )
 column=(type=decimal(0) update=yes updatewhereclause=yes key=yes name=seq dbname="bdinfodetprog.seq" )
 column=(type=decimal(0) update=yes updatewhereclause=yes key=yes name=prog_seq dbname="bdinfodetprog.prog_seq" )
 column=(type=char(10) update=yes updatewhereclause=yes name=emp_no dbname="bdinfodetprog.emp_no" )
 column=(type=char(255) update=yes updatewhereclause=yes name=rem dbname="bdinfodetprog.rem" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"bdinfodetprog~" ) COLUMN(NAME=~"bdinfodetprog.prog_date~") COLUMN(NAME=~"bdinfodetprog.prog_cls~") COLUMN(NAME=~"bdinfodetprog.build_no~") COLUMN(NAME=~"bdinfodetprog.seq~") COLUMN(NAME=~"bdinfodetprog.prog_seq~") COLUMN(NAME=~"bdinfodetprog.emp_no~") COLUMN(NAME=~"bdinfodetprog.rem~")WHERE(    EXP1 =~"bdinfodetprog.prog_cls~"   OP =~"=~"    EXP2 =~":as_prog_cls~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"bdinfodetprog.build_no~"   OP =~"=~"    EXP2 =~":as_build_no~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"bdinfodetprog.seq~"   OP =~"=~"    EXP2 =~":an_seq~" ) ) ARG(NAME = ~"as_prog_cls~" TYPE = string)  ARG(NAME = ~"as_build_no~" TYPE = string)  ARG(NAME = ~"an_seq~" TYPE = number) " update="bdinfodetprog" updatewhere=0 updatekeyinplace=no arguments=(("as_prog_cls", string),("as_build_no", string),("an_seq", number))  sort="prog_date A " )
