compute(band=detail alignment="1" expression="if(left( item_no ,1) = 'P' and mid(item_no, 3,1) = 'Y' and (mid(item_no, 7,1) = 'A' or mid(item_no, 7,1) = 'B' or mid(item_no, 7,1) = 'C' or mid(item_no, 7,1) = 'D'), plan_qty, if(uom = 'M2' or uom = ~"SS~" ,truncate( long(mid( qa ,5,4)) * long(mid(qa,10,4)) *    plan_qty / 1000000 + 0.000000001, 2), if(uom = 'M', if( plan_qty < 0 , truncate(long(mid(  qa , 15,5)) *   plan_qty / 1000 - 0.00001,2), truncate(long(mid(  qa , 15,5)) *  plan_qty / 1000 + 0.00001,2)) ,     plan_qty )))"border="0" color="0" x="3072" y="4" height="52" width="270" format="#,##0.00" html.valueishtml="0"  name=obj_24092413 visible="1"  font.face="굴림체" font.height="-9" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="0" background.color="79741120~tif (getrow() = currentrow(), RGB(254,252,175), 78682240)" )
