text(band=header alignment="2" text="어음" border="6" color="33554432" x="2075" y="76" height="60" width="421" html.valueishtml="0"  name=inbill_t visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="15780518" )
