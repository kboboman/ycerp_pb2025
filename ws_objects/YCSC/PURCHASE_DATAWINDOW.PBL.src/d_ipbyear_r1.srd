$PBExportHeader$d_ipbyear_r1.srd
$PBExportComments$조업자재 거래처별구매년보(1999/07/03, 이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=480 color="536870912" )
summary(height=116 color="536870912" )
footer(height=0 color="536870912" )
detail(height=108 color="536870912" )
table(column=(type=long updatewhereclause=yes name=yy dbname="yy" )
 column=(type=char(30) updatewhereclause=yes name=bsupp_supp_name dbname="bsupp.supp_name" )
 column=(type=char(30) updatewhereclause=yes name=bitem_item_name dbname="bitem.item_name" )
 column=(type=char(30) updatewhereclause=yes name=binitem_qa dbname="binitem.qa" )
 column=(type=char(4) updatewhereclause=yes name=bitem_uom dbname="bitem.uom" )
 column=(type=decimal(2) updatewhereclause=yes name=tqty dbname="tqty" )
 column=(type=decimal(4) updatewhereclause=yes name=tamt dbname="tamt" )
 retrieve="  SELECT yy = datepart(year, binitem.in_date),
			bsupp.supp_name,   
         bitem.item_name,   
         binitem.qa,   
         bitem.uom,   
         tqty = sum(qty),   
         tamt = sum(amount)
    FROM binitem left outer join bitem on binitem.item_no = bitem.item_no
                              left outer join bsupp  on binitem.supp_no = bsupp.supp_no
   WHERE ( ( datepart(year, binitem.in_date) = :ai_year ) AND  
         ( binitem.area_no = :as_area ) )    
group by datepart(year, binitem.in_date),
			bsupp.supp_name,   
         bitem.item_name ,   
         binitem.qa,               
         bitem.uom    
         " arguments=(("ai_year", number),("as_area", string))  sort="yy A bsupp_supp_name A bitem_item_name A binitem_qa A " )
group(level=1 header.height=0 trailer.height=84 by=("bsupp_supp_name" ) header.color="536870912" trailer.color="536870912" )
