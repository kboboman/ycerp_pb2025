table(column=(type=char(10) updatewhereclause=yes name=loc_no dbname="loc_no" )
 column=(type=char(30) updatewhereclause=yes name=loc_name dbname="loc_name" )
 column=(type=char(4) updatewhereclause=yes name=yyyy dbname="yyyy" )
 column=(type=char(2) updatewhereclause=yes name=mm dbname="mm" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=decimal(2) updatewhereclause=yes name=rcpt_qty dbname="rcpt_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=issue_qty dbname="issue_qty" )
 retrieve="SELECT loc_no   = a.loc_no
     , loc_name = l.loc_name
     , yyyy     = a.yyyy
     , mm       = a.mm
     , item_no  = a.item_no
     , item_name= g.item_name
     , qa       = a.qa
     , uom      = g.uom
     , rcpt_qty = a.rcpt_qty
     , issue_qty= a.issue_qty
  FROM (
       SELECT loc_no
            , yyyy = cast(datepart(year, inaudit_date) as char(4))
            , mm   = cast(datepart(month,inaudit_date) as char(2))
            , item_no
            , qa
            , rcpt_qty  = sum(rcpt_qty)
            , issue_qty = sum(issue_qty)
         FROM ( /* 일자별 발생내역 집계 */
              SELECT cat = 'A', loc_no
                   , inaudit_date = convert(char(10),inaudit_date,111), item_no = inaudit_item, qa, rcpt_qty, issue_qty
                FROM inaudit      WITH (NOLOCK)     /* 재고수불_PROCESS */
               WHERE loc_no   = :as_locno
                 AND convert(char(7),inaudit_date,111)  = :as_month
              
              UNION ALL
              SELECT cat = 'B', loc_no
                   , inaudit_date = convert(char(10),inaudit_date,111), item_no = inaudit_item, qa, rcpt_qty, issue_qty
                FROM inaudit_loc  WITH (NOLOCK) /* 재고수불_지점보정 */
               WHERE loc_no   = :as_locno
                 AND convert(char(7),inaudit_date,111)  = :as_month
              ) A
        GROUP BY loc_no, cast(datepart(year, inaudit_date) as char(4)), cast(datepart(month,inaudit_date) as char(2)), item_no, qa
       ) A
       LEFT OUTER JOIN groupitem G ON a.item_no = g.item_no
       LEFT OUTER JOIN location  L ON a.loc_no  = l.loc_no
" arguments=(("as_locno", string),("as_month", string)) )
