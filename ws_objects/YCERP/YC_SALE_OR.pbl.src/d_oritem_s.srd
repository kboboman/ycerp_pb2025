release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="itemcost.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=qa dbname="itemcost.qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="itemcost.uom" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"itemcost~" ) COLUMN(NAME=~"itemcost.item_no~") COLUMN(NAME=~"itemcost.qa~") COLUMN(NAME=~"itemcost.uom~")) " update="itemcost" updatewhere=1 updatekeyinplace=no )
compute(band=detail alignment="0" expression="mid(qa, 1, 3) + 'X' + if(mid(qa, 5, 4) = '', '0000', mid(qa, 5, 4)) + 'X' +if(mid(qa, 10, 4) = '', '0000', mid(qa, 10, 4))"border="0" color="0" x="9" y="4" height="60" width="416" format="[general]"  name=cb_qa  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
htmltable(border="1" cellpadding="0" cellspacing="0" generatecss="no" nowrap="yes")