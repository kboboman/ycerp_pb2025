table(column=(type=char(4) update=yes updatewhereclause=yes key=yes name=cust_no dbname="customer_rem_his.cust_no" )
 column=(type=datetime update=yes updatewhereclause=yes key=yes name=idate dbname="customer_rem_his.idate" )
 column=(type=long update=yes updatewhereclause=yes key=yes identity=yes name=seq dbname="customer_rem_his.seq" )
 column=(type=char(255) update=yes updatewhereclause=yes name=rem dbname="rem" )
 column=(type=char(10) update=yes updatewhereclause=yes name=iuser dbname="customer_rem_his.iuser" )
 retrieve="SELECT customer_rem_his.cust_no
	, customer_rem_his.idate
	, customer_rem_his.seq
	, rem = replace(customer_rem_his.rem,char(13) + char(10),' | ')
	, customer_rem_his.iuser

FROM customer_rem_his   
WHERE customer_rem_his.cust_no = :as_cust_no
ORDER BY customer_rem_his.idate desc, customer_rem_his.seq desc
" update="customer_rem_his" updatewhere=1 updatekeyinplace=no arguments=(("as_cust_no", string)) )
