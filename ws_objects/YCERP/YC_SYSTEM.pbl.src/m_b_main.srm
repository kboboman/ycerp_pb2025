this.m_exit=create m_exit
this.Item[UpperBound(this.Item)+1]=this.m_bdinfo_m1
this.Item[UpperBound(this.Item)+1]=this.m_bdinfo_m
this.Item[UpperBound(this.Item)+1]=this.m_설계영업진행입력
this.Item[UpperBound(this.Item)+1]=this.m_공사영업진행입력
this.Item[UpperBound(this.Item)+1]=this.m_판매영업진행입력
this.Item[UpperBound(this.Item)+1]=this.m_-5
this.Item[UpperBound(this.Item)+1]=this.m_2
this.Item[UpperBound(this.Item)+1]=this.m_-7
this.Item[UpperBound(this.Item)+1]=this.m_bdcustper_m
this.Item[UpperBound(this.Item)+1]=this.m_bidinfo_input
this.Item[UpperBound(this.Item)+1]=this.m_saleinfo_input
this.Item[UpperBound(this.Item)+1]=this.m_-
this.Item[UpperBound(this.Item)+1]=this.m_modulexit
this.Item[UpperBound(this.Item)+1]=this.m_exit
end on

