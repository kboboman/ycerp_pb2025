table(column=(type=char(4) update=yes updatewhereclause=yes key=yes name=cust_no dbname="cust_no" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=item_cd dbname="item_cd" values="기본사항	100/거래조건	200/거래처동향	300/" )
 column=(type=char(20) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=sort dbname="sort" )
 column=(type=long updatewhereclause=yes name=sort_org dbname="sort_org" )
 column=(type=char(50) updatewhereclause=yes name=item_nm dbname="item_nm" )
 column=(type=long update=yes updatewhereclause=yes name=seq dbname="seq" )
 column=(type=char(10) update=yes updatewhereclause=yes name=iuser dbname="iuser" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=datetime update=yes updatewhereclause=yes name=idate dbname="idate" )
 column=(type=char(4099) update=yes updatewhereclause=no name=bigo dbname="bigo" )
 column=(type=datetime update=yes updatewhereclause=yes key=yes name=input_date dbname="input_date" )
 column=(type=char(1) updatewhereclause=yes name=sw_modify dbname="sw_modify" )
 retrieve="  SELECT cust_no   = a.cust_no
       , item_cd   = a.item_cd
       , item_name = (case when a.item_cd = '1' then '기본사항'
                           when a.item_cd = '2' then '거래조건'
                           when a.item_cd = '3' then '거래동향'
                           else a.item_cd
                      end)
       , sort      = a.sort
       , sort_org  = a.sort
       , item_nm   = b.item_nm
       , seq       = a.seq
       , iuser     = a.iuser
       , user_name = c.user_name
       , idate     = a.idate
       , bigo      = a.bigo
       , input_date= a.input_date
       , sw_modify = 'X'
    FROM customer_base a
         LEFT OUTER JOIN codemst  b ON a.item_cd = b.item_cd AND a.sort = b.sort AND b.type = '거래처_이력카드'
         LEFT OUTER JOIN login    c ON a.iuser   = c.user_id
   WHERE a.cust_no  = :as_custno
     AND ((:as_itemcd  = '%' and a.item_cd  LIKE '%') or
          (:as_itemcd <> '%' and a.item_cd     = :as_itemcd)
         )
   ORDER BY a.item_cd, a.sort, a.seq desc
" update="customer_base" updatewhere=0 updatekeyinplace=no arguments=(("as_custno", string),("as_itemcd", string)) )
