table(column=(type=char(50) updatewhereclause=yes name=pgmdesc dbname="pgmdesc" )
 column=(type=long updatewhereclause=yes name=cnt dbname="cnt" )
 retrieve="SELECT pgmdesc = a.pgmdesc
     , cnt     = SUM(a.tcnt)
  FROM mERPLOGS a                                        
 GROUP BY a.pgmdesc
"  sort="cnt D " )
