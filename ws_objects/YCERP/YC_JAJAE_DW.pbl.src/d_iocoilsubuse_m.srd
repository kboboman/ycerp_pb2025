 column=(type=char(4) updatewhereclause=yes name=coilsubuse_color_type dbname="coilsubuse.color_type" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=coilsubuse_unit_qty dbname="coilsubuse.unit_qty" )
 column=(type=long update=yes updatewhereclause=yes name=coilsubuse_cnt dbname="coilsubuse.cnt" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=coilsubuse_rem_qty dbname="coilsubuse.rem_qty" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=coilsubuse_rem_len dbname="coilsubuse.rem_len" )
 column=(type=char(20) update=yes updatewhereclause=yes name=coilsubuse_rem_lot dbname="coilsubuse.rem_lot" )
 column=(type=char(1) update=yes updatewhereclause=yes name=coilsubuse_coil_type dbname="coilsubuse.coil_type" )
 column=(type=char(17) update=yes updatewhereclause=yes name=coilsubuse_insp_no dbname="coilsubuse.insp_no" )
 column=(type=long update=yes updatewhereclause=yes name=coilsubuse_insp_seq dbname="coilsubuse.insp_seq" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=long updatewhereclause=yes name=qcnt dbname="qcnt" )
 column=(type=char(2) updatewhereclause=yes name=etc_no dbname="etc_no" )
 retrieve="  SELECT coilsubuse.area_no,   
         coilsubuse.use_date,   
         coilsubuse.supp_no,   
         coilsubuse.seq,   
         coilsubuse.item_no,   
         coilsubuse.qa,   
         coilsubuse.uom,   
         coilsubuse.loc_no,   
         coilsubuse.lot_no,   
         coilsubuse.color,   
         coilsubuse.color_type,   
         coilsubuse.unit_qty,   
         coilsubuse.cnt,   
         coilsubuse.rem_qty,   
         coilsubuse.rem_len,   
         coilsubuse.rem_lot,   
         coilsubuse.coil_type,   
         coilsubuse.insp_no,   
         coilsubuse.insp_seq,   
         groupitem.item_name,   
         qcnt = cnt,   
         etc_no = '  '  
    FROM coilsubuse,   
         groupitem  
   WHERE ( coilsubuse.item_no = groupitem.item_no ) and  
         ( ( coilsubuse.supp_no = :as_supp ) AND  
         ( coilsubuse.use_date between :ad_start and :ad_end ) AND  
         ( coilsubuse.area_no = :as_area ) )    
" update="coilsubuse" updatewhere=0 updatekeyinplace=no arguments=(("as_area", string),("as_supp", string),("ad_start", date),("ad_end", date))  sort="coilsubuse_use_date A coilsubuse_seq A " )
