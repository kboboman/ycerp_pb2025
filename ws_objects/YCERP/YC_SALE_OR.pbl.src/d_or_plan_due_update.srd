release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=168 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=360 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes key=yes name=order_no dbname="sale.order_no" )
 column=(type=datetime update=yes updatewhereclause=yes name=plan_date dbname="sale.plan_date" )
 column=(type=datetime update=yes updatewhereclause=yes name=due_date dbname="sale.due_date" )
 column=(type=char(80) update=yes updatewhereclause=yes name=rem dbname="sale.rem" )
 column=(type=char(80) update=yes updatewhereclause=yes name=rem1 dbname="sale.rem1" )
 column=(type=char(80) update=yes updatewhereclause=yes name=rem2 dbname="sale.rem2" )
 column=(type=char(4) updatewhereclause=yes name=sale_cust_no dbname="sale.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 retrieve="  SELECT sale.order_no,   
         sale.plan_date,   
         sale.due_date,   
         sale.rem,   
         sale.rem1,   
         sale.rem2,   
         sale.cust_no,   
         customer.cust_name  
    FROM sale LEFT OUTER JOIN customer  ON  sale.cust_no = customer.cust_no 
   WHERE ( sale.order_no like '%' + rtrim(:as_orderno) + '%' )
" update="sale" updatewhere=0 updatekeyinplace=yes arguments=(("as_orderno", string))  sort="order_no A " )
