table(column=(type=char(14) updatewhereclause=yes key=yes name=order_no dbname="sale.order_no" initial=" " )
 column=(type=datetime updatewhereclause=yes name=input_date dbname="sale.input_date" )
 column=(type=datetime update=yes updatewhereclause=yes name=confirm_date dbname="sale.confirm_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=sale_confirm_user dbname="sale.confirm_user" )
 column=(type=datetime updatewhereclause=yes name=cust_po_date dbname="sale.cust_po_date" initial=" " )
 column=(type=datetime updatewhereclause=yes name=order_date dbname="sale.order_date" initial=" " )
 column=(type=datetime updatewhereclause=yes name=due_date dbname="sale.due_date" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="sale.cust_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=confirm_flag dbname="sale.confirm_flag" values="	T/	N" )
 column=(type=char(10) updatewhereclause=yes name=area_no dbname="sale.area_no" )
 column=(type=char(20) updatewhereclause=yes name=tel_no dbname="sale.tel_no" )
 column=(type=datetime updatewhereclause=yes name=cust_po_date dbname="sale.cust_po_date" )
 column=(type=long update=yes updatewhereclause=yes name=revision_no dbname="sale.revision_no" )
 column=(type=datetime update=yes updatewhereclause=yes name=revision_date dbname="sale.revision_date" )
 column=(type=char(10) updatewhereclause=yes name=fob dbname="sale.fob" )
 column=(type=decimal(4) updatewhereclause=yes name=total dbname="total" )
 column=(type=decimal(4) updatewhereclause=yes name=balance_amt dbname="customer.balance_amt" )
 column=(type=decimal(4) updatewhereclause=yes name=bill_amount dbname="customer.bill_amount" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=char(1) updatewhereclause=yes name=credit_level dbname="customer.credit_level" )
 column=(type=decimal(4) updatewhereclause=yes name=credit_limit dbname="customer.credit_limit" )
 column=(type=char(11) updatewhereclause=yes name=scene_code dbname="sale.scene_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="SCENE.scene_desc" )
 column=(type=char(100) updatewhereclause=yes name=area_name dbname="area_name" )
 retrieve="  SELECT sale.order_no
       , sale.input_date
       , sale.confirm_date         
       , sale.confirm_user
       , sale.cust_po_date     
       , sale.order_date       
       , sale.due_date      
       , sale.cust_no
	  , sale.confirm_flag
	  , sale.area_no
	  , sale.tel_no
       , sale.cust_po_date
       , sale.revision_no
       , sale.revision_date
	  , sale.fob
       , isnull(sale.sale_tax,0) + isnull(sale.sale_amount,0) total
	  , customer.balance_amt
	  , customer.bill_amount
       , customer.cust_name 
       , customer.credit_level
	  , customer.credit_limit
       , sale.scene_code
       , scene.scene_desc	  
	  , dbo.uf_sale_area(sale.order_no,  convert(char(8), sale.order_date,112) ) area_name
		FROM sale  inner join customer on sale.cust_no          = customer.cust_no
						inner join scene on  sale.scene_code       = scene.scene_code
   WHERE ( sale.cust_no          = customer.cust_no ) 
     AND ( sale.scene_code       = scene.scene_code )
     AND ( sale.cust_no       LIKE :as_custno       )   
     AND ( sale.order_date      >= :ad_sdate        )   
     AND ( sale.order_date      <= :ad_edate        )   
     AND ( sale.CONFIRM_FLAG     = :as_confirm_flag ) 
     AND ( sale.open_close       = 'O'              )    

/*
    FROM sale  
       , customer
       , scene
   WHERE ( sale.cust_no          = customer.cust_no ) 
     AND ( sale.scene_code       = scene.scene_code )
     AND ( sale.cust_no       LIKE :as_custno       )   
     AND ( sale.order_date      >= :ad_sdate        )   
     AND ( sale.order_date      <= :ad_edate        )   
     AND ( sale.CONFIRM_FLAG     = :as_confirm_flag )   
     AND ( sale.open_close       = 'O'              )    
*/" update="sale" updatewhere=0 updatekeyinplace=no arguments=(("as_custno", string),("ad_sdate", date),("ad_edate", date),("as_confirm_flag", string))  sort="input_date D order_no A " )
