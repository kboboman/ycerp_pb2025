 columns = "area_name" rows = "item_name, qa" values = "sum(real_qty for crosstab)" sourcenames = "item_no, item_name, use_date, qa, coil_no, unit_qty, mod_len, cnt, sdate, edate, work_name, sc_flag, rem_qty, al_flag, real_qty, area_name")
