table(column=(type=char(10) updatewhereclause=yes name=work_no dbname="work_no" )
 column=(type=char(10) updatewhereclause=yes name=work_name dbname="work_name" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(2) updatewhereclause=yes name=week1 dbname="week1" )
 column=(type=char(2) updatewhereclause=yes name=week2 dbname="week2" )
 column=(type=char(2) updatewhereclause=yes name=week3 dbname="week3" )
 column=(type=char(2) updatewhereclause=yes name=week4 dbname="week4" )
 column=(type=char(2) updatewhereclause=yes name=week5 dbname="week5" )
 column=(type=char(2) updatewhereclause=yes name=week6 dbname="week6" )
 column=(type=char(2) updatewhereclause=yes name=week7 dbname="week7" )
 column=(type=char(24) updatewhereclause=yes name=day1 dbname="day1" )
 column=(type=char(24) updatewhereclause=yes name=day2 dbname="day2" )
 column=(type=char(24) updatewhereclause=yes name=day3 dbname="day3" )
 column=(type=char(24) updatewhereclause=yes name=day4 dbname="day4" )
 column=(type=char(24) updatewhereclause=yes name=day5 dbname="day5" )
 column=(type=char(24) updatewhereclause=yes name=day6 dbname="day6" )
 column=(type=char(24) updatewhereclause=yes name=day7 dbname="day7" )
 column=(type=decimal(6) updatewhereclause=yes name=make_qty1 dbname="make_qty1" )
 column=(type=decimal(6) updatewhereclause=yes name=make_qty2 dbname="make_qty2" )
 column=(type=decimal(6) updatewhereclause=yes name=make_qty3 dbname="make_qty3" )
 column=(type=decimal(6) updatewhereclause=yes name=make_qty4 dbname="make_qty4" )
 column=(type=decimal(6) updatewhereclause=yes name=make_qty5 dbname="make_qty5" )
 column=(type=decimal(6) updatewhereclause=yes name=make_qty6 dbname="make_qty6" )
 column=(type=decimal(6) updatewhereclause=yes name=make_qty7 dbname="make_qty7" )
 retrieve="select     a.work_no, 
               a.work_name, 
               b.item_no, 
               b.item_name, 
      		     a.week1,
      		     a.week2,
      		     a.week3,
      		     a.week4,
      		     a.week5,
      		     a.week6,
      		     a.week7,
      		     a.day1,
      		     a.day2,
      		     a.day3,
      		     a.day4,
      		     a.day5,
      		     a.day6,
      		     a.day7,
               sum(case when  b.work_date = convert(char(8), convert(smalldatetime, :as_sdate),112) then  b.make_qty else 0 end )                           make_qty1,
               sum(case when  b.work_date = convert(char(8), dateadd(day,1,convert(smalldatetime, :as_sdate)), 112) then  b.make_qty else 0 end ) make_qty2,
               sum(case when  b.work_date = convert(char(8), dateadd(day,2,convert(smalldatetime, :as_sdate)), 112) then  b.make_qty else 0 end ) make_qty3,
               sum(case when  b.work_date = convert(char(8), dateadd(day,3,convert(smalldatetime, :as_sdate)), 112) then  b.make_qty else 0 end ) make_qty4,
               sum(case when  b.work_date = convert(char(8), dateadd(day,4,convert(smalldatetime, :as_sdate)), 112) then  b.make_qty else 0 end ) make_qty5,
               sum(case when  b.work_date = convert(char(8), dateadd(day,5,convert(smalldatetime, :as_sdate)), 112) then  b.make_qty else 0 end ) make_qty6,
               sum(case when  b.work_date = convert(char(8), dateadd(day,6,convert(smalldatetime, :as_sdate)), 112) then  b.make_qty else 0 end ) make_qty7
from 
 (
       select work_no, work_name, 
		   substring(datename(dw, convert( smalldatetime, :as_sdate) ),1, 1) week1,
		   substring(datename(dw, convert(char(8), dateadd(day,1,convert(smalldatetime, :as_sdate)), 112)),1, 1) week2,
		   substring(datename(dw, convert(char(8), dateadd(day,2,convert(smalldatetime, :as_sdate)), 112)),1, 1) week3,
		   substring(datename(dw, convert(char(8), dateadd(day,3,convert(smalldatetime, :as_sdate)), 112)),1, 1) week4,
		   substring(datename(dw, convert(char(8), dateadd(day,4,convert(smalldatetime, :as_sdate)), 112)),1, 1) week5,
		   substring(datename(dw, convert(char(8), dateadd(day,5,convert(smalldatetime, :as_sdate)), 112)),1, 1) week6,
		   substring(datename(dw, convert(char(8), dateadd(day,6,convert(smalldatetime, :as_sdate)), 112)),1, 1) week7,
		   substring(convert(char(8), convert(smalldatetime, :as_sdate),112),5,2)+ '.' + substring(convert(char(8), convert(smalldatetime, :as_sdate),112),7,2)+'('+substring(datename(dw, convert(char(8), convert(smalldatetime, :as_sdate),112) ),1, 1)+')'  day1,
       substring(convert(char(8), dateadd(day,1,convert(smalldatetime, :as_sdate)), 112),5,2)+ '.' + substring(convert(char(8), dateadd(day,1,convert(smalldatetime, :as_sdate)), 112),7,2)+'('+ substring(datename(dw, convert(char(8), dateadd(day,1,convert(smalldatetime, :as_sdate)), 112)),1, 1)+')'  day2,
       substring(convert(char(8), dateadd(day,2,convert(smalldatetime, :as_sdate)), 112),5,2)+ '.' + substring(convert(char(8), dateadd(day,2,convert(smalldatetime, :as_sdate)), 112),7,2)+'('+ substring(datename(dw, convert(char(8), dateadd(day,2,convert(smalldatetime, :as_sdate)), 112)),1, 1)+')'  day3,
       substring(convert(char(8), dateadd(day,3,convert(smalldatetime, :as_sdate)), 112),5,2)+ '.' + substring(convert(char(8), dateadd(day,3,convert(smalldatetime, :as_sdate)), 112),7,2)+'('+ substring(datename(dw, convert(char(8), dateadd(day,3,convert(smalldatetime, :as_sdate)), 112)),1, 1)+')'  day4,
       substring(convert(char(8), dateadd(day,4,convert(smalldatetime, :as_sdate)), 112),5,2)+ '.' + substring(convert(char(8), dateadd(day,4,convert(smalldatetime, :as_sdate)), 112),7,2)+'('+ substring(datename(dw, convert(char(8), dateadd(day,4,convert(smalldatetime, :as_sdate)), 112)),1, 1)+')'  day5,
       substring(convert(char(8), dateadd(day,5,convert(smalldatetime, :as_sdate)), 112),5,2)+ '.' + substring(convert(char(8), dateadd(day,5,convert(smalldatetime, :as_sdate)), 112),7,2)+'('+ substring(datename(dw, convert(char(8), dateadd(day,5,convert(smalldatetime, :as_sdate)), 112)),1, 1)+')'  day6,
       substring(convert(char(8), dateadd(day,6,convert(smalldatetime, :as_sdate)), 112),5,2)+ '.' + substring(convert(char(8), dateadd(day,6,convert(smalldatetime, :as_sdate)), 112),7,2)+'('+ substring(datename(dw, convert(char(8), dateadd(day,6,convert(smalldatetime, :as_sdate)), 112)),1, 1)+')'  day7
      from wc
	 WHERE WORK_NO IN ( :AS_WC_NO )
 ) a left outer join 
 (
    select  a.wc_no, a.work_date, a.item_no, a.item_name, sum(a.make_qty) make_qty, sum(a.plan_qty) plan_qty
    from 
    (
            select a.wc_no, convert(char(8), a.work_date, 112) work_date, a.assy_item item_no, a.assy_qa qa, b.item_name,
            case when  substring( a.assy_item, 1, 1) = 'P' and substring( a.assy_item, 3,1) = 'Y' and (  substring( a.assy_item, 7,1) = 'A' or substring( a.assy_item, 7,1) = 'B' or  substring( a.assy_item, 7,1) = 'C' or substring( a.assy_item, 7,1) = 'D') then mpsdet.order_qty

            else
                                       
                                 case when b.uom = 'M2' or b.uom = 'SS' then   round( convert(decimal,substring( a.assy_qa,5,4) ) * convert(decimal, substring( a.assy_qa,10,4)) * mpsdet.order_qty / 1000000 ,2, 1 )
                                 else 
                                              case when  b.uom = 'M' then
                                                      case when mpsdet.order_qty < 0  then round(convert(decimal, substring( a.assy_qa, 15,5)) * mpsdet.order_qty / 1000 - 0.00001, 2,1 )
                                                       else round( convert(decimal, substring( a.assy_qa, 15,5) ) * mpsdet.order_qty / 1000 + 0.00001,2,1)
                                                       end 
                                               else mpsdet.order_qty
                                               end 
                                 end 
                                 
            end make_qty,
            mpsdet.order_qty plan_qty
            from routtempnew a with(nolock) INNER join groupitem b with(nolock) on a.assy_item   = b.item_no
            LEFT OUTER JOIN mpsdet   with(nolock) ON a.sale_no     = mpsdet.sale_no   
                                                                        AND a.seq_no      = mpsdet.seq_no  
                                                                        AND a.division     = mpsdet.division  
                                                                        AND a.operation  = mpsdet.operation 
                                                                        AND a.wc_no       = mpsdet.wc_no     
            where a.work_date between convert(smalldatetime, :as_sdate) and dateadd(day,6,convert(smalldatetime, :as_sdate))
             and a.plan_flag LIKE 'Y%'
    )  a
    group by a.wc_no, a.work_date, a.item_no, a.item_name
    
) b on a.work_no = b.wc_no
group by          a.work_no, 
                               a.work_name, 
                               b.item_no, 
                               b.item_name,
                					    a.day1,
                					    a.day2,
                					    a.day3,
                					    a.day4,
                					    a.day5,
                					    a.day6,
                					    a.day7,
                					    a.week1,
                					    a.week2,
                					    a.week3,
                					    a.week4,
                					    a.week5,
                					    a.week6,
                					    a.week7
order by a.work_no, b.item_no" arguments=(("as_sdate", string),("as_wc_no", stringlist)) )
