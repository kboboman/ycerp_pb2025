$PBExportHeader$d_cbriefing_r2.srd
$PBExportComments$현설정보관리[2001.03.15,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=592 color="536870912" )
summary(height=4 color="536870912" )
footer(height=0 color="536870912" )
detail(height=172 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=sale_no dbname="cestimate.sale_no" )
 column=(type=char(10) updatewhereclause=yes name=scene_no dbname="cestimate.scene_no" )
 column=(type=char(6) updatewhereclause=yes name=cust_no dbname="cestimate.cust_no" )
 column=(type=char(1) updatewhereclause=yes name=top_opinion dbname="cestimate.top_opinion" )
 column=(type=datetime updatewhereclause=yes name=briefing_date dbname="cestimate.briefing_date" )
 column=(type=char(100) updatewhereclause=yes name=part_enterprise dbname="cestimate.part_enterprise" )
 column=(type=datetime updatewhereclause=yes name=tender_date dbname="cestimate.tender_date" )
 column=(type=decimal(0) updatewhereclause=yes name=promise_amount dbname="cestimate.promise_amount" )
 column=(type=decimal(0) updatewhereclause=yes name=amount dbname="cestimate.amount" )
 column=(type=char(80) updatewhereclause=yes name=cestimate_result dbname="cestimate.result" )
 column=(type=datetime updatewhereclause=yes name=cestimate_createdate dbname="cestimate.createdate" )
 column=(type=char(10) updatewhereclause=yes name=cestimate_user_name dbname="cestimate.user_name" )
 column=(type=long updatewhereclause=yes name=cmon dbname="cmon" )
 column=(type=long updatewhereclause=yes name=cweek dbname="cweek" )
 retrieve="  SELECT cestimate.sale_no,   
         cestimate.scene_no,   
         cestimate.cust_no,   
         cestimate.top_opinion,
			cestimate.briefing_date,
         cestimate.part_enterprise,   
         cestimate.tender_date,   
         cestimate.promise_amount,   
         cestimate.amount, 
			cestimate.result,
			createdate,
			user_name,
			cmon = datepart(month, :ad_end),
			cweek = :ai_week  
    FROM cestimate left outer join login on cestimate.createdby = user_id 
   WHERE( briefing_date between :ad_start and :ad_end ) and
			( ( :as_topchk = 'N' AND  
         cestimate.top_sign is null) OR  
         ( :as_topchk <> 'N' AND  
         cestimate.top_sign is not null) )    
" arguments=(("ad_start", date),("ad_end", date),("ai_week", number),("as_topchk", string))  sort="briefing_date A " )
