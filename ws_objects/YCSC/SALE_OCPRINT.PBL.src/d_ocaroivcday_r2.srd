table(column=(type=decimal(0) updatewhereclause=yes name=amount dbname="glbilldet.amount" )
 column=(type=char(1) updatewhereclause=yes name=det_class dbname="glbilldet.det_class" )
 retrieve="  SELECT glbilldet.amount,   
         glbilldet.det_class  
    FROM glbilldet  
   WHERE ( substring(glbilldet.billdet_vcno, 2 , 8) between :as_start and :as_end )    
" arguments=(("as_start", string),("as_end", string)) )
