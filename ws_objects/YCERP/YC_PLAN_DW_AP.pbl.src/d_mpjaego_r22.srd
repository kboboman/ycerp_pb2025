 column=(type=char(14) updatewhereclause=yes key=yes name=order_no dbname="sale_jaego.order_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="seq_no" )
 column=(type=char(10) updatewhereclause=yes name=acct_no dbname="acct_no" )
 column=(type=char(10) updatewhereclause=yes key=yes name=item_no dbname="sale_jaego.item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes key=yes name=qa dbname="sale_jaego.qa" )
