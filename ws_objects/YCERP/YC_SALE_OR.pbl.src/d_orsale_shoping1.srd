release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="79741120" )
summary(height=72 color="536870912" )
footer(height=72 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=area_no dbname="saletemp.area_no" )
 column=(type=char(4) updatewhereclause=yes name=saletemp_cust_no dbname="saletemp.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(11) updatewhereclause=yes name=saletemp_scene_code dbname="saletemp.scene_code" initial=" " )
 column=(type=char(14) updatewhereclause=yes name=saletemp_order_no dbname="saletemp.order_no" initial=" " )
 column=(type=char(1) updatewhereclause=yes name=saletemp_sale_flag dbname="saletemp.sale_flag" initial=" " values="내수	D/수출	E/L//C	L/" )
 column=(type=char(3) updatewhereclause=yes name=saletemp_curr_code dbname="saletemp.curr_code" initial=" " )
 column=(type=datetime updatewhereclause=yes name=saletemp_order_date dbname="saletemp.order_date" initial=" " )
 column=(type=datetime updatewhereclause=yes name=saletemp_due_date dbname="saletemp.due_date" initial=" " )
 column=(type=long updatewhereclause=yes name=saletempdet_seq_no dbname="saletempdet.seq_no" )
 column=(type=char(10) updatewhereclause=yes name=saletempdet_item_no dbname="saletempdet.item_no" )
 column=(type=char(20) updatewhereclause=yes name=saletempdet_qa dbname="saletempdet.qa" )
 column=(type=char(2) updatewhereclause=yes name=saletempdet_uom dbname="saletempdet.uom" )
 column=(type=decimal(2) updatewhereclause=yes name=saletempdet_order_qty dbname="saletempdet.order_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=saletempdet_acc_qty dbname="saletempdet.acc_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=saletempdet_price dbname="saletempdet.price" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 column=(type=datetime updatewhereclause=yes name=c_start dbname="c_start" )
 column=(type=datetime updatewhereclause=yes name=c_end dbname="c_end" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name dbname="login.user_name" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(1) update=yes updatewhereclause=yes name=jupsu_flag dbname="jupsu_flag" values="접수	Y/미접수	N/" )
 column=(type=datetime update=yes updatewhereclause=yes name=jupsu_date dbname="jupsu_date" )
 column=(type=char(14) updatewhereclause=yes name=sale_no dbname="sale_no" )
 column=(type=char(1) updatewhereclause=yes name=chk_yn dbname="chk_yn" values="	Y/	N" )
 retrieve="  SELECT saletemp.area_no
       , saletemp.cust_no           
       , customer.cust_name         
       , saletemp.scene_code        
       , saletemp.order_no          
       , saletemp.sale_flag         
       , saletemp.curr_code         
       , saletemp.order_date        
       , saletemp.due_date          
       , saletempdet.seq_no         
       , saletempdet.item_no        
       , saletempdet.qa             
       , saletempdet.uom            
       , saletempdet.order_qty      
       , saletempdet.acc_qty        
       , saletempdet.price          
       , scene.scene_desc           
       , c_start       = convert(smalldatetime, :ad_start, 111)   
       , c_end         = convert(smalldatetime, :ad_end,   111)   
       , login.user_name       
       , groupitem.item_name
       , jupsu_flag    = (case when saletemp.jupsu_flag is null or rtrim(saletemp.jupsu_flag) = '' then 'N' else saletemp.jupsu_flag end)
       , jupsu_date    = saletemp.jupsu_date
       , sale_no       = isnull(saletemp.sale_no,'')
       , chk_yn        = 'N'
    FROM customer      
       , groupitem     
       , saletemp LEFT OUTER JOIN scene ON saletemp.cust_no = scene.cust_no  and saletemp.scene_code = scene.scene_code
       , saletempdet              
       , login  
/*   WHERE ( saletemp.open_close    NOT IN ('X','C')            )   	*/
   WHERE ( saletemp.open_close   = 'O'            )   	
     and ( saletemp.order_no           = saletempdet.order_no )   
     and ( saletemp.cust_no            = customer.cust_no     )   
     and ( saletempdet.item_no         = groupitem.item_no    )   
     and ( customer.salesman           = login.user_id        )   
     and ( ( saletemp.sale_flag       IN ( :asa_sale_flag )    ) AND  
           ( saletemp.order_date BETWEEN :ad_start AND :ad_end ) AND  
           ( customer.salesman      LIKE :as_sale  or 
             ( :as_ret = 'T'         and customer.salesman  in ( SELECT login.user_id FROM login,team 
                                                                  WHERE login.team_code = team.team_code AND team_manager = :as_sale) 
             ) 
           ) AND
           ( saletemp.area_no       LIKE :as_area ) 
         )
" arguments=(("asa_sale_flag", stringlist),("ad_start", date),("ad_end", date),("as_sale", string),("as_area", string),("as_ret", string))  sort="login_user_name A saletemp_order_no A saletemp_order_date A saletempdet_seq_no A customer_cust_name A saletemp_scene_code A " )
group(level=1 header.height=0 trailer.height=72 by=("login_user_name" ) header.color="536870912" trailer.color="536870912" )
group(level=2 header.height=0 trailer.height=0 by=("saletemp_cust_no" ) header.color="536870912" trailer.color="553648127" )
group(level=3 header.height=0 trailer.height=68 by=("saletemp_order_no" ) header.color="536870912" trailer.color="536870912" )
