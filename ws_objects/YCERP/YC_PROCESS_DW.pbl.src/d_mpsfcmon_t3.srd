release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=sfcday_qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=sfcday_uom dbname="uom" )
 column=(type=char(10) updatewhereclause=yes name=sfcday_item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=decimal(4) updatewhereclause=yes name=sum_qty dbname="sum_qty" )
 column=(type=datetime updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=datetime updatewhereclause=yes name=edate dbname="edate" )
 retrieve="  SELECT qa         = sfcday.assembly_qa   
       , uom        = sfcday.uom                        
       , item_no    = sfcday.assembly      
       , item_name  = groupitem.item_name               
       , sum_qty    = sum(make_qty)        
       , sdate      = convert(smalldatetime, :ad_start, 111)  
       , edate      = convert(smalldatetime, :ad_end,   111)  
    FROM sfcday   
       , wc       
       , groupitem  
   WHERE ( sfcday.wc_no            = wc.work_no        ) and  
         ( sfcday.assembly         = groupitem.item_no ) and  
         ( ( wc.work_name       like :as_wc   ) AND  
           ( sfcday.sfc_date between :ad_start and :ad_end  + ~" 23:59:59:999~" ) and 
           ( sfcday.area_no        = :as_area )
         )   
   GROUP BY 
             sfcday.assembly_qa   
          , sfcday.uom           
          , sfcday.assembly      
          , groupitem.item_name  
" arguments=(("as_wc", string),("ad_start", date),("ad_end", date),("as_area", string))  sort="groupitem_item_name A sfcday_qa A " )
group(level=1 header.height=0 trailer.height=84 by=("groupitem_item_name" ) header.color="536870912" trailer.color="79741120" )
