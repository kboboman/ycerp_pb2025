type m_zoom from menu within m_display
m_20% m_20%
m_40% m_40%
m_60% m_60%
m_80% m_80%
m_100% m_100%
m_120% m_120%
end type

on m_zoom.create
call super::create
this.text = "확대/축소"
this.toolbaritemorder = 8
this.m_20%=create m_20%
this.m_40%=create m_40%
this.m_60%=create m_60%
this.m_80%=create m_80%
this.m_100%=create m_100%
this.m_120%=create m_120%
this.Item[UpperBound(this.Item)+1]=this.m_20%
this.Item[UpperBound(this.Item)+1]=this.m_40%
this.Item[UpperBound(this.Item)+1]=this.m_60%
this.Item[UpperBound(this.Item)+1]=this.m_80%
this.Item[UpperBound(this.Item)+1]=this.m_100%
this.Item[UpperBound(this.Item)+1]=this.m_120%
end on

on m_zoom.destroy
call super::destroy
destroy(this.m_20%)
destroy(this.m_40%)
destroy(this.m_60%)
destroy(this.m_80%)
destroy(this.m_100%)
destroy(this.m_120%)
end on

type m_20% from menu within m_zoom
end type

event clicked;////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// Scale the display area to 20%
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

window	lw_frame, &
		lw_sheet

// uncheck all zoom menu items
parent.m_20%.checked = false
parent.m_40%.checked = false
parent.m_60%.checked = false
parent.m_80%.checked = false
parent.m_100%.checked = false
parent.m_120%.checked = false

this.checked = not this.checked

lw_frame = ParentWindow.ParentWindow()
if IsValid (lw_frame) then
	lw_sheet = lw_frame.GetActiveSheet()	
	if IsValid (lw_sheet) then
		lw_sheet.TriggerEvent ("ue_zoom")
	end if
end if
end event

on m_20%.create
call super::create
this.text = "20%"
end on

on m_20%.destroy
call super::destroy
end on

