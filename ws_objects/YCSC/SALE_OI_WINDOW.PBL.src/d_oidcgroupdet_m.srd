 retrieve="  SELECT dc_groupdet.dc_groupno,   
         dc_groupdet.cust_no,   
         dc_groupdet.scene_code,   
         dc_groupdet.do_no,   
         dc_groupdet.oi_no,   
         dc_groupdet.seq_no,   
         dc_groupdet.item_no,   
         dc_groupdet.qa,   
         dc_groupdet.qa_cust,   
         dc_groupdet.ship_qty,   
         dc_groupdet.price,   
         dc_groupdet.aroi_qty,   
         dc_groupdet.uom,   
         dc_groupdet.sale_no,   
         dc_groupdet.rate_cash,   
         dc_groupdet.rem,   
         dc_groupdet.do_rem,   
         dc_groupdet.coil_no,   
         dc_groupdet.cnt,   
         dc_groupdet.loc_no,   
         dc_groupdet.stock_qty  
    FROM dc_groupdet   
   WHERE dc_groupdet.dc_groupno   = :as_groupno
" update="dc_groupdet" updatewhere=1 updatekeyinplace=no arguments=(("as_groupno", string)) )
