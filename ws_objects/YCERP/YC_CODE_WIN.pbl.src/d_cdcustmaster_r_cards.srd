table(column=(type=char(4) updatewhereclause=yes name=customer_cust_no dbname="customer.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(10) updatewhereclause=yes name=salesman dbname="customer.salesman" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name dbname="login.user_name" )
 column=(type=decimal(2) updatewhereclause=yes name=opeomamt dbname="opeomamt" )
 column=(type=char(50) updatewhereclause=yes name=mgr_type dbname="mgr_type" )
 column=(type=long updatewhereclause=yes name=mgr_sort dbname="mgr_sort" )
 column=(type=long updatewhereclause=yes name=cust_sort dbname="cust_sort" )
 column=(type=char(1) updatewhereclause=yes name=open_close dbname="customer.open_close" )
 column=(type=long updatewhereclause=yes name=cust_idx dbname="cust_idx" )
 column=(type=long updatewhereclause=yes name=toplevel dbname="toplevel" )
 column=(type=char(10) updatewhereclause=yes name=imwon_user_id dbname="customer.imwon_user_id" )
 column=(type=char(1) updatewhereclause=yes name=print_yn dbname="print_yn" values="	Y/	N" )
 retrieve="SELECT customer.cust_no
     , customer.cust_name
     , customer.salesman
     , login.user_name
    , opeomamt  = opeom.balbf_amount + 
                   ( opeom.inv_01  + opeom.inv_02  + opeom.inv_03  + opeom.inv_04  + opeom.inv_05  + opeom.inv_06    + 
                     opeom.inv_07  + opeom.inv_08  + opeom.inv_09  + opeom.inv_10  + opeom.inv_11  + opeom.inv_12  ) - 
                   ( opeom.coll_01 + opeom.coll_02 + opeom.coll_03 + opeom.coll_04 + opeom.coll_05 + opeom.coll_06   + 
                     opeom.coll_07 + opeom.coll_08 + opeom.coll_09 + opeom.coll_10 + opeom.coll_11 + opeom.coll_12 )
     , mgr_type   =  mgr_type.item_nm
	, isnull((SELECT sort FROM codemst WHERE type = 'MGR_TYPE' and use_yn = 'Y' and item_cd = customer.mgr_type),99) mgr_sort
     , cust_sort  = 0
     , customer.open_close open_close
     , isnull(cs.cust_idx, 0) cust_idx
	, convert(int, dbo.uf_toplevel_sort(customer.top_level)) toplevel
     , customer.imwon_user_id
     , (CASE WHEN CUSTOMER.SALESMAN = :AS_SALESMAN then 'Y' else 'N' end ) print_yn
  FROM opeom (nolock) inner join customer (nolock) on opeom.cust_no     = customer.cust_no
                                          inner join  login (nolock) on  customer.salesman = login.user_id
								  LEFT OUTER JOIN (
																	  SELECT item_nm, item_cd
																	  FROM codemst  with(nolock)
																	  WHERE type = 'MGR_TYPE' AND use_yn = 'Y'
															 ) mgr_type on mgr_type.item_cd = customer.mgr_type		
								 left outer JOIN customer_sort cs (nolock) ON customer.cust_no  = cs.cust_no						
 WHERE opeom.cust_no     = customer.cust_no
   AND customer.salesman = login.user_id
   AND ( (:as_salesman  = '%' OR 
               :as_salesman <> '%' AND customer.salesman = :as_salesman) or 
		  /*2021.02.16 JOWONSUK (부)영업담당 검색 추가 */
	        (  :as_salesman  = '%' and customer.imwon_user_id LIKE '%' OR
	           :as_salesman <> '%' and customer.imwon_user_id    = :as_salesman )
            )
   AND ( convert(char(4), opeom.eom_year, 112) = convert(char(4),:ai_year) )    
   AND ( opeom.cust_no   IN ( SELECT distinct p.cust_no FROM customer_credit p ) )
 ORDER BY customer.cust_name
" arguments=(("as_salesman", string),("ai_year", number))  sort="cust_idx A login_user_name A toplevel A mgr_sort A customer_cust_name A " )
