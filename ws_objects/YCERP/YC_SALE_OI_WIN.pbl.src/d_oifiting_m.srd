table(column=(type=char(14) update=yes updatewhereclause=yes key=yes name=fit_no dbname="fit.fit_no" )
 column=(type=char(4) update=yes updatewhereclause=yes name=cust_no dbname="fit.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=datetime update=yes updatewhereclause=yes name=fit_date dbname="fit.fit_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=fit_user dbname="fit.fit_user" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(10) update=yes updatewhereclause=yes name=area_no dbname="fit.area_no" )
 column=(type=char(60) update=yes updatewhereclause=yes name=rem dbname="fit.rem" )
 column=(type=char(1) update=yes updatewhereclause=yes name=confirm_flag dbname="fit.confirm_flag" )
 column=(type=datetime update=yes updatewhereclause=yes name=sys_date dbname="fit.sys_date" )
 retrieve="  SELECT fit.fit_no
       , fit.cust_no
       , c.cust_name
       , fit.fit_date
       , fit.fit_user
       , user_name  = l.user_name
       , fit.area_no
       , fit.rem
       , fit.confirm_flag
       , fit.sys_date  
    FROM fit   
       , customer c
       , login    l
   WHERE fit.cust_no    = c.cust_no
     AND fit.fit_user   = l.user_id
     AND fit_no         = :as_fitno

" update="fit" updatewhere=0 updatekeyinplace=no arguments=(("as_fitno", string)) )
