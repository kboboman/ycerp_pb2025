table(column=(type=char(12) update=yes updatewhereclause=yes name=rqs_no dbname="rawmtrorder.rqs_no" )
 column=(type=char(8) update=yes updatewhereclause=yes name=input_dt dbname="rawmtrorder.input_dt" )
 column=(type=char(30) updatewhereclause=yes name=mngr_dept dbname="team.mngr_dept" )
