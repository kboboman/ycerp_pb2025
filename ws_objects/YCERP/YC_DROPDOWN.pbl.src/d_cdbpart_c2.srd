$PBExportHeader$d_cdbpart_c2.srd
$PBExportComments$조업자재사용부서명(1999/06/07,이인호) / 전체선택추가
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=64 color="8421504" )
detail(height=64 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=part_name dbname="bpart.part_name" )
 column=(type=char(1) updatewhereclause=yes key=yes name=part_no dbname="bpart.part_no" )
 column=(type=char(1) updatewhereclause=yes name=sort dbname="sort" )
 retrieve="  SELECT bpart.part_name,   
         bpart.part_no,
			'2' sort
    FROM bpart   
union all
  SELECT '전체' part_name,   
         '%' part_no,
			'1' sort" update="bpart" updatewhere=0 updatekeyinplace=no  sort="sort A part_name A " )
column(band=detail id=1 alignment="0" tabsequence=32766 border="0" color="0" x="9" y="4" height="56" width="507" format="[general]" html.valueishtml="0"  name=part_name  tag="조업자재사용부서명" visible="1" edit.limit=10 edit.case=any edit.autoselect=yes edit.autohscroll=yes edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="2" font.pitch="2" font.charset="129" background.mode="1" background.color="536870912" )
compute(band=footer alignment="2" expression="rowcount()"border="0" color="0" x="9" y="4" height="56" width="507" format="[GENERAL]" html.valueishtml="0"  name=compute_1 visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="553648127" )
htmltable(border="1" )
htmlgen(clientevents="1" clientvalidation="1" clientcomputedfields="1" clientformatting="0" clientscriptable="0" generatejavascript="1" netscapelayers="0" )
