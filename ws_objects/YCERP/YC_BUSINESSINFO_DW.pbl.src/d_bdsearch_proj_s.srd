$PBExportHeader$d_bdsearch_proj_s.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=72 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=88 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=bdinfodet_project dbname="bdinfodet.project" )
 column=(type=char(34) updatewhereclause=yes name=bd_positon dbname="bd_positon" )
 column=(type=long updatewhereclause=yes name=bdinfodet_square dbname="bdinfodet.square" )
 column=(type=char(7) updatewhereclause=yes name=bdinfodet_floors dbname="bdinfodet.floors" initial="0/0" )
 column=(type=datetime updatewhereclause=yes name=bdinfodet_makedate dbname="bdinfodet.makedate" )
 column=(type=char(10) updatewhereclause=yes name=bdinfodet_build_no dbname="bdinfodet.build_no" )
 column=(type=decimal(0) updatewhereclause=yes name=bdinfodet_seq dbname="bdinfodet.seq" )
 retrieve="SELECT bdinfodet.project,   
		bd_positon = (  SELECT city_name FROM bdcity where city_code = bdinfodet.city ) + bdinfodet.dong,   
		bdinfodet.square,
		bdinfodet.floors,
		bdinfodet.makedate,
		bdinfodet.build_no,
		bdinfodet.seq
 FROM bdinfo,   
		bdinfodet
WHERE ( bdinfodet.build_no = bdinfo.build_no ) and  
		( bdinfodet.std_chk = '1' ) AND  
		( bdinfodet.project like :arg_proj )
order by  bdinfodet.project, bd_positon" arguments=(("arg_proj", string)) )
