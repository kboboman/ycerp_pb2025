table(column=(type=datetime updatewhereclause=yes name=exscene_ex_year dbname="exscene.ex_year" )
 column=(type=char(40) updatewhereclause=yes name=exscene_ex_name dbname="exscene.ex_name" )
 column=(type=char(20) updatewhereclause=yes name=exscene_ex_into dbname="exscene.ex_into" )
 column=(type=char(80) updatewhereclause=yes name=exscene_ex_system dbname="exscene.ex_system" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 retrieve="  SELECT exscene.ex_year,   
         exscene.ex_name,   
         exscene.ex_into,   
         exscene.ex_system,   
         customer.cust_name  
    FROM customer,   
         exscene  
   WHERE ( customer.cust_no = exscene.cust_no )    
" )
