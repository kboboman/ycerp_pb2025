table(column=(type=char(10) updatewhereclause=yes name=item_no dbname="saledet.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="saledet.qa" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="GroupItem.item_name" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="GroupItem.uom" )
 column=(type=decimal(4) updatewhereclause=yes name=qoh dbname="qoh" )
 column=(type=char(1) updatewhereclause=yes name=order_no dbname="order_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="seq_no" )
 column=(type=char(1) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(1) updatewhereclause=yes name=saledet_rem dbname="saledet_rem" )
 column=(type=decimal(2) updatewhereclause=yes name=saledetqty dbname="saledetqty" )
 column=(type=decimal(4) updatewhereclause=yes name=pur_qty dbname="pur_qty" )
 retrieve="  SELECT saledet.item_no                         
       , saledet.qa                              
       , groupitem.item_name                     
       , groupitem.uom                           
       , qoh         = isnull(itemloc.qoh, 0) 
       , order_no    = ''                        
       , seq_no      = 0                      
       , cust_name   = ''                        
       , saledet_rem = ''                        
       , saledetqty  = sum(saledet.order_qty - saledet.rlse_qty)
       , pur_qty     = isnull(sum(purdet.order_qty), 0 )   
  FROM saledet inner join groupitem on saledet.item_no = groupitem.item_no and groupitem.source = 'B' 
                             left outer join  itemloc on saledet.item_no = itemloc.item_no 
                                                              and  saledet.qa = itemloc.qa
                                                              and itemloc.loc_no         = :as_loc
                            inner join sale on saledet.order_no       = sale.order_no
                            left outer join  purdet on saledet.order_no = purdet.sale_no 
                                                             and saledet.seq_no = purdet.sale_seq
   WHERE ( saledet.order_no    LIKE :as_order         )  
     AND ( sale.open_close        = 'O'               )    
     AND ( sale.confirm_flag      = 'Y'               ) 
     AND ( sale.order_date       >= DATEadd(month, -1 ,getdate()) ) 
     AND ( ( :as_area = 'S0001' and ((sale.area_no like :as_area ) or (sale.area_no = 'H0001')) ) or
                ( :as_area = 'B0001' and ( sale.area_no like :as_area ) ) or
                ( :as_area = '%'     and ( sale.area_no like :as_area ) ) 
              )
   GROUP BY saledet.item_no
          , saledet.qa            
          , groupitem.item_name   
          , groupitem.uom         
          , itemloc.qoh
  HAVING SUM(saledet.order_qty - saledet.rlse_qty) > 0 
/*
    FROM saledet  
       , groupitem   
       , itemloc     
       , sale       
       , purdet
   WHERE ( saledet.order_no    LIKE :as_order         )  
     AND ( saledet.item_no        = groupitem.item_no ) 
     AND ( groupitem.source       = 'B'               ) 
     AND ( saledet.item_no       *= itemloc.item_no   )   
     AND ( saledet.qa            *= itemloc.qa        )   
     AND ( itemloc.loc_no         = :as_loc           ) 
     AND ( saledet.order_no       = sale.order_no     )   
     AND ( saledet.order_no      *= purdet.sale_no    )   
     AND ( saledet.seq_no        *= purdet.sale_seq   )   
     AND ( sale.open_close        = 'O'               )    
     AND ( sale.confirm_flag      = 'Y'               ) 
     AND ( sale.order_date       >= DATEadd(month, -1 ,getdate()) ) 
     AND ( ( :as_area = 'S0001' and ((sale.area_no like :as_area ) or (sale.area_no = 'H0001')) ) or
           ( :as_area = 'B0001' and ( sale.area_no like :as_area ) )                              or
           ( :as_area = '%'     and ( sale.area_no like :as_area ) ) 
         )
   GROUP BY saledet.item_no       
          , saledet.qa            
          , groupitem.item_name   
          , groupitem.uom         
          , itemloc.qoh
  HAVING SUM(saledet.order_qty - saledet.rlse_qty) > 0 
*/" arguments=(("as_loc", string),("as_order", string),("as_area", string))  sort="item_name A qa A " )
