$PBExportComments$물품그룹리스트(1998/3/14, 성삼지)
release 8;
datawindow(units=0 timer_interval=0 color=67108864 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=item_no dbname="item.item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item.item_name" )
 column=(type=long updatewhereclause=yes name=cnt dbname="cnt" )
 column=(type=long updatewhereclause=yes name=mincnt dbname="mincnt" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="item.uom" )
 column=(type=char(1) updatewhereclause=yes name=use_flag dbname="item.use_flag" )
 retrieve="  SELECT DISTINCT item.item_no
       , item.item_name
       , cnt    = (SELECT count(*) FROM itemcost WHERE item_no = item.item_no)
       , mincnt = (SELECT count(*) FROM itemcost WHERE item_no = item.item_no AND price_min > 0)
       , item.uom
       , use_flag
    FROM item   
   WHERE use_flag = ~"Y~"
"  sort="item_name A " )
