release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=cat1 dbname="cat1" )
 column=(type=char(20) updatewhereclause=yes name=cat2 dbname="cat2" )
 column=(type=char(10) updatewhereclause=yes name=area_no dbname="area_no" )
 column=(type=char(10) updatewhereclause=yes name=wc_no dbname="wc_no" )
 column=(type=char(40) updatewhereclause=yes name=wc_name dbname="wc_name" )
 column=(type=char(10) updatewhereclause=yes name=sfc_date dbname="sfc_date" )
 column=(type=char(10) updatewhereclause=yes name=sfcday_item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=sfcday_qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=sfcday_uom dbname="uom" )
 column=(type=decimal(1) updatewhereclause=yes name=ot dbname="ot" )
 column=(type=decimal(4) updatewhereclause=yes name=sumqty1 dbname="sumqty1" )
 column=(type=decimal(4) updatewhereclause=yes name=sumqty2 dbname="sumqty2" )
 column=(type=decimal(0) updatewhereclause=yes name=getqty1 dbname="getqty1" )
 column=(type=decimal(0) updatewhereclause=yes name=getqty2 dbname="getqty2" )
 column=(type=decimal(1) updatewhereclause=yes name=alltime dbname="alltime" )
 column=(type=decimal(1) updatewhereclause=yes name=daytime dbname="daytime" )
 column=(type=decimal(1) updatewhereclause=yes name=overtime dbname="overtime" )
 column=(type=decimal(22) updatewhereclause=yes name=orate1 dbname="orate1" )
 column=(type=decimal(22) updatewhereclause=yes name=orate2 dbname="orate2" )
 column=(type=decimal(21) updatewhereclause=yes name=orate3 dbname="orate3" )
 column=(type=char(10) updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=char(10) updatewhereclause=yes name=edate dbname="edate" )
 retrieve="  SELECT cat1      = i.cat1
       , cat2      = i.cat2
       , area_no   = a.area_no
       , wc_no     = a.wc_no
       , wc_name   = a.wc_name   
       , sfc_date  = a.sfc_date  
       , item_no   = a.item_no   
       , item_name = a.item_name 
       , qa        = a.qa        
       , uom       = a.uom       
       , ot        = a.overtime
       , sumqty1   = a.sumqty1   
       , sumqty2   = a.sumqty2   
       , getqty1   = a.getqty1   
       , getqty2   = a.getqty2   
       , alltime   = a.alltime   
       , daytime   = a.daytime   
       , overtime  = a.overtime  
       , orate1    = (a.getqty1 / a.daytime  / 60)
       , orate2    = (a.getqty2 / a.overtime / 60)
       , orate3    = (a.getqty1 + a.getqty2) / (a.daytime + a.overtime) / 60
       , sdate     = a.sdate     
       , edate     = a.edate     
    FROM (
         SELECT area_no   = a.area_no
              , wc_no     = a.wc_no
              , wcno_grp  = a.wcno_grp
              , wc_name   = a.wc_name   
              , sfc_date  = a.sfc_date  
              , item_no   = a.item_no   
              , item_name = a.item_name 
              , qa        = a.qa        
              , uom       = a.uom       
              , ot        = a.overtime
              , alltime   = isnull(b.all_time,0)
              , daytime   = isnull(b.daytime,0)  
              , overtime  = isnull(b.overtime,0)  
              , sumqty1   = (case when a.overtime = '' then a.sum_qty   else 0           end)
              , sumqty2   = (case when a.overtime = '' then 0           else a.sum_qty   end)
              , getqty1   = (case when a.overtime = '' then a.uf_getqty else 0           end)
              , getqty2   = (case when a.overtime = '' then 0           else a.uf_getqty end)
              , sdate     = a.sdate     
              , edate     = a.edate     
           FROM (
                SELECT area_no   = a.area_no
                     , wc_no     = a.wc_no
                     , wcno_grp  = left(a.wc_no,1) + '00'
                     , wc_name   = rtrim(b.work_name + space(30))         
                     , sfc_date  = convert(char(10),a.sfc_date,111)
                     , item_no   = a.assembly                         
                     , item_name = c.item_name                     
                     , qa        = a.assembly_qa                      
                     , uom       = a.uom                              
                     , overtime  = isnull(m.overtime,'')
                     , sum_qty   = sum(a.make_qty)                 
                     , uf_getqty = FLOOR(DBO.UF_GETQTY(a.assembly, a.assembly_qa, a.uom, sum(a.make_qty)))
                     , sdate     = convert(char(10),min(a.sfc_date),111)
                     , edate     = convert(char(10),max(a.sfc_date),111)
                  FROM sfcday  a 
                       LEFT OUTER JOIN mpsorder  m  ON a.mpsorder_order = m.order_no
                       LEFT OUTER JOIN wc        b  ON a.wc_no     = b.work_no
                       LEFT OUTER JOIN groupitem c  ON a.assembly  = c.item_no
                 WHERE ( b.work_name        LIKE :as_wc + '%' ) 
                   AND ( convert(char(10),a.sfc_date,111)  BETWEEN :as_start AND :as_end ) 
                   AND ( a.area_no             = :as_area ) 
                 GROUP BY a.area_no
                        , a.wc_no
                        , left(a.wc_no,1) + '00'
                        , b.work_name
                        , convert(char(10),a.sfc_date,111)
                        , a.assembly   
                        , c.item_name
                        , a.assembly_qa
                        , a.uom
                        , m.overtime
                ) A
                LEFT OUTER JOIN sfcdaywork  B  ON a.area_no  = b.area_no
                                              AND a.sfc_date = b.sfc_date
                                              AND a.wc_no    = b.wc_no
         ) A
         LEFT OUTER JOIN maketop10 i with (nolock) ON a.wcno_grp = i.work_no AND a.item_no = i.item_no
" arguments=(("as_wc", string),("as_start", string),("as_end", string),("as_area", string))  sort="wc_name A sfc_date A item_name A sfcday_qa A " )
