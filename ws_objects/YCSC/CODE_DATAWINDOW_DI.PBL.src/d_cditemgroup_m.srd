release 8;
datawindow(units=0 timer_interval=0 color=67108864 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=152 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=172 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="groupitem.item_no" initial="PZZZ000ZZZ" )
 column=(type=char(60) update=yes updatewhereclause=yes name=item_name dbname="groupitem.item_name" )
 column=(type=char(10) update=yes updatewhereclause=yes name=user_id dbname="groupitem.user_id" )
 column=(type=datetime update=yes updatewhereclause=yes name=sys_date dbname="groupitem.sys_date" )
 column=(type=char(1) update=yes updatewhereclause=yes name=p1 dbname="p1" initial="P" )
 column=(type=char(1) update=yes updatewhereclause=yes name=p2 dbname="p2" initial="Z" )
 column=(type=char(1) update=yes updatewhereclause=yes name=p3 dbname="p3" initial="Z" )
 column=(type=char(1) update=yes updatewhereclause=yes name=p4 dbname="p4" initial="Z" )
 column=(type=char(3) update=yes updatewhereclause=yes name=p5 dbname="p5" initial="000" )
 column=(type=char(1) update=yes updatewhereclause=yes name=p6 dbname="p6" initial="Z" )
 column=(type=char(1) update=yes updatewhereclause=yes name=p7 dbname="p7" initial="Z" )
 column=(type=char(1) update=yes updatewhereclause=yes name=p8 dbname="p8" initial="Z" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="groupitem.uom" )
 column=(type=char(1) update=yes updatewhereclause=yes name=source dbname="groupitem.source" values="구매품	B/반제품	M/완제품	W/스리팅	E/" )
 column=(type=long update=yes updatewhereclause=yes name=pat_no dbname="groupitem.pat_no" )
 column=(type=char(2) update=yes updatewhereclause=yes name=mp_uom dbname="groupitem.mp_uom" )
 column=(type=char(20) update=yes updatewhereclause=yes name=item_group dbname="groupitem.item_group" )
 column=(type=char(1) update=yes updatewhereclause=yes name=use_flag dbname="groupitem.use_flag" initial="Y" values="사용	Y/불가	C/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=qa_rule dbname="groupitem.qa_rule" initial="Y" values="	Y/	N" )
 column=(type=char(10) update=yes updatewhereclause=yes name=acct_no dbname="groupitem.acct_no" values="상품	G/제품	P/원재료	M/기타	E/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=cost_yn dbname="cost_yn" initial="N" values="	Y/	N" )
 retrieve="  SELECT groupitem.item_no,   
         groupitem.item_name,   
         groupitem.user_id,   
         groupitem.sys_date,   
         groupitem.p1,   
         groupitem.p2,   
         groupitem.p3,   
         groupitem.p4,   
         groupitem.p5,   
         groupitem.p6,   
         groupitem.p7,   
         groupitem.p8,   
         groupitem.uom,   
         groupitem.source,   
         groupitem.pat_no,   
         groupitem.mp_uom,   
         groupitem.item_group,   
         groupitem.use_flag,   
         groupitem.qa_rule,
         groupitem.acct_no,
         cost_yn  = groupitem.cost_yn
    FROM groupitem   
" update="groupitem" updatewhere=1 updatekeyinplace=no  sort="item_no A " )
