 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(20) updatewhereclause=yes name=coilmst_coil_no dbname="coilmst.coil_no" )
 column=(type=char(20) updatewhereclause=yes name=coilmst_qa dbname="coilmst.qa" )
 column=(type=long updatewhereclause=yes name=coilmst_unit_qty dbname="coilmst.unit_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=purdet_unit_qty dbname="purdet.unit_qty" )
 column=(type=char(56) updatewhereclause=yes name=mak dbname="mak" )
 column=(type=char(10) updatewhereclause=yes name=pur_buyer dbname="pur.buyer" )
 column=(type=char(80) updatewhereclause=yes name=supply_addr dbname="pur.supply_addr" )
 column=(type=char(15) updatewhereclause=yes name=supply_tel dbname="pur.supply_tel" )
 column=(type=char(255) updatewhereclause=yes name=pur_cham dbname="pur.cham" )
 column=(type=char(15) updatewhereclause=yes name=supp_tel_no dbname="supp.tel_no" )
 column=(type=char(15) updatewhereclause=yes name=supp_fax_no dbname="supp.fax_no" )
 retrieve="  SELECT DISTINCT supp.supp_name   
       , purdet.order_no   
       , purdet.seq_no   
       , purdet.item_no   
       , purdet.qa   
       , purdet.due_date   
       , purdet.order_qty   
       , purdet.rlse_date   
       , purdet.price   
       , purdet.uom   
       , purdet.rlse_qty   
       , purdet.product_no   
       , purdet.rcpt_loc   
       , purdet.pur_type   
       , purdet.rem   
       , purdet.coil_no   
       , purdet.serial_no   
       , purdet.work_type   
       , purdet.cnt   
       , purdet.result_type   
       , purdet.com_qty   
       , purdet.sale_no   
       , purdet.sale_seq   
       , purdet.cust_name   
       , purdet.sale_rem   
       , purdet.color   
       , groupitem_a.item_name   
       , groupitem_b.item_name   
       , coilmst.coil_no   
       , coilmst.qa   
       , coilmst.unit_qty   
       , purdet.unit_qty
       , mak = (case when substring(pur.order_no, 1, 1) = 'B' 
                     then '연락처: TEL: 031) 494 - 0960        FAX: 031) 494 - 0961' 
                     else '연락처: TEL: 031) 499 - 9600        FAX: 031) 499 - 9609'
                end)   
       , pur.buyer
       , pur.supply_addr
       , pur.supply_tel
       , pur.cham
       , supp.tel_no
       , supp.fax_no
    FROM purdet inner join pur on purdet.order_no = pur.order_no
                           inner join supp on pur.supp_no  = supp.supp_no 
                           inner join groupitem groupitem_a on purdet.item_no = groupitem_a.item_no
                           inner join coilsliting on purdet.product_no    = coilsliting.order_no and  purdet.serial_no     = coilsliting.seq
                           inner join coilorderdet on coilsliting.order_no = coilorderdet.order_no
                           inner join coilmst on coilorderdet.coil_no = coilmst.coil_no and ( coilorderdet.loc_no  = coilmst.loc_no or supp.supp_no = coilmst.loc_no )
                           left outer join groupitem groupitem_b on coilsliting.item_no = groupitem_b.item_no  
   WHERE ( pur.order_no         = :arg_order            ) 
" arguments=(("arg_order", string))  sort="purdet_seq_no A " )
