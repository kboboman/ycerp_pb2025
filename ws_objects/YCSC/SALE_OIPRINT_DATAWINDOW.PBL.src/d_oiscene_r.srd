$PBExportComments$현장별 자재투입현황 display(1998/04/29, 정재수)
release 5;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no grid.lines=0 )
header(height=81 color="536870912" )
summary(height=1 color="536870912" )
footer(height=1 color="536870912" )
detail(height=93 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=dodet_item_no dbname="dodet.item_no" )
 column=(type=char(20) updatewhereclause=yes name=dodet_qa dbname="dodet.qa" )
 column=(type=char(2) updatewhereclause=yes name=dodet_uom dbname="dodet.uom" )
 column=(type=datetime updatewhereclause=yes name=do_do_date dbname="do.do_date" )
 column=(type=decimal(2) updatewhereclause=yes name=dodet_ship_qty dbname="dodet.ship_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=dodet_price dbname="dodet.price" )
 column=(type=decimal(4) updatewhereclause=yes name=dodet_rate_cash dbname="dodet.rate_cash" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"do~" )  TABLE(NAME=~"dodet~" ) COLUMN(NAME=~"dodet.item_no~") COLUMN(NAME=~"dodet.qa~") COLUMN(NAME=~"dodet.uom~") COLUMN(NAME=~"do.do_date~") COLUMN(NAME=~"dodet.ship_qty~") COLUMN(NAME=~"dodet.price~") COLUMN(NAME=~"dodet.rate_cash~")    JOIN (LEFT=~"do.do_no~"    OP =~"=~"RIGHT=~"dodet.do_no~" )WHERE(    EXP1 =~"do.cust_no~"   OP =~"=~"    EXP2 =~":as_cust_no~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"do.spot_code~"   OP =~"in~"    EXP2 =~":asa_scene_code~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"do.do_date~"   OP =~">=~"    EXP2 =~":ad_start~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"do.do_date~"   OP =~"<=~"    EXP2 =~":ad_end~" ) ) ARG(NAME = ~"as_cust_no~" TYPE = string)  ARG(NAME = ~"asa_scene_code~" TYPE = stringlist)  ARG(NAME = ~"ad_start~" TYPE = date)  ARG(NAME = ~"ad_end~" TYPE = date) " arguments=(("as_cust_no", string),("asa_scene_code", stringlist),("ad_start", date),("ad_end", date)) )
