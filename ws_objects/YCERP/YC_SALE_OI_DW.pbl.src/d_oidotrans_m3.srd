$PBExportHeader$d_oidotrans_m3.srd
$PBExportComments$거래처 매출이관(결재자 비고)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=788 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=trans_no dbname="trans_no" )
 column=(type=char(50) updatewhereclause=yes name=tr_rem1 dbname="tr_rem1" )
 column=(type=char(50) updatewhereclause=yes name=tr_rem2 dbname="tr_rem2" )
 column=(type=char(50) updatewhereclause=yes name=tr_rem3 dbname="tr_rem3" )
 column=(type=char(50) updatewhereclause=yes name=tr_rem4 dbname="tr_rem4" )
 column=(type=char(50) updatewhereclause=yes name=tr_rem5 dbname="tr_rem5" )
 column=(type=char(50) updatewhereclause=yes name=tr_remh dbname="tr_remh" )
 column=(type=char(20) updatewhereclause=yes name=rank1 dbname="rank1" )
 column=(type=char(20) updatewhereclause=yes name=rank2 dbname="rank2" )
 column=(type=char(20) updatewhereclause=yes name=rank3 dbname="rank3" )
 column=(type=char(20) updatewhereclause=yes name=rank4 dbname="rank4" )
 column=(type=char(4) updatewhereclause=yes name=rank5 dbname="rank5" )
 column=(type=char(4) updatewhereclause=yes name=rankh dbname="rankh" )
 column=(type=char(1) updatewhereclause=yes name=cc_flag dbname="cc_flag" )
 retrieve="  SELECT trans_no   = a.trans_no
       , tr_rem1    = a.tr_rem1      
       , tr_rem2    = a.tr_rem2      
       , tr_rem3    = a.tr_rem3      
       , tr_rem4    = a.tr_rem4      
       , tr_rem5    = a.tr_rem5   
       , tr_remh    = a.tr_remh   
       , rank1      = l1.rank
       , rank2      = l2.rank
       , rank3      = l3.rank
       , rank4      = l4.rank
       , rank5      = '승인' /* l5.rank */
       , rankh      = '협조' /* lh.rank */
       , cc_flag    = (case when (a.tr_appdt1 is not null) or (a.tr_appdt2 is not null) or
                                 (a.tr_appdt3 is not null) or (a.tr_appdt4 is not null) or
                                 (a.tr_appdt5 is not null)    then '1' 
                            else '0' 
                       end)
    FROM dotrans a  with(nolock)     
         LEFT OUTER JOIN dotransdet  b with(nolock) ON a.trans_no   = b.trans_no
         LEFT OUTER JOIN login       d with(nolock) ON a.tr_app1    = d.user_id
         LEFT OUTER JOIN login      l1 with(nolock) ON a.tr_app1    = l1.user_id
         LEFT OUTER JOIN login      l2 with(nolock) ON a.tr_app2    = l2.user_id
         LEFT OUTER JOIN login      l3 with(nolock) ON a.tr_app3    = l3.user_id
         LEFT OUTER JOIN login      l4 with(nolock) ON a.tr_app4    = l4.user_id
         LEFT OUTER JOIN login      l5 with(nolock) ON a.tr_app5    = l5.user_id
         LEFT OUTER JOIN login      lh with(nolock) ON a.tr_apph    = lh.user_id
   WHERE a.trans_no  = :as_transno
" arguments=(("as_transno", string)) )
