event clicked;// 작업장별 생산계획 대비 실적 현황
string ls_sql, ls_where, ls_area, ls_order_flag, ls_sel_flag
date   ld_sdate, ld_edate

OpenWithParm(w_whwcplan_w, ist_code)
ist_code = Message.PowerObjectParm
if ist_code.okcancel = "N" then return

dw_area.accepttext()

ls_area  = dw_area.object.area[1]
ld_sdate = date(ist_code.start_date)
ld_edate = date(ist_code.end_date)

ls_order_flag = ist_code.order_flag
ls_sel_flag   = ist_code.sel_flag

dw_1.retrieve( ls_order_flag, ld_sdate, ld_edate, ls_sel_flag, ls_area )
if dw_1.rowcount() < 1 then
	messagebox("확인", "조회조건에 만족하는 내역이 없습니다.",information!)
   return
end if

