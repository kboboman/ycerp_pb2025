table(column=(type=char(14) updatewhereclause=yes name=purdet_sale_no dbname="sale_no" )
 column=(type=long updatewhereclause=yes name=purdet_sale_seq dbname="purdet.sale_seq" )
 column=(type=char(10) updatewhereclause=yes name=purdet_order_no dbname="purdet.order_no" )
 column=(type=long updatewhereclause=yes name=inspdet_seq_no dbname="inspdet.seq_no" )
 column=(type=char(14) updatewhereclause=yes name=inspdet_insp_no dbname="inspdet.insp_no" )
 column=(type=long updatewhereclause=yes name=inspdet_oi_no dbname="inspdet.oi_no" )
 column=(type=char(10) updatewhereclause=yes name=groupitem_item_no dbname="groupitem.item_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=decimal(2) updatewhereclause=yes name=inspdet_rcpt_qty dbname="inspdet.rcpt_qty" )
 column=(type=char(2) updatewhereclause=yes name=inspdet_uom dbname="inspdet.uom" )
 column=(type=decimal(4) updatewhereclause=yes name=inspdet_price dbname="inspdet.price" )
 column=(type=decimal(6) updatewhereclause=yes name=ship_amount dbname="ship_amount" )
 column=(type=decimal(4) updatewhereclause=yes name=insp_cash dbname="insp.insp_cash" )
 column=(type=char(10) updatewhereclause=yes name=pur_order_no dbname="pur.order_no" )
 column=(type=datetime updatewhereclause=yes name=pur_order_date dbname="pur.order_date" )
 column=(type=char(10) updatewhereclause=yes name=inspdet_loc_no dbname="inspdet.loc_no" )
 column=(type=char(20) updatewhereclause=yes name=inspdet_qa dbname="inspdet.qa" )
 column=(type=long updatewhereclause=yes name=inspdet_cnt dbname="inspdet.cnt" )
 column=(type=decimal(4) updatewhereclause=yes name=inspdet_comqty dbname="inspdet.comqty" )
 column=(type=datetime updatewhereclause=yes name=insp_insp_date dbname="insp.insp_date" )
 column=(type=char(30) updatewhereclause=yes name=supp_supp_name dbname="supp.supp_name" )
 column=(type=char(50) updatewhereclause=yes name=purdet_cust_name dbname="purdet.cust_name" )
 column=(type=datetime updatewhereclause=yes name=insp_log_date dbname="insp.log_date" )
 column=(type=char(2) updatewhereclause=yes name=purdet_com_uom dbname="com_uom" )
 column=(type=char(1) updatewhereclause=yes name=supp_round dbname="supp.round" )
 column=(type=char(2) updatewhereclause=yes name=coilmst_etc_no dbname="coilmst.etc_no" )
 column=(type=char(20) updatewhereclause=yes name=etc_name dbname="etc_name" )
 column=(type=char(14) updatewhereclause=yes name=dono dbname="dono" )
 column=(type=long updatewhereclause=yes name=doseq dbname="doseq" )
 retrieve="  SELECT sale_no  = isnull(purdet.sale_no, '')
       , purdet.sale_seq
       , purdet.order_no       
       , inspdet.seq_no        
       , inspdet.insp_no       
       , inspdet.oi_no         

       , groupitem.item_no     
       , groupitem.item_name   
       , inspdet.rcpt_qty      
       , inspdet.uom           
       , inspdet.price         
       , ship_amount = b.ship_amount
       , insp.insp_cash
       , pur.order_no          
       , pur.order_date
       , inspdet.loc_no        
       , inspdet.qa            
       , inspdet.cnt           
       , inspdet.comqty        
       , insp.insp_date        
       , supp.supp_name     
       , purdet.cust_name      
       , insp.log_date               
       , com_uom  = inspdet.com_uom
       , supp.round               
       , coilmst.etc_no
       , etc_name = (case when insp.ship_flag = 'D' AND insp.ship_amount > 0 then inspdet.insp_no
                          else (SELECT coiletc.etc_name FROM coiletc WHERE etc_no = coilmst.etc_no)
                     end)
       , dono     = isnull(dodet.do_no, '')
       , doseq    = dodet.oi_no
    FROM inspdet  with (nolock)
         LEFT OUTER JOIN insp      with (nolock) ON insp.insp_no    = inspdet.insp_no
         LEFT OUTER JOIN purdet    with (nolock) ON inspdet.pur_no  = purdet.order_no AND inspdet.seq_no = purdet.seq_no
         LEFT OUTER JOIN pur       with (nolock) ON inspdet.pur_no  = pur.order_no
         LEFT OUTER JOIN coilmst   with (nolock) ON inspdet.coil_no = coilmst.coil_no AND inspdet.loc_no = coilmst.loc_no
         LEFT OUTER JOIN supp      with (nolock) ON insp.supp_no    = supp.supp_no
         LEFT OUTER JOIN groupitem with (nolock) ON inspdet.item_no = groupitem.item_no
         LEFT OUTER JOIN (
              SELECT insp_no     = a.insp_no
                   , oi_no       = min(a.oi_no)
                   , ship_amount = avg(a.ship_amount)
                FROM (
                     SELECT inspdet.insp_no
                          , inspdet.oi_no
                          , ship_amount = insp.ship_amount
                       FROM inspdet with (nolock) 
                          , insp    with (nolock) 
                      WHERE ( insp.insp_no             = inspdet.insp_no )   
                        AND ( insp.insp_date     BETWEEN :ad_date1 AND :ad_date2 )
                     ) A
               GROUP BY a.insp_no
         ) B ON inspdet.insp_no = b.insp_no AND inspdet.oi_no = b.oi_no
         LEFT OUTER JOIN (
              SELECT a.sale_no, a.seq_no, do_no = max(a.do_no), oi_no = max(a.oi_no), prt_date = max(a.prt_date)
                FROM (
                     SELECT do.do_no, dodet.oi_no, do.prt_date, dodet.sale_no, dodet.seq_no
                       FROM dodet with (nolock)
                            LEFT OUTER JOIN do with (nolock) ON dodet.do_no = do.do_no
                      WHERE do.do_date >= dateadd(month, -2, :ad_date1)  /* 이월반영 */
                     ) A
               GROUP BY a.sale_no, a.seq_no
         ) DODET ON purdet.sale_no = dodet.sale_no AND purdet.sale_seq = dodet.seq_no
   WHERE ( insp.insp_date     BETWEEN :ad_date1 AND :ad_date2  )
     AND ( ( :as_supp  = '%'      AND insp.supp_no   LIKE :as_supp ) or
           ( :as_supp <> '%'      AND insp.supp_no      = :as_supp )
         )
     AND ( ( :as_area  = 'S'      AND inspdet.pur_no LIKE 'PUR%'   ) or
           ( :as_area  = '%'      AND insp.area_no   LIKE '%'      ) or
           ( inspdet.pur_no      LIKE :as_area + '%'               ) 
         ) 
   ORDER BY purdet.cust_name, inspdet.insp_no
" arguments=(("as_supp", string),("ad_date1", date),("ad_date2", date),("as_area", string))  sort="supp_supp_name A groupitem_item_name A inspdet_qa A purdet_order_no A inspdet_seq_no A " )
group(level=1 header.height=0 trailer.height=80 by=("supp_supp_name" ) header.color="536870912" trailer.color="12639424" )
