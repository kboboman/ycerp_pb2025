$PBExportHeader$d_cust_aim2_custlist_r.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=char(4) update=yes updatewhereclause=yes key=yes name=cust_no dbname="customer.cust_no" )
 column=(type=char(50) update=yes updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=char(6) update=yes updatewhereclause=yes name=id dbname="id" )
 column=(type=char(8) updatewhereclause=yes name=open_close dbname="open_close" )
 retrieve="select a.cust_no,
       a.cust_name, 
       isnull(( SELECT  '등록  '
                FROM cust_aim b
                WHERE (a.cust_no = b.cust_code) and  
                      (datepart(year,b.tar_year) = :al_year) 
              ),'미등록') as id,
		 open_close = case when  open_close = 'C' then '사용불가' else '' end
from customer  a 
where a.salesman = :as_salesman
/* and (a.open_close <> 'C' or a.open_close is null) */
order by id desc, a.cust_name" update="customer" updatewhere=1 updatekeyinplace=no arguments=(("as_salesman", string),("al_year", number)) )
text(band=header alignment="2" text="구분" border="6" color="33554432" x="9" y="8" height="60" width="229" html.valueishtml="0"  name=id_t visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="67108864" )
