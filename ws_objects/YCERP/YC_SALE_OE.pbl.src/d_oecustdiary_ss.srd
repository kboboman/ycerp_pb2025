table(column=(type=char(30) updatewhereclause=yes name=team_team_name dbname="team.team_name" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name dbname="login.user_name" )
 column=(type=char(1) updatewhereclause=yes name=prt_chk dbname="prt_chk" )
 column=(type=datetime updatewhereclause=yes name=custdiary_diary_date dbname="custdiary.diary_date" )
 column=(type=char(1) updatewhereclause=yes name=custdiary_urgent dbname="custdiary.urgent" )
 column=(type=char(1) updatewhereclause=yes name=chk_team dbname="chk_team" )
 column=(type=char(10) updatewhereclause=yes name=custdiary_approve_team dbname="custdiary.approve_team" )
 column=(type=char(1) updatewhereclause=yes name=custdiary_process_flag dbname="custdiary.process_flag" )
 column=(type=char(10) updatewhereclause=yes name=custdiary_approve_top dbname="custdiary.approve_top" )
 column=(type=char(10) updatewhereclause=yes name=custdiary_cust_no dbname="custdiary.cust_no" )
 column=(type=char(60) updatewhereclause=yes name=custdiary_cust_name dbname="custdiary.cust_name" )
 column=(type=char(60) updatewhereclause=yes name=custdiary_bdcust_name dbname="custdiary.bdcust_name" )
 column=(type=char(100) updatewhereclause=yes name=desc1 dbname="custdiary.desc1" )
 column=(type=char(10) updatewhereclause=yes name=custdiary_emp_no dbname="custdiary.emp_no" )
 column=(type=long updatewhereclause=yes name=custdiary_seq_no dbname="custdiary.seq_no" )
 retrieve="  SELECT team.team_name           
       , login.user_name          
       , prt_chk  = ' '
       , custdiary.diary_date     
       , custdiary.urgent         
       , chk_team = ( case when ( custdiary.approve_team is null ) or ( custdiary.approve_team = '') then 'N' else 'Y' end )
       , custdiary.approve_team   
       , custdiary.process_flag   
       , custdiary.approve_top 
       , custdiary.cust_no        
       , custdiary.cust_name      
       , custdiary.bdcust_name    
       , custdiary.desc1          
       , custdiary.emp_no         
       , custdiary.seq_no         
 from custdiary left outer join team on custdiary.team_code = team.team_code
		 		   left outer join login on custdiary.emp_no = login.user_id 
WHERE  ( ( custdiary.emp_no          LIKE :as_user  ) AND (('%' = :as_chk) OR ( custdiary.process_flag = :as_chk )) AND
           ( ( ( custdiary.cust_name   LIKE :as_cust  )  OR ( :as_cust  = '%' AND custdiary.cust_name   IS NULL ) ) AND 
             ( ( custdiary.bdcust_name LIKE :as_com   )  OR ( :as_com   = '%' AND custdiary.bdcust_name IS NULL ) ) AND 
             ( ( custdiary.desc1       LIKE :as_title )  OR ( :as_title = '%' AND custdiary.desc1       IS NULL ) ) 
           ) AND
           ( (:as_all = 'Y') OR ( :as_all = 'N' AND custdiary.diary_date BETWEEN :ad_start AND :ad_end ) ) 
         )
/*
    FROM custdiary   
       , login    
       , team
   WHERE ( custdiary.emp_no           *= login.user_id  )   
     AND ( custdiary.team_code        *= team.team_code )   
     AND ( ( custdiary.emp_no          LIKE :as_user  ) AND (('%' = :as_chk) OR ( custdiary.process_flag = :as_chk )) AND
           ( ( ( custdiary.cust_name   LIKE :as_cust  )  OR ( :as_cust  = '%' AND custdiary.cust_name   IS NULL ) ) AND 
             ( ( custdiary.bdcust_name LIKE :as_com   )  OR ( :as_com   = '%' AND custdiary.bdcust_name IS NULL ) ) AND 
             ( ( custdiary.desc1       LIKE :as_title )  OR ( :as_title = '%' AND custdiary.desc1       IS NULL ) ) 
           ) AND
           ( (:as_all = 'Y') OR ( :as_all = 'N' AND custdiary.diary_date BETWEEN :ad_start AND :ad_end ) ) 
         )

*/" arguments=(("as_user", string),("as_chk", string),("as_cust", string),("as_com", string),("ad_start", date),("ad_end", date),("as_all", string),("as_title", string)) )
