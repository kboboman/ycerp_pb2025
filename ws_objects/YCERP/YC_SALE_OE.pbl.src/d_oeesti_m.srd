 column=(type=char(1) update=yes updatewhereclause=yes name=esti_case dbname="esti_case" values="단가견적	Y/단가견적	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=sale_succ dbname="estimate_head.sale_succ" initial="N" )
 retrieve="  SELECT estimate_head.estimate_no,   
         estimate_head.cust_no,   
         estimate_head.scene_code,   
         estimate_head.estimate_date,   
         estimate_head.system_no,   
         estimate_head.esti_flag,   
         estimate_head.emp_no,   
         estimate_head.esti_amount,   
         estimate_head.esti_tax,   
         estimate_head.esti_total,   
         estimate_head.rem,   
         estimate_head.vat_flag,   
         estimate_head.input_date,   
         estimate_head.user_id,   
         estimate_head.approve_team,   
         estimate_head.approve_top,   
         estimate_head.team_desc,   
         estimate_head.top_desc,   
         estimate_head.cust_name,   
         estimate_head.scene_desc,   
         esti_case = isnull(estimate_head.esti_case,'N'),   
         estimate_head.sale_succ  
    FROM estimate_head  
   WHERE estimate_head.estimate_no = :est_no    
" update="estimate_head" updatewhere=0 updatekeyinplace=no arguments=(("est_no", string)) )
