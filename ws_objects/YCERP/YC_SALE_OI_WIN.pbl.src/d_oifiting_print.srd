 retrieve="  SELECT cust_name    = customer.cust_name
       , fit_no       = fit.fit_no   
       , fit_seq      = fitdet.fit_seq
       , cust_no      = fit.cust_no   
       , fit_date     = fit.fit_date   
       , fit_user     = fit.fit_user   
       , fit_usernm   = la.user_name
       , area_no      = fit.area_no   
       , rem          = fit.rem   
       , confirm_flag = fit.confirm_flag   
       , req_date     = fitdet.req_date   
       , salesman     = fitdet.salesman   
       , req_seq      = fitdet.req_seq   
       , req_flag     = fitdet.req_flag 
       , scene_code   = fitdet.scene_code   
       , scene_desc   = scene.scene_desc
       , item_no      = fitdet.item_no   
       , item_name    = groupitem.item_name   
       , qa           = fitdet.qa   
       , uom          = fitdet.uom   
       , order_qty    = fitdet.order_qty   
       , rlse_qty     = fitdet.rlse_qty   
       , ship_qty     = fitdet.ship_qty   
       , sale_no      = fitdet.sale_no   
       , seq_no       = fitdet.seq_no   
       , do_no        = fitdet.do_no   
       , oi_no        = fitdet.oi_no   
       , issue_flag   = fitdet.issue_flag   
       , issue_schedule = fitdet.issue_schedule   
       , ship_flag    = fitdet.ship_flag   
       , ship_case    = fitdet.ship_case   
       , tel          = fitdet.tel   
       , rem_1        = fitdet.rem  
    FROM fit
         LEFT OUTER JOIN fitdet    ON fit.fit_no = fitdet.fit_no
         LEFT OUTER JOIN customer  ON fit.cust_no       = customer.cust_no
         LEFT OUTER JOIN groupitem ON fitdet.item_no    = groupitem.item_no
         LEFT OUTER JOIN scene     ON fitdet.scene_code = scene.scene_code
         LEFT OUTER JOIN login  LA ON fit.fit_user      = la.user_id
         LEFT OUTER JOIN login  LB ON fitdet.salesman   = lb.user_id
   WHERE ( fit.fit_no  = :as_fit_no )
" arguments=(("as_fit_no", string))  sort="seq_no A " )
