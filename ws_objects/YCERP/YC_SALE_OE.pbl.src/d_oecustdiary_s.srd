 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"custdiary~" ) COLUMN(NAME=~"custdiary.diary_date~") COLUMN(NAME=~"custdiary.emp_no~") COLUMN(NAME=~"custdiary.seq_no~") COLUMN(NAME=~"custdiary.team_code~") COLUMN(NAME=~"custdiary.cust_no~") COLUMN(NAME=~"custdiary.cust_name~") COLUMN(NAME=~"custdiary.bdcust_no~") COLUMN(NAME=~"custdiary.bdcust_name~") COLUMN(NAME=~"custdiary.start_time~") COLUMN(NAME=~"custdiary.end_time~") COLUMN(NAME=~"custdiary.desc1~") COLUMN(NAME=~"custdiary.desc2~") COLUMN(NAME=~"custdiary.desc3~") COLUMN(NAME=~"custdiary.desc4~") COLUMN(NAME=~"custdiary.desc5~") COLUMN(NAME=~"custdiary.desc6~") COLUMN(NAME=~"custdiary.desc7~") COLUMN(NAME=~"custdiary.desc8~") COLUMN(NAME=~"custdiary.desc9~") COLUMN(NAME=~"custdiary.desc10~") COLUMN(NAME=~"custdiary.proc1~") COLUMN(NAME=~"custdiary.proc2~") COLUMN(NAME=~"custdiary.proc3~") COLUMN(NAME=~"custdiary.proc4~") COLUMN(NAME=~"custdiary.proc5~") COLUMN(NAME=~"custdiary.proc6~") COLUMN(NAME=~"custdiary.proc7~") COLUMN(NAME=~"custdiary.proc8~") COLUMN(NAME=~"custdiary.proc9~") COLUMN(NAME=~"custdiary.proc10~") COLUMN(NAME=~"custdiary.process_flag~") COLUMN(NAME=~"custdiary.check2~") COLUMN(NAME=~"custdiary.urgent~") COLUMN(NAME=~"custdiary.sys_date~") COLUMN(NAME=~"custdiary.approve_team~") COLUMN(NAME=~"custdiary.check_date~") COLUMN(NAME=~"custdiary.approve_top~") COMPUTE(NAME=~"chk_team = ( case when ( custdiary.approve_team is null ) or (  custdiary.approve_team = '') then ~~~"N~~~" else ~~~"Y~~~" end )~")WHERE(    EXP1 =~"( ( custdiary.emp_no~"   OP =~"=~"    EXP2 =~":as_userid )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( custdiary.cust_no~"   OP =~"=~"    EXP2 =~":as_custno )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( custdiary.diary_date~"   OP =~"=~"    EXP2 =~":ad_diary ) )~" ) ) ARG(NAME = ~"as_userid~" TYPE = string)  ARG(NAME = ~"ad_diary~" TYPE = date)  ARG(NAME = ~"as_custno~" TYPE = string) " arguments=(("as_userid", string),("ad_diary", date),("as_custno", string)) )
