table(column=(type=char(4) update=yes updatewhereclause=yes key=yes name=custno dbname="car_intervalsdet.custno" )
 column=(type=char(11) update=yes updatewhereclause=yes key=yes name=scene dbname="car_intervalsdet.scene" )
 column=(type=datetime update=yes updatewhereclause=yes key=yes name=cardate dbname="car_intervalsdet.cardate" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=seq dbname="car_intervalsdet.seq" )
 column=(type=char(10) update=yes updatewhereclause=yes name=user_id dbname="car_intervalsdet.user_id" )
 column=(type=datetime update=yes updatewhereclause=yes name=cartime dbname="car_intervalsdet.cartime" )
 column=(type=char(50) update=yes updatewhereclause=yes name=car_gubun dbname="car_intervalsdet.car_gubun" )
 column=(type=char(50) update=yes updatewhereclause=yes name=car_destination dbname="car_intervalsdet.car_destination" )
 column=(type=char(150) update=yes updatewhereclause=yes name=contents dbname="car_intervalsdet.contents" )
 retrieve="  SELECT car_intervalsdet.custno
       , car_intervalsdet.scene
       , car_intervalsdet.cardate
       , car_intervalsdet.seq
       , car_intervalsdet.user_id
       , car_intervalsdet.cartime
       , car_intervalsdet.car_gubun
       , car_intervalsdet.car_destination
       , car_intervalsdet.contents  
    FROM car_intervalsdet   
   WHERE car_intervalsdet.custno    = :as_custno
     AND car_intervalsdet.scene     = :as_scene
     AND car_intervalsdet.cardate   = :ad_date
    " update="car_intervalsdet" updatewhere=1 updatekeyinplace=no arguments=(("as_custno", string),("as_scene", string),("ad_date", date))  sort="seq A " )
