$PBExportHeader$d_cditemwc_s1.srd
$PBExportComments$제품별작업장관리(1998/03/07 - 이인호)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=72 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=68 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=item_no dbname="item.item_no" )
 column=(type=char(20) updatewhereclause=yes name=rout_qa dbname="rout.qa" )
 column=(type=char(20) updatewhereclause=yes name=qa1 dbname="item.qa1" )
 column=(type=long updatewhereclause=yes name=item_pat_no dbname="item.pat_no" )
 column=(type=char(60) updatewhereclause=yes name=item_item_name dbname="item.item_name" )
 retrieve="  SELECT DISTINCT item.item_no
       , rout.qa
       , item.qa1
       , item.pat_no
       , item.item_name  
 FROM item left outer join rout  on  item.item_no = rout.item_no and item.qa1 = rout.qa
   WHERE ( 
                     ( item.item_no   like :as_item )  AND  
	               ( item.use_flag     = 'Y'             )  AND
       		     ( item.item_no      < 'PZZZG'  )
                  )    

/*
    FROM item
       , rout  
   WHERE ( item.item_no       *= rout.item_no) 
     and ( item.qa1           *= rout.qa     )
     and ( ( item.item_no   like :as_item ) AND  
           ( item.use_flag     = 'Y'      ) AND  
           ( item.item_no      < 'PZZZG'  ) 
         )    
*/" arguments=(("as_item", string))  sort="item_no A qa1 A " )
