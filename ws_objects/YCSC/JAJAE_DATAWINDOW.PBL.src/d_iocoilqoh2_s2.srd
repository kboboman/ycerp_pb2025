compute(band=trailer.1 alignment="1" expression="sum(  q_cnt_3  for group 1 )"border="0" color="0" x="2071" y="4" height="68" width="635" format="#,##0" html.valueishtml="0"  name=compute_11 visible="1"  font.face="굴림체" font.height="-11" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="15780518" )
compute(band=trailer.1 alignment="1" expression="sum(  q_cnt_1  for group 1 )"border="0" color="0" x="1445" y="4" height="68" width="617" format="#,##0" html.valueishtml="0"  name=compute_8 visible="1"  font.face="굴림체" font.height="-11" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="15780518" )
compute(band=trailer.1 alignment="0" expression="if( sort1= 'S', 'GI 소계 =','AL 소계 =')"border="0" color="0" x="9" y="4" height="68" width="1157" format="[GENERAL]" html.valueishtml="0"  name=compute_22 visible="1"  font.face="굴림체" font.height="-11" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="15780518" )
compute(band=footer alignment="1" expression="sum(  q_cnt_3  for all )"border="0" color="0" x="2071" y="4" height="68" width="635" format="#,##0" html.valueishtml="0"  name=compute_3 visible="1"  font.face="굴림체" font.height="-11" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="12639424" )
