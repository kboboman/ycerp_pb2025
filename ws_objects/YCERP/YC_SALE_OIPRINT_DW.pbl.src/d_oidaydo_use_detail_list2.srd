release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=224 color="536870912" )
summary(height=0 color="536870912" )
footer(height=92 color="8421504" )
detail(height=96 color="536870912" )
table(column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_name dbname="scene_name" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(10) updatewhereclause=yes name=inside dbname="inside" )
 column=(type=decimal(8) updatewhereclause=yes name=calc_amt dbname="calc_amt" )
 retrieve="       SELECT cust_name   = c.cust_name 
              , scene_name = scene.scene_desc
              , item_name   = g.item_name    
 	         ,  inside      = (case when v.cust_no IS NULL then '1.일반영업' else '2.계열사' end)
              , calc_amt    = sum(dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty) * dodet.price)/1000
           FROM do   with (nolock)
                INNER JOIN dodet       with (nolock) ON do.do_no      = dodet.do_no 
                LEFT OUTER JOIN customer  C with (nolock) ON do.cust_no    = c.cust_no
                LEFT OUTER JOIN login     L with (nolock) ON c.salesman    = l.user_id
                LEFT OUTER JOIN v_cust_inside  V          ON do.cust_no    = v.cust_no
                LEFT OUTER JOIN groupitem G with (nolock) ON dodet.item_no = g.item_no 
                LEFT OUTER JOIN (                
                                                    select a.item_no, a.category, a.item_name, a.type, b.item_nm
                                                      from itemtop10 a with(nolock) inner join (SELECT item_nm, item_cd  FROM codemst with(nolock) WHERE type = 'ITEMTOP10' AND use_yn = 'Y' ) b on a.category = b.item_cd                
                                                ) i ON dodet.item_no = i.item_no    
               LEFT OUTER JOIN scene with(nolock) on do.spot_code = scene.scene_code
          WHERE  do.cust_no = :as_cust_no
         and ( do.do_date   BETWEEN convert(datetime, :as_year + '01' + ' 00:00:00') AND convert(datetime, convert(char(8), dateadd(day,-1, dateadd(month, 1, convert(date, :as_year + '01') ) ), 112) + ' 23:59:59') )
          and (case when v.cust_no IS NULL then '1' else '2' end) like :as_inside
          and isnull(i.item_nm,'99) 미분류') = :as_category
  group by (case when v.cust_no IS NULL then '1.일반영업' else '2.계열사' end), c.cust_name, scene.scene_desc, g.item_name" arguments=(("as_year", string),("as_inside", string),("as_category", string),("as_cust_no", string))  sort="inside A cust_name A scene_name A " )
