 column=(type=long update=yes updatewhereclause=yes key=yes name=seq dbname="seq" )
 column=(type=char(40) updatewhereclause=yes name=scene_name dbname="scene_name" )
 column=(type=char(3) update=yes updatewhereclause=yes name=sub_seq dbname="sub_seq" )
 column=(type=char(30) update=yes updatewhereclause=yes name=subcon_name dbname="subcon_name" )
 column=(type=char(3) update=yes updatewhereclause=yes name=con_seq dbname="con_seq" )
 column=(type=char(30) update=yes updatewhereclause=yes name=con_name dbname="con_name" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(50) update=yes updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(5) update=yes updatewhereclause=yes name=uom dbname="uom" )
 column=(type=char(30) update=yes updatewhereclause=yes name=qa dbname="qa" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=act_qty dbname="act_qty" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=act_price dbname="act_price" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=act_totqty dbname="act_totqty" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=act_amount dbname="act_amount" )
 retrieve="  SELECT chk            = 'N'
       , cust_no        = a.cust_no
       , scene_code     = a.scene_code        
       , SID            = a.sid               /* 일위대가 SID  */
       , SIDQA          = a.sidqa             /* 일위대가 규격 */
       , SIDQTY         = a.sidqty            /* 일위대가 물량 */
       , seq            = a.seq               /* 순번          */
       , scene_name     = b.scene_desc        /* 현장명        */
       , sub_seq        = a.sub_seq           /* 소공사순번    */
       , subcon_name    = a.subcon_name       /* 소공사명      */
       , con_seq        = a.con_seq           /* 공종순번      */
       , con_name       = a.con_name          /* 공종명        */
       , item_no        = a.item_no           /* 자재코드      */
       , item_name      = c.itemnm_p          /* 자재명        */
       , uom            = a.uom               /* 단위          */
       , qa             = c.qa_y              /* 자재규격      */
       , act_qty        = a.act_qty           /* 소요량        */
       , act_price      = a.act_price         /* 단가          */
       , act_totqty     = a.act_totqty        /* 총수량        */
       , act_amount     = a.act_amount        /* 금액          */
    FROM custscene_bomaim a
       , scene            b
       , nbasis_det       c
   WHERE ( a.scene_code     = b.scene_code  )   
     AND ( a.sid            = c.sid         )   
     AND ( a.item_no        = c.item_no     )   
     AND ( a.scene_code     = :as_scene_code)
     AND ( c.cat            = '1.자재비'    )" update="custscene_bomaim" updatewhere=0 updatekeyinplace=no arguments=(("as_scene_code", string))  sort="sid A sidqa A sidqty A seq A " )
