table(column=(type=char(20) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(20) updatewhereclause=yes name=order_no dbname="order_no" )
 column=(type=number updatewhereclause=yes name=maxop dbname="maxop" )
 column=(type=char(20) updatewhereclause=yes name=wc_nm1 dbname="wc_nm1" )
 column=(type=char(20) updatewhereclause=yes name=wc_nm2 dbname="wc_nm2" )
 column=(type=char(20) updatewhereclause=yes name=wc_nm3 dbname="wc_nm3" )
 column=(type=number updatewhereclause=yes name=jan_qty dbname="jan_qty" )
 retrieve="  SELECT work_no     = 'P02'
       , item_no     = a.item_no
       , item_name   = v.item_name
       , cust_no     = a.cust_no
       , cust_name   = c.cust_name
       , scene_code  = a.scene_code
       , scene_desc  = s.scene_desc
       , order_no    = a.order_no
       , seq_no      = a.seq_no
       , due_date    = convert(char(5),a.due_date,101)
       , duedate     = a.due_date

       , order_qty   = a.order_qty
       , rlse_qty    = a.rlse_qty
       , jan_qty     = a.jan_qty
       , maxop       = v.maxop
       , wc1         = v.wc1
       , wc2         = v.wc2
       , wc3         = v.wc3
       , wc_nm1      = w1.work_name
       , wc_nm2      = w2.work_name
       , wc_nm3      = w3.work_name
    FROM v_rout_p02 V 
         INNER JOIN (
               SELECT s.cust_no
                    , s.scene_code
                    , s.due_date
                    , sd.order_no
                    , sd.seq_no
                    , sd.item_no
                    , qa   = left(sd.qa,14) + '00000'
                    , sd.order_qty
                    , sd.rlse_qty
                    , jan_qty     = sd.order_qty - sd.rlse_qty
                 FROM saledet SD with (nolock)
                      LEFT OUTER JOIN sale S with (nolock) ON sd.order_no = s.order_no
                WHERE (s.open_close     = 'O'             )
                  AND (s.order_date    >= dateadd(month, -1, getdate() ) )
                  AND (sd.order_qty     - sd.rlse_qty > 0 )
                  AND (s.due_date      >= '2013/04/01'    )                        
        ) A ON v.item_no = a.item_no  AND v.qa = a.qa
        LEFT OUTER JOIN wc        w1 with (nolock) ON v.wc1        = w1.work_no
        LEFT OUTER JOIN wc        w2 with (nolock) ON v.wc2        = w2.work_no
        LEFT OUTER JOIN wc        w3 with (nolock) ON v.wc3        = w3.work_no
        LEFT OUTER JOIN customer   c with (nolock) ON a.cust_no    = c.cust_no
        LEFT OUTER JOIN scene      s with (nolock) ON a.scene_code = s.scene_code
  WHERE v.item_name is not null
  ORDER BY v.item_name
"  sort="item_name A cust_name A order_no A maxop A wc_nm1 A wc_nm2 A wc_nm3 A " )
group(level=1 header.height=0 trailer.height=76 by=("item_name" ) header.color="536870912" trailer.color="12639424" )
