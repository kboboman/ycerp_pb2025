footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=item_no dbname="ineoymu.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="ineoymu.qa" )
 column=(type=decimal(4) updatewhereclause=yes name=eom_qoh dbname="eom_qoh" )
 column=(type=char(2) updatewhereclause=yes name=groupitem_uom dbname="GroupItem.uom" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 retrieve="  SELECT ineoymu.item_no,   
         ineoymu.qa,   
         eom_qoh = isnull(itemloc.qoh, 0) - isnull(cday.rcpt, 0) + isnull(cday.issue, 0),  
         groupitem.uom,   
         groupitem.item_name  
    FROM ineoymu  left outer join
                    (select item_no, qa, rcpt = sum(rcpt_qty), issue = sum(issue_qty) from ineoday
              			  where cdate > rtrim(:as_year) + rtrim(:as_mon) + '99'
              			    and loc_no = :as_loc 
              				group by item_no, qa
                    ) cday on ineoymu.item_no = cday.item_no and  ineoymu.qa  = cday.qa 
                   left outer join itemloc on ineoymu.loc_no   = itemloc.loc_no  AND ineoymu.item_no  = itemloc.item_no AND ineoymu.qa = itemloc.qa 
                   inner join    groupitem  on ineoymu.item_no     = groupitem.item_no   
                   inner join item on ineoymu.item_no = item.item_no and ineoymu.qa = item.qa          
             WHERE :as_user <> '%' and	
                   ( groupitem.use_flag <> 'C' ) and  
                   ( item.use_flag <> 'C' ) and  
                   ( ineoymu.cyear = rtrim(:as_year)) and  
                   ( ineoymu.cmon = rtrim(:as_mon)) and  
                   ( ( ineoymu.user_id = :as_user ) AND  
                   ( ineoymu.loc_no = :as_loc ) )    
union
  SELECT ineoym.item_no,   
         ineoym.qa,   
         eom_qoh = isnull(itemloc.qoh, 0) - isnull(cday.rcpt, 0) + isnull(cday.issue, 0),  
         groupitem.uom,   
         groupitem.item_name  
  FROM ineoym  left outer join
                     (select item_no, qa, rcpt = sum(rcpt_qty), issue = sum(issue_qty) from ineoday
                  			  where cdate > rtrim(:as_year) + rtrim(:as_mon) + '99'
                  			    and loc_no = :as_loc 
                  				group by item_no, qa
                   ) cday  on ineoym.item_no = cday.item_no and  ineoym.qa  = cday.qa 
                   left outer join itemloc on ineoym.loc_no   = itemloc.loc_no  AND ineoym.item_no  = itemloc.item_no AND ineoym.qa = itemloc.qa 
                   inner join    groupitem  on ineoym.item_no     = groupitem.item_no   
                   inner join item on ineoym.item_no = item.item_no and ineoym.qa = item.qa             
   WHERE :as_user = '%' and
         ( groupitem.use_flag <> 'C' ) and  
         ( item.use_flag <> 'C' ) and  
         ( ineoym.cyear = rtrim(:as_year)) and  
         ( ineoym.cmon = rtrim(:as_mon)) and  
         ( ( ineoym.loc_no = :as_loc ) )      

/*

SELECT ineoymu.item_no,   
         ineoymu.qa,   
         eom_qoh = isnull(itemloc.qoh, 0) - isnull(cday.rcpt, 0) + isnull(cday.issue, 0),  
         groupitem.uom,   
         groupitem.item_name  
    FROM ineoymu,   
         groupitem ,   
         itemloc ,   
			item,   
         (select item_no, qa, rcpt = sum(rcpt_qty), issue = sum(issue_qty) from ineoday
			  where cdate > rtrim(:as_year) + rtrim(:as_mon) + '99'
			    and loc_no = :as_loc 
				group by item_no, qa) cday 
   WHERE :as_user <> '%' and
			( ineoymu.item_no *= cday.item_no) and  
         ( ineoymu.qa *= cday.qa) and  
         ( ineoymu.item_no = groupitem.item_no ) and  
			( ineoymu.item_no = item.item_no) and  
         ( ineoymu.qa = item.qa) and  
         ( groupitem.use_flag <> 'C' ) and  
         ( item.use_flag <> 'C' ) and  
         ( ineoymu.item_no *= itemloc.item_no) and  
         ( ineoymu.qa *= itemloc.qa) and  
         ( ineoymu.loc_no *= itemloc.loc_no) and  
         ( ineoymu.cyear = rtrim(:as_year)) and  
         ( ineoymu.cmon = rtrim(:as_mon)) and  
         ( ( ineoymu.user_id = :as_user ) AND  
         ( ineoymu.loc_no = :as_loc ) )    
union
  SELECT ineoym.item_no,   
         ineoym.qa,   
         eom_qoh = isnull(itemloc.qoh, 0) - isnull(cday.rcpt, 0) + isnull(cday.issue, 0),  
         groupitem.uom,   
         groupitem.item_name  
    FROM ineoym,   
         groupitem ,   
         itemloc ,
			item,   
         (select item_no, qa, rcpt = sum(rcpt_qty), issue = sum(issue_qty) from ineoday
			  where cdate > rtrim(:as_year) + rtrim(:as_mon) + '99'
			    and loc_no = :as_loc 
				group by item_no, qa) cday 
   WHERE :as_user = '%' and
			( ineoym.item_no *= cday.item_no) and  
         ( ineoym.qa *= cday.qa) and  
         ( ineoym.item_no = groupitem.item_no ) and  
			( ineoym.item_no = item.item_no) and  
         ( ineoym.qa = item.qa) and  
         ( groupitem.use_flag <> 'C' ) and  
         ( item.use_flag <> 'C' ) and  
         ( ineoym.item_no *= itemloc.item_no) and  
         ( ineoym.qa *= itemloc.qa) and  
         ( ineoym.loc_no *= itemloc.loc_no) and  
         ( ineoym.cyear = rtrim(:as_year)) and  
         ( ineoym.cmon = rtrim(:as_mon)) and  
         ( ( ineoym.loc_no = :as_loc ) )    
*/" arguments=(("as_year", string),("as_mon", string),("as_user", string),("as_loc", string))  sort="groupitem_item_name A qa A " )
