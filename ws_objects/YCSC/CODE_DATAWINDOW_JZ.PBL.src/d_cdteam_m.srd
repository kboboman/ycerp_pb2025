 column=(type=char(10) update=yes updatewhereclause=yes name=team_manager dbname="team.team_manager" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"team~" ) COLUMN(NAME=~"team.team_code~") COLUMN(NAME=~"team.parent_code~") COLUMN(NAME=~"team.team_name~") COLUMN(NAME=~"team.team_manager~")WHERE(    EXP1 =~"team.team_code~"   OP =~"<>~"    EXP2 =~"'00000'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"team.parent_code~"   OP =~"=~"    EXP2 =~":as_team~" ) ) ARG(NAME = ~"as_team~" TYPE = string) " update="team" updatewhere=1 updatekeyinplace=no arguments=(("as_team", string)) )
