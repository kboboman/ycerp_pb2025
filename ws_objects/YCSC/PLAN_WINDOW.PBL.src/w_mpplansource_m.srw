event itemchanged;string   ls_where, ls_sql, ls_data, ls_scenesql, ls_scene_code, ls_scene_name, ls_null, ls_usernm
long     ll_found, ll_row, ll_cnt

this.accepttext()
setnull(ls_null)

choose case dwo.name
	case "cust_no"
		this.getchild("cust_no", idwc_cust)
		
		ls_data = data
		SELECT count(*) INTO :ll_found FROM customer
		 WHERE cust_no = :ls_data;
		if ll_found = 0 then
			MessageBox("확인","위와 같은고객이 존재하지 않습니다!",exclamation!)
			return 1
		end if
		
		SELECT count(*) INTO :ll_found FROM customer
		 WHERE cust_no = :ls_data AND open_close = 'C';
		if ll_found = 1 then
			MessageBox("확인","사용불가중인 거래처입니다. ~r~n거래처 RELOAD를 하신후 사용하시기 바랍니다.!",exclamation!)
			return 1
		end if

		this.object.scene_code[1] = ls_null
		SELECT count(*) INTO :ll_cnt FROM scene
		 WHERE cust_no = :ls_data;
		 
		idwc_scene.reset() 
		if ll_cnt > 0 then
			// 선택한 거래처의 현장만 보여주기
//			is_scenesql = idwc_scene.describe("datawindow.table.select")
			wf_sceneretrieve(ls_data)
		end if

//		if idwc_scene.rowcount() > 0 then
//			this.object.protect[1] = 'N'
//		else
//			this.object.protect[1] = 'Y'
//		end if
		
//		this.object.cust_no.background.color = rgb(192,192,192)
//		this.object.cust_no.protect = 1
		this.setcolumn("scene_code")
		this.setfocus()
		
	case "scene_code"
		ls_data = data
		SELECT count(*) INTO :ll_cnt FROM scene WHERE cust_no = :ls_data;
		 
		idwc_scene.reset() 
		if ll_cnt > 0 then			
			wf_sceneretrieve(ls_data)	// 선택한 거래처의 현장만 보여주기
		end if

		SELECT count(*) INTO :ll_found FROM scene WHERE scene_code  = :ls_data;
		if ll_found = 0 then
			MessageBox("확인","위와 같은 현장이 존재하지 않습니다!",exclamation!)
			return 1
		end if

	   this.getchild("scene_code", idwc_scene)
		ls_scene_code = this.object.scene_code[1]
		SELECT scene_desc INTO :ls_scene_name FROM scene WHERE scene_code = :ls_scene_code;
		idwc_scene.SetItem(1, "scene_code", ls_scene_code)
		idwc_scene.SetItem(1, "scene_desc", ls_scene_name)
		
		this.setcolumn("item_no")
		this.setfocus()
end choose

RETURN 0

end event

event getfocus;is_dwidx = "dw5"

end event

event clicked;//
long	 ll_protect
string ls_data, ls_usernm, ls_protect

//this.accepttext()
choose case dwo.name
	case "team_chk"
		if (this.object.team_id[row] = gs_userid) and (this.object.div_id[row] = "") then
			ls_data = this.object.team_chk[row]
			if ls_data = "N" then
				SELECT user_name INTO :ls_usernm FROM login WHERE user_id = :gs_userid;
				this.object.team_nm[row] = ls_usernm
				this.object.team_id[row] = gs_userid
			else
				this.object.team_nm[row] = ""
				this.object.team_id[row] = ""
			end if
		elseif string(this.object.team_chk.protect) = "1" then
		else
			ls_data = this.object.team_chk[row]
			if ls_data = "N" then
				SELECT user_name INTO :ls_usernm FROM login WHERE user_id = :gs_userid;
				this.object.team_nm[row] = ls_usernm
				this.object.team_id[row] = gs_userid
			else
				this.object.team_nm[row] = ""
				this.object.team_id[row] = ""
			end if
		end if
		
	case "div_chk"
		ls_protect = string(this.object.div_chk.protect)
		if ls_protect = "1" then
		else
			ls_data = this.object.div_chk[row]
			if ls_data = "N" then
				SELECT user_name INTO :ls_usernm FROM login WHERE user_id = :gs_userid;
				this.object.div_nm[row] = ls_usernm
				this.object.div_id[row] = gs_userid
				if this.object.team_id[row] = "" then
					this.object.team_chk[row] = "Y"
					this.object.team_nm[row] = ls_usernm
					this.object.team_id[row] = gs_userid
				end if
			else
				this.object.div_nm[row] = ""
				this.object.div_id[row] = ""
				if this.object.team_id[row] = gs_userid then
					this.object.team_chk[row] = "N"
					this.object.team_nm[row] = ""
					this.object.team_id[row] = ""
				end if
			end if
		end if
end choose


end event

