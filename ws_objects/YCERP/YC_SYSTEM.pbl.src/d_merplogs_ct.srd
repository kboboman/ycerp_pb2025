 crosstabdata="LOGIN	PDF자료실	매출집계	미출고	생산계획	수주조회	업체검색	여신현황	영업사원	일일업무	지점재고	채권연령	출고조회	출하요청" retrieve="SELECT id      = a.id                                    
     , uid     = a.uid                                   
     , uname   = rtrim(l.user_name)                      
     , olduid  = a.olduid                                
     , oname   = isnull(u.user_name,'')                  
     , sysdate = convert(char(10),a.sysdate,111)         
     , hhmm    = convert(char(5), a.sysdate,108)         
     , pgmdesc = a.pgmdesc                               
     , tcnt    = a.tcnt                                  
     , agent   = isnull(a.http_user_agent,'')            
     , raddr   = isnull(a.remote_addr,'')                
  FROM mERPLOGS a                                        
       LEFT OUTER JOIN login l  ON a.uid    = l.user_id     
       LEFT OUTER JOIN login u  ON a.olduid = u.user_id  
 WHERE a.pgmdesc <> 'LOGOUT'
   AND a.sysdate  between :as_sdate and :as_edate" arguments=(("as_sdate", string),("as_edate", string))  sort="sysdate D uname A " )
group(level=1 header.height=0 trailer.height=84 by=("sysdate" ) header.color="536870912" trailer.color="536870912" )
