table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="itemqa_pattern.item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="groupitem.item_name" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=qa dbname="itemqa_pattern.qa" )
 column=(type=char(2) update=yes updatewhereclause=yes key=yes name=uom dbname="itemqa_pattern.uom" )
