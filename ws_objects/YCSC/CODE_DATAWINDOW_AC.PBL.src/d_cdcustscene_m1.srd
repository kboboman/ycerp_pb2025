table(column=(type=char(4) update=yes updatewhereclause=yes key=yes name=cust_no dbname="custscene.cust_no" )
 column=(type=char(11) update=yes updatewhereclause=yes key=yes name=scene_code dbname="custscene.scene_code" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="custscene.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=qa dbname="custscene.qa" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="custscene.uom" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=pre_cost dbname="custscene.pre_cost" initial="0" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=price dbname="custscene.price" initial="0" )
 column=(type=char(30) update=yes updatewhereclause=yes name=rem dbname="custscene.rem" )
 column=(type=char(10) update=yes updatewhereclause=yes name=user_id dbname="custscene.user_id" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=custscene_std_cost dbname="custscene.std_cost" initial="0" )
 column=(type=datetime update=yes updatewhereclause=yes name=sys_date dbname="custscene.sys_date" )
 column=(type=decimal(4) updatewhereclause=yes name=std_cost dbname="itemcost.price" )
 column=(type=long updatewhereclause=yes name=c_price dbname="c_price" initial="0" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene.scene_desc" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 retrieve="  SELECT custscene.cust_no      
       , custscene.scene_code   
       , custscene.item_no      
       , custscene.qa           
       , custscene.uom          
       , custscene.pre_cost     
       , custscene.price        
       , custscene.rem          
       , custscene.user_id  
       , custscene.std_cost     
       , custscene.sys_date     
       , itemcost.price         
       , c_price  = 0
       , customer.cust_name
       , scene.scene_desc
       , groupitem.item_name    
    FROM custscene   
       , itemcost    
       , groupitem   
       , customer  
       , scene
   WHERE ( custscene.item_no     = itemcost.item_no   )  
     AND ( custscene.qa          = itemcost.qa        )  
     AND ( itemcost.item_no      = groupitem.item_no  )  
     AND ( custscene.cust_no     = customer.cust_no   )  
     AND ( custscene.scene_code  = scene.scene_code   )  
     AND ( ( custscene.cust_no       = :as_custno    ) AND  
           ( custscene.scene_code    = :as_sceneno   ) AND  
           ( customer.salesman    like :as_salesman  ) 
         )    
" update="custscene" updatewhere=0 updatekeyinplace=no arguments=(("as_custno", string),("as_sceneno", string),("as_salesman", string))  sort="item_no A qa A " )
