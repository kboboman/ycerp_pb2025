datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=long updatewhereclause=yes name=spid dbname="spid" )
 column=(type=long updatewhereclause=yes name=blocked dbname="blocked" )
 column=(type=char(255) updatewhereclause=yes name=program_name dbname="program_name" )
 column=(type=char(255) updatewhereclause=yes name=loginname dbname="loginname" )
 column=(type=char(255) updatewhereclause=yes name=hostname dbname="hostname" )
 column=(type=char(24) updatewhereclause=yes name=macaddr dbname="macaddr" )
 column=(type=char(30) updatewhereclause=yes name=login_time dbname="login_time" )
 column=(type=char(30) updatewhereclause=yes name=last_batch dbname="last_batch" )
 column=(type=long updatewhereclause=yes name=use_hour dbname="use_hour" )
 retrieve="SELECT spid         = s.spid
     , blocked      = s.blocked
     , program_name = rtrim(s.program_name)
     , loginname    = rtrim(s.loginame)
     , hostname     = rtrim(s.hostname)
     , macaddr      = rtrim(s.net_address)
     , login_time   = convert(varchar, s.login_time, 20)
     , last_batch   = convert(varchar, s.last_batch, 20)
     , use_hour     = datediff(hh, s.login_time, last_batch)
  FROM master.dbo.sysprocesses S
 ORDER BY spid   
" )
