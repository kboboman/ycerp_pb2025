               case "vat_user"   // VAT담당자                  
                  if isnull(ls_vat_user) then                  
                  else                                         
                     UPDATE customer SET vat_user = :ls_vat_user  WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if                                       

               case "vat_phone"   // VAT연락처                 
                  if isnull(ls_vat_phone) then                 
                  else                                         
                     UPDATE customer SET vat_phone = :ls_vat_phone  WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if                                       

               case "vat_email"   // VAT메일                   
                  if isnull(ls_vat_email) then                 
                  else                                         
                     UPDATE customer SET vat_email = :ls_vat_email  WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if                                       

               case "icube_no"   // 더존                       
                  if isnull(ls_icube_no) then                  
                  else                                         
                     UPDATE customer SET icube_no = :ls_icube_no  WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if 
						
               case "dambo_ymde"   // 담보만기                          
                  if isnull(ld_dambo_ymde) then                  
                  else                                         
                     UPDATE customer SET dambo_ymde = :ld_dambo_ymde  WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if 

               case "captain_relation"   // 대표자관계                          
                  if isnull(ls_captain_relation) then                  
                  else                                         
                     UPDATE customer SET captain_relation = :ls_captain_relation  WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if 

               case "dambo_bigo"   		// 담보비고                          
                  if isnull(ls_dambo_bigo) then                  
                  else                                         
                     UPDATE customer SET dambo_bigo = :ls_dambo_bigo  WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if 

               //////////////////////////////////////////////////////////////////////
					case "custmain"   // 주거래건설사(CUSTINFO)
                  if isnull(ls_custmain) then                  
                  else                                         
                     UPDATE custinfo SET main_co = :ls_custmain  WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if 

               case "licensenm"   // 면허명(CUSTINFO)                          
                  if isnull(ls_licensenm) then                  
                  else                                         
                     UPDATE custinfo SET license_name = :ls_licensenm  WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if 
						
						
               case "addr1"   // 거래처우편                    
                  if isnull(ls_addr1) then                     
                  else                                         
                     UPDATE customer SET addr1 = :ls_addr1  WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if                      						
						
               case "addr"   // 거래처주소
                  if isnull(ls_addr) then                     
                  else                                         
                     UPDATE customer SET addr = :ls_addr  WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if                      						
						

               case "top_level"   // 종합등급
                  if isnull(ls_top_level) then                     
                  else                                         
                     UPDATE customer SET  top_level= :ls_top_level  WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if                						
						
            end choose                                         
            //////////////////////////////////////////////////////////////
                                                               
            if SWUpdate <> 0 then                              
               ROLLBACK;                                       
               mle_1.text = mle_1.text + string(ll_row,"000") + "행 오류 : " + ls_custno + "~r~n"
            end if                                             
            //////////////////////////////////////////////////////////////
         end if                                                
      next                                                     
   end if                                                      
next                                                           

SetPointer(oldpointer)
dw_26.enabled = true
MessageBox("확인", "거래처 일괄변경 작업완료 하였습니다.")

end event

type cbx_all from checkbox within tabpage_7
integer x = 59
integer y = 128
integer width = 238
integer height = 60
integer textsize = -10
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
long textcolor = 128
long backcolor = 79220952
string text = "전체"
end type

event clicked;//
string ls_field, ls_chk
long   ll_row, ll_width

for ll_row = 1 to dw_26.rowcount()
	if cbx_all.checked = true then
		dw_26.object.chk[ll_row] = "Y"
	else
		dw_26.object.chk[ll_row] = "N"
	end if

	ls_field = dw_26.object.field[ll_row]
	ll_width = dw_26.object.lwidth[ll_row]
	
	if isnull(ls_field) OR ls_field = "" then
	else
		ls_chk  = dw_26.object.chk[ll_row]
		choose case ls_chk 
			case "Y"
				dw_27.Modify( ls_field + ".width=" + string(ll_width) )
			case "N"
				dw_27.Modify( ls_field + ".width=0" )
		end choose				
	end if
next


end event

type cb_import from commandbutton within tabpage_7
integer x = 1911
integer y = 8
integer width = 503
integer height = 80
integer taborder = 260
integer textsize = -10
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "엑셀 가져오기"
end type

event clicked;// 엑셀 가져오기
Pointer oldpointer // Declares a pointer variable
string  ls_chk, ls_field, ls_type, ls_custno, ls_custnm, ls_value
long    ll_cnt, ll_xlsRows, ll_dw26row, ll_dw27row, iRow, ll_id, ll_find
Boolean SWExit

oldpointer = SetPointer(HourGlass!)

/////////////////////////////////////////////////////////////////////////
// 데이터 실행범위 설정
/////////////////////////////////////////////////////////////////////////
// ll_xlsRows = xlSheet.Application.WorksheetFunction.COUNTA(oRng,"")-2
// string oRng = "A:A"
/////////////////////////////////////////////////////////////////////////
SWExit = true
Do While SWExit
	ll_xlsRows = ll_xlsRows + 1

	iRow = iRow + 1
	if IsNull(xlSheet.Cells[iRow, 1].Value) then SWExit = false
Loop		// 로우MAX
/////////////////////////////////////////////////////////////////////////

// 엑셀가져오기
date    ldate_value
decimal ldec_value

iRow   = 2
ll_cnt = 0
hpb_1.position = 0
hpb_1.visible  = true
xlsImport      = true

ls_custno = trim(string(xlSheet.Cells[1,  1].Value))   // 코드                              
ls_custnm = trim(string(xlSheet.Cells[1,  2].Value))   // 거래처명
if ls_custno = "코드" AND ls_custnm = "거래처명" then
else
	MessageBox("확인","엑셀파일의 A열, B열은 '코드', '거래처명' 으로 시작해야합니다.")
	RETURN
end if


dw_27.SetRedraw( false )
Do While xlsImport
	ll_cnt = ll_cnt + 1
	
   hpb_1.position = (ll_cnt / ll_xlsRows) * 100

   ls_custno  = trim(string(xlSheet.Cells[iRow,  1].Value))   // 거래처코드       
	if isnull(ls_custno) OR ls_custno = "" OR LenA(ls_custno) <> 4 then
		// SKIP
	else
		ll_dw27row = dw_27.insertrow(0)
		
		//dw_27.ScrollToRow(ll_dw27row)

		dw_27.object.chk[ll_dw27row]       = "N"                                     // 선택                              
		dw_27.object.cust_no[ll_dw27row]   = string(xlSheet.Cells[iRow,  1].Value)   // 코드                              
		dw_27.object.cust_name[ll_dw27row] = string(xlSheet.Cells[iRow,  2].Value)   // 거래처 
		
		for ll_dw26row = 1 to dw_26.rowcount()
			ls_chk     = dw_26.object.chk[ll_dw26row]
			ls_field   = dw_26.object.field[ll_dw26row]
			ls_type    = dw_26.object.ftype[ll_dw26row]
			ll_id      = dw_26.object.id[ll_dw26row] + 2
			
//			if isnull(ll_id) = false then
//				messagebox('알림', string(dw_26.object.id[ll_dw26row]) )
//			end if
			
			if ls_chk = "Y" then
				choose case ls_type
					// "여신일자", "계약일", "담보일자", "담보만기", "채권관리", "대표자생년"
					case "DATE"
						if isnull(string(xlSheet.Cells[iRow, ll_id].Value)) then
						else
							ldate_value = Date(xlSheet.Cells[iRow, ll_id].Value)
							dw_27.SetItem(ll_dw27row, ls_field, ldate_value)
						end if
					
					// "신용한도액", "보증금액", "담보금액", "회전월"
					case "DEC"
						if isnull(string(xlSheet.Cells[iRow, ll_id].Value)) then
						else
							ldec_value  = dec(xlSheet.Cells[iRow, ll_id].Value)
							dw_27.SetItem(ll_dw27row, ls_field, ldec_value)
						end if						

					case else
						if isnull(string(xlSheet.Cells[iRow, ll_id].Value)) then
						else
							ls_value    = string(xlSheet.Cells[iRow, ll_id].Value)
							dw_27.SetItem(ll_dw27row, ls_field, ls_value)
						end if
				end choose
			end if
		next
	end if
	
	iRow = iRow + 1

	if IsNull(xlSheet.Cells[iRow, 1].Value) then xlsImport = false
Loop
dw_27.SetRedraw( true )
SetPointer(oldpointer)

dw_26.enabled     = true
cb_excute.enabled = true

cb_import.text    = "엑셀 가져오기"
cb_import.enabled = false

ddlb_sheet.reset()
ddlb_sheet.enabled = false
hpb_1.position = 0
hpb_1.visible  = true

// Quits Excel
OleExcel.Application.Quit()
OleExcel.DisconnectObject()       

Destroy xlSheet
Destroy OleExcel

end event

