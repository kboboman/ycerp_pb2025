release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=type_cd dbname="TYPE_CD" )
 column=(type=char(30) update=yes updatewhereclause=yes name=type_nm dbname="TYPE_NM" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=code_cd dbname="CODE_CD" )
 column=(type=char(30) update=yes updatewhereclause=yes name=code_nm dbname="CODE_NM" )
 retrieve="  SELECT TYPE_CD,   
         TYPE_NM,   
         CODE_CD,   
         CODE_NM  
    FROM code_table   
   WHERE type_cd    LIKE :as_cd" update="code_table" updatewhere=1 updatekeyinplace=no arguments=(("as_cd", string)) )
