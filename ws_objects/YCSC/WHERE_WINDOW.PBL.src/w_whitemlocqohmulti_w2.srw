event clicked;// 품목조회
string ls_filter, ls_custno, ls_locno
long   ll_row

dw_4.accepttext()
ls_custno = trim(UPPER(dw_4.object.cust_no[1]))

if isnull(ls_custno) OR ls_custno = "" then 
	is_where = ""
else
	if rb_code.checked = true then
		ls_filter = ls_custno + '%'
		is_where = "item_no like '" + ls_filter + "'"
	else
		ls_filter = '%' + ls_custno + '%'
		is_where = "item_name like '" + ls_filter + "'"
	end if
end if
dw_2.SetFilter(is_where)
dw_2.Filter()

// 규격 리스트
dw_3.reset()
ll_row = dw_2.getrow()
if isnull(ll_row) or ll_row < 1 then return		// 품목

ls_locno  = dw_loc.object.loc_no[1]
ls_custno = dw_2.object.item_no[ll_row]

/*2018.02.07 조원석 수정 대전저장소는 대전저장소로 나머지는 %  */
//if ls_locno = 'WS00000011' THEN
//	ls_locno = 'WS00000011'
//ELSE
//	ls_locno = '%'
//END IF

dw_3.setredraw(false)
dw_3.retrieve( ls_locno, ls_custno )
dw_3.setredraw(true)

end event

