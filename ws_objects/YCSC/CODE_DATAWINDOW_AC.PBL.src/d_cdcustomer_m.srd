 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"customer~" ) COLUMN(NAME=~"customer.cust_no~") COLUMN(NAME=~"customer.register_no~") COLUMN(NAME=~"customer.cust_name~") COLUMN(NAME=~"customer.captain_name~") COLUMN(NAME=~"customer.industry_code~") COLUMN(NAME=~"customer.industry_type~") COLUMN(NAME=~"customer.addr~") COLUMN(NAME=~"customer.tel_no~") COLUMN(NAME=~"customer.contact~") COLUMN(NAME=~"customer.duty~") COLUMN(NAME=~"customer.salesman~") COLUMN(NAME=~"customer.credit_limit~") COLUMN(NAME=~"customer.terms~") COLUMN(NAME=~"customer.curr_code~") COLUMN(NAME=~"customer.shipto_addr~") COLUMN(NAME=~"customer.last_tn_date~") COLUMN(NAME=~"customer.fax_no~") COLUMN(NAME=~"customer.cust_type~") COLUMN(NAME=~"customer.credit_level~") COLUMN(NAME=~"customer.bank_name~") COLUMN(NAME=~"customer.license_name~") COLUMN(NAME=~"customer.balance_amt~") COLUMN(NAME=~"customer.start_date~") COLUMN(NAME=~"customer.main_co~") COLUMN(NAME=~"customer.balbf_amt~") COLUMN(NAME=~"customer.year_balbf~") COLUMN(NAME=~"customer.rem~") COLUMN(NAME=~"customer.emp_qty~") COLUMN(NAME=~"customer.resident_card~") COLUMN(NAME=~"customer.fob~")WHERE(    EXP1 =~"customer.cust_no~"   OP =~"=~"    EXP2 =~":as_custno~" ) ) ARG(NAME = ~"as_custno~" TYPE = string) " update="customer" updatewhere=1 updatekeyinplace=no arguments=(("as_custno", string)) )
