table(column=(type=char(10) updatewhereclause=yes key=yes name=assembly dbname="bom.assembly" )
 column=(type=char(20) updatewhereclause=yes key=yes name=assembly_qa dbname="bom.assembly_qa" )
 column=(type=long updatewhereclause=yes key=yes name=sequence dbname="bom.sequence" )
 column=(type=char(10) updatewhereclause=yes name=component dbname="bom.component" )
 column=(type=char(20) updatewhereclause=yes name=component_qa dbname="bom.component_qa" )
 column=(type=decimal(4) updatewhereclause=yes name=qpa dbname="bom.qpa" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"bom~" ) COLUMN(NAME=~"bom.assembly~") COLUMN(NAME=~"bom.assembly_qa~") COLUMN(NAME=~"bom.sequence~") COLUMN(NAME=~"bom.component~") COLUMN(NAME=~"bom.component_qa~") COLUMN(NAME=~"bom.qpa~")WHERE(    EXP1 =~"bom.assembly~"   OP =~"=~"    EXP2 =~":arg_item~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"bom.assembly_qa~"   OP =~"like~"    EXP2 =~":arg_qa~" ) ) ARG(NAME = ~"arg_item~" TYPE = string)  ARG(NAME = ~"arg_qa~" TYPE = string) " update="bom" updatewhere=0 updatekeyinplace=no arguments=(("arg_item", string),("arg_qa", string)) )
