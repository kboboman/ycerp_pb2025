$PBExportHeader$d_opeom_customer_check.srd
$PBExportComments$판매거래처와 OPEOM CHECK(1998/02/23 - 김구현)
release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes key=yes name=customer_cust_no dbname="customer.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=decimal(4) updatewhereclause=yes name=customer_bill_amount dbname="customer.bill_amount" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=customer_balance_amt dbname="customer.balance_amt" )
 column=(type=decimal(2) updatewhereclause=yes name=balance_amt2 dbname="balance_amt2" )
 column=(type=long updatewhereclause=yes name=cyear dbname="cyear" )
 column=(type=decimal(2) updatewhereclause=yes name=eom_amt dbname="eom_amt" )
 retrieve="  SELECT customer.cust_no       
       , customer.cust_name     
       , customer.bill_amount   
       , customer.balance_amt   
       , balance_amt2 = ( customer.balance_amt 
                        - (SELECT isnull(sum(inv_01  + inv_02  + inv_03  + inv_04  + inv_05  + inv_06 
                                           + inv_07  + inv_08  + inv_09  + inv_10  + inv_11  + inv_12 
                                           - coll_01 - coll_02 - coll_03 - coll_04 - coll_05 - coll_06 
                                           - coll_07 - coll_08 - coll_09 - coll_10 - coll_11 - coll_12), 0) 
                             FROM opeom A
                            WHERE ( customer.cust_no         = A.cust_no ) 
                              AND ( datepart(year, eom_year) > :ai_year  )
                           )
                        )
       , cyear        = datepart(year, eom_year) 
       , eom_amt      = isnull((balbf_amount 
                      + inv_01 + inv_02 + inv_03 + inv_04 + inv_05 + inv_06 
                      + inv_07 + inv_08 + inv_09 + inv_10 + inv_11 + inv_12 
                      - coll_01 - coll_02 - coll_03 - coll_04 - coll_05 - coll_06 
                      - coll_07 - coll_08 - coll_09 - coll_10 - coll_11 - coll_12 ),0)  
    FROM customer,   
         opeom  
   WHERE ( customer.cust_no         *= opeom.cust_no ) 
     AND ( datepart(year, eom_year)  = :ai_year      ) 
" update="customer" updatewhere=0 updatekeyinplace=no arguments=(("ai_year", number))  sort="customer_cust_name A " )
