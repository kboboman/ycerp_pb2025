event keydown;long ll_row,i
string ls_wc,ls_wc1,ls_flag

IF keyflags = 1 THEN
   IF keydown(KeyLeftButton!) THEN
		ll_row = this.getrow()
      if ll_row < 1 then return
      this.accepttext()
		for i = ll_row to 1 step -1
			 if i <> ll_row then
				 if this.IsSelected(i) = true then
					 exit
				 end if
			 end if
          this.SelectRow(i, NOT this.IsSelected(i))
		next
	END IF
END IF

end event

event rowfocuschanged;long ll_row
string ls_order

ll_row = this.getrow()
if ll_row < 1 then return

if cbx_2.checked = true then return

ls_order = this.object.coilorderdet_order_no[ll_row]

dw_10.retrieve(ls_order)

end event

event clicked;if row < 1 then return

string ls_filter, ls_order
long ll_row
int li_cnt

if cbx_2.checked = true then
	this.SelectRow(row, NOT this.IsSelected(row))
	ls_filter = ''
	li_cnt = 0
	for ll_row = 1 to this.rowcount()
		if this.isselected(ll_row) = true then
			ls_order = this.object.coilorderdet_order_no[ll_row]
			if li_cnt = 0 then
				ls_filter = "coilsliting_order_no = '" + ls_order + "'"
				li_cnt = 1
			else
				ls_filter = ls_filter + " OR coilsliting_order_no = '" + ls_order + "'"
			end if
		end if
	next
	if ls_filter = '' then
		ls_filter = "coilsliting_order_no = 'NON'"
	end if
	dw10.SetFilter(ls_filter)
	dw10.Filter( )
end if



end event

