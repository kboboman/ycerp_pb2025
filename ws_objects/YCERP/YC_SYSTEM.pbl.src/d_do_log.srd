$PBExportComments$접속로그[2006/06/27]이기영
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=84 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=log_date dbname="log_date" )
 column=(type=long updatewhereclause=yes name=log_seq dbname="do_log.log_seq" )
 column=(type=char(10) updatewhereclause=yes name=gs_userid dbname="do_log.gs_userid" )
 column=(type=char(10) updatewhereclause=yes name=gs_username dbname="gs_username" )
 column=(type=char(15) updatewhereclause=yes name=do_no dbname="do_log.do_no" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="do_log.user_id" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(20) updatewhereclause=yes name=do_area_no dbname="do_area_no" )
 column=(type=char(1) updatewhereclause=yes name=do_case dbname="do_log.do_case" values="정상	A/미수불	C/반품내역	D/" )
 column=(type=char(10) updatewhereclause=yes name=do_date dbname="do_date" )
 column=(type=char(10) updatewhereclause=yes name=issue_date dbname="issue_date" )
 column=(type=char(1) updatewhereclause=yes name=ship_flag dbname="do_log.ship_flag" )
 column=(type=decimal(0) updatewhereclause=yes name=ship_amount dbname="do_log.ship_amount" )
 column=(type=decimal(0) updatewhereclause=yes name=do_cash dbname="do_log.do_cash" )
 column=(type=decimal(0) updatewhereclause=yes name=do_rate dbname="do_log.do_rate" )
 column=(type=decimal(0) updatewhereclause=yes name=do_total dbname="do_log.do_total" )
 column=(type=char(50) updatewhereclause=yes name=do_jobtype dbname="do_jobtype" )
 column=(type=char(60) updatewhereclause=yes name=do_jobdesc dbname="do_log.do_jobdesc" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="do_log.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_nm dbname="cust_nm" )
 column=(type=char(11) updatewhereclause=yes name=spot_code dbname="do_log.spot_code" )
 column=(type=char(40) updatewhereclause=yes name=spot_nm dbname="spot_nm" )
 column=(type=char(30) updatewhereclause=yes name=pgm_name dbname="do_log.pgm_name" )
 column=(type=char(255) updatewhereclause=yes name=contents dbname="do_log.contents" )
 retrieve="SELECT log_date    = CONVERT(CHAR(10), log_date, 111)
     , log_seq     
     , gs_userid   
     , gs_username = (SELECT TOP 1 user_name FROM login WHERE user_id = do_log.gs_userid)
     , do_no       
     , user_id     
     , user_name   = (SELECT TOP 1 user_name FROM login WHERE user_id = do_log.user_id)
     , do_area_no  = (SELECT TOP 1 area_name FROM area  WHERE area_no = do_log.do_area_no)
     , do_case     
     , do_date     = CONVERT(CHAR(10), do_date,    111)
     , issue_date  = CONVERT(CHAR(10), issue_date, 111)
     , ship_flag
     , ship_amount
     , do_cash    
     , do_rate    
     , do_total   
     , do_jobtype = (SELECT item_nm FROM codemst WHERE item_cd = (SELECT do_jobtype FROM do  WHERE do_no = do_log.do_no) )
     , do_jobdesc
     , cust_no    
     , cust_nm    = (SELECT TOP 1 cust_name  FROM customer WHERE cust_no = do_log.cust_no)
     , spot_code  
     , spot_nm    = (SELECT TOP 1 scene_desc FROM scene    WHERE cust_no = do_log.cust_no AND scene_code = do_log.spot_code)
     , pgm_name
     , contents
  FROM do_log
 WHERE ( :as_flag = 'A' and log_date BETWEEN :ad_start_date AND :ad_end_date )
    OR ( :as_flag = 'B' and do_date  BETWEEN :ad_start_date AND :ad_end_date )
" arguments=(("as_flag", string),("ad_start_date", date),("ad_end_date", date))  sort="log_date D log_seq A " )
