$PBExportComments$코일입고확인서(2004/03/19,이인호) 코일 외
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no rows_per_detail = 15 )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=4288 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=insp_insp_date dbname="insp.insp_date" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(20) updatewhereclause=yes name=thin dbname="thin" )
 column=(type=char(2) updatewhereclause=yes name=inspdet_uom dbname="inspdet.uom" )
 column=(type=long updatewhereclause=yes name=coilmst_length dbname="coilmst.length" )
 column=(type=decimal(2) updatewhereclause=yes name=inspdet_cnt dbname="cnt" )
 column=(type=decimal(4) updatewhereclause=yes name=inspdet_comqty dbname="inspdet.comqty" )
 column=(type=char(20) updatewhereclause=yes name=inspdet_coil_no dbname="inspdet.coil_no" )
 retrieve="  SELECT insp.insp_date
       , groupitem.item_name
       , thin  = inspdet.qa
       , inspdet.uom
       , coilS.length
       , cnt   = inspdet.rcpt_qty
       , inspdet.comqty
       , inspdet.coil_no
FROM insp inner join  inspdet on insp.insp_no     = inspdet.insp_no                             
			     inner join  groupitem on inspdet.item_no  = groupitem.item_no
			  	left outer join coilmst coilS on   inspdet.coil_no  = coilS.coil_no  and inspdet.loc_no = coilS.loc_no
WHERE ( insp.insp_no     = :as_insp          )
/*
    FROM insp
       , inspdet
       , groupitem
       , coilmst coilS
   WHERE ( insp.insp_no     = inspdet.insp_no   ) 
     AND ( inspdet.coil_no *= coilS.coil_no     )
     AND ( inspdet.loc_no  *= coilS.loc_no      )
     AND ( inspdet.item_no  = groupitem.item_no ) 
     AND ( insp.insp_no     = :as_insp          )
*/
" arguments=(("as_insp", string)) )
