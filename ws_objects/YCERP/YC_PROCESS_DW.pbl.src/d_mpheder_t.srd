 retrieve="  SELECT mps.order_no,   
         mps.wc_no,   
         mps.start_date,   
         mps.order_date,   
         mps.due_date,   
         mps.planner,   
         mps.work_time,   
         mps.open_close,   
         mps.close_date,   
         mps.revision_no,   
         mps.revision_date,   
         mps.rem  
    FROM mps   
" update="mps" updatewhere=1 updatekeyinplace=no )
