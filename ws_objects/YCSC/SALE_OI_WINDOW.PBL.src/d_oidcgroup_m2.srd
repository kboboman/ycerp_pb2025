table(column=(type=char(14) update=yes updatewhereclause=yes key=yes name=dc_groupno dbname="dc_groupdet.dc_groupno" )
 column=(type=char(4) update=yes updatewhereclause=yes key=yes name=cust_no dbname="dc_groupdet.cust_no" )
 column=(type=char(11) update=yes updatewhereclause=yes key=yes name=scene_code dbname="dc_groupdet.scene_code" )
 column=(type=char(14) update=yes updatewhereclause=yes name=do_no dbname="dc_groupdet.do_no" )
 column=(type=long update=yes updatewhereclause=yes name=oi_no dbname="dc_groupdet.oi_no" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=seq_no dbname="dc_groupdet.seq_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="dc_groupdet.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="dc_groupdet.qa" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa_cust dbname="dc_groupdet.qa_cust" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=ship_qty dbname="dc_groupdet.ship_qty" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=price dbname="dc_groupdet.price" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=aroi_qty dbname="dc_groupdet.aroi_qty" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="dc_groupdet.uom" )
 column=(type=char(14) update=yes updatewhereclause=yes name=sale_no dbname="dc_groupdet.sale_no" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=rate_cash dbname="dc_groupdet.rate_cash" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=calc_amt dbname="dc_groupdet.calc_amt" initial="0" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=calc_rate dbname="dc_groupdet.calc_rate" initial="0" )
 column=(type=char(50) update=yes updatewhereclause=yes name=rem dbname="dc_groupdet.rem" )
 column=(type=char(12) update=yes updatewhereclause=yes name=do_rem dbname="dc_groupdet.do_rem" )
 column=(type=char(20) update=yes updatewhereclause=yes name=coil_no dbname="dc_groupdet.coil_no" )
 column=(type=long update=yes updatewhereclause=yes name=cnt dbname="dc_groupdet.cnt" )
 column=(type=char(10) update=yes updatewhereclause=yes name=loc_no dbname="dc_groupdet.loc_no" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=stock_qty dbname="dc_groupdet.stock_qty" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene.scene_desc" )
 retrieve="  SELECT dc_groupdet.dc_groupno,   
         dc_groupdet.cust_no,   
         dc_groupdet.scene_code,   
         dc_groupdet.do_no,   
         dc_groupdet.oi_no,   
         dc_groupdet.seq_no,   
         dc_groupdet.item_no,   
         dc_groupdet.qa,   
         dc_groupdet.qa_cust,   
         dc_groupdet.ship_qty,   
         dc_groupdet.price,   
         dc_groupdet.aroi_qty,   
         dc_groupdet.uom,   
         dc_groupdet.sale_no,   
         dc_groupdet.rate_cash,   
         dc_groupdet.calc_amt,   
         dc_groupdet.calc_rate,   
         dc_groupdet.rem,   
         dc_groupdet.do_rem,   
         dc_groupdet.coil_no,   
         dc_groupdet.cnt,   
         dc_groupdet.loc_no,   
         dc_groupdet.stock_qty,
         customer.cust_name,  
         scene.scene_desc  
    FROM dc_groupdet  
         LEFT OUTER JOIN customer ON dc_groupdet.cust_no    = customer.cust_no
         LEFT OUTER JOIN scene    ON dc_groupdet.scene_code = scene.scene_code
   WHERE dc_groupdet.dc_groupno = :as_groupno    
" update="dc_groupdet" updatewhere=0 updatekeyinplace=no arguments=(("as_groupno", string)) )
