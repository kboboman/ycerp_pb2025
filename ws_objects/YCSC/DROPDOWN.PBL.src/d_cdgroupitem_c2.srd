 retrieve="  SELECT groupitem.item_no,   
         groupitem.uom,   
         groupitem.source,   
         groupitem.item_name  
    FROM groupitem  
   WHERE groupitem.use_flag <> 'C'" update="groupitem" updatewhere=0 updatekeyinplace=no  sort="item_name A " )
