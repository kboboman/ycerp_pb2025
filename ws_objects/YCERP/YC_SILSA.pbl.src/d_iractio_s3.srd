$PBExportHeader$d_iractio_s3.srd
$PBExportComments$실사차이보고서(2000/09/02,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=88 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=char(30) updatewhereclause=yes name=loc_name dbname="loc_name" )
 column=(type=decimal(4) updatewhereclause=yes name=eom_qoh dbname="eom_qoh" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=qoh dbname="qoh" initial="0" )
 column=(type=char(26) updatewhereclause=yes name=title dbname="title" )
 retrieve="SELECT item_no     = itemloc.item_no   
     , qa          = itemloc.qa        
     , item_name   = g.item_name
     , uom         = g.uom
     , loc_name    = l.loc_name      
     , eom_qoh     = itemloc.qoh - isnull(cday.rcpt, 0) + isnull(cday.issue, 0)   /* 월말재고(현재고-입고+출고) */
     , qoh         = isnull(ineoym.qoh, 0)                                        /* 실사수량 */
     , title       = convert(char(4),:as_year) + '년 ' + convert(char(2),:as_mon) + '월 실사차이보고서'
  FROM itemloc    (nolock) 
       LEFT OUTER JOIN groupitem G (nolock) ON itemloc.item_no = g.item_no AND g.use_flag = 'Y'
       LEFT OUTER JOIN location  L (nolock) ON itemloc.loc_no  = l.loc_no
       LEFT OUTER JOIN ineoym      (nolock) ON itemloc.loc_no  = ineoym.loc_no 
                                           AND itemloc.item_no = ineoym.item_no
                                           AND itemloc.qa      = ineoym.qa
                                           AND ineoym.cyear = :as_year AND ineoym.cmon = :as_mon   
       LEFT OUTER JOIN (
            SELECT loc_no, item_no, qa, rcpt = sum(rcpt_qty), issue = sum(issue_qty) 
              FROM ineoym (nolock)
             WHERE loc_no   = :as_loc 
               AND (( cyear = :as_year AND cmon > :as_mon ) OR ( cyear > :as_year ) )
             GROUP BY loc_no, item_no, qa
       ) cday ON itemloc.loc_no = cday.loc_no AND itemloc.item_no = cday.item_no AND itemloc.qa = cday.qa
 WHERE ( itemloc.loc_no     = :as_loc      ) 
   AND ( itemloc.item_no    < 'PZZZ'       )
   AND ( itemloc.item_no  NOT IN ('GZZZMISZZZ', 'GCYZZZZZZZ') ) /* 기타(Y.S.P), 전월착오분 */
   AND ( itemloc.item_no LIKE :as_item AND g.item_name LIKE :as_name ) 
   AND ( g.item_name  NOT LIKE '%LOSS%' )
   AND ( NOT (g.uom = 'M2' AND g.item_no like 'PCY%') ) 
" arguments=(("as_loc", string),("as_year", string),("as_mon", string),("as_item", string),("as_name", string))  sort="item_name A qa A " )
