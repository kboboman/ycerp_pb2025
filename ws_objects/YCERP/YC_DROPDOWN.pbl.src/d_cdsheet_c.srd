$PBExportHeader$d_cdsheet_c.srd
$PBExportComments$SHEET리스트(open_close ='O')(1998/05/18,곽용덕)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=sheet_no dbname="sheetmst.sheet_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="sheetmst.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="sheetmst.qa" )
 column=(type=char(10) updatewhereclause=yes name=loc_no dbname="sheetmst.loc_no" )
 column=(type=long updatewhereclause=yes name=qcnt dbname="sheetmst.qcnt" )
 column=(type=decimal(4) updatewhereclause=yes name=unit_qty dbname="sheetmst.unit_qty" )
 column=(type=char(30) updatewhereclause=yes name=loc_name dbname="location.loc_name" )
 retrieve="  SELECT sheetmst.sheet_no,   
         sheetmst.item_no,   
         sheetmst.qa,   
         sheetmst.loc_no,   
         sheetmst.qcnt,   
         sheetmst.unit_qty,   
         location.loc_name  
    FROM location,   
         sheetmst  
   WHERE ( sheetmst.loc_no = location.loc_no ) and  
         ( ( sheetmst.open_close = ~"O~" ) )    
" )
