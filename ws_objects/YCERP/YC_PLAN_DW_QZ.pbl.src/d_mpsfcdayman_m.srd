table(column=(type=char(1) updatewhereclause=yes name=chk dbname="CHK" values="	1/	0" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=area_no dbname="AREA_NO" )
 column=(type=datetime update=yes updatewhereclause=yes key=yes name=sfc_date dbname="SFC_DATE" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=wc_no dbname="WC_NO" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=user_id dbname="USER_ID" )
 column=(type=char(1) update=yes updatewhereclause=yes key=yes name=work1 dbname="WORK1" values="	1/	0" )
 column=(type=char(1) update=yes updatewhereclause=yes key=yes name=work2 dbname="WORK2" values="	1/	0" )
 column=(type=char(1) update=yes updatewhereclause=yes key=yes name=work3 dbname="WORK3" values="	1/	0" )
 column=(type=real update=yes updatewhereclause=yes key=yes name=time1 dbname="TIME1" initial="0" )
 column=(type=real update=yes updatewhereclause=yes key=yes name=time2 dbname="TIME2" initial="0" )
 column=(type=real update=yes updatewhereclause=yes key=yes name=time3 dbname="TIME3" initial="0" )
 column=(type=char(50) update=yes updatewhereclause=yes key=yes name=bigo dbname="BIGO" )
 retrieve="  SELECT CHK  = '0'                                             
       , AREA_NO  = A.AREA_NO                                      
       , SFC_DATE = A.SFC_DATE                                     
       , WC_NO    = A.WC_NO                                        
       , USER_ID  = A.USER_ID                                      
       , WORK1    = A.WORK1                                        
       , WORK2    = A.WORK2                                        
       , WORK3    = A.WORK3                                        
       , TIME1    = A.TIME1                                        
       , TIME2    = A.TIME2                                        
       , TIME3    = A.TIME3                                        
       , BIGO     = A.BIGO                                         
    FROM SFCDAYMAN A                                             
   WHERE A.AREA_NO    LIKE :AS_AREANO                     
     AND CONVERT(CHAR(10), A.SFC_DATE,111)  = :AS_SFCDATE
     AND A.WC_NO      LIKE :AS_WCNO                       
" update="SFCDAYMAN" updatewhere=0 updatekeyinplace=no arguments=(("as_areano", string),("as_sfcdate", string),("as_wcno", string)) )
