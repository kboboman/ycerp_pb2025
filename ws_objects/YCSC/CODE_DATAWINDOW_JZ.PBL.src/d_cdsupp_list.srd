 retrieve="  SELECT supp.supp_no,   
         supp.register_no,   
         supp.supp_name,   
         supp.captain_name,   
         supp.addr,   
         supp.contact,   
         supp.position,   
         supp.tel_no,   
         supp.rem,   
         supp.buyer,   
         supp.industry_type,   
         supp.industry_code,   
         supp.credit_limit,   
         supp.terms,   
         supp.fob,   
         supp.last_tran_date,   
         supp.currency_type,   
         supp.fax_no,   
         supp.subcon,   
         supp.type,   
         supp.round,   
         supp.yspsub_flag,   
         supp.set_sdate  ,
         use_yn  = supp.use_yn
    FROM supp  
" update="supp" updatewhere=1 updatekeyinplace=no )
