event clicked;//==GF_USEPROGRAM(프로그램 사용현황)==============================================================
GF_USEPROGRAM( gs_userid, Parent.ClassName(), "P", string(gf_today(),'yyyy/mm/dd'), Parent.Title )
//================================================================================================
datawindow dw_dest

choose case is_dw
	case "dw_3"
		dw_dest = dw3
	case "dw_4"
		dw_dest = dw4
	case "dw_5"
		dw_dest = dw5
	case "dw_6"
		dw_dest = dw6
	case "dw_7"
		dw_dest = dw7
end choose

string  ls_Docname, ls_Named, ls_ExpandName
integer ls_Value,   li_Pos,   li_value

if dw_dest.rowcount() > 0 then
	ls_value = GetFileSaveName("Select File", ls_Docname, ls_Named, "XLS", "엑셀 (*.XLS), *.XLS,CSV(쉽표로 분리), *.CSV,")
	li_Pos   = PosA(ls_Named, ".")
	ls_ExpandName = MidA(ls_Named, li_Pos + 1, LenA(ls_Named)- li_Pos)
	if ls_Value = 1 then
		if ls_ExpandName = "xls" OR ls_ExpandName = "XLS" then
			dw_dest.SaveAsascii(ls_DocName)
		elseif ls_ExpandName = "csv" OR ls_ExpandName = "CSV" then
			dw_dest.SaveAs(ls_DocName, CSV!, TRUE)
		end if
	end if
end if	

end event

type tab_1 from tab within w_mpplansos_m
integer x = 32
integer y = 444
integer width = 4718
integer height = 2032
integer taborder = 70
boolean bringtotop = true
integer textsize = -10
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
long backcolor = 79741120
boolean raggedright = true
boolean focusonbuttondown = true
integer selectedtab = 2
tabpage_1 tabpage_1
tabpage_2 tabpage_2
tabpage_3 tabpage_3
end type

on tab_1.create
this.tabpage_1=create tabpage_1
this.tabpage_2=create tabpage_2
this.tabpage_3=create tabpage_3
this.Control[]={this.tabpage_1,&
this.tabpage_2,&
this.tabpage_3}
end on

on tab_1.destroy
destroy(this.tabpage_1)
destroy(this.tabpage_2)
destroy(this.tabpage_3)
end on

event selectionchanged;//
choose case newindex
	case 1		// 미생산계획
		cb_sale.enabled   = true	// 수주현황
//		tab_1.tabpage_3.cb_group.enabled  = true	// 물품별 소계
		pb_insert.enabled = false
		pb_delete.enabled = false
		pb_cancel.enabled = false
		
		em_1.enabled = false
		em_2.enabled = false
		
	case 2		// 소재신청
		//dw4.retrieve()		// 신청리스트
//		if dw5.rowcount() < 1 then dw5.insertrow(0)

		is_dwidx = "dw5"				// SHEET 기본값
		cb_sale.enabled   = true	// 수주현황
//		tab_1.tabpage_3.cb_group.enabled  = false	// 물품별 소계
		pb_insert.enabled = true
		pb_delete.enabled = true
		pb_cancel.enabled = true

		em_1.enabled = true
		em_2.enabled = true
		
	case 3		// 제품별 공정단계
		cb_sale.enabled  = false	// 수주현황
//		tab_1.tabpage_3.cb_group.enabled = false	// 물품별 소계
		em_1.enabled = true
		em_2.enabled = true
end choose
end event

