 column=(type=long update=yes updatewhereclause=yes name=oi_no dbname="areom.oi_no" )
 retrieve="  SELECT areom.cust_no,   
         areom.cust_name,   
         areom.aroi_date,   
         areom.doar_no,   
         areom.do_flag,   
         areom.item_name,   
         areom.qa,   
         areom.uom,   
         areom.do_qty,   
         areom.price,   
         areom.amount,   
         areom.vat,   
         areom.tot_amount,   
         areom.vc_amount,   
         areom.seq_no,   
         areom.bal_amount,   
         areom.oi_no  
    FROM areom   
" update="areom" updatewhere=1 updatekeyinplace=no  sort="cust_no A aroi_date A doar_no A item_name A " )
