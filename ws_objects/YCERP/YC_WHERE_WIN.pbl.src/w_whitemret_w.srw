event clicked;//
long   ll_day,  ll_row
string ls_item, ls_qa, ls_loc

ll_row = dw8.getrow()
if ll_row < 1 then return

ll_day = DaysAfter(date(em_4.text), date(em_5.text)) 
if ll_day < 0 then
	messagebox("확인", "기간을 확인하십시요")
	return
elseif ll_day > 365 then
	messagebox("확인", "기간범위를 365일 이하로 해 주십시요")
	return
end if

ls_item = dw8.object.item_no[ll_row]
ls_qa   = dw8.object.qa[ll_row]
dw9.retrieve( date(em_4.text), date(em_5.text), em_4.text, ls_item, ls_qa, is_loc )

end event

