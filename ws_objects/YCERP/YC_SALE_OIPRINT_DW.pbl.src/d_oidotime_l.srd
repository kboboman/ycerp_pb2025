$PBExportHeader$d_oidotime_l.srd
$PBExportComments$거래명세서 출고시간
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=do_area_no dbname="area_no" )
 column=(type=datetime updatewhereclause=yes name=do_do_date dbname="do_date" )
 column=(type=datetime updatewhereclause=yes name=log_date dbname="log_date" )
 column=(type=char(4) updatewhereclause=yes name=prt_time dbname="prt_time" )
 column=(type=char(16) updatewhereclause=yes name=prt_date dbname="prt_date" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_total dbname="do_total" )
 column=(type=char(14) updatewhereclause=yes name=do_do_no dbname="do_no" )
 column=(type=char(60) updatewhereclause=yes name=do_rem dbname="rem" )
 column=(type=char(10) updatewhereclause=yes name=carname dbname="carname" )
 column=(type=char(40) updatewhereclause=yes name=docar_cargo_name dbname="cargo_name" )
 retrieve="  SELECT area_no    = a.area_no    
       , do_date    = a.do_date    
       , log_date   = a.log_date
       , prt_time   = a.prt_time
       , prt_date   = a.prt_date   
       , do_total   = a.do_total   
       , do_no      = a.do_no      
       , rem        = a.rem        
       , carname    = a.carname    
       , cargo_name = a.cargo_name 
    FROM (
         SELECT area_no    = (SELECT area_name FROM area WHERE area_no = do.area_no)
              , do_date    = do.do_date
              , log_date   = do.log_date
              , prt_time   = (case when do.prt_date is null 
                                   then left(right(convert(char(16),do.log_date, 120),5),2)
                                   else left(right(convert(char(16),do.prt_date, 120),5),2)
                              end)
              , prt_date   = convert(char(16),do.prt_date, 120)
              , do_total   = do.do_total
              , do_no      = do.do_no
              , inout      = docar.inout
              , rem        = do.rem
              , carname    = docar.name
              , cargo_name = docar.cargo_name 
           
           FROM do
                LEFT OUTER JOIN docar ON do.driver = docar.driver 
          WHERE ((:as_areano  = '%') OR
                 (:as_areano <> '%' AND do.area_no = :as_areano)
                )
            AND ((:as_custno  = '%') OR
                 (:as_custno <> '%' AND do.cust_no = :as_custno)
                )
            AND ( do_date between :ad_sdate AND :ad_edate )
            AND ( do.do_total > 0 )
         ) A
   WHERE ((:as_time  = '%') OR
          (:as_time <> '%' AND a.prt_time = :as_time)
         )
     AND ((:as_inout  = '%') OR
          (:as_inout <> '%' AND a.inout = 'I')
         )
" arguments=(("as_areano", string),("as_custno", string),("ad_sdate", date),("ad_edate", date),("as_time", string),("as_inout", string))  sort="do_area_no A do_do_date A log_date A prt_time A prt_date A " )
