$PBExportHeader$d_cdexscenedet_m.srd
$PBExportComments$고객예상현장관리(1998/3/19,성삼지)
release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=84 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=long update=yes updatewhereclause=yes key=yes name=ex_seq dbname="exscenedet.ex_seq" )
 column=(type=char(10) update=yes updatewhereclause=yes name=ex_item dbname="exscenedet.ex_item" values="천정	a/벽체	b/" )
 column=(type=char(20) update=yes updatewhereclause=yes name=ex_qa dbname="exscenedet.ex_qa" )
 column=(type=char(15) update=yes updatewhereclause=yes name=ex_qty dbname="exscenedet.ex_qty" )
 column=(type=char(40) update=yes updatewhereclause=yes name=ex_rem dbname="exscenedet.ex_rem" )
 column=(type=char(4) update=yes updatewhereclause=yes key=yes name=cust_no dbname="exscenedet.cust_no" )
 column=(type=datetime update=yes updatewhereclause=yes key=yes name=ex_year dbname="exscenedet.ex_year" )
 column=(type=char(40) update=yes updatewhereclause=yes key=yes name=ex_name dbname="exscenedet.ex_name" )
 retrieve="  SELECT exscenedet.ex_seq,   
         exscenedet.ex_item,   
         exscenedet.ex_qa,   
         exscenedet.ex_qty,   
         exscenedet.ex_rem,   
         exscenedet.cust_no,   
         exscenedet.ex_year,   
         exscenedet.ex_name  
    FROM exscenedet  
   WHERE ( exscenedet.cust_no = :as_code ) AND  
         ( exscenedet.ex_name = :as_name ) AND  
         ( exscenedet.ex_year = :as_year )    
" update="exscenedet" updatewhere=0 updatekeyinplace=no arguments=(("as_code", string),("as_year", datetime),("as_name", string)) )
