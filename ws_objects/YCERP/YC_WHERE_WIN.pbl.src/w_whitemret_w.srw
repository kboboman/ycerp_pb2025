event pb_retrieve::clicked;//
string ls_user, ls_date, ls_sdate, ls_edate, ls_area, ls_wc, ls_flag
long   ll_row
date   ld_date

//==GF_USEPROGRAM(프로그램 사용현황)==============================================================
GF_USEPROGRAM( gs_userid, Parent.ClassName(), "R", string(gf_today(),"yyyy/mm/dd"), Parent.Title )
//================================================================================================

debugbreak()

ls_area = dw_area.object.area[1]
if isnull(ls_area) or ls_area = "" then
	MessageBox("확인","사업장을 선택하십시요.",exclamation!)
	RETURN
end if

choose case tab_1.SelectedTab
	case 1	// 재고현황
		ld_date = date(tab_1.tabpage_1.em_1.text)
		ls_date = string(date(tab_1.tabpage_1.em_1.text), "yyyymmdd")

		dw3.accepttext()
		ls_user = dw3.object.user_id[1]
		
		if isnull(ls_user) or trim(ls_user) = "" then
			MessageBox("확인","담당자를 선택하십시요.",exclamation!)
			RETURN
		end if
		
		dw4.setredraw(false)
		if tab_1.tabpage_1.cbx_7.checked = true then
			dw4.dataobject = "d_whitemret_ss"
			dw4.settransobject(sqlca)
			if dw4.retrieve( ld_date, ls_date, ls_user, is_loc, ls_area) = 0 then
				MessageBox("확인","해당하는 조건의 데이터가 존재하지 않습니다.",exclamation!)
			else
				MessageBox("확인","조회작업 완료.",exclamation!)
			end if
		else
			dw4.dataobject = "d_whitemret_s1"	// 테스트
			dw4.settransobject(sqlca)
			
			ls_date = tab_1.tabpage_1.em_1.text
			if dw4.retrieve( ls_date, ls_user, is_loc, ls_area) = 0 then
				MessageBox("확인","해당하는 조건의 데이터가 존재하지 않습니다.",exclamation!)
			else
				MessageBox("확인","조회작업 완료.",exclamation!)
			end if
		end if
		
		dw4.sharedata(dw_2)
		wf_fil()		
		dw4.setredraw(true)

	case 2	// 생산계획,지시
		cb_5.triggerevent( clicked! )	// 해지
		
		ld_date = date(tab_1.tabpage_2.em_2.text)
		
//		if tab_1.tabpage_2.rb_1.checked = true then
//			dw17.visible = true
//			dw18.visible = false
//			
//			tab_1.tabpage_2.cbx_6.visible = true 	// 작업지시
//			dw5.reset()
//			is_flag = 'Y%'
//		else
//			tab_1.tabpage_2.cbx_6.visible = false 	// 작업지시
//			dw5.reset()			
//			is_flag = 'N%'			
//		end if
		
		
		if tab_1.tabpage_2.rb_6.checked = true then		// 작업지시
		
			dw18.retrieve( ld_date, is_wc, ls_area)
			MessageBox("확인","조회작업 완료.",exclamation!)
			
		else
			
			dw17.retrieve( ld_date, is_wc, is_flag, ls_area)
			MessageBox("확인","조회작업 완료.",exclamation!)
			
		end if

		debugbreak()
		ls_wc   = is_wc
		ls_flag = is_flag

		// 출력화면
		if dw5.retrieve( ld_date, is_wc, is_flag, ls_area) = 0 then
			MessageBox("확인","해당하는 조건의 데이터가 존재하지 않습니다.",exclamation!)
		end if
		
	case 3	// 재고이력검색
		if dw8.rowcount() = 0 then
			MessageBox("확인","'재고현황' 탭에서 먼저 조회하시기 바랍니다.",exclamation!)
		else
			MessageBox("확인","조회작업 완료.",exclamation!)
		end if
		
	case 4	// 수불부
		if	MessageBox("확인","수불부 조회작업중 잠시만 기다려 주십시요.", question!, yesno!, 1) = 2 then
			RETURN
		end if
		
		ls_sdate = tab_1.tabpage_4.em_3.text
		ls_edate = tab_1.tabpage_4.em_6.text

		string ls_top15 = "N"	
		
		if tab_1.tabpage_4.cbx_top15.checked = true then ls_top15 = "Y"

		if tab_1.tabpage_4.rb_5.checked = true then			// 리스트
			tab_1.tabpage_4.em_3.text = LeftA(tab_1.tabpage_4.em_3.text,8) + "01"
			ls_sdate = tab_1.tabpage_4.em_3.text
			ll_row   = dw15.retrieve( ls_sdate, ls_edate, is_loc, ls_top15)
		elseif tab_1.tabpage_4.rb_3.checked = true then		// 집계
			ll_row   = dw7.retrieve( ls_sdate, ls_edate, is_loc, ls_top15 )
		end if
		
		MessageBox("확인","조회작업 완료.",exclamation!)
		
		if ll_row = 0 then
			MessageBox("확인","해당하는 조건의 데이터가 존재하지 않습니다.",exclamation!)
		else
			MessageBox("확인","조회작업 완료.",exclamation!)
		end if
		
	case 5	// 장기재고
		dw11.retrieve( is_loc )
		
	case 6	// 발주현황
		ll_row = dw13.retrieve( LeftA(ls_area,1), "%", date(tab_1.tabpage_6.em_8.text), date(tab_1.tabpage_6.em_9.text) )
		if ll_row = 0 then
			MessageBox("확인","해당하는 조건의 데이터가 존재하지 않습니다.",exclamation!)
		else
			dw13.object.datawindow.horizontalscrollsplit= dw13.object.oqty.x
			dw13.sharedata(dw_14)
			MessageBox("확인","조회작업 완료.",exclamation!)
		end if
end choose

end event

