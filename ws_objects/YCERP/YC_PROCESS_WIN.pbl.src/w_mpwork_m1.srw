long backcolor = 67108864
string text = "해제"
end type

event clicked;// 해제
long   ll_row
real   lr_time
string ls_work

if RightA(sle_time.text,1) = "0" or RightA(sle_time.text,1) = "5" then
	lr_time = real(sle_time.text)
	if lr_time > 0 and  lr_time < 5 then
		if tab_1.tabpage_5.cbx_7.checked = true then
			ls_work = "0"
			lr_time = 0
		
			for ll_row = 1 to dw9.rowcount()
				if dw9.object.chk[ll_row] = "1" then
					choose case tab_1.tabpage_5.ddlb_3.text
						case "전체"
							dw9.object.work1[ll_row] = ls_work
							dw9.object.work2[ll_row] = ls_work
							dw9.object.work3[ll_row] = ls_work
		
							dw9.object.time1[ll_row] = lr_time
							dw9.object.time2[ll_row] = lr_time
							dw9.object.time3[ll_row] = lr_time
							
						case "오전"
							dw9.object.work1[ll_row] = ls_work
		
							dw9.object.time1[ll_row] = lr_time
				
						case "오후"
							dw9.object.work2[ll_row] = ls_work
		
							dw9.object.time2[ll_row] = lr_time
				
						case "야간"
							dw9.object.work3[ll_row] = ls_work
							dw9.object.time3[ll_row] = lr_time
					end choose
				end if
			next
		end if
	else
		sle_time.setfocus()
		MessageBox("확인","작업시간은 30분 단위로만 계산합니다.(0.5는 30분)")
	end if
else
	sle_time.setfocus()
	MessageBox("확인","작업시간은 30분 단위로만 계산합니다.(0.5는 30분)")
end if
tab_1.tabpage_5.cbx_7.checked = false

end event

