$PBExportHeader$d_scene_comparison.srd
$PBExportComments$송장마스터와디테일합계값점검장표(21.12.11 조원석)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=84 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes key=yes name=do_no dbname="do.do_no" )
 column=(type=decimal(4) updatewhereclause=yes name=do_cash dbname="do.do_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=do_rate dbname="do.do_rate" )
 column=(type=decimal(9) updatewhereclause=yes name=c_calc_amt dbname="c_calc_amt" )
 column=(type=decimal(8) updatewhereclause=yes name=c_tax_amt dbname="c_tax_amt" )
 column=(type=decimal(8) updatewhereclause=yes name=c_do_total dbname="c_do_total" )
 column=(type=decimal(4) updatewhereclause=yes name=do_total dbname="do.do_total" )
 column=(type=long updatewhereclause=yes name=limit_flag dbname="limit_flag" )
 retrieve="select  do.do_no, 
            do.do_cash,            
            do.do_rate, 
            round(c.calc_amt,0,1)+(case when do.ship_flag = 'D' AND do.shipamt_case = 'R' THEN round(do.ship_amount,0,1) else 0 end ) c_calc_amt,
            round( (round(c.calc_amt,0,1)+(case when do.ship_flag = 'D' AND do.shipamt_case = 'R' THEN round(do.ship_amount,0,1) else 0 end ))*0.1,0,1) c_tax_amt,
            round(c.calc_amt,0,1)+(case when do.ship_flag = 'D' AND do.shipamt_case = 'R' THEN round(do.ship_amount,0,1) else 0 end ) +
            round( (round(c.calc_amt,0,1)+(case when do.ship_flag = 'D' AND do.shipamt_case = 'R' THEN round(do.ship_amount,0,1) else 0 end ))*0.1,0,1) c_do_total,            
            do.do_total,
		 (case when convert(date, convert(char(6),dateadd(month, 1, do_date),112)+'12') > convert(date, getdate() ) then 1 else 0 end ) limit_flag
 from do inner join (
                                              select a.do_no, 
											 calc_amt    = sum(case when a.round = 'Y' 
																	  then round(a.price * a.calc_qty, 0)                                                                                                  
																	 else  round( a.price * a.calc_qty, 0, 1 )
																	 end ),
																	tax_amt    =  sum( case when a.tax_sign = 'Y' then (case when a.round = 'Y' 
																	  then round( round(a.price * a.calc_qty, 0)/10, 0, 1 )
																	 else  round( round( a.price * a.calc_qty, 0, 1 )/10, 0, 1 )
																	 end) 
																	else 0 end )
																	 from 
																	 (
																			 SELECT do.ship_flag, 
																								 do.shipamt_case, 
																								 dodet.do_no, 
																								 dodet.oi_no, 
																								 dodet.price price,
																								 dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty) calc_qty, 
																								 customer.round, 
																								 isnull(sale.tax_sign, 'Y') tax_sign
																				FROM do   with(nolock) inner join dodet with(nolock) on do.do_no = dodet.do_no							 	                                  
																														inner join customer on do.cust_no = customer.cust_no
																														left outer join sale on dodet.sale_no = sale.order_no
																				 WHERE ( convert(char(8),do.do_date,112)   BETWEEN :arg_date1 AND :arg_date2 )
																						  and do.cust_no  = :arg_cust_no
																	 ) a  
																	 group by a.do_no

                                  ) c on do.do_no = c.do_no     
where abs( (round(c.calc_amt,0,1)+(case when do.ship_flag = 'D' AND do.shipamt_case = 'R' THEN round(do.ship_amount,0,1) else 0 end ) + round( (round(c.calc_amt,0,1)+(case when do.ship_flag = 'D' AND do.shipamt_case = 'R' THEN round(do.ship_amount,0,1) else 0 end ))*0.1,0,1) ) - do.do_total ) > :arg_gab
order by do.do_no" update="do" updatewhere=0 updatekeyinplace=no arguments=(("arg_cust_no", string),("arg_date1", string),("arg_date2", string),("arg_gab", number)) )
