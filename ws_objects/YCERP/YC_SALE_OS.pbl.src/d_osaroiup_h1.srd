 column=(type=char(12) updatewhereclause=yes name=aroiinv_no dbname="aroiinv.aroiinv_no" )
 retrieve="PBSELECT( VERSION(400) DISTINCT ()TABLE(NAME=~"aroi~" )  TABLE(NAME=~"aroiinv~" )  TABLE(NAME=~"dodet~" )  TABLE(NAME=~"do~" ) COLUMN(NAME=~"do.do_no~") COLUMN(NAME=~"do.invoice_print~") COLUMN(NAME=~"aroiinv.aroiinv_no~")    JOIN (LEFT=~"dodet.do_no~"    OP =~"=~"RIGHT=~"do.do_no~" )    JOIN (LEFT=~"aroiinv.aroiinv_no~"    OP =~"=~"RIGHT=~"aroi.aroiinv_no~" )    JOIN (LEFT=~"aroi.do_no~"    OP =~"=~"RIGHT=~"dodet.do_no~" )    JOIN (LEFT=~"aroi.oi_no~"    OP =~"=~"RIGHT=~"dodet.oi_no~" )WHERE(    EXP1 =~"aroiinv.cust_no~"   OP =~"=~"    EXP2 =~":as_cust_no~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"aroiinv.open_close~"   OP =~"in~"    EXP2 =~"('O', 'T')~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"aroiinv.delete_flag~"   OP =~"=~"    EXP2 =~"'N'~" ) ) ARG(NAME = ~"as_cust_no~" TYPE = string) " update="do" updatewhere=1 updatekeyinplace=yes arguments=(("as_cust_no", string)) )
