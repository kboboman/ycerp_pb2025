table(column=(type=char(17) updatewhereclause=yes key=yes name=order_no dbname="sudodet1.order_no" )
 column=(type=char(10) updatewhereclause=yes name=wc_no dbname="sudodet1.wc_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="sudodet1.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="sudodet1.qa" )
 column=(type=datetime updatewhereclause=yes name=due_date dbname="sudodet1.due_date" )
 column=(type=decimal(4) updatewhereclause=yes name=plan_qty dbname="sudodet1.plan_qty" initial="0" )
 column=(type=decimal(4) updatewhereclause=yes name=rcpt_qty dbname="sudodet1.rcpt_qty" initial="0" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(1) update=yes updatewhereclause=yes name=sudo_type dbname="sudodet1.sudo_type" initial="A" )
 column=(type=char(2) updatewhereclause=yes name=groupitem_uom dbname="GroupItem.uom" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="cust_name" )
 column=(type=char(14) updatewhereclause=yes name=sudodet1_sale_no dbname="sudodet1.sale_no" )
 column=(type=long updatewhereclause=yes name=sudodet1_seq_no dbname="sudodet1.seq_no" )
 column=(type=long updatewhereclause=yes name=operation dbname="sudodet1.operation" )
 column=(type=char(50) updatewhereclause=yes name=rem dbname="sudodet1.rem" )
 column=(type=char(4) updatewhereclause=yes name=sudodet1_color dbname="sudodet1.color" )
 column=(type=char(10) updatewhereclause=yes name=area_no dbname="sudodet1.area_no" )
 retrieve="  SELECT DISTINCT sudodet1.order_no,   
         sudodet1.wc_no,   
         sudodet1.item_no,   
         sudodet1.qa,   
         sudodet1.due_date,   
         sudodet1.plan_qty,   
         sudodet1.rcpt_qty,   
         groupitem.item_name,   
         sudodet1.sudo_type,   
         groupitem.uom,   
         cust_name = dbo.uf_getcustname(sudodet1.sale_no),   
         sudodet1.sale_no,   
         sudodet1.seq_no,   
         sudodet1.operation,   
         sudodet1.rem,   
         sudodet1.color,
         sudodet1.area_no  
   FROM sudodet1 left outer join  sale  on  sudodet1.sale_no = sale.order_no
/*                                                      and sale.open_close <> 'C' 한도초과 */
										    and sale.open_close = 'O'
          ,groupitem
   WHERE ( sudodet1.item_no = groupitem.item_no ) and  
         ( sudodet1.sudo_type in ('A') ) AND 
         ( sudodet1.area_no = :as_area ) 
/*
    FROM sudodet1,   
         groupitem,   
         sale  
   WHERE ( sudodet1.item_no = groupitem.item_no ) and  
         ( sudodet1.sudo_type in ('A') ) AND  
         ( ( sudodet1.sale_no *= sale.order_no) and  
         	  ( sale.open_close <> 'C'  )  )   AND 
         ( sudodet1.area_no = :as_area ) 
*/

	" update="sudodet1" updatewhere=0 updatekeyinplace=yes arguments=(("as_area", string))  sort="item_no A qa A " )
