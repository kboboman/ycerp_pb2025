table(column=(type=char(14) update=yes updatewhereclause=yes key=yes name=order_no dbname="sale_jaego.order_no" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="sale_jaego.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=qa dbname="sale_jaego.qa" )
 column=(type=datetime update=yes updatewhereclause=yes name=order_date dbname="sale_jaego.order_date" )
 column=(type=decimal(2) update=yes updatewhereclause=yes key=yes name=order_qty dbname="sale_jaego.order_qty" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=qoh dbname="sale_jaego.qoh" )
 column=(type=char(10) update=yes updatewhereclause=yes name=loc_no dbname="sale_jaego.loc_no" )
 column=(type=datetime update=yes updatewhereclause=yes name=en_date dbname="sale_jaego.en_date" )
 column=(type=char(255) updatewhereclause=yes name=bigo dbname="sale_jaego.bigo" )
 retrieve="  SELECT order_no
       , item_no
       , qa
       , order_date
       , order_qty
       , qoh
       , loc_no
       , en_date
       , bigo
    FROM sale_jaego
   WHERE (loc_no     = :as_locno)  /* 저장소   */
     AND (item_no    = '')         /* 수주일자 */
  
  UNION ALL
  
  SELECT order_no    = sale.order_no
       , item_no     = saledet.item_no        
       , qa          = saledet.qa
       , order_date  = sale.order_date
       , order_qty   = saledet.order_qty      
       , qoh         = isnull(itemloc.qoh, 0)
       , loc_no      = itemloc.loc_no
       , en_date     = sale_jaego.en_date
       , bigo        = sale_jaego.bigo
    FROM saledet       (nolock)
         LEFT OUTER JOIN sale        (nolock) ON saledet.order_no= sale.order_no 
         LEFT OUTER JOIN itemloc     (nolock) ON saledet.item_no = itemloc.item_no AND saledet.qa = itemloc.qa       

         LEFT OUTER JOIN sale_jaego  (nolock) ON sale.order_no   = sale_jaego.order_no 
                                             AND saledet.item_no = sale_jaego.item_no AND saledet.order_qty = sale_jaego.order_qty
/*   WHERE sale.open_close        <> 'C'      한도초과*/
   WHERE sale.open_close        = 'O'         	         
     AND (itemloc.loc_no         = :as_locno      )         /* 저장소   */
     AND (sale.order_date  BETWEEN :as_sdate AND :as_edate) /* 수주일자 */
     AND ((:as_custno   = '%')  OR
          (:as_custno  <> '%'  AND sale.cust_no      = :as_custno   )         /* 거래처   */
         )
     AND ((:as_scene    = '%')  OR
          (:as_scene   <> '%'  AND sale.scene_code   = :as_scene    )         /* 현장     */
         )
     AND ((:as_confirm  = '%')  OR
          (:as_confirm <> '%'  AND sale.confirm_flag = :as_confirm  )         /* 수주확정 */
         )
     AND ((:as_outtype  = '%')  OR
          (:as_outtype  = '1'  AND saledet.order_qty - saledet.rlse_qty <= 0) OR   /* 출고   */
          (:as_outtype  = '2'  AND saledet.order_qty - saledet.rlse_qty  > 0)      /* 미출고 */
         )
" update="sale_jaego" updatewhere=1 updatekeyinplace=no arguments=(("as_locno", string),("as_sdate", string),("as_edate", string),("as_custno", string),("as_scene", string),("as_confirm", string),("as_outtype", string))  sort="item_no A qa A order_no A order_qty A " )
