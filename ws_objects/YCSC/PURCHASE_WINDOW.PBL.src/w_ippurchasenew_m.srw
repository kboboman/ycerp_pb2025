boolean visible = false
integer taborder = 190
end type

type pb_delete from w_inheritance`pb_delete within w_ippurchasenew_m
integer x = 3803
integer taborder = 200
end type

event pb_delete::clicked;long i,ll_rowcount
string ls_order, ls_subcon

dw_1.accepttext()
if dw_1.rowcount() < 1 then return
if trim(dw_1.object.po_print[1]) = 'Y' then
	MessageBox("경고", " 확정이 되어있슴으로 삭제가 불가능합니다.", Exclamation!)
	return
end if
if messagebox('확인','발주내역 전체를 삭제하시겠습니까?', Exclamation!, OKCancel!, 2) = 2 then
	return
end if

if dw3.rowcount() < 1 then return
dw3.RowsMove(1, dw3.rowcount(), Primary!,  dw3, 1, Delete!)

dw_9.dataobject = 'd_prslitcon_h'
dw_9.settransobject(sqlca)

if dw_1.rowcount() < 1 then return
ls_order = trim(dw_1.object.order_no[1])
ls_subcon = trim(dw_1.object.subcon[1])

ll_rowcount = dw3.deletedcount()
		//외주구매'Y'/자재가공'J'/외주가공'P'/외주스리팅가공시'C'의 처리.
for i = 1 to ll_rowcount
	if wf_deleteproc(ls_subcon, i) = false then
		rollback;
		return 
	end if
next
dw_1.RowsMove(1, dw_1.rowcount(), Primary!,  dw_1, 1, Delete!)
wf_update2( dw_1, dw3,"Y")
pb_retrieve.triggerevent(clicked!)
end event

