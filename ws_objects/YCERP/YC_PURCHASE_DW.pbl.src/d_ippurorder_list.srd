$PBExportHeader$d_ippurorder_list.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=92 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=pur_supp_no dbname="pur.supp_no" )
 column=(type=char(30) updatewhereclause=yes name=supp_supp_name dbname="supp.supp_name" )
 column=(type=char(10) updatewhereclause=yes name=purdet_order_no dbname="purdet.order_no" )
 column=(type=char(14) updatewhereclause=yes name=purdet_sale_no dbname="purdet.sale_no" )
 retrieve="  SELECT DISTINCT pur.supp_no
       , supp.supp_name
       , purdet.order_no   
       , purdet.sale_no   
    FROM purdet   
         LEFT OUTER JOIN pur       ON purdet.order_no   = pur.order_no
         LEFT OUTER JOIN groupitem ON purdet.item_no    = groupitem.item_no
         LEFT OUTER JOIN supp      ON pur.supp_no       = supp.supp_no
   WHERE ( purdet.sale_no      = :as_saleno )
" arguments=(("as_saleno", string))  sort="purdet_order_no A " )
