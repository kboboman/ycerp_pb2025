table(column=(type=char(30) updatewhereclause=yes name=supp_supp_name dbname="supp_name" )
 column=(type=char(10) updatewhereclause=yes name=purdet_order_no dbname="order_no" initial=" " )
 column=(type=decimal(0) updatewhereclause=yes name=purdet_seq_no dbname="seq_no" initial=" " )
 column=(type=char(10) updatewhereclause=yes name=purdet_item_no dbname="item_no" )
 column=(type=char(20) updatewhereclause=yes name=purdet_qa dbname="qa" )
 column=(type=datetime updatewhereclause=yes name=purdet_due_date dbname="due_date" initial=" " )
 column=(type=decimal(4) updatewhereclause=yes name=purdet_order_qty dbname="order_qty" initial=" " )
 column=(type=datetime updatewhereclause=yes name=purdet_rlse_date dbname="rlse_date" initial=" " )
 column=(type=decimal(4) updatewhereclause=yes name=purdet_price dbname="price" initial=" " )
 column=(type=char(2) updatewhereclause=yes name=purdet_uom dbname="uom" initial=" " )
 column=(type=decimal(4) updatewhereclause=yes name=purdet_rlse_qty dbname="rlse_qty" initial=" " )
 column=(type=char(17) updatewhereclause=yes name=purdet_product_no dbname="product_no" )
 column=(type=char(20) updatewhereclause=yes name=purdet_rcpt_loc dbname="rcpt_loc" )
 column=(type=char(1) updatewhereclause=yes name=purdet_pur_type dbname="pur_type" initial=" " )
 column=(type=char(30) updatewhereclause=yes name=purdet_rem dbname="rem" initial=" " )
 column=(type=char(20) updatewhereclause=yes name=purdet_coil_no dbname="coil_no" initial=" " )
 column=(type=long updatewhereclause=yes name=purdet_serial_no dbname="serial_no" initial=" " )
 column=(type=char(1) updatewhereclause=yes name=purdet_work_type dbname="work_type" initial=" " )
 column=(type=long updatewhereclause=yes name=purdet_cnt dbname="cnt" initial=" " )
 column=(type=char(1) updatewhereclause=yes name=purdet_result_type dbname="result_type" initial=" " )
 column=(type=decimal(4) updatewhereclause=yes name=purdet_com_qty dbname="com_qty" initial="null" )
 column=(type=char(14) updatewhereclause=yes name=purdet_sale_no dbname="sale_no" )
 column=(type=long updatewhereclause=yes name=purdet_sale_seq dbname="sale_seq" )
 column=(type=char(50) updatewhereclause=yes name=purdet_cust_name dbname="cust_name" )
 column=(type=char(50) updatewhereclause=yes name=purdet_sale_rem dbname="sale_rem" )
 column=(type=char(4) updatewhereclause=yes name=purdet_color dbname="color" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=purdet_draw_no dbname="draw_no" )
 column=(type=char(54) updatewhereclause=yes name=mak dbname="mak" )
 column=(type=char(10) updatewhereclause=yes name=buyer dbname="buyer" )
 column=(type=char(255) updatewhereclause=yes name=cham dbname="cham" )
 column=(type=char(15) updatewhereclause=yes name=tel_no dbname="tel_no" )
 column=(type=char(15) updatewhereclause=yes name=fax_no dbname="fax_no" )
 retrieve="  SELECT supp.supp_name,   
         purdet.order_no,   
         purdet.seq_no,   
         purdet.item_no,   
         purdet.qa,   
         purdet.due_date,   
         purdet.order_qty,   
         purdet.rlse_date,   
         purdet.price,   
         purdet.uom,   
         purdet.rlse_qty,   
         purdet.product_no,   
         purdet.rcpt_loc,   
         purdet.pur_type,   
         purdet.rem,   
         purdet.coil_no,   
         purdet.serial_no,   
         purdet.work_type,   
         purdet.cnt,   
         purdet.result_type,   
         purdet.com_qty,   
         purdet.sale_no,   
         purdet.sale_seq,   
         purdet.cust_name,   
         purdet.sale_rem,   
         purdet.color,   
         groupitem.item_name,   
         purdet.draw_no,   
         mak = (case when substring(pur.order_no, 1,1) = ~'B~' then ~'연락처: TEL: 02)2690 - 1999        FAX: 02)2601 - 1075~' 
                     else ~'연락처: TEL: 02)2690 - 1999        FAX: 02)2601 - 1075~' end),   
         pur.buyer,   
         pur.cham,
			supp.tel_no,
			supp.fax_no  
    FROM pur,   
         purdet,   
         supp,   
         groupitem  
   WHERE ( pur.order_no = purdet.order_no ) and  
         ( pur.supp_no = supp.supp_no ) and  
         ( purdet.item_no = groupitem.item_no ) and  
         ( ( pur.order_no = :arg_order ) )    
" arguments=(("arg_order", string))  sort="purdet_seq_no A " )
