this.m_osteamaroi_r=create m_osteamaroi_r
this.m_osteamaroiweek_r=create m_osteamaroiweek_r
this.Item[UpperBound(this.Item)+1]=this.m_aroiq1
this.Item[UpperBound(this.Item)+1]=this.m_5
this.Item[UpperBound(this.Item)+1]=this.m_6
this.Item[UpperBound(this.Item)+1]=this.m_-14
