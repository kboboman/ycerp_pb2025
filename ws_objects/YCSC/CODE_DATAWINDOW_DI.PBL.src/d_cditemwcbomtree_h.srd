release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=84 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=component dbname="bom.component" )
 column=(type=char(20) updatewhereclause=yes name=component_qa dbname="bom.component_qa" )
 column=(type=char(1) updatewhereclause=yes name=item_source dbname="groupitem.source" )
 retrieve="  SELECT bom.component,   
         bom.component_qa,   
         groupitem.source  
    FROM bom,   
         groupitem  
   WHERE ( bom.component = groupitem.item_no ) and  
         ( ( bom.assembly = :as_itemno ) AND  
         ( bom.assembly_qa = :as_qa ) )    
" arguments=(("as_itemno", string),("as_qa", string)) )
