footer(height=72 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=coilsfcday_sfc_date dbname="sfc_date" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=coil_no dbname="coil_no" )
 column=(type=char(20) updatewhereclause=yes name=coilmst_qa dbname="qa" )
 column=(type=decimal(4) updatewhereclause=yes name=qty dbname="qty" )
 column=(type=long updatewhereclause=yes name=coilmst_cnt dbname="cnt" )
 column=(type=char(30) updatewhereclause=yes name=wc_name dbname="wc_name" )
 column=(type=char(30) updatewhereclause=yes name=supp_name dbname="supp_name" )
 column=(type=datetime updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=datetime updatewhereclause=yes name=edate dbname="edate" )
 retrieve="  SELECT sfc_date = itemmove.move_date,   
         item_name = groupitem.item_name,   
         coil_no = itemmovedet.lot_no,   
         qa = itemmovedet.qa,   
         qty = itemmovedet.move_qty,   
         cnt = itemmovedet.cnt,   
         wc_name = location_a.loc_name,   
         supp_name = location_b.loc_name,   
         sdate = convert(smalldatetime, :ad_start, 111),   
         edate = convert(smalldatetime, :ad_end, 111)
    FROM itemmove,   
         itemmovedet,   
         groupitem,   
         location  location_a,
         location  location_b
   WHERE ( itemmove.move_no = itemmovedet.move_no ) and  
         ( itemmove.class = 'C' ) and  
         ( itemmovedet.item_no = groupitem.item_no ) and  
         ( itemmove.src_loc = location_a.loc_no ) and  
         ( itemmove.tar_loc = location_b.loc_no ) and  
         ( ( itemmove.move_date between :ad_start and :ad_end ))   and    
         ( ( itemmove.tar_loc like :as_supp ))    

" arguments=(("ad_start", date),("ad_end", date),("as_supp", string))  sort="coilsfcday_sfc_date A groupitem_item_name A coilmst_qa A qty A " )
