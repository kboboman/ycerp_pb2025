$PBExportHeader$d_cditemwc_s.srd
$PBExportComments$제품별작업장관리(1998/03/07 - 이인호)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=84 color="536870912" )
table(column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" values="	Y/	N" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=rout_qa dbname="qa" )
 column=(type=char(20) updatewhereclause=yes name=qa1 dbname="qa1" )
 column=(type=long updatewhereclause=yes name=item_pat_no dbname="pat_no" )
 column=(type=long updatewhereclause=yes name=cnt dbname="cnt" )
 retrieve="SELECT chk       = 'N'
     , item_no   = a.item_no
     , item_name = a.item_name  
     , qa        = a.qa
     , qa1       = a.qa1
     , pat_no    = a.pat_no
     , cnt       = (SELECT count(*) FROM rout WHERE item_no = a.item_no AND qa = a.qa)
  FROM (
       SELECT DISTINCT a.item_no
            , a.item_name  
            , b.qa
            , a.qa1
            , a.pat_no
         FROM item a
              LEFT OUTER JOIN rout b ON a.item_no = b.item_no AND a.qa1 = b.qa
        WHERE a.use_flag     = 'Y' 
          AND a.item_no   LIKE :as_item  
          AND a.item_no      < 'PZZZG'
          AND a.qa1         <> 'P'  /* ITEM의 qa1 = 'P'는 SKIP' 2012/09/20 */
       ) A
 ORDER BY 1, 5
" arguments=(("as_item", string)) )
