 crosstabdata="강일웅	고미정	권은상	권춘기	길병학	김상환	김소영	김수정	김재철	박수진	배예준	심지원	이수원	이수원(화)	임은영	조형섭	최명수	최성욱" retrieve="  SELECT user_id    = a.user_id    
       , user_name  = isnull(b.user_name, a.user_id)
       , msg_date   = convert(char(10),a.msg_date,111)
       , errornum   = rtrim(a.errornum   )
       , swhere     = rtrim(a.swhere     )
       , object     = rtrim(a.object     )
       , sevent     = rtrim(a.sevent     )
       , line       = rtrim(a.line       )
       , message    = rtrim(a.message    )
       , version    = rtrim(a.version    )
       , close_date = a.close_date 
       , close_id   = a.close_id   
       , close_name = c.user_name
		 , rec_status = a.rec_status
    FROM system_error A
         LEFT OUTER JOIN login B  ON a.user_id  = b.user_id   
         LEFT OUTER JOIN login C  ON a.close_id = c.user_id   
   WHERE convert(char(10),a.msg_date,111)   BETWEEN :as_sdate AND :as_edate
   ORDER BY msg_date desc" arguments=(("as_sdate", string),("as_edate", string))  sort="msg_date D swhere A sevent A object A line A version D " )
