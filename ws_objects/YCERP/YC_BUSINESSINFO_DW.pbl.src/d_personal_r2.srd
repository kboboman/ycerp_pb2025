 retrieve="select personal_id,
	     yc_user_id,
		connect_level,
           write_date,
           write_user_id
from   bogo_personal_connection_det
where personal_id = :as_personal_id
   and  gubun = :as_gubun" arguments=(("as_personal_id", number),("as_gubun", string)) )
