cb_sale cb_sale
tab_2 tab_2
st_12 st_12
gb_4 gb_4
end type
global w_mpplansource_m w_mpplansource_m

type variables
st_print i_print
string is_wcname, is_area, is_dwidx, is_scenesql, is_filename
datawindowchild idwc_wc, idwc_cust, idwc_scene, idwc_item
datawindow  dw3, dw4, dw5, dw6, dw7

//
int    ii_row, ii_Sheet
OLEObject OleExcel, xlSheet
Boolean SWContinue = False

end variables

forward prototypes
public subroutine wf_area (string as_area)
public subroutine wf_sceneretrieve (string as_cust)
end prototypes

public subroutine wf_area (string as_area);string ls_name

SELECT REPLACE(area_name,'사업장','') INTO :ls_name 
  FROM area
 WHERE area_no = :as_area;

end subroutine

public subroutine wf_sceneretrieve (string as_cust);// 선택한 거래처의 현장만 보여주기
string ls_where, ls_sql

ls_where = " WHERE scene.cust_no = ~~'" + as_cust + "~~'"
ls_sql   = "datawindow.table.select = '" + is_scenesql + ls_where + "'"

dw5.getchild("scene_code", idwc_scene)
idwc_scene.SetTransObject(sqlca)
idwc_scene.Modify(ls_sql)
idwc_scene.Retrieve()

end subroutine

on w_mpplansource_m.create
int iCurrent
call super::create
this.em_1=create em_1
this.em_2=create em_2
this.st_2=create st_2
this.st_1=create st_1
this.st_3=create st_3
this.dw_area=create dw_area
this.pb_excel=create pb_excel
this.tab_1=create tab_1
this.cb_group=create cb_group
this.st_5=create st_5
this.st_time=create st_time
this.cb_sale=create cb_sale
this.tab_2=create tab_2
this.st_12=create st_12
this.gb_4=create gb_4
iCurrent=UpperBound(this.Control)
this.Control[iCurrent+1]=this.em_1
this.Control[iCurrent+2]=this.em_2
this.Control[iCurrent+3]=this.st_2
this.Control[iCurrent+4]=this.st_1
this.Control[iCurrent+5]=this.st_3
this.Control[iCurrent+6]=this.dw_area
this.Control[iCurrent+7]=this.pb_excel
this.Control[iCurrent+8]=this.tab_1
this.Control[iCurrent+9]=this.cb_group
this.Control[iCurrent+10]=this.st_5
this.Control[iCurrent+11]=this.st_time
this.Control[iCurrent+12]=this.cb_sale
this.Control[iCurrent+13]=this.tab_2
this.Control[iCurrent+14]=this.st_12
this.Control[iCurrent+15]=this.gb_4
end on

on w_mpplansource_m.destroy
call super::destroy
destroy(this.em_1)
destroy(this.em_2)
destroy(this.st_2)
destroy(this.st_1)
destroy(this.st_3)
destroy(this.dw_area)
destroy(this.pb_excel)
destroy(this.tab_1)
destroy(this.cb_group)
destroy(this.st_5)
destroy(this.st_time)
destroy(this.cb_sale)
destroy(this.tab_2)
destroy(this.st_12)
destroy(this.gb_4)
end on

event open;call super::open;//==GF_USEPROGRAM(프로그램 사용현황)===========================================================
GF_USEPROGRAM( gs_userid, THIS.ClassName(), "O", string(gf_today(),'yyyy/mm/dd'), THIS.Title )
//=============================================================================================

string ls_clause, ls_where
dw3 = tab_1.tabpage_1.dw_3
dw4 = tab_1.tabpage_2.dw_4
dw5 = tab_1.tabpage_2.dw_5
dw6 = tab_1.tabpage_2.dw_6
dw7 = tab_1.tabpage_3.dw_7

pb_cancel.visible = false
dw_1.visible  = false
tab_2.visible = false
st_12.visible = false

dw_2.insertrow(0)
dw_2.getchild('wc_no', idwc_wc)
idwc_wc.insertrow(1)
idwc_wc.setitem(1,"work_no"," ")
idwc_wc.setitem(1,"work_name","전체")
idwc_wc.accepttext()

choose case LeftA(gs_userid, LenA(gs_userid) - 2)
	case "msb"
		dw_2.object.wc_no[1] = "B01" 	// 절곡
	case "msp"
		dw_2.object.wc_no[1] = "P02"	// 도장02호
	case "msy"
		dw_2.object.wc_no[1] = "Y00"	// YSP
	case "msu"
		dw_2.object.wc_no[1] = "U01"	// 유압금형
	case "msc"
		dw_2.object.wc_no[1] = "S01"	// 스리타
	case "mss"
		dw_2.object.wc_no[1] = "F00"	// 성형
	case "msio"
		dw_2.object.wc_no[1] = ""		// 출고
	case else
		dw_2.object.wc_no[1] = " "		// 전체
end choose

dw_area.SetTransObject(SQLCA)
dw_area.insertrow(0)  
dw_area.object.area[1] = "S0001" //gs_area
//dw_area.accepttext()

dw3.object.pri.width = 0	// 순위
dw3.SetTransObject(SQLCA)
dw4.SetTransObject(SQLCA)
dw5.SetTransObject(SQLCA)
dw6.SetTransObject(SQLCA)
dw7.SetTransObject(SQLCA)

dw5.getchild("scene_code", idwc_scene)
idwc_scene.settransobject(sqlca)
idwc_scene.insertrow(0)  
is_scenesql = idwc_scene.describe("datawindow.table.select")

em_1.text = string(today(),'yyyy/mm/dd')
em_2.text = string(today(),'yyyy/mm/dd')

tab_1.selecttab(1)
pb_retrieve.PostEvent(Clicked!)

end event

event resize;call super::resize;tab_1.width  = this.width  - 128
tab_1.height = this.height - 560

dw3.width  = this.width  - 219
dw3.height = this.height - 792

//dw4.width  = this.width  - 219
//dw4.height = this.height - 792
//

dw6.width  = this.width  - 219
dw6.height = this.height - 1352

dw7.width  = this.width  - 219
dw7.height = this.height - 792

end event

type pb_save from w_inheritance`pb_save within w_mpplansource_m
integer x = 3950
integer y = 56
end type

event pb_save::clicked;call super::clicked;long    ll_row, ll_y, ll_chk
integer li_seq
string  ls_sosno, ls_seq, ls_area, ls_sosdate, ls_maxno, ls_saleno, ls_saleseq, ls_key1, ls_key2

if dw6.rowcount() < 1 then return

// 수주번호, 순번 공난 삭제하기
for ll_row = dw6.rowcount() to 1 step -1
	ls_saleno  = dw6.object.sale_no[ll_row]
	ls_saleseq = string(dw6.object.seq[ll_row])
   if ls_saleno = "" or ls_saleseq = "" then
		dw6.deleterow( ll_row )	// 수주번호, 순번 공난 삭제하기
	end if
next

// 수주번호, 순번 공난 삭제하기
for ll_row = 1 to dw6.rowcount()
	ll_chk  = 0
	ls_saleno  = dw6.object.sale_no[ll_row]
	ls_saleseq = string(dw6.object.seq[ll_row])
	ls_key1    = ls_saleno + ls_saleseq
	for ll_y = 1 to dw6.rowcount()
		if ll_row = ll_y then	// 같은행 중복검사 제외
		else
			ls_key2  = dw6.object.sale_no[ll_y] + string(dw6.object.seq[ll_y])
			if ls_key1 = ls_key2 then	// 수주번호 + 순번 중복 시 오류
				dw6.scrolltorow( ll_y )
				ll_chk = ll_y
				exit
			end if
		end if
	next
	
	if ll_chk = ll_y then exit
next
if ll_chk = ll_y then
	MessageBox("확인", string(ll_chk) + "행 수주번호+순번 중복 체크 오류입니다.")	
	RETURN
end if

if MessageBox("확인","저장 하시겠습니까?", Exclamation!, OKCancel!, 1) = 2 THEN
	RETURN
end if

//==GF_USEPROGRAM(프로그램 사용현황)==============================================================
GF_USEPROGRAM( gs_userid, Parent.ClassName(), "S", string(gf_today(),'yyyy/mm/dd'), Parent.Title )
//================================================================================================

////////////////////////////////////////
// 소재신청 저장
////////////////////////////////////////
// 신청번호 부여(IS20120106-001)
////////////////////////////////////////
ls_sosno = dw5.getitemstring(1, "sos_no")
if isnull(ls_sosno) or ls_sosno = "" then
	ls_area    = "I" + LeftA(dw_area.object.area[1],1)
	ls_sosdate = string(today(), "yyyymmdd")
	ls_maxno   = ls_area + ls_sosdate + "-" + "%"
		
	SELECT MAX(sos_no) INTO :ls_sosno
	  FROM itemsos
	 WHERE sos_no LIKE :ls_maxno;
	if isnull(ls_sosno) or ls_sosno = "" then
		ls_sosno = ls_area + ls_sosdate + "-" + "001"
	else
		li_seq   = integer(MidA(ls_sosno, 12, 3))
		li_seq   = li_seq + 1
		ls_seq   = "00" + string(li_seq)
		ls_sosno = LeftA(ls_sosno, 11) + RightA(ls_seq, 3)
	end if

	dw5.object.user_id[1] = gs_userid
	dw5.object.sos_no[1]  = ls_sosno
end if
			
for ll_row = 1 to dw6.rowcount() 
	dw6.object.sos_no[ll_row] = ls_sosno
	dw6.object.seq_no[ll_row] = ll_row
next		
if wf_update2(dw5, dw6,"Y") = false then
	MessageBox('오류dw6','소재신청 저장중 오류가 발생했습니다.',exclamation!)
	RETURN
end if

dw4.retrieve()		// 신청리스트

end event

