type dw_5 from datawindow within tabpage_3
event keydown pbm_dwnkey
integer y = 92
integer width = 4526
integer height = 1788
integer taborder = 20
boolean bringtotop = true
string dataobject = "d_mpsfcuse_m"
boolean hscrollbar = true
boolean vscrollbar = true
