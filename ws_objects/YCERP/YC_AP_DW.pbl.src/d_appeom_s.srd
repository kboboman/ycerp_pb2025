 retrieve="  SELECT appeom.supp_no,   
         appeom.supp_name,   
         appeom.apoi_date,   
         appeom.inspap_no,   
         appeom.insp_flag,   
         appeom.item_name,   
         appeom.qa,   
         appeom.uom,   
         appeom.insp_qty,   
         appeom.price,   
         appeom.amount,   
         appeom.vat,   
         appeom.tot_amount,   
         appeom.vc_amount,   
         appeom.seq_no,   
         appeom.bal_amount,   
         appeom.oi_no  
    FROM appeom   
" update="appeom" updatewhere=0 updatekeyinplace=no )
