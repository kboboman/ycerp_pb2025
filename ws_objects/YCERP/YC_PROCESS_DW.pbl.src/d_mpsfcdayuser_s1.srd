table(column=(type=char(10) updatewhereclause=yes name=login_user_name dbname="login.user_name" )
 retrieve="  SELECT login.user_name  
    FROM sfcdayuser,   
         login  
   WHERE ( sfcdayuser.user_id    = login.user_id )
     and ( ( sfcdayuser.area_no  = :as_area ) AND  
           ( sfcdayuser.wc_no    = :as_wc   ) AND  
           ( sfcdayuser.sfc_date = :ad_date ) 
         )    
" arguments=(("as_area", string),("as_wc", string),("ad_date", date)) )
