table(column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" values="	Y/	N" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=rout_qa dbname="qa" )
 column=(type=char(20) updatewhereclause=yes name=qa1 dbname="qa1" )
 column=(type=long updatewhereclause=yes name=item_pat_no dbname="pat_no" )
 column=(type=long updatewhereclause=yes name=cnt dbname="cnt" )
 column=(type=long updatewhereclause=yes name=represent_cnt dbname="represent_cnt" )
 column=(type=char(10) updatewhereclause=yes name=work_nm1 dbname="work_nm1" )
 column=(type=char(60) updatewhereclause=yes name=item_nm1 dbname="item_nm1" )
 column=(type=char(10) updatewhereclause=yes name=work_nm2 dbname="work_nm2" )
 column=(type=char(60) updatewhereclause=yes name=item_nm2 dbname="item_nm2" )
 column=(type=char(10) updatewhereclause=yes name=work_nm3 dbname="work_nm3" )
 column=(type=char(60) updatewhereclause=yes name=item_nm3 dbname="item_nm3" )
 column=(type=char(10) updatewhereclause=yes name=work_nm4 dbname="work_nm4" )
 column=(type=char(60) updatewhereclause=yes name=item_nm4 dbname="item_nm4" )
 retrieve="SELECT chk       = 'N'
     , item_no   = a.item_no
     , item_name = a.item_name  
     , qa        = rtrim(a.qa)
     , qa1       = rtrim(a.qa1)
     , pat_no    = a.pat_no
     , cnt       = (SELECT count(*) FROM rout  with(nolock) WHERE item_no = a.item_no AND qa = a.qa)
     , represent_cnt       = ( SELECT count(*) FROM rout  with(nolock) WHERE item_no = a.item_no AND qa = a.qa and rout.represent = 'Y' )
     , work_nm1  = b.work_nm1
     , item_nm1  = b.item_nm1     
     , work_nm2  = b.work_nm2
     , item_nm2  = b.item_nm2     
     , work_nm3  = b.work_nm3
     , item_nm3  = b.item_nm3
     , work_nm4  = b.work_nm4
     , item_nm4  = b.item_nm4
  FROM (
       SELECT item_no   = a.item_no
            , item_name = a.item_name  
            , qa        = b.qa 
            , qa1       = a.qa1 
            , pat_no    = a.pat_no 
         FROM item A with(nolock)
              LEFT OUTER JOIN rout B  with(nolock) ON a.item_no = b.item_no AND a.qa1 = b.qa
        WHERE a.item_no   LIKE :as_itemno 
          AND a.use_flag     = 'Y' 
          AND a.qa1         <> 'P'
        GROUP BY a.item_no, a.item_name, b.qa, a.qa1, a.pat_no
       ) A
       
       LEFT OUTER JOIN (
            SELECT item_no   = a.item_no
                 , qa        = a.qa

                 , work_nm1  = w1.work_name
                 , item_nm1  = a.nm1            
                 , work_nm2  = w2.work_name
                 , item_nm2  = a.nm2            
                 , work_nm3  = w3.work_name
                 , item_nm3  = a.nm3
                 , work_nm4  = w4.work_name
                 , item_nm4  = a.nm4
              FROM (
                   SELECT item_no
                        , qa  = a.qa
                        , nm1 = max(a.nm1), nm2 = max(a.nm2), nm3 = max(a.nm3), nm4 = max(a.nm4)
                        , wc1 = max(a.wc1), wc2 = max(a.wc2), wc3 = max(a.wc3), wc4 = max(a.wc4)
                     FROM (
                          SELECT item_no = a.item_no, qa = a.qa1, nm1 = a.nm1, nm2 = a.nm2, nm3 = a.nm3   
                               , nm4 = a.nm4, wc1 = a.wc1, wc2 = a.wc2, wc3 = a.wc3, wc4 = a.wc4
                            FROM (
									SELECT item_no = a.item_no
										  , qa1     = a.qa1
										  , nm1     = (case when b.operation = 1 then g1.item_name else '' end)
										  , nm2     = (case when b.operation = 2 then g2.item_name else '' end)
										  , nm3     = (case when b.operation = 3 then g3.item_name else '' end)
										  , nm4     = (case when b.operation = 4 then g4.item_name else '' end)
										  , wc1     = (case when b.operation = 1 then b.wc_no      else '' end)
										  , wc2     = (case when b.operation = 2 then b.wc_no      else '' end)
										  , wc3     = (case when b.operation = 3 then b.wc_no      else '' end)
										  , wc4     = (case when b.operation = 4 then b.wc_no      else '' end)
									  FROM item a  with(nolock)
											 LEFT OUTER JOIN rout B  with(nolock)      ON a.item_no  = b.item_no AND a.qa1 = b.qa
											 LEFT OUTER JOIN groupitem G1  with(nolock) ON b.assembly = g1.item_no
											 LEFT OUTER JOIN groupitem G2  with(nolock) ON b.assembly = g2.item_no
											 LEFT OUTER JOIN groupitem G3  with(nolock) ON b.assembly = g3.item_no
											 LEFT OUTER JOIN groupitem G4  with(nolock) ON b.assembly = g4.item_no
									 WHERE a.item_no   LIKE :as_itemno
										AND a.qa1         <> 'P'
										AND a.use_flag     = 'Y' 
                                 ) A
                           GROUP BY a.item_no, a.qa1, a.nm1, a.nm2, a.nm3, a.nm4, a.wc1, a.wc2, a.wc3, a.wc4
                          ) A
                    GROUP BY item_no, qa
                   ) A
                   LEFT OUTER JOIN wc w1 ON w1.work_no = a.wc1
                   LEFT OUTER JOIN wc w2 ON w2.work_no = a.wc2
                   LEFT OUTER JOIN wc w3 ON w3.work_no = a.wc3
                   LEFT OUTER JOIN wc w4 ON w4.work_no = a.wc4
       ) B  ON a.item_no = b.item_no AND a.qa = b.qa
 ORDER BY 1, 5
" arguments=(("as_itemno", string))  sort="if( isnull(rout_qa), 1, 0 ) D " )
