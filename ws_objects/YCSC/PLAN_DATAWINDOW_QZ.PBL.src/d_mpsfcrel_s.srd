$PBExportHeader$d_mpsfcrel_s.srd
$PBExportComments$작업지시서 조회(1998/5/8,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=84 color="536870912" )
summary(height=0 color="536870912" )
footer(height=68 color="8421504" )
detail(height=68 color="536870912" )
table(column=(type=char(16) updatewhereclause=yes name=order_no dbname="mpsorder.order_no" )
 column=(type=char(10) updatewhereclause=yes name=wc_work_name dbname="wc.work_name" )
 column=(type=char(10) updatewhereclause=yes name=wc_no dbname="mpsorder.wc_no" )
 column=(type=char(1) updatewhereclause=yes name=overtime dbname="overtime" )
 retrieve="  SELECT mpsorder.order_no,   
         wc.work_name,   
         mpsorder.wc_no , 
         overtime = (case when mpsorder.overtime = 'Y' then mpsorder.overtime else '' end)
    FROM mpsorder,   
         wc  
   WHERE ( mpsorder.wc_no = wc.work_no ) and  
         ( ( mpsorder.order_date = :as_date ) AND  
           ( mpsorder.area_no = :as_area ) 
         )    
" arguments=(("as_date", date),("as_area", string))  sort="order_no A " )
text(band=header alignment="2" text="작업지시번호" border="6" color="0" x="9" y="12" height="60" width="485" html.valueishtml="0"  name=order_no_t visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="79741120" )
