table(column=(type=char(14) updatewhereclause=yes key=yes name=order_no dbname="saledet.order_no" )
 column=(type=long updatewhereclause=yes key=yes name=seq_no dbname="saledet.seq_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="saledet.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="saledet.qa" )
 column=(type=char(20) updatewhereclause=yes name=qa_cust dbname="saledet.qa_cust" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="saledet.uom" )
 column=(type=decimal(2) updatewhereclause=yes name=order_qty dbname="saledet.order_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=price dbname="saledet.price" )
 column=(type=decimal(2) updatewhereclause=yes name=acc_qty dbname="saledet.acc_qty" )
 column=(type=char(1) updatewhereclause=yes name=saledet_saledet_text dbname="saledet.saledet_text" )
 column=(type=char(1) update=yes updatewhereclause=yes name=action dbname="saledet.action" values="직출고	A/통화대기	B/통화후	C/방문	D/외주	E/화곡	F/" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=sol_qty dbname="saledet.sol_qty" )
 column=(type=char(10) update=yes updatewhereclause=yes name=loc_no dbname="saledet.loc_no" )
 column=(type=decimal(0) updatewhereclause=yes name=issue_qty dbname="issuereq.issue_qty" )
 column=(type=datetime update=yes updatewhereclause=yes name=rlse_date dbname="saledet.rlse_date" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=rlse_qty dbname="saledet.rlse_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=issueqty_org dbname="saledet.issueqty_org" )
 column=(type=char(50) updatewhereclause=yes name=rem dbname="saledet.rem" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_plan_qty dbname="saledet.plan_qty" )
 column=(type=datetime updatewhereclause=yes name=saledet_plan_close dbname="saledet.plan_close" )
 column=(type=char(1) updatewhereclause=yes name=sale_tax_sign dbname="sale.tax_sign" initial=" " )
 column=(type=char(4) updatewhereclause=yes name=color dbname="saledet.color" )
 column=(type=char(20) updatewhereclause=yes name=tel_no dbname="sale.tel_no" )
 column=(type=char(20) updatewhereclause=yes name=telno_cap dbname="sale.telno_cap" )
 column=(type=char(80) updatewhereclause=yes name=shipto_addr dbname="sale.shipto_addr" initial=" " )
 column=(type=char(1) updatewhereclause=yes name=ship_flag dbname="sale.ship_flag" )
 column=(type=char(10) updatewhereclause=yes name=fob dbname="sale.fob" initial=" " )
 column=(type=char(3) updatewhereclause=yes name=sale_curr_code dbname="sale.curr_code" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="GroupItem.item_name" )
 column=(type=char(12) updatewhereclause=yes name=saledet_do_rem dbname="saledet.do_rem" )
 column=(type=char(1) updatewhereclause=yes name=shipamt_case dbname="sale.shipamt_case" values="현금	C/외상	R/" )
 column=(type=char(10) updatewhereclause=yes name=sale_area_no dbname="sale.area_no" )
 column=(type=long updatewhereclause=yes name=cnt dbname="cnt" )
 column=(type=long updatewhereclause=yes name=qcnt dbname="qcnt" )
 column=(type=long updatewhereclause=yes name=unit_qty dbname="unit_qty" )
 column=(type=char(20) updatewhereclause=yes name=coil_no dbname="coil_no" )
 column=(type=char(1) updatewhereclause=yes name=source dbname="source" values="	Y/	N" )
 column=(type=char(4) updatewhereclause=yes name=flag dbname="flag" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=stock_qty dbname="saledet.stock_qty" )
 column=(type=long updatewhereclause=yes name=stock_issue dbname="stock_issue" )
 column=(type=char(1) updatewhereclause=yes name=round dbname="customer.round" )
 column=(type=char(14) updatewhereclause=yes name=fit_no dbname="fitdet.fit_no" )
 column=(type=long updatewhereclause=yes name=fit_seq dbname="fitdet.fit_seq" )
 column=(type=char(1) updatewhereclause=yes name=pre_sale_yn dbname="pre_sale_yn" )
 column=(type=datetime updatewhereclause=yes name=req_date dbname="issuereq.req_date" )
 column=(type=char(10) updatewhereclause=yes name=salesman dbname="issuereq.salesman" )
 column=(type=long updatewhereclause=yes name=req_seq dbname="issuereq.req_seq" )
 column=(type=long updatewhereclause=yes name=seq dbname="issuereq.seq" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="sale.cust_no" )
 retrieve="SELECT DISTINCT 				    saledet.order_no   
										  , saledet.seq_no              
										  , saledet.item_no             
										  , saledet.qa                
										  , saledet.qa_cust            
										  , saledet.uom                 
										  , saledet.order_qty           
										  , saledet.price               
										  , saledet.acc_qty             
										  , saledet.saledet_text        
										  , saledet.action              
										  , saledet.sol_qty             
										  , saledet.loc_no              
										  , c.issue_qty
										  , saledet.rlse_date           
										  , saledet.rlse_qty            
										  , saledet.issue_qty issueqty_org
										  , saledet.rem                 
										  , saledet.plan_qty            
										  , saledet.plan_close          
										  , sale.tax_sign               
										  , saledet.color               
										  , sale.tel_no                 
										  , sale.telno_cap
										  , sale.shipto_addr            
										  , sale.ship_flag              
										  , sale.fob                    
										  , sale.curr_code              
										  , groupitem.item_name         
										  , saledet.do_rem              
										  , sale.shipamt_case           
										  , sale.area_no                
										  , cnt      = 0                
										  , qcnt     = 0                
										  , unit_qty = 0                
										  , coil_no  = space(20)        
										  , source   = 'N'              
										  , flag     = (case when itemalter.tar_qa is not null then '대체'  
																	when intemp.intemp_no is not null then '가입' 
																	else 'N' 
															 end)      
										  , saledet.stock_qty     
											, 0 stock_issue
										  , customer.round  
										  , fitdet.fit_no
										  , fitdet.fit_seq
										  , isnull(sale.pre_sale_yn,'N') pre_sale_yn
										  , C.req_date
										  , C.salesman 
										  , C.req_seq 
										  , C.seq
										  , sale.cust_no
			 FROM issuereq   A WITH (NOLOCK)
			  LEFT OUTER JOIN issuereqdet   B WITH (NOLOCK) ON a.req_date  = b.req_date AND a.salesman = b.salesman AND a.req_seq = b.req_seq
			  LEFT OUTER JOIN issuereqdet_sale c with(nolock) on b.req_date = c.req_date and b.salesman = c.salesman and b.req_seq = c.req_seq and  b.seq = c.seq
			  INNER JOIN saledet   ON c.order_no    = saledet.order_no and c.seq_no = saledet.seq_no
			  INNER JOIN sale     WITH (NOLOCK) ON b.sale_no    = sale.order_no
        		  LEFT OUTER JOIN itemalter with (nolock) ON c.order_no = itemalter.order_no AND c.seq_no = itemalter.seq
        	       LEFT OUTER JOIN intemp    with (nolock) ON c.order_no = intemp.order_no    AND c.seq_no = intemp.seq_no         
			  LEFT OUTER JOIN location L WITH (NOLOCK) ON a.accept_user = l.loc_manager
			  LEFT OUTER JOIN login     f WITH (NOLOCK) ON b.salesman   = f.user_id
		       LEFT OUTER JOIN login     j WITH (NOLOCK) ON a.accept_user   = j.user_id
			  LEFT OUTER JOIN customer  WITH (NOLOCK) ON b.cust_no    = customer.cust_no
			  LEFT OUTER JOIN scene     E WITH (NOLOCK) ON b.scene_code = e.scene_code
			  LEFT OUTER JOIN groupitem  WITH (NOLOCK) ON c.item_no    = groupitem.item_no
                  LEFT OUTER JOIN fitdet    with (nolock) ON saledet.order_no = fitdet.sale_no     AND saledet.seq_no = fitdet.seq_no
			 where a.req_date BETWEEN convert(datetime,  :as_reqdate +' 00:00:00' ) and convert(datetime,  :as_reqdate + ' 23:59:59' )	
/*			 where a.req_date BETWEEN DateAdd(month, -6, convert(datetime,  :as_reqdate +' 00:00:00' ) ) and convert(datetime,  :as_reqdate + ' 23:59:59' )		테스트용 */
                      AND sale.order_date >= DateAdd(month, -6, getdate() )
				 AND ( c.item_no    is not null     )
                      AND ( isnull(saledet.order_qty,0) - isnull(saledet.rlse_qty,0) > 0 )
			      AND  sale.open_close   = 'O'
				 AND ( b.req_flag    = 'A'              ) /* 출고의뢰 */
				 AND ( a.confirm_flag= 'Y'           ) /* 확정     */		
                      AND sale.cust_no like :as_cust_no
                      AND sale.scene_code like :as_scene_code
                      AND sale.order_no like :as_order_no
		           AND l.loc_no = :as_loc_no" update="saledet" updatewhere=0 updatekeyinplace=no arguments=(("as_loc_no", string),("as_reqdate", string),("as_order_no", string),("as_cust_no", string),("as_scene_code", string))  sort="order_no A seq_no A " )
