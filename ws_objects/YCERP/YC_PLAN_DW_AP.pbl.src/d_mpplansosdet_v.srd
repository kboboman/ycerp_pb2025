 column=(type=char(14) update=yes updatewhereclause=yes name=sale_no dbname="sale_no" )
 column=(type=long update=yes updatewhereclause=yes name=seq dbname="seq" )
 column=(type=char(50) updatewhereclause=yes name=salerem dbname="salerem" )
 column=(type=char(20) update=yes updatewhereclause=yes name=secure dbname="secure" )
 column=(type=long update=yes updatewhereclause=yes name=ask dbname="ask" )
 column=(type=long update=yes updatewhereclause=yes name=stock dbname="stock" )
 column=(type=long update=yes updatewhereclause=yes name=fault dbname="fault" )
 column=(type=long update=yes updatewhereclause=yes name=short dbname="short" )
 column=(type=char(60) update=yes updatewhereclause=yes name=rem dbname="rem" )
 column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" initial="N" values="	Y/	N" )
 column=(type=char(14) update=yes updatewhereclause=yes key=yes name=sos_no dbname="sos_no" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=seq_no dbname="seq_no" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(11) updatewhereclause=yes name=scene_code dbname="scene_code" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(4) update=yes updatewhereclause=yes name=color dbname="color" )
 retrieve="  SELECT cust_name  = c.cust_name
       , scene_desc = s.scene_desc
       , metrial    = itemsosdet.metrial
       , assembly   = itemsosdet.assembly
       , w1         = itemsosdet.w1
       , w2         = itemsosdet.w2
       , h1         = itemsosdet.h1
       , h2         = itemsosdet.h2
       , qty        = itemsosdet.qty   
       , width      = itemsosdet.width
       , height     = itemsosdet.height
       , sale_no    = itemsosdet.sale_no   
       , seq        = itemsosdet.seq  
       , salerem    = saledet.rem
       , secure     = itemsosdet.secure
       , ask        = itemsosdet.ask
       , stock      = itemsosdet.stock
       , fault      = itemsosdet.fault
       , short      = itemsosdet.short
       , rem        = itemsosdet.rem
       , chk        = 'N'   

       , sos_no     = itemsosdet.sos_no   
       , seq_no     = itemsosdet.seq_no   
       , cust_no    = sale.cust_no
       , scene_code = sale.scene_code
       , item_no    = itemsosdet.item_no   
       , item_name  = groupitem.item_name
       , qa         = itemsosdet.qa   
       , color      = itemsosdet.color   
    FROM itemsosdet
         LEFT OUTER JOIN itemsos    ON itemsosdet.sos_no  = itemsos.sos_no     
         LEFT OUTER JOIN sale       ON itemsosdet.sale_no = sale.order_no
         LEFT OUTER JOIN saledet    ON itemsosdet.sale_no = saledet.order_no
         LEFT OUTER JOIN customer C ON sale.cust_no       = c.cust_no
         LEFT OUTER JOIN scene    S ON sale.scene_code    = s.scene_code
         LEFT OUTER JOIN groupitem  ON itemsosdet.item_no = groupitem.item_no
   WHERE itemsosdet.sos_no   = :as_sosno
" update="itemsosdet" updatewhere=0 updatekeyinplace=no arguments=(("as_sosno", string))  sort="seq_no A " )
