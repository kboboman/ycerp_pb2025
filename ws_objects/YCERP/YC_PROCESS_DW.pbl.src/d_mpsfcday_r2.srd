$PBExportHeader$d_mpsfcday_r2.srd
$PBExportComments$생산일보조회_보고서(일자별)(1998/05/08,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=468 color="536870912" )
summary(height=84 color="536870912" )
footer(height=0 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=sfcday_wc_no dbname="sfcday.wc_no" )
 column=(type=char(10) updatewhereclause=yes name=wc_work_name dbname="wc.work_name" initial=" " )
 column=(type=char(10) updatewhereclause=yes name=sfcdate dbname="sfcdate" )
 column=(type=char(10) updatewhereclause=yes name=sfcday_item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(20) updatewhereclause=yes name=sfcday_qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=sfcday_uom dbname="sfcday.uom" )
 column=(type=decimal(4) updatewhereclause=yes name=sum_qty dbname="sum_qty" )
 column=(type=decimal(0) updatewhereclause=yes name=uf_getqty dbname="uf_getqty" )
 column=(type=datetime updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=datetime updatewhereclause=yes name=edate dbname="edate" )
 retrieve="  SELECT sfcday.wc_no,   
         wc.work_name,
         sfcdate  = convert(char(10),sfcday.sfc_date,111),
         item_no  = sfcday.assembly,   
         groupitem.item_name,   
         qa       = sfcday.assembly_qa,   
         sfcday.uom,   
         sum_qty  = sum(make_qty),   
         uf_getqty = FLOOR(DBO.UF_GETQTY(sfcday.assembly, sfcday.assembly_qa, sfcday.uom, sum(make_qty))),
         sdate    = convert(smalldatetime, :ad_start, 111),   
         edate    = convert(smalldatetime, :ad_end, 111)  
    FROM sfcday,   
         wc,   
         groupitem  
   WHERE ( sfcday.wc_no     = wc.work_no ) 
     and ( sfcday.assembly  = groupitem.item_no ) 
     and ( ( wc.work_name        like :as_wc + ~"%~" ) AND  
           ( sfcday.sfc_date  between :ad_start and :ad_end + ~" 23:59:59:999~" ) and
			  ( sfcday.area_no = :as_area ) 
         )   
GROUP BY sfcday.wc_no,   
         wc.work_name,   
			convert(char(10),sfcday.sfc_date,111),
         sfcday.assembly,   
         groupitem.item_name,   
         sfcday.assembly_qa,   
         sfcday.uom" arguments=(("as_wc", string),("ad_start", date),("ad_end", date),("as_area", string))  sort="sfcday_wc_no A sfcday_item_no A sfcday_qa A " )
group(level=1 header.height=0 trailer.height=0 by=("sfcday_wc_no" ) header.color="536870912" trailer.color="536870912" )
group(level=2 header.height=0 trailer.height=84 by=("sfcdate" ) header.color="536870912" trailer.color="536870912" )
