compute(band=detail alignment="1" expression="if(left( dodet_item_no  ,1) = 'P' and mid( dodet_item_no , 3,1) = 'Y' and (mid( dodet_item_no , 7,1) = 'A' or mid( dodet_item_no , 7,1) = 'B' or mid( dodet_item_no , 7,1) = 'C' or mid( dodet_item_no , 7,1) = 'D' or left(dodet_item_no, 5) = 'PCYSZ'),  dodet_ship_qty , if( dodet_uom  = 'M2' or dodet_uom = 'SS' ,truncate( long(mid(  dodet_qa  ,5,4)) * long(mid(  dodet_qa ,10,4)) *     dodet_ship_qty  / 1000000, 2), if( dodet_uom  = 'M', if (dodet_ship_qty < 0 , truncate(long(mid( dodet_qa , 15,5)) *  dodet_ship_qty / 1000 - 0.00001,2), truncate(long(mid( dodet_qa , 15,5)) * dodet_ship_qty  / 1000 + 0.00001,2)) ,    dodet_ship_qty  )))"border="0" color="0" x="3918" y="4" height="60" width="421" format="#,##0.00" html.valueishtml="0"  name=c_acc_qty visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
column(band=detail id=17 alignment="1" tabsequence=32766 border="0" color="0" x="4347" y="4" height="60" width="320" format="#,##0.00" html.valueishtml="0"  name=dodet_price  tag="출고단가" visible="1" edit.limit=0 edit.case=any edit.focusrectangle=no edit.autoselect=yes edit.autohscroll=yes edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
compute(band=detail alignment="1" expression="if ( round = 'Y',  if( do_curr_code = 'WON', if ( c_acc_qty < 0 ,  round(dodet_price * c_acc_qty, 0),  round(dodet_price * c_acc_qty, 0)) ,  round(dodet_price  *  c_acc_qty, 2) ), if( do_curr_code = 'WON', if ( c_acc_qty < 0 ,  truncate(dodet_price * c_acc_qty, 0),  truncate(dodet_price * c_acc_qty + 0.000001, 0)) ,  truncate(dodet_price  *  c_acc_qty, 2) ))"border="0" color="0" x="4677" y="4" height="60" width="448" format="#,##0.00" html.valueishtml="0"  name=c_amt visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
