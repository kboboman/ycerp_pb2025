footer(height=76 color="8421504" )
detail(height=160 color="536870912" )
table(column=(type=char(12) updatewhereclause=yes key=yes name=ask_no dbname="ask_det.ask_no" )
 column=(type=long updatewhereclause=yes key=yes name=seq_no dbname="ask_det.seq_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="ask_det.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="ask_det.qa" )
 column=(type=char(10) update=yes updatewhereclause=yes name=loc_no dbname="ask_det.loc_no" )
 column=(type=decimal(2) updatewhereclause=yes name=ask_qty dbname="ask_det.ask_qty" initial="0" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=rlse_qty dbname="ask_det.rlse_qty" initial="0" )
 column=(type=char(50) update=yes updatewhereclause=yes name=rem dbname="ask_det.rem" )
 column=(type=datetime update=yes updatewhereclause=yes name=rlse_date dbname="ask_det.rlse_date" initial="today()" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=issue_qty dbname="ask_det.issue_qty" initial="0" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="groupitem.item_name" )
 column=(type=char(1) update=yes updatewhereclause=yes name=rlse_flag dbname="ask_det.rlse_flag" values="완료	Y/진행	N/" )
 column=(type=char(1) updatewhereclause=yes name=proc_flag dbname="ask_head.proc_flag" )
 column=(type=decimal(4) updatewhereclause=yes name=qoh dbname="qoh" )
 column=(type=char(1) updatewhereclause=yes name=sel dbname="sel" values="	Y/	N" )
 column=(type=char(30) updatewhereclause=yes name=loc_name dbname="location.loc_name" )
 column=(type=char(14) update=yes updatewhereclause=yes name=sale_no dbname="ask_det.sale_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(4) updatewhereclause=yes name=flag dbname="flag" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="groupitem.uom" )
 retrieve="  SELECT ask_det.ask_no         
       , ask_det.seq_no         
       , ask_det.item_no        
       , ask_det.qa             
       , ask_det.loc_no         
       , ask_det.ask_qty        
       , ask_det.rlse_qty       
       , ask_det.rem            
       , ask_det.rlse_date      
       , ask_det.issue_qty      
       , groupitem.item_name    
       , ask_det.rlse_flag      
       , ask_head.proc_flag     
       , qoh       = 0.0000                
       , sel       = 'N'              
       , location.loc_name      
       , ask_det.sale_no        
       , cust_name = dbo.uf_getcustname(ask_det.sale_no)                                
       , flag      = (CASE WHEN intemp.intemp_no IS NOT NULL THEN '가입' ELSE 'N' END)
       , groupitem.uom  
    FROM ask_det     
         LEFT OUTER JOIN ask_head  with (nolock) ON ask_det.ask_no  = ask_head.ask_no
         LEFT OUTER JOIN groupitem with (nolock) ON ask_det.item_no = groupitem.item_no
         LEFT OUTER JOIN location  with (nolock) ON ask_det.loc_no  = location.loc_no
         LEFT OUTER JOIN intemp    with (nolock) ON ask_det.ask_no  = intemp.order_no  AND ask_det.seq_no = intemp.seq_no
   WHERE ( ask_det.ask_no  = :as_askno )    
" update="ask_det" updatewhere=0 updatekeyinplace=yes arguments=(("as_askno", string))  sort="ask_no A seq_no A " )
