table(column=(type=char(16) update=yes updatewhereclause=yes key=yes name=order_no dbname="mpsorder.order_no" )
 column=(type=datetime update=yes updatewhereclause=yes name=order_date dbname="mpsorder.order_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=wc_no dbname="mpsorder.wc_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=area_no dbname="mpsorder.area_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=open_close dbname="mpsorder.open_close" initial="O" )
 column=(type=char(10) update=yes updatewhereclause=yes name=planner dbname="mpsorder.planner" )
 column=(type=char(1) update=yes updatewhereclause=yes name=overtime dbname="mpsorder.overtime" values="	Y/	N" )
 column=(type=char(40) update=yes updatewhereclause=yes name=rem dbname="mpsorder.rem" )
 retrieve="  SELECT mpsorder.order_no,   
         mpsorder.order_date,   
         mpsorder.wc_no,   
         mpsorder.area_no,   
         mpsorder.open_close,   
         mpsorder.planner,   
         mpsorder.overtime,   
         mpsorder.rem  
    FROM mpsorder  
   WHERE mpsorder.order_no = :arg_order    
" update="mpsorder" updatewhere=0 updatekeyinplace=no arguments=(("arg_order", string)) )
