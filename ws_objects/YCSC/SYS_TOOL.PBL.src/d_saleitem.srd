footer(height=0 color="536870912" )
detail(height=88 color="536870912" )
table(column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=char(10) updatewhereclause=yes name=itemloc_item_no dbname="item_no" )
 column=(type=char(20) updatewhereclause=yes name=itemloc_qa dbname="qa" )
 column=(type=decimal(4) updatewhereclause=yes name=compute_0004 dbname="compute_0004" )
 column=(type=char(10) updatewhereclause=yes name=c_date dbname="c_date" )
 retrieve="select item_name, item_no, qa, sum(qoh), c_date from (
      	select tb_ax.item_name, tb_ax.item_no, tb_ax.qa, sum(tb_ax.qoh) as qoh, tb_ax.c_date
        from (
                		SELECT location.loc_name,
                			itemloc.loc_no,   
                			groupitem.item_name,   
                			itemloc.item_no,   
                			itemloc.qa,   
                			qoh = isnull(itemloc.qoh, 0) - isnull(H.rcptqty, 0) + isnull(H.issueqty, 0),   
                			c_date = convert(varchar(10), :as_date, 111)
                		FROM 	itemloc inner join groupitem on  itemloc.item_no = groupitem.item_no  
                            			            inner join location on itemloc.loc_no = location.loc_no
                                          		left outer join 	(
                                                                          select 	ineoday.item_no, 
                                                                                      ineoday.qa, 
                                                                                      rcptqty = isnull(sum(ineoday.rcpt_qty), 0),
                                                                    				          issueqty = isnull(sum(ineoday.issue_qty), 0)
                                                                    			from ineoday
                                                                    			WHERE (( ineoday.loc_no = 'WS00000000')	
                                                                    			AND not ( ineoday.item_no >= 'PZZZFZ' 
                                                                    			or  ( ineoday.item_no like 'm%' and ineoday.item_no like 'm[13]_[12]%') ) )    
                                                                    			and cdate > :as_date2
                                                                    			group by ineoday.item_no, ineoday.qa
                                                                    		
                                                                    			union
                                                                    			select item_no = '', qa = '', rcptqty = 0 , issueqty = 0 
                                                                			) H on itemloc.item_no = H.item_no and itemloc.qa = H.qa
                            		              inner join tmp_item80 xx on itemloc.item_no = xx.item_no and itemloc.qa = xx.qa
                		WHERE  ( NOT (groupitem.uom = 'M2' and groupitem.item_no like 'PCY%') ) and  
                              			(  ( itemloc.loc_no = 'WS00000000') and 
                              		        not ( groupitem.item_no >= 'PZZZFZ' 
                              		         or  ( groupitem.item_no like 'm%' and groupitem.item_no like 'm[13]_[12]%') ) ) 
      		
              		union 
              		
              		SELECT location.loc_name,
              			itemloc.loc_no,   
              			groupitem.item_name,   
              			itemloc.item_no,   
              			itemloc.qa,   
              			qoh = isnull(itemloc.qoh, 0) - isnull(H.rcptqty, 0) + isnull(H.issueqty, 0),   
              			c_date = convert(varchar(10), :as_date, 111)
              		FROM 	itemloc  inner join groupitem on itemloc.item_no = groupitem.item_no
                          			             inner join location on itemloc.loc_no = location.loc_no
                                        		 left outer join (select 	ineoday.item_no, ineoday.qa, rcptqty = isnull(sum(ineoday.rcpt_qty), 0),
                                                                          				issueqty = isnull(sum(ineoday.issue_qty), 0)
                                                                          			from ineoday
                                                                          			WHERE (( ineoday.loc_no = 'WS00000006')	
                                                                          			AND not ( ineoday.item_no >= 'PZZZFZ' 
                                                                          			or  ( ineoday.item_no like 'm%' and ineoday.item_no like 'm[13]_[12]%') ) )    
                                                                          			and cdate > :as_date2
                                                                          			group by ineoday.item_no, ineoday.qa
                                                                          		
                                                                          			union
                                                                          			select item_no = '', qa = '', rcptqty = 0 , issueqty = 0 
                                                                			) H on itemloc.item_no = H.item_no 
                                                            and itemloc.qa = H.qa
              		                           inner join tmp_item80 xx on itemloc.item_no = xx.item_no 
                                                            and itemloc.qa = xx.qa
              		WHERE ( NOT (groupitem.uom = 'M2' and groupitem.item_no like 'PCY%') ) and  
              			                        (  ( itemloc.loc_no = 'WS00000006') and 
              		                              not ( groupitem.item_no >= 'PZZZFZ' 
              		                              or  ( groupitem.item_no like 'm%' and groupitem.item_no like 'm[13]_[12]%') ) ) 
      	) tb_ax
      	group by tb_ax.item_name, tb_ax.item_no, tb_ax.qa, tb_ax.c_date		
	
	union
	
    	select tb_ax.item_name, tb_ax.item_no, tb_ax.qa, sum(tb_ax.qoh) as qoh, tb_ax.c_date 
      from (
              		SELECT location.loc_name,
              			itemloc.loc_no,   
              			groupitem.item_name,   
              			itemloc.item_no,   
              			itemloc.qa,   
              			qoh = isnull(itemloc.qoh, 0) - isnull(H.rcptqty, 0) + isnull(H.issueqty, 0),   
              			c_date = convert(varchar(10), :as_date, 111)
              		FROM 	itemloc inner join groupitem on itemloc.item_no = groupitem.item_no
              			                        inner join location on itemloc.loc_no = location.loc_no
                                      			left outer join (select 	ineoday.item_no, ineoday.qa, rcptqty = isnull(sum(ineoday.rcpt_qty), 0),
                                                                				issueqty = isnull(sum(ineoday.issue_qty), 0)
                                                                			from ineoday
                                                                			WHERE (( ineoday.loc_no = 'WS00000007')	
                                                                			AND not ( ineoday.item_no >= 'PZZZFZ' 
                                                                			or  ( ineoday.item_no like 'm%' and ineoday.item_no like 'm[13]_[12]%') ) )    
                                                                			and cdate > :as_date2
                                                                			group by ineoday.item_no, ineoday.qa
                                                                		
                                                                			union
                                                                			select item_no = '', qa = '', rcptqty = 0 , issueqty = 0 
                                            			          ) H on itemloc.item_no = H.item_no and itemloc.qa = H.qa
                            		             inner join  tmp_item80 xx on itemloc.item_no = xx.item_no and itemloc.qa = xx.qa
                		WHERE ( NOT (groupitem.uom = 'M2' and groupitem.item_no like 'PCY%') ) and  
                			              (  ( itemloc.loc_no = 'WS00000007') and 
                		                    not ( groupitem.item_no >= 'PZZZFZ' 
                		                    or  ( groupitem.item_no like 'm%' and groupitem.item_no like 'm[13]_[12]%') ) ) 
    		
    		union
    	
    		SELECT location.loc_name,
    			itemloc.loc_no,   
    			groupitem.item_name,   
    			itemloc.item_no,   
    			itemloc.qa,   
    			qoh = isnull(itemloc.qoh, 0) - isnull(H.rcptqty, 0) + isnull(H.issueqty, 0),   
    			c_date = convert(varchar(10), :as_date, 111)
    		FROM 	itemloc inner join groupitem on itemloc.item_no = groupitem.item_no
    			                        inner join location on itemloc.loc_no = location.loc_no
                            			left outer join (
                                                          select 	ineoday.item_no, ineoday.qa, rcptqty = isnull(sum(ineoday.rcpt_qty), 0),
                                                    				issueqty = isnull(sum(ineoday.issue_qty), 0)
                                                    			from ineoday
                                                    			WHERE (( ineoday.loc_no = 'WS00000008')	
                                                    			AND not ( ineoday.item_no >= 'PZZZFZ' 
                                                    			or  ( ineoday.item_no like 'm%' and ineoday.item_no like 'm[13]_[12]%') ) )    
                                                    			and cdate > :as_date2
                                                    			group by ineoday.item_no, ineoday.qa
                                                    		
                                                    			union
                                                    			select item_no = '', qa = '', rcptqty = 0 , issueqty = 0 
                            			) H on itemloc.item_no = H.item_no and itemloc.qa = H.qa
                                  inner join  tmp_item80 xx on itemloc.item_no = xx.item_no and itemloc.qa = xx.qa
    		WHERE ( NOT (groupitem.uom = 'M2' and groupitem.item_no like 'PCY%') ) and  
    			              (  ( itemloc.loc_no = 'WS00000008') and 
    		                    not ( groupitem.item_no >= 'PZZZFZ' 
    		                    or  ( groupitem.item_no like 'm%' and groupitem.item_no like 'm[13]_[12]%') ) ) 
    	
    	) tb_ax
    	group by tb_ax.item_name, tb_ax.item_no, tb_ax.qa, tb_ax.c_date

) tb_bx
group by item_name, item_no, qa, c_date
order by 2,3" arguments=(("as_date", date),("as_date2", string))  sort="itemloc_item_no A itemloc_qa A " )
