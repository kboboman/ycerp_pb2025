$PBExportHeader$d_cditemwc_r.srd
$PBExportComments$제품별표준작업장보고서(1998/03/07,이인호)
release 5;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no )
header(height=501 color="536870912" )
summary(height=13 color="536870912" )
footer(height=5 color="536870912" )
detail(height=73 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=item_item_no dbname="item.item_no" )
 column=(type=char(60) update=yes updatewhereclause=yes name=item_name dbname="item.item_name" )
 column=(type=char(20) updatewhereclause=yes name=item_qa dbname="item.qa" )
 column=(type=char(20) updatewhereclause=yes name=wc_work_name dbname="wc.work_name" initial=" " )
 column=(type=long updatewhereclause=yes name=rout_operation dbname="rout.operation" )
 column=(type=char(2) updatewhereclause=yes name=rout_concurrent dbname="rout.concurrent" )
 column=(type=char(10) updatewhereclause=yes name=rout_wc_no dbname="rout.wc_no" )
 column=(type=decimal(4) updatewhereclause=yes name=rout_setup_time dbname="rout.setup_time" )
 column=(type=decimal(4) updatewhereclause=yes name=rout_queue_time dbname="rout.queue_time" )
 column=(type=decimal(4) updatewhereclause=yes name=rout_run_time dbname="rout.run_time" )
 column=(type=long updatewhereclause=yes name=rout_delivery_time dbname="rout.delivery_time" )
 column=(type=char(1) updatewhereclause=yes name=wc_work_type dbname="wc.work_type" initial=" " values="사내	D/외주	S/" )
 column=(type=char(10) updatewhereclause=yes name=rout_assembly dbname="rout.assembly" )
 column=(type=char(20) updatewhereclause=yes name=rout_assy_qa dbname="rout.assy_qa" )
 retrieve="PBSELECT( VERSION(400) DISTINCT ()TABLE(NAME=~"item~" )  TABLE(NAME=~"wc~" )  TABLE(NAME=~"rout~" ) COLUMN(NAME=~"item.item_no~") COLUMN(NAME=~"item.item_name~") COLUMN(NAME=~"item.qa~") COLUMN(NAME=~"wc.work_name~") COLUMN(NAME=~"rout.operation~") COLUMN(NAME=~"rout.concurrent~") COLUMN(NAME=~"rout.wc_no~") COLUMN(NAME=~"rout.setup_time~") COLUMN(NAME=~"rout.queue_time~") COLUMN(NAME=~"rout.run_time~") COLUMN(NAME=~"rout.delivery_time~") COLUMN(NAME=~"wc.work_type~") COLUMN(NAME=~"rout.assembly~") COLUMN(NAME=~"rout.assy_qa~")    JOIN (LEFT=~"rout.wc_no~"    OP =~"=~"RIGHT=~"wc.work_no~" )) "  sort="item_item_no A item_name A item_qa A rout_operation A " )
group(level=1 header.height=1 trailer.height=13 by=("item_item_no" ) header.color="553648127" trailer.color="536870912"  sort="count(item_item_no for group 1) A count(item_name for group 1) A count(item_qa for group 1) A " )
