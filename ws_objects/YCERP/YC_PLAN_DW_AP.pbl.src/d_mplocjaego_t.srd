table(column=(type=char(30) updatewhereclause=yes name=location_loc_name dbname="location.loc_name" )
 column=(type=decimal(4) updatewhereclause=yes name=qoh dbname="itemloc.qoh" )
 column=(type=char(10) updatewhereclause=yes name=loc_no dbname="location.loc_no" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"itemloc~" )  TABLE(NAME=~"location~" ) COLUMN(NAME=~"location.loc_name~") COLUMN(NAME=~"itemloc.qoh~") COLUMN(NAME=~"location.loc_no~")    JOIN (LEFT=~"itemloc.loc_no~"    OP =~"=~"RIGHT=~"location.loc_no~" )WHERE(    EXP1 =~"itemloc.item_no~"   OP =~"=~"    EXP2 =~":arg_item~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"itemloc.qa~"   OP =~"=~"    EXP2 =~":arg_qa~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"location.loc_type~"   OP =~"=~"    EXP2 =~"'N' ~" ) ) ARG(NAME = ~"arg_item~" TYPE = string)  ARG(NAME = ~"arg_qa~" TYPE = string) " arguments=(("arg_item", string),("arg_qa", string)) )
