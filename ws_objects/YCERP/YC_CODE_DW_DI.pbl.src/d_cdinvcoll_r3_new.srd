 retrieve="  SELECT a.cust_no   
       , a.cust_name   
       , a.captain_name   
       , birthday     = a.cap_birthday
       , cap_birthday = datediff(year,a.cap_birthday, getdate())
       , rotate     = vc.rotate
       , a.class
       , class_bigo = (case when a.class = 'A1'  then '(사월회)'
                            when a.class = 'A2'  then '(공략업체)'
                            when a.class = 'A3'  then '(우량,중점)'
                            when a.class = 'B1'  then '(유통업체)'
                            when a.class = 'B2'  then '(년간,입찰)'
                            when a.class = 'B3'  then '(생산업체)'
                            when a.class = 'C1'  then '(중간업체)'
                            when a.class = 'C11' then '(중간-채권)'
                            when a.class = 'C2'  then '(소액업체)'
                            when a.class = 'C22' then '(소액-채권)'
                            when a.class = 'D'   then '(장기고액)'
                            when a.class = 'X1'  then '(단발,특수)'
                            when a.class = 'X2'  then '(채권회수)'
                            when a.class = 'X3'  then '(관망,대기)'
                       end)
       , a.sale_address
       , colllevel = '' /*vc.colllevel*/
       , a.top_level
	  , substring(a.top_level,1,1) top_level1
	  , substring(a.top_level,2,1) top_level2
	  , ( case when substring(a.top_level,1,1) = 'A' then '(유지)'
			  when substring(a.top_level,1,1) = 'B' then '(공략)'
			  when substring(a.top_level,1,1) = 'C' then ( case when substring(a.top_level,2,1)  = 'X' then  '(중단)' else '(수금)' end )
			  else ''
         end ) top_level2_name
       , a.price_level   
       , a.credit_level   
       , a.credit_limit   
       , a.level_grade   
       , a.collect_ymd   
       , a.catain_value
       , a.joint_head   
       , a.jointor   
       , a.joint_amt   
       , a.joint_value
       , a.dambo_rem   
       , a.dambo_ymd   
       , a.dambo_ymde
       , a.dambo_amt   
       , a.dambo_value
       , a.dambo_bigo   
       , a.captain_relation
         
       , b.license_name
       , b.rem5

       , c.sys_date   
       , c.outamt   
       , c.c_rate   
       , c.y_rate   
       , c.y_amt   
       , c.s_rate1   
       , c.s_amt1   
       , c.s_rate2   
       , c.s_amt2   
       , c.s_rate3   
       , c.s_amt3   
       , c.s_rate4   
       , c.s_amt4   
       , c.s_rate5   
       , c.s_amt5   
       , c.s_rate6   
       , c.s_amt6   
       , c.s_rate7   
       , c.s_amt7   
       , c.s_rate8   
       , c.s_amt8   
       , c.s_rate9   
       , c.s_amt9   
       , c.s_rate10   
       , c.s_amt10   
       , c.s_rate11   
       , c.s_amt11   
       , c.s_rate12   
       , c.s_amt12
       , ceo_his = rtrim(a.captain_name) + ' / ' +  substring(convert(char(6), a.cap_birthday, 112),1,4)+'.'+substring(convert(char(6), a.cap_birthday, 112),5,2) +' / 만('+  convert(char(2), datediff( month, a.cap_birthday, getdate()) / 12) + ')세'
/*     , dbo.uf_getcustbigo(a.cust_no, '111') bigo_111
       , dbo.uf_getcustbigo(a.cust_no, '202') bigo_202
       , dbo.uf_getcustbigo(a.cust_no, '302') bigo_302
       , dbo.uf_getcustbigo(a.cust_no, '303') bigo_303
*/
    , e.month1_amt
    , e.month2_amt
    , e.month3_amt
    , e.month4_amt
    , e.month5_amt
    , e.month6_amt
    , e.month7_amt
    , e.month8_amt
    , e.month9_amt
    , e.month10_amt
    , e.month11_amt
    , e.month12_amt
    , f.month1_aim
    , f.month2_aim
    , f.month3_aim
    , f.month4_aim
    , f.month5_aim
    , f.month6_aim
    , f.month7_aim
    , f.month8_aim
    , f.month9_aim
    , f.month10_aim
    , f.month11_aim
    , f.month12_aim
    , g.yyyymm1
    , g.yyyymm2
    , g.yyyymm3
    , g.yyyymm4
    , g.yyyymm5
    , g.yyyymm6
    , g.yyyymm7
    , g.yyyymm8
    , g.yyyymm9
    , g.yyyymm10
    , g.yyyymm11
    , g.yyyymm12
    , a.sale_insurance			
    , a.sale_insurance_gigan			
    , a.sale_insurance_start_date			
    , a.sale_insurance_end_date			
    , a.sale_insurance_bigo			
	  , (
						SELECT substring(A.BIGO,1, 2000)
						 FROM CUSTOMER_BASE A with(nolock) INNER JOIN  (
																										SELECT A.CUST_NO, A.ITEM_CD, A.SORT, A.INPUT_DATE, MAX(SEQ) SEQ
																										 FROM CUSTOMER_BASE A INNER JOIN
																										 (
																											SELECT CUST_NO, ITEM_CD, SORT, MAX(input_date) input_date
																											FROM CUSTOMER_BASE
																											WHERE CUST_NO = a.cust_no
																											GROUP BY CUST_NO, ITEM_CD, SORT
																										  ) B ON A.CUST_NO = B.CUST_NO AND A.ITEM_CD = B.ITEM_CD AND A.SORT = B.SORT AND A.input_date = B.input_date
																										  GROUP BY A.CUST_NO, A.ITEM_CD, A.SORT, A.INPUT_DATE
																								 ) B 
																				ON A.CUST_NO = B.CUST_NO AND A.ITEM_CD = B.ITEM_CD AND A.SORT = B.SORT AND  A.input_date = B.INPUT_DATE AND A.SEQ = B.SEQ
									 						    INNER JOIN CODEMST C ON A.SORT = C.SORT AND C.BIGO LIKE '%(여신관리항목)%'
						  WHERE A.CUST_NO = a.cust_no
								AND  A.SORT = '111'     
	    ) bigo_111
	  , (
						SELECT substring(A.BIGO,1, 2000)
						 FROM CUSTOMER_BASE A with(nolock) INNER JOIN    (
																										SELECT A.CUST_NO, A.ITEM_CD, A.SORT, A.INPUT_DATE, MAX(SEQ) SEQ
																										 FROM CUSTOMER_BASE A INNER JOIN
																										 (
																											SELECT CUST_NO, ITEM_CD, SORT, MAX(input_date) input_date
																											FROM CUSTOMER_BASE
																											WHERE CUST_NO = a.cust_no
																											GROUP BY CUST_NO, ITEM_CD, SORT
																										  ) B ON A.CUST_NO = B.CUST_NO AND A.ITEM_CD = B.ITEM_CD AND A.SORT = B.SORT AND A.input_date = B.input_date
																										  GROUP BY A.CUST_NO, A.ITEM_CD, A.SORT, A.INPUT_DATE
																								 ) B 
																				ON A.CUST_NO = B.CUST_NO AND A.ITEM_CD = B.ITEM_CD AND A.SORT = B.SORT AND  A.input_date = B.INPUT_DATE AND A.SEQ = B.SEQ
									 						    INNER JOIN CODEMST C ON A.SORT = C.SORT AND C.BIGO LIKE '%(여신관리항목)%'
						  WHERE A.CUST_NO = a.cust_no
								AND  A.SORT = '202'     
	    ) bigo_202
	  , (
						SELECT substring(A.BIGO,1, 2000)
						 FROM CUSTOMER_BASE A with(nolock) INNER JOIN    (
																										SELECT A.CUST_NO, A.ITEM_CD, A.SORT, A.INPUT_DATE, MAX(SEQ) SEQ
																										 FROM CUSTOMER_BASE A INNER JOIN
																										 (
																											SELECT CUST_NO, ITEM_CD, SORT, MAX(input_date) input_date
																											FROM CUSTOMER_BASE
																											WHERE CUST_NO = a.cust_no
																											GROUP BY CUST_NO, ITEM_CD, SORT
																										  ) B ON A.CUST_NO = B.CUST_NO AND A.ITEM_CD = B.ITEM_CD AND A.SORT = B.SORT AND A.input_date = B.input_date
																										  GROUP BY A.CUST_NO, A.ITEM_CD, A.SORT, A.INPUT_DATE
																								 ) B 
																				ON A.CUST_NO = B.CUST_NO AND A.ITEM_CD = B.ITEM_CD AND A.SORT = B.SORT AND  A.input_date = B.INPUT_DATE AND A.SEQ = B.SEQ
									 						    INNER JOIN CODEMST C ON A.SORT = C.SORT AND C.BIGO LIKE '%(여신관리항목)%'
						  WHERE A.CUST_NO = a.cust_no
								AND  A.SORT = '302'     
	    ) bigo_302
	  , (
						SELECT substring(A.BIGO,1, 2000)
						 FROM CUSTOMER_BASE A with(nolock) INNER JOIN  (
																										SELECT A.CUST_NO, A.ITEM_CD, A.SORT, A.INPUT_DATE, MAX(SEQ) SEQ
																										 FROM CUSTOMER_BASE A INNER JOIN
																										 (
																											SELECT CUST_NO, ITEM_CD, SORT, MAX(input_date) input_date
																											FROM CUSTOMER_BASE
																											WHERE CUST_NO = a.cust_no
																											GROUP BY CUST_NO, ITEM_CD, SORT
																										  ) B ON A.CUST_NO = B.CUST_NO AND A.ITEM_CD = B.ITEM_CD AND A.SORT = B.SORT AND A.input_date = B.input_date
																										  GROUP BY A.CUST_NO, A.ITEM_CD, A.SORT, A.INPUT_DATE
																								 ) B 
																				ON A.CUST_NO = B.CUST_NO AND A.ITEM_CD = B.ITEM_CD AND A.SORT = B.SORT AND  A.input_date = B.INPUT_DATE AND A.SEQ = B.SEQ
									 						    INNER JOIN CODEMST C ON A.SORT = C.SORT AND C.BIGO LIKE '%(여신관리항목)%'
						  WHERE A.CUST_NO = a.cust_no
								AND  A.SORT = '303'     
	    ) bigo_303

	  , CASE  WHEN SUBSTRING(CONVERT(CHAR(6), GETDATE(), 112),5,2) = '01' THEN D.MOD_01
				WHEN SUBSTRING(CONVERT(CHAR(6), GETDATE(), 112),5,2) = '02' THEN D.MOD_02
				WHEN SUBSTRING(CONVERT(CHAR(6), GETDATE(), 112),5,2) = '03' THEN D.MOD_03
				WHEN SUBSTRING(CONVERT(CHAR(6), GETDATE(), 112),5,2) = '04' THEN D.MOD_04
				WHEN SUBSTRING(CONVERT(CHAR(6), GETDATE(), 112),5,2) = '05' THEN D.MOD_05
				WHEN SUBSTRING(CONVERT(CHAR(6), GETDATE(), 112),5,2) = '06' THEN D.MOD_06
				WHEN SUBSTRING(CONVERT(CHAR(6), GETDATE(), 112),5,2) = '07' THEN D.MOD_07
				WHEN SUBSTRING(CONVERT(CHAR(6), GETDATE(), 112),5,2) = '08' THEN D.MOD_08
				WHEN SUBSTRING(CONVERT(CHAR(6), GETDATE(), 112),5,2) = '09' THEN D.MOD_09
				WHEN SUBSTRING(CONVERT(CHAR(6), GETDATE(), 112),5,2) = '10' THEN D.MOD_10
				WHEN SUBSTRING(CONVERT(CHAR(6), GETDATE(), 112),5,2) = '11' THEN D.MOD_11
				WHEN SUBSTRING(CONVERT(CHAR(6), GETDATE(), 112),5,2) = '12' THEN D.MOD_12
          END / 1000000 AIM_MOD
	  , CASE WHEN SUBSTRING(CONVERT(CHAR(6),  DATEADD(MM, -1, GETDATE() ), 112),5,2) = '01' THEN D.MOD_01
				WHEN SUBSTRING(CONVERT(CHAR(6), DATEADD(MM, -1, GETDATE() ), 112),5,2) = '02' THEN D.MOD_02
				WHEN SUBSTRING(CONVERT(CHAR(6), DATEADD(MM, -1, GETDATE() ), 112),5,2) = '03' THEN D.MOD_03
				WHEN SUBSTRING(CONVERT(CHAR(6), DATEADD(MM, -1, GETDATE() ), 112),5,2) = '04' THEN D.MOD_04
				WHEN SUBSTRING(CONVERT(CHAR(6), DATEADD(MM, -1, GETDATE() ), 112),5,2) = '05' THEN D.MOD_05
				WHEN SUBSTRING(CONVERT(CHAR(6), DATEADD(MM, -1, GETDATE() ), 112),5,2) = '06' THEN D.MOD_06
				WHEN SUBSTRING(CONVERT(CHAR(6), DATEADD(MM, -1, GETDATE() ), 112),5,2) = '07' THEN D.MOD_07
				WHEN SUBSTRING(CONVERT(CHAR(6), DATEADD(MM, -1, GETDATE() ), 112),5,2) = '08' THEN D.MOD_08
				WHEN SUBSTRING(CONVERT(CHAR(6), DATEADD(MM, -1, GETDATE() ), 112),5,2) = '09' THEN D.MOD_09
				WHEN SUBSTRING(CONVERT(CHAR(6), DATEADD(MM, -1, GETDATE() ), 112),5,2) = '10' THEN D.MOD_10
				WHEN SUBSTRING(CONVERT(CHAR(6), DATEADD(MM, -1, GETDATE() ), 112),5,2) = '11' THEN D.MOD_11
				WHEN SUBSTRING(CONVERT(CHAR(6), DATEADD(MM, -1, GETDATE() ), 112),5,2) = '12' THEN D.MOD_12
          END / 1000000 PRE_AIM_MOD
    FROM customer A with(nolock)
         LEFT OUTER JOIN customer_outamt C with(nolock) ON a.cust_no = c.cust_no AND datepart(year, c.eom_year) = :ai_year
         LEFT OUTER JOIN custinfo B with(nolock) ON a.cust_no = b.cust_no
         LEFT OUTER JOIN v_customer VC ON a.cust_no = vc.cid
	       LEFT OUTER JOIN CUST_AIM D ON A.CUST_NO = D.CUST_CODE AND CONVERT(CHAR(4), TAR_YEAR, 112) = :ai_year,
        (

                  SELECT SUM(case when convert(char(6), dateadd(month,-11,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) = a.YYYYMM then (a.SALE_AMT) else 0 end )/1000000 month12_amt,
                                     SUM(case when convert(char(6), dateadd(month,-10,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) = a.YYYYMM then (a.SALE_AMT) else 0 end )/1000000 month11_amt,
                                     SUM(case when convert(char(6), dateadd(month, -9,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) = a.YYYYMM then (a.SALE_AMT) else 0 end )/1000000    month10_amt,
                                     SUM(case when convert(char(6), dateadd(month, -8,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) = a.YYYYMM then (a.SALE_AMT) else 0 end )/1000000    month9_amt,
                                     SUM(case when convert(char(6), dateadd(month, -7,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) = a.YYYYMM then (a.SALE_AMT) else 0 end )/1000000    month8_amt,
                                     SUM(case when convert(char(6), dateadd(month, -6,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) = a.YYYYMM then (a.SALE_AMT) else 0 end ) /1000000   month7_amt,
                                     SUM(case when convert(char(6), dateadd(month, -5,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) = a.YYYYMM then (a.SALE_AMT) else 0 end ) /1000000   month6_amt,
                                     SUM(case when convert(char(6), dateadd(month, -4,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) = a.YYYYMM then (a.SALE_AMT) else 0 end ) /1000000   month5_amt,
                                     SUM(case when convert(char(6), dateadd(month, -3,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) = a.YYYYMM then (a.SALE_AMT) else 0 end ) /1000000   month4_amt,
                                     SUM(case when convert(char(6), dateadd(month, -2,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) = a.YYYYMM then (a.SALE_AMT) else 0 end ) /1000000   month3_amt,
                                     SUM(case when convert(char(6), dateadd(month, -1,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) = a.YYYYMM then (a.SALE_AMT) else 0 end ) /1000000   month2_amt,
                                     SUM(case when convert(char(6),getdate(),112)= a.YYYYMM then (a.SALE_AMT) else 0 end ) /1000000                                                                                                                month1_amt
                  FROM 
                  (
                             SELECT   cust_no   = a.cust_no   
                                               , convert(char(6), dateadd(month,-1,a.do_date),112) yyyymm
                            	                 , SALE_AMT  = sum(a.do_total) 
                            FROM do a with(nolock)
                            	  LEFT OUTER JOIN customer b with(nolock)  ON a.cust_no  = b.cust_no
                            WHERE a.do_date  BETWEEN convert(datetime, convert(char(8), dateadd(month,-10,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) + ' 00:00:00')
                                                                                         AND  convert(datetime,  convert(char(8), dateadd(day,-1, dateadd( month, 1, convert(datetime, convert(char(6),getdate(),112)+'01' ))) , 112 ) +  ' 23:59:59')
                             AND ( b.cust_flag         = 'N' )
                             AND ( b.cust_type        <> 'E' )
                            AND (  isnull(a.ewol,'N')  = 'Y' )
                            AND  A.CUST_NO = :as_cust_no
                            GROUP BY a.cust_no, convert(char(6), dateadd(month,-1,a.do_date),112)
                          union all
                          SELECT a.CUST_NO
                                        , convert(char(6),a.do_date,112) yyyymm
                          	            , SALE_AMT  = sum(a.do_total) 
                          FROM do a with(nolock)
                          	  LEFT OUTER JOIN customer b with(nolock)  ON a.cust_no  = b.cust_no
                          WHERE a.do_date BETWEEN convert(datetime, convert(char(8), dateadd(month,-11,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) + ' 00:00:00') 
                                                                                AND  convert(datetime,  convert(char(8), dateadd(day,-1, dateadd( month, 1, convert(datetime, convert(char(6),getdate(),112)+'01' ))) , 112 ) +  ' 23:59:59')
                           AND ( b.cust_flag         = 'N' )
                           AND ( b.cust_type        <> 'E' )
                           AND ( isnull(a.ewol,'N')  <> 'Y' )
                           AND A.CUST_NO = :as_cust_no
                          GROUP BY a.CUST_NO, convert(char(6),a.do_date,112)
                  ) a
        ) e,
      (
                                    select 
                                               sum(case when convert(char(6), dateadd(month,-11,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) = a.yyyymm then a.mod_amt else 0 end )/1000000 month12_aim,
                                               sum(case when convert(char(6), dateadd(month,-10,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) = a.yyyymm then a.mod_amt else 0 end )/1000000 month11_aim,
                                               sum(case when convert(char(6), dateadd(month,-9,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) = a.yyyymm then a.mod_amt else 0 end )/1000000 month10_aim,
                                               sum(case when convert(char(6), dateadd(month,-8,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) = a.yyyymm then a.mod_amt else 0 end )/1000000 month9_aim,
                                               sum(case when convert(char(6), dateadd(month,-7,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) = a.yyyymm then a.mod_amt else 0 end )/1000000 month8_aim,
                                               sum(case when convert(char(6), dateadd(month,-6,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) = a.yyyymm then a.mod_amt else 0 end )/1000000 month7_aim,
                                               sum(case when convert(char(6), dateadd(month,-5,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) = a.yyyymm then a.mod_amt else 0 end )/1000000 month6_aim,
                                               sum(case when convert(char(6), dateadd(month,-4,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) = a.yyyymm then a.mod_amt else 0 end )/1000000 month5_aim,
                                               sum(case when convert(char(6), dateadd(month,-3,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) = a.yyyymm then a.mod_amt else 0 end )/1000000 month4_aim,
                                               sum(case when convert(char(6), dateadd(month,-2,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) = a.yyyymm then a.mod_amt else 0 end )/1000000 month3_aim,
                                               sum(case when convert(char(6), dateadd(month,-1,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) = a.yyyymm then a.mod_amt else 0 end )/1000000 month2_aim,
                                               sum(case when convert(char(6), getdate(),112) = a.yyyymm then a.mod_amt else 0 end ) /1000000                                                                                                           month1_aim
                                    from 
                                    (
                                                   select distinct  a.yyyymm, a.mod_amt
                                                   from 
                                                   (           
                                                          select convert(char(4), dateadd(month,-11,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112)+'01' yyyymm,  mod_01 mod_amt
                                                          from CUST_AIM
                                                          where tar_year = convert(datetime, convert(char(4), dateadd(month,-11,convert(datetime,  convert(char(6),getdate(),112)+'01' )),121)+ +'-01-01'  + ' 00:00:00' )                             
                                                              and cust_code = :as_cust_no                                
                                                          union all
                                                          select convert(char(4), dateadd(month,-11,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112)+'02' yyyymm,  mod_02 mod_amt
                                                          from CUST_AIM
                                                          where tar_year = convert(datetime, convert(char(4), dateadd(month,-11,convert(datetime,  convert(char(6),getdate(),112)+'01' )),121)+ +'-01-01'  + ' 00:00:00' )                             
                                                              and cust_code = :as_cust_no
                                                          union all    
                                                          select convert(char(4), dateadd(month,-11,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112)+'03' yyyymm,  mod_03 mod_amt
                                                          from CUST_AIM
                                                          where tar_year = convert(datetime, convert(char(4), dateadd(month,-11,convert(datetime,  convert(char(6),getdate(),112)+'01' )),121)+ +'-01-01'  + ' 00:00:00' )                             
                                                              and cust_code = :as_cust_no    
                                                          union all
                                                          select convert(char(4), dateadd(month,-11,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112)+'04' yyyymm,  mod_04 mod_amt
                                                          from CUST_AIM
                                                          where tar_year = convert(datetime, convert(char(4), dateadd(month,-11,convert(datetime,  convert(char(6),getdate(),112)+'01' )),121)+ +'-01-01'  + ' 00:00:00' )                             
                                                              and cust_code = :as_cust_no
                                                          union all
                                                          select convert(char(4), dateadd(month,-11,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112)+'05' yyyymm,  mod_05 mod_amt
                                                          from CUST_AIM
                                                          where tar_year = convert(datetime, convert(char(4), dateadd(month,-11,convert(datetime,  convert(char(6),getdate(),112)+'01' )),121)+ +'-01-01'  + ' 00:00:00' )                             
                                                              and cust_code = :as_cust_no
                                                          union all
                                                          select convert(char(4), dateadd(month,-11,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112)+'06' yyyymm,  mod_06 mod_amt
                                                          from CUST_AIM
                                                          where tar_year = convert(datetime, convert(char(4), dateadd(month,-11,convert(datetime,  convert(char(6),getdate(),112)+'01' )),121)+ +'-01-01'  + ' 00:00:00' )                             
                                                              and cust_code = :as_cust_no                                
                                                          union all
                                                          select convert(char(4), dateadd(month,-11,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112)+'07' yyyymm,  mod_07 mod_amt
                                                          from CUST_AIM
                                                          where tar_year = convert(datetime, convert(char(4), dateadd(month,-11,convert(datetime,  convert(char(6),getdate(),112)+'01' )),121)+ +'-01-01'  + ' 00:00:00' )                             
                                                              and cust_code = :as_cust_no
                                                          union all    
                                                          select convert(char(4), dateadd(month,-11,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112)+'08' yyyymm,  mod_08 mod_amt
                                                          from CUST_AIM
                                                          where tar_year = convert(datetime, convert(char(4), dateadd(month,-11,convert(datetime,  convert(char(6),getdate(),112)+'01' )),121)+ +'-01-01'  + ' 00:00:00' )                             
                                                              and cust_code = :as_cust_no    
                                                          union all
                                                          select convert(char(4), dateadd(month,-11,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112)+'09' yyyymm,  mod_09 mod_amt
                                                          from CUST_AIM
                                                          where tar_year = convert(datetime, convert(char(4), dateadd(month,-11,convert(datetime,  convert(char(6),getdate(),112)+'01' )),121)+ +'-01-01'  + ' 00:00:00' )                             
                                                              and cust_code = :as_cust_no
                                                          union all
                                                          select convert(char(4), dateadd(month,-11,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112)+'10' yyyymm,  mod_10 mod_amt
                                                          from CUST_AIM
                                                          where tar_year = convert(datetime, convert(char(4), dateadd(month,-11,convert(datetime,  convert(char(6),getdate(),112)+'01' )),121)+ +'-01-01'  + ' 00:00:00' )                             
                                                              and cust_code = :as_cust_no
                                                          union all
                                                          select convert(char(4), dateadd(month,-11,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112)+'11' yyyymm,  mod_11 mod_amt
                                                          from CUST_AIM
                                                          where tar_year = convert(datetime, convert(char(4), dateadd(month,-11,convert(datetime,  convert(char(6),getdate(),112)+'01' )),121)+ +'-01-01'  + ' 00:00:00' )                             
                                                              and cust_code = :as_cust_no
                                                          union all
                                                          select convert(char(4), dateadd(month,-11,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112)+'12' yyyymm,  mod_12 mod_amt
                                                          from CUST_AIM
                                                          where tar_year = convert(datetime, convert(char(4), dateadd(month,-11,convert(datetime,  convert(char(6),getdate(),112)+'01' )),121)+ +'-01-01'  + ' 00:00:00' )                             
                                                              and cust_code = :as_cust_no
                                                          union all
                                                          select convert(char(4),getdate(),112)+'01',   mod_01 mod_amt
                                                          from CUST_AIM
                                                          where tar_year = convert(datetime, convert(char(4),getdate(),121)+'-01-01' + ' 00:00:00')
                                                              and cust_code = :as_cust_no                                
                                                          union all
                                                          select convert(char(4),getdate(),112)+'02',   mod_02 mod_amt
                                                          from CUST_AIM
                                                          where tar_year = convert(datetime, convert(char(4),getdate(),121)+'-01-01' + ' 00:00:00')
                                                              and cust_code = :as_cust_no                                
                                                          union all
                                                          select convert(char(4),getdate(),112)+'03',   mod_03 mod_amt
                                                          from CUST_AIM
                                                          where tar_year = convert(datetime, convert(char(4),getdate(),121)+'-01-01' + ' 00:00:00')
                                                              and cust_code = :as_cust_no                                
                                                          union all
                                                          select convert(char(4),getdate(),112)+'04',   mod_04 mod_amt
                                                          from CUST_AIM
                                                          where tar_year = convert(datetime, convert(char(4),getdate(),121)+'-01-01' + ' 00:00:00')
                                                              and cust_code = :as_cust_no                                
                                                          union all
                                                          select convert(char(4),getdate(),112)+'05',   mod_05 mod_amt
                                                          from CUST_AIM
                                                          where tar_year = convert(datetime, convert(char(4),getdate(),121)+'-01-01' + ' 00:00:00')
                                                              and cust_code = :as_cust_no                                
                                                          union all
                                                          select convert(char(4),getdate(),112)+'06',   mod_06 mod_amt
                                                          from CUST_AIM
                                                          where tar_year = convert(datetime, convert(char(4),getdate(),121)+'-01-01' + ' 00:00:00')
                                                              and cust_code = :as_cust_no                 
                                                          union all
                                                          select convert(char(4),getdate(),112)+'07',   mod_07 mod_amt
                                                          from CUST_AIM
                                                        where tar_year = convert(datetime, convert(char(4),getdate(),121)+'-01-01' + ' 00:00:00')
                                                            and cust_code = :as_cust_no                                
                                                        union all
                                                        select convert(char(4),getdate(),112)+'08',   mod_08 mod_amt
                                                        from CUST_AIM
                                                        where tar_year = convert(datetime, convert(char(4),getdate(),121)+'-01-01' + ' 00:00:00')
                                                            and cust_code = :as_cust_no                                
                                                        union all
                                                        select convert(char(4),getdate(),112)+'09',   mod_09 mod_amt
                                                        from CUST_AIM
                                                        where tar_year = convert(datetime, convert(char(4),getdate(),121)+'-01-01' + ' 00:00:00')
                                                            and cust_code = :as_cust_no         
                                                        union all
                                                        select convert(char(4),getdate(),112)+'10',   mod_10 mod_amt
                                                        from CUST_AIM
                                                        where tar_year = convert(datetime, convert(char(4),getdate(),121)+'-01-01' + ' 00:00:00')
                                                            and cust_code = :as_cust_no                                
                                                        union all
                                                        select convert(char(4),getdate(),112)+'11',   mod_11 mod_amt
                                                        from CUST_AIM
                                                        where tar_year = convert(datetime, convert(char(4),getdate(),121)+'-01-01' + ' 00:00:00')
                                                            and cust_code = :as_cust_no                                
                                                        union all
                                                        select convert(char(4),getdate(),112)+'12',   mod_12 mod_amt
                                                        from CUST_AIM
                                                        where tar_year = convert(datetime, convert(char(4),getdate(),121)+'-01-01' + ' 00:00:00')
                                                            and cust_code = :as_cust_no
                                                  ) a
                                  ) a    
                                  where a.yyyymm between convert(char(6), dateadd(month,-11,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) and convert(char(6),getdate(),112)

      ) f,
	(

		select 
					  substring(convert(char(6), dateadd(month,-11,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) ,5,2) yyyymm12,
					  substring(convert(char(6), dateadd(month,-10,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) ,5,2) yyyymm11,
					  substring(convert(char(6), dateadd(month,-9,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) ,5,2) yyyymm10,
					  substring(convert(char(6), dateadd(month,-8,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) ,5,2) yyyymm9,
					  substring(convert(char(6), dateadd(month,-7,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) ,5,2) yyyymm8,
					  substring(convert(char(6), dateadd(month,-6,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) ,5,2) yyyymm7,
					  substring(convert(char(6), dateadd(month,-5,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) ,5,2) yyyymm6,
					  substring(convert(char(6), dateadd(month,-4,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) ,5,2) yyyymm5,                      
					  substring(convert(char(6), dateadd(month,-3,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) ,5,2) yyyymm4,           
					  substring(convert(char(6), dateadd(month,-2,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) ,5,2) yyyymm3,
					  substring(convert(char(6), dateadd(month,-1,convert(datetime,  convert(char(6),getdate(),112)+'01' )),112) ,5,2) yyyymm2,
					  substring(convert(char(6),getdate(),112) ,5,2)                                                                                                            yyyymm1                      
		from dual
	) g
   WHERE ( a.cust_no = :as_cust_no )
  
" arguments=(("as_cust_no", string),("ai_year", number)) )
