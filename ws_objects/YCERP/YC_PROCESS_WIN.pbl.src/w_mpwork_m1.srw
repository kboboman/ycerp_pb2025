event clicked;long ll_row, ll_cnt

if this.rowcount() < 1 then return

//
GF_DWClick2Info(this, ddlb_fld, ddlb_op, sle_value3, row, dwo.name, ddlb_dwtitles)

if cbx_multi.checked = false then
	//ll_row = this.getrow()
	ll_row = row
	if ll_row = 0 then
		for ll_cnt = 1 to ll_row
			this.SelectRow(ll_row, NOT this.IsSelected(ll_cnt))
		next
	else
		this.SelectRow(ll_row, NOT this.IsSelected(ll_row))
	end if
else
	// 다중선택
	GF_MULTI_SELECT(this, row)
end if

end event

type cb_1 from commandbutton within tabpage_1
integer x = 1600
integer y = 8
integer width = 494
integer height = 80
integer taborder = 71
boolean bringtotop = true
integer textsize = -10
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "작업일보작성"
end type

event clicked;// 작업일보작성
datawindow dwsource, dwtarget
long   ll_rowcount,  ll_rowcount1, ll_cnt,  ll_row,     ll_count,   ll_first, ll_saleseq
string ls_plan,      ls_loc,       ls_assy, ls_assyqa,  ls_uom,     ls_qa1
string ls_cust,      ls_custname,  ls_sale, ls_old_time, ls_saleno, ls_bigo, ls_locname
real   lr_qty,       lr_hebe,      lr_len
time   lt_Time

dwsource = dw3	// 작업일보대상항목
dwtarget = dw4	// 작업일보등록

dw_2.accepttext()
dwtarget.accepttext()
dwsource.accepttext()
ll_rowcount  = dwsource.rowcount()
ll_rowcount1 = dwtarget.rowcount()

if dw_2.rowcount() > 0 then
	ls_loc = trim(dw_2.object.loc_no[1])
else
	ls_loc = ""
end if
if isnull(ls_loc) OR ls_loc = "" then RETURN

SELECT loc_name INTO :ls_locname FROM location WHERE loc_no = :ls_loc;
if MessageBox("확인","완성품 입고저장소를'" + ls_locname + "' 로 등록하게 됩니다.~n~n계속 진행하시겠습니까?",exclamation!,YesNo!, 2) = 2 then
	dw_2.SetColumn("loc_no")
	dw_2.setfocus()
	RETURN
end if

ll_count = 0
for ll_cnt = 1 to ll_rowcount
	if dwsource.isselected(ll_cnt) then
      ll_count ++
	end if
next
if ll_count = 0 then
	MessageBox("오류","작업일보를 작성할 항목을 선택하세요.",exclamation!)
	return
end if

// 작업일보대상항목
if wf_dw3_itemchk() = false then	return

ls_old_time = string(now(), 'hh:mm:ss:fff')
ll_first = 10000
for ll_cnt = 1 to ll_rowcount
	if dwsource.isselected(ll_cnt) then
		ls_plan = trim(dwsource.object.mpsdet_plan_no[ll_cnt])
		
		ll_row = dwtarget.insertrow(0)
		if ll_row < ll_first then ll_first = ll_row
		
		dwtarget.object.order_no[ll_row]       = ls_plan
		dwtarget.object.mpsorder_order[ll_row] = dwsource.object.mpsorder_order[ll_cnt]
		dwtarget.object.order_seq[ll_row]      = dwsource.object.order_seq[ll_cnt]
		
		// 생산입고에 로직입니다.
		for ll_count = 1 to 100000
			if ls_old_time <> string(now(), 'hh:mm:ss:fff') then
				ls_old_time = string(now(),'hh:mm:ss:fff')	
				exit
			end if	
		next
		
		lt_Time = time(MidA(string(today(),'yyyy/mm/dd hh:mm:ss:fff'),11))
		dwtarget.object.sfc_date[ll_row]    = datetime(date(dw_2.object.work_date[1]), lt_Time)
		dwtarget.object.item_no[ll_row]     = dwsource.object.item_no[ll_cnt]
		dwtarget.object.qa[ll_row]          = dwsource.object.qa[ll_cnt]
		dwtarget.object.assembly[ll_row]    = dwsource.object.assy_item[ll_cnt]
		dwtarget.object.assembly_qa[ll_row] = dwsource.object.assy_qa[ll_cnt]
		dwtarget.object.wc_no[ll_row]       = dwsource.object.wc_no[ll_cnt]
		dwtarget.object.sfcday_operation[ll_row]    = dwsource.object.routtempnew_operation[ll_cnt]
		dwtarget.object.groupitem_item_name[ll_row] = dwsource.object.groupitem_item_name1[ll_cnt]
		dwtarget.object.uom[ll_row]         = dwsource.object.groupitem_uom[ll_cnt]
		
		// 성형반만 길이가 있는경우 M로 환산단위 들어가게 함
		if LeftA(dwsource.object.wc_no[ll_cnt],1) = "F" and dwsource.object.wc_no[ll_cnt] < "F24" &
			and isnumber(MidA(dwsource.object.qa[ll_cnt], 15,5)) then
			if integer(MidA(dwsource.object.qa[ll_cnt], 15,5)) > 0 then
				dwtarget.object.uom[ll_row] = "M"
			end if
		end if
		dwtarget.object.plan_qty[ll_row]   = dwsource.object.plan_qty[ll_cnt] - dwsource.object.make_qty[ll_cnt]
		dwtarget.object.make_qty[ll_row]   = dwsource.object.plan_qty[ll_cnt] - dwsource.object.make_qty[ll_cnt]
		dwtarget.object.per_qty[ll_row]    = dwsource.object.work_per[ll_cnt]
		dwtarget.object.sale_no[ll_row]    = dwsource.object.sale_no[ll_cnt]
		dwtarget.object.seq_no[ll_row]     = dwsource.object.seq_no[ll_cnt]
		dwtarget.object.color[ll_row]      = dwsource.object.item_color[ll_cnt]
		dwtarget.object.cust_no[ll_row]    = dwsource.object.cust_no[ll_cnt]
		dwtarget.object.scene_code[ll_row] = dwsource.object.scene_code[ll_cnt]
		dwtarget.object.area_no[ll_row]    = dwsource.object.area_no[ll_cnt]
		
		ls_saleno    = dwsource.object.sale_no[ll_cnt]		// 수주번호
		ll_saleseq   = dwsource.object.seq_no[ll_cnt]		// 수주순번
		
		SELECT rtrim(rem) INTO :ls_bigo FROM saledet WHERE order_no = :ls_saleno AND seq_no = :ll_saleseq;
		dwtarget.object.saledet_rem[ll_row] = ls_bigo		// 수주상세 비고
		dwtarget.object.user_id[ll_row]     = gs_userid
		
		ls_sale = trim(dwsource.object.sale_no[ll_cnt])
		if MidA(ls_sale,1,2) <> 'NO' then
			ls_cust = trim(dwsource.object.cust_no[ll_cnt])
			SELECT cust_name INTO :ls_custname FROM customer WHERE cust_no = :ls_cust;
			dwtarget.object.cust_name[ll_row] = trim(ls_custname)
		end if
		
		dwtarget.object.loc_no[ll_row] = ls_loc
		ls_assy   = trim(dwsource.object.assy_item[ll_cnt])
		ls_assyqa = trim(dwsource.object.assy_qa[ll_cnt])
		ls_uom    = trim(dwsource.object.groupitem_uom[ll_cnt])
		if isnull(ls_uom) or ls_uom = "" then
			ls_uom = trim(dwsource.object.auom[ll_cnt])
			dwtarget.object.uom[ll_row] = ls_uom
		end if
		ls_uom    = trim(dwsource.object.auom[ll_cnt])
		lr_qty    = dwsource.object.plan_qty[ll_cnt] - dwsource.object.make_qty[ll_cnt]

		setnull(lr_hebe)
		SELECT price_c INTO :lr_hebe FROM item WHERE item_no = :ls_assy AND qa = :ls_assyqa;
		if isnull(lr_hebe) then	lr_hebe = 0
			
		choose case trim(ls_uom)
			case 'M'
				 lr_len = real(long(MidA(ls_assyqa,15,5)) / 1000.0)
				 dwtarget.object.hebe[ll_row] = lr_len * lr_hebe * lr_qty
			case else
				 dwtarget.object.hebe[ll_row] = lr_hebe * lr_qty
		end choose
	end if
next

MessageBox("확인","작업일보를 작성 하였습니다.",information!)
dwsource.selectrow(0,false)
tab_1.selecttab(2)
dwtarget.scrolltorow(ll_first)

end event

