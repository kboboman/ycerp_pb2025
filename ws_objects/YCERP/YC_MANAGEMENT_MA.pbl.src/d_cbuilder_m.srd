table(column=(type=long update=yes updatewhereclause=yes key=yes identity=yes name=id dbname="make_manager.id" )
 column=(type=char(100) update=yes updatewhereclause=yes name=site_name dbname="make_manager.site_name" )
 column=(type=char(100) update=yes updatewhereclause=yes name=site_address dbname="make_manager.site_address" )
 column=(type=char(8) update=yes updatewhereclause=yes name=work_fr_gigan_date dbname="make_manager.work_fr_gigan_date" )
 column=(type=char(8) update=yes updatewhereclause=yes name=work_to_gigan_date dbname="make_manager.work_to_gigan_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=salesman dbname="make_manager.salesman" )
 column=(type=char(60) update=yes updatewhereclause=yes name=company_name dbname="make_manager.company_name" )
 column=(type=char(60) update=yes updatewhereclause=yes name=builder_name dbname="make_manager.builder_name" )
 column=(type=char(60) update=yes updatewhereclause=yes name=keyman dbname="make_manager.keyman" )
 column=(type=char(20) update=yes updatewhereclause=yes name=grade dbname="make_manager.grade" )
 column=(type=char(40) update=yes updatewhereclause=yes name=kind dbname="make_manager.kind" )
 column=(type=char(1) update=yes updatewhereclause=yes name=gubun dbname="make_manager.gubun" values="입찰	1/견적	2/" )
 column=(type=char(100) update=yes updatewhereclause=yes name=work_value dbname="make_manager.work_value" )
 column=(type=long update=yes updatewhereclause=yes name=work_area dbname="make_manager.work_area" )
 column=(type=char(100) update=yes updatewhereclause=yes name=special_note dbname="make_manager.special_note" )
 column=(type=char(8) update=yes updatewhereclause=yes name=order_date dbname="make_manager.order_date" )
 column=(type=char(100) update=yes updatewhereclause=yes name=attend_name dbname="make_manager.attend_name" )
 column=(type=char(100) update=yes updatewhereclause=yes name=attend_company_name dbname="make_manager.attend_company_name" )
 column=(type=char(8) update=yes updatewhereclause=yes name=tender_date dbname="make_manager.tender_date" )
 column=(type=char(1) update=yes updatewhereclause=yes name=tender_type dbname="make_manager.tender_type" values="전자입찰	1/off입찰	2/" )
 column=(type=long update=yes updatewhereclause=yes name=estimation_amt dbname="make_manager.estimation_amt" )
 column=(type=char(100) update=yes updatewhereclause=yes name=success_company dbname="make_manager.success_company" )
 column=(type=long update=yes updatewhereclause=yes name=success_amt dbname="make_manager.success_amt" )
 column=(type=long update=yes updatewhereclause=yes name=rank dbname="make_manager.rank" )
 column=(type=char(100) update=yes updatewhereclause=yes name=fail_reason dbname="make_manager.fail_reason" )
 column=(type=char(1) update=yes updatewhereclause=yes name=result dbname="make_manager.result" values="공사	1/자재	2/해당없음	3/" )
 column=(type=char(8) update=yes updatewhereclause=yes name=write_date dbname="make_manager.write_date" )
 retrieve="select id,
		site_name,
		site_address,
		work_fr_gigan_date,
		work_to_gigan_date,
		salesman,
		company_name,
		builder_name,
		keyman,
		grade,
		kind,
		gubun,
		work_value,
          work_area,
		special_note,
		order_date,
		attend_name,
		attend_company_name,
		tender_date,
		tender_type,
		estimation_amt,
		success_company,
		success_amt,
		rank,
		fail_reason,
		result,
          write_date
from make_manager
where id = :arg_id
" update="make_manager" updatewhere=0 updatekeyinplace=no arguments=(("arg_id", number)) )
