$PBExportComments$월 매입확정(2001/12/26,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=char(12) update=yes updatewhereclause=yes key=yes name=apoiinv_apoiinv_no dbname="apoiinv.apoiinv_no" )
 column=(type=datetime updatewhereclause=yes name=apoiinv_oi_date dbname="apoiinv.oi_date" )
 column=(type=decimal(4) updatewhereclause=yes name=apoiinv_apoiinv_cash dbname="apoiinv_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=apoiinv_apoiinv_rate dbname="apoiinv.apoiinv_rate" )
 column=(type=char(1) updatewhereclause=yes name=apoiinv_printed dbname="apoiinv.printed" values="	Y/	N" )
 column=(type=char(40) update=yes updatewhereclause=yes name=apoiinv_rem dbname="apoiinv.rem" )
 column=(type=decimal(0) updatewhereclause=yes name=apoiinv_dc dbname="apoiinv.dc" )
 column=(type=decimal(0) updatewhereclause=yes name=apoiinv_dc_rate dbname="apoiinv.dc_rate" )
 column=(type=char(1) update=yes updatewhereclause=yes name=apoiinv_open_close dbname="apoiinv.open_close" values="	S/	O" )
 column=(type=char(10) update=yes updatewhereclause=yes name=apoiinv_confirm_user dbname="apoiinv.confirm_user" )
 column=(type=char(1) updatewhereclause=yes name=pur_flag dbname="apoiinv.pur_flag" )
 column=(type=char(1) updatewhereclause=yes name=chk_user dbname="chk_user" values="	Y/	N" )
 column=(type=char(10) update=yes updatewhereclause=yes name=apoiinv_top_user dbname="apoiinv.top_user" )
 column=(type=char(30) updatewhereclause=yes name=supp_supp_name dbname="supp.supp_name" )
 column=(type=char(13) updatewhereclause=yes name=yymm dbname="yymm" )
 retrieve="  SELECT apoiinv.apoiinv_no                                 
       , apoiinv.oi_date                                    
       , apoiinv_cash = apoiinv.apoiinv_cash - apoiinv.dc   
       , apoiinv.apoiinv_rate                               
       , apoiinv.printed                                    
       , apoiinv.rem                                        
       , apoiinv.dc                                         
       , apoiinv.dc_rate                                   
       , apoiinv.open_close                              
       , apoiinv.confirm_user                            
       , apoiinv.pur_flag                                
       , chk_user     = (case when apoiinv.top_user is null OR apoiinv.top_user = '' then 'N' else 'Y' end)
       , apoiinv.top_user                                
       , supp.supp_name                                  
       , yymm         = cast(datepart(year,:ad_sdate) as char(4)) + ' 년 ' + cast(datepart(month,:ad_sdate) as char(2)) + ' 월'
    FROM apoiinv
       , supp  
   WHERE ( oi_date  between :ad_sdate AND :ad_edate    ) 
     AND ( apoiinv.supp_no              = supp.supp_no ) 
     AND ( apoiinv.inv_area             = :as_area     ) 
     AND ( apoiinv.delete_flag         <> 'Y'          ) 
     AND ( apoiinv.open_close           = :as_con      ) 

" update="apoiinv" updatewhere=0 updatekeyinplace=yes arguments=(("ad_sdate", date),("ad_edate", date),("as_con", string),("as_area", string))  sort="pur_flag A supp_supp_name A " )
group(level=1 header.height=68 trailer.height=68 by=("pur_flag" ) header.color="12639424" trailer.color="12639424" )
