table(column=(type=char(10) updatewhereclause=yes name=item_no dbname="saledet.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="saledet.qa" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="GroupItem.item_name" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="GroupItem.uom" )
 column=(type=decimal(4) updatewhereclause=yes name=qoh dbname="qoh" )
 column=(type=char(14) updatewhereclause=yes name=order_no dbname="saledet.order_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="saledet.seq_no" )
 column=(type=char(50) updatewhereclause=yes name=saledet_rem dbname="saledet.rem" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=decimal(2) updatewhereclause=yes name=saledetqty dbname="saledetqty" )
 column=(type=decimal(4) updatewhereclause=yes name=pur_qty dbname="pur_qty" )
 column=(type=char(4) updatewhereclause=yes name=color dbname="color" )
 retrieve="  SELECT saledet.item_no                  
       , saledet.qa                       
       , groupitem.item_name              
       , groupitem.uom                    
       , qoh        = isnull(itemloc.qoh, 0)  
       , saledet.order_no                 
       , saledet.seq_no                
       , saledet.rem                   
       , customer.cust_name               
       , saledetqty = saledet.order_qty
       , pur_qty    = isnull(sum(purdet.order_qty), 0 )
       , color      = saledet.color
    FROM saledet WITH(NOLOCK) 
                                     inner join  sale WITH(NOLOCK) on saledet.order_no  = sale.order_no
                                                                                                       AND  sale.open_close        = 'O'  
                                                                                                      AND sale.confirm_flag     IN ('T', 'Y')
                                                                                                      AND ( sale.order_no    LIKE :as_order   )  
                                     inner join customer WITH(NOLOCK) on sale.cust_no           = customer.cust_no      
                                     inner join  groupitem WITH(NOLOCK)  on saledet.item_no = groupitem.item_no                                     
                                     left outer join purdet WITH(NOLOCK) on saledet.order_no  = purdet.sale_no    AND  saledet.seq_no  = purdet.sale_seq  
                                     left outer join  itemloc  WITH(NOLOCK)   on saledet.item_no  = itemloc.item_no and saledet.qa   = itemloc.qa
                                                                                           and itemloc.loc_no  = :as_loc
   
   GROUP BY saledet.item_no    
       , saledet.qa            
       , groupitem.item_name   
       , groupitem.uom         
       , qoh                
       , saledet.order_no      
       , saledet.seq_no     
       , saledet.rem        
       , customer.cust_name    
       , saledet.order_qty
       , saledet.color
/*
    FROM saledet  
       , groupitem   
       , itemloc     
       , sale     
       , customer 
       , purdet
   WHERE ( saledet.order_no    LIKE :as_order         )  
     AND ( saledet.item_no        = groupitem.item_no ) 
     AND ( saledet.item_no       *= itemloc.item_no   )   
     AND ( saledet.qa            *= itemloc.qa        )   
     AND ( itemloc.loc_no         = :as_loc           ) 
     AND ( saledet.order_no       = sale.order_no     )   
     AND ( saledet.order_no      *= purdet.sale_no    )   
     AND ( saledet.seq_no        *= purdet.sale_seq   )   
     AND ( sale.cust_no           = customer.cust_no  )   
     AND ( sale.open_close        = 'O'               )
     AND ( sale.confirm_flag     IN ('T', 'Y')        )
   GROUP BY saledet.item_no    
       , saledet.qa            
       , groupitem.item_name   
       , groupitem.uom         
       , qoh                
       , saledet.order_no      
       , saledet.seq_no     
       , saledet.rem        
       , customer.cust_name    
       , saledet.order_qty
       , saledet.color
*/" arguments=(("as_loc", string),("as_order", string))  sort="item_name A qa A " )
