 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"item~" ) COLUMN(NAME=~"item.item_no~") COLUMN(NAME=~"item.qa~") COLUMN(NAME=~"item.loc_no~") COLUMN(NAME=~"item.item_name~") COLUMN(NAME=~"item.product_group~") COLUMN(NAME=~"item.uom~") COLUMN(NAME=~"item.source~") COLUMN(NAME=~"item.leadtime~") COLUMN(NAME=~"item.count_code~") COLUMN(NAME=~"item.qoh~") COLUMN(NAME=~"item.sales_reserved~") COLUMN(NAME=~"item.prodn_reserved~") COLUMN(NAME=~"item.pur_reserved~") COLUMN(NAME=~"item.item_wc~") COLUMN(NAME=~"item.supplier~") COLUMN(NAME=~"item.reorder~") COLUMN(NAME=~"item.safety_stock~") COLUMN(NAME=~"item.lot~") COLUMN(NAME=~"item.obsolete_code~") COLUMN(NAME=~"item.scrap_qty~") COLUMN(NAME=~"item.price_a~") COLUMN(NAME=~"item.price_b~") COLUMN(NAME=~"item.price_c~") COLUMN(NAME=~"item.std_setup~") COLUMN(NAME=~"item.std_material~") COLUMN(NAME=~"item.std_labor~") COLUMN(NAME=~"item.std_burden~") COLUMN(NAME=~"item.std_subcontract~") COLUMN(NAME=~"item.std_machine~") COLUMN(NAME=~"item.heft~") COLUMN(NAME=~"item.volume~") COLUMN(NAME=~"item.rem~") COLUMN(NAME=~"item.target_item~") COLUMN(NAME=~"item.target_qa~") COLUMN(NAME=~"item.last_tran_date~") COLUMN(NAME=~"item.month_qty~") COLUMN(NAME=~"item.safety_day~") COLUMN(NAME=~"item.qa1~") COLUMN(NAME=~"item.pat_no~")WHERE(    EXP1 =~"item.item_no~"   OP =~"=~"    EXP2 =~":as_item~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"item.qa~"   OP =~"=~"    EXP2 =~":as_qa~" ) ) ARG(NAME = ~"as_item~" TYPE = string)  ARG(NAME = ~"as_qa~" TYPE = string) " update="item" updatewhere=0 updatekeyinplace=yes arguments=(("as_item", string),("as_qa", string)) )
