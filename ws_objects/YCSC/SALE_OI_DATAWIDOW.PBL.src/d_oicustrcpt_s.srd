$PBExportHeader$d_oicustrcpt_s.srd
$PBExportComments$반품매출확인관리반품번호선택(2000/05/08,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=79219928 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=72 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes key=yes name=order_no dbname="ret.ret_no" )
 column=(type=char(14) updatewhereclause=yes name=sale_no dbname="ret.sale_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=process_flag dbname="ret.process_flag" values="	Y/	S" )
 column=(type=datetime updatewhereclause=yes name=ret_date dbname="ret.ret_date" )
 column=(type=char(14) update=yes updatewhereclause=yes name=do_no dbname="ret.do_no" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="ret.cust_no" )
 column=(type=char(11) updatewhereclause=yes name=spot_code dbname="ret.spot_code" )
 column=(type=char(10) updatewhereclause=yes name=ret_rcpt_area dbname="ret.rcpt_area" )
 retrieve="  SELECT ret.ret_no,   
         ret.sale_no,   
         ret.process_flag,   
         ret.ret_date,   
         ret.do_no,   
         customer.cust_name,   
         scene.scene_desc,   
         ret.cust_no,   
         ret.spot_code,   
         ret.rcpt_area  
	FROM ret inner join customer on ret.cust_no         = customer.cust_no
				  left outer join scene on ret.spot_code  = scene.scene_code and ret.cust_no = scene.cust_no				  
     WHERE  ( ret.process_flag   IN (:as_flag, 'P')  )    
" update="ret" updatewhere=0 updatekeyinplace=no arguments=(("as_flag", string))  sort="order_no A " )
