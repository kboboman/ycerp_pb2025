compute(band=footer alignment="1" expression="sum( apoiinv_apoiinv_cash - apoiinv_dc  for all)"border="0" color="0" x="699" y="4" height="60" width="430" format="#,##0" html.valueishtml="0"  name=compute_2 visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
