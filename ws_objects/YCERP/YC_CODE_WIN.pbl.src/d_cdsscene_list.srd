table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=scene_code dbname="SScene.scene_code" )
 column=(type=char(40) update=yes updatewhereclause=yes name=scene_desc dbname="SScene.scene_desc" )
 column=(type=long updatewhereclause=yes name=cnt dbname="cnt" )
 column=(type=char(50) update=yes updatewhereclause=yes name=scene_use dbname="scene_use" )
 column=(type=char(40) update=yes updatewhereclause=yes name=scene_scale dbname="SScene.scene_scale" )
 column=(type=char(50) update=yes updatewhereclause=yes name=scene_order dbname="SScene.scene_order" )
 column=(type=char(50) update=yes updatewhereclause=yes name=scene_plan dbname="SScene.scene_plan" )
 column=(type=char(50) update=yes updatewhereclause=yes name=scene_inspect dbname="SScene.scene_inspect" )
 column=(type=datetime updatewhereclause=yes name=construct_time1 dbname="SScene.construct_time1" )
 column=(type=datetime updatewhereclause=yes name=construct_time2 dbname="SScene.construct_time2" )
 column=(type=char(10) updatewhereclause=yes name=site_zip dbname="SScene.site_zip" )
 column=(type=char(80) updatewhereclause=yes name=site_address dbname="SScene.site_address" )
 column=(type=char(255) updatewhereclause=yes name=scenedesc dbname="scenedesc" )
 retrieve="  SELECT SScene.scene_code   
       , SScene.scene_desc   
       , cnt       = (SELECT count(*) FROM SSceneHIS WHERE SSceneHIS.scene_code = SScene.scene_code)
       , scene_use = a.item_nm   
       , SScene.scene_scale   
       , SScene.scene_order   
       , SScene.scene_plan   
       , SScene.scene_inspect   
       , SScene.construct_time1   
       , SScene.construct_time2  
       , SScene.site_zip   
       , SScene.site_address   
       , scenedesc = replace(Upper(SScene.scene_desc), ' ', '')
    FROM SScene
         LEFT OUTER JOIN (
              SELECT item_cd, item_nm FROM codemst WHERE type = '선행영업_용도' AND use_yn = 'Y'
         ) A ON SScene.scene_use = A.item_cd
" update="SScene" updatewhere=1 updatekeyinplace=no  sort="scene_code D " )
