 column=(type=decimal(4) updatewhereclause=yes name=price_c dbname="item.price_c" )
 column=(type=decimal(4) updatewhereclause=yes name=month_qty dbname="item.month_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=safety_day dbname="item.safety_day" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"item~" ) COLUMN(NAME=~"item.item_no~") COLUMN(NAME=~"item.qa~") COLUMN(NAME=~"item.item_name~") COLUMN(NAME=~"item.uom~") COLUMN(NAME=~"item.qoh~") COLUMN(NAME=~"item.pur_reserved~") COLUMN(NAME=~"item.reorder~") COLUMN(NAME=~"item.safety_stock~") COLUMN(NAME=~"item.lot~") COLUMN(NAME=~"item.price_a~") COLUMN(NAME=~"item.price_b~") COLUMN(NAME=~"item.price_c~") COLUMN(NAME=~"item.month_qty~") COLUMN(NAME=~"item.safety_day~")WHERE(    EXP1 =~"item.source~"   OP =~"=~"    EXP2 =~"'B'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"item.reorder~"   OP =~">~"    EXP2 =~"item.qoh + item.pur_reserved~" ) ) ORDER(NAME=~"item.item_no~" ASC=yes )  ORDER(NAME=~"item.qa~" ASC=yes ) " update="item" updatewhere=0 updatekeyinplace=no )
