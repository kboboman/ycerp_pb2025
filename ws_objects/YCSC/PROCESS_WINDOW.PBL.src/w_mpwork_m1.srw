type pb_alltime from picturebutton within tabpage_6
integer x = 27
integer y = 24
integer width = 864
integer height = 96
integer taborder = 110
integer textsize = -10
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "조업시간 산출"
boolean originalsize = true
vtextalign vtextalign = vcenter!
end type

event clicked;//
real   lr_alltime, lr_chktime
long   ll_row
string ls_areano, ls_sfcdate, ls_wcno

ls_areano  = dw_area.object.area[1]
ls_sfcdate = string(id_date,"yyyy/mm/dd")
ls_wcno    = dw_2.object.wc_no[1]

ll_row = dw11.rowcount()
if ll_row > 1 then return


if ls_areano = "" or isnull(ls_areano) or ls_sfcdate = "" or isnull(ls_sfcdate) or &
   ls_wcno = ""   or isnull(ls_wcno) then
	MessageBox("확인", ls_sfcdate + "일 작업장, 작업일자를 선택하시기 바랍니다." ,exclamation!)
	return
end if


SELECT ALL_TIME = MAX(A.TIME1) + MAX(A.TIME2) + MAX(A.TIME3) INTO :lr_alltime
  FROM SFCDAYMAN A                                             
 WHERE A.AREA_NO       = :ls_areano                    
	AND CONVERT(CHAR(10), A.SFC_DATE,111)  = :ls_sfcdate
	AND A.WC_NO         = :ls_wcno                      
 GROUP BY AREA_NO, SFC_DATE, WC_NO;

INSERT INTO SFCDAYWORK (AREA_NO, SFC_DATE, WC_NO, ALL_TIME)
VALUES ( :ls_areano, :id_date, :ls_wcno, :lr_alltime );
if sqlca.sqlcode < 0 then
	rollback;
	MessageBox("확인", ls_sfcdate + "일 조업시간 산출에서 오류가 발생하였습니다." ,exclamation!)
else
	commit;
end if		

dw11.retrieve(dw_area.object.area[1], string(id_date,"yyyy/mm/dd"), dw_2.object.wc_no[1])


//lr_chktime = dw11.object.all_time[1]
//if isnull(lr_chktime) then lr_chktime = 0
//
//if lr_chktime <> lr_alltime then
//	//if MessageBox("확인", ls_sfcdate + "일 조업시간이 작업자 투입과 일치하지 않습니다.~n~n" + &
//	//              "작업자 투입시간 집계값을 반영합니까?", Exclamation!, OKCancel!, 1) = 1 then
//		dw11.object.all_time[1] = lr_alltime
//	//end if
//end if

end event

