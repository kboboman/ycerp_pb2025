 retrieve="  SELECT docar.driver
       , docar.name
       , docar.cargo_name
       , docar.inout
       , docar.rem
       , docar.hp
       , docar.open_close
       , docar.icube_no  
       , docar.car_company
       , docar.car_kind
       , docar.sys_date
    FROM docar   
" update="docar" updatewhere=1 updatekeyinplace=no  sort="open_close D driver A " )
