table(column=(type=char(10) updatewhereclause=yes name=item_no dbname="groupitem.item_no" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="groupitem.uom" )
 column=(type=char(1) updatewhereclause=yes name=source dbname="groupitem.source" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="groupitem.item_name" )
 retrieve="  SELECT groupitem.item_no,   
         groupitem.uom,   
         groupitem.source,   
         groupitem.item_name  
    FROM groupitem  
   WHERE groupitem.use_flag <> 'C'    
"  sort="item_name A " )
