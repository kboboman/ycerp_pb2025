$PBExportHeader$d_oisaledo_r1.srd
$PBExportComments$영업사원별 출고현황(운반비+)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="79741120" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="553648127" )
table(column=(type=char(10) updatewhereclause=yes name=user_name dbname="login.user_name" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="do.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=char(11) updatewhereclause=yes name=do_spot_code dbname="do.spot_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 column=(type=datetime updatewhereclause=yes name=do_do_date dbname="do.do_date" )
 column=(type=char(12) updatewhereclause=yes name=do_inv_no dbname="do.inv_no" )
 column=(type=char(30) updatewhereclause=yes name=do_ship_flag dbname="ship_flag" values="착불	C/대여	D/부담	B/방문	M/" )
 column=(type=char(1) updatewhereclause=yes name=ship_flag2 dbname="ship_flag2" )
 column=(type=decimal(0) updatewhereclause=yes name=do_ship_amount dbname="do.ship_amount" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_rate dbname="do.do_rate" )
 column=(type=char(3) updatewhereclause=yes name=do_curr_code dbname="do.curr_code" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_cash dbname="do.do_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_total dbname="do.do_total" )
 column=(type=char(1) updatewhereclause=yes name=do_shipamt_case dbname="do.shipamt_case" )
 column=(type=char(14) updatewhereclause=yes name=do_do_no dbname="do.do_no" )
 column=(type=long updatewhereclause=yes name=dodet_oi_no dbname="dodet.oi_no" )
 column=(type=char(10) updatewhereclause=yes name=dodet_item_no dbname="dodet.item_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(20) updatewhereclause=yes name=dodet_qa dbname="dodet.qa" )
 column=(type=char(2) updatewhereclause=yes name=dodet_uom dbname="dodet.uom" )
 column=(type=decimal(2) updatewhereclause=yes name=dodet_ship_qty dbname="dodet.ship_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=dodet_price dbname="dodet.price" )
 column=(type=decimal(4) updatewhereclause=yes name=dodet_rate_cash dbname="dodet.rate_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=c_acc_qty dbname="c_acc_qty" )
 column=(type=char(1) updatewhereclause=yes name=round dbname="customer.round" )
 column=(type=char(14) updatewhereclause=yes name=dodet_sale_no dbname="dodet.sale_no" )
 column=(type=datetime updatewhereclause=yes name=do_prt_date dbname="do.prt_date" )
 column=(type=datetime updatewhereclause=yes name=do_issue_date dbname="do.issue_date" )
 column=(type=datetime updatewhereclause=yes name=do_ship_date dbname="do.ship_date" )
 column=(type=long updatewhereclause=yes name=datecalc dbname="datecalc" )
 retrieve="  SELECT login.user_name
       , do.cust_no        
       , customer.cust_name   
       , do.spot_code   
       , scene.scene_desc   
       , do.do_date     
       , do.inv_no         
       , ship_flag  = dbo.uf_getshipflag(do.ship_flag)
       , ship_flag2 = do.ship_flag
       , do.ship_amount
       , do.do_rate        
       , do.curr_code      
       , do.do_cash        
       , do.do_total       
       , do.shipamt_case   
       , do.do_no       
       , dodet.oi_no     
       , dodet.item_no   
       , groupitem.item_name
       , dodet.qa    
       , dodet.uom   
       , dodet.ship_qty   
       , dodet.price   
       , dodet.rate_cash
       , c_acc_qty = round(dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty),2,1)
       , customer.round
       , dodet.sale_no
       , do.prt_date
       , do.issue_date
       , do.ship_date
       , datecalc    = DATEDIFF(month, do.issue_date, do.do_date) 
FROM  do with(nolock) inner join dodet with(nolock) on do.do_no = dodet.do_no 
					          	   inner join groupitem with(nolock)  on dodet.item_no = groupitem.item_no
						        inner join customer with(nolock)  on do.cust_no = customer.cust_no
                                       inner join login with(nolock) on  customer.salesman = login.user_id
                                       left outer join scene  with(nolock) on do.cust_no = scene.cust_no and do.spot_code = scene.scene_code
where ( do.sale_flag         IN ( :as_saleflag )  )  
     and ( do.do_date      BETWEEN :as_sdate  and :as_edate )
     and ( do.do_no           LIKE :as_area          )
     and ((customer.salesman  LIKE :as_salesman ) OR 
          (:as_team = 'T' AND customer.salesman  IN ( SELECT login.user_id  FROM login, team 
                                                       WHERE login.team_code   = team.team_code  AND team_manager = :as_salesman) )
         )
" arguments=(("as_saleflag", stringlist),("as_sdate", string),("as_edate", string),("as_salesman", string),("as_area", string),("as_team", string))  sort="cust_no A do_spot_code A do_do_date A do_do_no A dodet_oi_no A " )
group(level=1 header.height=0 trailer.height=80 by=("cust_no" ) header.color="553648127" trailer.color="15780518" )
group(level=2 header.height=0 trailer.height=80 by=("do_do_no" ) header.color="536870912" trailer.color="12639424" )
