release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=584 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=68 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="item.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="item.qa" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="item.uom" )
 column=(type=char(1) update=yes updatewhereclause=yes name=source dbname="item.source" values="완제품	W/반제품	M/구매품	B/" )
 column=(type=char(5) update=yes updatewhereclause=yes name=count_code dbname="item.count_code" values="주간단위	W/보름단위	H/매월단위	M/격월단위	G/분가단위	B/6개월단위	S/년단위	Y/" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=lot dbname="item.lot" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=leadtime dbname="item.leadtime" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=reorder dbname="item.reorder" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=safety_stock dbname="item.safety_stock" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=price_a dbname="item.price_a" )
 column=(type=char(30) updatewhereclause=yes name=location_loc_name dbname="location.loc_name" )
 column=(type=char(60) update=yes updatewhereclause=yes name=item_name dbname="item.item_name" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"item~" )  TABLE(NAME=~"location~" ) COLUMN(NAME=~"item.item_no~") COLUMN(NAME=~"item.qa~") COLUMN(NAME=~"item.uom~") COLUMN(NAME=~"item.source~") COLUMN(NAME=~"item.count_code~") COLUMN(NAME=~"item.lot~") COLUMN(NAME=~"item.leadtime~") COLUMN(NAME=~"item.reorder~") COLUMN(NAME=~"item.safety_stock~") COLUMN(NAME=~"item.price_a~") COLUMN(NAME=~"location.loc_name~") COLUMN(NAME=~"item.item_name~")    JOIN (LEFT=~"item.loc_no~"    OP =~"=~"RIGHT=~"location.loc_no~" )) " )
