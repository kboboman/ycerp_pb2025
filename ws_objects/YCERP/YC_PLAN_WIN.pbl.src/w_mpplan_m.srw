fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
long textcolor = 33554432
long backcolor = 67108864
string text = "파일보기"
end type

event clicked;// 
Blob    lb_picture, lb_pictemp
string  ls_filepath, ls_nullarray[], ls_orderno, ls_filename, ls_ext, ls_null
integer li_rtn, li_i, li_cnt, li_loop, i, li_filenum
long    ll_filelen

setnull( ls_null )
ls_orderno  = dw6.object.sale_no[dw6.getrow()]

SELECT filename INTO :ls_filename FROM SalePIC WHERE order_no = :ls_orderno;
ls_ext = Lower(RightA(ls_filename,3)) 

if ls_orderno <> "" then	
	if ls_ext <> "pdf" then
		OpenWithParm( w_orderno_pic, ls_orderno)
		this.checked = false
	else		
		SELECTBLOB filebin INTO :lb_picture FROM SalePIC WHERE SalePIC.order_no = :ls_orderno;
		
		ll_filelen = LenA(lb_picture)
		if ll_filelen > 32765 then
			if mod(ll_filelen,32765) = 0 then
				li_loop = ll_filelen / 32765
			else
				li_loop = (ll_filelen/32765) + 1
			end if
		else
			li_loop = 1
		end if
                                                   
		li_rtn = GetFileSaveName( "Select File", is_path, is_file, "pdf","Portable Documents File, *.pdf")
		if li_rtn = 1 then
			li_filenum = FileOpen(is_path, StreamMode!, Write!, Shared!, Append!)
	
			for i = 1 to li_loop
				if i = li_loop then
					lb_pictemp = BlobMid(lb_picture, (i - 1) * 32765 + 1)
				else
					lb_pictemp = BlobMid(lb_picture, (i - 1) * 32765 + 1,32765)
				end if
				FileWrite(li_filenum, lb_pictemp)
			next
			Fileclose(li_filenum)
	
			ls_filename = is_path 
			li_rtn = ShellExecuteA(0, "open", ls_filename, "", "", 10)
			if li_rtn <= 32 then
				Run("rundll32.exe shell32.dll,OpenAs_RunDLL " + ls_filename )   // 연결프로그램 팝업창을 OPEN
			end if
		end if
		this.checked = false
	end if
end if
end event

