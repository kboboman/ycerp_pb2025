$PBExportHeader$d_plan_project1.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=72 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=88 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=long updatewhereclause=yes name=plan_year dbname="plan_year" )
 column=(type=long updatewhereclause=yes name=plan_month dbname="plan_month" )
 column=(type=long updatewhereclause=yes name=plan_day dbname="plan_day" )
 column=(type=decimal(4) updatewhereclause=yes name=plan_qty dbname="plan_qty" )
 retrieve="  SELECT cust_no    = plan_project.cust_no
       , cust_name  = c.cust_name
       , item_no    = plan_project.item_no
       , plan_year  = Year(plan_project.plan_date)
       , plan_month = Month(plan_project.plan_date)
       , plan_day   = Day(plan_project.plan_date)
       , plan_qty   = plan_project.plan_qty  
    FROM plan_project 
         LEFT OUTER JOIN customer  C ON plan_project.cust_no = c.cust_no
   WHERE plan_project.plan_date between :ad_sdate AND :ad_edate
" arguments=(("ad_sdate", datetime),("ad_edate", datetime)) )
