table(column=(type=long updatewhereclause=yes name=year dbname="YEAR" )
 column=(type=decimal(6) updatewhereclause=yes name=inv01_1 dbname="INV01_1" )
 column=(type=decimal(6) updatewhereclause=yes name=inv01_2 dbname="INV01_2" )
