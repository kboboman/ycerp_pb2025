 column=(type=char(1) updatewhereclause=yes name=pop_status dbname="mpsdet.pop_status" values="pop연동전	1/pop연동완료	2/pop반송	3/" )
 column=(type=char(1) updatewhereclause=yes name=pop_status_protect dbname="mpsdet.pop_status_protect" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 retrieve="  SELECT mpsdet.plan_no,   
         mpsdet.order_no,   
         mpsdet.item_no,   
         mpsdet.uom,   
         mpsdet.order_qty,   
         mpsdet.due_date,   
         mpsdet.priority,   
         mpsdet.qa,   
         mpsdet.wc_no,   
         mpsdet.sale_no,   
         mpsdet.seq_no,   
         mpsdet.suju_type,   
         mpsdet.work_time,   
         mpsdet.setup_time,   
         mpsdet.rcpt_type,   
         mpsdet.rcpt_qty,   
         mpsdet.napgi_date,   
         mpsdet.item_color,   
         mpsdet.cust_no,   
         mpsdet.scene_code,   
         mpsdet.work_per,   
         mpsdet.division,   
         mpsdet.operation,   
	    mpsdet.pop_status,
	    mpsdet.pop_status pop_status_protect,
         groupitem.item_name,   
         customer.cust_name,   
         scene.scene_desc  
    FROM mpsdet with(nolock)
         LEFT OUTER JOIN groupitem with(nolock) ON mpsdet.item_no = groupitem.item_no 
         LEFT OUTER JOIN customer with(nolock) ON mpsdet.cust_no = customer.cust_no 
         LEFT OUTER JOIN scene  with(nolock)   ON mpsdet.scene_code = scene.scene_code  
   WHERE mpsdet.order_no = :arg_order   
		AND isnull(customer.sale_control,'N') <> 'A'
   ORDER BY mpsdet.priority ASC   
" update="mpsdet" updatewhere=0 updatekeyinplace=no arguments=(("arg_order", string)) )
