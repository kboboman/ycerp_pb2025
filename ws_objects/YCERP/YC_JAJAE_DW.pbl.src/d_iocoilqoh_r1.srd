table(column=(type=char(20) updatewhereclause=yes key=yes name=coilmst_coil_no dbname="coil_no" )
 column=(type=decimal(1) updatewhereclause=yes name=coilmst_wid dbname="wid" )
 column=(type=char(10) updatewhereclause=yes name=coilmst_item_no dbname="item_no" )
 column=(type=char(20) updatewhereclause=yes name=coilmst_qa dbname="qa" )
 column=(type=char(10) updatewhereclause=yes key=yes name=coilmst_loc_no dbname="loc_no" )
 column=(type=datetime updatewhereclause=yes name=coilmst_rcpt_date dbname="rcpt_date" )
 column=(type=long updatewhereclause=yes name=coilmst_unit_qty dbname="unit_qty" )
 column=(type=long updatewhereclause=yes name=coilmst_length dbname="length" )
 column=(type=long updatewhereclause=yes name=coilmst_cnt dbname="cnt" )
 column=(type=long updatewhereclause=yes name=coilmst_qcnt dbname="qcnt" )
 column=(type=char(4) updatewhereclause=yes name=coilmst_color_no dbname="color_no" )
 column=(type=char(10) updatewhereclause=yes name=coilmst_supp_no dbname="supp_no" )
 column=(type=char(1) updatewhereclause=yes name=coilmst_flag dbname="flag" values="원코일	W/스리팅	S/" )
 column=(type=char(14) updatewhereclause=yes name=coilmst_porder_no dbname="porder_no" )
 column=(type=long updatewhereclause=yes name=coilmst_pseq_no dbname="pseq_no" )
 column=(type=char(1) updatewhereclause=yes name=coilmst_open_close dbname="open_close" values="재고	O/계획	M/작업지시	P/외주가공	S/사용완료	C/" )
 column=(type=char(40) updatewhereclause=yes name=coilmst_rem dbname="rem" )
 column=(type=char(1) update=yes updatewhereclause=yes name=long_stock_yn dbname="long_stock_yn" values="	Y/	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=use_yn dbname="use_yn" values="	Y/	N" )
 column=(type=char(20) updatewhereclause=yes name=pcoil_no dbname="pcoil_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=char(30) updatewhereclause=yes name=location_loc_name dbname="loc_name" )
 column=(type=char(30) updatewhereclause=yes name=supp_supp_name dbname="supp_name" )
 column=(type=char(2) updatewhereclause=yes name=coilmst_etc_no dbname="etc_no" )
 column=(type=decimal(4) updatewhereclause=yes name=inspdet_price dbname="price" )
 column=(type=decimal(4) updatewhereclause=yes name=inspdet_unit_qty dbname="inspdet_unit_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=inspdet_comqty dbname="comqty" )
 column=(type=char(3) updatewhereclause=yes name=coil_grp dbname="coil_grp" )
 column=(type=char(30) updatewhereclause=yes name=pcoil_supp_name dbname="pcoil_supp_name" )
 retrieve=" select	DISTINCT    a.coil_no   
			 , a.wid   
			 , a.item_no   
			 , a.qa   
			 , a.loc_no   
			 , a.rcpt_date   
			 , a.unit_qty   
			 , a.length   
			 , a.cnt   
			 , a.qcnt   
			 , a.color_no   
			 , a.supp_no   
			 , a.flag   
			 , a.porder_no   
			 , a.pseq_no   
			 , a.open_close   
			 , a.rem   
			 , a.long_stock_yn
			 , a.use_yn
		      , a.pcoil_no
			 , a.item_name   
			 , a.loc_name   
			 , a.supp_name   
			 , a.etc_no
			 , a.price 
			 , a.inspdet_unit_qty
			 , a.comqty
			 , a.coil_grp   
/*			 , b.supp_name pcoil_supp_name*/
			 , dbo.uf_pcoil_supp_name(a.coil_no) pcoil_supp_name
from 
(
		 SELECT coilmst.coil_no   
				 , coilmst.wid   
				 , coilmst.item_no   
				 , coilmst.qa   
				 , coilmst.loc_no   
				 , coilmst.rcpt_date   
				 , coilmst.unit_qty   
				 , coilmst.length   
				 , coilmst.cnt   
				 , coilmst.qcnt   
				 , coilmst.color_no   
				 , coilmst.supp_no   
				 , coilmst.flag   
				 , coilmst.porder_no   
				 , coilmst.pseq_no   
				 , coilmst.open_close   
				 , coilmst.rem   
			      , dbo.uf_pcoil_no(coilmst.coil_no) pcoil_no
				 , groupitem.item_name   
				 , location.loc_name   
				 , supp.supp_name   
				 , coilmst.etc_no
				 , inspdet.price 
				 , inspdet.comqty
				 , inspdet.unit_qty inspdet_unit_qty
				 , groupitem.coil_grp   
				 , coilmst.long_stock_yn
				 , coilmst.use_yn
		  FROM coilmst with(nolock)  
					INNER JOIN groupitem with(nolock) ON coilmst.item_no = groupitem.item_no
				     INNER JOIN (
											 SELECT A.LOC_NO, A.LOC_NAME
												  FROM
												  (
																SELECT :as_loc GUBUN, 'N' WORK_CHK, 'N' STOCK_CHK, LOC_NO, LOC_NAME FROM LOCATION
																WHERE RTRIM(LTRIM(LOC_NO)) LIKE :as_loc
																UNION ALL
																SELECT :as_loc GUBUN, 'Y' WORK_CHK, :as_stock_chk STOCK_CHK,  LOC_NO, LOC_NAME FROM LOCATION
																WHERE LOC_NO <> 'WW01'
																 AND RTRIM(LTRIM(LOC_NO)) LIKE :as_loc                          
																UNION ALL
																SELECT 'WW01' GUBUN, 'Y' WORK_CHK, :as_stock_chk STOCK_CHK,  LOC_NO, LOC_NAME FROM LOCATION
																WHERE LOC_NO = 'WW01'                
																UNION ALL
																SELECT 'WS00000000' GUBUN, 'Y' WORK_CHK, :as_stock_chk STOCK_CHK,  LOC_NO, LOC_NAME FROM LOCATION
																WHERE LOC_NO = 'WS00000000'                                                                  
																UNION ALL
																SELECT 'WW01' GUBUN, 'Y' WORK_CHK, :as_stock_chk STOCK_CHK, LOC_NO, LOC_NAME FROM LOCATION
																WHERE LOC_TYPE = 'W'
																UNION ALL
																SELECT 'WS00000000' GUBUN, 'Y' WORK_CHK, :as_stock_chk STOCK_CHK, LOC_NO, LOC_NAME FROM LOCATION
																WHERE LOC_TYPE = 'W'                                                     
																UNION ALL
																SELECT :as_loc GUBUN,  :as_work_chk  WORK_CHK, 'Y' STOCK_CHK,  LOC_NO, LOC_NAME FROM LOCATION
																WHERE LOC_NO <> 'WW01'
																 AND RTRIM(LTRIM(LOC_NO)) LIKE :as_loc                          
																UNION ALL
																SELECT 'WW01' GUBUN, :as_work_chk WORK_CHK, 'Y' STOCK_CHK,  LOC_NO, LOC_NAME FROM LOCATION
																WHERE LOC_NO = 'WW01'                
																UNION ALL
																SELECT 'WS00000000' GUBUN, :as_work_chk WORK_CHK, 'Y' STOCK_CHK,  LOC_NO, LOC_NAME FROM LOCATION
																WHERE LOC_NO = 'WS00000000'                                                                  
																UNION ALL
																SELECT 'WW01' GUBUN, :as_work_chk WORK_CHK, 'Y' STOCK_CHK,  LOC_NO, LOC_NAME FROM LOCATION
																WHERE LOC_NO = 'WS00000003'
																UNION ALL
																SELECT 'WS00000000' GUBUN, :as_work_chk WORK_CHK, 'Y' STOCK_CHK,  LOC_NO, LOC_NAME FROM LOCATION
																WHERE LOC_NO = 'WS00000003'                                                                  
												  ) A
												 WHERE A.GUBUN = :as_loc
														AND A.WORK_CHK = :as_work_chk
														AND A.STOCK_CHK = :as_stock_chk					  
					  				) location on coilmst.loc_no  = location.loc_no
					LEFT OUTER JOIN supp  with(nolock)    ON coilmst.supp_no = supp.supp_no
					LEFT OUTER JOIN inspdet with(nolock)  ON coilmst.coil_no = inspdet.coil_no AND coilmst.item_no = inspdet.item_no				
		     where ( RTRIM(LTRIM(coilmst.item_no)) LIKE :as_item ) 
			  AND ( coilmst.flag       LIKE :as_flag          )
			  AND ( coilmst.open_close   IN ( :as_oc ) )
			  AND ((:as_coil  = '%' AND groupitem.coil_grp LIKE :as_coil ) OR
					 (:as_coil <> '%' AND groupitem.coil_grp    = :as_coil )
					)
			  AND NOT EXISTS ( SELECT * FROM lossitem WHERE loss_item = coilmst.item_no )
 ) a left outer join (
						 select distinct a.loc_no, a.pcoil_no, a.supp_no, b.supp_name
						 from coilmst a with(nolock) inner join supp b with(nolock) on a.supp_no = b.supp_no
                           ) b on a.pcoil_no = b.pcoil_no and a.loc_no = b.loc_no
" update="coilmst" updatewhere=0 updatekeyinplace=no arguments=(("as_coil", string),("as_loc", string),("as_item", string),("as_flag", string),("as_oc", stringlist),("as_work_chk", string),("as_stock_chk", string))  sort="mid(coilmst_item_no,3,1) A coilmst_item_no A mid( coilmst_qa, 5, 6) A coilmst_unit_qty A coilmst_loc_no A " )
group(level=1 header.height=0 trailer.height=72 by=("mid(coilmst_item_no,3,1) + mid(coilmst_item_no,2,1)" ) header.color="536870912" trailer.color="15780518" )
group(level=2 header.height=0 trailer.height=72 by=("coilmst_item_no" ) header.color="536870912" trailer.color="12639424" )
group(level=3 header.height=0 trailer.height=68 by=("mid( coilmst_qa, 5, 6)" ) header.color="536870912" trailer.color="536870912" )
