table(column=(type=long update=yes updatewhereclause=yes key=yes identity=yes name=id dbname="OPEOM_IMWON_ORG.ID" )
 column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" )
 column=(type=long update=yes updatewhereclause=yes name=seq dbname="OPEOM_IMWON_ORG.seq" )
 column=(type=char(20) update=yes updatewhereclause=yes name=area dbname="OPEOM_IMWON_ORG.area" )
 column=(type=char(10) update=yes updatewhereclause=yes name=area_mgr dbname="OPEOM_IMWON_ORG.area_mgr" )
 column=(type=char(20) update=yes updatewhereclause=yes name=sector dbname="OPEOM_IMWON_ORG.sector" )
 column=(type=char(10) update=yes updatewhereclause=yes name=sector_mgr dbname="OPEOM_IMWON_ORG.sector_mgr" )
 column=(type=char(20) update=yes updatewhereclause=yes name=team dbname="OPEOM_IMWON_ORG.team" )
 column=(type=char(10) update=yes updatewhereclause=yes name=team_mgr dbname="OPEOM_IMWON_ORG.team_mgr" )
 column=(type=char(10) update=yes updatewhereclause=yes name=tbl_info dbname="OPEOM_IMWON_ORG.tbl_info" values="담당자	LOGIN/거래처	CUSTOMER/" )
 column=(type=char(10) update=yes updatewhereclause=yes name=user_id dbname="OPEOM_IMWON_ORG.user_id" )
 column=(type=char(20) update=yes updatewhereclause=yes name=user_name dbname="OPEOM_IMWON_ORG.user_name" )
 column=(type=char(10) update=yes updatewhereclause=yes name=rank dbname="OPEOM_IMWON_ORG.rank" )
 column=(type=char(50) update=yes updatewhereclause=yes name=bigo dbname="OPEOM_IMWON_ORG.bigo" )
 column=(type=long updatewhereclause=yes name=custcnt dbname="custcnt" )
 retrieve=" SELECT ID
      , chk   = 'N'
      , seq
      , area
      , area_mgr
      , sector
      , sector_mgr
      , team
      , team_mgr
      , tbl_info
      , user_id
      , user_name
      , rank
      , bigo
      , custcnt  = (case when user_id = 'insite' 
                              then ( SELECT count(*) FROM codemst WHERE type = '내부업체' AND use_yn ='Y' )
                         else ( SELECT count(*) FROM customer C WHERE c.IMWON_USER_ID = OPEOM_IMWON_ORG.user_id AND c.open_close = 'O' )
                    end)
   FROM OPEOM_IMWON_ORG
" update="OPEOM_IMWON_ORG" updatewhere=0 updatekeyinplace=no  sort="seq A " )
