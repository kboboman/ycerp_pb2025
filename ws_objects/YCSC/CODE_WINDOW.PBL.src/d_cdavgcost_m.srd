footer(height=88 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" values="	Y/	N" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="item_no" )
 column=(type=char(60) update=yes updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(1) update=yes updatewhereclause=yes name=use_yn dbname="use_yn" values="사용	Y/불가	N/" )
 column=(type=char(10) update=yes updatewhereclause=yes name=user_id dbname="user_id" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=datetime update=yes updatewhereclause=yes name=sys_date dbname="sys_date" )
 retrieve="  SELECT chk        = 'N'
       , item_no    = avgcost.item_no
       , item_name  = g.item_name
       , use_yn     = avgcost.use_yn
       , user_id    = avgcost.user_id
       , user_name  = l.user_name
       , sys_date   = avgcost.sys_date
    FROM avgcost   
         LEFT OUTER JOIN groupitem G ON avgcost.item_no = g.item_no
         LEFT OUTER JOIN login     L ON avgcost.user_id = l.user_id
" update="avgcost" updatewhere=0 updatekeyinplace=no  sort="use_yn D item_name A " )
