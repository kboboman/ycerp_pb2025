table(column=(type=char(17) updatewhereclause=yes name=mpsdet_plan_no dbname="mpsdet.plan_no" )
 column=(type=char(17) updatewhereclause=yes name=order_no dbname="mpsdet.order_no" )
 column=(type=char(10) updatewhereclause=yes name=mpsdet_wc_no dbname="mpsdet.wc_no" )
 column=(type=char(14) updatewhereclause=yes name=mpsdet_sale_no dbname="mpsdet.sale_no" )
 column=(type=long updatewhereclause=yes name=mpsdet_priority dbname="mpsdet.priority" )
 column=(type=long updatewhereclause=yes name=mpsdet_priority dbname="mpsdet.seq_no" )
 column=(type=char(10) updatewhereclause=yes name=mpsdet_item_no dbname="mpsdet.item_no" )
 column=(type=char(20) updatewhereclause=yes name=mpsdet_qa dbname="mpsdet.qa" )
 column=(type=char(2) updatewhereclause=yes name=mpsdet_uom dbname="mpsdet.uom" )
 column=(type=decimal(4) updatewhereclause=yes name=mpsdet_order_qty dbname="mpsdet.order_qty" )
 column=(type=char(50) updatewhereclause=yes name=mpsdet_rem dbname="mpsdet.rem" )
 column=(type=datetime updatewhereclause=yes name=mps_start_date dbname="mps.start_date" )
 column=(type=char(80) updatewhereclause=yes name=sale_rem dbname="sale.rem" )
 column=(type=char(80) updatewhereclause=yes name=sale_rem1 dbname="sale.rem1" )
 column=(type=char(80) updatewhereclause=yes name=sale_rem2 dbname="sale.rem2" )
 column=(type=datetime updatewhereclause=yes name=sale_cust_po_date dbname="sale.cust_po_date" )
 column=(type=datetime updatewhereclause=yes name=sale_plan_date dbname="sale.plan_date" )
 column=(type=datetime updatewhereclause=yes name=sale_due_date dbname="sale.due_date" )
 column=(type=char(10) updatewhereclause=yes name=wc_work_name dbname="wc.work_name" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene.scene_desc" )
 column=(type=char(10) updatewhereclause=yes name=color_color_name dbname="color.color_name" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=decimal(4) updatewhereclause=yes name=acc_qty dbname="acc_qty" )
 retrieve=" SELECT DISTINCT mpsdet.plan_no,   
         mpsdet.order_no,   
         mpsdet.wc_no,   
         mpsdet.sale_no,
         mpsdet.priority,   
         mpsdet.seq_no,   
         mpsdet.item_no,   
         mpsdet.qa,   
         mpsdet.uom,   
         mpsdet.order_qty,   
         mpsdet.rem,
         mps.start_date,   
         sale.rem,
         sale.rem1,
         sale.rem2,
         sale.cust_po_date,
         sale.plan_date,
         sale.due_date,
         wc.work_name,   
         customer.cust_name,   
         scene.scene_desc,   
         color.color_name,   
         groupitem.item_name,   
         acc_qty = dbo.uf_getqty(mpsdet.item_no, mpsdet.qa, mpsdet.uom, mpsdet.order_qty)
    FROM mpsdet with(nolock) inner join mps with(nolock) on mpsdet.order_no = mps.order_no   
                              inner join wc with(nolock) on mpsdet.wc_no = wc.work_no
                              left outer join customer with(nolock) on mpsdet.cust_no = customer.cust_no
                              left outer join scene with(nolock) on mpsdet.scene_code = scene.scene_code
                              left outer join color with(nolock) on mpsdet.item_color = color.color_code
                              inner join sale with(nolock) on mpsdet.sale_no = sale.order_no
                              inner join groupitem with(nolock) on mpsdet.item_no = groupitem.item_no
   WHERE ( mpsdet.mpsorder_order = :as_order )
/*
    FROM mpsdet,   
         wc,   
         customer,   
         scene,   
         color,   
         mps,
         sale,
         groupitem  
   WHERE ( mpsdet.scene_code *= scene.scene_code)
     and ( mpsdet.cust_no *= customer.cust_no)
     and ( mpsdet.item_color *= color.color_code)
     and ( mpsdet.item_no = groupitem.item_no )
     and ( mpsdet.order_no = mps.order_no )
     and ( mpsdet.sale_no = sale.order_no )
	  and ( mpsdet.wc_no = wc.work_no )
     and ( ( mpsdet.mpsorder_order = :as_order ) )
*/
" arguments=(("as_order", string))  sort="mpsdet_sale_no A mpsdet_plan_no A " )
