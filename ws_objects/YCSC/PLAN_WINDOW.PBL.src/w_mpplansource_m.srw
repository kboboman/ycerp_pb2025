type cb_request from commandbutton within tabpage_1
integer x = 283
integer y = 8
integer width = 411
integer height = 76
integer taborder = 100
boolean bringtotop = true
integer textsize = -10
integer weight = 400
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "소재신청 ▶"
end type

event clicked;long   ll_row,   ll_newrow, ll_cnt, ll_dw6_cnt
string ls_check, ls_itemno, ls_orderno, ls_col, ls_divid

if dw_2.object.wc_no[1] = "" then
	if MessageBox("확인","전체 작업장 소재를 신청 하시겠습니까?", Exclamation!, OKCancel!, 2) = 2 then
		dw_2.setcolumn("wc_no")
		dw_2.setfocus()
		return
	end if
end if

if dw5.rowcount() > 0 then ls_divid = dw5.object.div_id[1]
if isnull(ls_divid) or ls_divid = "" then		// 미 결재인 경우
	tab_1.selecttab(2)
	if MessageBox("확인","신규 소재신청 하시겠습니까?", Exclamation!, YesNo!, 2) = 1 then
		dw5.reset()
		dw6.reset()
		
		ll_row = dw5.insertrow(0)
	//	ll_row = dw6.insertrow(0)
	// dw6.scrolltorow(ll_row)
	
		dw5.setcolumn("cust_no")
		dw5.setfocus()
	else
		// 기존 내용에 추가하기
	end if
else	// 결재완료분은 수정할 수 없음
	if MessageBox("확인","신규 소재신청 하시겠습니까?", Exclamation!, YesNo!, 2) = 1 then
		ll_row = dw5.insertrow(0)
//		ll_row = dw6.insertrow(0)
		dw6.scrolltorow(ll_row)	
		dw5.setcolumn("cust_no")
		dw5.setfocus()
	else
		return
	end if	
end if


//dw3.setredraw( false )	오류발생함
ll_dw6_cnt = dw6.rowcount()
for ll_row = 1 to dw3.rowcount()
	ls_check = dw3.object.chk[ll_row]
   if ls_check = "Y" then
		ll_cnt = ll_cnt + 1
		
		ll_newrow = dw6.insertrow(0)
		dw6.ScrollToRow(ll_newrow)
		
		dw6.object.seq_no[ll_newrow]     = ll_dw6_cnt + ll_row    
		dw6.object.sale_no[ll_newrow]    = dw3.object.sale_no[ll_row]    
		dw6.object.seq[ll_newrow]        = dw3.object.seq_no[ll_row]     
		dw6.object.item_no[ll_newrow]    = dw3.object.item_no[ll_row] 
		dw6.object.item_name[ll_newrow]  = dw3.object.item_name1[ll_row] 
		dw6.object.qa[ll_newrow]         = dw3.object.qa[ll_row]         
		dw6.object.color[ll_newrow]      = dw3.object.color_name[ll_row] 
		
		dw6.object.b1_drawno[ll_newrow]  = ""
		dw6.object.b1_qa1[ll_newrow]     = 0
		dw6.object.b1_qa2[ll_newrow]     = 0
		dw6.object.b1_qa3[ll_newrow]     = 0
		dw6.object.b1_qa4[ll_newrow]     = 0
		dw6.object.qty[ll_newrow]        = dw3.object.order_qty[ll_row]
		dw6.object.b1_qa5[ll_newrow]     = 0
		dw6.object.b1_qa6[ll_newrow]     = 0
		dw6.object.b1_qa7[ll_newrow]     = 0
		dw6.object.b1_qa8[ll_newrow]     = 0
		dw6.object.b1_cuts[ll_newrow]    = 0
		dw6.object.b1_rem[ll_newrow]     = ""
		
		dw6.object.p1_qa1[ll_newrow]     = 0
		dw6.object.p1_qa2[ll_newrow]     = 0
		dw6.object.p1_face[ll_newrow]    = 0
		dw6.object.p1_rem[ll_newrow]     = dw3.object.routtempnew_rem[ll_row]
		dw6.object.p1_refcolor[ll_newrow]= ""
		dw6.object.p1_keyno[ll_newrow]   = ""
	end if	
next

// 복사한 row 삭제하기 
for ll_row = dw3.rowcount() to 1 step -1
	ls_check = dw3.object.chk[ll_row]
   if ls_check = "Y" then
		dw3.deleterow( ll_row )
	end if	
next
//dw3.setredraw( true )	오류발생함

cbx_1.checked = false			// 전체
tab_1.selecttab(2)				// 소재신청
dw5.setcolumn("item_no")
dw5.setfocus()

MessageBox("확인", string(ll_cnt) + " 건 소재신청 자료 복사완료!")

end event

