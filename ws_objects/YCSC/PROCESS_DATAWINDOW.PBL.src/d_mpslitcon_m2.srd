$PBExportHeader$d_mpslitcon_m2.srd
$PBExportComments$슬리팅작업지시상세2(2000/06/10,이인호)
release 6;
datawindow(units=0 timer_interval=0 color=79741120 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=160 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=152 color="536870912" )
table(column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=decimal(2) updatewhereclause=yes name=thin dbname="thin" )
 column=(type=long updatewhereclause=yes name=order_seq dbname="coilorderdet.order_seq" )
 column=(type=char(14) updatewhereclause=yes name=order_no dbname="coilsliting.order_no" )
 column=(type=long updatewhereclause=yes name=seq dbname="coilsliting.seq" )
 column=(type=char(20) updatewhereclause=yes name=coil_no dbname="coilsliting.coil_no" )
 column=(type=decimal(1) updatewhereclause=yes name=wid dbname="coilsliting.wid" )
 column=(type=decimal(4) updatewhereclause=yes name=unit_qty dbname="coilsliting.unit_qty" )
 column=(type=long updatewhereclause=yes name=cnt dbname="coilsliting.cnt" )
 column=(type=decimal(2) updatewhereclause=yes name=length dbname="coilsliting.length" )
 column=(type=char(30) updatewhereclause=yes name=rem dbname="coilsliting.rem" )
 column=(type=decimal(1) updatewhereclause=yes name=swid dbname="swid" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"coilsliting~" )  TABLE(NAME=~"groupitem~" )  TABLE(NAME=~"coilorderdet~" ) COLUMN(NAME=~"groupitem.item_name~") COMPUTE(NAME=~"thin = convert (decimal (3,2) ,  substring(coilsliting.qa,1,1) + ~~~".~~~" +  substring(coilsliting.qa,2,2))~") COLUMN(NAME=~"coilorderdet.order_seq~") COLUMN(NAME=~"coilsliting.order_no~") COLUMN(NAME=~"coilsliting.seq~") COLUMN(NAME=~"coilsliting.coil_no~") COLUMN(NAME=~"coilsliting.wid~") COLUMN(NAME=~"coilsliting.unit_qty~") COLUMN(NAME=~"coilsliting.cnt~") COLUMN(NAME=~"coilsliting.length~") COLUMN(NAME=~"coilsliting.rem~") COMPUTE(NAME=~" swid  = case when sheet = ~~~"C~~~" or sheet = ~~~"L~~~"  then convert (decimal (5,1) , substring(qa,5,4) + ~~~".~~~" + substring(qa, 10,1))  when  sheet = ~~~"S~~~" then convert (decimal (5,0) , substring(qa,5,4))  end~")    JOIN (LEFT=~"coilsliting.item_no~"    OP =~"=~"RIGHT=~"groupitem.item_no~" )    JOIN (LEFT=~"coilorderdet.order_no~"    OP =~"=~"RIGHT=~"coilsliting.order_no~" )WHERE(    EXP1 =~"coilorderdet.order_date~"   OP =~"between~"    EXP2 =~":ad_start and :ad_end~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"coilorderdet.proc_flag~"   OP =~"=~"    EXP2 =~":as_flag~" ) ) ARG(NAME = ~"ad_start~" TYPE = date)  ARG(NAME = ~"ad_end~" TYPE = date)  ARG(NAME = ~"as_flag~" TYPE = string) " arguments=(("ad_start", date),("ad_end", date),("as_flag", string))  sort="order_seq A order_no A seq A " )
