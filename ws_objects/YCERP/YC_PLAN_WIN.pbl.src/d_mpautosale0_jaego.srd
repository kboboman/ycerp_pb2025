footer(height=80 color="8421504" )
detail(height=92 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=itemjaego_area_no dbname="itemjaego.area_no" )
 column=(type=char(10) updatewhereclause=yes name=itemjaego_item_no dbname="itemjaego.item_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(20) updatewhereclause=yes name=itemjaego_qa dbname="itemjaego.qa" )
 column=(type=char(1) updatewhereclause=yes name=save_stock dbname="save_stock" )
 retrieve="  SELECT i.area_no
       , i.item_no
       , g.item_name
       , i.qa
       , save_stock  = (SELECT save_stock FROM item WHERE item_no = i.item_no AND qa = i.qa) 
    FROM itemjaego i
         LEFT OUTER JOIN groupitem g ON i.item_no = g.item_no
   WHERE i.area_no = 'S0001'
     AND substring(i.item_no,1,2) <> 'M2'"  sort="groupitem_item_name A itemjaego_qa A " )
