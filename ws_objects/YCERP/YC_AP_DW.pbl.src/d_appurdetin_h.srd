table(column=(type=char(10) updatewhereclause=yes key=yes name=order_no dbname="purdet.order_no" initial=" " )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="purdet.item_no" initial=" " )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="purdet.qa" )
 column=(type=datetime updatewhereclause=yes name=due_date dbname="purdet.due_date" initial=" " )
 column=(type=decimal(4) updatewhereclause=yes name=order_qty dbname="purdet.order_qty" initial="0 " )
 column=(type=datetime update=yes updatewhereclause=yes name=rlse_date dbname="purdet.rlse_date" initial=" " )
 column=(type=decimal(4) updatewhereclause=yes name=price dbname="purdet.price" initial="0 " )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="purdet.uom" initial=" " )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=rlse_qty dbname="purdet.rlse_qty" initial="0 " )
 column=(type=char(30) updatewhereclause=yes name=rem dbname="purdet.rem" initial=" " )
 column=(type=char(20) updatewhereclause=yes name=purdet_rcpt_loc dbname="purdet.rcpt_loc" )
 column=(type=char(17) updatewhereclause=yes name=product_no dbname="purdet.product_no" initial=" " )
 column=(type=decimal(0) updatewhereclause=yes key=yes name=seq_no dbname="purdet.seq_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=result_type dbname="purdet.result_type" )
 retrieve="  SELECT purdet.order_no,   
         purdet.item_no,   
         purdet.qa,   
         purdet.due_date,   
         purdet.order_qty,   
         purdet.rlse_date,   
         purdet.price,   
         purdet.uom,   
         purdet.rlse_qty,   
         purdet.rem,   
         purdet.rcpt_loc,   
         purdet.product_no,   
         purdet.seq_no,   
         purdet.result_type  
    FROM purdet  
   WHERE ( purdet.order_no = :as_order ) AND  
         ( purdet.seq_no = :as_seq )    
" update="purdet" updatewhere=0 updatekeyinplace=yes arguments=(("as_order", string),("as_seq", number)) )
