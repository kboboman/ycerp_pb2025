release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=84 color="536870912" )
summary(height=0 color="536870912" )
footer(height=68 color="12639424" )
detail(height=76 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=sale_order_no dbname="sale.order_no" )
 column=(type=datetime updatewhereclause=yes name=sale_due_date dbname="sale.due_date" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_order_qty dbname="saledet.order_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_rlse_qty dbname="saledet.rlse_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=corder dbname="corder" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="saledet.uom" )
 column=(type=char(10) updatewhereclause=yes name=citem dbname="citem" )
 column=(type=char(20) updatewhereclause=yes name=cqa dbname="cqa" )
 retrieve="select sale.order_no, sale.due_date, customer.cust_name, scene.scene_desc,
		 saledet.order_qty, saledet.rlse_qty, corder = saledet.order_qty - saledet.rlse_qty,
		 saledet.uom, citem = saledet.item_no, cqa = saledet.qa
	from sale inner join saledet on sale.order_no = saledet.order_no
                      inner join customer on sale.cust_no = customer.cust_no
		           left outer join scene on sale.scene_code = scene.scene_code
  WHERE saledet.item_no = :as_item
	and saledet.qa = :as_qa
	and sale.open_close = 'O'
	and ( ( :as_area = 'S0001' and ( ( sale.area_no like :as_area ) or (sale.area_no = 'H0001') ) )
           		or ( :as_area = 'B0001' and ( sale.area_no = :as_area ) )
			  		or ( :as_area = 'T0001' and ( sale.area_no = :as_area ) )
			  		or ( :as_area = '%' and ( sale.area_no like :as_area ) ) )
	and order_date between  :ad_start and :ad_end

union all

select sale.order_no, sale.due_date, customer.cust_name, scene.scene_desc,
		 saledet.order_qty, saledet.rlse_qty, corder = saledet.order_qty - saledet.rlse_qty,
		 saledet.uom, citem = rout.assembly, cqa =  rout.assy_qa
	from sale inner join saledet on sale.order_no = saledet.order_no
                      inner join customer on sale.cust_no = customer.cust_no
		           left outer join scene on sale.scene_code = scene.scene_code
                      inner join rout on saledet.item_no = rout.item_no
						and saledet.qa =rout.qa
  WHERE rout.assembly = :as_item
	and rout.assy_qa = :as_qa
	and sale.order_no = saledet.order_no
	and sale.open_close = 'O'
	and ( ( :as_area = 'S0001' and ( ( sale.area_no like :as_area ) or (sale.area_no = 'H0001') ) )
           		or ( :as_area = 'B0001' and ( sale.area_no = :as_area ) )
			  		or ( :as_area = 'T0001' and ( sale.area_no = :as_area ) )
			  		or ( :as_area = '%' and ( sale.area_no like :as_area ) ) )
	and order_date between  :ad_start and :ad_end
	and rout.item_no <>  rout.assembly
" arguments=(("as_area", string),("ad_start", date),("ad_end", date),("as_item", string),("as_qa", string))  sort="sale_order_no A customer_cust_name A scene_scene_desc A " )
