table(column=(type=char(4) update=yes updatewhereclause=yes key=yes name=sid dbname="NBASIS_MST.sid" )
 column=(type=char(50) update=yes updatewhereclause=yes name=sname dbname="NBASIS_MST.sname" )
 column=(type=datetime update=yes updatewhereclause=yes name=sdate dbname="NBASIS_MST.sdate" )
 column=(type=char(4) update=yes updatewhereclause=yes name=uom dbname="NBASIS_MST.uom" initial="M2" )
 column=(type=char(50) update=yes updatewhereclause=yes name=remark dbname="NBASIS_MST.remark" )
 column=(type=char(1) update=yes updatewhereclause=yes name=use_flag dbname="NBASIS_MST.use_flag" initial="N" values="사용	Y/불가	N/" )
 column=(type=char(10) update=yes updatewhereclause=yes name=sysuser dbname="NBASIS_MST.sysuser" )
 column=(type=datetime update=yes updatewhereclause=yes name=sysdate dbname="NBASIS_MST.sysdate" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=amt1 dbname="amt1" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=amt2 dbname="amt2" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=amt3 dbname="amt3" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=amount dbname="amount" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="login.user_name" )
 retrieve="SELECT nbasis_mst.sid
     , nbasis_mst.sname
     , nbasis_mst.sdate
     , nbasis_mst.uom
     , nbasis_mst.remark
     , nbasis_mst.use_flag
     , nbasis_mst.sysuser
     , nbasis_mst.sysdate
     , amt1       = isnull(nbasis_mst.amt1,0)
     , amt2       = isnull(nbasis_mst.amt2,0)
     , amt3       = isnull(nbasis_mst.amt3,0)
     , amount     = isnull(nbasis_mst.amount,0)
     , login.user_name
  FROM nbasis_mst
       LEFT OUTER JOIN login ON nbasis_mst.sysuser = login.user_id
 WHERE nbasis_mst.sid      = :as_sid 

" update="nbasis_mst" updatewhere=0 updatekeyinplace=no arguments=(("as_sid", string)) )
