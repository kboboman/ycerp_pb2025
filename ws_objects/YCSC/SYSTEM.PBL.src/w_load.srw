global type w_load from window
integer x = 1038
integer y = 236
integer width = 1353
integer height = 452
boolean titlebar = true
string title = "자료LOAD(w_load)"
windowtype windowtype = popup!
long backcolor = 79741120
string icon = "DataPipeline!"
boolean center = true
st_1 st_1
ole_1 ole_1
gb_1 gb_1
gb_2 gb_2
end type
global w_load w_load

on w_load.create
this.st_1=create st_1
this.ole_1=create ole_1
this.gb_1=create gb_1
this.gb_2=create gb_2
this.Control[]={this.st_1,&
this.ole_1,&
this.gb_1,&
this.gb_2}
end on

on w_load.destroy
destroy(this.st_1)
destroy(this.ole_1)
destroy(this.gb_1)
destroy(this.gb_2)
end on

