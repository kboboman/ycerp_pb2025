 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"bdinfo~" )  TABLE(NAME=~"bdinfodet~" ) COLUMN(NAME=~"bdinfodet.lastcom~") COLUMN(NAME=~"bdinfodet.bidcash~") COLUMN(NAME=~"bdinfodet.rem~") COLUMN(NAME=~"bdinfodet.partcom~") COLUMN(NAME=~"bdinfodet.offcash~") COLUMN(NAME=~"bdinfodet.actcash~") COLUMN(NAME=~"bdinfodet.conkind~") COLUMN(NAME=~"bdinfodet.biddate~") COLUMN(NAME=~"bdinfodet.sitedate~") COLUMN(NAME=~"bdinfodet.project~") COLUMN(NAME=~"bdinfodet.buildingcom~")    JOIN (LEFT=~"bdinfodet.build_no~"    OP =~"=~"RIGHT=~"bdinfo.build_no~" )WHERE(    EXP1 =~"bdinfodet.bid_chk~"   OP =~"=~"    EXP2 =~"'1'~" ) ) " )
