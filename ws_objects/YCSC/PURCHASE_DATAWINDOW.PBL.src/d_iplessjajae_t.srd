$PBExportComments$부족자재리스트(1998/03/17,곽용덕)
release 5;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no grid.lines=0 )
header(height=73 color="536870912" )
summary(height=1 color="536870912" )
footer(height=1 color="536870912" )
detail(height=69 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=item_no dbname="lessqoh.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="lessqoh.qa" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="lessqoh.item_name" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="lessqoh.uom" )
 column=(type=decimal(4) updatewhereclause=yes name=qoh dbname="lessqoh.qoh" )
 column=(type=decimal(4) updatewhereclause=yes name=pur_reserved dbname="lessqoh.pur_reserved" )
 column=(type=decimal(2) updatewhereclause=yes name=reorder dbname="lessqoh.reorder" )
 column=(type=decimal(4) updatewhereclause=yes name=sales_reserved dbname="lessqoh.sales_reserved" )
 column=(type=decimal(2) updatewhereclause=yes name=saleqty dbname="saleqty" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"lessqoh~" ) COLUMN(NAME=~"lessqoh.item_no~") COLUMN(NAME=~"lessqoh.qa~") COLUMN(NAME=~"lessqoh.item_name~") COLUMN(NAME=~"lessqoh.uom~") COLUMN(NAME=~"lessqoh.qoh~") COLUMN(NAME=~"lessqoh.pur_reserved~") COLUMN(NAME=~"lessqoh.reorder~") COLUMN(NAME=~"lessqoh.sales_reserved~") COMPUTE(NAME=~"sum(lessqoh.saledetqty) saleqty~") GROUP(NAME=~"lessqoh.item_no~") GROUP(NAME=~"lessqoh.qa~") GROUP(NAME=~"lessqoh.sales_reserved~") GROUP(NAME=~"lessqoh.reorder~") GROUP(NAME=~"lessqoh.pur_reserved~") GROUP(NAME=~"lessqoh.qoh~") GROUP(NAME=~"lessqoh.uom~") GROUP(NAME=~"lessqoh.item_name~")) " filter=" reorder  >  aaa" )
