event dw_2::itemchanged;string   ls_where, ls_sql, ls_salesman, ls_cust_addr, ls_terms
string   ls_data, ls_level, ls_scene_addr, ls_tel_no, ls_telno_cap, ls_curr, ls_addrtel
string   ls_end, ls_date, ls_null, ls_sale_control, ls_cust_chk, ls_utong_yn 
string   ls_order_no, ls_credit_level, ls_fob, ls_order_no1, ls_conf, ls_area_no, ls_confirm, ls_itemno, ls_costyn
string	ls_cust_no, ls_order_no2, ls_order_date
decimal  lr_amt, ldc_saleamt, ldc_credit_limit, ld_date, ldt_null
decimal  lr_bill, lr_balance, lr_total, lr_credit_limit
date     ld_pdate
DateTime ldt_cust_po_date, ldt_order_date, ldt_due_date, ld_gftoday
long     ll_found, ll_row, ll_row1, ll_cnt, ll_cnt1, ll_cnt2, ll_cnt3
int      li_cnt, li_today

setnull(ls_null)
choose case dwo.name
	case "order_date"
		// 당월 수주금액
		ls_order_date	= gf_replaceall(LeftA(data, 10),'-','')
		ls_cust_no		= this.getitemstring(1, 'cust_no')
		
		// 거래처 등급체크
		SELECT 
			a.credit_level, a.salesman, a.shipto_addr, a.tel_no, a.curr_code, isnull(b.limit_amt,a.credit_limit), a.terms
		INTO 
			:ls_level, :ls_salesman, :ls_cust_addr, :ls_tel_no, :ls_curr, :ldc_credit_limit, :ls_terms 
		FROM 
			customer a left outer join orexceed b	on a.cust_no = b.cust_no
																and (:ls_order_date between b.start_date and b.end_date)
																and b.use_yn = 'Y'
		WHERE 
			a.cust_no  = :ls_cust_no
		using sqlca;
		// 여신한도액 표기
		this.object.credit_limit[1] = ldc_credit_limit
		
	case 'cust_no'
		this.getchild("cust_no", idwc_cust)
		
		if ( GF_Permission("판매관리_입력", gs_userid) = "Y" OR GF_Permission("판매관리_입력(부분)", gs_userid) = "Y" OR GF_Permission("판매관리_조회", gs_userid) = "Y" OR GF_Permission("판매관리_입력(영업담당)", gs_userid) = "Y") then
		else
			if GF_PERMISSION("공무관리담당자", gs_userid) = 'Y' then
				if this.object.cust_no[row] = is_custconst then
					// 공무관리담당자는 거래처변경 못함
				else
					MessageBox("확인","공무관리담당자는 거래처만 선택할 수 있습니다!",exclamation!)
					return 1
				end if
			end if
		end if

		ls_data = data
		SELECT count(*) INTO :ll_found FROM customer WHERE cust_no = :ls_data;
		if ll_found = 0 then
			MessageBox("확인","위와 같은고객이 존재하지 않습니다!",exclamation!)
			return 1
		end if
		
		SELECT count(*) INTO :ll_found FROM customer WHERE cust_no = :ls_data and open_close = 'C';
		if ll_found = 1 then
			MessageBox("확인","사용불가중인 거래처입니다. ~r~n" &
						+ "거래처 RELOAD를 하신후 사용하시기 바랍니다.!",exclamation!)
			return 1
		end if

		SELECT isnull(sale_control,'N') INTO :ls_sale_control FROM customer WHERE cust_no = :ls_data;
		if ls_sale_control = 'A' or ls_sale_control = 'Y' then // 매출통제
			MessageBox("확인","매출통제 대상 거래처입니다.~r~n~n영업지원팀에 문의 바랍니다.!",stopsign!)
		end if

		ls_order_date	= string(dw_2.getitemdatetime(1, 'order_date') ,'yyyymmdd')
		// 거래처 등급체크, 한도 금액 확인
		SELECT 
			 a.credit_level
			,a.salesman
			,a.shipto_addr
			,a.tel_no
			,a.curr_code
			,isnull(b.limit_amt,a.credit_limit)
			,a.terms
		INTO 
			 :ls_level
			,:ls_salesman
			,:ls_cust_addr
			,:ls_tel_no
			,:ls_curr
			,:ldc_credit_limit
			,:ls_terms 
		FROM 
			customer a left outer join orexceed b	on a.cust_no = b.cust_no
																and (:ls_order_date between b.start_date and b.end_date)
																and b.use_yn = 'Y'
		WHERE 
			a.cust_no  = :ls_data
		using sqlca;		
		
		// 선입금업체
		if ls_terms = "선입금해지" then
			MessageBox("확인","선입금 약속업체 입니다.~n~n선입금 확인 후 영업관리팀에 문의바랍니다.!",stopsign!)
			return 1
		end if
		
		// 당월 수주금액
		ls_cust_no		= data
		ls_order_no2	= dw_2.getitemstring(1, 'order_no')
		ldc_saleamt		= gf_get_amt_receivable(ls_cust_no, ls_order_no2)

		dw_2.object.saleamt[1] = ldc_saleamt
		
		// 신용등급 표기
		this.object.credit_level[1] = ls_level
		// 여신한도액 표기
		this.object.credit_limit[1] = ldc_credit_limit
		 
      //2008-01-09 h등급 s와 동급으로 처리.				 
		if ls_level = 'V' or ls_level = 'X' then
			MessageBox("확인","수주입력이 불가한 거래처등급(V,X)입니다.!~r~n판매지원팀에 문의바랍니다.",exclamation!)
			return 1
		end if
		
		//거래처 3개월동안 매출수금 체크
		if ls_level = 'A' or ls_level = 'B' or ls_level = 'C' or ls_level = 'E' or ls_level = 'S' then
			SELECT top 1 dateadd(month, -4 , getdate()) INTO :ld_date 
			  FROM login 
			 WHERE user_id   = :gs_userid;
			ls_date  = string(year(date(ld_date))) + "/" + string(month(date(ld_date))) + '/01'
			ld_pdate = date(ls_date)
			
			ll_cnt1 = 0
			SELECT count(*) INTO :ll_cnt1 FROM do
			 WHERE cust_no = :ls_data AND do_date > :ld_pdate;
			 
			ll_cnt2 = 0
			SELECT count(*) INTO :ll_cnt2 FROM aroivc
			 WHERE cust_no = :ls_data
				AND oi_date > :ld_pdate	AND delete_key = 'N';
				
			ll_cnt3 = 0
			SELECT count(*) INTO :ll_cnt3 FROM customer 
			 WHERE cust_no = :ls_data AND last_tn_date > :ld_pdate;
			
			if ll_cnt1 + ll_cnt2 + ll_cnt3 = 0 then
				MessageBox("확인","수주입력이 불가한(3개월동안 거래가 없는) 거래처입니다.!~r~n " &
							+ "판매거래처관리의 최종거래일자를 3개월 이내로 조정하세요.",exclamation!)
				return 1
			end if
		end if
		
		choose case trim(data)
			case "N004"				// 건축사업본부 
				this.object.ship_flag[1] = 'A'
			case "N009", "N011"	// 유창부설연구소, 모듈러사업부
				this.object.ship_flag[1] = 'R'
		end choose
		
		if trim(data) = 'N004' then
			this.object.ship_flag.background.color = rgb(192,192,192)
			this.object.ship_flag.protect = 1		
		else
			this.object.ship_flag.background.color = 1087434968
			this.object.ship_flag.protect = 0
		end if
		
		this.object.scene_code[1] = ls_null
		SELECT count(*) INTO :ll_cnt FROM scene WHERE cust_no = :ls_data;
		 
		idwc_scene.reset() 
		if ll_cnt > 0 then
			// 선택한 거래처의 현장만 보여주기
			wf_sceneretrieve(ls_data)
		end if
		
		if idwc_scene.rowcount() > 0 then
			this.object.protect[1] = 'N'
		else
			this.object.protect[1] = 'Y'
		end if
		
		if isnull(ls_salesman) or trim(ls_salesman) = '' then
			MessageBox('경고','선택한 거래처의 담당영업사원이 지정되지 않았습니다.~n~n' &
						+ '영업지원팀에 문의 바랍니다.(거래처관리에서 담당영업사원 지정)',stopsign!)
		end if
		
		this.object.curr_code[1]   = ls_curr		// 통화코드
		this.object.salesman[1]    = ls_salesman	// 영업담당자
		this.object.shipto_addr[1] = ls_cust_addr	// 거래처주소
		this.object.tel_no[1]      = ls_tel_no		// 거래처전화

		this.object.cust_no.background.color = rgb(192,192,192)
		this.object.cust_no.protect = 1
		this.setcolumn("scene_code")
		this.setfocus()
		
	case 'scene_code'
		string	ls_yn, ls_temp
		
		ls_data = data
		select
			case 	when isnull(b.scene_approval_yn, 'N') = 'Y' then 'Y'
					when isnull(a.approval_yn, 'Y') = 'Y' then 'Y'
					else 'N' end
		into
			:ls_yn
		from 
			scene a left outer join customer b
		on
			a.cust_no = b.cust_no
		where 
			a.scene_code	= :ls_data
		using sqlca;
		
		if gf_null_chk(ls_yn) = true then
			ls_yn = 'Null'
		end if
		
		choose case ls_yn 
			case 'Null'
				MessageBox("확인","위와 같은현장은 존재하지 않습니다!",exclamation!)
				return 1
			case 'N'
				ls_temp	= '선택한 현장은 승인되지 않았습니다.~r~nF9키를 눌러서 승인요청을 하세요.'
				MessageBox("확인",ls_temp,exclamation!)
				return 1				
			case 'Y'
				/*2018.05.16 jowonsuk 추가 유통현장 체크 */
				SELECT isnull(utong_yn,'N')  INTO :ls_utong_yn FROM scene WHERE scene_code  = :ls_data;
				this.object.utong_yn[1] = ls_utong_yn
		end choose

		pb_1.enabled = true	// 라인추가
		cb_3.enabled = true	// 가져오기

		// 운송처주소, 연락처 마스터 정보 가져오기 //
		ls_addrtel = ""
		SELECT item_cd INTO :ls_addrtel FROM codemst WHERE type = '판매수주관리_운송처주소연락처' AND use_yn = 'Y';
		if isnull(ls_addrtel) or ls_addrtel = "" or upper(ls_addrtel) = "NO" then
			ls_scene_addr = ""	// 운송처주소
			ls_tel_no     = ""	// 연락처 
			ls_telno_cap  = ""	// 보조연락처 
		else
			SELECT scene_addr, 		scene_tel, 	scene_telcap 
			INTO      :ls_scene_addr, 		:ls_tel_no,	:ls_telno_cap
			FROM scene
			WHERE scene_code = :ls_data;
		end if

		this.object.shipto_addr[1] = ls_scene_addr
		this.object.tel_no[1]      = ls_tel_no
		this.object.telno_cap[1]   = ls_telno_cap

		this.setcolumn("order_date")
		this.setfocus()
		
	case 'tax_sign'
		lr_amt = this.getitemdecimal(1, "sale_amount")
		if data = 'Y' then
			dw_3.Accepttext()
			this.object.sale_tax[1] = 0
			IF this.object.curr_code[1] = 'WON' then
				dw_2.object.sale_tax[1] = TRUNCATE((lr_amt / 10) + 0.0000001, 0 )
			else
				dw_2.object.sale_tax[1] = TRUNCATE((lr_amt / 10) + 0.0000001, 2 )
			end if
		else
			this.object.sale_tax[1] = 0
		end if
		
	case 'cust_po_date'
		ldt_order_date		= this.getitemdatetime(row, 'order_date') 
		ldt_cust_po_date	= gf_convert_stringtodatetime(data, 'itemchanged')
		if ldt_order_date > ldt_cust_po_date  then
			MessageBox("확인","주문일자보다 요구납기가 늦습니다.!",exclamation!)
			return 1
		end if
		// 요구납기 CHECK
		if date(ldt_cust_po_date) = date("8282-08-28") OR date(ldt_cust_po_date) = date("9999-09-29") then
			// 빨리빨리, 회신일자
		else
			ld_gftoday	= GF_TODAY()
			li_today		= DaysAfter(date(ld_gftoday), date(ldt_cust_po_date))
			if li_today < 0 then li_today = li_today * -1
			if li_today > 60 then	// 요구납기 정상 처리 : 금일부터 60일 이내 
				MessageBox("경고", "요구납기일자는 " + LeftA(String(ld_gftoday),10) + " 부터 +60일 까지(" + String(RelativeDate(date(ld_gftoday), 60),'yyyy/mm/dd') + ") 처리가능 합니다.")  
				dw_2.setcolumn('cust_po_date')
				dw_2.setfocus()
				RETURN 1
			end if
			this.object.due_date[1] = ldt_cust_po_date
		end if
		
	case 'due_date'
		ldt_order_date		= this.getitemdatetime(row, 'order_date') 
		ldt_due_date		= gf_convert_stringtodatetime(data, 'itemchanged')
		
		if ldt_order_date > ldt_due_date then
			MessageBox("확인","주문일자보다 확정납기가 늦습니다.!",exclamation!)
			return 1
		end if
		// 확정납기 CHECK
		ld_gftoday = GF_TODAY()
		li_today   = DaysAfter(date(ld_gftoday), date(ldt_due_date))
		if li_today < 0 then li_today = li_today * -1
		if li_today > 60 then	// 확정납기 정상 처리 : 금일부터 60일 이내 
			MessageBox("경고", "납기일자는 " + LeftA(String(ld_gftoday),10) + " 부터 +60일 까지(" + String(RelativeDate(date(ld_gftoday), 60),'yyyy/mm/dd') + ") 처리가능 합니다.")  
			dw_2.setcolumn('due_date')
			dw_2.setfocus()
			RETURN 1
		end if
		
		IF isnull(string(this.object.cust_po_date[1])) then
			this.object.cust_po_date[1] = ldt_due_date
		end if
	case 'ship_flag'
		if data = 'M' or data = 'H' or data = 'T' or data = 'P' or data = 'Y' then //각 방문, Y:YSP사업장은 sort가 null
			this.object.shipamt_case[1] = 'C'	//현금
		end if
		if data = 'D' or data = 'B' then		   //부담,대여
			this.object.shipamt_case[1] = 'R'	//외상
		end if
	case 'arrival_date'
		ls_data	= LeftA(data,10)
		if not IsDate(trim(ls_data)) then
			 MessageBox("입력 오류", "올바른 날짜 형식이 아닙니다.", StopSign!)
			 return 1  // 입력 거부
		end if
end choose

RETURN 0

end event

event dw_2::retrieveend;Blob   	lb_picture, lb_pictemp
long   	ll_filelen
int    	li_loop, li_filenum, i
string	ls_confirm_flag, ls_cust_no, ls_orderno, ls_filename, ls_ext, ls_file_path
decimal  ldc_saleamt

Boolean 	lb_subdir[]
Double 	ld_size[]
Integer  li_cnt, li_max, li_item, li_file_pointer, li_rtn, l_open_check = 0
INTEGER	li_start, li_start_1, li_start_2, li_start_3, li_start_4, li_prog 
LONG		ll_file_size, ll_loops, ll_lastpro, ll_blob_length, lul_sumfilesize, lul_down_size
LONG		ll_startTime,  ll_EndTime
BLOB 		lb_file_content ,  lb_temp  
constant long LENGTH = 32765

st_filename.text = ""
this.object.cust_no.background.color = RGB(192,192,192)
this.object.cust_no.protect = 1

if rowcount > 0 then
	ls_orderno	= this.object.order_no[1]
	ls_cust_no	= this.getitemstring(1, 'cust_no')
	ls_confirm_flag = this.getitemstring(1, "sale_confirm_flag")
	if (ls_confirm_flag = 'T') or (ls_confirm_flag = 'Y') then	// T: 수주, Y: 생산
		pb_1.enabled = false	// 추가

		pb_2.enabled = false // 품목삭제
		pb_3.enabled = false	// 다중추가
		dw_3.Modify("datawindow.readonly = yes")
	else
		pb_1.enabled = true	// 추가
		pb_2.enabled = true  // 품목삭제
		pb_3.enabled = true	// 다중추가
		dw_3.modify("datawindow.readonly = no")
	end if
	
	WF_SceneRetRieve( dw_2.object.cust_no[dw_2.getrow()] )
	
	// 이미지
	cbx_attch.text = "첨부보기"
	SELECT filename INTO :ls_filename   FROM SalePIC WHERE SalePIC.order_no = :ls_orderno;
	ls_ext  = Lower(RightA(ls_filename,3))
	st_filename.text = ls_filename
	
	if ls_ext = "pdf" then
		st_filename.text = ls_filename
	else
		p_1.visible = false
		p_1.width   = il_maxWidth
		p_1.height  = il_maxHeight
		
		p_1.setredraw( false )
		SELECTBLOB filebin INTO :lb_picture FROM SalePIC WHERE SalePIC.order_no = :ls_orderno;
		if sqlca.sqlcode = 100 then
			p_2.PictureName = ""
			p_1.PictureName = ""
		else
			IF sqlca.sqlcode = 0 THEN
				gf_download(lb_picture, 'C:',  'YC.jpg')
				ls_file_path = "C:"+ 'YC.jpg'	//저장 경로 및 화일
			END IF 
			
			p_2.PICTURENAME = ls_file_path
			p_1.PICTURENAME = ls_file_path
			WF_Images_Resize( p_2, p_1 )
		end if
		p_1.setredraw( true )	
	end if
	//미수금 셋팅	
	ldc_saleamt		= gf_get_amt_receivable(ls_cust_no, ls_orderno)
	this.object.saleamt[1] = ldc_saleamt
end if

end event

event dw_2::itemerror;string   ls_null
datetime ldt_null
setnull(ldt_null)
setnull(ls_null)

choose case dwo.name
	case "cust_no"
		this.object.cust_no[1] = ls_null
	case "scene_code"
		this.object.scene_code[1] = ls_null
	case "class"
		this.object.class[1] = 0
	case "due_date"
		this.object.due_date[1]     = ldt_null
		this.object.cust_po_date[1] = ldt_null
end choose

return 2

end event

event dw_2::rbuttondown;string ls_confirm_flag

this.accepttext()
if this.rowcount() < 1 then return

ls_confirm_flag = this.getitemstring(1, "sale_confirm_flag")
if ls_confirm_flag = 'Y' then
	return
end if

string   ls_color
gs_where lst_code

this.accepttext()
choose case dwo.name
	case 'color'
		openwithparm(w_whcolor_m, lst_code)
		lst_code = message.powerobjectparm
		if lst_code.chk = "N" then return

		this.getchild("color", idwc_color)
		idwc_color.SetTransObject(sqlca)
		idwc_color.retrieve()
		this.object.color[1] = lst_code.str1
end choose

end event

event dw_2::buttonclicked;call super::buttonclicked;string	ls_order_no, ls_rem, ls_rem1, ls_rem2, ls_msg, ls_sqlerrtext, ls_sale_make_rem
string	ls_shipto_addr,ls_telno_cap,ls_tel_no, ls_ship_flag, ls_ship_case, ls_cust_po_no
datetime	ldt_arrival_date

if dw_2.accepttext( ) = -1 then return

choose case dwo.name
	case 'b_rem'
		ls_order_no			= this.getitemstring(row, 'order_no')			
		ls_rem				= this.getitemstring(row, 'rem')
		ls_rem1				= this.getitemstring(row, 'rem1')
		ls_rem2				= this.getitemstring(row, 'rem2')
		ls_sale_make_rem	= this.getitemstring(row, 'sale_make_rem')
		ls_shipto_addr		= this.getitemstring(row, 'shipto_addr')
		ls_telno_cap		= this.getitemstring(row, 'telno_cap')
		ls_tel_no			= this.getitemstring(row, 'tel_no')
		ls_ship_flag		= this.getitemstring(row, 'ship_flag')			//운송방법
		ls_ship_case		= this.getitemstring(row, 'ship_case')			//운송수단
		ls_cust_po_no		= this.getitemstring(row, 'cust_po_no')		//고객발주번호
		ldt_arrival_date	= this.getitemdatetime(row, 'arrival_date')	//도착일시
		
		if gf_null_chk(ls_order_no) = true then
			messagebox("오류","수주번호를 다시 확인하세요!")
			return
		end if
		
		ls_msg	= "수주번호[ " + ls_order_no + "]의~r~n특기사항/주소/전화번호/도착일시등을~r~n수정을 수정하시겠습니까?"
		if messagebox("확인", ls_msg, exclamation!, okcancel!, 2) = 2 then return
		
		update
			sale
		set
			 rem 				= :ls_rem
			,rem1 			= :ls_rem1
			,rem2 			= :ls_rem2
			,make_rem 		= :ls_sale_make_rem
			,shipto_addr	= :ls_shipto_addr
			,telno_cap		= :ls_telno_cap
			,tel_no			= :ls_tel_no
			,ship_flag		= :ls_ship_flag
			,ship_case		= :ls_ship_case
			,cust_po_no		= :ls_cust_po_no
			,arrival_date	= :ldt_arrival_date
		where
			order_no = :ls_order_no
		using sqlca;
		
		if sqlca.sqlcode <> 0 then 
			ls_sqlerrtext	= sqlca.sqlerrtext
			rollback using sqlca;
			messagebox("sql error", ls_sqlerrtext)
			return
		end if
		
		commit using sqlca;
		messagebox("확인","수정 완료했습니다.")

	case else
		gs_where lst_where
		
		lst_where.str1 = "KD" + string(today(), "yyyymmdd")
		lst_where.str2 = "S"
		OpenWithParm (w_oeesti_w, lst_where) 
end choose

end event

event dw_2::doubleclicked;call super::doubleclicked;//// 공무관리담당자는 거래처변경 못함
if row < 1 then return 

if (GF_Permission("판매관리_입력", gs_userid) = "Y" or GF_Permission("판매관리_입력(부분)", gs_userid) = "Y" OR GF_Permission("판매관리_조회", gs_userid) = "Y" OR GF_Permission("판매관리_입력(영업담당)", gs_userid) = "Y" ) then
else
	if GF_PERMISSION("공무관리담당자", gs_userid) = 'Y' then
		return
	end if
end if	

if dw_3.rowcount() > 0 then 
	messagebox('경고', ' 하단에 물품을 선택한다음 거래처나 현장을 변경하시면,~r~n~r~n 최근단가를 다시 가져올수 없습니다.~r~n~r~n 거래처 나 현장을 변경할경우 하단의 내용을 삭제후 다시 작업하세요.', stopsign!)
end if

if trim(this.object.order_no[row]) = '' or isnull(this.object.order_no[row]) then
	choose case dwo.name
		case 'cust_no_t','scene_code_t'
			Open(w_orcust_s) 
	end choose
end if


end event

event dw_2::keydown;call super::keydown;// 1 Shift, 2 Ctrl, 3 Shift + Ctrl keys
IF keyflags = 2 THEN
	IF key = KeyS! THEN
		if MessageBox("확인", "수주내용을 저장 하시겠습니까?", Exclamation!, OKCancel!, 2) = 1 then
			pb_save.triggerevent(clicked!)
		end if
	END IF
END IF

end event

event dw_2::clicked;call super::clicked;choose case dwo.name
	case "scene_code"
		this.scrolltorow(row)
		
	case else
end choose

end event

event dw_2::getfocus;call super::getfocus;// 한글 키보드 
long mode

mode = ImmGetContext( handle(parent) )
ImmSetConversionStatus( mode, 1, 0 )		// 2번째 인수값 1=KOR, 2=ENG

end event

