$PBExportComments$일일업무(생산)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=92 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=diary_date dbname="diary_date" )
 column=(type=char(50) updatewhereclause=yes name=work_name dbname="work_name" )
 column=(type=long updatewhereclause=yes name=cqty dbname="cqty" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="user_id" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 retrieve="SELECT Distinct diary_date = a.diary_date
     , work_name = a.work_name
     , cqty      = a.cqty
     , user_id   = a.user_id
     , user_name = login.user_name
  FROM plan_diary a
       LEFT OUTER JOIN login ON a.user_id = login.user_id
 WHERE ( a.diary_date  BETWEEN :as_sdate AND :as_edate )
   AND ( a.cqty     > 0                                )
   AND ( :as_workno   <> '%' AND a.work_no      = :as_workno
         OR           
         :as_workno    = '%' AND a.work_no   LIKE :as_workno
       )
   AND ( :as_employee <> '%' AND a.employee     = :as_employee
         OR
         :as_employee  = '%' AND a.employee  LIKE :as_employee
       )
" arguments=(("as_workno", string),("as_sdate", string),("as_edate", string),("as_employee", string))  sort="user_name A " )
