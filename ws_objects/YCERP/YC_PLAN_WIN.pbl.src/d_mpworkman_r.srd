footer(height=0 color="553648127" )
detail(height=88 color="536870912" )
table(column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" )
 column=(type=char(10) updatewhereclause=yes name=area_no dbname="sfcworkman.area_no" )
 column=(type=char(20) updatewhereclause=yes name=area_name dbname="area_name" )
 column=(type=char(10) updatewhereclause=yes name=work_no dbname="sfcworkman.work_no" )
 column=(type=char(20) updatewhereclause=yes name=work_nm dbname="sfcworkman.work_nm" )
 column=(type=datetime updatewhereclause=yes name=work_day dbname="sfcworkman.work_day" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="sfcworkman.user_id" )
 column=(type=datetime updatewhereclause=yes name=work_stime dbname="sfcworkman.work_stime" )
 column=(type=datetime updatewhereclause=yes name=work_etime dbname="sfcworkman.work_etime" )
 column=(type=decimal(6) updatewhereclause=yes name=chk_time dbname="chk_time" )
 column=(type=char(20) updatewhereclause=yes name=name_kor dbname="sfcworkman.name_kor" )
 column=(type=char(10) updatewhereclause=yes name=job_no dbname="sfcworkman.job_no" )
 column=(type=char(20) updatewhereclause=yes name=job_name dbname="sfcworkman.job_name" )
 column=(type=char(1) updatewhereclause=yes name=sfcworkman_confirm1 dbname="sfcworkman.confirm1" )
 column=(type=char(1) updatewhereclause=yes name=sfcworkman_confirm2 dbname="sfcworkman.confirm2" )
 column=(type=char(1) updatewhereclause=yes name=sfcworkman_confirm3 dbname="sfcworkman.confirm3" )
 column=(type=char(2) updatewhereclause=yes name=sel dbname="sel" )
 column=(type=char(1) updatewhereclause=yes name=man_type dbname="sfcworkman.man_type" values="외국	F/	D/" )
 column=(type=char(1) updatewhereclause=yes name=day_labor dbname="sfcworkman.day_labor" )
 column=(type=char(255) updatewhereclause=yes name=contents dbname="sfcworkman.contents" )
 column=(type=char(100) updatewhereclause=yes name=company dbname="sfcworkman.company" )
 column=(type=char(1) updatewhereclause=yes name=sfcworkman_booking dbname="sfcworkman.booking" )
 column=(type=char(1) updatewhereclause=yes name=sfcworkman_absent dbname="sfcworkman.absent" )
 column=(type=datetime updatewhereclause=yes name=sys_date dbname="sfcworkman.sys_date" )
 column=(type=long updatewhereclause=yes name=sortkey dbname="sortkey" )
 column=(type=char(10) updatewhereclause=yes name=uid_org dbname="uid_org" )
 column=(type=char(1) updatewhereclause=yes name=timecard dbname="timecard" )
 retrieve="  SELECT chk       = 'N'
       , sfcworkman.area_no   
       , area_name = a.area_name   
       , sfcworkman.work_no   
       , sfcworkman.work_nm  
       , sfcworkman.work_day   
       , sfcworkman.user_id   
       , sfcworkman.work_stime   
       , sfcworkman.work_etime   
       , chk_time   = (case when convert(char(8),sfcworkman.work_stime,108) > '17:30:00'   /* 순수투입시간 */
                                 then datediff(mi, sfcworkman.work_stime, sfcworkman.work_etime) / 60.0    
                            else (datediff(mi, sfcworkman.work_stime, sfcworkman.work_etime) - 60.0) / 60.0    
                       end)
       , sfcworkman.name_kor   
       , sfcworkman.job_no 
       , sfcworkman.job_name
       , sfcworkman.confirm1   
       , sfcworkman.confirm2   
       , sfcworkman.confirm3   
       , sel        = space(2)
       , sfcworkman.man_type   
       , sfcworkman.day_labor
       , sfcworkman.contents   
       , sfcworkman.company   
       , sfcworkman.booking   
       , sfcworkman.absent
       , sfcworkman.sys_date   
       , sortkey   = (case when sfcworkman.work_nm = sfcworkman.job_name then 1
                           else 2
                      end)
       , uid_org   = sfcworkman.user_id   
       , timecard  = 'N'
    FROM sfcworkman
         LEFT OUTER JOIN area A ON sfcworkman.area_no = a.area_no   
   WHERE ((:as_area    = '%' AND sfcworkman.area_no LIKE :as_area) OR
          (:as_area   <> '%' AND sfcworkman.area_no    = :as_area)
         )
     AND ((:as_workno  = '%' AND sfcworkman.work_no LIKE :as_workno) OR
          (:as_workno <> '%' AND sfcworkman.work_no    = :as_workno)
         )
     AND ( sfcworkman.work_day  between :as_sdate AND :as_edate    )
" arguments=(("as_area", string),("as_workno", string),("as_sdate", string),("as_edate", string))  sort="work_nm A work_day D sortkey A job_name A day_labor A man_type A name_kor A work_stime A " )
