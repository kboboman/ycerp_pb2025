$PBExportHeader$d_iractio_s3.srd
$PBExportComments$실사차이보고서(2000/09/02,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="12639424" )
detail(height=80 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=itemloc_item_no dbname="itemloc.item_no" )
 column=(type=char(20) updatewhereclause=yes name=itemloc_qa dbname="itemloc.qa" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="itemloc.item_name" )
 column=(type=char(2) updatewhereclause=yes name=itemloc_uom dbname="itemloc.uom" )
 column=(type=char(30) updatewhereclause=yes name=itemloc_loc_name dbname="itemloc.loc_name" )
 column=(type=char(26) updatewhereclause=yes name=title dbname="title" )
 column=(type=decimal(4) updatewhereclause=yes name=qoh dbname="qoh" initial="0" )
 column=(type=decimal(4) updatewhereclause=yes name=eom_qoh dbname="eom_qoh" )
 retrieve="SELECT itemloc.item_no,   
		itemloc.qa,   
		item_name,   
		uom,
		loc_name,
		title =  convert(char(4),:as_year) + '년 ' + convert(char(2), :as_mon) + '월 실사차이보고서',
		qoh = isnull(ineoym.qoh,0),   /* 실사수량 */
		eom_qoh = itemloc.qoh - isnull(cday.rcpt, 0) + isnull(cday.issue, 0)
    FROM itemloc left outer join ineoym on itemloc.item_no = ineoym.item_no 
                                     and itemloc.qa = ineoym.qa 
                                     and itemloc.loc_no = ineoym.loc_no
         						and ineoym.cyear = :as_year 
							and ineoym.cmon = :as_mon
                             inner join groupitem on itemloc.item_no = groupitem.item_no
                             inner join location on itemloc.loc_no = location.loc_no
                             left outer join (select item_no, qa, rcpt = sum(rcpt_qty), issue = sum(issue_qty) from ineoym
                                            			  where (( cyear = rtrim(:as_year) 
                                            				 		and cmon > rtrim(:as_mon) )
                                            						 or ( cyear > rtrim(:as_year) ))			 
                                            				and loc_no = :as_loc 
                                            				group by item_no, qa) cday on itemloc.item_no = cday.item_no and itemloc.qa = cday.qa
   WHERE ( NOT(groupitem.uom = 'M2' and groupitem.item_no like 'PCY%') ) and	
         ( itemloc.loc_no = location.loc_no ) and  
         ( ( itemloc.loc_no = :as_loc ) AND  
         (itemloc.item_no like :as_item AND  
         groupitem.use_flag = 'Y' AND  
         groupitem.item_name like :as_name) AND  
         itemloc.item_no < 'PZZZ' )    AND 
			itemloc.item_no NOT IN ('GZZZMISZZZ', 'GCYZZZZZZZ')" arguments=(("as_loc", string),("as_year", string),("as_mon", string),("as_item", string),("as_name", string))  sort="itemloc_item_no A itemloc_qa A " )
