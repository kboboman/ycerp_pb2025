table(column=(type=char(4) update=yes updatewhereclause=yes key=yes name=cust_no dbname="custitem.cust_no" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="custitem.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=qa dbname="custitem.qa" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="custitem.uom" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=pre_cost dbname="custitem.pre_cost" initial="0" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=custitem_std_cost dbname="custitem.std_cost" initial="0" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=price dbname="custitem.price" initial="0" )
 column=(type=char(30) update=yes updatewhereclause=yes name=rem dbname="custitem.rem" )
 column=(type=datetime update=yes updatewhereclause=yes name=sys_date dbname="custitem.sys_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=user_id dbname="custitem.user_id" )
 column=(type=long updatewhereclause=yes name=c_price dbname="c_price" )
 column=(type=decimal(4) updatewhereclause=yes name=std_cost dbname="itemcost.price" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="groupitem.item_name" )
 retrieve="  SELECT custitem.cust_no    
       , custitem.item_no    
       , custitem.qa         
       , custitem.uom        
       , custitem.pre_cost   
       , custitem.std_cost   
       , custitem.price      
       , custitem.rem        
       , custitem.sys_date   
       , custitem.user_id    
       , c_price     = 0 
       , itemcost.price      
       , customer.cust_name
       , groupitem.item_name  
    FROM custitem    
         LEFT OUTER JOIN itemcost    ON custitem.item_no = itemcost.item_no AND custitem.qa  = itemcost.qa 
         LEFT OUTER JOIN groupitem   ON custitem.item_no = groupitem.item_no
         LEFT OUTER JOIN customer    ON custitem.cust_no = customer.cust_no  
   WHERE custitem.cust_no    = :as_custno
" update="custitem" updatewhere=0 updatekeyinplace=no arguments=(("as_custno", string))  sort="item_name A qa A " )
