 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"itemjaego~" )  TABLE(NAME=~"itemloc~" )  TABLE(NAME=~"groupitem~" )  TABLE(NAME=~"area~" ) COLUMN(NAME=~"itemloc.item_no~") COLUMN(NAME=~"itemloc.qa~") COLUMN(NAME=~"groupitem.item_name~") COLUMN(NAME=~"itemloc.qoh~")    JOIN (LEFT=~"itemloc.item_no~"    OP =~"=~"RIGHT=~"groupitem.item_no~" )    JOIN (LEFT=~"itemjaego.item_no~"    OP =~"=~"RIGHT=~"itemloc.item_no~" )    JOIN (LEFT=~"itemjaego.qa~"    OP =~"=~"RIGHT=~"itemloc.qa~" )    JOIN (LEFT=~"itemjaego.area_no~"    OP =~"=~"RIGHT=~"area.area_no~" )    JOIN (LEFT=~"area.def_loc~"    OP =~"=~"RIGHT=~"itemloc.loc_no~" )WHERE(    EXP1 =~"itemjaego.item_no~"   OP =~"like~"    EXP2 =~":as_item~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"groupitem.item_name~"   OP =~"like~"    EXP2 =~":as_name~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"itemjaego.area_no~"   OP =~"=~"    EXP2 =~":as_area~" ) ) ARG(NAME = ~"as_item~" TYPE = string)  ARG(NAME = ~"as_name~" TYPE = string)  ARG(NAME = ~"as_area~" TYPE = string) " arguments=(("as_item", string),("as_name", string),("as_area", string))  sort="itemloc_item_no A itemloc_qa A " )
