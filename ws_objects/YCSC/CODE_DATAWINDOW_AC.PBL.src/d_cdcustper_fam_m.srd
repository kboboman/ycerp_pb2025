 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"custfam~" ) COLUMN(NAME=~"custfam.cust_idno~") COLUMN(NAME=~"custfam.fam_name~") COLUMN(NAME=~"custfam.fam_rel~") COLUMN(NAME=~"custfam.fam_id~") COLUMN(NAME=~"custfam.fam_ename~") COLUMN(NAME=~"custfam.fam_birth~") COLUMN(NAME=~"custfam.fam_age~") COLUMN(NAME=~"custfam.fam_job~") COLUMN(NAME=~"custfam.fam_fcorp~") COLUMN(NAME=~"custfam.fam_ps~") COLUMN(NAME=~"custfam.fam_marriage~") COLUMN(NAME=~"custfam.fam_school~") COLUMN(NAME=~"custfam.fam_addr~")WHERE(    EXP1 =~"custfam.cust_idno~"   OP =~"=~"    EXP2 =~":ai_idno~" ) ) ARG(NAME = ~"ai_idno~" TYPE = number) " update="custfam" updatewhere=1 updatekeyinplace=no arguments=(("ai_idno", number)) )
