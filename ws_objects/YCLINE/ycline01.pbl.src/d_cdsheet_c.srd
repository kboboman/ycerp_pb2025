release 8;
datawindow(units=0 timer_interval=0 color=67108864 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=1 )
header(height=88 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=84 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=sheet_no dbname="sheetmst.sheet_no" )
 column=(type=decimal(4) updatewhereclause=yes name=unit_qty dbname="sheetmst.unit_qty" )
 column=(type=long updatewhereclause=yes name=qcnt dbname="sheetmst.qcnt" )
 column=(type=decimal(2) updatewhereclause=yes name=thin dbname="thin" )
 column=(type=char(10) updatewhereclause=yes name=loc_no dbname="sheetmst.loc_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="sheetmst.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="sheetmst.qa" )
 column=(type=char(1) updatewhereclause=yes name=flag dbname="sheetmst.flag" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="groupitem.uom" )
 retrieve="  SELECT sheetmst.sheet_no,   
         sheetmst.unit_qty,   
         sheetmst.qcnt,   
         thin = convert (decimal (3,2) , substring(qa,1,1) + ~".~" + substring(qa, 2,2)),   
         sheetmst.loc_no,   
         sheetmst.item_no,   
         sheetmst.qa,   
         sheetmst.flag,   
         groupitem.item_name,   
         groupitem.uom  
    FROM sheetmst,   
         groupitem  
   WHERE ( sheetmst.item_no = groupitem.item_no ) and  
         ( ( sheetmst.open_close = ~"O~" ) AND  
         ( sheetmst.item_no not in (select loss_item from lossitem) ) AND  
         ( sheetmst.loc_no = :as_loc ) AND  
         ( sheetmst.sheet_no like :as_coil ) AND  
         ( sheetmst.qa like :as_qa ) AND  
         ( ( :al_unit = 0 ) or ( :al_unit <> 0 and ( sheetmst.unit_qty = :al_unit ) ) )  )  
" retrieve.asneeded=yes arguments=(("as_loc", string),("as_coil", string),("as_qa", string),("al_wid", number),("al_unit", number))  sort="thin A unit_qty A sheet_no A " )
