$PBExportHeader$d_osteamopeom_item10_r.srd
$PBExportComments$매출실적집계표
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=yes )
header(height=708 color="536870912" )
summary(height=132 color="553648127" )
footer(height=0 color="536870912" )
detail(height=92 color="536870912" )
table(column=(type=long updatewhereclause=yes name=seq dbname="seq" )
 column=(type=char(20) updatewhereclause=yes name=area dbname="area" )
 column=(type=char(20) updatewhereclause=yes name=sector dbname="sector" )
 column=(type=char(20) updatewhereclause=yes name=team dbname="team" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="user_id" )
 column=(type=char(20) updatewhereclause=yes name=login_user_name dbname="user_name" )
 column=(type=char(10) updatewhereclause=yes name=login_rank dbname="rank" )
 column=(type=decimal(9) updatewhereclause=yes name=pre_yinv dbname="pre_yinv" )
 column=(type=decimal(6) updatewhereclause=yes name=cur_ayinv dbname="cur_ayinv" )
 column=(type=decimal(6) updatewhereclause=yes name=cur_amninv dbname="cur_amninv" )
 column=(type=decimal(9) updatewhereclause=yes name=cur_inv dbname="cur_inv" )
 column=(type=decimal(6) updatewhereclause=yes name=curinv_rate dbname="curinv_rate" )
 column=(type=decimal(9) updatewhereclause=yes name=bsale_amt dbname="bsale_amt" )
 column=(type=decimal(6) updatewhereclause=yes name=increm_rate dbname="increm_rate" )
 column=(type=decimal(6) updatewhereclause=yes name=cur_aminv dbname="cur_aminv" )
 column=(type=decimal(7) updatewhereclause=yes name=cur_minv dbname="cur_minv" )
 column=(type=decimal(6) updatewhereclause=yes name=cur_aminv_s dbname="cur_aminv_s" )
 column=(type=decimal(9) updatewhereclause=yes name=cur_minv_s dbname="cur_minv_s" )
 column=(type=decimal(6) updatewhereclause=yes name=inv_s_rate dbname="inv_s_rate" )
 column=(type=decimal(6) updatewhereclause=yes name=inv_rate dbname="inv_rate" )
 column=(type=long updatewhereclause=yes name=cyear dbname="cyear" )
 column=(type=long updatewhereclause=yes name=cmon dbname="cmon" )
 column=(type=char(2) updatewhereclause=yes name=space dbname="space" )
 column=(type=decimal(9) updatewhereclause=yes name=top10_pre_yinv dbname="top10_pre_yinv" )
 retrieve="SELECT            
	seq         = o.seq                     /* 순서       */  
	, area        = o.area                    /* 권역       */
	, sector      = o.sector                  /* 본부       */
	, team        = o.team                    /* 팀         */
	, user_id     = o.user_id                 /* 담당자     */
	, user_name   = o.user_name               /* 담당자명   */
	, rank        = o.rank                    /* 직책       */
	, pre_yinv    = z.pre_yinv                /* 전년 실적                                             */
	, cur_ayinv   = z.cur_ayinv               /* 매출목표   - 당년 목표                                */
	, cur_amninv  = z.cur_amninv              /* 매출목표   - 당년누계목표                             */
	, cur_inv     = z.cur_inv                 /* 매출실적   - 매출누계                                 */
	, curinv_rate = (case when z.cur_ayinv = 0 then 0 else (z.cur_inv / z.cur_ayinv)     end) /* 매출실적   - 진행율  = (매출누계 / 당년목표    )      */
	, bsale_amt   = z.bsale_amt               /* 전년       - 동월실적                                 */
	, increm_rate = (case when z.bsale_amt = 0 then 0 else (z.cur_minv / z.bsale_amt) -1 end) /* 실적       - 신장율  = (당월매출 / 전년동월실적) -1   */
	, cur_aminv   = z.cur_aminv               /* 매출       - 당월매출목표                             */
	, cur_minv    = z.cur_minv                /* 목표및진행 - 당월매출                                 */	  
	, cur_aminv_s   = z.cur_aminv_s               /* 매출       - 당월매출목표                             */
	, cur_minv_s    = z.cur_minv_s                /* 목표및진행 - 당월매출                                 */	  
	, inv_s_rate    = (case when z.cur_aminv_s = 0 then 0 else (z.cur_minv_s / z.cur_aminv_s)    end) /* 목표및진행 - 진행율  = (당월매출 / 당월매출목표)      */
	, inv_rate    = (case when z.cur_aminv = 0 then 0 else (z.cur_minv / z.cur_aminv)    end) /* 목표및진행 - 진행율  = (당월매출 / 당월매출목표)      */
	, cyear       = :ai_year
	, cmon        = :ai_month
	, space  = '  '
	, top10_pre_yinv	= zz.un_outamt				 /* 미출고현황(전략제품) */
FROM (
            						SELECT salesman    = (case when m.item_cd IS NOT NULL then 'insite' else aa.salesman end)
            									, bsale_amt  = sum(aa.bsale_amt)     /* 전년 - 동월실적 */
            									, pre_yinv   = sum(aa.pre_yinv)
            									, cur_ayinv  = sum(aa.cur_ayinv)
            									, cur_amninv = sum(aa.cur_amninv)
            									, cur_inv    = sum(aa.cur_inv)
            									, cur_aminv  = sum(aa.cur_aminv)
            									, cur_minv   = sum(aa.cur_minv)
            									, cur_aminv_s  = sum(aa.cur_aminv_s)
            									, cur_minv_s   = sum(aa.cur_minv_s)
            									FROM (
            																						 SELECT salesman    = c.salesman 
                      																										, user_name   = l.user_name
                      																										, cust_no    = c.cust_no
            																														  , bsale_amt  = sum(o_bf.bsale_amt) / 1000																																									
            																														  , pre_yinv   = sum(o_bf.pre_yinv) / 1000
            																														  , cur_ayinv  = sum((t.special_01 + t.special_02 + t.special_03 + t.special_04 + t.special_05 + t.special_06 + t.special_07 + t.special_08 + t.special_09 + t.special_10 + t.special_11 + t.special_12 ) / 1.1) / 1000
            																														  , cur_amninv = sum((case :ai_month 
            																																						 when 1 then t.special_01
            																																						 when 2 then t.special_01 + t.special_02
            																																						 when 3 then t.special_01 + t.special_02 + t.special_03
            																																						 when 4 then t.special_01 + t.special_02 + t.special_03 + t.special_04
            																																						 when 5 then t.special_01 + t.special_02 + t.special_03 + t.special_04 + t.special_05
            																																						 when 6 then t.special_01 + t.special_02 + t.special_03 + t.special_04 + t.special_05 + t.special_06
            																																						 when 7 then t.special_01 + t.special_02 + t.special_03 + t.special_04 + t.special_05 + t.special_06 + t.special_07
            																																						 when 8 then t.special_01 + t.special_02 + t.special_03 + t.special_04 + t.special_05 + t.special_06 + t.special_07 + t.special_08
            																																						 when 9 then t.special_01 + t.special_02 + t.special_03 + t.special_04 + t.special_05 + t.special_06 + t.special_07 + t.special_08 + t.special_09
            																																						 when 10 then t.special_01 + t.special_02 + t.special_03 + t.special_04 + t.special_05 + t.special_06 + t.special_07 + t.special_08 + t.special_09 + t.special_10
            																																						 when 11 then t.special_01 + t.special_02 + t.special_03 + t.special_04 + t.special_05 + t.special_06 + t.special_07 + t.special_08 + t.special_09 + t.special_10 + t.special_11
            																																						 when 12 then t.special_01 + t.special_02 + t.special_03 + t.special_04 + t.special_05 + t.special_06 + t.special_07 + t.special_08 + t.special_09 + t.special_10 + t.special_11 + t.special_12 
            																																					 end) / 1.1) / 1000
            																														  , cur_inv    = sum(o_bf.cur_inv) / 1000
																																  , cur_aminv  = sum((case :ai_month  
																																								 when 1 then t.mod_01
																																								 when 2 then t.mod_02
																																								 when 3 then t.mod_03
																																								 when 4 then t.mod_04
																																								 when 5 then t.mod_05
																																								 when 6 then t.mod_06
																																								 when 7 then t.mod_07
																																								 when 8 then t.mod_08
																																								 when 9 then t.mod_09
																																								 when 10 then t.mod_10
																																								 when 11 then t.mod_11
																																								 when 12 then t.mod_12 
																																							 end) / 1.1) / 1000
																																  , cur_minv       = sum(o_bf.cur_minv)  / 1000
            																														  , cur_aminv_s  = sum((case :ai_month  
            																																						 when 1 then t.special_01
            																																						 when 2 then t.special_02
            																																						 when 3 then t.special_03
            																																						 when 4 then t.special_04
            																																						 when 5 then t.special_05
            																																						 when 6 then t.special_06
            																																						 when 7 then t.special_07
            																																						 when 8 then t.special_08
            																																						 when 9 then t.special_09
            																																						 when 10 then t.special_10
            																																						 when 11 then t.special_11
            																																						 when 12 then t.special_12 
            																																					 end) / 1.1) / 1000
            																														  , cur_minv_s   = sum(o_bf.cur_minv_s) / 1000
            																													  FROM customer   C with(nolock)
            																															 LEFT OUTER JOIN cust_aim    t   with(nolock) ON c.cust_no = t.cust_code   AND datepart(year, t.tar_year)    = :ai_year
            																															 left outer join (                
            																																								  select  a.cust_no,
            																																												  sum(pre_yinv) pre_yinv,
            																																												  sum(cur_inv) cur_inv,
            																																												  sum(bsale_amt) bsale_amt,
            																																												  sum(cur_minv_s) cur_minv_s,
            																																												  sum(last_day) last_day,
            																																												  sum(cur_minv) cur_minv
            																																								  from
            																																								  (                         
																																												 SELECT cust_no         = b.cust_no
																																																		  , item_no         = a.item_no  
																																																		  , pre_yinv        = (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price)
																																																		  , cur_inv          = 0
																																																		  , bsale_amt     = 0
																																																		  , cur_minv_s       = 0
																																																		  , last_day         = 0                                                                                                      
																																																		  , cur_minv       = 0
																																																	  FROM dodet A with(nolock) inner join do B with(nolock) ON a.do_no = b.do_no
																																																																	 inner  join itemtop10 G with(nolock) on a.item_no   = g.item_no  and g.category in (select item_cd  from codemst where type = 'ITEMTOP10' and prt_yn = 'Y')
																																																		where convert(char(4),  (case when 'ISSUE' = :as_flag then ( case when b.do_date > b.issue_date then b.issue_date else b.do_date end  ) else b.do_date end), 112) =  convert(char(4), dateadd(year, - 1, substring(:as_sdate,1,4)+substring(:as_sdate,6,2)+'01'),112 )
																																														  union all
																																														 SELECT cust_no         = b.cust_no
																																																		  , item_no         = a.item_no  
																																																		  , pre_yinv          = 0
																																																		  , cur_inv        = (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price)                                  
																																																		  , bsale_amt     = 0
																																																		  , cur_minv_s    = 0
																																																		  , last_day         = 0       
																																																		  , cur_minv       = 0                                                                                               
																																																	  FROM dodet A with(nolock) inner join do B with(nolock) ON a.do_no = b.do_no
																																																																	inner join itemtop10 G with(nolock) on a.item_no   = g.item_no  and g.category in (select item_cd  from codemst where type = 'ITEMTOP10' and prt_yn = 'Y')
																																																	 WHERE convert(char(8),(case when 'ISSUE' = :as_flag then ( case when b.do_date > b.issue_date then b.issue_date else b.do_date end  ) else b.do_date end),112) between substring(:as_sdate,1,4)+'0101' and  substring(:as_edate,1,4)+substring(:as_edate,6,2)+substring(:as_edate,9,2)
																																														  union all
																																														 SELECT cust_no         = b.cust_no
																																																		  , item_no         = a.item_no  
																																																		  , pre_yinv          = 0
																																																		  , cur_inv          = 0
																																																		  , bsale_amt     = (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price)                    
																																																		  , cur_minv_s       = 0
																																																		  , last_day         = 0                                                  
																																																		  , cur_minv       = 0                                                    
																																																	  FROM dodet A with(nolock) inner join do B with(nolock) ON a.do_no = b.do_no
																																																																	 inner join itemtop10 G with(nolock) on a.item_no   = g.item_no  and g.category in (select item_cd  from codemst where type = 'ITEMTOP10' and prt_yn = 'Y')
																																																	 WHERE convert(char(6),(case when 'ISSUE' = :as_flag then ( case when b.do_date > b.issue_date then b.issue_date else b.do_date end  ) else b.do_date end),112) = convert(char(6), dateadd(year, - 1, substring(:as_sdate,1,4)+substring(:as_sdate,6,2)+'01'),112)
																																														  union all
																																														 SELECT cust_no         = b.cust_no
																																																		  , item_no         = a.item_no  
																																																		  , pre_yinv          = 0
																																																		  , cur_inv          = 0
																																																		  , bsale_amt     = 0    
																																																		  , cur_minv_s       = (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price)
																																																		  , last_day         = 0
																																																		  , cur_minv          = 0
																																																	  FROM dodet A with(nolock) inner join do B with(nolock) ON a.do_no = b.do_no
																																																																	 inner join itemtop10 G with(nolock) on a.item_no   = g.item_no and g.category in (select item_cd  from codemst where type = 'ITEMTOP10' and prt_yn = 'Y') 
																																																	 WHERE convert(char(6), (case when 'ISSUE' = :as_flag then ( case when b.do_date > b.issue_date then b.issue_date else b.do_date end  ) else b.do_date end) ,112) = substring(:as_sdate,1,4)+substring(:as_sdate,6,2)
																																														  union all
																																															select cust_no         = a.cust_no
																																																				  , item_no         = ''
																																																				  , pre_yinv          = 0
																																																				  , cur_inv          = 0
																																																				  , bsale_amt     = 0    
																																																				  , cur_minv_s       = 0
																																																				  , last_day         = 0
																																																				  , cur_minv          = sum(a.cur_minv)
																																															from
																																																(
																																																SELECT distinct	cust_no         = b.cust_no
																																																			, b.do_no
																																																				  , item_no         = ''
																																																				  , pre_yinv          = 0
																																																				  , cur_inv          = 0
																																																				  , bsale_amt     = 0    
																																																				  , cur_minv_s       = 0
																																																				  , last_day         = 0
																																																				  , cur_minv          = (b.do_total) / 1.1
																																																			  FROM dodet A with(nolock) inner join do B with(nolock) ON a.do_no = b.do_no																																																																	 
																																																			 WHERE convert(char(6), (case when 'ISSUE' = :as_flag then ( case when b.do_date > b.issue_date then b.issue_date else b.do_date end  ) else b.do_date end) ,112) = substring(:as_sdate,1,4)+substring(:as_sdate,6,2)
																																															) a 
																																															group by a.cust_no                      
																									
																																											  ) a 
																																											  group by a.cust_no
																																								  ) o_bf ON c.cust_no = o_bf.cust_no  
																																		 LEFT OUTER JOIN opeom    o_af with(nolock) ON c.cust_no = o_af.cust_no  AND convert(char(4), o_af.eom_year, 112) = substring(:as_sdate,1,4)
																													 LEFT OUTER JOIN login     L  with(nolock) ON c.salesman = l.user_id
																																 WHERE ( c.cust_flag   = 'N' )
																														 AND ( c.cust_type <> 'E' )
																																 GROUP BY c.cust_no, c.salesman, l.user_name
            															  ) AA
            															  LEFT OUTER JOIN codemst   M  with(nolock) ON aa.cust_no  = m.item_cd  AND m.type = '내부업체' AND m.use_yn ='Y'    
            					 group by (case when m.item_cd IS NOT NULL then 'insite' else aa.salesman end)

         ) Z
			LEFT OUTER JOIN (
									SELECT salesman  = a.salesman
										  , un_outamt = sum(a.un_outamt) / 1000
									  FROM (
											 SELECT salesman  = c.salesman
													, cust_no   = a.cust_no             
													, cust_name = c.cust_name
													, un_outamt = dbo.uf_getqty(b.item_no, b.qa ,b.uom,( b.order_qty - b.rlse_qty ) ) * b.price
												FROM sale      A   
													  LEFT OUTER JOIN saledet   B ON a.order_no = b.order_no
																							INNER JOIN itemtop10 G ON B.item_no = G.item_no and G.category in (select item_cd  from codemst where type = 'ITEMTOP10' and prt_yn = 'Y')
													  LEFT OUTER JOIN customer  C ON a.cust_no  = c.cust_no
											  WHERE ( b.order_qty        > b.rlse_qty  )
												 AND ( a.open_close       = 'O'           )
												 AND ( a.due_date   BETWEEN DateAdd(day, - 30, convert(date, replace(:as_edate,'/',''), 112)) AND DateAdd(day, 30, convert(date, replace(:as_edate,'/',''), 112)) )
											 ) A
									 GROUP BY a.salesman
									) ZZ ON Z.salesman = ZZ.salesman
         LEFT OUTER JOIN (
                                                    SELECT DISTINCT  seq              = a.seq          /* 순서       */
                                                                                   , area              = a.area         /* 권역       */
                                                                                   , sector           = a.sector       /* 본부       */
                                                                                   , team             = a.team         /* 팀         */
                                                                                   , user_id         = a.user_id      /* 담당자     */
                                                                                   , user_name   = a.user_name    /* 담당자명   */
                                                                                   , rank              = a.rank         /* 직책       */
                                                      FROM (
                                                                       SELECT seq         = a.seq          /* 순서       */
                                                                            , area        = a.area         /* 권역       */
                                                                            , sector      = a.sector       /* 본부       */
                                                                            , team        = a.team         /* 팀         */
                                                                            , user_id     = a.user_id      /* 담당자     */
                                                                            , user_name   = a.user_name    /* 담당자명   */
                                                                            , rank        = a.rank         /* 직책       */                                                         
                                                                         FROM UF_MyMembers( :as_salesman ) M 
                                                                              LEFT OUTER JOIN opeom_org A with(nolock) ON m.user_id = a.user_id                                                         
                                                                       UNION ALL
                                                                       /* 내부업체(insite) */
                                                                       SELECT seq         = a.seq          /* 순서       */
                                                                            , area        = a.area         /* 권역       */
                                                                            , sector      = a.sector       /* 본부       */
                                                                            , team        = a.team         /* 팀         */
                                                                            , user_id     = a.user_id      /* 담당자     */
                                                                            , user_name   = a.user_name    /* 담당자명   */
                                                                            , rank        = a.rank         /* 직책       */
                                                                         FROM opeom_org A  with(nolock)
                                                                        WHERE (a.user_id     = 'insite')
                                                                          AND (:as_salesman  = '%' OR :as_salesman = dbo.UF_INSITE() )
                                                                  ) A
                                            ) O  ON o.user_id = z.salesman
   WHERE o.seq  IS NOT NULL
   ORDER BY o.seq" arguments=(("as_salesman", string),("ai_year", number),("ai_month", number),("as_sdate", string),("as_edate", string),("as_flag", string))  sort="seq A user_id A " )
group(level=1 header.height=0 trailer.height=104 by=("area" ) header.color="536870912" trailer.color="536870912" )
group(level=2 header.height=0 trailer.height=88 by=("sector" ) header.color="536870912" trailer.color="536870912" )
group(level=3 header.height=0 trailer.height=88 by=("team" ) header.color="536870912" trailer.color="553648127" )
text(band=header alignment="0" text="(매출: V.A.T별도, 수금: V.A.T포함, 단위: 천원)" border="0" color="33554432" x="18" y="404" height="60" width="1554" html.valueishtml="0"  name=t_32 visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="553648127" )
text(band=header alignment="2" text="담  당" border="0" color="0" x="338" y="556" height="60" width="338" html.valueishtml="0"  name=t_29 visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="553648127" )
