$PBExportComments$환율관리(1998/05/01,성삼지)
release 5;
datawindow(units=0 timer_interval=0 color=79741120 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no )
header(height=85 color="536870912" )
summary(height=1 color="536870912" )
footer(height=1 color="536870912" )
detail(height=81 color="536870912" )
table(column=(type=datetime update=yes updatewhereclause=yes key=yes name=curr_date dbname="currency.curr_date" )
 column=(type=char(3) update=yes updatewhereclause=yes key=yes name=curr_code dbname="currency.curr_code" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=exp_rate dbname="currency.exp_rate" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=rev_rate dbname="currency.rev_rate" initial="0" )
 column=(type=char(30) update=yes updatewhereclause=yes name=rem dbname="currency.rem" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"currency~" ) COLUMN(NAME=~"currency.curr_date~") COLUMN(NAME=~"currency.curr_code~") COLUMN(NAME=~"currency.exp_rate~") COLUMN(NAME=~"currency.rev_rate~") COLUMN(NAME=~"currency.rem~")WHERE(    EXP1 =~"currency.curr_code~"   OP =~"=~"    EXP2 =~":as_currcode~" ) ) ORDER(NAME=~"currency.curr_date~" ASC=no) ARG(NAME = ~"as_currcode~" TYPE = string) " update="currency" updatewhere=1 updatekeyinplace=no arguments=(("as_currcode", string)) )
