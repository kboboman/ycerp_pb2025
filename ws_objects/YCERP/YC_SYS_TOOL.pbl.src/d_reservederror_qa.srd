table(column=(type=decimal(4) updatewhereclause=yes name=item_sales_reserved dbname="item.sales_reserved" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="item.qa" )
 column=(type=decimal(4) updatewhereclause=yes name=reservedqoh dbname="reservedqoh" )
 retrieve="PBSELECT( VERSION(400) DISTINCT ()TABLE(NAME=~"item~" )  TABLE(NAME=~"itemloc~" ) COLUMN(NAME=~"item.sales_reserved~") COLUMN(NAME=~"item.qa~") COMPUTE(NAME=~"sum(itemloc.reserved) reservedqoh~")    JOIN (LEFT=~"item.item_no~"    OP =~"=~"RIGHT=~"itemloc.item_no~"    OUTER1 =~"item.item_no~" )    JOIN (LEFT=~"item.qa~"    OP =~"=~"RIGHT=~"itemloc.qa~"    OUTER1 =~"item.qa~" )WHERE(    EXP1 =~"item.item_no~"   OP =~"=~"    EXP2 =~":as_item~" )  GROUP(NAME=~"item.item_no~") GROUP(NAME=~"item.qa~") GROUP(NAME=~"item.sales_reserved~")   HAVING (   EXP1 =~"item.sales_reserved~"   OP =~"<>~"    EXP2 =~"sum(itemloc.reserved)~" )) ARG(NAME = ~"as_item~" TYPE = string) " arguments=(("as_item", string)) )
column(band=detail id=2 alignment="0" tabsequence=32766 border="0" color="0" x="14" y="8" height="60" width="640" format="[general]"  name=qa edit.limit=0 edit.case=any edit.autoselect=yes  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="0" background.color="536870912~tif (getrow() = currentrow(), RGB(254,252,175), 78682240)" )
