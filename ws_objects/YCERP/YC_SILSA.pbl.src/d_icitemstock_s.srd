$PBExportHeader$d_icitemstock_s.srd
$PBExportComments$장기재고조회(2003/08/25, 이인호)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=84 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=76 color="536870912"  height.autosize=yes)
table(column=(type=char(10) updatewhereclause=yes name=loc_no dbname="itemstock.loc_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="itemstock.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="itemstock.qa" )
 column=(type=decimal(0) updatewhereclause=yes name=qty dbname="itemstock.qty" )
 column=(type=char(60) updatewhereclause=yes name=reason1 dbname="itemstock.reason1" )
 column=(type=char(60) updatewhereclause=yes name=reason2 dbname="itemstock.reason2" )
 column=(type=char(60) updatewhereclause=yes name=reason3 dbname="itemstock.reason3" )
 column=(type=char(10) updatewhereclause=yes name=chk1_user dbname="itemstock.chk1_user" )
 column=(type=char(10) updatewhereclause=yes name=chk2_user dbname="itemstock.chk2_user" )
 column=(type=datetime updatewhereclause=yes name=user_date dbname="itemstock.user_date" )
 column=(type=char(1) updatewhereclause=yes name=reason_code dbname="itemstock.reason_code" initial="Z" )
 column=(type=decimal(4) updatewhereclause=yes name=loc_qoh dbname="loc_qoh" )
 column=(type=char(186) updatewhereclause=yes name=reason dbname="reason" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(30) updatewhereclause=yes name=location_loc_name dbname="location.loc_name" )
 retrieve="  SELECT itemstock.loc_no   
       , itemstock.item_no   
       , itemstock.qa   
       , itemstock.qty   
       , itemstock.reason1   
       , itemstock.reason2   
       , itemstock.reason3   
       , itemstock.chk1_user   
       , itemstock.chk2_user   
       , itemstock.user_date   
       , itemstock.reason_code   
       , loc_qoh  = isnull(itemloc.qoh, 0)   
       , reason   = rtrim(itemstock.reason1) 
                  + (case when itemstock.reason1 is null or rtrim(itemstock.reason1) = '' then '' else ' | ' end)
                  + rtrim(itemstock.reason2) 
                  + (case when itemstock.reason2 is null or rtrim(itemstock.reason2) = '' then '' else ' | ' end)
                  + rtrim(itemstock.reason3)
       , groupitem.item_name   
       , location.loc_name 
    FROM itemstock inner join groupitem on  itemstock.item_no = groupitem.item_no
						  inner join location on itemstock.loc_no = location.loc_no
						  left outer join itemloc on itemstock.loc_no = itemloc.loc_no and itemstock.item_no = itemloc.item_no and itemstock.qa = itemloc.qa			
   WHERE  ( itemstock.loc_no      = :as_loc )  AND
                   ( 
                           :as_sdate  = '%' AND itemstock.user_date LIKE '%'
                           OR
                           :as_sdate <> '%' AND itemstock.user_date   >= :as_sdate
                   ) 
/*
    FROM itemstock
       , groupitem   
       , location
       , itemloc
   WHERE ( itemstock.item_no     = groupitem.item_no ) 
     AND ( itemstock.loc_no      = location.loc_no   ) 
     AND ( itemstock.loc_no     *= itemloc.loc_no    ) 
     AND ( itemstock.item_no    *= itemloc.item_no   ) 
     AND ( itemstock.qa         *= itemloc.qa        ) 
     AND ( itemstock.loc_no      = :as_loc           ) 
     AND ( :as_sdate  = '%' AND itemstock.user_date LIKE '%'
           OR
           :as_sdate <> '%' AND itemstock.user_date   >= :as_sdate
         ) 
*/" arguments=(("as_loc", string),("as_sdate", string))  sort="groupitem_item_name A qa A user_date A " )
