$PBExportHeader$d_ocaroivc_openclose.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=84 color="536870912" )
summary(height=0 color="536870912" )
footer(height=88 color="8421504" )
detail(height=92 color="536870912" )
table(column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" values="	Y/	N" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(12) updatewhereclause=yes name=vc_no dbname="vc_no" )
 column=(type=decimal(4) updatewhereclause=yes name=amount dbname="amount" )
 column=(type=char(1) updatewhereclause=yes name=open_close dbname="open_close" values="마감	C/오픈	O/이관	T/" )
 column=(type=datetime updatewhereclause=yes name=oi_date dbname="oi_date" )
 column=(type=datetime updatewhereclause=yes name=close_date dbname="close_date" )
 retrieve="SELECT chk         = 'N'
     , cust_no     = aroivc.cust_no
     , cust_name   = customer.cust_name
     , vc_no       = aroivc.vc_no
     , amount      = aroivc.amount
     , open_close  = aroivc.open_close
     , oi_date     = aroivc.oi_date
     , close_date  = aroivc.close_date
  FROM aroivc
       LEFT OUTER JOIN customer ON aroivc.cust_no = customer.cust_no
 WHERE ( oi_date BETWEEN :ad_sdate AND :ad_edate )
   AND ((:as_openclose   = '%' ) OR
        (:as_openclose  <> '%' AND aroivc.open_close = :as_openclose)
       )


" arguments=(("ad_sdate", date),("ad_edate", date),("as_openclose", string))  sort="oi_date D cust_name A " )
