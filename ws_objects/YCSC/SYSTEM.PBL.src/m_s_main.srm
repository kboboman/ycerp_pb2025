global type m_s_main from menu
m_manage m_manage
m_retrieve m_retrieve
m_window m_window
end type
global m_s_main m_s_main

on m_s_main.create
m_s_main=this
call super::create
this.m_manage=create m_manage
this.m_retrieve=create m_retrieve
this.m_window=create m_window
this.Item[UpperBound(this.Item)+1]=this.m_manage
this.Item[UpperBound(this.Item)+1]=this.m_retrieve
this.Item[UpperBound(this.Item)+1]=this.m_window
end on

on m_s_main.destroy
call super::destroy
destroy(this.m_manage)
destroy(this.m_retrieve)
destroy(this.m_window)
end on

type m_manage from menu within m_s_main
m_reg m_reg
m_auth m_auth
m_codemst_m m_codemst_m
m_- m_-
m_user m_user
m_globals_m m_globals_m
