 column=(type=char(11) update=yes updatewhereclause=yes name=scene_code dbname="DoTransDET.scene_code" )
 retrieve="SELECT DoTransDET.trans_no
		, DoTransDET.seq_no
		, DoTransDET.do_no
		, DoTransDET.trans_amt
		, DoTransDET.bigo
		, DoTransDET.cust_no
		, DoTransDET.scene_code  
FROM DoTransDET
WHERE DoTransDET.trans_no = :as_trans_no
" update="DoTransDET" updatewhere=1 updatekeyinplace=no arguments=(("as_trans_no", string)) )
