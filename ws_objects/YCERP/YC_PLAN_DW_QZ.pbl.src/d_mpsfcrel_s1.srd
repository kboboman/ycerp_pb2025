$PBExportComments$작업지시서 조회(1998/5/8,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(17) updatewhereclause=yes name=order_no dbname="mps.order_no" )
 column=(type=char(10) updatewhereclause=yes name=wc_no dbname="mps.wc_no" )
 retrieve="  SELECT DISTINCT mps.order_no
       , mps.wc_no  
    FROM mpsdet  
         LEFT OUTER JOIN mps ON mpsdet.order_no = mps.order_no         
   WHERE ( mps.area_no            = :as_area )   
     AND ((:as_wc    = '%') OR
          (:as_wc   <> '%' AND mps.wc_no = :as_wc )
         )
     AND ( mps.start_date         = :as_date )
     AND ( mpsdet.mpsorder_order is null     )
" arguments=(("as_wc", string),("as_date", date),("as_area", string))  sort="order_no A " )
