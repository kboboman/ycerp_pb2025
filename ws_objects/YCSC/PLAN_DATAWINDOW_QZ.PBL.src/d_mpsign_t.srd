$PBExportComments$생산계획확정(1999/06/03, 이인호)
release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=72 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=char(17) updatewhereclause=yes name=mps_order_no dbname="mps.order_no" )
 column=(type=char(20) updatewhereclause=yes name=wc_work_name dbname="wc.work_name" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"mps~" )  TABLE(NAME=~"wc~" ) COLUMN(NAME=~"mps.order_no~") COLUMN(NAME=~"wc.work_name~")    JOIN (LEFT=~"mps.wc_no~"    OP =~"=~"RIGHT=~"wc.work_no~" )WHERE(    EXP1 =~"( mps.open_close~"   OP =~"=~"    EXP2 =~"'A')~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"mps.area_no~"   OP =~"=~"    EXP2 =~":as_area~" ) ) ORDER(NAME=~"mps.order_no~" ASC=no) ARG(NAME = ~"as_area~" TYPE = string) " arguments=(("as_area", string)) )
text(band=header alignment="2" text="생산계획번호"border="2" color="0" x="9" y="8" height="60" width="544"  name=mps_order_no_t  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="15780518" )
text(band=header alignment="2" text="작업장명"border="2" color="0" x="558" y="8" height="60" width="672"  name=wc_work_name_t  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="15780518" )
column(band=detail id=1 alignment="0" tabsequence=32766 border="0" color="0" x="9" y="4" height="60" width="544" format="[general]"  name=mps_order_no  tag="생산계획번호" edit.limit=17 edit.case=any edit.autoselect=yes edit.autohscroll=yes  font.face="굴림체" font.height="-10" font.weight="400"  font.family="2" font.pitch="2" font.charset="129" background.mode="0" background.color="536870912~tif(getrow()=currentrow(), rgb(254, 252, 175), 1087434968)" )
column(band=detail id=2 alignment="0" tabsequence=32766 border="0" color="0" x="558" y="4" height="60" width="672" format="[general]"  name=wc_work_name  tag="작업장이름" edit.limit=20 edit.case=any edit.autoselect=yes edit.autohscroll=yes  font.face="굴림체" font.height="-10" font.weight="400"  font.family="2" font.pitch="2" font.charset="129" background.mode="0" background.color="536870912~tif(getrow()=currentrow(), rgb(254, 252, 175), 1087434968)" )
