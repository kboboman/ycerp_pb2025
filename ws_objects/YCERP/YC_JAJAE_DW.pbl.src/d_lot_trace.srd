 column=(type=long updatewhereclause=yes name=sfc_cnt dbname="sfc_cnt" )
 column=(type=decimal(4) updatewhereclause=yes name=sfc_unitqty dbname="sfc_unitqty" )
 column=(type=decimal(4) updatewhereclause=yes name=sfc_useqty dbname="sfc_useqty" )
 column=(type=char(10) updatewhereclause=yes name=rem_locno dbname="rem_locno" )
 column=(type=char(30) updatewhereclause=yes name=rem_locname dbname="rem_locname" )
 column=(type=char(6) updatewhereclause=yes name=cat dbname="cat" )
 retrieve="  SELECT coil_no         = b.coil_no                 
       , coil_name       = j.item_name
       , wid             = (select top 1 wid      from coilmst where coil_no = b.coil_no)
       , unitqty         = (select top 1 unit_qty from coilmst where coil_no = b.coil_no)
       , coilorder       = coilorder_order           
       , product_no      = b.product_no              
       , order_no        = a.pur_no      
       , insp_no         = a.insp_no                 
       , oi_no           = a.oi_no                   
       , lot_no          = a.coil_no        
       , serial_no       = b.serial_no               

       , item_no         = a.item_no                 
       , item_name       = f.item_name
       , qa              = a.qa                      
       , uom             = a.uom                     
       , rcpt_qty        = a.rcpt_qty                
       , loc_no          = a.loc_no                  
       , loc_name        = d.loc_name
       , cnt             = a.cnt                     
       , comqty          = a.comqty                  
       , unit_qty        = a.unit_qty                

       , order_qty       = b.order_qty               
       , rcpt_loc        = b.rcpt_loc                
       , rcpt_name       = e.loc_name                

       , sfcorderno      = g.do_no 
       , wc_no           = g.cust_no   
       , work_name       = g.cust_name   
       , use_date        = g.do_date   
       , sfc_cnt         = g.cnt   
       , sfc_unitqty     = g.unit_qty   
       , sfc_useqty      = g.real_qty           
       , rem_locno       = g.loc_no 
       , rem_locname     = g.loc_name 
       , cat             = g.sos
    FROM inspdet a                                                  /* 발주입고 */
         LEFT OUTER JOIN purdet b       ON a.pur_no   = b.order_no AND a.seq_no = b.seq_no /* 발주서   */
         LEFT OUTER JOIN coilorderdet c ON b.coil_no  = c.coil_no   /* */
         LEFT OUTER JOIN location     d ON a.loc_no   = d.loc_no
         LEFT OUTER JOIN location     e ON b.rcpt_loc = e.loc_no
         LEFT OUTER JOIN groupitem    f ON a.item_no  = f.item_no
         LEFT OUTER JOIN groupitem    j ON b.item_no  = j.item_no
         LEFT OUTER JOIN V_DO_SFCUSE  g ON a.coil_no  = g.coil_no   /* 판매, 사용자재 */
   WHERE b.coil_no        = :as_coilno
   ORDER BY insp_no, oi_no, serial_no
   " arguments=(("as_coilno", string)) )
