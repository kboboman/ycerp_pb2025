type dw_5 from datawindow within tabpage_2
integer x = 14
integer y = 108
integer width = 3456
integer height = 1140
integer taborder = 40
string title = "none"
string dataobject = "d_lot_trace2"
boolean hscrollbar = true
boolean vscrollbar = true
boolean hsplitscroll = true
boolean livescroll = true
borderstyle borderstyle = stylelowered!
end type

event clicked;// 스리팅지시
string ls_orderno, ls_lotno, ls_pcoilno

if this.rowcount() < 1 then RETURN

debugbreak()
dw6.reset()		// 발주서
dw7.reset()		// 발주입고

ls_orderno = this.object.order_no[row]
choose case dwo.name
	case "pcoil_no"
		ls_lotno   = this.object.pcoil_no[row]
	case "lot_no"
		ls_lotno   = this.object.lot_no[row]
	case else
		ls_lotno   = this.object.lot_no[row]
end choose

// 이전코일 조회
SELECT top 1 pcoil_no INTO :ls_pcoilno FROM coilmst WHERE coil_no = :ls_lotno;
tab_1.tabpage_1.sle_pcoil.text   = ls_pcoilno

if cbx_13.checked = true then		// 스리팅계획 추적
	tab_1.tabpage_1.sle_lotno.text   = ls_lotno

	dw4.reset()		// 스리팅계획
	dw4.retrieve( ls_lotno )   // 스리팅계획

	tab_1.selectedtab = 1
	tab_1.postevent( selectionchanged! )
else
	dw6.retrieve( ls_orderno )		// 발주서
	dw8.retrieve( ls_lotno )		// 코일이동
	dw9.retrieve( ls_lotno )		// 작업일보등록

	if dw6.rowcount() > 0 then
		tab_1.selectedtab = 3
		tab_1.postevent( selectionchanged! )
	else
		if dw8.rowcount() > 0 then
			tab_1.selectedtab = 5
			tab_1.postevent( selectionchanged! )
		end if
	end if
end if

end event

