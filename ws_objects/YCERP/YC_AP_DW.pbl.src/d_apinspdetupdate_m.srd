 column=(type=char(14) update=yes updatewhereclause=yes key=yes name=insp_no dbname="inspdet.insp_no" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=oi_no dbname="inspdet.oi_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="inspdet.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="inspdet.qa" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=rcpt_qty dbname="inspdet.rcpt_qty" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="inspdet.uom" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=price dbname="inspdet.price" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=apoi_qty dbname="inspdet.apoi_qty" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=rate_cash dbname="inspdet.rate_cash" )
 column=(type=char(14) update=yes updatewhereclause=yes name=pur_no dbname="inspdet.pur_no" )
 column=(type=long update=yes updatewhereclause=yes name=seq_no dbname="inspdet.seq_no" )
 column=(type=char(50) update=yes updatewhereclause=yes name=rem dbname="inspdet.rem" )
 column=(type=char(10) update=yes updatewhereclause=yes name=loc_no dbname="inspdet.loc_no" )
 column=(type=long update=yes updatewhereclause=yes name=cnt dbname="inspdet.cnt" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=comqty dbname="inspdet.comqty" )
 column=(type=char(3) updatewhereclause=yes name=insp_curr_code dbname="insp.curr_code" )
 column=(type=char(10) updatewhereclause=yes name=supp_no dbname="insp.supp_no" )
 column=(type=datetime updatewhereclause=yes name=insp_date dbname="insp.insp_date" )
 column=(type=char(1) updatewhereclause=yes name=close_yn dbname="insp.close_yn" )
 column=(type=char(1) updatewhereclause=yes name=subcon dbname="pur.subcon" )
 column=(type=char(1) updatewhereclause=yes name=purdet_work_type dbname="purdet.work_type" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=unit_qty dbname="inspdet.unit_qty" )
 column=(type=char(17) updatewhereclause=yes name=product_no dbname="purdet.product_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=coil_no dbname="inspdet.coil_no" )
 column=(type=char(1) updatewhereclause=yes name=pur_tax_sign dbname="pur.tax_sign" )
 column=(type=char(30) updatewhereclause=yes name=location_loc_name dbname="location.loc_name" )
 column=(type=char(1) updatewhereclause=yes name=supp_round dbname="supp.round" )
 column=(type=char(2) update=yes updatewhereclause=yes name=com_uom dbname="inspdet.com_uom" )
 column=(type=char(2) updatewhereclause=yes name=coilmst_etc_no dbname="coilmst.etc_no" )
 column=(type=char(20) updatewhereclause=yes name=purdet_coil_no dbname="purdet.coil_no" )
 column=(type=long updatewhereclause=yes name=serial_no dbname="purdet.serial_no" )
 column=(type=char(14) updatewhereclause=yes name=sale_no dbname="purdet.sale_no" )
 column=(type=long updatewhereclause=yes name=sale_seq dbname="purdet.sale_seq" )
 column=(type=char(20) updatewhereclause=yes name=supp_coil_no dbname="purdet.supp_coil_no" )
 column=(type=long updatewhereclause=yes name=wlen dbname="purdet.wlen" )
 column=(type=char(20) updatewhereclause=yes name=origin_supp_coil_no dbname="purdet.origin_supp_coil_no" )
 column=(type=long updatewhereclause=yes name=origin_wlen dbname="purdet.origin_wlen" )
 column=(type=char(1) updatewhereclause=yes name=ingubun dbname="purdet.ingubun" )
 column=(type=char(80) updatewhereclause=yes name=supply_addr dbname="pur.supply_addr" )
 column=(type=char(15) updatewhereclause=yes name=supply_tel dbname="pur.supply_tel" )
 column=(type=char(20) updatewhereclause=yes name=coilsliting_coil_no dbname="coilsliting.coilsliting_coil_no" )
 column=(type=decimal(4) updatewhereclause=yes name=coilsliting_unit_qty dbname="coilsliting.coilsliting_unit_qty" )
 column=(type=char(2) updatewhereclause=yes name=iotype dbname="iotype" )
 column=(type=decimal(8) updatewhereclause=yes name=camt dbname="camt" )
 column=(type=char(50) updatewhereclause=yes name=sale_rem dbname="purdet.sale_rem" )
 retrieve="SELECT 
	  item.item_name      
	, item.source         
	, inspdet.insp_no     
	, inspdet.oi_no       
	, inspdet.item_no     
	, inspdet.qa          
	, inspdet.rcpt_qty    
	, inspdet.uom         
	, inspdet.price       
	, inspdet.apoi_qty    
	, inspdet.rate_cash   
	, inspdet.pur_no      
	, inspdet.seq_no      
	, inspdet.rem         
	, inspdet.loc_no      
	, inspdet.cnt         
	, inspdet.comqty      
	, insp.curr_code      
	, insp.supp_no
	, insp.insp_date
	, insp.close_yn
	, pur.subcon subcon
	, purdet.work_type    
	, inspdet.unit_qty    
	, purdet.product_no   
	, inspdet.coil_no     
	, pur.tax_sign        
	, location.loc_name   
	, supp.round          
	, inspdet.com_uom  
	, coilmst.etc_no
	, purdet.coil_no
	, purdet.serial_no
	, purdet.sale_no
	, purdet.sale_seq
	, purdet.supp_coil_no  
	, purdet.wlen
	, purdet.supp_coil_no  origin_supp_coil_no
	, purdet.wlen			   origin_wlen
	, purdet.ingubun
	, pur.supply_addr
	, pur.supply_tel
	, coilsliting.coil_no coilsliting_coil_no
	, coilsliting.unit_qty coilsliting_unit_qty
	, (case when pur.subcon = 'N' then 'RI'
			when pur.subcon = 'Y' then 'RI'
			when pur.subcon = 'W' then 'RI'
			when pur.subcon = 'L' then 'RI'
		else 'RO' end) iotype
	, camt  = isnull((case when supp.round = 'Y' then ROUND(comqty * inspdet.price, 0, 0) 
									else ROUND(comqty * inspdet.price, 0, 1) 
							 end), 0)
	, purdet.sale_rem	sale_rem
FROM 
	insp      
		LEFT OUTER JOIN inspdet  ON insp.insp_no    = inspdet.insp_no
		LEFT OUTER JOIN item     ON inspdet.item_no = item.item_no AND inspdet.qa = item.qa
		LEFT OUTER JOIN pur      ON inspdet.pur_no  = pur.order_no
		LEFT OUTER JOIN purdet   ON inspdet.pur_no  = purdet.order_no AND inspdet.seq_no = purdet.seq_no
		LEFT OUTER JOIN coilmst  ON inspdet.coil_no = coilmst.coil_no AND inspdet.loc_no = coilmst.loc_no
		LEFT OUTER JOIN location ON inspdet.loc_no  = location.loc_no
		LEFT OUTER JOIN supp     ON insp.supp_no    = supp.supp_no
		LEFT OUTER JOIN coilsliting on purdet.product_no = coilsliting.order_no and purdet.serial_no = coilsliting.seq
WHERE 
	insp.insp_no    LIKE :as_inspno
" update="inspdet" updatewhere=0 updatekeyinplace=no arguments=(("as_inspno", string))  sort="oi_no A " )
