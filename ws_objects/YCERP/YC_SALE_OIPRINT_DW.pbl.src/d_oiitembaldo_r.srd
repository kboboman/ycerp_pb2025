$PBExportHeader$d_oiitembaldo_r.srd
$PBExportComments$제품별 제품출고및 미출고조회(1998/5/14,성삼지)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="cust_name" )
 column=(type=char(10) updatewhereclause=yes name=saledet_item_no dbname="item_no" )
 column=(type=char(20) updatewhereclause=yes name=saledet_qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=saledet_uom dbname="uom" )
 column=(type=datetime updatewhereclause=yes name=sale_due_date dbname="due_date" initial=" " )
 column=(type=char(14) updatewhereclause=yes name=sale_order_no dbname="order_no" initial=" " )
 column=(type=long updatewhereclause=yes name=saledet_seq_no dbname="seq_no" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_order_qty dbname="order_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_rlse_qty dbname="rlse_qty" )
 column=(type=decimal(5) updatewhereclause=yes name=not_issue dbname="not_issue" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene_desc" )
 column=(type=char(20) updatewhereclause=yes name=customer_bus_cord dbname="bus_cord" )
 column=(type=char(20) updatewhereclause=yes name=customer_bus_rep dbname="bus_rep" )
 column=(type=char(30) updatewhereclause=yes name=customer_industry_code dbname="industry_code" )
 column=(type=char(6) updatewhereclause=yes name=sta dbname="sta" )
 column=(type=decimal(2) updatewhereclause=yes name=acc_qty dbname="acc_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=price dbname="price" )
 retrieve="  SELECT distinct c.cust_name   
       , sd.item_no   
       , sd.qa   
       , sd.uom   
       , s.due_date   
       , s.order_no   
       , sd.seq_no   
       , sd.order_qty   
       , sd.rlse_qty
       , not_issue = dbo.uf_getqty( sd.item_no, sd.qa, sd.uom, sd.order_qty - sd.rlse_qty)
       , g.item_name   
       , sc.scene_desc   
       , c.bus_cord   
       , c.bus_rep   
       , c.industry_code
       , sta       = DBO.UF_GetSaleStatus(sd.order_no, sd.seq_no)
       , sd.acc_qty
       , sd.price
    FROM UF_MyCustomers( :as_salesman ) M
         LEFT OUTER JOIN customer   C ON m.cust_no     = c.cust_no
         LEFT OUTER JOIN sale       S ON m.cust_no     = s.cust_no AND s.open_close = 'O'
         LEFT OUTER JOIN saledet   SD ON s.order_no    = sd.order_no 
         LEFT OUTER JOIN groupitem  G ON sd.item_no    = g.item_no
         LEFT OUTER JOIN scene     SC ON s.scene_code  = sc.scene_code
         LEFT OUTER JOIN login      L ON c.salesman    = l.user_id
   WHERE ( s.area_no        LIKE :as_area ) 
     AND ( s.order_date  BETWEEN :as_sdate AND :as_edate ) 
     AND ((:as_team  = '%' AND m.cust_no   LIKE '%'  ) OR 
          (:as_team <> '%' AND m.salesman     = :as_salesman )
         )
     AND ((:as_custno  = '%'   AND m.cust_no   LIKE '%'  ) OR 
          (:as_custno  = 'ALL' AND m.cust_no   LIKE '%'  ) OR 
          (:as_custno <> 'ALL' AND m.cust_no      = :as_custno )
         )
/*     AND ( (:as_itemno  = '%' ) OR
          		(:as_itemno <> '%' AND sd.item_no = :as_itemno )
         	   ) */
     AND ( (:as_gubun   = '%' AND sd.item_no LIKE '%') OR
          		(:as_gubun  <> '%' AND sd.item_no IN (:as_itemno))
	      	)
     AND ( sd.order_qty      > sd.rlse_qty )
 " arguments=(("as_area", string),("as_custno", string),("as_itemno", stringlist),("as_sdate", string),("as_edate", string),("as_salesman", string),("as_team", string),("as_gubun", string))  sort="saledet_item_no A saledet_qa A sale_due_date A customer_cust_name A scene_scene_desc A sale_order_no A saledet_seq_no A " )
group(level=1 header.height=0 trailer.height=76 by=("saledet_item_no" ) header.color="536870912" trailer.color="12639424" )
