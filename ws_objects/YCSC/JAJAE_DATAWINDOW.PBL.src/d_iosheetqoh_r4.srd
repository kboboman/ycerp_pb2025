$PBExportHeader$d_iosheetqoh_r4.srd
$PBExportComments$원/스리팅 sheet재고 규격별 집계현황(2006/01/12,정갑용)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=76 color="536870912" )
summary(height=68 color="536870912" )
footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=sheetmst_item_no dbname="sheetmst.item_no" )
 column=(type=char(20) updatewhereclause=yes name=c_qa dbname="c_qa" )
 column=(type=decimal(4) updatewhereclause=yes name=c_unit_qty dbname="c_unit_qty" )
 column=(type=long updatewhereclause=yes name=c_qcnt dbname="c_qcnt" )
 column=(type=decimal(4) updatewhereclause=yes name=c_unit_sum dbname="c_unit_sum" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(1) updatewhereclause=yes name=sheetmst_flag dbname="sheetmst.flag" values="원코일	W/반제품	S/" )
 retrieve="  SELECT sheetmst.item_no,   
         c_qa = substring(sheetmst.qa,1,13),   
         c_unit_qty = sum(sheetmst.unit_qty),   
         c_qcnt = sum(sheetmst.qcnt),
			c_unit_sum = sum (sheetmst.unit_qty * sheetmst.qcnt),
         groupitem.item_name,
			sheetmst.flag
    FROM sheetmst left outer join  groupitem on sheetmst.item_no = groupitem.item_no
						 inner join  location on sheetmst.loc_no = location.loc_no
         					 left outer join  supp on sheetmst.supp_no = supp.supp_no
    where  ( ( :as_work_chk = 'N' and :as_stock_chk = 'N'  and sheetmst.loc_no in (:asa_loc) )   
  		  or ( :as_work_chk = 'Y' AND ( ( 'WW01' not in (:asa_loc) and sheetmst.loc_no in (:asa_loc) ) 
											 or  ( ( 'WW01' in (:asa_loc)) 
												and ( sheetmst.loc_no in (:asa_loc) OR ( sheetmst.loc_no in ( select loc_no from location where loc_type = 'W' or loc_type = 'Y') ) ) ) ) ) 
  		 or ( :as_stock_chk = 'Y' AND ( ( 'WW01' not in (:asa_loc) and sheetmst.loc_no in (:asa_loc) ) 
											 or  ( ( 'WW01' in (:asa_loc) ) 
												and ( sheetmst.loc_no in (:asa_loc) OR sheetmst.loc_no = 'WS00000003' ) ) ) )
			)
		and ( sheetmst.item_no in (:asa_item) )
         and ( sheetmst.flag like :as_flag )
         and ( sheetmst.open_close in ( :as_oc ) )
 			and not exists ( select * from lossitem where loss_item = sheetmst.item_no )
group by sheetmst.item_no,   
         substring(sheetmst.qa,1,13),   
         groupitem.item_name,
			sheetmst.flag
order by  sheetmst.item_no,  substring(sheetmst.qa,1,13)
" arguments=(("asa_loc", stringlist),("asa_item", stringlist),("as_flag", string),("as_oc", stringlist),("as_work_chk", string),("as_stock_chk", string))  sort="mid(sheetmst_item_no,3,1) A sheetmst_item_no A c_qa A " )
