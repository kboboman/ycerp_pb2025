text(band=header alignment="2" text="장기재고" border="0" color="0" x="1856" y="8" height="60" width="622" html.valueishtml="0"  name=longstock_qty_t visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="16777215" )
text(band=header alignment="2" text="규격" border="0" color="0" x="1038" y="8" height="60" width="809" html.valueishtml="0"  name=itemstockdet_qa_t visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="16777215" )

sparse(names="groupitem_item_name")htmltable(border="1" )
