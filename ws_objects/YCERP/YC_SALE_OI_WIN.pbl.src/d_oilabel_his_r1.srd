$PBExportHeader$d_oilabel_his_r1.srd
$PBExportComments$출고요청 리스트
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=88 color="553648127" )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(30) updatewhereclause=yes name=label_no dbname="label_no" )
 column=(type=datetime updatewhereclause=yes name=sys_date dbname="label_item.sys_date" )
 column=(type=long updatewhereclause=yes name=number dbname="number" )
 column=(type=long updatewhereclause=yes name=print_group dbname="label_item.print_group" )
 column=(type=char(19) updatewhereclause=yes name=original_label_no dbname="label_item.original_label_no" )
 retrieve="select 	substring(label_no,1,14)+'-'+substring(label_no,15,5) label_no,
			sys_date,
			count(*) number,
			print_group,
			label_no original_label_no
from label_item
where req_date    = :as_req_date
    and salesman  = :as_salesman
    and req_seq    = :as_req_seq
    and req_flag    = :as_req_flag
    and seq           = :as_seq
    and order_no  = :as_order_no
    and not EXISTS (
								SELECT * 
									 FROM v_item_fitting 
								WHERE v_item_fitting.item_no  = label_item.item_no
									  and  v_item_fitting.qa = substring(label_item.qa,1,14)+'00000'
						 )
group by  substring(label_no,1,14), sys_date, print_group, label_no " arguments=(("as_req_date", datetime),("as_salesman", string),("as_req_seq", number),("as_req_flag", string),("as_seq", number),("as_order_no", string))  sort="sys_date D label_no A " )
text(band=header alignment="2" text="라벨출력시간" border="6" color="0" x="9" y="8" height="72" width="658" html.valueishtml="0"  name=t_1 visible="1"  font.face="굴림체" font.height="-11" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="16777215" )
