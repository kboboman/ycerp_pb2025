$PBExportHeader$d_oiyspitemtype_s.srd
$PBExportComments$YSP TYPE별 실적현황(판매단가)(2000/03/06,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no  crosstab.dynamic = yes grid.lines=0 grid.columnmove=no selected.mouse=no )
header[1](height=80 color="536870912" )
header[2](height=76 color="536870912" )
header[3](height=68 color="536870912" )
summary(height=84 color="536870912" )
footer(height=0 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=group1 dbname="group1" )
 column=(type=char(20) updatewhereclause=yes name=group2 dbname="group2" )
 column=(type=char(20) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa1 dbname="qa1" )
 column=(type=number updatewhereclause=yes name=qty dbname="qty" )
 column=(type=number updatewhereclause=yes name=amt dbname="amt" )
 retrieve="  SELECT yspgroup.group1,   
         yspgroup.group2,   
         groupitem.item_name,
			qa1 = substring(dodet.qa, 1,3),
			mon = right('00' + rtrim(convert(char(2), datepart(month, do.do_date))) ,2) +~"월~",
         qty = sum(dodet.ship_qty),
         amt = sum( dodet.ship_qty  *  isnull(dodet.price, 0) )
    FROM do,   
         dodet,
			custyspitem,
			groupitem,
   		uf_yspgrouptbl() yspgroup	
   WHERE ( dodet.item_no = yspgroup.item_no ) and  
         ( do.do_no = dodet.do_no) and  
			( do.do_date between :ad_start and :ad_end ) and
         ( do.area_no = :as_area)    and
			( dodet.item_no = groupitem.item_no )    AND   
			( (:as_flag = 'A' ) OR
           (:as_flag = 'P' AND ( ( dodet.item_no like 'PCYSYS%' ) 
									  or (dodet.item_no like 'GCYSYS%') 
									  or ( dodet.item_no like ~"PCYSZ%~" ) ) ) OR
           (:as_flag = 'Q' AND not ( ( dodet.item_no like 'PCYSYS%' ) 
											or (dodet.item_no like 'GCYSYS%') 
											or ( dodet.item_no like ~"PCYSZ%~" ) ) ) )

group by yspgroup.group1,   
         yspgroup.group2,   
         do.do_date, groupitem.item_name, dodet.qa
order by yspgroup.group1,   
         yspgroup.group2,   
         do.do_date,  groupitem.item_name, dodet.qa
" arguments=(("as_area", string),("ad_start", date),("ad_end", date),("as_flag", string))  sort="group1 A group2 A item_name A qa1 A " )
