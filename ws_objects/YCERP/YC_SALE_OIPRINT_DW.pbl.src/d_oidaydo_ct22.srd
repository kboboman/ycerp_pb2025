$PBExportHeader$d_oidaydo_ct22.srd
$PBExportComments$출고집계(수주일)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no  crosstab.dynamic = yes grid.lines=0 grid.columnmove=no selected.mouse=no )
header[1](height=68 color="536870912" )
header[2](height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=92 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=category dbname="category" )
 column=(type=char(20) updatewhereclause=yes name=gtype dbname="gtype" )
 column=(type=char(20) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=number updatewhereclause=yes name=cqty dbname="cqty" )
 retrieve="  SELECT cat          = substring(a.category,1,2)
       , category     = a.category   
       , gtype        = a.gtype
       , due_date     = a.due_date + (case when :as_yymm = 'Y' then a.due_days else '(' + a.due_days + ')' end)
       , item_name    = a.item_name  
       , cqty         = a.cqty       
    FROM (
         SELECT category     = (case when 'N' = 'Y' and substring(i.category,1,2) = '16' then i.type 
                                     else isnull(i.category, '99) 미분류')
                                end)
              , gtype        = i.type
              , due_date     = (case when :as_yymm = 'Y' then convert(char(04),b.do_date,111)
                                     else convert(char(08),b.do_date,11)
                                end)
              , due_days     = (case when :as_yymm = 'Y' then ' ' + right('00'+replace(cast(datepart(m,b.do_date) as char(2)),' ',''),2)+'월'
                                     else (case when datepart(dw,b.do_date) = 1 then '일'
                                                when datepart(dw,b.do_date) = 2 then '월'
                                                when datepart(dw,b.do_date) = 3 then '화'
                                                when datepart(dw,b.do_date) = 4 then '수'
                                                when datepart(dw,b.do_date) = 5 then '목'
                                                when datepart(dw,b.do_date) = 6 then '금'
                                                when datepart(dw,b.do_date) = 7 then '토'
                                           end)
                                end)
              , item_name    = g.item_name
              , cqty         = dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty)
           FROM dodet   a with (nolock)  
                LEFT OUTER JOIN do   b      with (nolock) ON a.do_no   = b.do_no
                LEFT OUTER JOIN groupitem g with (nolock) ON a.item_no = g.item_no
                LEFT OUTER JOIN itemtop10 i with (nolock) ON a.item_no = i.item_no  
          WHERE convert(char(10),b.do_date,111) BETWEEN :as_sdate AND :as_edate
            AND ((:as_area     = '%' and b.area_no  LIKE :as_area) OR
                 (:as_area    <> '%' and b.area_no     = :as_area)
                )
         ) A
   WHERE substring(a.category,1,2) NOT IN ('08', '09', '10')
" arguments=(("as_area", string),("as_sdate", string),("as_edate", string),("as_yymm", string))  sort="category A gtype A item_name A " )
group(level=1 header.height=0 trailer.height=92 by=("category" ) header.color="536870912" trailer.color="536870912" )
group(level=2 header.height=0 trailer.height=92 by=("gtype" ) header.color="536870912" trailer.color="536870912" )
