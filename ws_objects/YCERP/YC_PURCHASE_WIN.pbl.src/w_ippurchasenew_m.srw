type cb_18 from commandbutton within tabpage_4
integer x = 1719
integer y = 4
integer width = 1211
integer height = 88
integer taborder = 40
boolean bringtotop = true
integer textsize = -10
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "수주물품별 재고현황(NEW) 가져오기"
end type

event clicked;//======================================================================
// 수주물품별 재고현황(NEW) : dw_jaego
// 거래처 검사 -> cb_14(검색) -> dw_6 선택 -> pb_5(물품이동) 반복수행
//======================================================================
long   ll_row, ll_seqno, ll_y, ll_cnt
string ls_orderno, ls_itemno, ls_qa, ls_uom, ls_supp

if dw_1.rowcount() < 1 then
	MessageBox("오류","거래처 정보를 입력 하십시오.", Exclamation!)
	return
end if

ls_supp = trim(dw_1.object.supp_no[1])
if isnull(ls_supp) or ls_supp = "" then
	MessageBox("오류","거래처를 입력하십시오.", Exclamation!)
	dw_1.setcolumn('supp_no')
	dw_1.setfocus()
	return
end if	

//======================================================================
// 거래처 검사 -> cb_14(검색) -> dw_6 선택 -> pb_5(물품이동) 반복수행
//======================================================================
ib_auto = true
//======================================================================
for ll_row = 1 to dw_jaego.rowcount()
	cb_18.text = "수주물품별 재고현황(NEW) 가져오기 " + string(ll_row) + " / " + string(dw_jaego.rowcount())
	is_orderno = dw_jaego.object.order_no[ll_row]		// 수주번호
	// !!########-###
	em_3.text  = ls_orderno //left(ls_orderno,10) + right(ls_orderno,3)
	em_3.text  = LeftA(dw_jaego.object.order_no[ll_row],10) + RightA(dw_jaego.object.order_no[ll_row],3)	

	ll_seqno   = dw_jaego.object.seq_no[ll_row]  	// 순번
	ls_itemno  = dw_jaego.object.item_no[ll_row]  	// 품목
	ls_qa      = dw_jaego.object.qa[ll_row]   	   // 규격
	ls_uom     = dw_jaego.object.item_uom[ll_row]   // 단위
	
	//==============================
	cb_14.triggerevent( clicked! )	// 수주번호 검색 dw6.retrieve 하는 trigger event
	//==============================
	for ll_y = 1 to dw6.rowcount()
		// 수주내역 조회 후 "수주물품별 재고현황(NEW)"과 동일한 품목이면 선택하기 
		if (ll_seqno = dw6.object.seq_no[ll_y]) and (ls_itemno = dw6.object.item_no[ll_y]) and &
		   (ls_qa = dw6.object.qa[ll_y]) and (ls_uom = dw6.object.uom[ll_y]) then
			dw6.SelectRow( ll_y, true )		// 품목선택
			ll_cnt = ll_cnt + 1
		end if
	next
	
	if ll_cnt > 0 then
	   //==============================
		pb_5.triggerevent( clicked! )	// 물품이동	
	   //==============================
	end if

	if ib_move = false then 
		MessageBox("확인", "물품이동 작업에서 오류가 발생하였습니다.")
		exit
	end if
	
next

//
ib_auto = false
ib_move = false
dw6.reset()
dw_jaego.reset()
cb_18.text    = "수주물품별 재고현황(NEW) 가져오기"
cb_18.enabled = false	// 수주물품별 재고현황(NEW) 가져오기
tab_1.selecttab(1)		// 발주서내역
MessageBox("확인", "수주물품별 재고현황(NEW) 가져오기 작업완료.")

end event

