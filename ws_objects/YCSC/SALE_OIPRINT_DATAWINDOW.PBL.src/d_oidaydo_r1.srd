$PBExportHeader$d_oidaydo_r1.srd
$PBExportComments$일자별 제품출고 현황(1999/6/21,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=96 color="536870912" )
detail(height=88 color="536870912" )
table(column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=decimal(2) updatewhereclause=yes name=ship_qty dbname="ship_qty" )
 column=(type=char(1) updatewhereclause=yes name=round dbname="round" )
 column=(type=decimal(4) updatewhereclause=yes name=cqty dbname="cqty" )
 column=(type=decimal(4) updatewhereclause=yes name=price dbname="price" )
 column=(type=decimal(8) updatewhereclause=yes name=cprice dbname="cprice" )
 retrieve="  SELECT a.cust_name
       , a.cust_no   
       , a.item_no   
       , a.item_name   
       , a.qa   
       , a.uom   
       , a.ship_qty   
       , a.round  
       , a.cqty
       , a.price    
       , cprice       = (case when a.round = 'Y' then 
                                   (case when a.cqty < 0 then round(a.price * a.cqty, 0) else round(a.price * a.cqty, 0) end)                         
                              else (case when a.cqty < 0 then round(a.price * a.cqty, 0, 1) else round(a.price * a.cqty + 0.000001, 0, 1) end)
                         end)
    FROM (
         SELECT customer.cust_name
              , do.cust_no   
              , dodet.item_no   
              , groupitem.item_name   
              , dodet.qa   
              , dodet.uom   
              , dodet.ship_qty   
              , round  = customer.round  
              , cqty   = round(dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty),2,1)
              , price  = dodet.price
           FROM do   
                LEFT OUTER JOIN dodet     ON do.do_no      = dodet.do_no
                LEFT OUTER JOIN groupitem ON dodet.item_no = groupitem.item_no
                LEFT OUTER JOIN customer  ON do.cust_no    = customer.cust_no
          WHERE ( do.do_date  BETWEEN :ad_start AND :ad_end ) 
            AND ((:as_area  = '%' AND do.area_no LIKE :as_area) OR
                 (:as_area <> '%' AND do.area_no    = :as_area)
                ) 
         ) A
" arguments=(("ad_start", date),("ad_end", date),("as_area", string)) )
