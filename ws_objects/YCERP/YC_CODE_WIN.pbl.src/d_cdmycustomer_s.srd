table(column=(type=char(10) updatewhereclause=yes name=user_id dbname="user_id" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(10) updatewhereclause=yes name=rank dbname="rank" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(10) updatewhereclause=yes name=ref_user dbname="ref_user" )
 column=(type=decimal(2) updatewhereclause=yes name=amt dbname="AMT" )
 retrieve="  SELECT DISTINCT user_id    = a.user_id    
       , user_name  = a.user_name  
       , rank       = a.rank       
       , cust_no    = a.cust_no    
       , cust_name  = a.cust_name  
       , ref_user   = (SELECT user_name FROM login WHERE user_id = :as_userid)
	  , B.AMT
    FROM (
         SELECT a.user_id
              , l.user_name
              , a.rank 
              , c.cust_no
              , c.cust_name              
           FROM ( /* 매출조직도별 거래처목록 */
                     SELECT DISTINCT user_id = a.user_id, rank = a.rank
                       FROM (
								 SELECT user_id, rank FROM opeom_org WHERE area_mgr   = :as_userid   /* 권역장 */
								 UNION ALL
								 SELECT user_id, rank FROM opeom_org WHERE sector_mgr = :as_userid   /* 본부장 */
								 UNION ALL
								 SELECT user_id, rank FROM opeom_org WHERE team_mgr   = :as_userid   /* 팀장   */
								 UNION ALL
								 SELECT user_id, rank FROM opeom_org WHERE user_id    = :as_userid   /* 담당   */
                            ) A
                      WHERE (:as_userid <> 'insite' AND a.user_id <> 'insite')
                ) A 
                LEFT OUTER JOIN customer C ON a.user_id = c.salesman AND c.open_close = 'O'
                LEFT OUTER JOIN login    L ON a.user_id = l.user_id
       
         UNION ALL
       
         SELECT user_id   = c.salesman
              , user_name = l.user_name
              , rank      = ''
              , cust_no   = c.cust_no
              , cust_name = c.cust_name
           FROM customer C
                LEFT OUTER JOIN login  L ON c.salesman = l.user_id
          WHERE c.cust_no IN (SELECT DISTINCT rtrim(item_cd)
                                FROM codemst (NOLOCK)  
                               WHERE (type = '내부업체' AND use_yn = 'Y')
                                 AND (:as_userid  = '%'      OR 
                                      :as_userid  = 'insite' OR
                                      :as_userid IN (SELECT item_cd FROM codemst WHERE type = '내부업체열람' AND use_yn = 'Y')
                                     )
                             )
            AND c.open_close = 'O'
       
         UNION ALL
       
         SELECT user_id   = c.salesman
              , user_name = l.user_name
              , rank      = ''
              , cust_no   = c.cust_no
              , cust_name = c.cust_name
           FROM customer C
                LEFT OUTER JOIN login  L ON c.salesman = l.user_id
          WHERE c.mgr_type   = 'H'
            AND c.open_close = 'O'
         ) A left outer join
         (
			  SELECT opeom.cust_no   
					, balbf_amount +
					  inv_01   + inv_02   +  inv_03   +   inv_04   +  inv_05   +   inv_06   +  inv_07   +   inv_08   +   inv_09   +   inv_10   +   inv_11   +   inv_12   -
					  coll_01  -  coll_02  -   coll_03  -    coll_04  -    coll_05  -    coll_06  -    coll_07  -    coll_08  -    coll_09  -     coll_10  - coll_11  - coll_12   amt
				 FROM opeom  
				WHERE ( datepart(year,opeom.eom_year) = convert(char(4), getdate(), 121) )    

	  ) B ON A.CUST_NO = B.CUST_NO
union all
  SELECT DISTINCT user_id    = a.user_id    
       , user_name  = a.user_name  
       , rank       = a.rank       
       , cust_no    = a.cust_no    
       , cust_name  = a.cust_name  
       , ref_user   = (SELECT user_name FROM login WHERE user_id = :as_userid)
	  , B.AMT
    FROM (
         SELECT a.user_id
              , l.user_name
              , a.rank 
              , c.cust_no
              , c.cust_name              
           FROM ( /* 매출조직도별 거래처목록 */
                     SELECT DISTINCT user_id = a.user_id, rank = a.rank
                       FROM (
								 SELECT user_id, rank FROM opeom_org WHERE area_mgr   = :as_userid   /* 권역장 */
								 UNION ALL
								 SELECT user_id, rank FROM opeom_org WHERE sector_mgr = :as_userid   /* 본부장 */
								 UNION ALL
								 SELECT user_id, rank FROM opeom_org WHERE team_mgr   = :as_userid   /* 팀장   */
								 UNION ALL
								 SELECT user_id, rank FROM opeom_org WHERE user_id    = :as_userid   /* 담당   */
                            ) A
                      WHERE (:as_userid <> 'insite' AND a.user_id <> 'insite')
                ) A 
                LEFT OUTER JOIN customer C ON a.user_id = c.imwon_user_id AND c.open_close = 'O'
                LEFT OUTER JOIN login    L ON a.user_id = l.user_id
       
         UNION ALL
       
         SELECT user_id   = c.imwon_user_id
              , user_name = l.user_name
              , rank      = ''
              , cust_no   = c.cust_no
              , cust_name = c.cust_name
           FROM customer C
                LEFT OUTER JOIN login  L ON c.imwon_user_id = l.user_id
          WHERE c.cust_no IN (SELECT DISTINCT rtrim(item_cd)
                                FROM codemst (NOLOCK)  
                               WHERE (type = '내부업체' AND use_yn = 'Y')
                                 AND (:as_userid  = '%'      OR 
                                      :as_userid  = 'insite' OR
                                      :as_userid IN (SELECT item_cd FROM codemst WHERE type = '내부업체열람' AND use_yn = 'Y')
                                     )
                             )
            AND c.open_close = 'O'
       
         UNION ALL
       
         SELECT user_id   = c.imwon_user_id
              , user_name = l.user_name
              , rank      = ''
              , cust_no   = c.cust_no
              , cust_name = c.cust_name
           FROM customer C
                LEFT OUTER JOIN login  L ON c.imwon_user_id = l.user_id
          WHERE c.mgr_type   = 'H'
            AND c.open_close = 'O'
         ) A left outer join
         (
			  SELECT opeom.cust_no   
					, balbf_amount +
					  inv_01   + inv_02   +  inv_03   +   inv_04   +  inv_05   +   inv_06   +  inv_07   +   inv_08   +   inv_09   +   inv_10   +   inv_11   +   inv_12   -
					  coll_01  -  coll_02  -   coll_03  -    coll_04  -    coll_05  -    coll_06  -    coll_07  -    coll_08  -    coll_09  -     coll_10  - coll_11  - coll_12   amt
				 FROM opeom  
				WHERE ( datepart(year,opeom.eom_year) = convert(char(4), getdate(), 121) )    

	  ) B ON A.CUST_NO = B.CUST_NO
" arguments=(("as_userid", string))  sort="user_name A cust_name A cust_no A " )
