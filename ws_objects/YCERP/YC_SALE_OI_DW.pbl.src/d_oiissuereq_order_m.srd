detail(height=92 color="536870912" )
table(column=(type=datetime update=yes updatewhereclause=yes key=yes name=req_date dbname="issuereq_order.req_date" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=salesman dbname="issuereq_order.salesman" )
 column=(type=char(14) update=yes updatewhereclause=yes key=yes name=order_no dbname="issuereq_order.order_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 retrieve="  SELECT issuereq_order.req_date
       , issuereq_order.salesman
       , issuereq_order.order_no
       , cust_name  = customer.cust_name
       , scene_desc = scene.scene_desc
    FROM issuereq_order
         LEFT OUTER JOIN sale     ON issuereq_order.order_no = sale.order_no
         LEFT OUTER JOIN scene    ON sale.scene_code = scene.scene_code
         LEFT OUTER JOIN customer ON sale.cust_no = customer.cust_no
   WHERE ( issuereq_order.req_date >= :ad_reqdate )
     AND ( issuereq_order.salesman  = :as_userid  )
 " update="issuereq_order" updatewhere=0 updatekeyinplace=no arguments=(("ad_reqdate", datetime),("as_userid", string)) )
