$PBExportComments$코일재고현황(스리팅)(1998,09/09,곽용덕)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=76 color="536870912" )
summary(height=68 color="536870912" )
footer(height=0 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=coilmst_coil_no dbname="coilmst.coil_no" )
 column=(type=decimal(1) updatewhereclause=yes name=coilmst_wid dbname="coilmst.wid" )
 column=(type=char(10) updatewhereclause=yes name=coilmst_item_no dbname="coilmst.item_no" )
 column=(type=char(20) updatewhereclause=yes name=coilmst_qa dbname="coilmst.qa" )
 column=(type=char(10) updatewhereclause=yes name=coilmst_loc_no dbname="coilmst.loc_no" )
 column=(type=datetime updatewhereclause=yes name=coilmst_rcpt_date dbname="coilmst.rcpt_date" )
 column=(type=long updatewhereclause=yes name=coilmst_unit_qty dbname="coilmst.unit_qty" )
 column=(type=long updatewhereclause=yes name=coilmst_length dbname="coilmst.length" )
 column=(type=long updatewhereclause=yes name=coilmst_cnt dbname="coilmst.cnt" )
 column=(type=long updatewhereclause=yes name=coilmst_qcnt dbname="coilmst.qcnt" )
 column=(type=char(4) updatewhereclause=yes name=coilmst_color_no dbname="coilmst.color_no" )
 column=(type=char(10) updatewhereclause=yes name=coilmst_supp_no dbname="coilmst.supp_no" )
 column=(type=char(1) updatewhereclause=yes name=coilmst_flag dbname="coilmst.flag" values="원코일	W/스리팅	S/" )
 column=(type=char(14) updatewhereclause=yes name=coilmst_porder_no dbname="coilmst.porder_no" )
 column=(type=long updatewhereclause=yes name=coilmst_pseq_no dbname="coilmst.pseq_no" )
 column=(type=char(1) updatewhereclause=yes name=coilmst_open_close dbname="coilmst.open_close" values="재고	O/계획	M/작업지시	P/외주가공	S/사용완료	C/" )
 column=(type=char(40) updatewhereclause=yes name=coilmst_rem dbname="coilmst.rem" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(30) updatewhereclause=yes name=location_loc_name dbname="location.loc_name" )
 column=(type=char(30) updatewhereclause=yes name=supp_supp_name dbname="supp.supp_name" )
 column=(type=char(2) updatewhereclause=yes name=coilmst_etc_no dbname="coilmst.etc_no" )
 column=(type=decimal(4) updatewhereclause=yes name=inspdet_price dbname="inspdet.price" )
 retrieve="  SELECT coilmst.coil_no,   
         coilmst.wid,   
         coilmst.item_no,   
         coilmst.qa,   
         coilmst.loc_no,   
         coilmst.rcpt_date,   
         coilmst.unit_qty,   
         coilmst.length,   
         coilmst.cnt,   
         coilmst.qcnt,   
         coilmst.color_no,   
         coilmst.supp_no,   
         coilmst.flag,   
         coilmst.porder_no,   
         coilmst.pseq_no,   
         coilmst.open_close,   
         coilmst.rem,   
         groupitem.item_name,   
         location.loc_name,   
         supp.supp_name,   
         coilmst.etc_no,
		inspdet.price  
    FROM coilmst  LEFT OUTER JOIN  groupitem ON coilmst.item_no = groupitem.item_no
                              INNER JOIN location ON coilmst.loc_no = location.loc_no
                              LEFT OUTER JOIN supp ON coilmst.supp_no = supp.supp_no
			                        LEFT OUTER JOIN inspdet  ON coilmst.coil_no = inspdet.coil_no      
   WHERE ( ( :as_work_chk = 'N' and :as_stock_chk = 'N'  and coilmst.loc_no like :as_loc )   
  		                or ( :as_work_chk = 'Y' AND ( ( :as_loc <> 'WS00000000' and :as_loc <> 'WW01' and coilmst.loc_no like :as_loc ) 
											         or  ( (:as_loc = 'WS00000000' or :as_loc = 'WW01') 
												      and ( coilmst.loc_no like :as_loc OR ( coilmst.loc_no in ( select loc_no from location where  loc_type = 'W' ) ) ) ) ) ) 
                		 or ( :as_stock_chk = 'Y' AND ( ( :as_loc <> 'WS00000000' and :as_loc <> 'WW01' and coilmst.loc_no like :as_loc ) 
              											 or  ( (:as_loc = 'WS00000000' or :as_loc = 'WW01') 
              												and ( coilmst.loc_no like :as_loc OR coilmst.loc_no = 'WS00000003' ) ) ) )
              			)
			and ( coilmst.item_no like :as_item )
      and ( coilmst.flag like :as_flag )
      and ( coilmst.open_close in ( :as_oc ) )
 			and not exists ( select * from lossitem where loss_item = coilmst.item_no )
/*
    FROM coilmst,   
         groupitem,   
         location,   
         supp,
			inspdet
   WHERE ( coilmst.item_no *= groupitem.item_no )
	  and ( coilmst.loc_no = location.loc_no )
     and ( coilmst.supp_no *= supp.supp_no )
	  and ( ( :as_work_chk = 'N' and :as_stock_chk = 'N'  and coilmst.loc_no like :as_loc )   
  		  or ( :as_work_chk = 'Y' AND ( ( :as_loc <> 'WS00000000' and :as_loc <> 'WW01' and coilmst.loc_no like :as_loc ) 
											 or  ( (:as_loc = 'WS00000000' or :as_loc = 'WW01') 
												and ( coilmst.loc_no like :as_loc OR ( coilmst.loc_no in ( select loc_no from location where  loc_type = 'W' ) ) ) ) ) ) 
  		 or ( :as_stock_chk = 'Y' AND ( ( :as_loc <> 'WS00000000' and :as_loc <> 'WW01' and coilmst.loc_no like :as_loc ) 
											 or  ( (:as_loc = 'WS00000000' or :as_loc = 'WW01') 
												and ( coilmst.loc_no like :as_loc OR coilmst.loc_no = 'WS00000003' ) ) ) )
			)
			and ( coilmst.item_no like :as_item )
         and ( coilmst.flag like :as_flag )
         and ( coilmst.open_close in ( :as_oc ) )
 			and not exists ( select * from lossitem where loss_item = coilmst.item_no )
			and coilmst.coil_no *= inspdet.coil_no
*/" arguments=(("as_loc", string),("as_item", string),("as_flag", string),("as_oc", stringlist),("as_work_chk", string),("as_stock_chk", string))  sort="mid(coilmst_item_no,3,1) A coilmst_item_no A mid( coilmst_qa, 5, 6) A coilmst_unit_qty A coilmst_loc_no A " )
group(level=1 header.height=0 trailer.height=80 by=("mid(coilmst_item_no,3,1) + mid(coilmst_item_no,2,1)" ) header.color="536870912" trailer.color="15780518" )
group(level=2 header.height=0 trailer.height=68 by=("coilmst_item_no" ) header.color="536870912" trailer.color="12639424" )
group(level=3 header.height=0 trailer.height=72 by=("mid( coilmst_qa, 5, 6)" ) header.color="536870912" trailer.color="536870912" )
