release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=68 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=user_id dbname="login.user_id" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="login.user_name" )
 column=(type=char(30) updatewhereclause=yes name=team_team_name dbname="team.team_name" )
 retrieve="  SELECT login.user_id
       , login.user_name
       , team.team_name 
    FROM login
       , salehp
       , team  
   WHERE login.user_id    = salehp.user_id  
     AND salehp.salesman  = 'Y'
     AND login.team_code  = team.team_code
/*
  SELECT login.user_id
       , login.user_name 
       , team.team_name 
    FROM login
       , team  
   WHERE ( login.team_code    = team.team_code ) 
     AND ( login.use_flag    <>  'N'           ) 
     AND ( ( team.parent_code = '60000' ) OR  
           ( team.parent_code = '70000' ) OR  
           ( team.parent_code = '80000' ) OR  
           ( team.parent_code = '91000' ) OR  
           ( team.parent_code = '92000' ) OR  
           ( team.parent_code = '90000' ) 
         )
*/
"  sort="team_team_name A user_name A " )
