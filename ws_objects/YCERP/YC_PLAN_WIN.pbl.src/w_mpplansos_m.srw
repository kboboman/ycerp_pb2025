event pb_print::clicked;//==GF_USEPROGRAM(프로그램 사용현황)==============================================================
GF_USEPROGRAM( gs_userid, Parent.ClassName(), "P", string(gf_today(),'yyyy/mm/dd'), Parent.Title )
//================================================================================================

string  ls_saleno, ls_chk
long    ll_row, ll_dw9cnt, ll_dw9row, ll_found
integer li_ret

w_repsuper w_print
st_print   l_print

// dw6의 선택된 수주번호를 중복체크하여 dw9에 복사하기
dw9.reset()
for ll_row = 1 to dw6.rowcount()
	ls_chk    =	dw6.object.chk[ll_row]
	ls_saleno =	dw6.object.sale_no[ll_row]
	
	if ls_chk = "Y" then
		ll_dw9cnt = dw9.RowCount()
		
		if ll_dw9cnt > 0 then
			ll_found = dw9.Find( "sale_no = '" + ls_saleno + "' ", 1, ll_dw9cnt )
			if ll_found > 0 then 
				CONTINUE
			else
				ll_dw9row = dw9.insertrow(0)
				dw9.object.sale_no[ll_dw9row] = ls_saleno
			end if
		else
			ll_dw9row = dw9.insertrow(0)
			dw9.object.sale_no[ll_dw9row] = ls_saleno
		end if
	end if
next

if dw9.Rowcount() > 0 then
	li_ret = MessageBox("확인", "소요자재 신청내역을 출력 하시겠습니까?",Exclamation!, YesNo!, 1)
	if li_ret = 1 then
		PrintSetup()
		for ll_row = 1 to dw9.RowCount()
			ls_saleno =	dw9.object.sale_no[ll_row]
			dw_1.retrieve( ls_saleno )		// 신청서
			
			dw_1.Modify("DataWindow.Print.Orientation=1 DataWindow.Print.Paper.Size=9 Datawindow.Zoom=100")
			dw_1.print()
		next
//	elseif li_ret = 2 then
//		for ll_row = 1 to dw9.RowCount()
//			ls_saleno =	dw9.object.sale_no[ll_row]
//			if isnull(ls_saleno) OR ls_saleno = "" then RETURN
//			
//			dw_1.retrieve( ls_saleno )		// 신청서
//			
//			l_print.st_datawindow  = dw_1
//			l_print.st_print_sheet = " 프린트용지 : A4"
//			l_print.st_print_desc  = " 이 프로그램은 소요자재 신청 현황을 출력합니다." 
//			
//			gs_print_control = "DataWindow.Print.Orientation=1 DataWindow.Print.Paper.Size=9 Datawindow.Zoom=100"
//			OpenSheetWithParm(w_print, l_print, parentwindow(), 1, Original!)
//		next
	else
		MessageBox("확인", "출력작업을 취소하였습니다.")
	end if
else
	MessageBox("확인", "출력할 대상을 먼저 선택하시기 바랍니다.")
end if
dw9.reset()
	
end event

