end if

dw4.retrieve(id_date, is_wc, dw_area.object.area[1])
dw5.retrieve(dw_area.object.area[1], id_date, is_wc)
tab_1.tabpage_2.dw_7.retrieve(gs_area, dw_2.object.wc_no[1], date(dw_2.object.work_date[1]) )

