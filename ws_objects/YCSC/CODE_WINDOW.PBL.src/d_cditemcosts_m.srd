table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="ItemCOSTS.item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=qa dbname="ItemCOSTS.qa" )
 column=(type=char(2) update=yes updatewhereclause=yes key=yes name=uom dbname="ItemCOSTS.uom" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=draw_no dbname="ItemCOSTS.draw_no" )
 column=(type=char(60) update=yes updatewhereclause=yes key=yes name=product_name dbname="ItemCOSTS.product_name" )
 column=(type=char(50) update=yes updatewhereclause=yes name=item_group dbname="ItemCOSTS.item_group" )
 column=(type=char(1) update=yes updatewhereclause=yes name=busy dbname="ItemCOSTS.busy" )
 column=(type=long update=yes updatewhereclause=yes name=sort_idx dbname="ItemCOSTS.sort_idx" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=price_c dbname="ItemCOSTS.price_c" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=price_b dbname="ItemCOSTS.price_b" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=price_a dbname="ItemCOSTS.price_a" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=price_s dbname="ItemCOSTS.price_s" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=price_ss dbname="ItemCOSTS.price_ss" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=price_w dbname="ItemCOSTS.price_w" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=price_dis dbname="ItemCOSTS.price_dis" )
 column=(type=char(1) update=yes updatewhereclause=yes name=use_yn dbname="ItemCOSTS.use_yn" values="사용	Y/불가	N/" )
 column=(type=char(10) update=yes updatewhereclause=yes name=user_id dbname="ItemCOSTS.user_id" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=datetime update=yes updatewhereclause=yes name=sys_date dbname="ItemCOSTS.sys_date" )
 column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" )
 retrieve="  SELECT ItemCOSTS.item_no
       , item_name   = g.item_name   
       , ItemCOSTS.qa
       , ItemCOSTS.uom
       , ItemCOSTS.draw_no
       , ItemCOSTS.product_name   
       , ItemCOSTS.item_group
       , ItemCOSTS.busy
       , ItemCOSTS.sort_idx
       , ItemCOSTS.price_c   
       , ItemCOSTS.price_b   
       , ItemCOSTS.price_a   
       , ItemCOSTS.price_s   
       , ItemCOSTS.price_ss   
       , ItemCOSTS.price_w   
       , ItemCOSTS.price_dis   
       , ItemCOSTS.use_yn   
       , ItemCOSTS.user_id   
       , user_name = l.user_name
       , ItemCOSTS.sys_date 
       , chk     = 'N' 
    FROM ItemCOSTS
         LEFT OUTER JOIN groupitem G ON ItemCOSTS.item_no = g.item_no
         LEFT OUTER JOIN login     L ON ItemCOSTS.user_id = l.user_id
   WHERE ( ItemCOSTS.use_yn  = 'Y' )
" update="ItemCOSTS" updatewhere=0 updatekeyinplace=no  sort="item_group A busy A sort_idx A item_name A qa A " )
