table(column=(type=char(10) updatewhereclause=yes name=supp_no dbname="supp_no" )
 column=(type=char(30) updatewhereclause=yes name=supp_name dbname="supp_name" )
 column=(type=char(15) update=yes updatewhereclause=yes name=icube_no dbname="icube_no" )
 retrieve="  SELECT supp_no   = supp.supp_no
       , supp_name = supp.supp_name
       , icube_no  = supp.icube_no  
    FROM supp   
   WHERE ( supp.supp_no  = :as_custno )

" arguments=(("as_custno", string)) )
