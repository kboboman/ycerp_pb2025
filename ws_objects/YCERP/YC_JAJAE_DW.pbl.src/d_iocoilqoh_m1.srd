$PBExportComments$코일재고관리(스리팅)(2001/11/01,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="67108864" )
detail(height=72 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes key=yes name=coilmst_coil_no dbname="coilmst.coil_no" )
 column=(type=decimal(1) updatewhereclause=yes name=coilmst_wid dbname="coilmst.wid" )
 column=(type=char(10) updatewhereclause=yes name=coilmst_item_no dbname="coilmst.item_no" )
 column=(type=char(20) updatewhereclause=yes name=coilmst_qa dbname="coilmst.qa" )
 column=(type=char(10) updatewhereclause=yes key=yes name=coilmst_loc_no dbname="coilmst.loc_no" )
 column=(type=datetime updatewhereclause=yes name=coilmst_rcpt_date dbname="coilmst.rcpt_date" )
 column=(type=long update=yes updatewhereclause=yes name=coilmst_unit_qty dbname="coilmst.unit_qty" )
 column=(type=long updatewhereclause=yes name=coilmst_length dbname="coilmst.length" )
 column=(type=long updatewhereclause=yes name=coilmst_cnt dbname="coilmst.cnt" )
 column=(type=long update=yes updatewhereclause=yes name=coilmst_qcnt dbname="coilmst.qcnt" )
 column=(type=long updatewhereclause=yes name=length dbname="length" )
 column=(type=long updatewhereclause=yes name=total_length dbname="total_length" )
 column=(type=char(4) updatewhereclause=yes name=coilmst_color_no dbname="coilmst.color_no" )
 column=(type=char(10) updatewhereclause=yes name=coilmst_supp_no dbname="coilmst.supp_no" )
 column=(type=char(1) updatewhereclause=yes name=coilmst_flag dbname="coilmst.flag" values="원코일	W/스리팅	S/" )
 column=(type=char(14) updatewhereclause=yes name=coilmst_porder_no dbname="coilmst.porder_no" )
 column=(type=long updatewhereclause=yes name=coilmst_pseq_no dbname="coilmst.pseq_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=coilmst_open_close dbname="coilmst.open_close" values="재고	O/계획	M/작업지시	P/외주가공	S/사용완료	C/" )
 column=(type=char(40) updatewhereclause=yes name=coilmst_rem dbname="coilmst.rem" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(30) updatewhereclause=yes name=location_loc_name dbname="location.loc_name" )
 column=(type=char(30) updatewhereclause=yes name=supp_supp_name dbname="supp.supp_name" )
 column=(type=char(2) updatewhereclause=yes name=coilmst_etc_no dbname="coilmst.etc_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=coilmst_long_stock_yn dbname="coilmst.long_stock_yn" values="	Y/	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=coilmst_use_yn dbname="coilmst.use_yn" values="	Y/	N" )
 retrieve="  SELECT coilmst.coil_no,   
         coilmst.wid,   
         coilmst.item_no,   
         coilmst.qa,   
         coilmst.loc_no,   
         coilmst.rcpt_date,   
         coilmst.unit_qty,   
         coilmst.length,   
         coilmst.cnt,   
         coilmst.qcnt,   
	    isnull(coilmst.length,0) length,
         isnull(coilmst.qcnt,0)*isnull(coilmst.length,0) total_length,
         coilmst.color_no,   
         coilmst.supp_no,   
         coilmst.flag,   
         coilmst.porder_no,   
         coilmst.pseq_no,   
         coilmst.open_close,   
         coilmst.rem,   
         groupitem.item_name,   
         location.loc_name,   
         supp.supp_name,   
         coilmst.etc_no,
         coilmst.long_stock_yn,
	    coilmst.use_yn  
    FROM coilmst LEFT OUTER JOIN groupitem ON coilmst.item_no = groupitem.item_no LEFT OUTER JOIN location ON coilmst.loc_no = location.loc_no LEFT OUTER JOIN supp ON coilmst.supp_no = supp.supp_no  
   WHERE ( coilmst.loc_no like :as_loc ) AND  
         ( coilmst.item_no like :as_item ) AND  
         ( coilmst.flag like :as_flag ) AND  
         ( coilmst.open_close in ( :as_oc ) )    
" update="coilmst" updatewhere=0 updatekeyinplace=no arguments=(("as_loc", string),("as_item", string),("as_flag", string),("as_oc", stringlist))  sort="mid(coilmst_item_no,3,1)+mid(coilmst_item_no,2,1) A coilmst_item_no A mid( coilmst_qa, 5, 6) A coilmst_unit_qty A " )
group(level=1 header.height=0 trailer.height=80 by=("mid(coilmst_item_no,3,1) + mid(coilmst_item_no,2,1)" ) header.color="536870912" trailer.color="15780518" )
group(level=2 header.height=0 trailer.height=0 by=("coilmst_item_no" ) header.color="536870912" trailer.color="12639424" )
group(level=3 header.height=0 trailer.height=72 by=("mid( coilmst_qa, 5, 6)" ) header.color="536870912" trailer.color="536870912" )
