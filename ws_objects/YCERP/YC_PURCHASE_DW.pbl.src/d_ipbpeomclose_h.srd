$PBExportHeader$d_ipbpeomclose_h.srd
$PBExportComments$년마감의 대상인 모든 거래처(1999/05/25, 이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=84 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=84 color="536870912" )
table(column=(type=char(3) updatewhereclause=yes name=supp_no dbname="bpeom.supp_no" )
 column=(type=char(30) updatewhereclause=yes name=supp_name dbname="supp_name" )
 column=(type=decimal(2) updatewhereclause=yes name=balance_amt dbname="balance_amt" )
 retrieve="  SELECT bpeom.supp_no  
       , supp_name   = bsupp.supp_name
       , balance_amt = balbf_amount + inv_01 + inv_02 + inv_03 + inv_04 + inv_05 + inv_06 + inv_07 + inv_08 + inv_09 + inv_10 + inv_11 + inv_12
                     - coll_01 - coll_02 - coll_03 - coll_04 - coll_05 - coll_06 - coll_07 - coll_08 - coll_09 - coll_10 - coll_11 - coll_12
    FROM bpeom  
         LEFT OUTER JOIN bsupp ON bpeom.supp_no = bsupp.supp_no
   WHERE ( bpeom.area_no  = :arg_area ) 
     AND ( bpeom.eom_year = :ai_year  )    
" arguments=(("arg_area", string),("ai_year", number))  sort="supp_name A " )
