$PBExportHeader$d_supplier_unit_det_m.srd
release 8;
datawindow(units=0 timer_interval=0 color=134217750 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=88 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=supp_no dbname="supplier_unit_det.supp_no" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=ver dbname="supplier_unit_det.ver" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="supplier_unit_det.item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="GroupItem.item_name" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=qa dbname="supplier_unit_det.qa" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="supplier_unit_det.uom" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=amount dbname="supplier_unit_det.amount" )
 column=(type=decimal(4) updatewhereclause=yes name=origin_amount dbname="supplier_unit_det.origin_amount" )
 column=(type=decimal(4) updatewhereclause=yes name=pre_amount dbname="pre_amount" )
 column=(type=char(40) update=yes updatewhereclause=yes name=part_no dbname="supplier_unit_det.part_no" )
 column=(type=char(30) update=yes updatewhereclause=yes name=rem dbname="supplier_unit_det.rem" )
 column=(type=char(8) update=yes updatewhereclause=yes name=write_date dbname="supplier_unit_det.write_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=write_user_id dbname="supplier_unit_det.write_user_id" )
 retrieve="select a.supp_no,
           a.ver,
           a.item_no,
           b.item_name,
           a.qa,
           a.uom,
           a.amount,
           a.amount origin_amount,
           isnull(c.amount,0) pre_amount,
           a.part_no,
           a.rem,
           a.write_date,
           a.write_user_id            
from supplier_unit_det a inner join groupitem b on a.item_no = b.item_no
							   left outer join (
														select supp_no, item_no, qa, amount 
  														   from supplier_unit_det with(nolock)
														where   supp_no = :as_supp_no
															and ver = :as_ver - 1
												) c on a.supp_no = c.supp_no and a.item_no = c.item_no and a.qa = c.qa
where a.supp_no = :as_supp_no
   and  a.ver = :as_ver
/*
from supplier_unit_det a, groupitem b 
where a.item_no *= b.item_no
   and  a.supp_no = :as_supp_no
   and  a.ver = :as_ver
*/

" update="supplier_unit_det" updatewhere=0 updatekeyinplace=no arguments=(("as_supp_no", string),("as_ver", number)) )
