$PBExportHeader$d_oeesticon_m.srd
$PBExportComments$견적서결재관리 HEAD(2001/02/22,이인호)
release 6;
datawindow(units=0 timer_interval=0 color=79219928 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes key=yes name=estimate_no dbname="estimate_head.estimate_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=approve_team dbname="estimate_head.approve_team" )
 column=(type=char(10) update=yes updatewhereclause=yes name=approve_top dbname="estimate_head.approve_top" )
 column=(type=char(1) updatewhereclause=yes name=chk_team dbname="chk_team" values="	Y/	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=esti_flag dbname="estimate_head.esti_flag" values="	Y/	N/	B" )
 column=(type=char(60) updatewhereclause=yes name=cust_name dbname="estimate_head.cust_name" )
 column=(type=char(60) updatewhereclause=yes name=scene_desc dbname="estimate_head.scene_desc" )
 retrieve="  SELECT estimate_head.estimate_no,   
         estimate_head.approve_team,   
         estimate_head.approve_top,   
         chk_team = ( case when ( estimate_head.approve_team is null ) or ( estimate_head.approve_team = '') then ~"N~" else ~"Y~" end ),   
         estimate_head.esti_flag,   
         estimate_head.cust_name,   
         estimate_head.scene_desc  
    FROM estimate_head  
   WHERE ( estimate_head.esti_flag like :as_flag ) AND  
         ( estimate_head.estimate_date between :ad_start and :ad_end ) AND  
         ( estimate_head.system_no like :as_item )  AND  
         ( estimate_head.cust_name like :as_cust ) AND  
         ( estimate_head.scene_desc like :as_scene )" update="estimate_head" updatewhere=0 updatekeyinplace=yes arguments=(("as_flag", string),("ad_start", date),("ad_end", date),("as_cust", string),("as_scene", string),("as_item", string)) )
