 column=(type=char(10) updatewhereclause=yes name=tlogin dbname="TLOGIN" )
 column=(type=datetime updatewhereclause=yes name=msgdate dbname="MSGDATE" )
 column=(type=char(100) updatewhereclause=yes name=msg dbname="MSG" )
 column=(type=char(1) updatewhereclause=yes name=del dbname="DEL" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="USER_NAME" )
 retrieve="SELECT PKID       = A.PKID
     , TLOGIN     = A.TLOGIN
     , MSGDATE    = A.MSGDATE
     , MSG        = A.MSG
     , DEL        = A.DEL
     , USER_NAME  = B.USER_NAME
  FROM PROJECTMSGDET A
       LEFT OUTER JOIN LOGIN B  ON B.USER_ID = A.TLOGIN
" )
