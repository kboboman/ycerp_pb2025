 retrieve="  SELECT samp.samp_no,   
         samp.cust_no,   
         samp.scene_code,   
         samp.order_date,   
         samp.salesman,   
         samp.area_no,   
         samp.login_id,   
         samp.rem  
    FROM samp   
	where samp.samp_no = :as_samp_no
" update="samp" updatewhere=1 updatekeyinplace=no arguments=(("as_samp_no", string)) )
