table(column=(type=char(20) updatewhereclause=yes name=coil_no dbname="coilmst.coil_no" )
 column=(type=char(14) updatewhereclause=yes name=coilorder_order_no dbname="coilorder.order_no" )
 column=(type=char(14) updatewhereclause=yes name=coilsfcday_order_no dbname="coilsfcday.order_no" )
 column=(type=long updatewhereclause=yes name=coilsfcday_seq dbname="coilsfcday.seq" )
 column=(type=datetime updatewhereclause=yes name=coilsfcday_sfc_date dbname="coilsfcday.sfc_date" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(20) updatewhereclause=yes name=coilmst_qa dbname="coilmst.qa" )
 column=(type=char(10) updatewhereclause=yes name=coilsfcday_item_no dbname="coilsfcday.item_no" )
 column=(type=long updatewhereclause=yes name=coilsfcday_unit_qty dbname="coilsfcday.unit_qty" )
 column=(type=long updatewhereclause=yes name=coilsfcday_cnt dbname="coilsfcday.cnt" )
 column=(type=long updatewhereclause=yes name=coilmst_unit_qty dbname="coilmst.unit_qty" )
 column=(type=char(20) updatewhereclause=yes name=lot_no dbname="lot_no" )
 column=(type=decimal(1) updatewhereclause=yes name=swid dbname="swid" )
 column=(type=long updatewhereclause=yes name=tot_qty dbname="tot_qty" )
 column=(type=decimal(17) updatewhereclause=yes name=rate dbname="rate" )
 column=(type=datetime updatewhereclause=yes name=start_date dbname="start_date" )
 column=(type=datetime updatewhereclause=yes name=end_date dbname="end_date" )
 column=(type=char(4) updatewhereclause=yes name=place dbname="place" )
 column=(type=char(2) updatewhereclause=yes name=coilmst_etc_no dbname="coilmst.etc_no" )
 retrieve="  SELECT DISTINCT coilmst.coil_no
       , coilorder.order_no                                   
       , coilsfcday.order_no                                           
       , coilsfcday.seq                                                  
       , coilsfcday.sfc_date                                           
       , groupitem.item_name                                           
       , coilmst.qa                                                          
       , coilsfcday.item_no                                            
       , coilsfcday.unit_qty                                           
       , coilsfcday.cnt                                                  
       , coilmst.unit_qty                                              
       , lot_no     = coilsfcday.coil_no                                            
       , swid       = (case when sheet = 'C' or sheet = 'L' then convert(decimal(5,1), substring(coilsfcday.qa,5,4) + '.' + substring(coilsfcday.qa, 10,1)) 
                            when sheet = 'S'                then convert(decimal(5,0), substring(coilsfcday.qa,5,4)) 
                       end)
       , tot_qty    = coilsfcday.unit_qty * coilsfcday.cnt
       , rate       = convert(dec(20,6), (coilsfcday.unit_qty * coilsfcday.cnt) ) / coilmst.unit_qty * 100
       , start_date = convert(smalldatetime, :ad_start, 111)
       , end_date   = convert(smalldatetime, :ad_end,   111)
       , place      = (case when :as_flag = '%' then '전체'
                            when :as_flag = 'I' then '사내'
                            when :as_flag = 'O' then '외주'
                       end)
       , coilmst.etc_no                                                        
    FROM coilmst                                                               
       , groupitem                                                             
       , coilorderdet                                                          
       , coilsfcday                                                            
       , coilorder                                                             
   WHERE ( coilorder.order_no          = coilorderdet.coilorder_order )        
     AND ( coilorderdet.order_no       = coilsfcday.order_no          )        
     AND ( coilorderdet.coil_no        = coilmst.coil_no              )        
     AND ( coilmst.item_no             = groupitem.item_no            )        
     AND ( coilmst.loc_no             <> 'WS00000003'                 ) /* 코일장기저장소 */
     AND ((coilsfcday.sfc_date   BETWEEN :ad_start  and :ad_end       ) and
			 (coilorder.wc_place       LIKE :as_flag                     )
         )   
" arguments=(("ad_start", date),("ad_end", date),("as_flag", string))  sort="coilsfcday_order_no A coilsfcday_seq A groupitem_item_name A coilmst_qa A coilsfcday_sfc_date A " )
