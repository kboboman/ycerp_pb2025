$PBExportHeader$d_osaroirep_r2.srd
$PBExportComments$매출현황 운반비체크
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=84 color="10789024" )
detail(height=80 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(12) updatewhereclause=yes name=aroiinv_no dbname="aroiinv_no" )
 column=(type=char(14) updatewhereclause=yes name=do_do_no dbname="do_no" )
 column=(type=decimal(4) updatewhereclause=yes name=ship_cost dbname="ship_cost" )
 column=(type=char(4) updatewhereclause=yes name=cust_no1 dbname="cust_no1" )
 column=(type=char(11) updatewhereclause=yes name=spot_code dbname="spot_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=char(14) updatewhereclause=yes name=do_no1 dbname="do_no1" )
 column=(type=char(1) updatewhereclause=yes name=do_check dbname="do_check" )
 column=(type=decimal(0) updatewhereclause=yes name=ship_amount dbname="ship_amount" )
 column=(type=char(10) updatewhereclause=yes name=do_ship_date dbname="ship_date" )
 column=(type=char(10) updatewhereclause=yes name=do_date dbname="do_date" )
 column=(type=char(5) updatewhereclause=yes name=cat dbname="cat" )
 column=(type=long updatewhereclause=yes name=datecalc dbname="datecalc" )
 retrieve="SELECT user_name    = l.user_name
     , cust_no      = a.cust_no
     , cust_name    = c.cust_name
     , aroiinv_no   = a.aroiinv_no
     , do_no        = a.do_no
     , ship_cost    = isnull(a.ship_cost,0)

     , cust_no1     = a.cust_no
     , spot_code    = a.spot_code  
     , scene_desc   = s.scene_desc
     , do_no1       = a.do_no1
     , do_check    = (case when do.do_no is not null then 'Y' else 'N' end)
     , ship_amount  = isnull(a.ship_amount,0)
     , ship_date    = a.ship_date  
     , do_date      = a.do_date  
     , cat          = a.cat        
     , datecalc     = a.datecalc   
  FROM (
       SELECT cust_no      = isnull(a.cust_no,b.cust_no)
            , aroiinv_no   = isnull(a.aroiinv_no,'')
            , do_no        = isnull(a.do_no,'')
            , ship_cost    = isnull(a.ship_cost,0)
       
            , cust_no1     = b.cust_no
            , spot_code    = (case when b.spot_code is null then
                                        (SELECT spot_code FROM do WHERE do_no = a.do_no ) 
                                   else b.spot_code
                              end)
            , do_no1       = isnull(b.do_no, a.do_no)
            , ship_amount  = b.ship_amount
            , ship_date    = b.ship_date  
            , do_date      = b.do_date  
            , cat          = b.cat        
            , datecalc     = b.datecalc   
         FROM (
              SELECT cust_no     = aroiinv.cust_no                                                                                          
                   , aroiinv_no  = aroiinv.aroiinv_no       /* 계산서번호 */                                                                
                   , ship_cost   = (case when aroi.seq_no = 1 then aroiinv.ship_cost else 0 end) /* 운반비(공급가액) */
                   , do_no       = aroi.do_no                                                                                               
                   , oi_date     = aroiinv.oi_date                                                                                          
                FROM aroiinv                                                                                                  
                     LEFT OUTER JOIN aroi  ON aroiinv.aroiinv_no = aroi.aroiinv_no
               WHERE ( ( aroiinv.sale_flag        IN ( 'D','L','E' )    ) AND                                                 
                       ( convert(char(10),aroiinv.oi_date,111)  BETWEEN :as_sdate and :as_edate ) AND                   
                       ( aroiinv.delete_flag       = 'N'              )                                                       
                     ) 
                 AND aroi.seq_no = 1 
              ) A
       
              FULL OUTER JOIN (
                     SELECT cat         = '2.ETC'
                          , cust_no     = doshipetc.cust_no
                          , spot_code   = doshipetc.scene_code                                         
                          , ship_date   = convert(char(10),doshipetc.etc_date,111)
                          , do_date     = convert(char(10),doshipetc.etc_date,111)
                          , datecalc    = 0
                          , do_no       = doshipetc.do_no
                          , ship_amount = doshipetc.ship_amount                            
                          , do_flag     = (SELECT do.ship_flag FROM do WHERE do.do_no = doshipetc.do_no)
                       FROM doshipetc   
                      WHERE ( ( doshipetc.etc_area      LIKE '%'   ) and  
                              ( convert(char(10),doshipetc.etc_date,111)   BETWEEN :as_sdate and :as_edate ) and  
                              ( doshipetc.doship_req       = 'Y'   )
                            )
                        AND doshipetc.do_no is not null
                        AND doshipetc.ship_amount <> 0  
              ) B   ON  a.do_no  =  b.do_no
       ) A
       LEFT OUTER JOIN do           ON a.do_no1    = do.do_no
       LEFT OUTER JOIN customer C   ON a.cust_no   = c.cust_no
       LEFT OUTER JOIN scene    S   ON a.spot_code = s.scene_code
       LEFT OUTER JOIN login    L   ON c.salesman  = l.user_id
" arguments=(("as_sdate", string),("as_edate", string))  sort="cust_name A aroiinv_no A do_do_no A " )
