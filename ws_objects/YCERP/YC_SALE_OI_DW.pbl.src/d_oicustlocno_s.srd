$PBExportHeader$d_oicustlocno_s.srd
$PBExportComments$직출고저장소선택데이타원도우(1998/5/27,성삼지)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=72 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=68 color="536870912" )
table(column=(type=decimal(4) updatewhereclause=yes name=loc_qoh dbname="itemloc.qoh" initial=" " )
 column=(type=char(30) updatewhereclause=yes name=location_loc_name dbname="location.loc_name" )
 column=(type=char(10) updatewhereclause=yes name=itemloc_loc_no dbname="itemloc.loc_no" initial=" " )
 column=(type=char(1) updatewhereclause=yes name=location_loc_type dbname="location.loc_type" )
 retrieve="  SELECT itemloc.qoh,   
         rtrim(ltrim(location.loc_name)) location_loc_name,   
         itemloc.loc_no,   
         location.loc_type  
    FROM (select IL.loc_no, IL.item_no, IL.qa, qoh = sum(IL.qoh) from 
						( select loc_no = loc_no, item_no = item_no, qa = qa, qoh = qoh from itemloc
						   where qoh > 0
						  ) IL
				group by IL.loc_no, IL.item_no, IL.qa
			) itemloc,   
         location
			
   WHERE ( itemloc.loc_no = location.loc_no ) and  
         ( ( itemloc.qoh > 0 ) AND  
         ( location.loc_type = 'N' ) )   " )
text(band=header alignment="2" text="저장소번호" border="0" color="0" x="9" y="8" height="60" width="352" html.valueishtml="0"  name=itemloc_loc_no_t visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="15780518" )
