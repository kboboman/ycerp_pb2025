table(column=(type=datetime updatewhereclause=yes name=start_date dbname="start_date" )
 column=(type=char(17) updatewhereclause=yes name=plan_no dbname="plan_no" )
 column=(type=char(10) updatewhereclause=yes name=wc_no dbname="wc_no" )
 column=(type=long updatewhereclause=yes name=priority dbname="priority" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=decimal(4) updatewhereclause=yes name=order_qty dbname="order_qty" )
 column=(type=char(50) updatewhereclause=yes name=rem dbname="rem" )
 column=(type=decimal(4) updatewhereclause=yes name=rcpt_qty dbname="rcpt_qty" )
 column=(type=long updatewhereclause=yes name=work_qty dbname="work_qty" )
 column=(type=char(17) updatewhereclause=yes name=order_no dbname="order_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="seq_no" )
 column=(type=char(14) updatewhereclause=yes name=sale_no dbname="sale_no" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(11) updatewhereclause=yes name=scene_code dbname="scene_code" )
 column=(type=char(4) updatewhereclause=yes name=item_color dbname="item_color" )
 column=(type=long updatewhereclause=yes name=operation dbname="operation" )
 column=(type=long updatewhereclause=yes name=division dbname="division" )
 column=(type=long updatewhereclause=yes name=work_per dbname="work_per" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=decimal(4) updatewhereclause=yes name=hebe dbname="hebe" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=char(91) updatewhereclause=yes name=cust_scene dbname="cust_scene" )
 column=(type=char(10) updatewhereclause=yes name=color_name dbname="color_name" )
 column=(type=decimal(4) updatewhereclause=yes name=plan_qty dbname="plan_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=make_qty dbname="make_qty" )
 column=(type=char(10) updatewhereclause=yes name=assy_item dbname="assy_item" )
 column=(type=char(20) updatewhereclause=yes name=assy_qa dbname="assy_qa" )
 column=(type=char(16) updatewhereclause=yes name=mpsorder_order dbname="mpsorder_order" )
 column=(type=long updatewhereclause=yes name=order_seq dbname="order_seq" )
 column=(type=char(10) updatewhereclause=yes name=area_no dbname="area_no" )
 column=(type=long updatewhereclause=yes name=unit_qty dbname="unit_qty" )
 column=(type=long updatewhereclause=yes name=page_qty dbname="page_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=order_qty2 dbname="order_qty2" )
 column=(type=decimal(4) updatewhereclause=yes name=rcpt_qty2 dbname="rcpt_qty2" )
 retrieve="SELECT start_date = mps.start_date           
     , plan_no    = rtrim(ltrim(mpsdet.plan_no))           
     , wc_no      = rtrim(ltrim(mpsdet.wc_no))             
     , priority   = mpsdet.priority          
     , item_no    = rtrim(ltrim(mpsdet.item_no))           
     , qa         = rtrim(ltrim(mpsdet.qa))                
     , uom        = rtrim(ltrim(mpsdet.uom))               
     , order_qty  = mpsdet.order_qty         
     , rem        = rtrim(ltrim(mpsdet.rem))               
     , rcpt_qty   = mpsdet.rcpt_qty          
     , work_qty   = 0                        
     , order_no   = rtrim(ltrim(mpsdet.order_no))
     , seq_no     = mpsdet.seq_no
     , sale_no    = rtrim(ltrim(mpsdet.sale_no))           
     , cust_no    = rtrim(ltrim(mpsdet.cust_no))           
     , scene_code = rtrim(ltrim(mpsdet.scene_code))        
     , item_color = rtrim(ltrim(mpsdet.item_color))        
     , operation  = mpsdet.operation         
     , division   = mpsdet.division          
     , work_per   = mpsdet.work_per          

     , item_name  = rtrim(ltrim(item.item_name))
     , hebe       = isnull(item.price_c, 0)  
     , cust_name  = rtrim(ltrim(customer.cust_name))
     , scene_desc = rtrim(ltrim(scene.scene_desc))
     , cust_scene = rtrim(ltrim(isnull(customer.cust_name, '') + ' ' + isnull(scene.scene_desc, '')))
     , color_name = rtrim(ltrim(color.color_name))
     , plan_qty   = routtempnew.plan_qty     
     , make_qty   = routtempnew.make_qty     
     , assy_item  = rtrim(ltrim(routtempnew.assy_item))
     , assy_qa    = rtrim(ltrim(routtempnew.assy_qa))
     , mpsorder_order = rtrim(ltrim(mpsdet.mpsorder_order))
     , order_seq  = mpsdet.order_seq         
     , area_no    = rtrim(ltrim(routtempnew.area_no))      
     , unit_qty   = 0                        
     , page_qty   = 1
     , order_qty2 = mpsdet.order_qty         
     , rcpt_qty2  = mpsdet.rcpt_qty          
  FROM mpsdet with(nolock) inner join   mps with(nolock) on  mpsdet.order_no = mps.order_no    
                          				      inner join    routtempnew with(nolock) on    routtempnew.sale_no       = mpsdet.sale_no   
                                                                                         AND routtempnew.seq_no        = mpsdet.seq_no
                                                                                         AND routtempnew.operation     = mpsdet.operation
                                                                                         AND routtempnew.wc_no         = mpsdet.wc_no
                                                                                         AND routtempnew.division      = mpsdet.division
                                                                                         AND routtempnew.area_no       = mps.area_no
                                                inner join item with(nolock) on  mpsdet.item_no            = item.item_no and mpsdet.qa  = item.qa
                                                left outer join customer with(nolock) on   mpsdet.cust_no   = customer.cust_no
                                                left outer join scene  with(nolock) on mpsdet.scene_code  = scene.scene_code
                                                left outer join  color with(nolock) on   mpsdet.item_color  = color.color_code        
 WHERE mps.start_date            = :ad_date
   AND  mpsdet.mpsorder_order    IS NOT NULL
   AND mpsdet.wc_no              = :ls_wc_no
   AND mps.area_no               = :as_area
   AND routtempnew.process_flag <> 'C'
   AND ( mpsdet.order_no IN (:asa_order_no) AND mpsdet.order_seq IN (:as_order_seq) )
/*
  FROM routtempnew
     , mps        
     , mpsdet     
     , item       
     , customer   
     , scene      
     , color
 WHERE mps.order_no              = mpsdet.order_no
   AND mps.start_date            = :ad_date
   AND mpsdet.mpsorder_order    IS NOT NULL
   AND mpsdet.wc_no              = :ls_wc_no
   AND mps.area_no               = :as_area
   AND mpsdet.cust_no           *= customer.cust_no
   AND mpsdet.item_no            = item.item_no
   AND mpsdet.qa                 = item.qa
   AND mpsdet.scene_code        *= scene.scene_code
   AND mpsdet.item_color        *= color.color_code
   AND routtempnew.sale_no       = mpsdet.sale_no
   AND routtempnew.area_no       = mps.area_no
   AND routtempnew.seq_no        = mpsdet.seq_no
   AND routtempnew.operation     = mpsdet.operation
   AND routtempnew.wc_no         = mpsdet.wc_no
   AND routtempnew.division      = mpsdet.division
   AND routtempnew.process_flag <> 'C'
   AND ( mpsdet.order_no IN (:asa_order_no) AND mpsdet.order_seq IN (:as_order_seq) )
*/" arguments=(("ls_wc_no", string),("ad_date", date),("as_area", string),("asa_order_no", stringlist),("as_order_seq", numberlist))  sort="mpsorder_order A order_seq A " )
