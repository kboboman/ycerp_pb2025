table(column=(type=char(14) updatewhereclause=yes name=coilsliting_order_no dbname="coilsliting.order_no" )
 column=(type=long updatewhereclause=yes name=coilsliting_seq dbname="coilsliting.seq" )
 column=(type=decimal(1) updatewhereclause=yes name=swid dbname="swid" )
 column=(type=long updatewhereclause=yes name=coilsliting_cnt dbname="coilsliting.cnt" )
 column=(type=decimal(4) updatewhereclause=yes name=coilsliting_unit_qty dbname="coilsliting.unit_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=thin dbname="thin" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(20) updatewhereclause=yes name=coilsfcday_coil_no dbname="coilsfcday.coil_no" )
 column=(type=long updatewhereclause=yes name=lb_cnt dbname="lb_cnt" initial="0" )
 retrieve="SELECT coilsliting.order_no,
		 coilsliting.seq,   
		 swid = convert (decimal (5,1), substring(coilsliting.qa,5,4) + '.' + substring(coilsliting.qa, 10,1)),   
           coilsliting.cnt,
		 coilsliting.unit_qty,
            thin = convert (decimal (3,2), substring(coilsliting.qa,1,1) + '.' + substring(coilsliting.qa, 2,2)),   
		 groupitem.item_name,
		 coilsfcday.coil_no,
		 lb_cnt = 0
  FROM coilsliting INNER JOIN groupitem ON coilsliting.item_no = groupitem.item_no
		                    INNER JOIN coilorderdet ON coilsliting.order_no = coilorderdet.order_no
		                    LEFT OUTER JOIN coilsfcday ON coilsliting.order_no = coilsfcday.order_no AND  coilsliting.seq = coilsfcday.seq 
                                                                         AND coilsfcday.item_no not in ( select lossitem.loss_item from lossitem )
 WHERE ( coilorderdet.coilorder_order = :as_order_no ) 
       AND  ( coilorderdet.order_seq = :as_order_seq )
/*     
  FROM coilsliting,
		 coilorderdet,
		 coilsfcday,
		 groupitem
 WHERE ( coilsliting.item_no = groupitem.item_no ) and
		 ( coilorderdet.order_no = coilsliting.order_no ) and  
		 ( coilsliting.order_no *= coilsfcday.order_no ) and
		 ( coilsliting.seq *= coilsfcday.seq ) and
		 ( coilorderdet.coilorder_order = :as_order_no ) and
		 ( coilorderdet.order_seq = :as_order_seq ) and
       ( coilsfcday.item_no not in ( select lossitem.loss_item from lossitem ))
*/       " arguments=(("as_order_no", string),("as_order_seq", number)) )
