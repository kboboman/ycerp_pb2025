$PBExportHeader$d_qcitemcoil_list.srd
$PBExportComments$품목별코일규격관리(2005/06/09, 이인호)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa123 dbname="qa123" )
 column=(type=long updatewhereclause=yes name=qa4 dbname="qa4" )
 column=(type=decimal(2) updatewhereclause=yes name=ship_qty dbname="ship_qty" )
 column=(type=char(10) update=yes updatewhereclause=yes name=coil_item dbname="coil_item" )
 column=(type=char(60) updatewhereclause=yes name=coil_name dbname="coil_name" )
 column=(type=char(255) updatewhereclause=yes name=coil_qa dbname="coil_qa" )
 retrieve="  SELECT item_no   = a.item_no     /* 출고품목 */
       , item_name = c.item_name
       , qa123     = a.qa123       /* 출고규격 */
       , qa4       = a.cm          /* 출고길이 */
       , ship_qty  = a.ship_qty    /* 출고수량 */
       , coil_item = b.coil_item   /* 스리팅 품목 */
       , coil_name = d.item_name
       , coil_qa   = b.coil_qa     /* 스리팅 규격 */
    FROM ( /* 기간별 출고데이터 */
         SELECT b.item_no
              , qa123     = substring(b.qa,1,13)
              , qa4       = b.qa
              , cm        = convert(int,substring(b.qa,15,5))
              , ship_qty  = sum(b.ship_qty )
           FROM do A     
                LEFT OUTER JOIN dodet B  ON a.do_no  = b.do_no		
          WHERE a.do_date    BETWEEN :as_sdate AND :as_edate
          GROUP BY b.item_no, substring(b.qa,1,13), b.qa, convert(int,substring(b.qa,15,5))
         ) A
         LEFT OUTER JOIN ( /* 품목별 코일규격관리 */
              SELECT item_no   = a.item_no     /* 완제품 명칭 */
                   , qa123     = a.qa          /* 완제품 규격 */
                   , coil_item = a.coil_item   /* 스리팅 품목 */
                   , coil_qa   = replace(convert(char(10),a.thick ), '.','') + 'X'
                               + (case when width > 99 then left('0' + replace(convert(char(10),a.width * 10000), '.',''), 4)
                                       else left('00' + replace(convert(char(10),a.width * 10000), '.',''), 4)
                                  end)
                   , seq_no    = a.seq_no      /* 종류 */
                FROM itemcoil A  
               WHERE a.seq_no  = 1
         ) B  ON a.item_no  = b.item_no  AND a.qa123 = b.qa123
         LEFT OUTER JOIN GROUPITEM C   ON a.item_no    = c.item_no
         LEFT OUTER JOIN GROUPITEM D   ON b.coil_item  = d.item_no
   ORDER BY item_name, qa123, cm
" arguments=(("as_sdate", string),("as_edate", string)) )
