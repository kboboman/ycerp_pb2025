release 8;
datawindow(units=3 timer_interval=0 color=1073741824 processing=2 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 0 print.margin.right = 0 print.margin.top = 0 print.margin.bottom = 0 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no label.name="Pin Fed Address 3.5x.94  4097,4145/63/77" label.width=10000 label.height=5000 label.rows=1 label.rows.spacing=0 label.columns=1 label.columns.spacing=0 label.topdown=no label.sheet=no label.shape=roundrectangle label.ellipse_height=0 label.ellipse_width=0 )
detail(height=5000 color="536870912" )
table(column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(18) updatewhereclause=yes name=thin dbname="thin" )
 column=(type=long updatewhereclause=yes name=unit_qty dbname="unit_qty" )
 column=(type=long updatewhereclause=yes name=length dbname="length" )
 column=(type=char(4) updatewhereclause=yes name=coilsfcday_color_no dbname="color_no" )
 column=(type=char(20) updatewhereclause=yes name=coil_no dbname="coil_no" )
 column=(type=char(2) updatewhereclause=yes name=item_no dbname="item_no" values="무도장	0/YC-001	1/YC-003	3/YC-004	4/국방색	A/검정	B/흑백	C/백색	D/펜시	F/골드	G/회색	H/도장아이보리	I/지정색	J/카파	K/라미네이트	L/밀러	M/무정전	N/롤아이보리	R/실버	S/T-Bar 백색	W/기타	Z/" )
 column=(type=char(25) updatewhereclause=yes name=onecoil dbname="onecoil" )
 column=(type=char(20) updatewhereclause=yes name=onecoil_no dbname="onecoil_no" )
 column=(type=char(9) updatewhereclause=yes name=t_wc dbname="t_wc" )
 retrieve="SELECT DISTINCT groupitem.item_name
     , thin     = substring(cm1.qa,1,1) + '.' + substring(cm1.qa, 2,2) + ' * ' + convert(varchar(8), cm1.wid)
     , unit_qty = cm1.unit_qty
     , length   = cm1.length
     , color_no = cm1.color_no
     , coil_no  = cm1.coil_no
     , item_no  = right(rtrim(cm1.item_no),1)
     , onecoil  = ( substring(cm2.qa,1,1) + '.' + substring(cm2.qa, 2,2) + '*' 
                + convert(varchar(8), cm2.wid) + '*' + convert(varchar(8), cm2.unit_qty) )
     , onecoil_no = cm2.coil_no
     , t_wc     = '성형'+ right(:as_loc, 2) + '호기'
  FROM coilmst cm1 with(nolock) INNER JOIN  groupitem with(nolock) ON cm1.item_no   = groupitem.item_no
						    LEFT OUTER JOIN coilmst cm2 with(nolock) ON cm1.pcoil_no = cm2.coil_no
 WHERE cm1.coil_no   = :as_coil
      AND cm1.LOC_NO    = :as_loc
/*
  FROM coilmst cm1
     , coilmst cm2
     , groupitem
 WHERE cm1.item_no   = groupitem.item_no
   AND cm1.coil_no   = :as_coil
   AND cm1.LOC_NO    = :as_loc
   AND cm1.pcoil_no *= cm2.coil_no
*/
" arguments=(("as_coil", string),("as_loc", string)) )
