table(column=(type=char(14) updatewhereclause=yes name=inspdet_insp_no dbname="inspdet.insp_no" )
 column=(type=long updatewhereclause=yes name=inspdet_oi_no dbname="inspdet.oi_no" )
 column=(type=char(10) updatewhereclause=yes name=inspdet_item_no dbname="inspdet.item_no" )
 column=(type=char(20) updatewhereclause=yes name=inspdet_qa dbname="inspdet.qa" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=decimal(2) updatewhereclause=yes name=inspdet_rcpt_qty dbname="inspdet.rcpt_qty" )
 column=(type=char(2) updatewhereclause=yes name=inspdet_uom dbname="inspdet.uom" )
 column=(type=char(14) updatewhereclause=yes name=inspdet_pur_no dbname="inspdet.pur_no" )
 retrieve="  SELECT inspdet.insp_no       
       , inspdet.oi_no         
       , inspdet.item_no       
       , inspdet.qa            
       , groupitem.item_name   
       , inspdet.rcpt_qty      
       , inspdet.uom           
       , inspdet.pur_no  
    FROM inspdet   
       , insp      
       , groupitem  
   WHERE ( inspdet.insp_no        = insp.insp_no      )   
     AND ( inspdet.item_no        = groupitem.item_no )   
     AND ( ( insp.supp_no         = :as_supp ) AND  
           ( insp.insp_date between :ad_start and :ad_end ) AND  
           ( insp.area_no         = :as_area ) 
         )    
" arguments=(("as_area", string),("as_supp", string),("ad_start", date),("ad_end", date)) )
