table(column=(type=long update=yes updatewhereclause=yes key=yes name=seq_no dbname="aroi.seq_no" )
 column=(type=char(14) update=yes updatewhereclause=yes name=do_no dbname="aroi.do_no" )
 column=(type=long update=yes updatewhereclause=yes name=oi_no dbname="aroi.oi_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="aroi.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="aroi.qa" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="aroi.uom" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=ship_qty dbname="aroi.ship_qty" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=price dbname="aroi.price" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=rate_cash dbname="aroi.rate_cash" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=ori_amount dbname="aroi.ori_amount" )
 column=(type=char(14) update=yes updatewhereclause=yes name=sale_no dbname="aroi.sale_no" )
 column=(type=char(30) update=yes updatewhereclause=yes name=rem dbname="aroi.rem" )
 column=(type=decimal(4) updatewhereclause=yes name=price_a dbname="item.price_a" )
 column=(type=char(60) updatewhereclause=yes name=item_item_name dbname="item.item_name" )
 column=(type=char(1) updatewhereclause=yes name=pick dbname="pick" initial="N" values="	Y/	N" )
 column=(type=decimal(3) updatewhereclause=yes name=a_price dbname="item.a_price" initial="0" )
 column=(type=decimal(2) updatewhereclause=yes name=a_qty dbname="item.a_qty" initial="0" )
 column=(type=long update=yes updatewhereclause=yes name=dc_rate dbname="aroi.dc_rate" )
 column=(type=long updatewhereclause=yes name=c_dc dbname="item.c_dc" )
 column=(type=char(12) update=yes updatewhereclause=yes key=yes name=aroiinv_no dbname="aroi.aroiinv_no" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"item~" )  TABLE(NAME=~"aroi~" ) COLUMN(NAME=~"aroi.seq_no~") COLUMN(NAME=~"aroi.do_no~") COLUMN(NAME=~"aroi.oi_no~") COLUMN(NAME=~"aroi.item_no~") COLUMN(NAME=~"aroi.qa~") COLUMN(NAME=~"aroi.uom~") COLUMN(NAME=~"aroi.ship_qty~") COLUMN(NAME=~"aroi.price~") COLUMN(NAME=~"aroi.rate_cash~") COLUMN(NAME=~"aroi.ori_amount~") COLUMN(NAME=~"aroi.sale_no~") COLUMN(NAME=~"aroi.rem~") COLUMN(NAME=~"item.price_a~") COLUMN(NAME=~"item.item_name~") COMPUTE(NAME=~"'N' pick~") COMPUTE(NAME=~"0000000.000a_price~") COMPUTE(NAME=~"0000000.00a_qty~") COLUMN(NAME=~"aroi.dc_rate~") COMPUTE(NAME=~"00 c_dc~") COLUMN(NAME=~"aroi.aroiinv_no~")    JOIN (LEFT=~"aroi.item_no~"    OP =~"=~"RIGHT=~"item.item_no~" )    JOIN (LEFT=~"aroi.qa~"    OP =~"=~"RIGHT=~"item.qa~" )WHERE(    EXP1 =~"aroi.aroiinv_no~"   OP =~"=~"    EXP2 =~":as_aroiinv_no~" ) ) ARG(NAME = ~"as_aroiinv_no~" TYPE = string) " update="aroi" updatewhere=0 updatekeyinplace=no arguments=(("as_aroiinv_no", string))  sort="seq_no A " )
