release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=long update=yes updatewhereclause=yes key=yes name=item_no dbname="bitem.item_no" )
 column=(type=char(30) update=yes updatewhereclause=yes name=item_name dbname="bitem.item_name" )
 column=(type=char(10) update=yes updatewhereclause=yes name=rem dbname="bitem.rem" )
 column=(type=char(4) update=yes updatewhereclause=yes name=uom dbname="bitem.uom" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=price dbname="bitem.price" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=qoh dbname="bitem.qoh" initial="0" )
 column=(type=char(1) update=yes updatewhereclause=yes name=qoh_type dbname="bitem.qoh_type" initial="N" values="재고 유	Y/재고 무	N/" )
 column=(type=char(3) update=yes updatewhereclause=yes name=supp_no dbname="bitem.supp_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=catgroup dbname="bitem.catgroup" )
 retrieve="  SELECT bitem.item_no,   
         bitem.item_name,   
         bitem.rem,   
         bitem.uom,   
         bitem.price,   
         bitem.qoh,   
         bitem.qoh_type,   
         bitem.supp_no,   
         bitem.catgroup  
    FROM bitem   
" update="bitem" updatewhere=1 updatekeyinplace=no  sort="item_name A " )
