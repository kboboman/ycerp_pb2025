$PBExportHeader$d_ioinoutsum_r.srd
$PBExportComments$저장소별 입출고집계(2001/09/14,이인호)
release 8;
datawindow(units=0 timer_interval=60000 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=356 color="536870912" )
summary(height=84 color="536870912" )
footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(30) updatewhereclause=yes name=location_loc_name dbname="loc_name" )
 column=(type=decimal(4) updatewhereclause=yes name=rcpt_qty dbname="rcpt_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=issue_qty dbname="issue_qty" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=decimal(4) updatewhereclause=yes name=cqty dbname="cqty" )
 column=(type=long updatewhereclause=yes name=price dbname="price" )
 column=(type=decimal(4) updatewhereclause=yes name=qoh dbname="qoh" )
 column=(type=char(10) updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=char(10) updatewhereclause=yes name=edate dbname="edate" )
 retrieve="  SELECT groupitem.item_name
       , groupitem.uom   
       , itemloc.qa   
       , loc_name  = ( case when :as_loc = 'A' then '전체' else location.loc_name end)   
       , rcpt_qty  = isnull(sum(ineoday.rcpt_qty), 0)   
       , issue_qty = isnull(sum(ineoday.issue_qty), 0)   
       , itemloc.item_no
       , cqty      = dbo.uf_getqty(itemloc.item_no, itemloc.qa, groupitem.uom, (isnull(itemloc.qoh, 0) - isnull(eoday.eqoh, 0 )))
       , price     = 0 /* isnull(dbo.uf_getprice(itemloc.item_no, itemloc.qa, groupitem.uom), 0) */   
       , qoh       = (isnull(itemloc.qoh, 0)   - isnull(eoday.eqoh, 0))
       , sdate     = convert(char(10), substring(:as_start, 1, 4) + '/' + substring(:as_start, 5, 2) + '/' + substring(:as_start, 7, 2))   
       , edate     = convert(char(10), substring(:as_end,   1, 4) + '/' + substring(:as_end,   5, 2) + '/' + substring(:as_end,   7, 2))
 FROM itemloc with(nolock) left outer join ineoday with(nolock) on ( itemloc.loc_no = ineoday.loc_no    ) AND ( itemloc.item_no = ineoday.item_no   ) AND ( itemloc.qa = ineoday.qa        )
                                                                    left outer  join location with(nolock) on  ( itemloc.loc_no  = location.loc_no   ) 
                                                                    inner join  groupitem on ( itemloc.item_no        = groupitem.item_no ) 
                                                                    inner join  item on ( itemloc.item_no        = item.item_no      ) and ( itemloc.qa             = item.qa )
                                                                    left outer join  (
                                                                                                               select item_no, qa, loc_no, eqoh = (isnull(sum(rcpt_qty), 0) - isnull(sum(issue_qty), 0))
                                                                                                                  from ineoday
                                                                                                                WHERE cdate > :as_end
                                                                                                              group by item_no, qa, loc_no
                                                                                            ) eoday on  ( itemloc.item_no   = eoday.item_no     ) AND ( itemloc.qa            = eoday.qa          ) AND ( itemloc.loc_no   = eoday.loc_no      )
     where ( item.use_flag         <> 'C'               )
	  AND ( itemloc.loc_no      like :as_loc           )
	  AND ( ineoday.cdate    between :as_start and :as_end )
	  AND ( groupitem.item_no   like :as_item          )
	  AND ( groupitem.item_name like :as_name          )
	  AND ( groupitem.item_no      < 'PZZZFZ'          ) 
	  AND ( NOT (groupitem.uom     = 'M2' and groupitem.item_no like 'PCY%') )     
   GROUP BY groupitem.item_name
          , groupitem.uom         
          , itemloc.item_no       
          , itemloc.qa         
          , dbo.uf_getprice(itemloc.item_no, itemloc.qa, groupitem.uom)   
          , groupitem.uom
          , (case when :as_loc = 'A' then '전체' else location.loc_name end )
          , (isnull(itemloc.qoh, 0) - isnull(eoday.eqoh, 0))
          , dbo.uf_getqty(itemloc.item_no, itemloc.qa, groupitem.uom, (isnull(itemloc.qoh, 0) - isnull(eoday.eqoh, 0 )))
/*
    FROM itemloc,    
         ineoday,    
         location,   
         groupitem,
         item,
         (select item_no, qa, loc_no, eqoh = (isnull(sum(rcpt_qty), 0) - isnull(sum(issue_qty), 0))
            from ineoday
           WHERE cdate > :as_end
           group by item_no, qa, loc_no
         ) eoday
   WHERE ( itemloc.loc_no        *= location.loc_no   ) 
     AND ( itemloc.item_no        = groupitem.item_no ) 
     AND ( itemloc.loc_no        *= ineoday.loc_no    )
     AND ( itemloc.item_no       *= ineoday.item_no   )
     AND ( itemloc.qa            *= ineoday.qa        )
     AND ( itemloc.item_no        = item.item_no      )
     AND ( itemloc.qa             = item.qa           )
     AND ( item.use_flag         <> 'C'               )
     AND ( itemloc.loc_no      like :as_loc           )
     AND ( ineoday.cdate    between :as_start and :as_end )
     AND ( groupitem.item_no   like :as_item          )
     AND ( groupitem.item_name like :as_name          )
     AND ( itemloc.item_no       *= eoday.item_no     )
     AND ( itemloc.qa            *= eoday.qa          )
     AND ( itemloc.loc_no        *= eoday.loc_no      )
     AND ( groupitem.item_no      < 'PZZZFZ'          ) 
     AND ( NOT (groupitem.uom     = 'M2' and groupitem.item_no like 'PCY%') )            
   GROUP BY groupitem.item_name
          , groupitem.uom         
          , itemloc.item_no       
          , itemloc.qa         
          , dbo.uf_getprice(itemloc.item_no, itemloc.qa, groupitem.uom)   
          , groupitem.uom
          , (case when :as_loc = 'A' then '전체' else location.loc_name end )
          , (isnull(itemloc.qoh, 0) - isnull(eoday.eqoh, 0))
          , dbo.uf_getqty(itemloc.item_no, itemloc.qa, groupitem.uom, (isnull(itemloc.qoh, 0) - isnull(eoday.eqoh, 0 )))
*/
      " arguments=(("as_loc", string),("as_start", string),("as_end", string),("as_item", string),("as_name", string))  sort="groupitem_item_name A qa A location_loc_name A " )
