$PBExportHeader$d_mpsfcday_t.srd
$PBExportComments$생산일보조회(1998/05/08,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=sfcday_wc_no dbname="wc_no" )
 column=(type=char(10) updatewhereclause=yes name=wc_work_name dbname="work_name" initial=" " )
 column=(type=char(50) updatewhereclause=yes name=sfcday_cust_name dbname="cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene_desc" )
 column=(type=char(20) updatewhereclause=yes name=sfcday_qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=sfcday_uom dbname="uom" )
 column=(type=char(10) updatewhereclause=yes name=sfcday_item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=decimal(4) updatewhereclause=yes name=sum_qty dbname="sum_qty" )
 column=(type=decimal(0) updatewhereclause=yes name=uf_getqty dbname="uf_getqty" )
 column=(type=decimal(4) updatewhereclause=yes name=calc dbname="calc" )
 column=(type=char(10) updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=char(10) updatewhereclause=yes name=edate dbname="edate" )
 retrieve="  SELECT wc_no     = a.wc_no                
       , work_name = b.work_name              
       , cust_name = a.cust_name         
       , scene_desc= d.scene_desc            
       , qa        = a.assembly_qa     
       , uom       = a.uom                  
       , item_no   = a.assembly   
       , item_name = c.item_name         
       , sum_qty   = sum(make_qty)     
       , uf_getqty = floor(DBO.UF_GETQTY(a.assembly, a.assembly_qa, a.uom, sum(a.make_qty)))
       , calc      = isnull(DBO.UF_GetItemCalc_PUB( a.wc_no, a.assembly, a.assembly_qa, sum(a.make_qty) ),0)
       , sdate     = convert(char(10),min(a.sfc_date),111)
       , edate     = convert(char(10),max(a.sfc_date),111)
    FROM sfcday    a  
         LEFT OUTER JOIN wc        b  ON a.wc_no      = b.work_no
         LEFT OUTER JOIN groupitem c  ON a.assembly   = c.item_no
         LEFT OUTER JOIN scene     d  ON a.scene_code = d.scene_code
   WHERE ( b.work_name      LIKE :as_wc + '%' ) 
     AND ( convert(char(10),a.sfc_date,111)   BETWEEN :as_start and :as_end ) 
     AND ( a.area_no           = :as_area     ) 
   GROUP BY a.wc_no         
          , b.work_name     
          , a.cust_name  
          , d.scene_desc  
          , a.assembly_qa   
          , a.uom           
          , a.assembly      
          , c.item_name
" arguments=(("as_wc", string),("as_start", string),("as_end", string),("as_area", string))  sort="sfcday_wc_no A wc_work_name A sfcday_cust_name A scene_scene_desc A groupitem_item_name A sfcday_qa A " )
group(level=1 header.height=0 trailer.height=0 by=("sfcday_wc_no" ) header.color="536870912" trailer.color="536870912" )
group(level=2 header.height=0 trailer.height=72 by=("sfcday_cust_name" , "scene_scene_desc" ) header.color="536870912" trailer.color="553648127" )
