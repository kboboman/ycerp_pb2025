$PBExportHeader$d_mpsfcday_r3.srd
$PBExportComments$생산일보조회_보고서(일자별)(1998/05/08,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=468 color="536870912" )
summary(height=84 color="536870912" )
footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(40) updatewhereclause=yes name=wc_name dbname="wc_name" )
 column=(type=char(10) updatewhereclause=yes name=sfcday_sfc_date dbname="sfc_date" )
 column=(type=char(10) updatewhereclause=yes name=sfcday_item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=sfcday_qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=sfcday_uom dbname="uom" )
 column=(type=char(1) updatewhereclause=yes name=overtime dbname="overtime" )
 column=(type=decimal(4) updatewhereclause=yes name=sumqty1 dbname="sumqty1" )
 column=(type=decimal(4) updatewhereclause=yes name=sumqty2 dbname="sumqty2" )
 column=(type=decimal(0) updatewhereclause=yes name=getqty1 dbname="getqty1" )
 column=(type=decimal(0) updatewhereclause=yes name=getqty2 dbname="getqty2" )
 column=(type=char(10) updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=char(10) updatewhereclause=yes name=edate dbname="edate" )
 retrieve="  SELECT wc_name   = a.wc_name   
       , sfc_date  = a.sfc_date  
       , item_no   = a.item_no   
       , item_name = a.item_name 
       , qa        = a.qa        
       , uom       = a.uom       
       , overtime  = a.overtime  
       , sumqty1   = (case when a.overtime = '' then a.sum_qty   else 0           end)
       , sumqty2   = (case when a.overtime = '' then 0           else a.sum_qty   end)
       , getqty1   = (case when a.overtime = '' then a.uf_getqty else 0           end)
       , getqty2   = (case when a.overtime = '' then 0           else a.uf_getqty end)
       , sdate     = a.sdate     
       , edate     = a.edate     
    FROM (
         SELECT wc_name   = rtrim(b.work_name + space(30))         
              , sfc_date  = convert(char(10),a.sfc_date,111)
              , item_no   = a.assembly                         
              , item_name = c.item_name                     
              , qa        = a.assembly_qa                      
              , uom       = a.uom                              
              , overtime  = isnull(m.overtime,'')
              , sum_qty   = sum(a.make_qty)                 
              , uf_getqty = FLOOR(DBO.UF_GETQTY(a.assembly, a.assembly_qa, a.uom, sum(a.make_qty)))
              , sdate     = convert(char(10),min(a.sfc_date),111)
              , edate     = convert(char(10),max(a.sfc_date),111)
           FROM sfcday  a 
                LEFT OUTER JOIN mpsorder  m  ON a.mpsorder_order = m.order_no
                LEFT OUTER JOIN wc        b  ON a.wc_no     = b.work_no
                LEFT OUTER JOIN groupitem c  ON a.assembly  = c.item_no
          WHERE ( b.work_name        LIKE :as_wc + '%' ) 
            AND ( convert(char(10),a.sfc_date,111)  BETWEEN :as_start AND :as_end ) 
            AND ( a.area_no             = :as_area ) 
          GROUP BY b.work_name
                 , convert(char(10),a.sfc_date,111)
                 , a.assembly   
                 , c.item_name
                 , a.assembly_qa
                 , a.uom
                 , m.overtime
         ) A
" arguments=(("as_wc", string),("as_start", string),("as_end", string),("as_area", string))  sort="wc_name A sfcday_sfc_date A groupitem_item_name A sfcday_qa A " )
