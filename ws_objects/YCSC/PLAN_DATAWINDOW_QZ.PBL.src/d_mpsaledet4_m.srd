 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"mpsdet~" )  TABLE(NAME=~"groupitem~" )  TABLE(NAME=~"customer~" )  TABLE(NAME=~"scene~" ) COLUMN(NAME=~"mpsdet.plan_no~") COLUMN(NAME=~"mpsdet.order_no~") COLUMN(NAME=~"mpsdet.item_no~") COLUMN(NAME=~"mpsdet.uom~") COLUMN(NAME=~"mpsdet.order_qty~") COLUMN(NAME=~"mpsdet.due_date~") COLUMN(NAME=~"mpsdet.priority~") COLUMN(NAME=~"mpsdet.qa~") COLUMN(NAME=~"mpsdet.wc_no~") COLUMN(NAME=~"mpsdet.sale_no~") COLUMN(NAME=~"mpsdet.seq_no~") COLUMN(NAME=~"mpsdet.suju_type~") COLUMN(NAME=~"mpsdet.work_time~") COLUMN(NAME=~"mpsdet.setup_time~") COLUMN(NAME=~"mpsdet.rcpt_type~") COLUMN(NAME=~"mpsdet.rcpt_qty~") COLUMN(NAME=~"mpsdet.napgi_date~") COLUMN(NAME=~"mpsdet.item_color~") COLUMN(NAME=~"mpsdet.cust_no~") COLUMN(NAME=~"mpsdet.scene_code~") COLUMN(NAME=~"mpsdet.work_per~") COLUMN(NAME=~"mpsdet.division~") COLUMN(NAME=~"mpsdet.operation~") COLUMN(NAME=~"groupitem.item_name~") COLUMN(NAME=~"customer.cust_name~") COLUMN(NAME=~"scene.scene_desc~")    JOIN (LEFT=~"mpsdet.item_no~"    OP =~"=~"RIGHT=~"groupitem.item_no~"    OUTER1 =~"mpsdet.item_no~" )    JOIN (LEFT=~"mpsdet.cust_no~"    OP =~"=~"RIGHT=~"customer.cust_no~"    OUTER1 =~"mpsdet.cust_no~" )    JOIN (LEFT=~"mpsdet.scene_code~"    OP =~"=~"RIGHT=~"scene.scene_code~"    OUTER1 =~"mpsdet.scene_code~" )WHERE(    EXP1 =~"mpsdet.order_no~"   OP =~"=~"    EXP2 =~":arg_order~" ) ) ORDER(NAME=~"mpsdet.priority~" ASC=yes ) ARG(NAME = ~"arg_order~" TYPE = string) " update="mpsdet" updatewhere=0 updatekeyinplace=no arguments=(("arg_order", string)) )
