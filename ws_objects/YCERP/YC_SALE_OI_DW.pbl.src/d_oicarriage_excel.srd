 column=(type=char(1) updatewhereclause=yes name=fax dbname="FAX" )
 column=(type=char(1) updatewhereclause=yes name=email dbname="EMAIL" )
 column=(type=char(1) updatewhereclause=yes name=homepage dbname="HOMEPAGE" )
 column=(type=char(1) updatewhereclause=yes name=local_cd dbname="LOCAL_CD" )
 column=(type=char(1) updatewhereclause=yes name=limit_am dbname="LIMIT_AM" )
 column=(type=char(1) updatewhereclause=yes name=fr_dt dbname="FR_DT" )
 column=(type=char(1) updatewhereclause=yes name=to_dt dbname="TO_DT" )
 column=(type=char(20) updatewhereclause=yes name=ba_nb dbname="BA_NB" )
 column=(type=char(1) updatewhereclause=yes name=inter_am dbname="INTER_AM" )
 column=(type=char(1) updatewhereclause=yes name=inter_rt dbname="INTER_RT" )
 column=(type=char(1) updatewhereclause=yes name=inter_dt dbname="INTER_DT" )
 column=(type=char(1) updatewhereclause=yes name=due_dt dbname="DUE_DT" )
 column=(type=char(1) updatewhereclause=yes name=liq_ws dbname="LIQ_WS" )
 column=(type=char(1) updatewhereclause=yes name=liq_rs dbname="LIQ_RS" )
 column=(type=char(40) updatewhereclause=yes name=depositor dbname="DEPOSITOR" )
 column=(type=char(20) updatewhereclause=yes name=dummy2 dbname="DUMMY2" )
 column=(type=char(1) updatewhereclause=yes name=tr_nmk dbname="TR_NMK" )
 column=(type=char(1) updatewhereclause=yes name=attr_nmk dbname="ATTR_NMK" )
 column=(type=char(1) updatewhereclause=yes name=ceo_nmk dbname="CEO_NMK" )
 column=(type=char(1) updatewhereclause=yes name=deposit_fg dbname="DEPOSIT_FG" )
 column=(type=char(1) updatewhereclause=yes name=deposit_nm dbname="DEPOSIT_NM" )
 column=(type=char(1) updatewhereclause=yes name=trso_fg dbname="TRSO_FG" )
 column=(type=char(1) updatewhereclause=yes name=settle_pay dbname="SETTLE_PAY" )
 column=(type=char(1) updatewhereclause=yes name=settle_rcp dbname="SETTLE_RCP" )
 column=(type=char(1) updatewhereclause=yes name=settle_cd dbname="SETTLE_CD" )
 column=(type=char(1) updatewhereclause=yes name=paycon_dc dbname="PAYCON_DC" )
 column=(type=char(1) updatewhereclause=yes name=trgrp_cd dbname="TRGRP_CD" )
 column=(type=char(1) updatewhereclause=yes name=pjt_cd dbname="PJT_CD" )
 column=(type=char(1) updatewhereclause=yes name=link_cd dbname="LINK_CD" )
 column=(type=char(12) updatewhereclause=yes name=car_no dbname="car_no" )
 column=(type=char(8) updatewhereclause=yes key=yes name=cardate dbname="car_carriage.cardate" )
 column=(type=char(11) updatewhereclause=yes key=yes name=scene_code dbname="car_carriage.scene_code" )
 column=(type=long updatewhereclause=yes key=yes name=car_seq dbname="car_carriage.car_seq" )
 retrieve="SELECT '1000' CO_CD,                              /* 회사코드               */
              ''			 TR_CD,                          /* 거래처코드           */
              a.car_cust_name TR_NM,            /* 거래처명              */
              '' ATTR_NM,                                   /* 거래처명약칭       */
              '' TR_FG,                                         /* 거래처 구분          */
              a.owner_reg REG_NB,                  /* 사업장등록번호    */
              '' PPL_NB,                                       /* 주민등록번호       */
              a.owner_name CEO_NM,             /* 대표자명              */
              a.business,                                       /* 업태                     */
              a.jongmok,                                      /* 종목                     */
              '' ZIP,                                                 /* 우편번호               */   
              a.owner_addr DIV_ADDR1,          /* 주소상세1            */ 
              ''  ADDR2,                     			          /* 주소상세2            */ 
              a.owner_tel TEL,                                    /* 전화번호              */ 
              '' FAX,                                              /* 팩스번호              */  
              '' EMAIL,                                          /* 이메일                 */ 
              '' HOMEPAGE,                                /* 홈페이지 주소     */  
              '' LOCAL_CD,                                   /* 지역코드             */  
              '' LIMIT_AM,                                    /* 한도금액              */  
              '' FR_DT,                                           /* 시작일                 */  
              '' TO_DT,                                          /* 종료일                 */   
              a.owner_bank_no BA_NB,             /* 예금 계좌번호      */                             
              '' INTER_AM,                                    /*월불입액             */               
              '' INTER_RT,                                      /* 이자율                */               
              '' INTER_DT,                                      /* 거래시작일         */               
              '' DUE_DT,                                        /* 거래종료일         */               
              '' LIQ_WS,                                          /* 카드구분            */          
              '' LIQ_RS,                                            /* 주류코드           */          
              a.owner_bank_master DEPOSITOR, /* 예금주명          */          
              a.owner_bank_name DUMMY2,     /* 지점명              */          
              '' TR_NMK,                                          /*거래처명(제2외국어)*/
              '' ATTR_NMK,                                      /*약칭거래처명(제2외국어)*/
              ''  CEO_NMK,                                      /*대표자명(제2외국어)*/
              ''  DEPOSIT_FG,                                  /*예금종류                   */
              ''  DEPOSIT_NM,                                 /*예금명                       */
              ''  TRSO_FG,                                        /*거래형태                    */
              ''  SETTLE_PAY,                                   /*지급결제예정             */
              ''  SETTLE_RCP,                                   /*수금회수예정              */
              ''  SETTLE_CD,                                     /*수금회수은행코드       */
              ''  PAYCON_DC,                                  /*결제기준                      */
              ''  TRGRP_CD,                                       /*거래처분류                 */
              ''  PJT_CD,                                             /*프로젝트코드              */  
              ''  LINK_CD,                                            /*외부데이터코드           */             
               a.car_no,
               a.cardate,
		    a.scene_code,															
		    a.car_seq															   
FROM dbo.car_carriage a with(nolock)
where a.cardate between :ls_fr_date and :ls_to_date
    and a.car_status = '03'" update="car_carriage" updatewhere=0 updatekeyinplace=no arguments=(("ls_fr_date", string),("ls_to_date", string)) )
