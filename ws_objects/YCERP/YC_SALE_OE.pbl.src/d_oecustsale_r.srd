table(column=(type=char(10) update=yes updatewhereclause=yes name=cust_sale_lot_no dbname="cust_sale.lot_no" )
 column=(type=char(6) update=yes updatewhereclause=yes name=cust_sale_yyyymm dbname="cust_sale.yyyymm" )
 column=(type=char(10) update=yes updatewhereclause=yes name=cust_sale_salesman dbname="cust_sale.salesman" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name dbname="login.user_name" )
 column=(type=char(4) update=yes updatewhereclause=yes name=cust_no dbname="cust_sale.cust_no" )
