table(column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(11) updatewhereclause=yes name=do_spot_code dbname="spot_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene_desc" )
 column=(type=char(14) updatewhereclause=yes name=do_do_no dbname="do_no" )
 column=(type=long updatewhereclause=yes name=dodet_oi_no dbname="oi_no" )
 column=(type=datetime updatewhereclause=yes name=do_do_date dbname="do_date" )
 column=(type=datetime updatewhereclause=yes name=ship_date dbname="ship_date" )
 column=(type=char(10) updatewhereclause=yes name=dodet_item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=dodet_qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=dodet_uom dbname="uom" )
 column=(type=decimal(2) updatewhereclause=yes name=dodet_ship_qty dbname="ship_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=dodet_price dbname="price" )
 column=(type=decimal(4) updatewhereclause=yes name=dodet_rate_cash dbname="rate_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=c_acc_qty dbname="c_acc_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_rate dbname="do_rate" )
 column=(type=char(3) updatewhereclause=yes name=do_curr_code dbname="curr_code" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_cash dbname="do_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_total dbname="do_total" )
 column=(type=char(1) updatewhereclause=yes name=do_shipamt_case dbname="shipamt_case" )
 column=(type=char(30) updatewhereclause=yes name=do_ship_flag dbname="ship_flag" values="착불	C/대여	D/부담	B/방문	M/" )
 column=(type=char(1) updatewhereclause=yes name=ship_flag2 dbname="ship_flag2" )
 column=(type=decimal(0) updatewhereclause=yes name=do_ship_amount dbname="ship_amount" )
 column=(type=char(1) updatewhereclause=yes name=round dbname="round" )
 column=(type=char(14) updatewhereclause=yes name=dodet_sale_no dbname="sale_no" )
 column=(type=datetime updatewhereclause=yes name=do_prt_date dbname="prt_date" )
 column=(type=long updatewhereclause=yes name=datecalc dbname="datecalc" )
 column=(type=decimal(4) updatewhereclause=yes name=do_rate dbname="do_rate" )
 column=(type=decimal(4) updatewhereclause=yes name=do_cash dbname="do_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=do_total dbname="do_total" )
 retrieve="  SELECT cust_no      = a.cust_no      
       , cust_name    = a.cust_name    
       , spot_code    = a.spot_code    
       , scene_desc   = a.scene_desc   
       , do_no        = a.do_no        
       , oi_no        = a.oi_no        
       , do_date      = a.do_date      
       , ship_date    = a.ship_date    
       , item_no      = a.item_no      
       , item_name    = a.item_name    
       , qa           = a.qa           
       , uom          = a.uom          
       , ship_qty     = a.ship_qty     
       , price        = a.price        
       , rate_cash    = a.rate_cash    
       , c_acc_qty    = a.c_acc_qty    
       , do_rate      = a.do_rate      
       , curr_code    = a.curr_code    
       , do_cash      = a.do_cash      
       , do_total     = a.do_total     
       , shipamt_case = a.shipamt_case 
       , ship_flag    = a.ship_flag    
       , ship_flag2   = a.ship_flag2   
       , ship_amount  = a.ship_amount  
       , round        = a.round      
       , sale_no      = a.sale_no      
       , prt_date     = a.prt_date     
       , datecalc     = a.datecalc     
       , do_rate      = b.do_rate
       , do_cash      = b.do_cash
       , do_total     = b.do_total
    FROM (
         SELECT cust_no      = do_ewol.cust_no       
              , cust_name    = customer.cust_name  
              , spot_code    = do_ewol.spot_code     
              , scene_desc   = scene.scene_desc    
              , do_no        = do_ewol.do_no         
              , oi_no        = dodet_ewol.oi_no       
              , do_date      = do_ewol.do_date       
              , ship_date    = do_ewol.ship_date       
              , item_no      = dodet_ewol.item_no     
              , item_name    = groupitem.item_name 
              , qa           = dodet_ewol.qa          
              , uom          = dodet_ewol.uom         
              , ship_qty     = dodet_ewol.ship_qty    
              , price        = dodet_ewol.price       
              , rate_cash    = dodet_ewol.rate_cash   
              , c_acc_qty    = round(dbo.uf_getqty(dodet_ewol.item_no, dodet_ewol.qa, dodet_ewol.uom, dodet_ewol.ship_qty),2,1)
              , do_rate      = do_ewol.do_rate       
              , curr_code    = do_ewol.curr_code     
              , do_cash      = do_ewol.do_cash       
              , do_total     = do_ewol.do_total      
              , shipamt_case = do_ewol.shipamt_case   
              , ship_flag    = dbo.uf_getshipflag(do_ewol.ship_flag)
              , ship_flag2   = do_ewol.ship_flag
              , ship_amount  = do_ewol.ship_amount   
              , fob          = do_ewol.fob           
              , bus_tel      = customer.bus_tel    
              , tel_no       = customer.tel_no     
              , round        = customer.round      
              , sale_no      = dodet_ewol.sale_no       
              , prt_date     = do_ewol.prt_date
              , datecalc     = DATEDIFF(month, do_ewol.issue_date, do_ewol.do_date) 
           FROM do_ewol          
              , dodet_ewol       
              , groupitem
              , customer 
              , scene
          WHERE ( do_ewol.do_no          = dodet_ewol.do_no  )   
            AND ( do_ewol.cust_no        = customer.cust_no  )   
            AND ( do_ewol.spot_code      = scene.scene_code  )   
            AND ( dodet_ewol.item_no     = groupitem.item_no )   
            AND ( :as_salesman  = '%' AND customer.salesman  LIKE :as_salesman
                  OR
                  :as_salesman <> '%' AND customer.salesman     = :as_salesman
                )
            AND ( :as_areano    = '%' AND do_ewol.area_no    LIKE :as_areano
                  OR
                  :as_areano   <> '%' AND do_ewol.area_no       = :as_areano
                )
            AND ( :as_custno    = '%' AND do_ewol.cust_no    LIKE :as_custno
                  OR
                  :as_custno   <> '%' AND do_ewol.cust_no       = :as_custno
                )
            AND ( do_ewol.do_date    BETWEEN :as_sdate AND :as_edate )
         ) A
         FULL OUTER JOIN (  /* 출고상세 삭제시 순번 재정의 안됨 */
            SELECT do_no    = a.do_no
                 , oi_no    = min(a.oi_no)
                 , do_rate  = max(a.do_rate)
                 , do_cash  = max(a.do_cash)
                 , do_total = max(a.do_total)
              FROM (
                    SELECT do_no        = a.do_no       
                         , oi_no        = b.oi_no       
                         , do_rate      = a.do_rate     
                         , do_cash      = a.do_cash     
                         , do_total     = a.do_total    
                      FROM do_ewol    a       
                         , dodet_ewol b       
                         , groupitem  c  
                         , customer   d
                     WHERE ( a.do_no       = b.do_no    ) 
                       AND ( b.item_no     = c.item_no  ) 
                       AND ( a.cust_no     = d.cust_no  ) 
                       AND ( :as_salesman  = '%' AND d.salesman  LIKE :as_salesman
                             OR
                             :as_salesman <> '%' AND d.salesman     = :as_salesman
                           )
                       AND ( :as_areano    = '%' AND a.area_no   LIKE :as_areano
                             OR
                             :as_areano   <> '%' AND a.area_no      = :as_areano
                           )
                       AND ( :as_custno    = '%' AND a.cust_no   LIKE :as_custno
                             OR
                             :as_custno   <> '%' AND a.cust_no      = :as_custno
                           )
                       AND ( a.do_date    BETWEEN :as_sdate AND :as_edate )
                  /* order by 1, 2 */
                  ) A
              GROUP BY a.do_no
         ) B  ON a.do_no = b.do_no AND a.oi_no = b.oi_no                         
" arguments=(("as_salesman", string),("as_areano", string),("as_custno", string),("as_sdate", string),("as_edate", string))  sort="cust_no A do_spot_code A do_do_date A do_do_no A dodet_oi_no A " )
