 column=(type=datetime update=yes updatewhereclause=yes name=make_date dbname="make_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=make_user dbname="make_user" )
 column=(type=char(73) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(15) updatewhereclause=yes name=user_name dbname="user_name" )
 retrieve="  SELECT cust_no      = a.cust_no   
       , eom_year     = a.eom_year   
       , balbf_amount = a.balbf_amount   
       , inv_01       = a.inv_01   
       , inv_02       = a.inv_02   
       , inv_03       = a.inv_03   
       , inv_04       = a.inv_04   
       , inv_05       = a.inv_05   
       , inv_06       = a.inv_06   
       , inv_07       = a.inv_07   
       , inv_08       = a.inv_08   
       , inv_09       = a.inv_09   
       , inv_10       = a.inv_10   
       , inv_11       = a.inv_11   
       , inv_12       = a.inv_12   
       , coll_01      = a.coll_01   
       , coll_02      = a.coll_02   
       , coll_03      = a.coll_03   
       , coll_04      = a.coll_04   
       , coll_05      = a.coll_05   
       , coll_06      = a.coll_06   
       , coll_07      = a.coll_07   
       , coll_08      = a.coll_08   
       , coll_09      = a.coll_09   
       , coll_10      = a.coll_10   
       , coll_11      = a.coll_11   
       , coll_12      = a.coll_12   
       , make_date    = a.make_date   
       , make_user    = a.make_user   
       , cust_name    = rtrim(c.cust_name) + (case when c.collect_ymd is null  then '' 
                                                   else '  채권관리 : ' + convert(char(10),collect_ymd,111)
                                              end) 
       , user_name = (case when c.salesman = 'leesy2' then '법무:' + s.user_name else b.user_name end)
    FROM opeom_beamt a
         LEFT OUTER JOIN customer c ON a.cust_no = c.cust_no
         LEFT OUTER JOIN (
              SELECT top 1  a.cust_no, b.user_name 
                FROM sale a
                     LEFT OUTER JOIN login b  ON a.salesman = b.user_id
               WHERE a.cust_no  = :aa 
               ORDER BY order_date desc
         ) S  ON a.cust_no = s.cust_no
         LEFT OUTER JOIN login B  ON c.salesman  = b.user_id
   WHERE ( a.cust_no    = :aa ) 
     AND ( datepart(year,a.eom_year) = :bb  ) 


" arguments=(("aa", string),("bb", number)) )
