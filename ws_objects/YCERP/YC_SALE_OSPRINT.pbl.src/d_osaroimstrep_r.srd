release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="79416533" )
summary(height=0 color="536870912" )
footer(height=80 color="15780518" )
detail(height=80 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=aroiinv_cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="cust_name" )
 column=(type=char(1) updatewhereclause=yes name=aroiinv_sale_flag dbname="sale_flag" values="내수	D/수출	E/L//C	L/" )
 column=(type=char(1) updatewhereclause=yes name=aroiinv_inv_type dbname="inv_type" values="매출	Y/선매출	N/" )
 column=(type=datetime updatewhereclause=yes name=aroiinv_oi_date dbname="oi_date" )
 column=(type=char(3) updatewhereclause=yes name=aroiinv_curr_code dbname="curr_code" )
 column=(type=decimal(4) updatewhereclause=yes name=aroiinv_aroiinv_cash dbname="aroiinv_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=aroiinv_ship_cost dbname="ship_cost" )
 column=(type=decimal(4) updatewhereclause=yes name=aroiinv_aroiinv_rate dbname="aroiinv_rate" )
 column=(type=decimal(0) updatewhereclause=yes name=aroiinv_dc dbname="dc" )
 column=(type=decimal(4) updatewhereclause=yes name=aroiinv_gl_cur_rate dbname="gl_cur_rate" )
 column=(type=decimal(0) updatewhereclause=yes name=aroiinv_dc_rate dbname="dc_rate" )
 column=(type=decimal(0) updatewhereclause=yes name=aroiinv_discount dbname="discount" )
 column=(type=char(12) updatewhereclause=yes name=aroiinv_aroiinv_no dbname="aroiinv_no" )
 column=(type=char(40) updatewhereclause=yes name=rem dbname="rem" )
 column=(type=char(20) updatewhereclause=yes name=aroiinv_inv_area dbname="inv_area" )
 retrieve="  SELECT aroiinv.cust_no        
       , customer.cust_name     
       , aroiinv.sale_flag      
       , aroiinv.inv_type       
       , aroiinv.oi_date        
       , aroiinv.curr_code      
       , aroiinv.aroiinv_cash   
       , aroiinv.ship_cost      
       , aroiinv.aroiinv_rate   
       , aroiinv.dc             
       , aroiinv.gl_cur_rate    
       , aroiinv.dc_rate        
       , aroiinv.discount       
       , aroiinv.aroiinv_no
       , aroiinv.rem     
       , inv_area  = a.area_desc
    FROM aroiinv   
       , customer  
       , (SELECT inv_area  = left(area.area_no,1) + substring(area.area_no, 4,2)
               , area_desc = area.area_name
            FROM area   
         ) a
   WHERE ( aroiinv.cust_no           = customer.cust_no ) 
     AND ( aroiinv.inv_area          = a.inv_area ) 
     AND ( customer.salesman      LIKE :as_userid       ) 
     AND ( aroiinv.sale_flag        IN ( 'D','L','E' )  )
     AND ( aroiinv.oi_date     BETWEEN :ad_start AND :ad_end )
     AND ( aroiinv.delete_flag       = 'N'              )
     AND ( aroiinv.inv_area       LIKE :as_area         )     
     AND ((:as_custno   = '%' AND aroiinv.cust_no LIKE :as_custno) OR
          (:as_custno  <> '%' AND aroiinv.cust_no    = :as_custno)
         )
" arguments=(("as_custno", string),("ad_start", date),("ad_end", date),("as_area", string),("as_userid", string))  sort="aroiinv_aroiinv_no A customer_cust_name A aroiinv_oi_date A " )
