 retrieve="SELECT itemsos.sos_no ,
       itemsos.subject ,
       itemsos.item_no ,
       itemsos.cust_no ,
       itemsos.scene_code ,
       itemsos.bigo ,
       itemsos.user_id ,
       itemsos.team_id ,
       itemsos.div_id 
  FROM itemsos
" update="itemsos" updatewhere=0 updatekeyinplace=no )
