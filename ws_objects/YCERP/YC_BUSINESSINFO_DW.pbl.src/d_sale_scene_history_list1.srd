																						null wall7,
																						null ceilling7, 
																						null pilotis7,
																				 		null etc7,
                                            														null salesman7                                            
																				  from sale_scene_interior
																				  where seq = 4
																				  union all
																				  select  scene_code,
																						null interior_name1, 
																						null wall1, 
																						null ceilling1, 
																						null pilotis1,
																				 		null etc1,
                                            														null salesman1,                                            
