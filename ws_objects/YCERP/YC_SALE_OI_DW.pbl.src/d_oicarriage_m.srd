 column=(type=char(40) updatewhereclause=yes name=owner_bank_master_origin dbname="car_carriage.owner_bank_master_origin" )
 column=(type=char(20) update=yes updatewhereclause=yes name=owner_bank_name dbname="car_carriage.owner_bank_name" )
 column=(type=char(20) updatewhereclause=yes name=owner_bank_name_origin dbname="car_carriage.owner_bank_name_origin" )
 column=(type=char(20) updatewhereclause=yes name=driver_name dbname="car_carriage.driver_name" )
 column=(type=char(12) updatewhereclause=yes name=car_no dbname="car_carriage.car_no" )
 column=(type=char(50) update=yes updatewhereclause=yes name=car_cust_name dbname="car_carriage.car_cust_name" )
 column=(type=char(50) updatewhereclause=yes name=car_cust_name_origin dbname="car_carriage.car_cust_name_origin" )
 column=(type=char(14) updatewhereclause=yes name=car_carriage_do_no dbname="car_carriage.do_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=carriage_length dbname="car_carriage.carriage_length" )
 column=(type=char(1) update=yes updatewhereclause=yes name=slip_yn dbname="car_carriage.slip_yn" values="	Y/	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=tax_yn dbname="car_carriage.tax_yn" values="	Y/	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=receipt_yn dbname="car_carriage.receipt_yn" values="	Y/	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=shipamt_yn dbname="car_carriage.shipamt_yn" values="	Y/	N" )
 column=(type=char(180) updatewhereclause=yes name=order_no dbname="order_no" )
 retrieve="SELECT (case when a.car_status = '03' then '작성전'
                        when  a.car_status = '04' then  '엑셀작성'
                end) car_status,
              substring(a.cardate,5,4) yymmdd,
		    a.cardate,
              a.car_seq,
              c.cust_no,
              c.cust_name, 
              a.scene_code,
              b.scene_desc,
              a.owner_reg, 
              a.owner_reg owner_reg_origin,
              a.owner_name, 
              a.owner_name owner_name_origin,
              a.business, 
              a.business business_origin,
              a.jongmok, 
              a.jongmok jongmok_origin,
              a.owner_addr, 
              a.owner_addr owner_addr_origin,
              a.owner_tel, 
              a.owner_tel owner_tel_origin, 
              a.owner_bank_no,               
              a.owner_bank_no owner_bank_no_origin, 
              a.owner_bank_master,
              a.owner_bank_master owner_bank_master_origin,
              a.owner_bank_name,
              a.owner_bank_name owner_bank_name_origin,
              a.driver_name,
              a.car_no,
              a.car_cust_name,
              a.car_cust_name car_cust_name_origin,
		    a.do_no,
		    a.carriage_length,
              a.slip_yn,
              a.tax_yn,
              a.receipt_yn,
              a.shipamt_yn,

		   dbo.uf_get_dosaleno(a.do_no) order_no
FROM car_carriage a inner join scene b on a.scene_code = b.scene_code
                                     inner join customer c on b.cust_no = c.cust_no
							inner join do d on a.do_no = d.do_no
where convert(char(8),d.do_date,112) between :ls_fr_date  and :ls_to_date
    and a.car_status in ( '03', '04' )
    and a.car_status like :ls_status
    and a.do_no is not null" update="car_carriage" updatewhere=0 updatekeyinplace=no arguments=(("ls_fr_date", string),("ls_to_date", string),("ls_status", string))  sort="car_carriage_car_status A yymmdd A scene_scene_desc A car_no A " )
