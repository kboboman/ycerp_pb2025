 retrieve="PBSELECT( VERSION(400) DISTINCT ()TABLE(NAME=~"pur~" )  TABLE(NAME=~"supp~" )  TABLE(NAME=~"purdet~" ) COLUMN(NAME=~"pur.order_no~") COLUMN(NAME=~"pur.supp_no~") COLUMN(NAME=~"pur.shipto_addr~") COLUMN(NAME=~"pur.curr_code~") COLUMN(NAME=~"pur.order_date~") COLUMN(NAME=~"pur.buyer~") COLUMN(NAME=~"pur.terms~") COLUMN(NAME=~"pur.fob~") COLUMN(NAME=~"pur.revision_no~") COLUMN(NAME=~"pur.revision_date~") COLUMN(NAME=~"pur.po_print~") COLUMN(NAME=~"pur.open_close~") COLUMN(NAME=~"pur.close_date~") COLUMN(NAME=~"pur.close_type~") COLUMN(NAME=~"pur.subcon~") COLUMN(NAME=~"supp.supp_name~")    JOIN (LEFT=~"pur.supp_no~"    OP =~"=~"RIGHT=~"supp.supp_no~" )    JOIN (LEFT=~"pur.order_no~"    OP =~"=~"RIGHT=~"purdet.order_no~" )) " update="pur" updatewhere=1 updatekeyinplace=no )
