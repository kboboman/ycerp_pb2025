 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"bdinfo~" )  TABLE(NAME=~"bdinfodet~" ) COLUMN(NAME=~"bdinfodet.seq~") COLUMN(NAME=~"bdinfodet.person~") COLUMN(NAME=~"bdinfodet.floors~") COLUMN(NAME=~"bdinfodet.city~") COLUMN(NAME=~"bdinfodet.master~") COLUMN(NAME=~"bdinfodet.designoffice~") COLUMN(NAME=~"bdinfodet.spec~") COLUMN(NAME=~"bdinfodet.workarea~") COLUMN(NAME=~"bdinfodet.buildingcom~") COLUMN(NAME=~"bdinfodet.bulidingphone~") COLUMN(NAME=~"bdinfodet.predate~") COLUMN(NAME=~"bdinfodet.completiondate~") COLUMN(NAME=~"bdinfodet.status~") COLUMN(NAME=~"bdinfodet.build_no~") COLUMN(NAME=~"bdinfodet.project~") COLUMN(NAME=~"bdinfodet.quantity~") COLUMN(NAME=~"bdinfodet.square~") COLUMN(NAME=~"bdinfodet.dong~") COLUMN(NAME=~"bdinfodet.std_chk~") COLUMN(NAME=~"bdinfodet.spec2~") COLUMN(NAME=~"bdinfodet.spec3~") COLUMN(NAME=~"bdinfodet.salequantity~") COLUMN(NAME=~"bdinfodet.dept~") COLUMN(NAME=~"bdinfodet.unit~")    JOIN (LEFT=~"bdinfodet.build_no~"    OP =~"=~"RIGHT=~"bdinfo.build_no~" )WHERE(    EXP1 =~"bdinfo.build_no~"   OP =~"=~"    EXP2 =~":arg_build_no~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"bdinfodet.std_chk~"   OP =~"=~"    EXP2 =~"'1'~" ) ) ARG(NAME = ~"arg_build_no~" TYPE = string) " arguments=(("arg_build_no", string)) )
