								when 11 then
									 opeom_b.coll_11
								when 12 then
									 opeom_b.coll_12 
							end))/1000
    FROM customer,   
         (select user_id, 
					team_code = (case  when login.team_code = '71000' or login.team_code ='72000' or login.team_code ='73000' or login.team_code ='74000' or
                                       login.team_code = '75000' or login.team_code ='76000' or login.team_code ='77000' or login.team_code ='78000' or login.team_code ='79000' 
													then login.team_code 
											 else '99000' end),   
         		team_name = (case  when login.team_code = '71000' or login.team_code ='72000' or login.team_code ='73000' or login.team_code ='74000' or
                                       login.team_code = '75000' or login.team_code ='76000'
													then team.team_name 
                                  when login.team_code = '77000' or login.team_code ='78000' or login.team_code ='79000' 
													then '서부점' 
											 else '기타' end),   
         		user_name = (case  when login.team_code = '71000' or login.team_code ='72000' or login.team_code ='73000' or login.team_code ='74000' or
                                       login.team_code = '75000' or login.team_code ='76000'
													then login.user_name 
                                  when login.team_code = '77000'
                                       then '서부-매장'
                                  when login.team_code = '78000'
                                       then '서부-영업' 
                                  when login.team_code = '79000' 
                                       then '서부-채권' 
											 else '공장,현금판매' end),
					rank_no   = (case  when login.team_code = '71000' or login.team_code ='72000' or login.team_code ='73000' or login.team_code ='74000' or
                                       login.team_code = '75000' or login.team_code ='76000' or login.team_code ='77000' or login.team_code ='78000' or login.team_code ='79000' 
													then login.rank_no 
											 else '00' end),
					rank      = (case  when login.team_code = '71000' or login.team_code ='72000' or login.team_code ='73000' or login.team_code ='74000' or
                                       login.team_code = '75000' or login.team_code ='76000' or login.team_code ='77000' or login.team_code ='78000' or login.team_code ='79000' 
													then login.rank 
											 else '外' end) 
			from login, team
			where login.team_code = team.team_code
			and use_flag = 'Y') UT,   
         cust_aim,   
         opeom opeom_a,   
         opeom opeom_b  
   WHERE ( customer.cust_flag = 'N' ) and
			( customer.cust_type <> 'E' ) and
			( customer.salesman = UT.user_id ) and  
         ( customer.cust_no *= cust_aim.cust_code) and  
         ( datepart(year,cust_aim.tar_year) = :ai_year ) and
         ( customer.cust_no *= opeom_a.cust_no) and  
         ( datepart(year,opeom_a.eom_year) = :ai_year - 1 ) AND
         ( customer.cust_no *= opeom_b.cust_no) and  
         ( datepart(year,opeom_b.eom_year) = :ai_year ) and
         ( customer.salesman like :as_userid )
	group by UT.team_code,   
         UT.team_name,   
         UT.user_name,
			UT.rank_no,
			UT.rank
*/			" filter=" pre_yinv <>0 or  cur_ayinv <>0 or   cur_amninv  <>0 or  cur_inv  <>0 or  cur_aminv  <>0 or  cur_minv  <>0 or  cur_amcoll  <>0 or  cur_mcoll  <>0 "arguments=(("ai_year", number),("ai_mon", number),("as_userid", string))  sort="login_team_code A login_rank_no A pre_yinv D login_user_name A " )
