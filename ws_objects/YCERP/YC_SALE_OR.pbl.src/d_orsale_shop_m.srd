 retrieve="  SELECT chk_yn   = 'N'
       , saleshop.order_no   
       , saleshop.cust_no   
       , saleshop.scene_code   
       , saleshop.order_date   
       , saleshop.due_date   
       , saleshop.estimate_no   
       , saleshop.sale_flag   
       , saleshop.curr_code   
       , saleshop.cust_po_no   
       , saleshop.cust_po_date   
       , saleshop.ship_flag   
       , saleshop.fob   
       , saleshop.salesman   
       , saleshop.confirm_flag   
       , saleshop.confirm_user   
       , saleshop.confirm_date   
       , saleshop.tax_sign   
       , saleshop.sale_tax   
       , saleshop.sale_amount   
       , saleshop.open_close   
       , saleshop.close_type   
       , saleshop.close_date   
       , saleshop.shipto_addr   
       , saleshop.rem   
       , saleshop.revision_no   
       , saleshop.revision_date   
       , saleshop.input_date   
       , saleshop.login_id   
       , saleshop.tel_no   
       , saleshop.ship_case   
       , saleshop.rem1   
       , saleshop.rem2   
       , saleshop.plan_date   
       , saleshop.shipamt_case   
       , saleshop.area_no   
       , saleshop.ysp_confirm   
       , saleshop.ysp_qty   
       , saleshop.color   
       , saleshop.type   
       , saleshop.class   
       , saleshop.ysp_qty2   
       , jupsu_flag = (case when s.order_no IS NULL then 'N' else 'Y' end)
       , saleshop.jupsu_date   
       , sale_no    = s.order_no
    FROM saleshop   
         LEFT OUTER JOIN sale         S ON saleshop.order_date = s.order_date AND saleshop.order_no = s.cust_po_no
   WHERE saleshop.order_date between :as_sdate AND :as_edate
     AND s.order_no IS NULL /* 수주관리 이관 주문장은 SKIP */
" update="saleshop" updatewhere=1 updatekeyinplace=no arguments=(("as_sdate", string),("as_edate", string))  sort="order_no D " )
