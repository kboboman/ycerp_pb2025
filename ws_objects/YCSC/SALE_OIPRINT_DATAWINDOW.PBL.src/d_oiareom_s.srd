 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="areom.uom" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=do_qty dbname="areom.do_qty" )
 column=(type=decimal(3) update=yes updatewhereclause=yes name=price dbname="areom.price" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=amount dbname="areom.amount" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=vat dbname="areom.vat" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=tot_amount dbname="areom.tot_amount" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=vc_amount dbname="areom.vc_amount" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=seq_no dbname="areom.seq_no" )
