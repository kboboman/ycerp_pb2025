$PBExportHeader$d_ocsaleageing_s.srd
$PBExportComments$매출채권 연령표
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(3) updatewhereclause=yes name=credit_day dbname="credit_day" )
 column=(type=char(4) updatewhereclause=yes name=yyyy dbname="yyyy" )
 column=(type=char(4) updatewhereclause=yes name=gubun dbname="gubun" )
 column=(type=decimal(2) updatewhereclause=yes name=ewol1 dbname="ewol1" )
 column=(type=decimal(2) updatewhereclause=yes name=m24 dbname="m24" )
 column=(type=decimal(2) updatewhereclause=yes name=m23 dbname="m23" )
 column=(type=decimal(2) updatewhereclause=yes name=m22 dbname="m22" )
 column=(type=decimal(2) updatewhereclause=yes name=m21 dbname="m21" )
 column=(type=decimal(2) updatewhereclause=yes name=m20 dbname="m20" )
 column=(type=decimal(2) updatewhereclause=yes name=m19 dbname="m19" )
 column=(type=decimal(2) updatewhereclause=yes name=m18 dbname="m18" )
 column=(type=decimal(2) updatewhereclause=yes name=m17 dbname="m17" )
 column=(type=decimal(2) updatewhereclause=yes name=m16 dbname="m16" )
 column=(type=decimal(2) updatewhereclause=yes name=m15 dbname="m15" )
 column=(type=decimal(2) updatewhereclause=yes name=m14 dbname="m14" )
 column=(type=decimal(2) updatewhereclause=yes name=m13 dbname="m13" )
 column=(type=decimal(2) updatewhereclause=yes name=m12 dbname="m12" )
 column=(type=decimal(2) updatewhereclause=yes name=m11 dbname="m11" )
 column=(type=decimal(2) updatewhereclause=yes name=m10 dbname="m10" )
 column=(type=decimal(2) updatewhereclause=yes name=m09 dbname="m09" )
 column=(type=decimal(2) updatewhereclause=yes name=m08 dbname="m08" )
 column=(type=decimal(2) updatewhereclause=yes name=m07 dbname="m07" )
 column=(type=decimal(2) updatewhereclause=yes name=m06 dbname="m06" )
 column=(type=decimal(2) updatewhereclause=yes name=m05 dbname="m05" )
 column=(type=decimal(2) updatewhereclause=yes name=m04 dbname="m04" )
 column=(type=decimal(2) updatewhereclause=yes name=m03 dbname="m03" )
 column=(type=decimal(2) updatewhereclause=yes name=m02 dbname="m02" )
 column=(type=decimal(2) updatewhereclause=yes name=m01 dbname="m01" )
 column=(type=decimal(2) updatewhereclause=yes name=ewol2 dbname="ewol2" )
 retrieve="    SELECT user_name    = RTRIM(LG.USER_NAME)                                                                  
         , cust_no      = EE.CODE                                                                              
         , cust_name    = RTRIM(CM.CUST_NAME)                                                                  
         , credit_day   = ISNULL(CM.CREDIT_DAY,0)                                                              
         , yyyy         = CONVERT(CHAR(4),:ai_dyyyy)                                                          
         , gubun        = EE.GUBUN                                                                             
         , ewol1        = EE.EWOL1                                                                             
         , m24          = EE.M12                                                                               
         , m23          = EE.M11                                                                               
         , m22          = EE.M10                                                                               
         , m21          = EE.M09                                                                               
         , m20          = EE.M08                                                                               
         , m19          = EE.M07                                                                               
         , m18          = EE.M06                                                                               
         , m17          = EE.M05                                                                               
         , m16          = EE.M04                                                                               
         , m15          = EE.M03                                                                               
         , m14          = EE.M02                                                                               
         , m13          = EE.M01                                                                               
         , m12          = EE.N12                                                                               
         , m11          = EE.N11                                                                               
         , m10          = EE.N10                                                                               
         , m09          = EE.N09                                                                               
         , m08          = EE.N08                                                                               
         , m07          = EE.N07                                                                               
         , m06          = EE.N06                                                                               
         , m05          = EE.N05                                                                               
         , m04          = EE.N04                                                                               
         , m03          = EE.N03                                                                               
         , m02          = EE.N02                                                                               
         , m01          = EE.N01                                                                               
         , ewol2        = EE.EWOL2                                                                             
      FROM (                                                                                                   
           SELECT CODE    = DD.CODE                                                                            
                , GUBUN   = DD.GUBUN                                                                           
                , EWOL1   = SUM(DD.EWOL1)                                                                      
                , M12     = SUM(DD.M12  )                                                                      
                , M11     = SUM(DD.M11  )                                                                      
                , M10     = SUM(DD.M10  )                                                                      
                , M09     = SUM(DD.M09  )                                                                      
                , M08     = SUM(DD.M08  )                                                                      
                , M07     = SUM(DD.M07  )                                                                      
                , M06     = SUM(DD.M06  )                                                                      
                , M05     = SUM(DD.M05  )                                                                      
                , M04     = SUM(DD.M04  )                                                                      
                , M03     = SUM(DD.M03  )                                                                      
                , M02     = SUM(DD.M02  )                                                                      
                , M01     = SUM(DD.M01  )                                                                      
                , N12     = SUM(DD.N12  )                                                                      
                , N11     = SUM(DD.N11  )                                                                      
                , N10     = SUM(DD.N10  )                                                                      
                , N09     = SUM(DD.N09  )                                                                      
                , N08     = SUM(DD.N08  )                                                                      
                , N07     = SUM(DD.N07  )                                                                      
                , N06     = SUM(DD.N06  )                                                                      
                , N05     = SUM(DD.N05  )                                                                      
                , N04     = SUM(DD.N04  )                                                                      
                , N03     = SUM(DD.N03  )                                                                      
                , N02     = SUM(DD.N02  )                                                                      
                , N01     = SUM(DD.N01  )                                                                      
                , EWOL2   = SUM(DD.EWOL2)                                                                      
             FROM (                                                                                            
                  SELECT SEQ    = CC.SEQ                                                                       
                       , CODE   = CC.CODE                                                                      
                       , YYYY   = CC.YYYY                                                                      
                       , GUBUN  = CC.GUBUN                                                                     
                       , M12    = (case when CC.YYYY = :ai_dyyyy AND CC.GUBUN = '매출' THEN CC.M12                          
                                   else (case when CC.YYYY = :ai_dyyyy AND CC.GUBUN = '수금' THEN CC.M12   else 0 end) end) 
                       , M11    = (case when CC.YYYY = :ai_dyyyy AND CC.GUBUN = '매출' THEN CC.M11                          
                                   else (case when CC.YYYY = :ai_dyyyy AND CC.GUBUN = '수금' THEN CC.M11   else 0 end) end) 
                       , M10    = (case when CC.YYYY = :ai_dyyyy AND CC.GUBUN = '매출' THEN CC.M10                          
                                   else (case when CC.YYYY = :ai_dyyyy AND CC.GUBUN = '수금' THEN CC.M10   else 0 end) end) 
                       , M09    = (case when CC.YYYY = :ai_dyyyy AND CC.GUBUN = '매출' THEN CC.M09                          
                                   else (case when CC.YYYY = :ai_dyyyy AND CC.GUBUN = '수금' THEN CC.M09   else 0 end) end) 
                       , M08    = (case when CC.YYYY = :ai_dyyyy AND CC.GUBUN = '매출' THEN CC.M08                          
                                   else (case when CC.YYYY = :ai_dyyyy AND CC.GUBUN = '수금' THEN CC.M08   else 0 end) end) 
                       , M07    = (case when CC.YYYY = :ai_dyyyy AND CC.GUBUN = '매출' THEN CC.M07                          
                                   else (case when CC.YYYY = :ai_dyyyy AND CC.GUBUN = '수금' THEN CC.M07   else 0 end) end) 
                       , M06    = (case when CC.YYYY = :ai_dyyyy AND CC.GUBUN = '매출' THEN CC.M06                          
                                   else (case when CC.YYYY = :ai_dyyyy AND CC.GUBUN = '수금' THEN CC.M06   else 0 end) end) 
                       , M05    = (case when CC.YYYY = :ai_dyyyy AND CC.GUBUN = '매출' THEN CC.M05                          
                                   else (case when CC.YYYY = :ai_dyyyy AND CC.GUBUN = '수금' THEN CC.M05   else 0 end) end) 
                       , M04    = (case when CC.YYYY = :ai_dyyyy AND CC.GUBUN = '매출' THEN CC.M04                          
                                   else (case when CC.YYYY = :ai_dyyyy AND CC.GUBUN = '수금' THEN CC.M04   else 0 end) end) 
                       , M03    = (case when CC.YYYY = :ai_dyyyy AND CC.GUBUN = '매출' THEN CC.M03                          
                                   else (case when CC.YYYY = :ai_dyyyy AND CC.GUBUN = '수금' THEN CC.M03   else 0 end) end) 
                       , M02    = (case when CC.YYYY = :ai_dyyyy AND CC.GUBUN = '매출' THEN CC.M02                          
                                   else (case when CC.YYYY = :ai_dyyyy AND CC.GUBUN = '수금' THEN CC.M02   else 0 end) end) 
                       , M01    = (case when CC.YYYY = :ai_dyyyy AND CC.GUBUN = '매출' THEN CC.M01                          
                                   else (case when CC.YYYY = :ai_dyyyy AND CC.GUBUN = '수금' THEN CC.M01   else 0 end) end) 
                       , EWOL1  = (case when CC.YYYY = :ai_dyyyy AND CC.GUBUN = '매출' THEN CC.EWOL                         
                                   else (case when CC.YYYY = :ai_dyyyy AND CC.GUBUN = '수금' THEN CC.EWOL  else 0 end) end) 

                       , N12    = (case when CC.YYYY = :ai_jyyyy AND CC.GUBUN = '매출' THEN CC.M12                          
                                   else (case when CC.YYYY = :ai_jyyyy AND CC.GUBUN = '수금' THEN CC.M12   else 0 end) end) 
                       , N11    = (case when CC.YYYY = :ai_jyyyy AND CC.GUBUN = '매출' THEN CC.M11                          
                                   else (case when CC.YYYY = :ai_jyyyy AND CC.GUBUN = '수금' THEN CC.M11   else 0 end) end) 
                       , N10    = (case when CC.YYYY = :ai_jyyyy AND CC.GUBUN = '매출' THEN CC.M10                          
                                   else (case when CC.YYYY = :ai_jyyyy AND CC.GUBUN = '수금' THEN CC.M10   else 0 end) end) 
                       , N09    = (case when CC.YYYY = :ai_jyyyy AND CC.GUBUN = '매출' THEN CC.M09                          
                                   else (case when CC.YYYY = :ai_jyyyy AND CC.GUBUN = '수금' THEN CC.M09   else 0 end) end) 
                       , N08    = (case when CC.YYYY = :ai_jyyyy AND CC.GUBUN = '매출' THEN CC.M08                          
                                   else (case when CC.YYYY = :ai_jyyyy AND CC.GUBUN = '수금' THEN CC.M08   else 0 end) end) 
                       , N07    = (case when CC.YYYY = :ai_jyyyy AND CC.GUBUN = '매출' THEN CC.M07                          
                                   else (case when CC.YYYY = :ai_jyyyy AND CC.GUBUN = '수금' THEN CC.M07   else 0 end) end) 
                       , N06    = (case when CC.YYYY = :ai_jyyyy AND CC.GUBUN = '매출' THEN CC.M06                          
                                   else (case when CC.YYYY = :ai_jyyyy AND CC.GUBUN = '수금' THEN CC.M06   else 0 end) end) 
                       , N05    = (case when CC.YYYY = :ai_jyyyy AND CC.GUBUN = '매출' THEN CC.M05                          
                                   else (case when CC.YYYY = :ai_jyyyy AND CC.GUBUN = '수금' THEN CC.M05   else 0 end) end) 
                       , N04    = (case when CC.YYYY = :ai_jyyyy AND CC.GUBUN = '매출' THEN CC.M04                          
                                   else (case when CC.YYYY = :ai_jyyyy AND CC.GUBUN = '수금' THEN CC.M04   else 0 end) end) 
                       , N03    = (case when CC.YYYY = :ai_jyyyy AND CC.GUBUN = '매출' THEN CC.M03                          
                                   else (case when CC.YYYY = :ai_jyyyy AND CC.GUBUN = '수금' THEN CC.M03   else 0 end) end) 
                       , N02    = (case when CC.YYYY = :ai_jyyyy AND CC.GUBUN = '매출' THEN CC.M02                          
                                   else (case when CC.YYYY = :ai_jyyyy AND CC.GUBUN = '수금' THEN CC.M02   else 0 end) end) 
                       , N01    = (case when CC.YYYY = :ai_jyyyy AND CC.GUBUN = '매출' THEN CC.M01                          
                                   else (case when CC.YYYY = :ai_jyyyy AND CC.GUBUN = '수금' THEN CC.M01   else 0 end) end) 
                       , EWOL2  = (case when CC.YYYY = :ai_jyyyy AND CC.GUBUN = '매출' THEN CC.EWOL                         
                                   else (case when CC.YYYY = :ai_jyyyy AND CC.GUBUN = '수금' THEN CC.EWOL  else 0 end) end) 
                    FROM (                                                                                     
                          SELECT SEQ     = '1'                                                                 
                               , CODE    = AA.CODE                                                             
                               , YYYY    = AA.YYYY                                                             
                               , GUBUN   = AA.GUBUN                                                            
                               , M12     = AA.M12                                                              
                               , M11     = AA.M11                                                              
                               , M10     = AA.M10                                                              
                               , M09     = AA.M09                                                              
                               , M08     = AA.M08                                                              
                               , M07     = AA.M07                                                              
                               , M06     = AA.M06                                                              
                               , M05     = AA.M05                                                              
                               , M04     = AA.M04                                                              
                               , M03     = AA.M03                                                              
                               , M02     = AA.M02                                                              
                               , M01     = AA.M01                                                              
                               , EWOL    = AA.EWOL                                                             
                            FROM (                                                                             
                                  SELECT CODE   = OPEOM.CUST_NO                                                
                                       , YYYY   = DATEPART(YEAR,OPEOM.EOM_YEAR)                                
                                       , GUBUN  = '매출'                                                       
                                       , M12    = OPEOM.INV_12                                                 
                                       , M11    = OPEOM.INV_11                                                 
                                       , M10    = OPEOM.INV_10                                                 
                                       , M09    = OPEOM.INV_09                                                 
                                       , M08    = OPEOM.INV_08                                                 
                                       , M07    = OPEOM.INV_07                                                 
                                       , M06    = OPEOM.INV_06                                                 
                                       , M05    = OPEOM.INV_05                                                 
                                       , M04    = OPEOM.INV_04                                                 
                                       , M03    = OPEOM.INV_03                                                 
                                       , M02    = OPEOM.INV_02                                                 
                                       , M01    = OPEOM.INV_01                                                 
                                       , EWOL   = OPEOM.BALBF_AMOUNT                                           
                                    FROM OPEOM       /* 고객별여신현황 */
                                   WHERE DATEPART(YEAR,OPEOM.EOM_YEAR)  =  :ai_jyyyy                              
                                                                                                               
                                  UNION  ALL                                                                   
                                                                                                               
                                  SELECT CODE   = OPEOM.CUST_NO                                                
                                       , YYYY   = DATEPART(YEAR,OPEOM.EOM_YEAR)                                
                                       , GUBUN  = '수금'                                                       
                                       , M12    = OPEOM.COLL_12                                                
                                       , M11    = OPEOM.COLL_11                                                
                                       , M10    = OPEOM.COLL_10                                                
                                       , M09    = OPEOM.COLL_09                                                
                                       , M08    = OPEOM.COLL_08                                                
                                       , M07    = OPEOM.COLL_07                                                
                                       , M06    = OPEOM.COLL_06                                                
                                       , M05    = OPEOM.COLL_05                                                
                                       , M04    = OPEOM.COLL_04                                                
                                       , M03    = OPEOM.COLL_03                                                
                                       , M02    = OPEOM.COLL_02                                                
                                       , M01    = OPEOM.COLL_01                                                
                                       , EWOL   = 0                                                            
                                    FROM OPEOM       /* 고객별여신현황 */
                                   WHERE DATEPART(YEAR,OPEOM.EOM_YEAR)  =  :ai_jyyyy                              
                                )  AA                                                                          
                                                                                                               
                          UNION ALL                                                                            
                                                                                                               
                          SELECT SEQ     = '2'                                                                 
                               , CODE    = BB.CODE                                                             
                               , YYYY    = BB.YYYY                                                             
                               , GUBUN   = BB.GUBUN                                                            
                               , M12     = BB.M12                                                              
                               , M11     = BB.M11                                                              
                               , M10     = BB.M10                                                              
                               , M09     = BB.M09                                                              
                               , M08     = BB.M08                                                              
                               , M07     = BB.M07                                                              
                               , M06     = BB.M06                                                              
                               , M05     = BB.M05                                                              
                               , M04     = BB.M04                                                              
                               , M03     = BB.M03                                                              
                               , M02     = BB.M02                                                              
                               , M01     = BB.M01                                                              
                               , EWOL    = BB.EWOL                                                             
                            FROM (                                                                             
                                  SELECT CODE    = OPEOM.CUST_NO                                               
                                       , YYYY    = DATEPART(YEAR,OPEOM.EOM_YEAR)                               
                                       , GUBUN   = '매출'                                                      
                                       , M12     = OPEOM.INV_12                                                
                                       , M11     = OPEOM.INV_11                                                
                                       , M10     = OPEOM.INV_10                                                
                                       , M09     = OPEOM.INV_09                                                
                                       , M08     = OPEOM.INV_08                                                
                                       , M07     = OPEOM.INV_07                                                
                                       , M06     = OPEOM.INV_06                                                
                                       , M05     = OPEOM.INV_05                                                
                                       , M04     = OPEOM.INV_04                                                
                                       , M03     = OPEOM.INV_03                                                
                                       , M02     = OPEOM.INV_02                                                
                                       , M01     = OPEOM.INV_01                                                
                                       , EWOL    = OPEOM.BALBF_AMOUNT                                          
                                    FROM OPEOM       /* 고객별여신현황 */
                                   WHERE DATEPART(YEAR,OPEOM.EOM_YEAR)  =  :ai_dyyyy                              
                                                                                                               
                                  UNION  ALL                                                                   
                                                                                                               
                                  SELECT CODE    = OPEOM.CUST_NO                                               
                                       , YYYY    = DATEPART(YEAR,OPEOM.EOM_YEAR)                               
                                       , GUBUN   = '수금'                                                      
                                       , M12     = OPEOM.COLL_12                                               
                                       , M11     = OPEOM.COLL_11                                               
                                       , M10     = OPEOM.COLL_10                                               
                                       , M09     = OPEOM.COLL_09                                               
                                       , M08     = OPEOM.COLL_08                                               
                                       , M07     = OPEOM.COLL_07                                               
                                       , M06     = OPEOM.COLL_06                                               
                                       , M05     = OPEOM.COLL_05                                               
                                       , M04     = OPEOM.COLL_04                                               
                                       , M03     = OPEOM.COLL_03                                               
                                       , M02     = OPEOM.COLL_02                                               
                                       , M01     = OPEOM.COLL_01                                               
                                       , EWOL    = 0                                                           
                                    FROM OPEOM       /* 고객별여신현황 */
                                   WHERE DATEPART(YEAR,OPEOM.EOM_YEAR)  =  :ai_dyyyy                              
                                )  BB                                                                          
                         ) CC                                                                                  
                   /*ORDER BY CC.CODE, CC.GUBUN, CC.SEQ DESC*/                                                   
                   ) DD                                                                                        
               GROUP BY DD.CODE, DD.GUBUN                                                                      
           ) EE                                                                                                
        LEFT OUTER JOIN CUSTOMER  CM ON  EE.CODE        =  CM.CUST_NO                                         
        LEFT OUTER JOIN LOGIN     LG ON  CM.SALESMAN    =  LG.USER_ID                                         
       WHERE CM.OPEN_CLOSE         = 'O'                                                                           
         AND ( LG.USER_ID       LIKE :as_userid OR 
              (:as_team = 'T' AND CM.SALESMAN IN (SELECT A.USER_ID  
                                                    FROM login A   LEFT OUTER JOIN team B  ON a.team_code  = b.team_code  
                                                   WHERE a.use_flag = 'Y' AND b.team_manager = :as_userid
                                                 ) 
              )
             )
       ORDER BY LG.USER_NAME, CM.CUST_NAME, EE.GUBUN                                                           
" arguments=(("as_userid", string),("ai_dyyyy", number),("ai_jyyyy", number),("as_team", string)) )
