$PBExportComments$작업진척조회(2002/09/14,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=datetime update=yes updatewhereclause=yes name=work_date dbname="work_date" )
 column=(type=long update=yes updatewhereclause=yes name=division dbname="division" )
 column=(type=long update=yes updatewhereclause=yes name=operation dbname="operation" )
 column=(type=char(14) update=yes updatewhereclause=yes name=sale_no dbname="sale_no" )
 column=(type=long update=yes updatewhereclause=yes name=seq_no dbname="seq_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(4) update=yes updatewhereclause=yes name=item_color dbname="item_color" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="uom" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=plan_qty dbname="plan_qty" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=setup_time dbname="setup_time" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=work_time dbname="work_time" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=make_qty dbname="make_qty" )
 column=(type=char(17) updatewhereclause=yes name=mpsdet_plan_no dbname="plan_no" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene_desc" )
 retrieve="  SELECT work_date   = routtempnew.work_date  
       , division    = routtempnew.division   
       , operation   = routtempnew.operation  
       , sale_no     = routtempnew.sale_no    
       , seq_no      = routtempnew.seq_no     
       , item_no     = (case when routtempnew.item_no = 'NO_ITEM' then routtempnew.assy_item else routtempnew.item_no end)
       , item_name   = (case when routtempnew.item_no = 'NO_ITEM' then g2.item_name          else g1.item_name        end)
       , qa          = (case when routtempnew.item_no = 'NO_ITEM' then routtempnew.assy_qa   else routtempnew.qa      end)
       , item_color  = routtempnew.item_color 
       , uom         = routtempnew.uom        
       , plan_qty    = routtempnew.plan_qty   
       , setup_time  = routtempnew.setup_time 
       , work_time   = routtempnew.work_time  
       , make_qty    = routtempnew.make_qty   
       , plan_no     = mpsdet.plan_no         
       , cust_name   = customer.cust_name     
       , scene_desc  = scene.scene_desc       
    FROM routtempnew   
         LEFT OUTER JOIN mpsdet ON routtempnew.division = mpsdet.division 
                               AND routtempnew.sale_no = mpsdet.sale_no AND routtempnew.seq_no = mpsdet.seq_no
         LEFT OUTER JOIN groupitem G1 ON routtempnew.item_no   = g1.item_no
         LEFT OUTER JOIN groupitem G2 ON routtempnew.assy_item = g2.item_no
         LEFT OUTER JOIN customer  ON routtempnew.cust_no      = customer.cust_no 
         LEFT OUTER JOIN scene     ON routtempnew.scene_code   = scene.scene_code 
   WHERE ( routtempnew.area_no     = :as_area ) 
     AND ((:arg_wc   = '%' AND routtempnew.wc_no  LIKE :arg_wc ) OR
          (:arg_wc  <> '%' AND routtempnew.wc_no     = :arg_wc )
         )
     AND ( routtempnew.plan_flag   = 'Y'      )  
     AND ( routtempnew.work_date   between :arg_date1 and :arg_date2 ) 
" arguments=(("arg_wc", string),("arg_date1", date),("arg_date2", date),("as_area", string))  sort="work_date A mpsdet_plan_no A operation A division A " )
group(level=1 header.height=0 trailer.height=80 by=("work_date" ) header.color="536870912" trailer.color="12639424" )
