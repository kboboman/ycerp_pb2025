table(column=(type=char(17) update=yes updatewhereclause=yes key=yes name=mps_order_no dbname="mps.order_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=mps_wc_no dbname="mps.wc_no" )
 column=(type=datetime update=yes updatewhereclause=yes name=mps_start_date dbname="mps.start_date" )
 column=(type=datetime update=yes updatewhereclause=yes name=mps_order_date dbname="mps.order_date" )
 column=(type=datetime update=yes updatewhereclause=yes name=mps_due_date dbname="mps.due_date" )
 column=(type=char(1) update=yes updatewhereclause=yes name=mps_open_close dbname="mps.open_close" )
 column=(type=datetime update=yes updatewhereclause=yes name=mps_close_date dbname="mps.close_date" )
 column=(type=long update=yes updatewhereclause=yes name=mps_revision_no dbname="mps.revision_no" )
 column=(type=datetime update=yes updatewhereclause=yes name=mps_revision_date dbname="mps.revision_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=mps_planner dbname="mps.planner" )
 column=(type=char(30) update=yes updatewhereclause=yes name=mps_rem dbname="mps.rem" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=mps_work_time dbname="mps.work_time" )
 retrieve="PBSELECT( VERSION(400) DISTINCT ()TABLE(NAME=~"mps~" )  TABLE(NAME=~"mpsdet~" ) COLUMN(NAME=~"mps.order_no~") COLUMN(NAME=~"mps.wc_no~") COLUMN(NAME=~"mps.start_date~") COLUMN(NAME=~"mps.order_date~") COLUMN(NAME=~"mps.due_date~") COLUMN(NAME=~"mps.open_close~") COLUMN(NAME=~"mps.close_date~") COLUMN(NAME=~"mps.revision_no~") COLUMN(NAME=~"mps.revision_date~") COLUMN(NAME=~"mps.planner~") COLUMN(NAME=~"mps.rem~") COLUMN(NAME=~"mps.work_time~")    JOIN (LEFT=~"mps.order_no~"    OP =~"=~"RIGHT=~"mpsdet.order_no~" )WHERE(    EXP1 =~"mpsdet.item_no~"   OP =~"=~"    EXP2 =~":A~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"mpsdet.qa~"   OP =~"=~"    EXP2 =~":B~" ) ) ARG(NAME = ~"A~" TYPE = string)  ARG(NAME = ~"B~" TYPE = string) " update="mps" updatewhere=0 updatekeyinplace=no arguments=(("A", string),("B", string)) )
