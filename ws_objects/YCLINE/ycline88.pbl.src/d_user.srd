$PBExportHeader$d_user.srd
$PBExportComments$사용자
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=92 color="536870912" )
summary(height=0 color="536870912" )
footer(height=88 color="8421504" )
detail(height=92 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=user_name dbname="login.user_name" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="login.user_id" )
 column=(type=char(30) updatewhereclause=yes name=team_team_name dbname="team.team_name" )
 retrieve="  SELECT login.user_name
       , login.user_id  
       , team.team_name
    FROM login  
         LEFT OUTER JOIN team  ON login.team_code = team.team_code
   WHERE ( login.use_flag  = 'Y' )
     AND ( login.team_code BETWEEN '90000' AND '99999' ) 
     AND ( login.user_id NOT IN ( SELECT user_id FROM sfcdayuser
                                   WHERE area_no = :as_area AND wc_no = :as_wc AND sfc_date = :ad_date 
                                ) 
         )    
/* 세콤데이터와 연결해야 함(V_INSABASE) */
" arguments=(("as_area", string),("as_wc", string),("ad_date", date))  sort="team_team_name A user_name A " )
