text(band=header alignment="2" text="01월매입" border="6" color="33554432" x="2674" y="8" height="60" width="507" html.valueishtml="0"  name=compute_0005_t visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="67108864" )
