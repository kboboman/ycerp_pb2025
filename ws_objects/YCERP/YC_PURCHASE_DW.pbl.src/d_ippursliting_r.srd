table(column=(type=char(14) updatewhereclause=yes name=coilsliting_order_no dbname="coilsliting.order_no" )
 column=(type=long updatewhereclause=yes name=coilsliting_seq dbname="coilsliting.seq" )
 column=(type=char(20) updatewhereclause=yes name=coilsliting_coil_no dbname="coilsliting.coil_no" )
 column=(type=decimal(1) updatewhereclause=yes name=coilsliting_wid dbname="coilsliting.wid" )
 column=(type=char(10) updatewhereclause=yes name=coilsliting_item_no dbname="coilsliting.item_no" )
 column=(type=char(20) updatewhereclause=yes name=coilsliting_qa dbname="coilsliting.qa" )
 column=(type=long updatewhereclause=yes name=coilsliting_cnt dbname="coilsliting.cnt" )
 column=(type=decimal(2) updatewhereclause=yes name=coilsliting_length dbname="coilsliting.length" )
 column=(type=char(1) updatewhereclause=yes name=coilsliting_proc_flag dbname="coilsliting.proc_flag" )
 column=(type=char(10) updatewhereclause=yes name=coilorder_supp_no dbname="coilorder.supp_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(30) updatewhereclause=yes name=supp_supp_name dbname="supp.supp_name" )
 column=(type=char(2) updatewhereclause=yes name=groupitem_uom dbname="GroupItem.uom" )
 column=(type=datetime updatewhereclause=yes name=coilorder_due_date dbname="coilorder.due_date" )
 column=(type=char(30) updatewhereclause=yes name=coilsliting_rem dbname="coilsliting.rem" )
 column=(type=decimal(4) updatewhereclause=yes name=coilsliting_unit_qty dbname="coilsliting.unit_qty" )
 column=(type=char(1) updatewhereclause=yes name=coilsliting_sheet dbname="coilsliting.sheet" )
 column=(type=char(10) updatewhereclause=yes name=loc_no dbname="coilsliting.loc_no" )
 retrieve="  SELECT coilsliting.order_no,   
         coilsliting.seq,   
         coilsliting.coil_no,   
         coilsliting.wid,   
         coilsliting.item_no,   
         coilsliting.qa,   
         coilsliting.cnt,   
         coilsliting.length,   
         coilsliting.proc_flag,   
         coilorder.supp_no,   
         groupitem.item_name,   
         supp.supp_name,   
         groupitem.uom,   
         coilorder.due_date,   
         coilsliting.rem,   
         coilsliting.unit_qty,   
         coilsliting.sheet,   
         coilsliting.loc_no  
    FROM coilsliting,   
         groupitem,   
         coilorderdet,  
         coilorder left outer join supp on coilorder.supp_no = supp.supp_no
   WHERE 
         ( coilsliting.item_no = groupitem.item_no ) and  
         ( coilsliting.order_no = coilorderdet.order_no ) and  
         ( coilorderdet.coilorder_order = coilorder.order_no ) and  
         ( ( coilsliting.order_no like :as_order ) AND  
         ( coilorder.wc_place = 'O' ) AND  
         ( coilorderdet.proc_flag = 'M' ) ) 
/*
    FROM coilsliting,   
         coilorder,   
         groupitem,   
         supp,   
         coilorderdet  
   WHERE ( coilorder.supp_no *= supp.supp_no) and  
         ( coilsliting.item_no = groupitem.item_no ) and  
         ( coilsliting.order_no = coilorderdet.order_no ) and  
         ( coilorderdet.coilorder_order = coilorder.order_no ) and  
         ( ( coilsliting.order_no like :as_order ) AND  
         ( coilorder.wc_place = 'O' ) AND  
         ( coilorderdet.proc_flag = 'M' ) ) 
*/" arguments=(("as_order", string))  sort="coilsliting_order_no A coilsliting_seq A " )
