table(column=(type=char(45) updatewhereclause=yes name=ceo_his dbname="ceo_his" )
 column=(type=char(2) updatewhereclause=yes name=top_level1 dbname="top_level1" )
 column=(type=char(2) updatewhereclause=yes name=top_level2 dbname="top_level2" )
 column=(type=char(6) updatewhereclause=yes name=top_level2_name dbname="top_level2_name" )
 column=(type=char(10) updatewhereclause=yes name=login_saleman_name dbname="login.saleman_name" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 retrieve="    select  ceo_his = rtrim(a.captain_name) + ' / ' +  substring(convert(char(6), a.cap_birthday, 112),1,4)+'.'+substring(convert(char(6), a.cap_birthday, 112),5,2) +' / 만('+  convert(char(2), datediff( month, a.cap_birthday, getdate()) / 12) + ')세'
          	  , substring(a.top_level,1,1) top_level1
          	  , substring(a.top_level,2,1) top_level2
          	  , ( case when substring(a.top_level,1,1) = 'A' then '(유지)'
          			  when substring(a.top_level,1,1) = 'B' then '(공략)'
          			  when substring(a.top_level,1,1) = 'C' then '(수금)'
          			  else ''
                   end ) top_level2_name
            , b.user_name saleman_name		
            , a.cust_name
from customer a left outer join login b on a.salesman = b.user_id
where cust_no = :as_cust_no
" arguments=(("as_cust_no", string)) )
