$PBExportComments$스리팅작업일보조회(2001/05/26,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=68 color="8421504" )
detail(height=68 color="536870912" )
table(column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(20) updatewhereclause=yes name=coilmst_qa dbname="coilmst.qa" )
 column=(type=char(10) updatewhereclause=yes name=coilsfcday_item_no dbname="coilsfcday.item_no" )
 column=(type=long updatewhereclause=yes name=coilsfcday_unit_qty dbname="unit_qty" )
 column=(type=long updatewhereclause=yes name=coilsfcday_cnt dbname="cnt" )
 column=(type=long updatewhereclause=yes name=coilmst_unit_qty dbname="unit_qty" )
 column=(type=decimal(1) updatewhereclause=yes name=swid dbname="swid" )
 column=(type=long updatewhereclause=yes name=tot_qty dbname="tot_qty" )
 column=(type=datetime updatewhereclause=yes name=start_date dbname="start_date" )
 column=(type=datetime updatewhereclause=yes name=end_date dbname="end_date" )
 retrieve="  SELECT groupitem.item_name                                           
       , coilmst.qa                                                          
       , coilsfcday.item_no                                            
       , unit_qty   = sum(coilsfcday.unit_qty)
       , cnt        = sum(coilsfcday.cnt)
       , unit_qty   = sum(coilmst.unit_qty)
       , swid       = sum((case when sheet = ~"C~" or sheet = ~"L~" then convert(decimal(5,1), substring(coilsfcday.qa,5,4) + ~".~" + substring(coilsfcday.qa, 10,1)) 
                                when sheet = ~"S~"                then convert(decimal(5,0), substring(coilsfcday.qa,5,4)) 
                           end))
       , tot_qty    = sum((coilsfcday.unit_qty * coilsfcday.cnt))
       , start_date = convert(smalldatetime, :ad_start, 111)
       , end_date   = convert(smalldatetime, :ad_end,   111)
    FROM coilmst                                                               
       , groupitem                                                             
       , coilorderdet                                                          
       , coilsfcday                                                            
       , coilorder                                                             
   WHERE ( coilorder.order_no          = coilorderdet.coilorder_order )        
     AND ( coilorderdet.order_no       = coilsfcday.order_no          )        
     AND ( coilorderdet.coil_no        = coilmst.coil_no              )        
     AND ( coilmst.item_no             = groupitem.item_no            )        
     AND ( coilmst.loc_no             <> 'WS00000003'                 ) /* 코일장기저장소 */
     AND ( coilsfcday.sfc_date   BETWEEN :ad_start  and :ad_end       )        
   GROUP BY groupitem.item_name                                           
       , coilmst.qa                                                          
       , coilsfcday.item_no                                            
       , coilsfcday.unit_qty                                           
       , coilsfcday.cnt                                                  
       , coilmst.unit_qty                                              
       , (case when sheet = ~"C~" or sheet = ~"L~" then convert(decimal(5,1), substring(coilsfcday.qa,5,4) + ~".~" + substring(coilsfcday.qa, 10,1)) 
               when sheet = ~"S~"                then convert(decimal(5,0), substring(coilsfcday.qa,5,4)) 
          end)
" arguments=(("ad_start", date),("ad_end", date))  sort="groupitem_item_name A coilmst_qa A " )
group(level=1 header.height=0 trailer.height=68 by=("groupitem_item_name" ) header.color="536870912" trailer.color="12639424" )
