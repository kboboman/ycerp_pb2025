type cb_prt1 from commandbutton within tabpage_2
integer x = 2624
integer y = 8
integer width = 649
integer height = 68
integer taborder = 40
boolean bringtotop = true
integer textsize = -9
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "5 X 10 바코드(개별)"
end type

event clicked;// 5 X 10 바코드(개별)
string   ls_chk, ls_saleno, ls_seqno, ls_custnm, ls_scenenm, ls_scene[], ls_qa, ls_bigo, ls_oldprinter
string   ls_saleno1, ls_saleno2, ls_saleno3, ls_saleno4, ls_saleno5, ls_setprn
long     ll_row, ll_prtcnt, ll_seqno, ll_w1, ll_w2, ll_h1, ll_h2
integer  li_ret
datetime ldt_getdate

if dw6.object.tchk[1] < 1 then
	MessageBox("확인","라벨출력 대상을 선택하시기 바랍니다.")
	RETURN
end if

PrintSetup()
ls_setprn     = PrintGetPrinter()
sle_prt1.text = ls_setprn
//ls_setprn = trim(sle_prt1.text)
if ls_setprn = "" then
	MessageBox("확인","라벨 프린터 이름을 입력하시기 바랍니다.")
	RETURN
end if
SetProfileString("YCERP.INI", "Database", "BARCODE1", ls_setprn)

if MessageBox("확인","절곡반 제품 라벨을 출력 하시겠습니까?", Exclamation!, OKCancel!, 2) = 2 then RETURN

dw6.accepttext()

dw_8.SetTransObject(SQLCA)

ls_oldprinter = PrintGetPrinter()

//long   ll_place
//string ls_setprn
//string ls_prntrs = PrintGetPrinters()
//
//ll_place   = pos(ls_prntrs, "~n") 
////mle_1.text = PrintGetPrinters()
//ls_setprn  = Left(ls_prntrs, ll_place - 1)
//PrintSetPrinter( ls_setprn )

// 프린트 선택
PrintSetPrinter( ls_setprn )

string ls_left, ls_top

ls_left = em_left.text
ls_top  = em_top.text

ldt_getdate = GF_TODAY()
for ll_row = 1 to dw6.rowcount()
	ls_chk = dw6.object.chk[ll_row]
	if isnull(ls_chk) OR ls_chk = "N" then CONTINUE
	
	/////////////////////////////////////////////////////////////////////
	// 절곡반 제품개별라벨
	/////////////////////////////////////////////////////////////////////
	GF_SPLIT(dw6.object.scene_desc[ll_row], "/", ls_scene)		// 현장명 분리

	dw_8.object.scene_t[1]    = "현장명"
	dw_8.object.qa_t[1]       = "규  격"
	dw_8.object.cust_t[1]     = "거래처"
	dw_8.object.order_t[1]    = "수  주"

	dw_8.object.scene_name[1] = dw6.object.cust_name[ll_row] + " | " + ls_scene[1]
	dw_8.object.cust_name[1]  = dw6.object.cust_name[ll_row]
	
//	ls_qa                     = dw6.object.qa[ll_row]				// 규격
// ls_qa                     = mid(ls_qa, 5, 9)
// ls_qa                     = GF_ReplaceAll(ls_qa, 'X', ' X ')
	ll_w1  = dw6.object.w1[ll_row]
	ll_w2  = dw6.object.w2[ll_row]
	ll_h1  = dw6.object.h1[ll_row]
	ll_h2  = dw6.object.h2[ll_row]
	
	ls_qa  = string(ll_w1) + " X " + string(ll_w2) + " X " + string(ll_h1) + " X " + string(ll_h2)
	dw_8.object.qa[1]         = ls_qa
		
	ls_saleno  = dw6.object.sale_no[ll_row]
	ll_seqno   = dw6.object.seq_no[ll_row]
	ls_seqno   = string(ll_seqno)
	dw_8.object.order[1]      = ls_saleno + "-" + ls_seqno
	
   ls_bigo    = dw6.object.salerem[ll_row]	// 수주비고
   ll_prtcnt  = dw6.object.qty[ll_row]			// 출력장수

	if isnull(ls_bigo) OR ls_bigo = "" then
	else
		dw_8.object.cust_t[1]     = "구  분"
		dw_8.object.cust_name[1]  = ls_bigo
	end if

	dw_8.modify("DataWindow.print.margin.left = 0 ")
	dw_8.modify("DataWindow.print.margin.top  = 0 ")
	dw_8.modify("DataWindow.print.margin.left = " + ls_left + " " )
	dw_8.modify("DataWindow.print.margin.top  = " + ls_top + " "  )
	dw_8.Modify("DataWindow.Print.Orientation = 2 DataWindow.Print.Copies = " + string(ll_prtcnt) )

	dw_8.print()		// 출력
	// 출력시간
	dw6.object.prt_date[ll_row]	 = ldt_getdate
	UPDATE itemsosdet SET prt_date = getdate() WHERE sale_no = :ls_saleno AND seq_no = :ll_seqno;
	/////////////////////////////////////////////////////////////////////
next
PrintSetPrinter( ls_oldprinter )

MessageBox("확인", "출력완료")

end event

type dw_5 from datawindow within tabpage_2
integer x = 2624
integer y = 80
integer width = 3246
integer height = 484
integer taborder = 80
string title = "none"
string dataobject = "d_mpplansos_m"
boolean livescroll = true
borderstyle borderstyle = stylelowered!
end type

event getfocus;is_dwidx = "dw5"

end event

event clicked;//
long	 ll_protect
string ls_data, ls_usernm, ls_protect

//this.accepttext()
choose case dwo.name
	case "team_chk"
		if (this.object.team_id[row] = gs_userid) and (this.object.div_id[row] = "") then
			ls_data = this.object.team_chk[row]
			if ls_data = "N" then
				SELECT user_name INTO :ls_usernm FROM login WHERE user_id = :gs_userid;
				this.object.team_nm[row] = ls_usernm
				this.object.team_id[row] = gs_userid
				cbx_modify.enabled = false	// 팀장, 최종결재 시 수정불가
			else
				this.object.team_nm[row] = ""
				this.object.team_id[row] = ""
				cbx_modify.enabled = true
			end if
			cbx_modify.triggerevent( clicked! )
		elseif string(this.object.team_chk.protect) = "1" then
			//
		else
			ls_data = this.object.team_chk[row]
			if ls_data = "N" then
				SELECT user_name INTO :ls_usernm FROM login WHERE user_id = :gs_userid;
				this.object.team_nm[row] = ls_usernm
				this.object.team_id[row] = gs_userid
				cbx_modify.enabled = false	// 팀장, 최종결재 시 수정불가
			else
				this.object.team_nm[row] = ""
				this.object.team_id[row] = ""
				cbx_modify.enabled = true
			end if
			cbx_modify.triggerevent( clicked! )
		end if		
		
	case "div_chk"
		ls_protect = string(this.object.div_chk.protect)
		if ls_protect = "1" then
		else
			ls_data = this.object.div_chk[row]
			if ls_data = "N" then
				SELECT user_name INTO :ls_usernm FROM login WHERE user_id = :gs_userid;
				this.object.div_nm[row] = ls_usernm
				this.object.div_id[row] = gs_userid
				cbx_modify.enabled = false	// 팀장, 최종결재 시 수정불가

				if this.object.team_id[row] = "" then
					this.object.team_chk[row] = "Y"
					this.object.team_nm[row] = ls_usernm
					this.object.team_id[row] = gs_userid
					cbx_modify.enabled = false	// 팀장, 최종결재 시 수정불가
				end if
			else
				this.object.div_nm[row] = ""
				this.object.div_id[row] = ""
				cbx_modify.enabled = true
				if this.object.team_id[row] = gs_userid then
					this.object.team_chk[row] = "N"
					this.object.team_nm[row] = ""
					this.object.team_id[row] = ""
					cbx_modify.enabled = true
				end if
			end if
			cbx_modify.triggerevent( clicked! )
		end if
end choose


end event

