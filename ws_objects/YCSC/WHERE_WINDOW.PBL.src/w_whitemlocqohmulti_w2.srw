	case 3
		tabpage_3.em_8.SelectText(9, 2)
		tabpage_3.em_8.setfocus()

	case 5
		tabpage_5.em_9.SelectText(8, 2)
		tabpage_5.em_9.setfocus()

	case 6
		tabpage_6.em_10.SelectText(9, 2)
		tabpage_6.em_10.setfocus()
end choose

end event

