type cbx_attch from checkbox within w_orsale_m
integer x = 5321
integer y = 1452
integer width = 434
integer height = 60
boolean bringtotop = true
integer textsize = -11
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
long textcolor = 33554432
long backcolor = 67108864
string text = "첨부하기"
end type

event clicked;// 첨부
Blob    lb_picture, lb_pictemp
string  ls_filepath, ls_nullarray[], ls_orderno, ls_filename, ls_ext, ls_null
integer li_rtn, li_i, li_cnt, li_loop, i, li_filenum
long    ll_filelen

setnull( ls_null )
if this.checked = false then 
	p_1.visible = false
	st_filename.text = ""
	RETURN
end if

ls_orderno = trim(dw_2.object.order_no[1])
SELECT filename INTO :ls_filename FROM SalePIC WHERE order_no = :ls_orderno;
ls_ext = Lower(RightA(ls_filename,3)) 
st_filename.text = ls_filename

if ls_orderno <> "" then	
	if ls_ext <> "pdf" then
		OpenWithParm( w_orderno_pic, ls_orderno)
		this.checked = false
	else		
		SELECTBLOB filebin INTO :lb_picture FROM SalePIC WHERE SalePIC.order_no = :ls_orderno;
		
		ll_filelen = LenA(lb_picture)
		if ll_filelen > 32765 then
			if mod(ll_filelen,32765) = 0 then
				li_loop = ll_filelen / 32765
			else
				li_loop = (ll_filelen/32765) + 1
			end if
		else
			li_loop = 1
		end if
                                                   
		li_rtn = GetFileSaveName( "Select File", is_path, is_file, "pdf","Portable Documents File, *.pdf")
		if li_rtn = 1 then
			li_filenum = FileOpen(is_path, StreamMode!, Write!, Shared!, Append!)
	
			for i = 1 to li_loop
				if i = li_loop then
					lb_pictemp = BlobMid(lb_picture, (i - 1) * 32765 + 1)
				else
					lb_pictemp = BlobMid(lb_picture, (i - 1) * 32765 + 1,32765)
				end if
				FileWrite(li_filenum, lb_pictemp)
			next
			Fileclose(li_filenum)
	
			ls_filename = is_path 
			li_rtn = ShellExecuteA(0, "open", ls_filename, "", "", 10)
			if li_rtn <= 32 then
				Run("rundll32.exe shell32.dll,OpenAs_RunDLL " + ls_filename )
			end if
		end if
		this.checked = false
	end if
else
	st_filename.text = ""
	
	li_rtn = GetFileOpenName("Select File", is_path, is_files[], "jpg", &
								  + "Graphic Files (*.bmp;*.gif;*.jpg;*.jpeg;*.pdf), *.bmp;*.gif;*.jpg;*.jpeg;*.pdf")
	if li_rtn > 0 then
		li_cnt = UpperBound(is_files)
		ls_ext = Lower(RightA(is_files[1],3))
		
		st_filename.text = is_files[1]
		this.checked = false

		if ls_ext = "pdf" then
		else
			p_1.PictureName = is_path
			p_2.PictureName = is_path

			p_1.x      = 100
			p_1.y      = 100
			p_1.width  = il_maxWidth
			p_1.height = il_maxHeight
			
		end if			
	else
		this.checked = false
		st_filename.text = ""
		is_files     = ls_nullarray		// 초기화
		p_1.visible  = false		
		p_1.picturename = ls_null
	end if
end if
end event

