$PBExportHeader$d_mpslituse_tt2.srd
$PBExportComments$원/스리팅 코일사용현황조회(외주)(2001/05/08,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=cdate dbname="cdate" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=coil_no dbname="coil_no" )
 column=(type=char(20) updatewhereclause=yes name=coilmst_qa dbname="qa" )
 column=(type=decimal(4) updatewhereclause=yes name=qty dbname="qty" )
 column=(type=long updatewhereclause=yes name=coilmst_cnt dbname="cnt" )
 column=(type=char(30) updatewhereclause=yes name=sname dbname="sname" )
 column=(type=datetime updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=datetime updatewhereclause=yes name=edate dbname="edate" )
 column=(type=char(1) updatewhereclause=yes name=flag dbname="flag" )
 column=(type=datetime updatewhereclause=yes name=audit_date dbname="audit_date" )
 retrieve="  SELECT DISTINCT cdate = inaudit.inaudit_date
       , item_name = groupitem.item_name         
       , coil_no   = coilmst.coil_no             
       , qa        = coilmst.qa                  
       , qty       = coilmst.unit_qty            
       , cnt       = coilmst.cnt                 
       , sname     = supp.supp_name              
       , sdate     = convert(smalldatetime, :ad_start, 111)   
       , edate     = convert(smalldatetime, :ad_end,   111)
       , flag      = 'W' 
       , audit_date= inaudit.inaudit_date 
    FROM inaudit with(nolock) inner join coilmst with(nolock) on inaudit.serial_id = coilmst.coil_no and  inaudit.loc_no         = coilmst.loc_no
                                                 inner join groupitem with(nolock) on inaudit.inaudit_item   = groupitem.item_no
                                                 inner join supp with(nolock) on  inaudit.destination    = supp.supp_no
   WHERE ( ( inaudit_type         = 'IO'                  ) AND  
                     ( coilmst.flag         = 'W'                   ) AND  
                     ( inaudit_date   BETWEEN :ad_start AND :ad_end ) 
                  )             
  UNION
  SELECT cdate = convert(datetime, convert(char(10), sfcuse.use_date,121) )
       , item_name = groupitem.item_name   
       , coil_no   = sfcuse.coil_no        
       , qa        = sfcuse.qa             
       , qty       = sfcuse.unit_qty       
       , cnt       = sfcuse.cnt            
       , sname     = wc.work_name          
       , sdate     = convert(smalldatetime, :ad_start, 111)   
       , edate     = convert(smalldatetime, :ad_end,   111)  
       , flag      = 'S' 
       , audit_date= sfcuse.use_date 
    FROM  sfcuse with(nolock) inner join groupitem with(nolock) on sfcuse.item_no = groupitem.item_no
                                                  left outer join wc with(nolock) on sfcuse.wc_no = wc.work_no
   WHERE ( (  sfcuse.use_date between  convert(datetime,  :ad_start +' 00:00:00' ) and convert(datetime,  :ad_end + ' 23:59:59' ) ) AND
                     ( sfcuse.coil_no        IS NOT NULL ) 
                  )
" arguments=(("ad_start", date),("ad_end", date))  sort="flag D cdate A groupitem_item_name A coilmst_qa A qty A " )
group(level=1 header.height=68 trailer.height=68 by=("flag" ) header.color="12639424" trailer.color="79741120" )
group(level=2 header.height=68 trailer.height=76 by=("cdate" ) header.color="536870912" trailer.color="536870912" )
group(level=3 header.height=0 trailer.height=0 by=("groupitem_item_name" ) header.color="536870912" trailer.color="536870912" )
