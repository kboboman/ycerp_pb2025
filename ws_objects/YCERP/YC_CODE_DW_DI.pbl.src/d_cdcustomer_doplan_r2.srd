 retrieve="  SELECT customer_doplan.cust_no,   
         customer_doplan.seq,   
         customer_doplan.grade,   
         customer_doplan.approval,   
         customer_doplan.market_share,   
         customer_doplan.const,   
         customer_doplan.const_scene,   
         customer_doplan.plan_size,   
         customer_doplan.plan_much,   
         customer_doplan.plan_terms,   
         customer_doplan.do_guarantee,   
         customer_doplan.mon1,   
         customer_doplan.mon2,   
         customer_doplan.mon3,   
         customer_doplan.mon4,   
         customer_doplan.mon5,   
         customer_doplan.mon6,   
         customer_doplan.mon7,   
         customer_doplan.mon8,   
         customer_doplan.mon9,   
         customer_doplan.mon10,   
         customer_doplan.mon11,   
         customer_doplan.mon12,   
         customer_doplan.ceo_confirm,   
         customer_doplan.ceo_remark
    FROM customer_doplan   
   WHERE customer_doplan.cust_no   = :aa
" update="customer_doplan" updatewhere=0 updatekeyinplace=no arguments=(("aa", string),("mm", number)) )
