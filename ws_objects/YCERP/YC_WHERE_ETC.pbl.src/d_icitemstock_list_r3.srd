table(column=(type=long update=yes updatewhereclause=yes key=yes identity=yes name=id dbname="itemstockout.id" )
 column=(type=long update=yes updatewhereclause=yes name=seq dbname="itemstockout.seq" )
 column=(type=char(1) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=qty dbname="itemstockout.qty" )
 column=(type=long updatewhereclause=yes name=stock_qty dbname="stock_qty" )
 column=(type=char(1) updatewhereclause=yes name=sale_no dbname="sale_no" )
 column=(type=long updatewhereclause=yes name=sale_seq dbname="itemstockout.sale_seq" )
