table(column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=decimal(4) updatewhereclause=yes name=price dbname="price" )
 column=(type=decimal(4) updatewhereclause=yes name=old_price dbname="old_price" )
 column=(type=datetime updatewhereclause=yes name=tran_date dbname="tran_date" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="user_id" )
 column=(type=char(30) updatewhereclause=yes name=rem dbname="rem" )
 column=(type=decimal(4) updatewhereclause=yes name=price_min dbname="price_min" )
 column=(type=datetime updatewhereclause=yes name=min_date dbname="min_date" )
 retrieve="SELECT item_no    = c.item_no
     , item_name  = g.item_name
     , qa         = c.qa
     , uom        = c.uom
     , price      = c.price
     , old_price  = c.old_price
     , tran_date  = c.tran_date
     , user_id    = c.user_id
     , rem        = c.rem
     , price_min  = c.price_min
     , min_date   = c.min_date 
  FROM itemcost C
       LEFT OUTER JOIN groupitem G  ON c.item_no = g.item_no
 WHERE c.price_min > 0
   AND g.use_flag = 'Y'
" )
