$PBExportHeader$d_oiscenerep_r1_sdhd.srd
$PBExportComments$현장별 자재투입현황 REPORT(2006/11/06, 이기영)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=668 color="536870912" )
summary(height=84 color="536870912" )
footer(height=4 color="536870912" )
detail(height=140 color="536870912" )
table(column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(11) updatewhereclause=yes name=do_spot_code dbname="do.spot_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 column=(type=datetime updatewhereclause=yes name=do_do_date dbname="do.do_date" )
 column=(type=char(14) updatewhereclause=yes name=do_do_no dbname="do.do_no" )
 column=(type=long updatewhereclause=yes name=dodet_oi_no dbname="dodet.oi_no" )
 column=(type=char(10) updatewhereclause=yes name=dodet_item_no dbname="dodet.item_no" )
 column=(type=char(20) updatewhereclause=yes name=dodet_qa dbname="dodet.qa" )
 column=(type=char(2) updatewhereclause=yes name=dodet_uom dbname="dodet.uom" )
 column=(type=decimal(2) updatewhereclause=yes name=dodet_ship_qty dbname="dodet.ship_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=dodet_price dbname="dodet.price" )
 column=(type=decimal(4) updatewhereclause=yes name=dodet_rate_cash dbname="dodet.rate_cash" )
 column=(type=char(4) updatewhereclause=yes name=do_cust_no dbname="do.cust_no" )
 column=(type=char(10) updatewhereclause=yes name=do_fob dbname="do.fob" )
 column=(type=char(30) updatewhereclause=yes name=do_ship_flag dbname="ship_flag" )
 column=(type=char(1) updatewhereclause=yes name=ship_flag2 dbname="ship_flag2" )
 column=(type=decimal(0) updatewhereclause=yes name=do_ship_amount dbname="do.ship_amount" )
 column=(type=char(1) updatewhereclause=yes name=do_shipamt_case dbname="do.shipamt_case" )
 column=(type=datetime updatewhereclause=yes name=cc_start dbname="c_start" )
 column=(type=datetime updatewhereclause=yes name=cc_end dbname="c_end" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_rate dbname="do.do_rate" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_total dbname="do.do_total" )
 column=(type=char(3) updatewhereclause=yes name=do_curr_code dbname="do.curr_code" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_cash dbname="do.do_cash" )
 column=(type=char(11) updatewhereclause=yes name=scene_scene_code dbname="SCENE.scene_code" )
 column=(type=char(10) updatewhereclause=yes name=scene_scene_charge dbname="SCENE.scene_charge" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(1) updatewhereclause=yes name=round dbname="customer.round" )
 retrieve="  SELECT customer.cust_name,   
         do.spot_code,   
         scene.scene_desc,   
         do.do_date,   
         do.do_no,   
         dodet.oi_no,   
         dodet.item_no,   
         dodet.qa,   
         dodet.uom,   
         dodet.ship_qty,   
         dodet.price,   
         dodet.rate_cash,   
         do.cust_no,   
         do.fob,   
         ship_flag = dbo.uf_getshipflag(do.ship_flag),   
         ship_flag2 = do.ship_flag,   
         do.ship_amount, 
			do.shipamt_case,  
         c_start = convert(smalldatetime, :ad_start, 111),   
         c_end = convert(smalldatetime, :ad_end, 111),   
         do.do_rate,   
         do.do_total,   
         do.curr_code,   
         do.do_cash,   
         scene.scene_code,   
         scene.scene_charge,   
         groupitem.item_name,   
         customer.round  
FROM do inner join dodet on do.do_no = dodet.do_no
		inner join groupitem on dodet.item_no = groupitem.item_no
		left outer join customer on do.cust_no = customer.cust_no
		left outer join scene on do.cust_no = scene.cust_no and do.spot_code = scene.scene_code
where ( ( do.cust_no = :as_cust_no ) AND  
             ( do.spot_code is not null ) AND  
             ( do.do_date between :ad_start and :ad_end ) AND
		   ( customer.salesman like :as_flag ) )     AND
  		   ( substring(do.do_no,1,2) in('SD','HD'))
" arguments=(("as_cust_no", string),("ad_start", date),("ad_end", date),("as_flag", string))  sort="scene_scene_desc A do_do_date A do_do_no A dodet_oi_no A " )
group(level=1 header.height=68 trailer.height=80 by=("do_spot_code" ) header.color="536870912" trailer.color="536870912" )
group(level=2 header.height=0 trailer.height=88 by=("do_do_no" ) header.color="536870912" trailer.color="536870912" )
