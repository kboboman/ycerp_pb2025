 column=(type=long updatewhereclause=yes name=saledet_seq_no dbname="saledet.seq_no" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"itemloc~" )  TABLE(NAME=~"saledet~" ) COLUMN(NAME=~"saledet.order_qty~") COLUMN(NAME=~"saledet.sol_qty~") COLUMN(NAME=~"itemloc.item_no~") COLUMN(NAME=~"itemloc.qa~") COLUMN(NAME=~"itemloc.loc_no~") COLUMN(NAME=~"itemloc.balbf~") COLUMN(NAME=~"itemloc.receipt_qty~") COLUMN(NAME=~"itemloc.issue_qty~") COLUMN(NAME=~"itemloc.qoh~") COLUMN(NAME=~"itemloc.reserved~") COLUMN(NAME=~"itemloc.balbf_fifo_cost~") COLUMN(NAME=~"saledet.order_no~") COLUMN(NAME=~"saledet.seq_no~")    JOIN (LEFT=~"saledet.item_no~"    OP =~"=~"RIGHT=~"itemloc.item_no~" )    JOIN (LEFT=~"saledet.qa~"    OP =~"=~"RIGHT=~"itemloc.qa~" )WHERE(    EXP1 =~"saledet.order_no~"   OP =~"=~"    EXP2 =~":as_order~" ) ) ARG(NAME = ~"as_order~" TYPE = string) " update="itemloc" updatewhere=0 updatekeyinplace=yes arguments=(("as_order", string))  sort="saledet_order_no A saledet_seq_no A " )
