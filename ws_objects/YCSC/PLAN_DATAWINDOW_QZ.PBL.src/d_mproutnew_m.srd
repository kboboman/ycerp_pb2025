release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=long updatewhereclause=yes name=operation dbname="rout.operation" )
 column=(type=char(10) updatewhereclause=yes name=wc_no dbname="rout.wc_no" )
 column=(type=decimal(4) updatewhereclause=yes name=setup_time dbname="rout.setup_time" )
 column=(type=decimal(4) updatewhereclause=yes name=run_time dbname="rout.run_time" )
 column=(type=char(10) updatewhereclause=yes name=assembly dbname="rout.assembly" )
 column=(type=char(20) updatewhereclause=yes name=assy_qa dbname="rout.assy_qa" )
 column=(type=long updatewhereclause=yes name=bom_no dbname="rout.bom_no" )
 column=(type=decimal(4) updatewhereclause=yes name=qpa dbname="rout.qpa" )
 column=(type=long updatewhereclause=yes name=work_per dbname="rout.work_per" )
 column=(type=char(10) updatewhereclause=yes name=wc_area_no dbname="wc.area_no" )
 retrieve="  SELECT rout.operation,   
         rout.wc_no,   
         rout.setup_time,   
         rout.run_time,   
         rout.assembly,   
         rout.assy_qa,   
         rout.bom_no,   
         rout.qpa,   
         rout.work_per,   
         wc.area_no  
    FROM rout,   
         wc  
   WHERE ( rout.wc_no = wc.work_no ) and  
         ( rout.item_no = :arg_item ) AND  
         ( rout.qa like :arg_qa )   
ORDER BY rout.operation DESC   
" arguments=(("arg_item", string),("arg_qa", string))  sort="operation D " )
