event clicked;long ll_row
string ls_salesman
if gf_permission('판매거래처관리edit', gs_userid) = 'N' then
//if gs_userid = 'chahc' then
	messagebox('확인', '권한이 없습니다. 전산실에 문의 하십시요.')
	return
end if

dw_1.accepttext( )
if tab_1.tabpage_6.cbx_2.checked = true then
	is_custno2 = '%'
else
	is_custno2 = upper(dw_1.object.cust_no[1])
end if

if isnull(is_custno2) or trim(is_custno2) = '' then
	messagebox('확인', '상단의 거래처를 선택후 작업하세요.')
	return
end if

if is_custno2 = '%' then
	messagebox('확인', '전체 거래처 선택시는 추가할수없습니다.')
	return
end if

tab_1.tabpage_6.dw_22.reset()
ll_row = tab_1.tabpage_6.dw_22.insertrow(0)
select isnull(salesman,'') into :ls_salesman 
from customer
where cust_no = :is_custno2;

tab_1.tabpage_6.dw_22.scrolltorow(ll_row)
tab_1.tabpage_6.dw_22.object.cust_no[ll_row] = is_custno2
tab_1.tabpage_6.dw_22.object.i_date[ll_row] = date(gdt_today)
tab_1.tabpage_6.dw_22.object.salesman[ll_row] = ls_salesman
