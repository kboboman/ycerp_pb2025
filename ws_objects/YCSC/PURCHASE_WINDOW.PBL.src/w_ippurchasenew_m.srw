event keydown pbm_dwnkey
integer x = 5
integer y = 100
integer width = 4562
integer height = 1416
integer taborder = 71
boolean bringtotop = true
string dataobject = "d_ipsudo1_m"
boolean hscrollbar = true
boolean vscrollbar = true
boolean hsplitscroll = true
boolean livescroll = true
borderstyle borderstyle = stylelowered!
end type

event keydown;long ll_row,i
string ls_wc,ls_wc1,ls_flag

IF keyflags = 1 THEN
   IF keydown(KeyLeftButton!) THEN
		ll_row = this.getrow()
      if ll_row < 1 then return
      this.accepttext()
		for i = ll_row to 1 step -1
			 if i <> ll_row then
				 if this.IsSelected(i) = true then
					 exit
				 end if
			 end if
          this.SelectRow(i, NOT this.IsSelected(i))
		next
	END IF
END IF

end event

event clicked;if row < 1 then return
this.scrolltorow(row)
this.SelectRow(row, NOT this.IsSelected(row))
end event

type cb_1 from commandbutton within tabpage_3
integer x = 2030
integer y = 8
integer width = 503
integer height = 84
integer taborder = 81
boolean bringtotop = true
integer textsize = -9
integer weight = 400
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "도급 => 사급"
end type

event clicked;long ll_rowcount,ll_rowcount1,ll_cnt,ll_find,ll_row,ll_count
string ls_plan,ls_qa,ls_item


dw4.accepttext()
dw5.accepttext()

ll_rowcount1 = dw4.rowcount()
ll_rowcount  = dw5.rowcount()

ll_count = 0
for ll_cnt = 1 to ll_rowcount
	if dw5.isselected(ll_cnt) then
      ll_count ++
	end if
next
if ll_count = 0 then
	messagebox('오류','외주(도급)대상물품을 선택하십시요.',exclamation!)
	return
end if

for ll_cnt = 1 to ll_rowcount
	if dw5.isselected(ll_cnt) then
		ls_plan = trim(dw5.object.order_no[ll_cnt])
		if ll_rowcount1 < 1 then
			ll_find = 0
		else
		   ll_find = dw4.find("order_no = '" + ls_plan + "'",1,dw4.rowcount())
		end if
		if ll_find = 0 then
			ls_item = trim(dw5.object.item_no[ll_cnt])
			ls_qa   = trim(dw5.object.qa[ll_cnt])
			ll_row = dw4.insertrow(0)
			dw4.object.issue_date[ll_row] = gf_today()
			dw4.object.groupitem_uom[ll_row] = dw5.object.groupitem_uom[ll_cnt]
			dw4.object.order_no[ll_row]   = ls_plan
			dw4.object.item_no[ll_row]    = ls_item
			dw4.object.qa[ll_row]         = ls_qa
         dw4.object.itemname1[ll_row]  = dw5.object.groupitem_item_name[ll_cnt]
			dw4.object.plan_qty[ll_row]   = dw5.object.plan_qty[ll_cnt]
			dw4.object.operation[ll_row]  = dw5.object.operation[ll_cnt]
			dw4.object.sudodet_sale_no[ll_row] = dw5.object.sudodet1_sale_no[ll_cnt]
			dw4.object.sudodet_seq_no[ll_row]  = dw5.object.sudodet1_seq_no[ll_cnt]
			dw4.object.customer_cust_name[ll_row]  = dw5.object.customer_cust_name[ll_cnt]
			dw4.object.wc_no[ll_row]   = dw5.object.wc_no[ll_cnt]
			dw4.object.due_date[ll_row]   = dw5.object.due_date[ll_cnt]
			dw4.object.rem[ll_row]   = dw5.object.rem[ll_cnt]
			dw4.object.area_no[ll_row]   = dw5.object.area_no[ll_cnt]
		end if
	end if
next

messagebox('확인','사급물품으로 이동되었습니다.',information!)
dw5.selectrow(0,false)
tab_1.selecttab(2)
end event

