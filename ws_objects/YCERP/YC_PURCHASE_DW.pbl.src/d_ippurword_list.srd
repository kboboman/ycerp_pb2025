release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=long update=yes updatewhereclause=yes name=sort dbname="sort" )
 column=(type=char(20) update=yes updatewhereclause=yes name=item_cd dbname="item_cd" )
 column=(type=char(100) update=yes updatewhereclause=yes name=bigo dbname="bigo" )
 column=(type=char(50) update=yes updatewhereclause=yes name=item_nm dbname="item_nm" )
 column=(type=char(50) update=yes updatewhereclause=yes name=type dbname="type" )
 column=(type=decimal(0) update=yes updatewhereclause=yes key=yes identity=yes name=id dbname="id" )
 column=(type=char(1) update=yes updatewhereclause=yes name=use_yn dbname="use_yn" values="사용	Y/미사용	N/" )
 column=(type=char(10) update=yes updatewhereclause=yes name=category dbname="category" )
 retrieve="  SELECT codemst.sort
       , codemst.item_cd
       , codemst.bigo
       , codemst.item_nm
	  , codemst.type
	  , codemst.id
	  , codemst.use_yn
	  , codemst.category
    FROM codemst   
   WHERE codemst.type = 'PURWORD' AND use_yn = 'Y'

" update="codemst" updatewhere=0 updatekeyinplace=no  sort="sort A " )
