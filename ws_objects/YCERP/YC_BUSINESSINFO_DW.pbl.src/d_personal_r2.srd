 column=(type=char(2) update=yes updatewhereclause=yes name=connect_level dbname="bogo_personal_connection_det.connect_level" values="상	상/중	중/하	하/" )
 column=(type=char(8) update=yes updatewhereclause=yes name=write_date dbname="bogo_personal_connection_det.write_date" )
