detail(height=92 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=item_item_no dbname="item_no" )
 column=(type=char(20) updatewhereclause=yes name=item_qa dbname="qa" )
 column=(type=char(60) updatewhereclause=yes name=item_item_name dbname="item_name" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=item_price_a dbname="price_a" )
 column=(type=decimal(4) updatewhereclause=yes name=itemcost_price dbname="price" )
 column=(type=char(10) updatewhereclause=yes key=yes name=itemcost_item_no dbname="item_no" )
 column=(type=char(20) updatewhereclause=yes key=yes name=itemcost_qa dbname="qa" )
 retrieve="SELECT item.item_no
     , item.qa 
     , item.item_name 
     , item.price_a 
     , itemcost.price 
     , itemcost.item_no 
     , itemcost.qa     
  FROM item 
     , itemcost     
 WHERE ( item.item_no      = itemcost.item_no ) 
   and ( ( item.qa      like rtrim(itemcost.qa) + '%' ) and 
         ( item.price_a   <> itemcost.price ) 
       )  
" update="itemcost" updatewhere=0 updatekeyinplace=no )
