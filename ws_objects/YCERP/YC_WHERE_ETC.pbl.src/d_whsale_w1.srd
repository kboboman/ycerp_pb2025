release 8;
datawindow(units=0 timer_interval=0 color=67108864 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=108 color="536870912" )
summary(height=120 color="536870912" )
footer(height=0 color="12639424" )
detail(height=88 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=saledet_cust_no dbname="customer.cust_no" )
 column=(type=char(14) updatewhereclause=yes name=sale_order_no dbname="order_no" )
 column=(type=datetime updatewhereclause=yes name=sale_due_date dbname="due_date" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene_desc" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_order_qty dbname="order_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_rlse_qty dbname="rlse_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=ask_rlse_qty dbname="ask_rlse_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=corder dbname="corder" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=char(10) updatewhereclause=yes name=citem dbname="citem" )
 column=(type=char(20) updatewhereclause=yes name=cqa dbname="cqa" )
 column=(type=decimal(4) updatewhereclause=yes name=make_qty dbname="make_qty" )
 retrieve=" SELECT       saledet.cust_no
        		 	, order_no  = saledet.order_no
        			, due_date  = saledet.due_date
        			, cust_name = customer.cust_name
        			, scene_desc= scene.scene_desc
        			, order_qty = isnull(saledet.order_qty,0) 
        			, rlse_qty  = isnull(saledet.rlse_qty,0)
     		           , ask_rlse_qty = isnull(ask.rlse_qty,0)
        			, corder    = isnull(saledet.order_qty,0) - isnull(saledet.rlse_qty, 0 ) - isnull(ask.rlse_qty,0)
        			, uom       = saledet.uom
        			, citem     = saledet.item_no
        			, cqa       = saledet.qa
        			, isnull(sfcday.make_qty, 0) make_qty
   FROM (
                             SELECT sale.due_date, sale.cust_no, SALE.scene_code, SALEDET.ORDER_NO,  SALEDET.ITEM_NO, SALEDET.QA,  saledet.uom, SUM(isnull(saledet.order_qty,0)) order_qty,  SUM(isnull(saledet.rlse_qty,0)) rlse_qty
                           FROM saledet with(nolock) inner join sale with(nolock) on saledet.order_no = sale.order_no
                          WHERE convert(char(8),sale.order_date,112)   between :ad_start and :ad_end
                              AND saledet.item_no   = :as_item
                              AND saledet.qa        = :as_qa
                              AND sale.open_close   = 'O' 
                              AND sale.confirm_flag IN ( 'Y', 'T' )      /*미확정 제외 */
                      GROUP BY  sale.due_date, sale.cust_no, SALE.scene_code, SALEDET.ORDER_NO, SALEDET.ITEM_NO, SALEDET.QA, saledet.uom
                  ) saledet left outer join customer with(nolock) on saledet.cust_no = customer.cust_no
						  INNER JOIN item WITH (NOLOCK) ON saledet.item_no = item.item_no and  saledet.qa = item.qa
						  left outer join scene with(nolock) on saledet.scene_code = scene.scene_code
						  left outer join (    
												select b.sale_no, b.item_no, b.qa, sum(d.make_qty) make_qty
												from routtempnew b with(nolock) inner join  (
																												select  a.sale_no, a.seq_no, a.division
																												from 
																												(
																														  select sale_no, seq_no, max(division) division
																														  from routtempnew with(nolock)
																														  where  item_no = :as_item
																															and qa =  :as_qa
																														  group by  sale_no, seq_no
																												) a                                                                                            
																										)  c on b.sale_no = c.sale_no and b.seq_no = c.seq_no and b.division  =c.division
												inner join sfcday d on  b.sale_no = d.sale_no and b.seq_no = d.seq_no and d.item_no = b.item_no and d.qa =  b.qa
												group by b.sale_no,  b.item_no, b.qa
											) sfcday on saledet.order_no = sfcday.sale_no and saledet.item_no = sfcday.item_no and saledet.qa = sfcday.qa
						 left outer join (
												select item_no, qa, sale_no, sum(isnull(rlse_qty,0)) rlse_qty
												from ask_det with(nolock)
												where convert(char(8),rlse_date,112)  between :ad_start and :ad_end 
													 and (case when loc_no = 'WS00000006' then 'WS00000008' else loc_no end)  = :as_locno /* 2019-08-29 JOWONSUK YSP저장소 미출고 내역 -> 화성저장소 변경 요청 */
													 and item_no   = :as_item
													 and qa        = :as_qa
												group by item_no, qa, sale_no
										  ) ask on saledet.order_no = ask.sale_no and saledet.item_no = ask.item_no and saledet.qa = ask.qa
  WHERE isnull(item.loc_no, :as_locno)   LIKE :as_locno	
	  AND isnull(saledet.order_qty,0) - isnull(saledet.rlse_qty,0 )  - isnull(ask.rlse_qty,0) > 0
    
/*
 SELECT  sale.cust_no
		 	,
 order_no  = sale.order_no
			,
 due_date  = sale.due_date
			,
 cust_name = customer.cust_name
			,
 scene_desc= scene.scene_desc
			,
 order_qty = saledet.order_qty
			,
 rlse_qty  = saledet.rlse_qty
			,
 corder    = isnull(saledet.order_qty,
0) - isnull(saledet.rlse_qty,
0) - isnull(ask.rlse_qty,
0)
			,
 uom       = saledet.uom
			,
 citem     = saledet.item_no
			,
 cqa       = saledet.qa
			,
 isnull(sfcday.make_qty,
 0) make_qty
   FROM saledet with(nolock) inner join sale with(nolock) on saledet.order_no = sale.order_no
									  inner join customer with(nolock) on sale.cust_no = customer.cust_no
									  INNER JOIN item WITH (NOLOCK) ON saledet.item_no = item.item_no and  saledet.qa = item.qa
									  left outer join scene with(nolock) on sale.scene_code = scene.scene_code
									  left outer join (    
																select b.sale_no,
 b.seq_no,
 b.item_no,
 b.qa,
 sum(d.make_qty) make_qty
																from routtempnew b with(nolock) inner join  (
																																select  a.sale_no,
 a.seq_no,
 a.division
																																from 
																																(
																																		  select sale_no,
 seq_no,
 max(division) division
																																		  from routtempnew with(nolock)
																																		  where  item_no = :as_item
																																			and qa =  :as_qa
																																		  group by  sale_no,
 seq_no
																																) a                                                                                            
																														)  c on b.sale_no = c.sale_no and b.seq_no = c.seq_no and b.division  =c.division
																inner join sfcday d on  b.sale_no = d.sale_no and b.seq_no = d.seq_no and d.item_no = b.item_no and d.qa =  b.qa
																group by b.sale_no,
 b.seq_no,
 b.item_no,
 b.qa
														) sfcday on saledet.order_no = sfcday.sale_no and saledet.seq_no = sfcday.seq_no and saledet.item_no = sfcday.item_no and saledet.qa = sfcday.qa
									 left outer join (
															select item_no,
 qa,
 sale_no,
 sum(rlse_qty) rlse_qty
															from ask_det with(nolock)
															where rlse_date between :ad_start and :ad_end 
																 and loc_no = :as_locno
																 and item_no   = :as_item
																 and qa        = :as_qa
															group by item_no,
 qa,
 sale_no
													  ) ask on saledet.order_no = ask.sale_no and saledet.item_no = ask.item_no and saledet.qa = ask.qa
  WHERE sale.order_date  between :ad_start and :ad_end
        AND saledet.item_no   = :as_item
        AND saledet.qa        = :as_qa
        AND sale.open_close   = 'O'
       AND isnull(item.loc_no,
 :as_locno)   LIKE :as_locno	
	  AND isnull(saledet.order_qty,
0) - isnull(saledet.rlse_qty,
0) <> 0
*/
 
" arguments=(("as_locno", string),("ad_start", string),("ad_end", string),("as_item", string),("as_qa", string))  sort="sale_order_no A customer_cust_name A scene_scene_desc A " )
