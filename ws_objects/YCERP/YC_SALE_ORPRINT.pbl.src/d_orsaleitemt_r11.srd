$PBExportComments$그룹물품집계표
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=담당자 dbname="담당자" )
 column=(type=char(20) updatewhereclause=yes name=전략품명 dbname="전략품명" )
 column=(type=long updatewhereclause=yes name=월 dbname="월" )
 column=(type=decimal(2) updatewhereclause=yes name=전년수량 dbname="전년수량" )
 column=(type=decimal(0) updatewhereclause=yes name=전년금액 dbname="전년금액" )
 column=(type=decimal(2) updatewhereclause=yes name=금년수량 dbname="금년수량" )
 column=(type=decimal(0) updatewhereclause=yes name=금년금액 dbname="금년금액" )
 retrieve="SELECT '담당자'   = b.user_name
     , '전략품명' = a.item_name
     , '월'       = a.mm
     , '전년수량' = a.year21
     , '전년금액' = a.year22
     , '금년수량' = a.year11
     , '금년금액' = a.year12
  FROM (
       SELECT distinct salesman
            , item_name
            , mm     = month(do_date)
            , year21 = sum( (case year(do_date) when (year(:ad_date) - 1) then calc_qty else 0 end) )
            , year22 = sum( (case year(do_date) when (year(:ad_date) - 1) then amount   else 0 end) )
            , year11 = sum( (case year(do_date) when (year(:ad_date) - 0) then calc_qty else 0 end) )
            , year12 = sum( (case year(do_date) when (year(:ad_date) - 0) then amount   else 0 end) )
         FROM doitem_sum
        GROUP BY salesman, item_name, month(do_date)
      /*ORDER BY salesman, item_name, month(do_date)*/
       ) A
       LEFT OUTER JOIN login B   ON a.salesman  = b.user_id
 WHERE ( a.salesman   LIKE :as_salesman OR 
         (:as_team = 'T' AND a.salesman IN (SELECT login.user_id  FROM login, team 
                                             WHERE login.team_code   = team.team_code  AND team_manager = :as_salesman
                                           ) 
         )
       )
 ORDER BY b.user_name, a.item_name, a.mm
 " arguments=(("ad_date", date),("as_salesman", string),("as_team", string)) )
group(level=1 header.height=0 trailer.height=80 by=("담당자" , "전략품명" ) header.color="536870912" trailer.color="12639424" )
