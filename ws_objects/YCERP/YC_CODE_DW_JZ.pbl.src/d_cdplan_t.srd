table(column=(type=char(10) updatewhereclause=yes key=yes name=work_no dbname="wc.work_no" )
 column=(type=char(10) updatewhereclause=yes name=work_name dbname="wc.work_name" )
 column=(type=char(1) updatewhereclause=yes name=work_type dbname="wc.work_type" values="사내	D/외주	S/" )
 column=(type=char(3) updatewhereclause=yes name=work_mes dbname="wc.work_mes" )
 column=(type=char(10) updatewhereclause=yes name=work_manager dbname="wc.work_manager" )
 column=(type=long updatewhereclause=yes name=capacity dbname="wc.capacity" )
 column=(type=char(20) updatewhereclause=yes name=work_pos dbname="wc.work_pos" )
 column=(type=long updatewhereclause=yes name=work_per dbname="wc.work_per" )
 column=(type=char(10) updatewhereclause=yes name=def_loc dbname="wc.def_loc" )
 column=(type=char(1) updatewhereclause=yes name=fact_wc dbname="wc.fact_wc" )
 column=(type=char(1) updatewhereclause=yes name=rout_auto dbname="wc.rout_auto" values="예	Y/아니오	N/" )
 column=(type=char(10) updatewhereclause=yes name=area_no dbname="wc.area_no" )
 column=(type=char(30) updatewhereclause=yes name=bigo dbname="wc.bigo" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="wc.user_id" )
 column=(type=char(1) updatewhereclause=yes name=use_yn dbname="use_yn" values="사용	Y/불가	N/" )
 retrieve="  SELECT w.work_no,   
         w.work_name,   
         w.work_type,   
         w.work_mes,   
         w.work_manager,   
         w.capacity,   
         w.work_pos,   
         w.work_per,   
         w.def_loc,   
         w.fact_wc,   
         w.rout_auto,   
         w.area_no,
         w.bigo,
         w.user_id,
         use_yn = (case when w.use_yn is null then 'Y' else w.use_yn end)
    FROM wc   w
   WHERE w.work_no    = :as_workno
" update="wc" updatewhere=0 updatekeyinplace=no arguments=(("as_workno", string)) )
