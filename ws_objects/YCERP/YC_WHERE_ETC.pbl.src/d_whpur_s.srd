$PBExportHeader$d_whpur_s.srd
$PBExportComments$발주번호선택(1998/02/10,곽용덕)
release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=order_no dbname="order_no" initial=" " )
 column=(type=datetime updatewhereclause=yes name=order_date dbname="pur.order_date" initial=" " )
 column=(type=char(1) updatewhereclause=yes name=subcon dbname="pur.subcon" initial=" " )
 column=(type=char(30) updatewhereclause=yes name=supp_supp_name dbname="supp.supp_name" )
 column=(type=char(10) updatewhereclause=yes name=pur_buyer dbname="pur.buyer" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="login.user_name" )
 retrieve="  SELECT order_no  = rtrim(pur.order_no)
       , pur.order_date   
       , pur.subcon       
       , supp.supp_name
       , pur.buyer  
       , login.user_name
    FROM pur
         LEFT OUTER JOIN supp  ON pur.supp_no = supp.supp_no
         LEFT OUTER JOIN login ON pur.buyer   = login.user_id
   WHERE ( pur.supp_no       LIKE :as_supp  ) 
     AND ( pur.po_print      LIKE :as_print ) 
     AND ( pur.open_close    LIKE :as_open  ) 
     AND ( pur.order_date BETWEEN :ad_start and :ad_end ) 
     AND ((pur.order_no      LIKE :as_area + '%' ) OR
          (:as_area = 'S' AND pur.order_no LIKE 'PUR%' ) 
         )
" arguments=(("as_supp", string),("as_print", string),("as_open", string),("ad_start", date),("ad_end", date),("as_area", string))  sort="order_date D order_no D " )
