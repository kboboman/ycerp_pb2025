end type

event clicked;// ▼ 추가
long ll_row, ll_cnt, ll_dw1row, ll_dw1rowcount, ll_dw2row
string ls_exist, ls_use, ls_item, ls_qa

dw_1.setredraw( false )
dw_1.accepttext()
dw3.accepttext()

if istr_where.chk = 'M' then
else
	dw_1.reset()
end if
ll_dw1rowcount = dw_1.rowcount()

choose case tab_1.SelectedTab
	case 1		// 품목검색
		ll_dw2row = dw2.getrow()
		for ll_row = dw3.GetSelectedRow(0) to dw3.rowcount()
			if dw3.IsSelected(ll_row) = true then
				ls_exist = 'N'
				for ll_dw1row = 1 to ll_dw1rowcount
					if dw2.object.item_no[ll_dw2row] = dw_1.object.item_no[ll_dw1row] and &
						dw3.object.qa[ll_row] = dw_1.object.qa[ll_dw1row] then
						ls_exist = 'Y'
						exit
					end if
				next
				if ls_exist = 'Y' then continue
				
				ls_item = dw2.object.item_no[ll_dw2row]
				ls_qa   = dw3.object.qa[ll_row]
				
				setnull( ls_use )
				SELECT use_flag INTO :ls_use FROM item WHERE item_no = :ls_item AND qa = :ls_qa;
				if ls_use = 'C' then
					messagebox("확인", "선택하신품목은 사용불가인 품목입니다 ~r~n" + &
											 "물품RELOAD 를 하신후에 다시 작업하여 주시기바랍니다")
					dw3.SelectRow(0, false)
					cbx_2.checked = false
					dw_1.scrolltorow(ll_cnt)
					dw_1.setredraw( true )
					RETURN
				end if
		
				ll_cnt = dw_1.insertrow(0)
				dw_1.object.item_no[ll_cnt]   = ls_item
				dw_1.object.qa[ll_cnt]        = ls_qa
				dw_1.object.uom[ll_cnt]       = dw2.object.uom[ll_dw2row]
				dw_1.object.source[ll_cnt]    = dw2.object.source[ll_dw2row]
				dw_1.object.loc_no[ll_cnt]    = is_loc
				dw_1.object.item_name[ll_cnt] = dw2.object.item_name[ll_dw2row]
				dw_1.object.qoh[ll_cnt]       = dw3.object.qoh[ll_row]
				dw_1.object.rem[ll_cnt]       = ""
			end if
		next
		dw3.SelectRow(0, false)
		
//	case 2
//		for ll_row = 1 to dw5.rowcount()
//			if dw5.IsSelected(ll_row) = true then
//				ls_exist = 'N'
//				for ll_dw1row = 1 to ll_dw1rowcount
//					if dw5.object.item_no[ll_row] = dw_1.object.item_no[ll_dw1row] and &
//						dw5.object.qa[ll_row] = dw_1.object.qa[ll_dw1row] then
//						ls_exist = 'Y'
//						exit
//					end if
//				next
//				if ls_exist = 'Y' then continue
//				ls_item = dw5.object.item_no[ll_row]
//				ls_qa = dw5.object.qa[ll_row]
//				SETNULL(ls_use)
//				select use_flag into :ls_use from item
//				 where item_no = :ls_item
//					and qa = :ls_qa;
//				if ls_use = 'C' then
//					messagebox("확인", "선택하신품목은 사용불가인 품목입니다 ~r~n" + &
//											 "물품RELOAD 를 하신후에 다시 작업하여 주시기바랍니다")
//					dw5.SelectRow(0, false)
//					cbx_2.checked = false
//					RETURN
//				end if
//		
//				ll_cnt = dw_1.insertrow(0)
//				dw_1.object.item_no[ll_cnt] = ls_item
//				dw_1.object.qa[ll_cnt] = ls_qa
//				dw_1.object.uom[ll_cnt] = dw5.object.uom[ll_row]
//				dw_1.object.loc_no[ll_cnt] = is_loc
//				dw_1.object.item_name[ll_cnt] = dw5.object.item_name[ll_row]
//				dw_1.object.qoh[ll_cnt] = dw5.object.qoh[ll_row]
//	
//				if tab_1.tabpage_2.rb_sale.checked = true then
//					dw_1.object.sale_no[ll_cnt] = dw5.object.order_no[ll_row]
//					dw_1.object.cust_name[ll_cnt] = dw5.object.cust_name[ll_row]
//					dw_1.object.order_qty[ll_cnt] = dw5.object.order_qty[ll_row]
//					dw_1.object.price[ll_cnt] = dw5.object.price[ll_row]
//				end if
//			end if
//		next
//		dw5.SelectRow(0, false)

	case 2		// 수주품목
		for ll_row = 1 to dw5.rowcount()
			if dw5.IsSelected(ll_row) = true then
				////////////////////////////////////////////////////////////////////
				// 수주입력상 중복검사 불필요(2012/02/21) (아파트동별 중복입력함)
				// 출고 송장발행시 오류발생 확인필요
				////////////////////////////////////////////////////////////////////
				// ls_exist = 'N'
				// for ll_dw1row = 1 to ll_dw1rowcount
				// 	if dw5.object.item_no[ll_row] = dw_1.object.item_no[ll_dw1row] and &
				// 		dw5.object.qa[ll_row] = dw_1.object.qa[ll_dw1row] then
				// 		ls_exist = 'Y'
				// 		exit
				// 	end if
				// next
				// if ls_exist = 'Y' then continue
				//////////////////////////////////////////////////
				
				ls_item = dw5.object.item_no[ll_row]
				ls_qa   = dw5.object.qa[ll_row]
		
				ll_cnt  = dw_1.insertrow(0)
				dw_1.object.item_no[ll_cnt]   = ls_item
				dw_1.object.qa[ll_cnt]        = ls_qa
				dw_1.object.uom[ll_cnt]       = dw5.object.uom[ll_row]
				dw_1.object.loc_no[ll_cnt]    = is_loc
				dw_1.object.item_name[ll_cnt] = dw5.object.item_name[ll_row]
				dw_1.object.qoh[ll_cnt]       = dw5.object.qoh[ll_row]
				dw_1.object.rem[ll_cnt]       = dw5.object.rem[ll_row]
	
				if tab_1.tabpage_2.rb_sale.checked = true then
					dw_1.object.sale_no[ll_cnt]   = dw5.object.order_no[ll_row]
					dw_1.object.cust_name[ll_cnt] = dw5.object.cust_name[ll_row]
					dw_1.object.order_qty[ll_cnt] = dw5.object.order_qty[ll_row]
					dw_1.object.price[ll_cnt]     = dw5.object.price[ll_row]
				end if
			end if
		next
		dw5.SelectRow(0, false)		// 선택해제
		
	case 3		// 출고송장
		for ll_row = 1 to dw8.rowcount()
			if dw8.IsSelected(ll_row) = true then
				//////////////////////////////////////////////////
				// 수주입력상 중복검사 불필요(2012/02/21)
				// 출고 송장발행시 오류발생 확인필요
				//////////////////////////////////////////////////
				// ls_exist = 'N'
				// for ll_dw1row = 1 to ll_dw1rowcount
				// 	if dw5.object.item_no[ll_row] = dw_1.object.item_no[ll_dw1row] and &
				// 		dw5.object.qa[ll_row] = dw_1.object.qa[ll_dw1row] then
				// 		ls_exist = 'Y'
				// 		exit
				// 	end if
				// next
				// if ls_exist = 'Y' then continue
				//////////////////////////////////////////////////
				
				ls_item = dw8.object.item_no[ll_row]
				ls_qa   = dw8.object.qa[ll_row]

				ll_cnt  = dw_1.insertrow(0)
				dw_1.object.item_no[ll_cnt]   = ls_item
				dw_1.object.qa[ll_cnt]        = ls_qa
				dw_1.object.uom[ll_cnt]       = dw8.object.uom[ll_row]
				dw_1.object.loc_no[ll_cnt]    = is_loc
				dw_1.object.item_name[ll_cnt] = dw8.object.item_name[ll_row]
				dw_1.object.qoh[ll_cnt]       = dw8.object.qoh[ll_row]
				dw_1.object.rem[ll_cnt]       = ""
	
				//if tab_1.tabpage_2.rb_sale.checked = true then		// 출고검색
				//	dw_1.object.sale_no[ll_cnt]   = dw8.object.order_no[ll_row]
					dw_1.object.cust_name[ll_cnt] = dw8.object.cust_name[ll_row]
					dw_1.object.order_qty[ll_cnt] = dw8.object.order_qty[ll_row]
					dw_1.object.price[ll_cnt]     = dw8.object.price[ll_row]
				//end if
			end if
		next
		dw8.SelectRow(0, false)		// 선택해제

	case 4		// 일위대가
		for ll_row = 1 to dw9.rowcount()
			if dw9.IsSelected(ll_row) = true then
				ls_item = dw9.object.item_no[ll_row]
				ls_qa   = dw9.object.qa[ll_row]
		
				ll_cnt  = dw_1.insertrow(0)
				dw_1.object.item_no[ll_cnt]   = ls_item
				dw_1.object.qa[ll_cnt]        = ls_qa
				dw_1.object.uom[ll_cnt]       = dw9.object.uom[ll_row]
				dw_1.object.loc_no[ll_cnt]    = is_loc
				dw_1.object.item_name[ll_cnt] = dw9.object.item_name[ll_row]
				dw_1.object.qoh[ll_cnt]       = dw9.object.qoh[ll_row]
				dw_1.object.rem[ll_cnt]       = ""
	
				//if tab_1.tabpage_2.rb_sale.checked = true then		// 수주검색
				//	dw_1.object.sale_no[ll_cnt]   = dw9.object.order_no[ll_row]
				//	dw_1.object.cust_name[ll_cnt] = dw9.object.cust_name[ll_row]
				//	dw_1.object.order_qty[ll_cnt] = dw9.object.order_qty[ll_row]
				//	dw_1.object.price[ll_cnt]     = dw9.object.price[ll_row]
				//end if
			end if
		next
		dw9.SelectRow(0, false)		// 선택해제
		
	case 5	// 물품요청
		for ll_row = 1 to dw11.rowcount()
			if dw11.IsSelected(ll_row) = true then
				ls_item = dw11.object.item_no[ll_row]
				ls_qa   = dw11.object.qa[ll_row]
		
				ll_cnt  = dw_1.insertrow(0)
				dw_1.object.item_no[ll_cnt]   = ls_item
				dw_1.object.qa[ll_cnt]        = ls_qa
				dw_1.object.uom[ll_cnt]       = dw11.object.uom[ll_row]
				dw_1.object.loc_no[ll_cnt]    = is_loc
				dw_1.object.item_name[ll_cnt] = dw11.object.item_name[ll_row]
				dw_1.object.qoh[ll_cnt]       = dw11.object.qoh[ll_row]				// 요청수량
				dw_1.object.rem[ll_cnt]       = ""
	
				//if tab_1.tabpage_2.rb_sale.checked = true then		// 수주검색
				//	dw_1.object.sale_no[ll_cnt]   = dw11.object.order_no[ll_row]
					dw_1.object.cust_name[ll_cnt] = tab_1.tabpage_5.em_9.text		// 물품요청번호
					dw_1.object.order_qty[ll_cnt] = dw11.object.ask_qty[ll_row]		// 요청수량
				//	dw_1.object.price[ll_cnt]     = dw11.object.price[ll_row]
				//end if
			end if
		next
		dw11.SelectRow(0, false)	// 선택해제
end choose

///////////////////////////////////////////
// 사용불가 제외
///////////////////////////////////////////
tab_1.tabpage_4.dw_orstand.settransobject(sqlca)
tab_1.tabpage_4.dw_orstand.insertrow(1)
tab_1.tabpage_4.dw_orstand.object.item_no[1] = ""

tab_1.tabpage_4.cbx_useyn.checked = true
tab_1.tabpage_4.cbx_useyn.triggerevent( clicked! )

//dw9.object.item_no.TabSequence = 0

cbx_2.checked = false
dw_1.scrolltorow(ll_cnt)
dw_1.setredraw( true )


end event

type cb_2 from commandbutton within w_whitemlocqohmulti_w4
integer x = 2738
integer y = 1872
integer width = 379
integer height = 80
integer taborder = 190
integer textsize = -10
integer weight = 400
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "취소"
end type

event clicked;istr_where.chk = "N"
CloseWithReturn(parent, istr_where)
end event

type cb_1 from commandbutton within w_whitemlocqohmulti_w4
integer x = 2738
integer y = 1768
integer width = 379
integer height = 80
integer taborder = 180
integer textsize = -10
integer weight = 400
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "확인"
end type

event clicked;long ll_row, ll_cnt

ll_cnt = 0
dw_1.accepttext()

for ll_row = 1 to dw_1.rowcount()
	ll_cnt = ll_cnt + 1
	istr_where.str1[ll_cnt] = dw_1.object.item_no[ll_row]
	istr_where.str2[ll_cnt] = dw_1.object.qa[ll_row]
	istr_where.str3[ll_cnt] = dw_1.object.uom[ll_row]
	istr_where.str4[ll_cnt] = dw_1.object.sale_no[ll_row]	
	istr_where.str5[ll_cnt] = dw_1.object.cust_name[ll_row]
	istr_where.str6[ll_cnt] = dw_1.object.rem[ll_row]
	
	istr_where.qty1[ll_cnt] = dw_1.object.qoh[ll_row]
	istr_where.qty2[ll_cnt] = dw_1.object.order_qty[ll_row]
	istr_where.qty3[ll_cnt] = dw_1.object.price[ll_row]
	istr_where.name[ll_cnt] = dw_1.object.item_name[ll_row]
next

if ll_cnt = 0 then return
istr_where.chk = "Y"
CloseWithReturn(parent, istr_where)

end event

type dw_1 from datawindow within w_whitemlocqohmulti_w4
integer x = 18
