release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="SCENE.scene_desc" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=char(11) updatewhereclause=yes name=scene_code dbname="SCENE.scene_code" )
 column=(type=char(11) updatewhereclause=yes name=scene dbname="scene" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="customer.cust_no" )
 column=(type=char(10) updatewhereclause=yes name=scene_charge dbname="SCENE.scene_charge" )
 column=(type=char(15) updatewhereclause=yes name=scene_tel dbname="SCENE.scene_tel" )
 column=(type=char(15) updatewhereclause=yes name=scene_telcap dbname="SCENE.scene_telcap" )
 retrieve="select a.scene_desc
     , b.cust_name
     , a.scene_code
     , scene   = right(scene_code,6)
     , b.cust_no
     , a.scene_charge
     , a.scene_tel
     , a.scene_telcap
  from scene a
     , customer b
 where a.scene_desc  like :as_name
   and a.cust_no        = b.cust_no
/*   and b.open_close    <> 'C'*/
   and b.open_close    = 'O' /* JOWONSUK 2022-05-25 한도초과 적용 */
 order by a.scene_desc, b.cust_name
" arguments=(("as_name", string)) )
