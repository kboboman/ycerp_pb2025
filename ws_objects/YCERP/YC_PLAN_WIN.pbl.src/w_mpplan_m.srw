	dw12.visible = true

	if dw12.rowcount() > 0 then
		if MessageBox("확인","도장색상별 집계 데이터를 새로고침 하시겠습니까?", Exclamation!, OKCancel!, 2) = 1 then
			dw12.retrieve( ls_area )
