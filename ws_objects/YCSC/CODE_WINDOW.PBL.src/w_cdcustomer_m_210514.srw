type ddlb_sheet from dropdownlistbox within tabpage_7
integer x = 713
integer y = 8
integer width = 837
integer height = 292
integer taborder = 40
boolean bringtotop = true
integer textsize = -10
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
long textcolor = 33554432
boolean sorted = false
boolean vscrollbar = true
borderstyle borderstyle = stylelowered!
end type

event selectionchanged;// 엑셀파일 필드명 전체 가져오기
Pointer oldpointer // Declares a pointer variable
string  ls_chk, ls_colsname, ls_field

long    ll_row, ll_cnt
long    iCol, iCols, ll_find, ll_width

Boolean SWExit

ii_Sheet = index
if ii_Sheet < 1 then RETURN

cb_import.text = "엑셀 가져오기"
cb_import.enabled = true

oldpointer = SetPointer(HourGlass!)
xlSheet = OleExcel.Application.Sheets(ii_Sheet)

/////////////////////////////////////////////////////////////////////////
// 데이터 실행범위 설정
/////////////////////////////////////////////////////////////////////////
// ll_xlsRows = xlSheet.Application.WorksheetFunction.COUNTA(oRng,"")-2
// string oRng = "A:A"
/////////////////////////////////////////////////////////////////////////
// 컬럼MAX
iCol   = 1
SWExit = true
Do While SWExit
	iCols = iCols + 1

	iCol = iCol + 1
	if IsNull(xlSheet.Cells[1, iCol].Value) then SWExit = false
Loop		

// dw_26의 컬럼명과 엑셀컬럼명이 동일하면 ID에 엑셀 컬럼ID 부여
for iCol = 1 to iCols
	ls_colsname = trim(string(xlSheet.Cells[1, iCol].Value))

	ll_find = dw_26.find( "cols = '" + ls_colsname + "'", 1, dw_26.rowcount() )
	if ll_find > 0 then
		ll_cnt = ll_cnt + 1
		
		ls_field = dw_26.object.field[ll_find]
		ll_width = dw_26.object.lwidth[ll_find]

		dw_26.object.chk[ll_find] = "Y"				
		dw_26.object.id[ll_find]  = ll_cnt			
		dw_27.Modify( ls_field + ".width=" + string(ll_width) )			
	end if
next		// xls 컬럼과 로우데이터 MATCH

for ll_row = 1 to dw_26.rowcount()
	dw_26.scrolltorow( ll_row )

	ls_field = dw_26.object.field[ll_row]
	ll_width = dw_26.object.lwidth[ll_row]
	
	if isnull(ls_field) OR ls_field = "" then
	else
		ls_chk  = dw_26.object.chk[ll_row]
		if ls_chk = "N" then
			dw_27.Modify( ls_field + ".width=0" )
		end if	
	end if	
next

SetPointer(oldpointer)
dw_26.enabled      = true
cb_excute.enabled  = true

end event

