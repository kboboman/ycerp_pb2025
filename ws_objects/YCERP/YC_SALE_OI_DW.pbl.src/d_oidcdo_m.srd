table(column=(type=char(14) update=yes updatewhereclause=yes key=yes name=do_no dbname="do.do_no" )
 column=(type=char(4) update=yes updatewhereclause=yes name=cust_no dbname="do.cust_no" )
 column=(type=char(11) update=yes updatewhereclause=yes name=spot_code dbname="do.spot_code" )
 column=(type=datetime update=yes updatewhereclause=yes name=do_date dbname="do.do_date" )
 column=(type=char(1) update=yes updatewhereclause=yes name=sale_flag dbname="do.sale_flag" initial="D" values="내수	D/수출	E/L//C	L/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=do_flag dbname="do.do_flag" initial="5" values="정품	5/불량	6/오류	4/에누리	3/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=invoice_print dbname="do.invoice_print" initial="N" values="마감	Y/진행	N/" )
 column=(type=char(3) update=yes updatewhereclause=yes name=curr_code dbname="do.curr_code" initial="WON" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=curr_rate dbname="do.curr_rate" initial="1" )
 column=(type=char(10) update=yes updatewhereclause=yes name=fob dbname="do.fob" initial="어음" )
 column=(type=char(1) update=yes updatewhereclause=yes name=ship_flag dbname="do.ship_flag" initial="C" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=ship_amount dbname="do.ship_amount" initial="0" )
 column=(type=char(80) update=yes updatewhereclause=yes name=shipto_addr dbname="do.shipto_addr" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=do_cash dbname="do.do_cash" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=do_rate dbname="do.do_rate" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=do_total dbname="do.do_total" initial="0" )
 column=(type=char(60) update=yes updatewhereclause=yes name=rem dbname="do.rem" )
 column=(type=char(20) update=yes updatewhereclause=yes name=tel_no dbname="do.tel_no" values="	Y/	N" )
 column=(type=char(12) update=yes updatewhereclause=yes name=inv_no dbname="do.inv_no" )
 column=(type=char(12) update=yes updatewhereclause=yes name=driver dbname="do.driver" )
 column=(type=char(1) update=yes updatewhereclause=yes name=do_case dbname="do.do_case" initial="D" )
 column=(type=char(13) update=yes updatewhereclause=yes name=dr_hp dbname="do.dr_hp" )
 column=(type=char(10) update=yes updatewhereclause=yes name=user_id dbname="do.user_id" )
 column=(type=char(1) update=yes updatewhereclause=yes name=ship_close dbname="do.ship_close" initial="O" )
 column=(type=char(10) update=yes updatewhereclause=yes name=area_no dbname="do.area_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=shipamt_case dbname="do.shipamt_case" )
 column=(type=datetime update=yes updatewhereclause=yes name=ship_date dbname="do.ship_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=close_user dbname="do.close_user" )
 column=(type=datetime update=yes updatewhereclause=yes name=issue_date dbname="do.issue_date" )
 column=(type=char(1) updatewhereclause=yes name=tax_chk dbname="tax_chk" initial="Y" values="	Y/	N" )
 retrieve="  SELECT do.do_no,   
         do.cust_no,   
         do.spot_code,   
         do.do_date,   
         do.sale_flag,   
         do.do_flag,   
         do.invoice_print,   
         do.curr_code,   
         do.curr_rate,   
         do.fob,   
         do.ship_flag,   
         do.ship_amount,   
         do.shipto_addr,   
         do.do_cash,   
         do.do_rate,   
         do.do_total,   
         do.rem,   
         do.tel_no,   
         do.inv_no,   
         do.driver,   
         do.do_case,   
         do.dr_hp,   
         do.user_id,   
         do.ship_close,   
         do.area_no,   
         do.shipamt_case,   
         do.ship_date,   
         do.close_user,   
         do.issue_date,   
         tax_chk = ( case  when do_rate > 0 then 'Y' else 'N' end )  
    FROM do  
   WHERE do.do_no = :as_order    
" update="do" updatewhere=1 updatekeyinplace=no arguments=(("as_order", string)) )
