 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"opeom~" )  TABLE(NAME=~"customer~" ) COLUMN(NAME=~"opeom.cust_no~") COLUMN(NAME=~"opeom.eom_year~") COLUMN(NAME=~"opeom.balbf_amount~") COLUMN(NAME=~"opeom.inv_01~") COLUMN(NAME=~"opeom.inv_02~") COLUMN(NAME=~"opeom.inv_03~") COLUMN(NAME=~"opeom.inv_04~") COLUMN(NAME=~"opeom.inv_05~") COLUMN(NAME=~"opeom.inv_06~") COLUMN(NAME=~"opeom.inv_07~") COLUMN(NAME=~"opeom.inv_08~") COLUMN(NAME=~"opeom.inv_09~") COLUMN(NAME=~"opeom.inv_10~") COLUMN(NAME=~"opeom.inv_11~") COLUMN(NAME=~"opeom.inv_12~") COLUMN(NAME=~"opeom.coll_01~") COLUMN(NAME=~"opeom.coll_02~") COLUMN(NAME=~"opeom.coll_03~") COLUMN(NAME=~"opeom.coll_04~") COLUMN(NAME=~"opeom.coll_05~") COLUMN(NAME=~"opeom.coll_06~") COLUMN(NAME=~"opeom.coll_07~") COLUMN(NAME=~"opeom.coll_08~") COLUMN(NAME=~"opeom.coll_09~") COLUMN(NAME=~"opeom.coll_10~") COLUMN(NAME=~"opeom.coll_11~") COLUMN(NAME=~"opeom.coll_12~") COLUMN(NAME=~"opeom.make_date~") COLUMN(NAME=~"opeom.make_user~") COLUMN(NAME=~"customer.cust_name~")    JOIN (LEFT=~"opeom.cust_no~"    OP =~"=~"RIGHT=~"customer.cust_no~" )WHERE(    EXP1 =~"opeom.cust_no~"   OP =~"=~"    EXP2 =~":aa~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"datepart(year,opeom.eom_year)~"   OP =~"=~"    EXP2 =~":bb ~" ) ) ARG(NAME = ~"aa~" TYPE = string)  ARG(NAME = ~"bb~" TYPE = number) " arguments=(("aa", string),("bb", number)) )
