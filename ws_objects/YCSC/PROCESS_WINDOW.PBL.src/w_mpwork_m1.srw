type cb_filteron2 from commandbutton within tabpage_5
integer x = 2610
integer y = 124
integer width = 160
integer height = 76
integer taborder = 50
integer textsize = -9
integer weight = 400
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "필터"
end type

event clicked;String ls_custnm, ls_column, ls_value, ls_temp, ls_text

ls_temp = ""
if dw9.FilteredCount() > 0 THEN
	dw9.setfilter(ls_temp)
	dw9.filter()
end if

// 필드
if trim(ddlb_col2.text) = "" then
	ls_column = ""
else
	String ls_col
	choose case trim(ddlb_col2.text)
		case "선택"
			ls_col  = "chk "
		case "작업장"
			ls_col  = "wc_no "
		case "작업자"
			ls_col  = "user_id "
		case "오전"
			ls_col  = "work1 "
		case "오후"
			ls_col  = "work2 "
		case "야간"
			ls_col  = "work3 "
	end choose		

	if trim(ddlb_4.text) = "LIKE" then
		ls_column = ls_col + trim(ddlb_4.text) + " '%" + trim(sle_value2.text) + "%' "
	else
		if ls_col = "msgdate " then
			ls_column = ls_col + trim(ddlb_4.text) + " #" + trim(sle_value2.text) + "# "
		elseif ls_col = "cnt " then
			ls_column = ls_col + trim(ddlb_4.text) + " "  + trim(sle_value2.text) + " "
		else
			ls_column = ls_col + trim(ddlb_4.text) + " '" + trim(sle_value2.text) + "' "
		end if
	end if
end if

if ls_column = "" then
	ls_temp = ls_column
else
	ls_temp = "(" + ls_column + ")"
end if

if ls_value <> "" then
	if ls_temp = "" then
		ls_temp = ls_value
	else
		ls_temp = "(" + ls_temp + ") AND (" + trim(ls_value) + ")"
	end if
end if

dw9.setfilter(ls_temp)
dw9.filter()

dw9.scrolltorow(1)
dw9.triggerevent(rowfocuschanged!)

end event

