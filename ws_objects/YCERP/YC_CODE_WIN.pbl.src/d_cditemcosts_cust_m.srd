 column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" values="	Y/	N" )
 retrieve="  SELECT cust_no     = ItemCOSTS_CUST.cust_no
       , cust_name   = c.cust_name
       , item_no     = ItemCOSTS_CUST.item_no
       , item_name   = g.item_name   
       , qa          = ItemCOSTS_CUST.qa
       , uom         = ItemCOSTS_CUST.uom
       , draw_no     = ItemCOSTS_CUST.draw_no
       , product_name= ItemCOSTS_CUST.product_name   
       , item_group  = ItemCOSTS_CUST.item_group
       , id          = ItemCOSTS_CUST.id
       , busy        = ItemCOSTS_CUST.busy
       , sort_idx    = ItemCOSTS_CUST.sort_idx
       , price       = ItemCOSTS_CUST.price   
       , price_top   = ItemCOSTS_CUST.price_top   
       , use_yn      = ItemCOSTS_CUST.use_yn   
       , user_id     = ItemCOSTS_CUST.user_id   
       , user_name   = l.user_name
       , sys_date    = ItemCOSTS_CUST.sys_date 
       , chk         = 'N' 
    FROM ItemCOSTS_CUST
         LEFT OUTER JOIN ItemCOSTS   ON ItemCOSTS_CUST.id      = ItemCOSTS.id
         LEFT OUTER JOIN groupitem G ON ItemCOSTS.item_no      = g.item_no
         LEFT OUTER JOIN customer  C ON ItemCOSTS_CUST.cust_no = c.cust_no
         LEFT OUTER JOIN login     L ON ItemCOSTS_CUST.user_id = l.user_id
   WHERE ((:as_custno   = '%') OR
          (:as_custno  <> '%' AND ItemCOSTS_CUST.cust_no  = :as_custno OR ItemCOSTS_CUST.cust_no IS NULL)
         ) 
     AND ( ItemCOSTS.use_yn  = 'Y' )
" update="ItemCOSTS_CUST" updatewhere=0 updatekeyinplace=no arguments=(("as_custno", string))  sort="item_group A busy A sort_idx A item_name A qa A cust_name A " )
