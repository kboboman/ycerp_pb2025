table(column=(type=char(14) updatewhereclause=yes name=coilorderdet_order_no dbname="coilorderdet.order_no" )
 column=(type=char(20) updatewhereclause=yes name=coilorderdet_coil_no dbname="coilorderdet.coil_no" )
 column=(type=decimal(1) updatewhereclause=yes name=coilorderdet_wid dbname="coilorderdet.wid" )
 column=(type=char(14) updatewhereclause=yes name=coilorder_order dbname="coilorderdet.coilorder_order" )
 column=(type=long updatewhereclause=yes name=order_seq dbname="coilorderdet.order_seq" )
 column=(type=long updatewhereclause=yes name=coilmst_unit_qty dbname="coilmst.unit_qty" )
 column=(type=char(40) updatewhereclause=yes name=coilorderdet_rem dbname="coilorderdet.rem" )
 column=(type=char(10) updatewhereclause=yes name=coilorderdet_loc_no dbname="coilorderdet.loc_no" )
 column=(type=char(2) updatewhereclause=yes name=coilmst_etc_no dbname="coilmst.etc_no" )
 retrieve="  SELECT DISTINCT coilorderdet.order_no,   
         coilorderdet.coil_no,   
         coilorderdet.wid,   
         coilorderdet.coilorder_order,   
         coilorderdet.order_seq,   
         coilmst.unit_qty,   
         coilorderdet.rem,   
         coilorderdet.loc_no,   
         coilmst.etc_no  
    FROM coilorderdet,   
         coilmst,   
         coilorder  
   WHERE ( coilorderdet.coil_no = coilmst.coil_no ) and  
         ( coilorderdet.coilorder_order = coilorder.order_no ) and  
         ( coilorderdet.loc_no = coilmst.loc_no ) and  
         ( ( coilorder.wc_place = 'O' ) AND  
         ( coilorderdet.proc_flag = 'M' ) )    
"  sort="order_seq A " )
