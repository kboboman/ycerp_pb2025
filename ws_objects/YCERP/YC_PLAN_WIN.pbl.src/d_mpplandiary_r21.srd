table(column=(type=long updatewhereclause=yes identity=yes name=cust_diary_id dbname="id" )
 column=(type=datetime updatewhereclause=yes name=diary_date dbname="diary_date" )
 column=(type=long updatewhereclause=yes name=seq dbname="seq" )
 column=(type=char(10) updatewhereclause=yes name=work_no dbname="work_no" )
 column=(type=char(51) updatewhereclause=yes name=work_name dbname="work_name" )
 column=(type=char(50) updatewhereclause=yes name=interview dbname="interview" )
 column=(type=char(4099) updatewhereclause=no name=contents dbname="contents" )
 column=(type=char(4099) updatewhereclause=no name=contents2 dbname="contents2" )
 column=(type=char(10) updatewhereclause=yes name=employee dbname="employee" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=long updatewhereclause=yes name=cqty dbname="cqty" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="user_id" )
 column=(type=char(10) updatewhereclause=yes name=input_name dbname="input_name" )
 column=(type=char(10) updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=char(10) updatewhereclause=yes name=edate dbname="edate" )
 retrieve="  SELECT id          = a.id
       , diary_date  = a.diary_date   
       , seq         = 0
       , work_no     = a.work_no   
       , work_name   = (case when a.work_no is null or a.work_no = '' then '*'+a.work_name else c.work_name end)
       , interview   = a.interview
       , contents    = a.contents   
       , contents2   = a.contents2  
       , employee    = a.employee
       , user_name   = l.user_name    
       , cqty        = a.cqty
       , user_id     = a.user_id
       , input_name  = u.user_name
       , sdate       = (case when :as_sdate is null then '          ' else :as_sdate end)
       , edate       = (case when :as_edate is null then '          ' else :as_edate end)
    FROM plan_diary A
         LEFT OUTER JOIN wc        C ON a.work_no  = c.work_no
         LEFT OUTER JOIN login     L ON a.employee = l.user_id
         LEFT OUTER JOIN login     U ON a.user_id  = u.user_id
/*       LEFT OUTER JOIN opeom_org O ON a.salesman = o.user_id */
   WHERE ( a.diary_date  BETWEEN :as_sdate AND :as_edate )
     AND ( :as_workno   <> '%' AND a.work_no    = :as_workno OR
           :as_workno    = '%' AND a.work_no LIKE :as_workno
         )
     AND ( :as_employee <> '%' AND a.employee    = :as_employee OR
           :as_employee  = '%' AND a.employee LIKE :as_employee
         )

" arguments=(("as_workno", string),("as_sdate", string),("as_edate", string),("as_employee", string))  sort="diary_date D seq A user_name A " )
