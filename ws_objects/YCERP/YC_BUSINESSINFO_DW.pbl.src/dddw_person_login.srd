table(column=(type=char(10) updatewhereclause=yes key=yes name=person_no dbname="login.user_id" )
 column=(type=char(5) updatewhereclause=yes name=team_code dbname="login.team_code" )
 column=(type=char(10) updatewhereclause=yes name=kor_name dbname="login.user_name" )
 retrieve="  SELECT login.user_id,   
         login.team_code,   
         login.user_name
    FROM login   
where team_code <> 'X1000' and team_code <> '00000' and team_code <> '93200'
and user_id <> '19950409' and user_id <> '19981206' and user_id <> '19840902' 
order by user_name" update="login" updatewhere=0 updatekeyinplace=no  sort="kor_name A " )
