detail(height=64 color="536870912" )
table(column=(type=char(12) updatewhereclause=yes name=glbilldet_billdet_vcno dbname="glbilldet.billdet_vcno" )
 column=(type=char(1) updatewhereclause=yes name=glbilldet_det_class dbname="glbilldet.det_class" values="어음	B/부도대	C/교환대	D/수입이자	E/물품대	F/상계	G/환불	R/" )
 column=(type=decimal(0) updatewhereclause=yes name=glbilldet_amount dbname="glbilldet.amount" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(12) updatewhereclause=yes name=glbill_bill_no dbname="glbill.bill_no" )
 column=(type=char(1) updatewhereclause=yes name=glbill_bill_class dbname="glbill.bill_class" values="받을어음	R/지급어음	P/교환어음	C/만기어음	E/부도어음	D/" )
 column=(type=char(20) updatewhereclause=yes name=glbill_draft dbname="glbill.draft" )
 column=(type=datetime updatewhereclause=yes name=glbill_close_date dbname="glbill.close_date" )
 retrieve="  SELECT glbilldet.billdet_vcno,   
         glbilldet.det_class,   
         glbilldet.amount,   
         customer.cust_name,   
         glbill.bill_no,   
         glbill.bill_class,   
         glbill.draft,   
         glbill.close_date
    FROM glbill,   
         glbilldet,   
         customer  
   WHERE ( glbill.vc_no = glbilldet.vc_no ) and  
         ( glbill.bill_no = glbilldet.bill_no ) and  
         ( glbill.cust_no = customer.cust_no ) and  
         ( ( substring(glbilldet.billdet_vcno, 2, 8) = :as_start ) and 
           ( ( ( '%' = :as_cust_no ) and ( glbill.cust_no like '%' ) ) or
             ( ( 'L%' = :as_cust_no ) and ( glbill.cust_no like 'L%' ) ) or
             ( ( 'A%' = :as_cust_no ) and ( glbill.cust_no NOT like 'L%' ) ) ) )
" arguments=(("as_start", string),("as_cust_no", string)) )
