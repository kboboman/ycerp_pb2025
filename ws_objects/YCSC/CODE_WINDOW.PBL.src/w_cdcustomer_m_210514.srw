event clicked;string  ls_Docname, ls_Named, ls_ExpandName
integer li_Pos, li_value

if tab_1.tabpage_6.dw_21.rowcount() > 0 then
	li_value = GetFileSaveName("Select File", ls_Docname, ls_Named, "XLS", "엑셀 (*.XLS), *.XLS, CSV(쉽표로 분리), *.CSV,")
	li_Pos   = PosA(ls_Named, ".")
	ls_ExpandName = MidA(ls_Named, li_Pos + 1, LenA(ls_Named)- li_Pos)

	if li_Value = 1 then
		if ls_ExpandName = "xls" OR ls_ExpandName = "XLS" then
			tab_1.tabpage_6.dw_21.SaveAsascii(ls_DocName)
		elseif ls_ExpandName = "csv" OR ls_ExpandName = "CSV" then
			tab_1.tabpage_6.dw_21.SaveAs(ls_DocName, CSV!, TRUE)
		end if
	end if
end if	

end event

type cb_7 from commandbutton within tabpage_6
integer x = 3017
integer y = 16
integer width = 247
integer height = 104
integer taborder = 191
integer textsize = -11
integer weight = 400
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
boolean enabled = false
string text = "저장"
end type

event clicked;dwitemstatus l_status, l_status_rem
long ll_seq, ll_row
datetime ldt_idate
string ls_cust_no

tab_1.tabpage_6.dw_22.accepttext()
if tab_1.tabpage_6.dw_22.rowcount() < 1 then 
	return
end if

ll_row = tab_1.tabpage_6.dw_22.getrow()
if isnull(tab_1.tabpage_6.dw_22.object.contents[ll_row]) or trim(tab_1.tabpage_6.dw_22.object.contents[ll_row]) = '' then
	messagebox("확인","관리내역을 입력하세요.")
	return
end if

if messagebox("저장","영업관리 내역만 저장됩니다. 저장하시겠습니까?",information!,okcancel!,2) = 2 then
	return
end if
//===============사용자별 프로그램 사용현황=================================
gf_usecount(gs_userid,parent.classname(),"S",string(today(),'yyyy/mm/dd'))
//==========================================================================
ls_cust_no = upper(tab_1.tabpage_6.dw_22.object.cust_no[ll_row])
ldt_idate = tab_1.tabpage_6.dw_22.object.i_date[ll_row]

select isnull(max(seq),0) + 1 into :ll_seq
from customer_cnts
where cust_no = :ls_cust_no
and i_date = :ldt_idate;

tab_1.tabpage_6.dw_22.object.seq[ll_row] = ll_seq

setpointer(hourglass!)
wf_update1(tab_1.tabpage_6.dw_22, "Y")
tab_1.tabpage_6.cb_5.triggerevent(clicked!)

end event

