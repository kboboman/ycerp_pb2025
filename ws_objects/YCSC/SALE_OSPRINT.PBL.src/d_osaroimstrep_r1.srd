$PBExportHeader$d_osaroimstrep_r1.srd
$PBExportComments$매출대장 REPORT(1998/05/15, 정재수)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 1 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 12 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=520 color="536870912" )
summary(height=92 color="536870912" )
footer(height=0 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=aroiinv_cust_no dbname="aroiinv.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(1) updatewhereclause=yes name=aroiinv_inv_type dbname="aroiinv.inv_type" values="매출	Y/선매출	N/" )
 column=(type=char(1) updatewhereclause=yes name=aroiinv_sale_flag dbname="aroiinv.sale_flag" values="내수	D/수출	E/L//C	L/" )
 column=(type=datetime updatewhereclause=yes name=aroiinv_oi_date dbname="aroiinv.oi_date" )
 column=(type=char(3) updatewhereclause=yes name=aroiinv_curr_code dbname="aroiinv.curr_code" )
 column=(type=decimal(4) updatewhereclause=yes name=aroiinv_aroiinv_cash dbname="aroiinv.aroiinv_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=aroiinv_ship_cost dbname="aroiinv.ship_cost" )
 column=(type=decimal(4) updatewhereclause=yes name=aroiinv_aroiinv_rate dbname="aroiinv.aroiinv_rate" )
 column=(type=decimal(0) updatewhereclause=yes name=aroiinv_dc dbname="aroiinv.dc" )
 column=(type=decimal(4) updatewhereclause=yes name=aroiinv_gl_cur_rate dbname="aroiinv.gl_cur_rate" )
 column=(type=char(10) updatewhereclause=yes name=c_start dbname="c_start" )
 column=(type=char(10) updatewhereclause=yes name=c_end dbname="c_end" )
 column=(type=decimal(0) updatewhereclause=yes name=aroiinv_dc_rate dbname="aroiinv.dc_rate" )
 column=(type=decimal(0) updatewhereclause=yes name=aroiinv_discount dbname="aroiinv.discount" )
 column=(type=char(12) updatewhereclause=yes name=aroiinv_aroiinv_no dbname="aroiinv.aroiinv_no" )
 column=(type=char(10) updatewhereclause=yes name=c_area dbname="c_area" )
 retrieve="  SELECT aroiinv.cust_no,   
         customer.cust_name,   
         aroiinv.inv_type,   
         aroiinv.sale_flag,   
         aroiinv.oi_date,   
         aroiinv.curr_code,   
         aroiinv.aroiinv_cash,   
         aroiinv.ship_cost,   
         aroiinv.aroiinv_rate,   
         aroiinv.dc,   
         aroiinv.gl_cur_rate,   
         '          ' c_start,   
         '          ' c_end,   
         aroiinv.dc_rate,   
         aroiinv.discount,   
         aroiinv.aroiinv_no,   
         '          ' c_area  
    FROM aroiinv,   
         customer  
   WHERE ( aroiinv.cust_no = customer.cust_no ) and  
         ( ( aroiinv.sale_flag in ( :asa_flag ) ) AND  
         ( aroiinv.oi_date between :ad_start and :ad_end ) AND  
         ( aroiinv.delete_flag = 'N' ) AND  
         ( aroiinv.inv_area like :as_inv ) )   AND
         ( customer.salesman like :as_userid ) 
" arguments=(("asa_flag", stringlist),("ad_start", date),("ad_end", date),("as_inv", string),("as_userid", string))  sort="aroiinv_aroiinv_no A customer_cust_name A aroiinv_oi_date A " )
group(level=1 header.height=0 trailer.height=80 by=("aroiinv_cust_no" ) header.color="536870912" trailer.color="536870912" )
