release 8;
datawindow(units=0 timer_interval=0 color=78160032 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=692 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=sale_order_no dbname="sale.order_no" initial=" " )
 column=(type=char(4) updatewhereclause=yes name=sale_cust_no dbname="sale.cust_no" initial=" " )
 column=(type=char(11) updatewhereclause=yes name=sale_scene_code dbname="sale.scene_code" initial=" " )
 column=(type=datetime updatewhereclause=yes name=sale_order_date dbname="sale.order_date" initial=" " )
 column=(type=datetime updatewhereclause=yes name=sale_due_date dbname="sale.due_date" initial=" " )
 column=(type=char(14) updatewhereclause=yes name=sale_estimate_no dbname="sale.estimate_no" initial=" " )
 column=(type=char(1) updatewhereclause=yes name=sale_sale_flag dbname="sale.sale_flag" initial=" " values="내수	D/수출	E/L//C	L/" )
 column=(type=char(1) updatewhereclause=yes name=sale_ship_flag dbname="sale.ship_flag" values="대여	D/부담	B/착불	C/방문	M/" )
 column=(type=char(10) updatewhereclause=yes name=sale_fob dbname="sale.fob" initial=" " )
 column=(type=char(10) updatewhereclause=yes name=sale_salesman dbname="sale.salesman" initial=" " )
 column=(type=char(80) updatewhereclause=yes name=sale_shipto_addr dbname="sale.shipto_addr" initial=" " )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene.scene_desc" )
 column=(type=char(10) updatewhereclause=yes name=sale_confirm_user dbname="sale.confirm_user" )
 column=(type=datetime updatewhereclause=yes name=sale_confirm_date dbname="sale.confirm_date" )
 column=(type=char(1) updatewhereclause=yes name=sale_confirm_flag dbname="sale.confirm_flag" values="확정	Y/미확정	N/" )
 column=(type=datetime updatewhereclause=yes name=sale_close_date dbname="sale.close_date" )
 column=(type=datetime updatewhereclause=yes name=sale_revision_date dbname="sale.revision_date" )
 column=(type=datetime updatewhereclause=yes name=sale_input_date dbname="sale.input_date" )
 column=(type=char(10) updatewhereclause=yes name=sale_login_id dbname="sale.login_id" )
 column=(type=long updatewhereclause=yes name=sale_revision_no dbname="sale.revision_no" )
 column=(type=datetime updatewhereclause=yes name=sale_cust_po_date dbname="sale.cust_po_date" )
 column=(type=char(1) updatewhereclause=yes name=sale_open_close dbname="sale.open_close" values="진행중	O/마감	C/" )
 column=(type=char(80) updatewhereclause=yes name=sale_rem dbname="sale.rem" )
 retrieve="  SELECT sale.order_no,   
         sale.cust_no,   
         sale.scene_code,   
         sale.order_date,   
         sale.due_date,   
         sale.estimate_no,   
         sale.sale_flag,   
         sale.ship_flag,   
         sale.fob,   
         sale.salesman,   
         sale.shipto_addr,   
         customer.cust_name,   
         scene.scene_desc,   
         sale.confirm_user,   
         sale.confirm_date,   
         sale.confirm_flag,   
         sale.close_date,   
         sale.revision_date,   
         sale.input_date,   
         sale.login_id,   
         sale.revision_no,   
         sale.cust_po_date,   
         sale.open_close,   
         sale.rem  
    FROM sale 
         LEFT OUTER JOIN scene    ON sale.scene_code = scene.scene_code
         LEFT OUTER JOIN customer ON sale.cust_no = customer.cust_no
   WHERE ( sale.order_no = :as_saleno )    
" arguments=(("as_saleno", string)) )
