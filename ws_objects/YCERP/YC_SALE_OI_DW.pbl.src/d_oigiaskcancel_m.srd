$PBExportComments$물품요청선정취소관리헤(2001/03/02,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=568 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=ask_date dbname="ask_head.ask_date" initial="today()" )
 column=(type=char(10) updatewhereclause=yes name=ask_loc dbname="ask_head.ask_loc" )
 column=(type=char(10) updatewhereclause=yes name=ask_user dbname="ask_head.ask_user" )
 column=(type=char(50) updatewhereclause=yes name=rem dbname="ask_head.rem" )
 column=(type=char(1) update=yes updatewhereclause=yes name=proc_flag dbname="ask_head.proc_flag" values="처리완료	Y/접수중	N/부분	P/" )
 column=(type=char(12) updatewhereclause=yes key=yes name=ask_no dbname="ask_head.ask_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=act_user dbname="ask_head.act_user" )
 column=(type=datetime update=yes updatewhereclause=yes name=act_date dbname="ask_head.act_date" )
 column=(type=char(10) updatewhereclause=yes name=f_area dbname="ask_head.f_area" )
 column=(type=char(10) updatewhereclause=yes name=t_area dbname="ask_head.t_area" )
 column=(type=char(60) update=yes updatewhereclause=yes name=driver dbname="ask_head.driver" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=ship_amount dbname="ask_head.ship_amount" )
 column=(type=char(50) update=yes updatewhereclause=yes name=rem2 dbname="ask_head.rem2" )
 column=(type=char(1) update=yes updatewhereclause=yes name=ship_close dbname="ask_head.ship_close" )
 retrieve="  SELECT ask_head.ask_date,   
         ask_head.ask_loc,   
         ask_head.ask_user,   
         ask_head.rem,   
         ask_head.proc_flag,   
         ask_head.ask_no,   
         ask_head.act_user,   
         ask_head.act_date,   
         ask_head.f_area,   
         ask_head.t_area,   
         ask_head.driver,   
         ask_head.ship_amount,   
         ask_head.rem2,   
         ask_head.ship_close  
    FROM ask_head  
   WHERE ask_head.ask_no = :aa    
" update="ask_head" updatewhere=1 updatekeyinplace=no arguments=(("aa", string)) )
