table(column=(type=char(4) update=yes updatewhereclause=yes key=yes name=sid dbname="sid" )
 column=(type=char(50) update=yes updatewhereclause=yes name=sname dbname="sname" )
 column=(type=char(8) update=yes updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="uom" )
 column=(type=char(50) update=yes updatewhereclause=yes name=remark dbname="remark" )
 column=(type=char(1) update=yes updatewhereclause=yes name=use_flag dbname="use_flag" initial="N" values="사용	Y/불가	N/" )
 column=(type=char(10) update=yes updatewhereclause=yes name=sysuser dbname="sysuser" )
 column=(type=datetime update=yes updatewhereclause=yes name=sysdate dbname="sysdate" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=qty1 dbname="qty1" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=qty2 dbname="qty2" )
 column=(type=decimal(0) updatewhereclause=yes name=qty3 dbname="qty3" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 retrieve="SELECT sid        = a.sid
     , sname      = a.sname
     , sdate      = a.sdate
     , uom        = a.uom
     , remark     = a.remark
     , use_flag   = a.use_flag
     , sysuser    = a.sysuser
     , sysdate    = a.sysdate
     , qty1       = a.qty1
     , qty2       = a.qty2
     , qty3       = a.qty3
     , user_name  = b.user_name
  FROM NBASIS_MST a
       LEFT OUTER JOIN login b  ON a.sysuser = b.user_id
 WHERE a.sid      = :as_sid" update="NBASIS_MST" updatewhere=0 updatekeyinplace=no arguments=(("as_sid", string)) )
