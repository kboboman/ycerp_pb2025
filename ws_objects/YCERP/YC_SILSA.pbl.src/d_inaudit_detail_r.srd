$PBExportHeader$d_inaudit_detail_r.srd
$PBExportComments$재고수불부(inaudit)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=char(8) updatewhereclause=yes name=년월 dbname="년월" )
 column=(type=char(10) updatewhereclause=yes name=저장소코드 dbname="저장소코드" )
 column=(type=char(30) updatewhereclause=yes name=저장소명 dbname="저장소명" )
 column=(type=char(10) updatewhereclause=yes name=물품코드 dbname="물품코드" )
 column=(type=char(60) updatewhereclause=yes name=물품명 dbname="물품명" )
 column=(type=char(2) updatewhereclause=yes name=단위 dbname="단위" )
 column=(type=char(20) updatewhereclause=yes name=규격 dbname="규격" )
 column=(type=char(4) updatewhereclause=yes name=물품유형 dbname="물품유형" )
 column=(type=char(1) updatewhereclause=yes name=사용유무 dbname="사용유무" )
 column=(type=char(1) updatewhereclause=yes name=assembly dbname="assembly" )
 column=(type=decimal(4) updatewhereclause=yes name=기초재고 dbname="기초재고" )
 column=(type=decimal(2) updatewhereclause=yes name=입고계 dbname="입고계" )
 column=(type=decimal(2) updatewhereclause=yes name=출고계 dbname="출고계" )
 column=(type=decimal(2) updatewhereclause=yes name=기말재고 dbname="기말재고" )
 column=(type=decimal(2) updatewhereclause=yes name=대체출고 dbname="대체출고" )
 column=(type=decimal(2) updatewhereclause=yes name=제품폐기출고 dbname="제품폐기출고" )
 column=(type=decimal(2) updatewhereclause=yes name=반품출고 dbname="반품출고" )
 column=(type=decimal(2) updatewhereclause=yes name=물품요청출고 dbname="물품요청출고" )
 column=(type=decimal(2) updatewhereclause=yes name=저장소출고 dbname="저장소출고" )
 column=(type=decimal(2) updatewhereclause=yes name=외주가공출고 dbname="외주가공출고" )
 column=(type=decimal(2) updatewhereclause=yes name=구매처출고 dbname="구매처출고" )
 column=(type=decimal(2) updatewhereclause=yes name=샘플출고 dbname="샘플출고" )
 column=(type=decimal(2) updatewhereclause=yes name=자재반품출고 dbname="자재반품출고" )
 column=(type=decimal(2) updatewhereclause=yes name=제품출고 dbname="제품출고" )
 column=(type=decimal(2) updatewhereclause=yes name=기타출고 dbname="기타출고" )
 column=(type=decimal(2) updatewhereclause=yes name=작업장으로출고 dbname="작업장으로출고" )
 column=(type=decimal(2) updatewhereclause=yes name=실사보정출고 dbname="실사보정출고" )
 column=(type=decimal(2) updatewhereclause=yes name=대체입고 dbname="대체입고" )
 column=(type=decimal(2) updatewhereclause=yes name=불량품입고 dbname="불량품입고" )
 column=(type=decimal(2) updatewhereclause=yes name=스리팅입고 dbname="스리팅입고" )
 column=(type=decimal(2) updatewhereclause=yes name=반품입고 dbname="반품입고" )
 column=(type=decimal(2) updatewhereclause=yes name=구매입고 dbname="구매입고" )
 column=(type=decimal(2) updatewhereclause=yes name=물품요청입고 dbname="물품요청입고" )
 column=(type=decimal(2) updatewhereclause=yes name=저장소입고 dbname="저장소입고" )
 column=(type=decimal(2) updatewhereclause=yes name=외주가공입고 dbname="외주가공입고" )
 column=(type=decimal(2) updatewhereclause=yes name=생산계획입고 dbname="생산계획입고" )
 column=(type=decimal(2) updatewhereclause=yes name=자재반품입고 dbname="자재반품입고" )
 column=(type=decimal(2) updatewhereclause=yes name=제품반품입고 dbname="제품반품입고" )
 column=(type=decimal(2) updatewhereclause=yes name=기타입고 dbname="기타입고" )
 column=(type=decimal(2) updatewhereclause=yes name=작업장에서입고 dbname="작업장에서입고" )
 column=(type=decimal(2) updatewhereclause=yes name=실사보정입고 dbname="실사보정입고" )
 retrieve="select a.yymm 년월, 
           a.loc_no 저장소코드,
           c.loc_name 저장소명,
           a.item_no 물품코드,
           d.item_name 물품명,     
		d.uom 단위,      
           a.qa 규격,
           a.물품유형, 
		 b.use_flag 사용유무, 
		 (case when e.item_no is null then '1' else '2' end ) assembly,
           sum(isnull(a.기초재고,0)) 기초재고,
           sum(isnull(a.입고계,0)) 입고계,
           sum(isnull(a.출고계,0)) 출고계,
           sum(isnull(a.기초재고,0)) + 
           sum(isnull(a.입고계,0)) -
           sum(isnull(a.출고계,0)) 기말재고,
           sum(isnull(a.대체출고,0)) 대체출고,
           sum(isnull(a.제품폐기출고,0)) 제품폐기출고,
           sum(isnull(a.반품출고,0)) 반품출고,
           sum(isnull(a.물품요청출고,0)) 물품요청출고,
           sum(isnull(a.저장소출고,0)) 저장소출고,
           sum(isnull(a.외주가공출고,0)) 외주가공출고,
           sum(isnull(a.구매처출고,0)) 구매처출고,
           sum(isnull(a.샘플출고,0)) 샘플출고,
           sum(isnull(a.자재반품출고,0)) 자재반품출고,
           sum(isnull(a.제품출고,0)) 제품출고,
           sum(isnull(a.기타출고,0)) 기타출고,
           sum(isnull(a.작업장으로출고,0)) 작업장으로출고,
           sum(isnull(a.실사보정출고,0)) 실사보정출고,
           sum(isnull(a.대체입고,0)) 대체입고,
           sum(isnull(a.불량품입고,0)) 불량품입고,
           sum(isnull(a.스리팅입고,0)) 스리팅입고,
           sum(isnull(a.반품입고,0)) 반품입고,
           sum(isnull(a.구매입고,0)) 구매입고,
           sum(isnull(a.물품요청입고,0)) 물품요청입고,
           sum(isnull(a.저장소입고,0)) 저장소입고,
           sum(isnull(a.외주가공입고,0)) 외주가공입고,
           sum(isnull(a.생산계획입고,0)) 생산계획입고,
           sum(isnull(a.자재반품입고,0)) 자재반품입고,
           sum(isnull(a.제품반품입고,0)) 제품반품입고,
           sum(isnull(a.기타입고,0)) 기타입고,
           sum(isnull(a.작업장에서입고,0)) 작업장에서입고,
           sum(isnull(a.실사보정입고,0)) 실사보정입고           
from 
(
select     
               substring(CONVERT(CHAR(8), INAUDIT_DATE,112),1,6) yymm,
               LOC_NO,
               INAUDIT_ITEM item_no,
               QA,
		   (
                       case when substring( INAUDIT_ITEM,1, 1) = 'G' then '상품'
                                when substring( INAUDIT_ITEM,1, 1) = 'M' then '자재'
                                when substring( INAUDIT_ITEM,1, 1) = 'P' then '제품' end
              ) 물품유형,
               0                                                                                                                                                       기초재고,
               SUM(case when inaudit_type = 'IA' then ISNULL(rcpt_qty,0) + ISNULL(ISSUE_QTY,0) end) 대체출고,
               SUM(case when inaudit_type = 'IB' then ISNULL(rcpt_qty,0) + ISNULL(ISSUE_QTY,0) end) 제품폐기출고,          
               SUM(case when inaudit_type = 'IF' then ISNULL(rcpt_qty,0) + ISNULL(ISSUE_QTY,0) end) 반품출고,           
               SUM(case when inaudit_type = 'IK' then ISNULL(rcpt_qty,0) + ISNULL(ISSUE_QTY,0) end) 물품요청출고,           
               SUM(case when inaudit_type = 'IL' then ISNULL(rcpt_qty,0) + ISNULL(ISSUE_QTY,0) end) 저장소출고,           
               SUM(case when inaudit_type = 'IO' then ISNULL(rcpt_qty,0) + ISNULL(ISSUE_QTY,0) end) 외주가공출고,           
               SUM(case when inaudit_type = 'IP' then ISNULL(rcpt_qty,0) + ISNULL(ISSUE_QTY,0) end) 구매처출고,           
               SUM(case when inaudit_type = 'IQ' then ISNULL(rcpt_qty,0) + ISNULL(ISSUE_QTY,0) end) 샘플출고,           
               SUM(case when inaudit_type = 'IR' then ISNULL(rcpt_qty,0) + ISNULL(ISSUE_QTY,0) end) 자재반품출고,           
               SUM(case when inaudit_type = 'IS' then ISNULL(rcpt_qty,0) + ISNULL(ISSUE_QTY,0) end) 제품출고,
               SUM(case when inaudit_type = 'IT' then ISNULL(rcpt_qty,0) + ISNULL(ISSUE_QTY,0) end) 기타출고,               
               SUM(case when inaudit_type = 'IW' then ISNULL(rcpt_qty,0) + ISNULL(ISSUE_QTY,0) end) 작업장으로출고,           
               SUM(case when inaudit_type = 'IX' then ISNULL(rcpt_qty,0) + ISNULL(ISSUE_QTY,0) end) 실사보정출고,                          
               SUM(case when inaudit_type = 'RA' then ISNULL(rcpt_qty,0) + ISNULL(ISSUE_QTY,0) end) 대체입고,           
               SUM(case when inaudit_type = 'RB' then ISNULL(rcpt_qty,0) + ISNULL(ISSUE_QTY,0) end) 불량품입고,           
               SUM(case when inaudit_type = 'RC' then ISNULL(rcpt_qty,0) + ISNULL(ISSUE_QTY,0) end) 스리팅입고,           
               SUM(case when inaudit_type = 'RF' then ISNULL(rcpt_qty,0) + ISNULL(ISSUE_QTY,0) end) 반품입고,           
               SUM(case when inaudit_type = 'RI' then ISNULL(rcpt_qty,0) + ISNULL(ISSUE_QTY,0) end) 구매입고,           
               SUM(case when inaudit_type = 'RK' then ISNULL(rcpt_qty,0) + ISNULL(ISSUE_QTY,0) end) 물품요청입고,           
               SUM(case when inaudit_type = 'RL' then ISNULL(rcpt_qty,0) + ISNULL(ISSUE_QTY,0) end) 저장소입고,          
               SUM(case when inaudit_type = 'RO' then ISNULL(rcpt_qty,0) + ISNULL(ISSUE_QTY,0) end) 외주가공입고,
               SUM(case when inaudit_type = 'RP' then ISNULL(rcpt_qty,0) + ISNULL(ISSUE_QTY,0) end) 생산계획입고,           
               SUM(case when inaudit_type = 'RR' then ISNULL(rcpt_qty,0) + ISNULL(ISSUE_QTY,0) end) 자재반품입고,
               SUM(case when inaudit_type = 'RS' then ISNULL(rcpt_qty,0) + ISNULL(ISSUE_QTY,0) end) 제품반품입고,
               SUM(case when inaudit_type = 'RT' then ISNULL(rcpt_qty,0) + ISNULL(ISSUE_QTY,0) end) 기타입고,
               SUM(case when inaudit_type = 'RW' then ISNULL(rcpt_qty,0) + ISNULL(ISSUE_QTY,0) end) 작업장에서입고,
               SUM(case when inaudit_type = 'RX' then ISNULL(rcpt_qty,0) + ISNULL(ISSUE_QTY,0) end) 실사보정입고,
               SUM(ISNULL(rcpt_qty,0)) 입고계,
               SUM(ISNULL(ISSUE_qty,0)) 출고계
from inaudit with(nolock)
WHERE INAUDIT_DATE  BETWEEN convert(datetime,  :as_from_date +' 00:00:00' ) and convert(datetime,  :as_to_date + ' 23:59:59' )
        and LOC_NO like :as_locno
	   and substring( INAUDIT_ITEM,1, 1) like :as_gubun
GROUP BY substring(CONVERT(CHAR(8), INAUDIT_DATE,112),1,6),
                LOC_NO,
               INAUDIT_ITEM,
               QA,
		   (
                       case when substring( INAUDIT_ITEM,1, 1) = 'G' then '상품'
                                when substring( INAUDIT_ITEM,1, 1) = 'M' then '자재'
                                when substring( INAUDIT_ITEM,1, 1) = 'P' then '제품' end
              )
union all
select     
              substring(:as_from_date,1,6) yymm,
              loc_no,
	         item_no,
	        qa,
		   (
                       case when substring( item_no,1, 1) = 'G' then '상품'
                                when substring( item_no,1, 1) = 'M' then '자재'
                                when substring( item_no,1, 1) = 'P' then '제품' end
              ) 물품유형,
	        isnull(stock_qty,0) 기초재고,
              0     				대체출고,
              0     				제품폐기출고,          
              0      				반품출고,           
              0  				     물품요청출고,           
              0     				저장소출고,           
              0        				외주가공출고,           
              0        				구매처출고,           
              0        				샘플출고,           
              0         				자재반품출고,           
              0        				제품출고,
              0        				기타출고,               
              0        				작업장으로출고,           
              0         				실사보정출고,                          
              0        				대체입고,           
              0        				불량품입고,           
              0      				스리팅입고,           
              0        				반품입고,           
              0         				구매입고,           
              0        				물품요청입고,           
              0         				저장소입고,          
              0        				외주가공입고,
              0         				생산계획입고,           
              0         				자재반품입고,
              0         				제품반품입고,
              0         				기타입고,
              0         				작업장에서입고,
              0         				실사보정입고,
              0         				입고계,
              0         				출고계
	 from item_stock with(nolock)
     where stock_date   = convert(char(10), dateadd(day, -1, convert(datetime, :as_from_date) ),112)
         and stock_qty <> 0
         and loc_no  LIKE :as_locno
	   and substring( item_no,1, 1) like :as_gubun
) a  inner join item b with(nolock) on a.item_no = b.item_no and a.qa = b.qa
      inner join location  c with(nolock) on a.loc_no = c.loc_no
      inner join groupitem d with(nolock) on a.item_no = d.item_no 

      LEFT OUTER JOIN (

										select distinct 
												item_no, 
												substring(qa,1,14)+'00000' qa   
										from item_fitting

							    ) e ON a.item_no = e.item_no AND  substring(a.qa,1,14)+'00000' = e.qa

/*where*/ /*b.use_flag = 'Y'	   */ /*2018.05.03 조원석 사용불가 제외  */		
    /*and  D.P3 <> 'Y'*/	/*주석처리 jowonsuk 2018.06.13*/
    /*and *//* D.cost_yn <> 'Y'*/ /*2018.04.12 조원석 비용 제외  */
    								    /*2018.05.03 조원석 비용 제외 주석처리  */
    								    /*2018.07.09 조원석 비용 제외 주석처리  */
 and d.cost_yn <> 'Y'
 and a.item_no not in ('PZZZPA9ZZZ', 'PZZZPP7ZZZ') /* jowonsuk 2018.07.09 , 계산서정정,  금형비 */											  
 and not exists (
						select b.item_no
						from
						  (
										 SELECT  item_no
										  FROM groupitem
										  WHERE groupitem.ITEM_NAME LIKE '%샘플%' or groupitem.item_name like '%LOSS%'
										  union all
										  select item_no
											from item_cost
						 ) b 
						 where  b.item_no = a.item_no
					 )
group by   a.yymm,
                 a.loc_no,
                 c.loc_name,
                 a.item_no,
                 a.qa,
                 d.item_name,
			 a.물품유형,
			 b.use_flag,
			 d.uom,
			 (case when e.item_no is null then '1' else '2' end )
having   sum(   abs(isnull(a.기초재고,0))              +
				    abs(isnull(a.대체출고,0))	         +	
				    abs(isnull(a.제품폐기출고,0))       +
				    abs(isnull(a.반품출고,0))             +
				    abs(isnull(a.물품요청출고,0))	  + 
				    abs(isnull(a.저장소출고,0)) 		  +	
				    abs(isnull(a.외주가공출고,0)) 	  + 
				    abs(isnull(a.구매처출고,0)) 		  +  
				    abs(isnull(a.샘플출고,0))		  + 	
				    abs(isnull(a.자재반품출고,0)) 	  +	
				    abs(isnull(a.제품출고,0)) 		  + 
				    abs(isnull(a.기타출고,0)) 		  +  
				    abs(isnull(a.작업장으로출고,0))   + 
				    abs(isnull(a.실사보정출고,0))      +	
				    abs(isnull(a.대체입고,0)) 		  + 
				    abs(isnull(a.불량품입고,0)) 		  +  
				    abs(isnull(a.스리팅입고,0))         + 
				    abs(isnull(a.반품입고,0)) 		  +	
				    abs(isnull(a.구매입고,0)) 		  + 
				    abs(isnull(a.물품요청입고,0)) 	  +  
				    abs(isnull(a.저장소입고,0))         + 
				    abs(isnull(a.외주가공입고,0))	  +	
				    abs(isnull(a.생산계획입고,0)) 	  + 
				    abs(isnull(a.자재반품입고,0)) 	  +  
				    abs(isnull(a.제품반품입고,0))      + 
				    abs(isnull(a.기타입고,0)) 		  +	
				    abs(isnull(a.작업장에서입고,0))   + 
				    abs(isnull(a.실사보정입고,0))     	  
				) <> 0 " arguments=(("as_gubun", string),("as_locno", string),("as_from_date", string),("as_to_date", string))  sort="년월 A 저장소코드 A 물품유형 A 물품코드 A 규격 A " )
text(band=header alignment="2" text="년월" border="6" color="0" x="9" y="4" height="68" width="247" html.valueishtml="0"  name=a_년월_t visible="1"  font.face="Arial" font.height="-12" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="2" background.color="67108864" )
