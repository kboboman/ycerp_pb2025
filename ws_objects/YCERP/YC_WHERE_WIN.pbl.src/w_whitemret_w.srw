forward prototypes
public subroutine wf_fil ()
public function boolean wf_mytemptable (string as_table, string as_from, string as_to, string as_loc)
end prototypes

public subroutine wf_fil ();//
string ls_file, ls_file1, ls_file2, ls_file3, ls_file4, ls_file5

// rcptqty, issueqty, qoh, notissueqty
ls_file = ""

if tab_1.tabpage_1.cbx_1.checked = true then
	ls_file1 = "( qoh - rcptqty + issueqty ) > 0 "
else
	ls_file1 = ""
end if

ls_file = ls_file1
if tab_1.tabpage_1.cbx_2.checked = true then
	if ls_file = "" then 
		ls_file2 = " rcptqty > 0 "
	else
		ls_file2 = " or rcptqty > 0 "
	end if
else
	ls_file2 = ""
end if

ls_file = ls_file1 + ls_file2
if tab_1.tabpage_1.cbx_3.checked = true then
	if ls_file = "" then 
		ls_file3 = " issueqty > 0 "
	else
		ls_file3 = " or issueqty > 0 "
	end if
else
	ls_file3 = ""
end if

ls_file = ls_file1 + ls_file2 + ls_file3
if tab_1.tabpage_1.cbx_4.checked = true then
	if ls_file = "" then 
		ls_file4 = " qoh > 0 "
	else
		ls_file4 = " or qoh > 0 "
	end if
else
	ls_file4 = ""
end if

ls_file = ls_file1 + ls_file2 + ls_file3 + ls_file4
if tab_1.tabpage_1.cbx_5.checked = true then
	if ls_file = "" then 
		ls_file5 = " notissueqty > 0 "
	else
		ls_file5 = " or notissueqty > 0 "
	end if
else
	ls_file5 = ""
end if

//
ls_file = ls_file1 + ls_file2 + ls_file3 + ls_file4 + ls_file5
if ls_file = "" then
	tab_1.tabpage_1.dw_4.setfilter("")
else
	tab_1.tabpage_1.dw_4.setfilter(ls_file)
end if

tab_1.tabpage_1.dw_4.filter()

end subroutine

public function boolean wf_mytemptable (string as_table, string as_from, string as_to, string as_loc);String ls_sql

ls_sql = " DROP TABLE " + as_table + "                                              " + &
         " CREATE TABLE " + as_table + " (                                          " + &
         "    ITEM_NO  CHAR(10)       ,                                             " + &
         "    QA       CHAR(20)       ,                                             " + &
         "    M_IQTY   DECIMAL(15, 4) ,                                             " + &
         "    A_IQTY   DECIMAL(15, 4) ,                                             " + &
         "    V_IQTY   DECIMAL(15, 4) ,                                             " + &
         "    R_IQTY   DECIMAL(15, 4) ,                                             " + &
         "    N_IQTY   DECIMAL(15, 4) ,                                             " + &
         "    W_IQTY   DECIMAL(15, 4) ,                                             " + &
         "    I_IQTY   DECIMAL(15, 4) ,                                             " + &
         "    D_OQTY   DECIMAL(15, 4) ,                                             " + &
         "    A_OQTY   DECIMAL(15, 4) ,                                             " + &
         "    V_OQTY   DECIMAL(15, 4) ,                                             " + &
         "    S_OQTY   DECIMAL(15, 4) ,                                             " + &
         "    P_OQTY   DECIMAL(15, 4) ,                                             " + &
         "    W_OQTY   DECIMAL(15, 4) ,                                             " + &
         "    U_OQTY   DECIMAL(15, 4) ,                                             " + &
         "    J_OQTY   DECIMAL(15, 4) ,                                             " + &
         "    QOH      DECIMAL(15, 4)                                               " + &
         " );                                                                       " + &
         "                                                                          " + &
         " INSERT INTO " + as_table + "                                             " + &
         " SELECT ITEM_NO    = D.ASSEMBLY                                           " + &
         "      , QA         = D.ASSEMBLY_QA                                        " + &
         "      , M_IQTY     = D.MAKE_QTY /*(생산)입고*/                            " + &
         "      , A_IQTY     = 0                                                    " + &
         "      , V_IQTY     = 0                                                    " + &
         "      , R_IQTY     = 0                                                    " + &
         "      , N_IQTY     = 0                                                    " + &
         "      , W_IQTY     = 0                                                    " + &
         "      , I_IQTY     = 0                                                    " + &
         "      , D_OQTY     = 0                                                    " + &
         "      , A_OQTY     = 0                                                    " + &
         "      , V_OQTY     = 0                                                    " + &
         "      , S_OQTY     = 0                                                    " + &
         "      , P_OQTY     = 0                                                    " + &
         "      , W_OQTY     = 0                                                    " + &
         "      , U_OQTY     = 0                                                    " + &
         "      , J_OQTY     = 0                                                    " + &
         "      , QOH        = 0                                                    " + &
         "   FROM SFCDAY D                                                          " + &
         "  WHERE CONVERT(CHAR(10),D.SFC_DATE,111)  BETWEEN " + as_from + " AND " + as_to + &
         "    AND D.LOC_NO          = " + as_loc + "                                " + &
         "                                                                          " + &
         " INSERT INTO " + as_table + "                                             " + &
         " SELECT ITEM_NO    = D.TAR_ITEM                                           " + &
         "      , QA         = D.TAR_QA                                             " + &
         "      , M_IQTY     = 0                                                    " + &
         "      , A_IQTY     = SUM(ISNULL(D.TAR_QTY, 0)) /*대체입고*/               " + &
         "      , V_IQTY     = 0                                                    " + &
         "      , R_IQTY     = 0                                                    " + &
         "      , N_IQTY     = 0                                                    " + &
         "      , W_IQTY     = 0                                                    " + &
         "      , I_IQTY     = 0                                                    " + &
         "      , D_OQTY     = 0                                                    " + &
         "      , A_OQTY     = 0                                                    " + &
         "      , V_OQTY     = 0                                                    " + &
         "      , S_OQTY     = 0                                                    " + &
         "      , P_OQTY     = 0                                                    " + &
         "      , W_OQTY     = 0                                                    " + &
         "      , U_OQTY     = 0                                                    " + &
         "      , J_OQTY     = 0                                                    " + &
         "      , QOH        = 0                                                    " + &
         "   FROM ITEMALTER D                                                       " + &
         "  WHERE CONVERT(CHAR(10),D.ALTER_DATE,111) BETWEEN " + as_from + " AND " + as_to + &
         "    AND D.TAR_LOC          = " + as_loc + "                               " + &
         "  GROUP BY D.TAR_ITEM, D.TAR_QA                                           " + &
         "                                                                          " + &
         " INSERT INTO " + as_table + "                                             " + &
         " SELECT ITEM_NO    = D.ITEM_NO                                            " + &
         "      , QA         = D.QA                                                 " + &
         "      , M_IQTY     = 0                                                    " + &
         "      , A_IQTY     = 0                                                    " + &
         "      , V_IQTY     = SUM(ISNULL(D.RLSE_QTY, 0)) /*저장소이동(입고)*/      " + &
         "      , R_IQTY     = 0                                                    " + &
         "      , N_IQTY     = 0                                                    " + &
         "      , W_IQTY     = 0                                                    " + &
         "      , I_IQTY     = 0                                                    " + &
         "      , D_OQTY     = 0                                                    " + &
         "      , A_OQTY     = 0                                                    " + &
         "      , V_OQTY     = 0                                                    " + &
         "      , S_OQTY     = 0                                                    " + &
         "      , P_OQTY     = 0                                                    " + &
         "      , W_OQTY     = 0                                                    " + &
         "      , U_OQTY     = 0                                                    " + &
         "      , J_OQTY     = 0                                                    " + &
         "      , QOH        = 0                                                    " + &
         "   FROM ASK_HEAD H                                                        " + &
         "      , ASK_DET  D                                                        " + &
         "  WHERE H.ASK_NO          = D.ASK_NO                                      " + &
         "    AND CONVERT(CHAR(10),D.RLSE_DATE,111) BETWEEN " + as_from + " AND " + as_to + &
         "    AND H.ASK_LOC         = " + as_loc + "                                " + &
         "  GROUP BY D.ITEM_NO, D.QA                                                " + &
         "                                                                          " + &
         " INSERT INTO " + as_table + "                                             " + &
         " SELECT ITEM_NO     = D.ITEM_NO                                           " + &
         "      , QA          = D.QA                                                " + &
         "      , M_IQTY      = 0                                                   " + &
         "      , A_IQTY      = 0                                                   " + &
         "      , V_IQTY      = 0                                                   " + &
         "      , R_IQTY      = SUM(ISNULL(D.SHIP_QTY, 0) * -1) /*반품(입고)*/      " + &
         "      , N_IQTY      = 0                                                   " + &
         "      , W_IQTY      = 0                                                   " + &
         "      , I_IQTY      = 0                                                   " + &
         "      , D_OQTY      = 0                                                   " + &
         "      , A_OQTY      = 0                                                   " + &
         "      , V_OQTY      = 0                                                   " + &
         "      , S_OQTY      = 0                                                   " + &
         "      , P_OQTY      = 0                                                   " + &
         "      , W_OQTY      = 0                                                   " + &
         "      , U_OQTY      = 0                                                   " + &
         "      , J_OQTY      = 0                                                   " + &
         "      , QOH         = 0                                                   " + &
         "   FROM DO    H                                                           " + &
         "      , DODET D                                                           " + &
         "  WHERE H.DO_NO            = D.DO_NO                                      " + &
         "    AND H.DO_CASE          = 'D'                                          " + &
         "    AND CONVERT(CHAR(10),H.ISSUE_DATE,111) BETWEEN " + as_from + " AND " + as_to + &
         "    AND D.LOC_NO           = " + as_loc + "                               " + &
         "  GROUP BY D.ITEM_NO, D.QA                                                " + &
         "                                                                          " + &
         " INSERT INTO " + as_table + "                                             " + &
         " SELECT ITEM_NO     = D.ITEM_NO                                           " + &
         "      , QA          = D.QA                                                " + &
         "      , M_IQTY      = 0                                                   " + &
         "      , A_IQTY      = 0                                                   " + &
         "      , V_IQTY      = 0                                                   " + &
         "      , R_IQTY      = 0                                                   " + &
         "      , N_IQTY      = SUM(ISNULL(D.FREE_QTY, 0)) /*무상(입고)*/           " + &
         "      , W_IQTY      = 0                                                   " + &
         "      , I_IQTY      = 0                                                   " + &
         "      , D_OQTY      = 0                                                   " + &
         "      , A_OQTY      = 0                                                   " + &
         "      , V_OQTY      = 0                                                   " + &
         "      , S_OQTY      = 0                                                   " + &
         "      , P_OQTY      = 0                                                   " + &
         "      , W_OQTY      = 0                                                   " + &
         "      , U_OQTY      = 0                                                   " + &
         "      , J_OQTY      = 0                                                   " + &
         "      , QOH         = 0                                                   " + &
         "   FROM RET    H                                                          " + &
         "      , RETDET D                                                          " + &
         "  WHERE CONVERT(CHAR(10),H.RET_DATE,111)    BETWEEN " + as_from + " AND " + as_to + &
         "    AND H.RET_NO            = D.RET_NO                                    " + &
         "    AND H.PROCESS_FLAG NOT IN ('O', 'Y')                                  " + &
         "    AND D.LOC_NO            = " + as_loc + "                              " + &
         "  GROUP BY D.ITEM_NO, D.QA                                                " + &
         "                                                                          " + &
         " INSERT INTO " + as_table + "                                             " + &
         " SELECT ITEM_NO     = D.ITEM_NO                                           " + &
         "      , QA          = D.QA                                                " + &
         "      , M_IQTY      = 0                                                   " + &
         "      , A_IQTY      = 0                                                   " + &
         "      , V_IQTY      = 0                                                   " + &
         "      , R_IQTY      = 0                                                   " + &
         "      , N_IQTY      = 0                                                   " + &
         "      , W_IQTY      = SUM(ISNULL(D.RCPT_QTY, 0)) /*가공입고*/             " + &
         "      , I_IQTY      = 0                                                   " + &
         "      , D_OQTY      = 0                                                   " + &
         "      , A_OQTY      = 0                                                   " + &
         "      , V_OQTY      = 0                                                   " + &
         "      , S_OQTY      = 0                                                   " + &
         "      , P_OQTY      = 0                                                   " + &
         "      , W_OQTY      = 0                                                   " + &
         "      , U_OQTY      = 0                                                   " + &
         "      , J_OQTY      = 0                                                   " + &
         "      , QOH         = 0                                                   " + &
         "   FROM INSP    H                                                         " + &
         "      , INSPDET D                                                         " + &
         "      , ITEM    I                                                         " + &
         "  WHERE CONVERT(CHAR(10),H.INSP_DATE,111) BETWEEN " + as_from + " AND " + as_to + &
         "    AND H.INSP_NO         = D.INSP_NO                                     " + &
         "    AND D.ITEM_NO         = I.ITEM_NO                                     " + &
         "    AND D.QA              = I.QA                                          " + &
         "    /*AND I.SAVE_STOCK      = 'Y'*/                                       " + &
         "    AND D.LOC_NO          = " + as_loc + "                                " + &
         "  GROUP BY D.ITEM_NO, D.QA                                                " + &
         "                                                                          " + &
         " INSERT INTO " + as_table + "                                             " + &
         " SELECT ITEM_NO     = H.ITEM_NO                                           " + &
         "      , QA          = H.QA                                                " + &
         "      , M_IQTY      = 0                                                   " + &
         "      , A_IQTY      = 0                                                   " + &
         "      , V_IQTY      = 0                                                   " + &
         "      , R_IQTY      = 0                                                   " + &
         "      , N_IQTY      = 0                                                   " + &
         "      , W_IQTY      = 0                                                   " + &
         "      , I_IQTY      = SUM(ISNULL(H.QTY, 0)) /*가입고*/                    " + &
         "      , D_OQTY      = 0                                                   " + &
         "      , A_OQTY      = 0                                                   " + &
         "      , V_OQTY      = 0                                                   " + &
         "      , S_OQTY      = 0                                                   " + &
         "      , P_OQTY      = 0                                                   " + &
         "      , W_OQTY      = 0                                                   " + &
         "      , U_OQTY      = 0                                                   " + &
         "      , J_OQTY      = 0                                                   " + &
         "      , QOH         = 0                                                   " + &
         "   FROM INTEMP H                                                          " + &
         "  WHERE CONVERT(CHAR(10),H.INTEMP_DATE,111) BETWEEN " + as_from + " AND " + as_to + &
         "    AND H.LOC_NO            = " + as_loc + "                              " + &
         "  GROUP BY H.ITEM_NO, H.QA                                                " + &
         "                                                                          " + &
         " INSERT INTO " + as_table + "                                             " + &
         " SELECT ITEM_NO     = D.ITEM_NO                                           " + &
         "      , QA          = D.QA                                                " + &
         "      , M_IQTY      = 0                                                   " + &
         "      , A_IQTY      = 0                                                   " + &
         "      , V_IQTY      = 0                                                   " + &
         "      , R_IQTY      = 0                                                   " + &
         "      , N_IQTY      = 0                                                   " + &
         "      , W_IQTY      = 0                                                   " + &
         "      , I_IQTY      = 0                                                   " + &
         "      , D_OQTY      = SUM(ISNULL(D.SHIP_QTY, 0)) /*출고(정상)*/           " + &
         "      , A_OQTY      = 0                                                   " + &
         "      , V_OQTY      = 0                                                   " + &
         "      , S_OQTY      = 0                                                   " + &
         "      , P_OQTY      = 0                                                   " + &
         "      , W_OQTY      = 0                                                   " + &
         "      , U_OQTY      = 0                                                   " + &
         "      , J_OQTY      = 0                                                   " + &
         "      , QOH         = 0                                                   " + &
         "   FROM DO    H                                                           " + &
         "      , DODET D                                                           " + &
         "  WHERE CONVERT(CHAR(10),H.ISSUE_DATE,111) BETWEEN " + as_from + " AND " + as_to + &
         "    AND H.DO_NO            = D.DO_NO                                      " + &
         "    AND H.DO_CASE         IN ('A', 'B', 'C')                              " + &
         "    AND D.LOC_NO           = " + as_loc + "                               " + &
         "  GROUP BY D.ITEM_NO, D.QA                                                " + &
         "                                                                          " + &
         " INSERT INTO " + as_table + "                                             " + &
         " SELECT ITEM_NO     = D.SRC_ITEM                                          " + &
         "      , QA          = D.SRC_QA                                            " + &
         "      , M_IQTY      = 0                                                   " + &
         "      , A_IQTY      = 0                                                   " + &
         "      , V_IQTY      = 0                                                   " + &
         "      , R_IQTY      = 0                                                   " + &
         "      , N_IQTY      = 0                                                   " + &
         "      , W_IQTY      = 0                                                   " + &
         "      , I_IQTY      = 0                                                   " + &
         "      , D_OQTY      = 0                                                   " + &
         "      , A_OQTY      = SUM(ISNULL(D.SRC_QTY, 0)) /*대체출고*/              " + &
         "      , V_OQTY      = 0                                                   " + &
         "      , S_OQTY      = 0                                                   " + &
         "      , P_OQTY      = 0                                                   " + &
         "      , W_OQTY      = 0                                                   " + &
         "      , U_OQTY      = 0                                                   " + &
         "      , J_OQTY      = 0                                                   " + &
         "      , QOH         = 0                                                   " + &
         "   FROM ITEMALTER D                                                       " + &
         "  WHERE CONVERT(CHAR(10),D.ALTER_DATE,111) BETWEEN " + as_from + " AND " + as_to + &
         "    AND D.SRC_LOC          = " + as_loc + "                               " + &
         "    AND D.ISSUE_FLAG       = 'Y'                                          " + &
         "  GROUP BY D.SRC_ITEM, D.SRC_QA                                           " + &
         "                                                                          " + &
         " INSERT INTO " + as_table + "                                             " + &
         " SELECT ITEM_NO     = D.ITEM_NO                                           " + &
         "      , QA          = D.QA                                                " + &
         "      , M_IQTY      = 0                                                   " + &
         "      , A_IQTY      = 0                                                   " + &
         "      , V_IQTY      = 0                                                   " + &
         "      , R_IQTY      = 0                                                   " + &
         "      , N_IQTY      = 0                                                   " + &
         "      , W_IQTY      = 0                                                   " + &
         "      , I_IQTY      = 0                                                   " + &
         "      , D_OQTY      = 0                                                   " + &
         "      , A_OQTY      = 0                                                   " + &
         "      , V_OQTY      = SUM(ISNULL(D.RLSE_QTY, 0)) /*저장소이동(출고)*/     " + &
         "      , S_OQTY      = 0                                                   " + &
         "      , P_OQTY      = 0                                                   " + &
         "      , W_OQTY      = 0                                                   " + &
         "      , U_OQTY      = 0                                                   " + &
         "      , J_OQTY      = 0                                                   " + &
         "      , QOH         = 0                                                   " + &
         "   FROM ASK_HEAD H                                                        " + &
         "      , ASK_DET  D                                                        " + &
         "  WHERE H.ASK_NO          = D.ASK_NO                                      " + &
         "    AND CONVERT(CHAR(10),D.RLSE_DATE,111) BETWEEN " + as_from + " AND " + as_to + &
         "    AND D.LOC_NO          = " + as_loc + "                                " + &
         "  GROUP BY D.ITEM_NO, D.QA                                                " + &
         "                                                                          " + &
         " INSERT INTO " + as_table + "                                             " + &
         " SELECT ITEM_NO      = D.ITEM_NO                                          " + &
         "      , QA           = D.QA                                               " + &
         "      , M_IQTY       = 0                                                  " + &
         "      , A_IQTY       = 0                                                  " + &
         "      , V_IQTY       = 0                                                  " + &
         "      , R_IQTY       = 0                                                  " + &
         "      , N_IQTY       = 0                                                  " + &
         "      , W_IQTY       = 0                                                  " + &
         "      , I_IQTY       = 0                                                  " + &
         "      , D_OQTY       = 0                                                  " + &
         "      , A_OQTY       = 0                                                  " + &
         "      , V_OQTY       = 0                                                  " + &
         "      , S_OQTY       = SUM(ISNULL(D.ISSUE_QTY, 0)) /*샘플(출고)*/         " + &
         "      , P_OQTY       = 0                                                  " + &
         "      , W_OQTY       = 0                                                  " + &
         "      , U_OQTY       = 0                                                  " + &
         "      , J_OQTY       = 0                                                  " + &
         "      , QOH          = 0                                                  " + &
         "   FROM SAMP    H                                                         " + &
         "      , SAMPDET D                                                         " + &
         "  WHERE H.SAMP_NO          = D.SAMP_NO                                    " + &
         "    AND CONVERT(CHAR(10),H.ORDER_DATE,111) BETWEEN " + as_from + " AND " + as_to + &
         "    AND D.LOC_NO           = " + as_loc + "                               " + &
         "  GROUP BY D.ITEM_NO, D.QA                                                " + &
         "                                                                          " + &
         " INSERT INTO " + as_table + "                                             " + &
         " SELECT ITEM_NO      = D.ITEM_NO                                          " + &
         "      , QA           = D.QA                                               " + &
         "      , M_IQTY       = 0                                                  " + &
         "      , A_IQTY       = 0                                                  " + &
         "      , V_IQTY       = 0                                                  " + &
         "      , R_IQTY       = 0                                                  " + &
         "      , N_IQTY       = 0                                                  " + &
         "      , W_IQTY       = 0                                                  " + &
         "      , I_IQTY       = 0                                                  " + &
         "      , D_OQTY       = 0                                                  " + &
         "      , A_OQTY       = 0                                                  " + &
         "      , V_OQTY       = 0                                                  " + &
         "      , S_OQTY       = 0                                                  " + &
         "      , P_OQTY       = SUM(ISNULL(D.QTY, 0)) /*폐기*/                     " + &
         "      , W_OQTY       = 0                                                  " + &
         "      , U_OQTY       = 0                                                  " + &
         "      , J_OQTY       = 0                                                  " + &
         "      , QOH          = 0                                                  " + &
         "   FROM ITEMABAN    H                                                     " + &
         "      , ITEMABANDET D                                                     " + &
         "  WHERE CONVERT(CHAR(10),H.ABAN_DATE,111) BETWEEN " + as_from + " AND " + as_to + &
         "    AND H.LOC_NO          = " + as_loc + "                                " + &
         "    AND H.ABAN_NO         = D.ABAN_NO                                     " + &
         "  GROUP BY D.ITEM_NO, D.QA                                                " + &
         "                                                                          " + &
         " INSERT INTO " + as_table + "                                             " + &
         " SELECT ITEM_NO      = D.COMPONENT                                        " + &
         "      , QA           = D.COMPONENT_QA                                     " + &
         "      , M_IQTY       = 0                                                  " + &
         "      , A_IQTY       = 0                                                  " + &
         "      , V_IQTY       = 0                                                  " + &
         "      , R_IQTY       = 0                                                  " + &
         "      , N_IQTY       = 0                                                  " + &
         "      , W_IQTY       = 0                                                  " + &
         "      , I_IQTY       = 0                                                  " + &
         "      , D_OQTY       = 0                                                  " + &
         "      , A_OQTY       = 0                                                  " + &
         "      , V_OQTY       = 0                                                  " + &
         "      , S_OQTY       = 0                                                  " + &
         "      , P_OQTY       = 0                                                  " + &
         "      , W_OQTY       = SUM(ISNULL(D.ISSUE_QTY, 0)) /*가공출고*/           " + &
         "      , U_OQTY       = 0                                                  " + &
         "      , J_OQTY       = 0                                                  " + &
         "      , QOH          = 0                                                  " + &
         "   FROM SUDODET D                                                         " + &
         "  WHERE CONVERT(CHAR(10),D.ISSUE_DATE,111) BETWEEN " + as_from + " AND " + as_to + &
         "    AND D.ISSUE_LOC        = " + as_loc + "                               " + &
         "  GROUP BY D.COMPONENT, D.COMPONENT_QA                                    " + &
         "                                                                          " + &
         " INSERT INTO " + as_table + "                                             " + &
         " SELECT ITEM_NO      = D.ITEM_NO                                          " + &
         "      , QA           = D.QA                                               " + &
         "      , M_IQTY       = 0                                                  " + &
         "      , A_IQTY       = 0                                                  " + &
         "      , V_IQTY       = 0                                                  " + &
         "      , R_IQTY       = 0                                                  " + &
         "      , N_IQTY       = 0                                                  " + &
         "      , W_IQTY       = 0                                                  " + &
         "      , I_IQTY       = 0                                                  " + &
         "      , D_OQTY       = 0                                                  " + &
         "      , A_OQTY       = 0                                                  " + &
         "      , V_OQTY       = 0                                                  " + &
         "      , S_OQTY       = 0                                                  " + &
         "      , P_OQTY       = 0                                                  " + &
         "      , W_OQTY       = 0                                                  " + &
         "      , U_OQTY       = SUM(ISNULL(D.USE_QTY, 0)) /*작업일보사용*/         " + &
         "      , J_OQTY       = 0                                                  " + &
         "      , QOH          = 0                                                  " + &
         "   FROM SFCUSE D                                                          " + &
         "      , ITEM   I                                                          " + &
         "  WHERE CONVERT(CHAR(10),D.USE_DATE,111) BETWEEN " + as_from + " AND " + as_to + &
         "    AND D.LOC_NO         = " + as_loc + "                                 " + &
         "    AND D.ITEM_NO        = I.ITEM_NO                                      " + &
         "    AND D.QA             = I.QA                                           " + &
         "    /*AND I.SAVE_STOCK     = 'Y'*/                                        " + &
         "  GROUP BY D.ITEM_NO, D.QA                                                " + &
         "                                                                          " + &
         " INSERT INTO " + as_table + "                                             " + &
         " SELECT ITEM_NO      = D.ASSY_ITEM                                        " + &
         "      , QA           = D.ASSY_QA                                          " + &
         "      , M_IQTY       = 0                                                  " + &
         "      , A_IQTY       = 0                                                  " + &
         "      , V_IQTY       = 0                                                  " + &
         "      , R_IQTY       = 0                                                  " + &
         "      , N_IQTY       = 0                                                  " + &
         "      , W_IQTY       = 0                                                  " + &
         "      , I_IQTY       = 0                                                  " + &
         "      , D_OQTY       = 0                                                  " + &
         "      , A_OQTY       = 0                                                  " + &
         "      , V_OQTY       = 0                                                  " + &
         "      , S_OQTY       = 0                                                  " + &
         "      , P_OQTY       = 0                                                  " + &
         "      , W_OQTY       = 0                                                  " + &
         "      , U_OQTY       = 0                                                  " + &
         "      , J_OQTY       = SUM(ISNULL(D.OUT_QTY, 0)) /*(재고생산)출고*/       " + &
         "      , QOH          = 0                                                  " + &
         "   FROM JAJAESUDO D                                                       " + &
         "  WHERE CONVERT(CHAR(10),D.ORDER_DT,111)  BETWEEN " + as_from + " AND " + as_to + &
         "    AND D.ISSUE_LOC       = " + as_loc + "                               " + &
         "  GROUP BY D.ASSY_ITEM, D.ASSY_QA                                         " + &
         "                                                                          " + &
         " INSERT INTO " + as_table + "                                             " + &
         " SELECT ITEM_NO      = D.ITEM_NO                                          " + &
         "      , QA           = D.QA                                               " + &
         "      , M_IQTY       = 0                                                  " + &
         "      , A_IQTY       = 0                                                  " + &
         "      , V_IQTY       = 0                                                  " + &
         "      , R_IQTY       = 0                                                  " + &
         "      , N_IQTY       = 0                                                  " + &
         "      , W_IQTY       = 0                                                  " + &
         "      , I_IQTY       = 0                                                  " + &
         "      , D_OQTY       = 0                                                  " + &
         "      , A_OQTY       = 0                                                  " + &
         "      , V_OQTY       = 0                                                  " + &
         "      , S_OQTY       = 0                                                  " + &
         "      , P_OQTY       = 0                                                  " + &
         "      , W_OQTY       = 0                                                  " + &
         "      , U_OQTY       = 0                                                  " + &
         "      , J_OQTY       = 0                                                  " + &
         "      , QOH          = ISNULL(D.QOH, 0) /*현재고*/                        " + &
         "   FROM ITEMLOC D                                                         " + &
         "      , ITEM    I                                                         " + &
         "  WHERE D.LOC_NO     = " + as_loc + "                                     " + &
         "    AND D.ITEM_NO    = I.ITEM_NO                                          " + &
         "    AND D.QA         = I.QA                                               " + &
         "    /*AND I.SAVE_STOCK = 'Y'*/                                            "
               
SQLCA.AutoCommit = true         
Execute immediate :ls_sql;
if SQLCA.SQLDBCode < 0 THEN
   ROLLBACK USING SQLCA;
   MessageBox('안내', SQLCA.SQLErrText)
   return false
end if

SQLCA.AutoCommit = false


return true

end function

on w_whitemret_w.create
int iCurrent
call super::create
this.tab_1=create tab_1
this.dw_area=create dw_area
this.dw_3=create dw_3
this.st_6=create st_6
this.st_7=create st_7
this.dw_12=create dw_12
this.pb_2=create pb_2
this.dw_14=create dw_14
this.cbx_item=create cbx_item
this.dw_16=create dw_16
this.cb_7=create cb_7
this.cb_6=create cb_6
this.cb_5=create cb_5
this.cb_4=create cb_4
this.sle_value=create sle_value
this.ddlb_op=create ddlb_op
this.st_15=create st_15
this.ddlb_fld=create ddlb_fld
this.ddlb_dwtitles=create ddlb_dwtitles
this.st_14=create st_14
this.dw_19=create dw_19
this.gb_4=create gb_4
iCurrent=UpperBound(this.Control)
this.Control[iCurrent+1]=this.tab_1
this.Control[iCurrent+2]=this.dw_area
this.Control[iCurrent+3]=this.dw_3
this.Control[iCurrent+4]=this.st_6
this.Control[iCurrent+5]=this.st_7
this.Control[iCurrent+6]=this.dw_12
this.Control[iCurrent+7]=this.pb_2
this.Control[iCurrent+8]=this.dw_14
this.Control[iCurrent+9]=this.cbx_item
this.Control[iCurrent+10]=this.dw_16
this.Control[iCurrent+11]=this.cb_7
this.Control[iCurrent+12]=this.cb_6
this.Control[iCurrent+13]=this.cb_5
this.Control[iCurrent+14]=this.cb_4
this.Control[iCurrent+15]=this.sle_value
this.Control[iCurrent+16]=this.ddlb_op
this.Control[iCurrent+17]=this.st_15
this.Control[iCurrent+18]=this.ddlb_fld
this.Control[iCurrent+19]=this.ddlb_dwtitles
this.Control[iCurrent+20]=this.st_14
this.Control[iCurrent+21]=this.dw_19
this.Control[iCurrent+22]=this.gb_4
end on

on w_whitemret_w.destroy
call super::destroy
destroy(this.tab_1)
destroy(this.dw_area)
destroy(this.dw_3)
destroy(this.st_6)
destroy(this.st_7)
destroy(this.dw_12)
destroy(this.pb_2)
destroy(this.dw_14)
destroy(this.cbx_item)
destroy(this.dw_16)
destroy(this.cb_7)
destroy(this.cb_6)
destroy(this.cb_5)
destroy(this.cb_4)
destroy(this.sle_value)
destroy(this.ddlb_op)
destroy(this.st_15)
destroy(this.ddlb_fld)
destroy(this.ddlb_dwtitles)
destroy(this.st_14)
destroy(this.dw_19)
destroy(this.gb_4)
end on

event open;call super::open;//==GF_USEPROGRAM(프로그램 사용현황)===========================================================
GF_USEPROGRAM( gs_userid, THIS.ClassName(), "O", string(gf_today(),'yyyy/mm/dd'), THIS.Title )
//=============================================================================================

ddlb_fld.reset()
ddlb_dwtitles.reset()
ddlb_dwtitles.visible = false

dw3  = dw_3
dw4  = tab_1.tabpage_1.dw_4
dw5  = tab_1.tabpage_2.dw_5
dw6  = tab_1.tabpage_2.dw_6
dw7  = tab_1.tabpage_4.dw_7
dw10 = tab_1.tabpage_4.dw_10
dw15 = tab_1.tabpage_4.dw_15
dw8  = tab_1.tabpage_3.dw_8
dw9  = tab_1.tabpage_3.dw_9
dw11 = tab_1.tabpage_5.dw_11
dw13 = tab_1.tabpage_6.dw_13
dw17 = tab_1.tabpage_2.dw_17
dw18 = tab_1.tabpage_2.dw_18
dw19 = dw_19

dw3.settransobject(sqlca)
dw4.settransobject(sqlca)
dw5.settransobject(sqlca)
dw6.settransobject(sqlca)
dw7.settransobject(sqlca)
dw9.settransobject(sqlca)
dw10.settransobject(sqlca)
dw11.settransobject(sqlca)
dw13.settransobject(sqlca)
dw15.settransobject(sqlca)
dw_16.settransobject(sqlca)
dw17.settransobject(sqlca)
dw18.settransobject(sqlca)
dw19.settransobject(sqlca)

dw_2.visible  = false
dw_12.visible = false
dw_14.visible = false
dw_16.visible = false
dw5.visible   = false	// 생산계획 출력화면
dw18.visible  = false

is_sort = dw17.describe("datawindow.table.sort")	// 기본SORT값

dw11.ShareData(dw_12)
dw13.ShareData(dw_14)

tab_1.tabpage_1.em_1.text = string(today(), 'yyyy/mm/dd')
tab_1.tabpage_2.em_2.text = string(today(), 'yyyy/mm/dd')
tab_1.tabpage_3.em_4.text = string(today(), 'yyyy/mm/dd')
tab_1.tabpage_3.em_5.text = string(today(), 'yyyy/mm/dd')
tab_1.tabpage_4.em_3.text = string(today(), 'yyyy/mm/01')
tab_1.tabpage_4.em_6.text = string(today(), 'yyyy/mm/dd')
tab_1.tabpage_6.em_8.text = string(today(), 'yyyy/mm/dd')
tab_1.tabpage_6.em_9.text = string(today(), 'yyyy/mm/dd')

dw_1.insertrow(1)
SELECT min(loc_no) INTO :is_loc FROM incounu WHERE user_id = :gs_userid;

dw_1.object.loc_no[1] = "WS00000000" // 기본값을 변경 is_loc
dw_1.accepttext()

// 담당자
dw3.insertrow(1)
dw3.getchild('user_id',idwc_user)
idwc_user.settransobject(sqlca)
if idwc_user.find( "user_id = '" + gs_userid + "'", 1, idwc_user.rowcount() ) > 0 then
else
	idwc_user.insertrow(1)
	idwc_user.setitem(1,'user_id',gs_userid)
	idwc_user.setitem(1,'user_name',gs_username)
	idwc_user.accepttext()
end if
dw3.setitem(1,'user_id',gs_userid)

// 작업장
dw6.insertrow(1)
dw6.getchild('wc_no',idwc_wc)
idwc_wc.settransobject(sqlca)
idwc_wc.insertrow(1)
idwc_wc.setitem(1,'work_no','%')
idwc_wc.setitem(1,'work_name','전체')
idwc_wc.accepttext()
is_wc = "%"
dw6.object.wc_no[1] = is_wc

//if gs_userid = '1999010s' then
//	dw_area.settransobject(sqlca)
//	dw_area.insertrow(1)
//	dw_area.getchild('area',idwc_area)
//	idwc_area.settransobject(sqlca)
//	idwc_area.insertrow(1)
//	idwc_area.setitem(1,'area_no','%')
//	idwc_area.setitem(1,'area_name','전체')
//	idwc_area.accepttext()
//	dw_area.object.area[1] = '%'
//else
	dw_area.settransobject(sqlca)
	dw_area.insertrow(0)  
	dw_area.object.area[1] = "S0001"	// 기본값을 변경	gs_area
	dw_area.accepttext()

	//pb_retrieve.triggerevent(clicked!)
//end if

tab_1.SelectedTab = 2 // 생산계획

end event

event resize;call super::resize;//
long  ll_width, ll_height

this.hide()

gb_4.width   = newwidth  - (gb_4.x * 2)

tab_1.width  = newwidth  - (gb_4.x * 2)
tab_1.height = newheight - tab_1.y - gb_4.x

ll_width     = tab_1.tabpage_1.width
ll_height    = tab_1.tabpage_1.height

tab_1.tabpage_1.dw_4.width   = ll_width
tab_1.tabpage_1.dw_4.height  = ll_height - tab_1.tabpage_1.dw_4.y

tab_1.tabpage_2.dw_17.width  = ll_width
tab_1.tabpage_2.dw_17.height = ll_height - tab_1.tabpage_2.dw_17.y
tab_1.tabpage_2.dw_5.x       = tab_1.tabpage_2.dw_17.x
tab_1.tabpage_2.dw_5.y       = tab_1.tabpage_2.dw_17.y
tab_1.tabpage_2.dw_5.width   = tab_1.tabpage_2.dw_17.width
tab_1.tabpage_2.dw_5.height  = tab_1.tabpage_2.dw_17.height
tab_1.tabpage_2.dw_18.x      = tab_1.tabpage_2.dw_17.x
tab_1.tabpage_2.dw_18.y      = tab_1.tabpage_2.dw_17.y
tab_1.tabpage_2.dw_18.width  = tab_1.tabpage_2.dw_17.width
tab_1.tabpage_2.dw_18.height = tab_1.tabpage_2.dw_17.height

tab_1.tabpage_3.dw_8.height  = ll_height - tab_1.tabpage_3.dw_8.y
tab_1.tabpage_3.st_name.width= ll_width  - tab_1.tabpage_3.st_name.x
tab_1.tabpage_3.dw_9.width   = ll_width  - tab_1.tabpage_3.dw_9.x
tab_1.tabpage_3.dw_9.height  = ll_height - tab_1.tabpage_3.dw_9.y

tab_1.tabpage_4.dw_10.width  = ll_width
tab_1.tabpage_4.dw_10.height = ll_height - tab_1.tabpage_4.dw_10.y
tab_1.tabpage_4.dw_7.x       = tab_1.tabpage_4.dw_10.x
tab_1.tabpage_4.dw_7.y       = tab_1.tabpage_4.dw_10.y
tab_1.tabpage_4.dw_7.width   = tab_1.tabpage_4.dw_10.width
tab_1.tabpage_4.dw_7.height  = tab_1.tabpage_4.dw_10.height
tab_1.tabpage_4.dw_15.x      = tab_1.tabpage_4.dw_10.x
tab_1.tabpage_4.dw_15.y      = tab_1.tabpage_4.dw_10.y
tab_1.tabpage_4.dw_15.width  = tab_1.tabpage_4.dw_10.width
tab_1.tabpage_4.dw_15.height = tab_1.tabpage_4.dw_10.height

tab_1.tabpage_5.dw_11.width  = ll_width
tab_1.tabpage_5.dw_11.height = ll_height - tab_1.tabpage_5.dw_11.y

tab_1.tabpage_6.dw_13.width  = ll_width
tab_1.tabpage_6.dw_13.height = ll_height - tab_1.tabpage_6.dw_13.y

dw_16.x      = (tab_1.width - 3300) / 2
dw_16.y      = (tab_1.height / 2)
dw_16.width  = 3300
dw_16.height = 1000

end event

