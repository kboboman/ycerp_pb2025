type cb_17 from commandbutton within w_mpwork_m1
boolean visible = false
integer x = 3657
integer y = 44
integer width = 773
integer height = 92
integer taborder = 30
boolean bringtotop = true
integer textsize = -10
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
boolean enabled = false
string text = "YSP->화성저장소 이동"
end type

event clicked;datetime ldt_date, ldt_sfcdatetime, ldt_today
string   ls_wc,   ls_old_time, ls_loc,   ls_plan,  ls_item, ls_qa,   ls_assy, ls_assyqa, ls_type
string   ls_sale, ls_suju,     ls_like1, ls_like2, ls_coil, ls_flag, ls_etc,  ls_rout
string   ls_comp, ls_compqa,   ls_uom,   ls_area,  ls_chk,  ls_sqlerrtext
string   ls_sfcday_key
long     ll_rowcount, ll_count, ll_row,  ll_chkcount, ll_cnt
int      li_division, li_seq,   li_operation
real     lr_makeqty,  lr_orderqty, lr_solqty, lr_planqty, lr_rlseqty

long ll_seq, l_count
string ls_tempno

dec{1}   ld_wid
dec{2}   ld_length

dwItemStatus l_status

dw_2.accepttext()
dw4.accepttext()

ls_wc = trim(dw_2.object.wc_no[1])
ls_sfcday_key    = trim(dw4.object.sfcday_key[1])
	
ll_rowcount = dw4.rowcount()

l_count = 0;

SELECT count(*)
	 into :l_count
from etcout		 
where qty <> 0
 and rem like :ls_sfcday_key+'%';	
 
if l_count = 0 then 

		for ll_row = 1 to ll_rowcount	
			
			ldt_sfcdatetime = dw4.object.sfc_date[ll_row]
			ldt_date   = datetime(date(string(ldt_sfcdatetime,'yyyy/mm/dd')))
			ldt_today   = datetime(date(string(wf_today(),'yyyy/mm/dd')))
			
			ls_loc     = trim(dw4.object.loc_no[ll_row])
			ls_plan    = trim(dw4.object.order_no[ll_row])
			ls_item    = trim(dw4.object.item_no[ll_row])
			ls_qa      = trim(dw4.object.qa[ll_row])
			ls_assy    = trim(dw4.object.assembly[ll_row])
			ls_assyqa  = trim(dw4.object.assembly_qa[ll_row])
			lr_makeqty = dw4.object.make_qty[ll_row] 
			lr_planqty = dw4.object.plan_qty[ll_row] 
			ls_type    = trim(dw4.object.type[ll_row])	
			ls_sfcday_key    = trim(dw4.object.sfcday_key[ll_row])
		
		
			if ls_type = 'C' then 
				ls_type = 'E'  // 완료
			else
				ls_type = 'Y'  // 가능
			end if
			
//			l_count = 0;
//			
//			SELECT count(*)
//				 into :l_count
//			from etcout		 
//			where qty <> 0
//			 and rem like :ls_sfcday_key+'%';				
		
//			if l_count = 0 then
			
				SELECT isnull(IDENT_CURRENT ('etcout'), 0) + 1
				INTO :ll_seq FROM dual;	 
				
//				ls_tempno = left(gs_area, 1) + 'T' + string(ldt_sfcdatetime, 'yyyymmdd') + "-" + right( "000" + trim(string(ll_seq)),3)
				ls_tempno = string(dw_1.object.etcout_date[1], 'yymmdd') + "-" + RightA( "0000000" + trim(string(ll_seq)),7)
			
				INSERT INTO etcout ( etcout_no, etcout_date, loc_no, item_no, qa,      qty, 			  etc_kind,  user_id,      user_date,    rem )
								  VALUES (:ls_tempno, :ldt_today, :ls_loc,  :ls_assy, :ls_assyqa, :lr_makeqty,           '00', :gs_userid,   :ldt_today,  :ls_sfcday_key+' YSP->화성이동');
				
				if sqlca.sqlcode < 0 then
					ls_sqlerrtext = string(sqlca.sqlerrtext)
					ROLLBACK;
					MessageBox('오류1',string(ll_row)+ ' 줄에서 [pb_save][etcout] insert중 DB오류가 발생했습니다.~r~n'+ ls_sqlerrtext, exclamation!)
					RETURN 0
				end if	
			
				
				INSERT INTO etcout ( etcout_no, etcout_date, loc_no,                   item_no, qa,                qty, 	 etc_kind,  user_id,      user_date,    rem )
								  VALUES (:ls_tempno, :ldt_today,   'WS00000008',  :ls_assy, :ls_assyqa, :lr_makeqty,           '99', :gs_userid,   :ldt_today,  :ls_sfcday_key+' YSP->화성이동');
				
				if sqlca.sqlcode < 0 then
					ls_sqlerrtext = string(sqlca.sqlerrtext)
					ROLLBACK;
					MessageBox('오류2',string(ll_row)+ ' 줄에서 [pb_save][etcout] insert중 DB오류가 발생했습니다.~r~n'+ ls_sqlerrtext, exclamation!)
					RETURN 0
				end if	
				
				
				////////////////////////////////////////////////////////////
				// 재고수불: IT
				////////////////////////////////////////////////////////////
				
				INSERT INTO inaudit ( inaudit_time, inaudit_date, inaudit_item, qa, order_no, rcpt_qty, issue_qty, loc_no, serial_id,
											inaudit_type, cost, destination, rem, user_id )
				VALUES (getdate(), :ldt_date, :ls_assy, :ls_assyqa, :ls_plan, 0, :lr_makeqty, :ls_loc, :ls_sfcday_key, 'IT', 0, :ls_wc, "YSP->화성이동", :gs_userid);
				
				if sqlca.sqlcode < 0 then
					ls_sqlerrtext = string(sqlca.sqlerrtext)
					ROLLBACK;
					MessageBox('오류3',string(ll_row)+ ' 줄에서 [pb_save][inaudit] insert중 DB오류가 발생했습니다.~r~n'+ ls_sqlerrtext, exclamation!)
					RETURN 0
				end if
				
				////////////////////////////////////////////////////////////
				// 재고수불: RT
				////////////////////////////////////////////////////////////	
				INSERT INTO inaudit ( inaudit_time, inaudit_date, inaudit_item, qa, order_no, rcpt_qty, issue_qty, loc_no, serial_id,
											inaudit_type, cost, destination, rem, user_id )
				VALUES (getdate(), :ldt_date, :ls_assy, :ls_assyqa, :ls_plan, :lr_makeqty, 0, 'WS00000008', :ls_sfcday_key, 'RT', 0, :ls_loc, "YSP->화성이동", :gs_userid);
				
				if sqlca.sqlcode < 0 then
					ls_sqlerrtext = string(sqlca.sqlerrtext)
					ROLLBACK;
					MessageBox('오류4',string(ll_row)+ ' 줄에서 [pb_save][inaudit] insert중 DB오류가 발생했습니다.~r~n'+ ls_sqlerrtext, exclamation!)
					RETURN 0
				end if			
				
//			end if
		
		next
		
		commit;
		
		MessageBox('알림', '저장소를 이동을 완료하였습니다.')
else
		MessageBox('알림', '이미 저장소 이동을 하였습니다.')
end if

cb_17.enabled = false
cb_23.enabled = true

end event

