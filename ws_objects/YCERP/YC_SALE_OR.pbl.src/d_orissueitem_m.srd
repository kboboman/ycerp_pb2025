$PBExportHeader$d_orissueitem_m.srd
$PBExportComments$이슈상품 수신자
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=88 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=long update=yes updatewhereclause=yes key=yes identity=yes name=id dbname="id" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(10) update=yes updatewhereclause=yes name=user_id dbname="user_id" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(255) update=yes updatewhereclause=yes name=bigo dbname="bigo" )
 column=(type=datetime update=yes updatewhereclause=yes name=sys_date dbname="sys_date" )
 retrieve="  SELECT id        = i.id
       , item_no   = i.item_no
       , qa        = i.qa
       , item_name = g.item_name
       , user_id   = i.user_id
       , user_name = l.user_name
       , bigo      = i.bigo
       , sys_date  = i.sys_date
    FROM issue_item I
         LEFT OUTER JOIN login     L with (nolock) ON i.user_id = l.user_id AND l.use_flag = 'Y'
         LEFT OUTER JOIN groupitem G with (nolock) ON i.item_no = g.item_no AND g.use_flag = 'Y'
         LEFT OUTER JOIN (
              SELECT item_no, qa FROM saledet with (nolock)
               WHERE order_no = :as_orderno
         ) S ON i.item_no = s.item_no AND i.qa = s.qa
   WHERE ((:as_orderno <> '%' AND i.item_no  IN (SELECT item_no FROM saledet WHERE order_no = :as_orderno)) OR
          (:as_orderno  = '%' AND i.item_no  LIKE :as_orderno)
         )
" update="issue_item" updatewhere=0 updatekeyinplace=no arguments=(("as_orderno", string)) )
