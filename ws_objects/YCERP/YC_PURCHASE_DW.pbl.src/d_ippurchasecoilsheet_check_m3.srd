table(column=(type=char(12) update=yes updatewhereclause=yes key=yes name=order_no dbname="order_coilsheet_check_det.order_no" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=round dbname="order_coilsheet_check_det.round" )
 column=(type=char(6) update=yes updatewhereclause=yes key=yes name=order_seq dbname="order_coilsheet_check_det.order_seq" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=check_seq dbname="order_coilsheet_check_det.check_seq" )
