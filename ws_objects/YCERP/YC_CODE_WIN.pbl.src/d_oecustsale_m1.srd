 column=(type=decimal(0) updatewhereclause=yes name=cust_sale_kind_amt3 dbname="cust_sale.kind_amt3" )
 column=(type=decimal(0) updatewhereclause=yes name=cust_sale_kind_qty4 dbname="cust_sale.kind_qty4" )
 column=(type=decimal(0) updatewhereclause=yes name=cust_sale_kind_amt4 dbname="cust_sale.kind_amt4" )
 column=(type=char(60) updatewhereclause=yes name=cust_sale_address dbname="cust_sale.address" )
 column=(type=char(40) updatewhereclause=yes name=cust_sale_rem dbname="cust_sale.rem" )
 retrieve="select  a.lot_no,
           a.yyyymm,
           a.salesman,
           b.user_name,
		a.cust_no,
           a.company_name,
           a.amt,
           a.project_name,
           a.kind_qty1,
           a.kind_amt1,
           a.kind_qty2,
           a.kind_amt2,
           a.kind_qty3,
           a.kind_amt3,          
           a.kind_qty4,
           a.kind_amt4,
           a.address,
           a.rem                    
from cust_sale a left outer join login b on a.salesman = b.user_id
where a.yyyymm like :as_yyyymm
" arguments=(("as_yyyymm", string)) )
