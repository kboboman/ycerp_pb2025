table(column=(type=number updatewhereclause=yes name=pri dbname="pri" )
 column=(type=char(20) updatewhereclause=yes name=order_no dbname="order_no" )
 column=(type=number updatewhereclause=yes name=order_seq dbname="order_seq" )
 column=(type=char(20) updatewhereclause=yes name=coil_no dbname="coil_no" )
 column=(type=char(20) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=number updatewhereclause=yes name=thin dbname="thin" )
 column=(type=number updatewhereclause=yes name=wid dbname="wid" )
 column=(type=number updatewhereclause=yes name=wlen dbname="wlen" )
 column=(type=number updatewhereclause=yes name=length dbname="length" )
 column=(type=number updatewhereclause=yes name=swid dbname="swid" )
 column=(type=number updatewhereclause=yes name=cnt dbname="cnt" )
 retrieve="  SELECT coilorder.order_no,   
         coilorderdet.coil_no,   
         coilorderdet.order_seq,   
         groupitem.item_name,   
         coilorderdet.wid,   
         coilsliting.seq,   
         wlen = coilmst.unit_qty * coilmst.qcnt,   
         thin = convert (decimal (3,2), substring(coilmst.qa,1,1) + ~".~" + substring(coilmst.qa, 2,2)),   
         swid = convert (decimal (5,1), substring(coilsliting.qa,5,4) + ~".~" + substring(coilsliting.qa, 10,1)),   
         coilmst.length,   
         coilsliting.cnt,   
         pri = 0  
    FROM coilmst,   
         coilorder,   
         coilorderdet,   
         coilsliting,   
         groupitem  
   WHERE ( coilorderdet.order_no = coilsliting.order_no ) and  
         ( coilorder.order_no = coilorderdet.coilorder_order ) and  
         ( coilorderdet.coil_no = coilmst.coil_no ) and  
         ( coilmst.item_no = groupitem.item_no ) and  
         ( coilorderdet.loc_no = coilmst.loc_no ) and  
         ( ( coilorderdet.proc_flag = 'M' ) AND  
         ( coilorder.wc_place = 'I' ) AND  
         ( coilorder.wc_no = :as_wc ) )    
" arguments=(("as_wc", string))  sort="pri A order_no A order_seq A coil_no A item_name A thin A wid A wlen A length A " )
