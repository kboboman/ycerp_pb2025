release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=char(15) updatewhereclause=yes name=icube_no dbname="customer.icube_no" )
 column=(type=char(4) updatewhereclause=yes key=yes name=cust_no dbname="customer.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=char(1) updatewhereclause=yes name=open_close dbname="customer.open_close" )
 retrieve="  SELECT customer.icube_no,
         customer.cust_no,   
         customer.cust_name,
         customer.open_close
    FROM customer   
   WHERE customer.icube_no  IS NOT NULL
     AND ( ( :as_open = 'O' and customer.open_close    = 'O' ) OR
           ( :as_open = '%' and customer.open_close LIKE '%' )
         )
     AND ( ( :as_salesman  = '%' and customer.salesman LIKE '%'          ) OR
           ( :as_salesman <> '%' and customer.salesman    = :as_salesman )           
         )

  UNION 
  SELECT '', '', '', ''
" update="customer" updatewhere=0 updatekeyinplace=no arguments=(("as_open", string),("as_salesman", string))  sort="cust_name A " )
