 column=(type=char(60) update=yes updatewhereclause=yes name=rem dbname="docar.rem" )
 column=(type=char(13) update=yes updatewhereclause=yes name=hp dbname="docar.hp" )
 column=(type=char(1) update=yes updatewhereclause=yes name=open_close dbname="docar.open_close" initial="O" values="사용	O/폐기	C/" )
