 retrieve="select area_code, 
		area_name,
		country_code,
          country_name
from car_area
where area_code = :as_area_code
and country_code <> '0000'" update="car_area" updatewhere=1 updatekeyinplace=no arguments=(("as_area_code", string))  sort="country_code A " )
