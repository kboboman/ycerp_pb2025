type dw_loc from datawindow within w_whitemlocqohmulti_w2
integer x = 2181
integer y = 8
integer width = 846
integer height = 84
integer taborder = 120
boolean bringtotop = true
string dataobject = "d_irlocno_s"
boolean border = false
boolean livescroll = true
end type

event itemchanged;//
string ls_locno, ls_item
long   ll_row

debugbreak()

ll_row   = dw2.getrow()
if isnull(row) or dw2.getrow() < 1 then return

this.accepttext()

ls_locno = data
ls_item  = dw2.object.item_no[ll_row]

is_loc   = ls_locno


//if is_loc = 'WS00000011' THEN
//	ls_locno =  'WS00000011'
//ELSE
//	ls_locno =  '%'
//END IF
//

choose case tab_1.selectedtab
	case 1
		dw3.reset()
		
		dw3.retrieve( ls_locno, ls_item )

	case 2
		tab_1.tabpage_2.cb_ret.postevent(clicked!)
end choose

end event

event losefocus;this.accepttext()

end event

