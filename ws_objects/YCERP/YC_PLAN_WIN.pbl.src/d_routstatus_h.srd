$PBExportHeader$d_routstatus_h.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=72 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(11) updatewhereclause=yes name=scene_code dbname="scene_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 retrieve="  SELECT DISTINCT cust_no   = s1.cust_no   
       , cust_name   = c.cust_name
       , scene_code  = s.scene_code
       , scene_desc  = s.scene_desc
    FROM saledet sd (nolock)
         LEFT OUTER JOIN sale       S1 (nolock) ON sd.order_no   = s1.order_no
         LEFT OUTER JOIN customer    C (nolock) ON s1.cust_no    = c.cust_no
         LEFT OUTER JOIN scene       S (nolock) ON s1.scene_code = s.scene_code 
         LEFT OUTER JOIN routtempnew R (nolock) ON sd.order_no   = r.sale_no AND sd.seq_no = r.seq_no
         LEFT OUTER JOIN wc         W1 (nolock) ON r.wc_no       = w1.work_no

   WHERE ( s1.tracking        = 'Y'          )
     AND ( sd.order_qty - sd.rlse_qty   > 0    )
     AND ((:as_work1  = 'Y' AND NOT ( w1.work_name = '' OR w1.work_name LIKE '성형%' OR w1.work_name LIKE '화성%' )) OR
          (:as_work1 <> 'Y' )
         )
" arguments=(("as_work1", string))  sort="cust_name A scene_desc A " )
