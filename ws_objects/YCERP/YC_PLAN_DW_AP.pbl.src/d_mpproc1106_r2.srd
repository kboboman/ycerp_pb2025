table(column=(type=char(14) updatewhereclause=yes name=order_no dbname="saledet.order_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="saledet.seq_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="saledet.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="saledet.qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="saledet.uom" )
 column=(type=decimal(2) updatewhereclause=yes name=order_qty dbname="saledet.order_qty" initial="0" )
 column=(type=decimal(4) updatewhereclause=yes name=price dbname="saledet.price" initial="0" )
 column=(type=decimal(2) updatewhereclause=yes name=acc_qty dbname="saledet.acc_qty" initial="0" )
 column=(type=char(1) updatewhereclause=yes name=saledet_text dbname="saledet.saledet_text" initial="N" )
 column=(type=datetime updatewhereclause=yes name=rlse_date dbname="saledet.rlse_date" )
 column=(type=decimal(2) updatewhereclause=yes name=rlse_qty dbname="saledet.rlse_qty" initial="0" )
 column=(type=char(50) updatewhereclause=yes name=rem dbname="saledet.rem" )
 column=(type=datetime updatewhereclause=yes name=plan_close dbname="saledet.plan_close" )
 column=(type=decimal(2) updatewhereclause=yes name=sol_qty dbname="saledet.sol_qty" initial="0" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_issue_qty dbname="saledet.issue_qty" initial="0" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_plan_qty dbname="saledet.plan_qty" initial="0" )
 column=(type=decimal(0) updatewhereclause=yes name=saledet_amt dbname="amt" )
 column=(type=char(4) updatewhereclause=yes name=color dbname="saledet.color" )
 column=(type=decimal(4) updatewhereclause=yes name=price_be dbname="saledet.price_be" initial="0" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_stock_qty dbname="saledet.stock_qty" )
 column=(type=char(10) updatewhereclause=yes name=customer_salesman dbname="customer.salesman" )
 column=(type=char(10) updatewhereclause=yes name=sale_login_id dbname="sale.login_id" )
 retrieve="  SELECT saledet.order_no   
       , saledet.seq_no   
       , saledet.item_no   
       , saledet.qa   
       , saledet.uom   
       , saledet.order_qty   
       , saledet.price   
       , saledet.acc_qty   
       , saledet.saledet_text   
       , saledet.rlse_date   
       , saledet.rlse_qty   
       , saledet.rem   
       , saledet.plan_close   
       , saledet.sol_qty   
       , saledet.issue_qty   
       , saledet.plan_qty   
       , amt    = 999999999999999    
       , saledet.color   
       , saledet.price_be   
       , groupitem.item_name   
       , saledet.stock_qty 
       , customer.salesman
       , sale.login_id  
    FROM saledet
         LEFT OUTER JOIN sale      ON saledet.order_no =  sale.order_no
         LEFT OUTER JOIN customer  ON sale.cust_no     = customer.cust_no
         LEFT OUTER JOIN groupitem ON saledet.item_no  = groupitem.item_no
   WHERE ( saledet.order_no = :as_order_no )
" arguments=(("as_order_no", string)) )
