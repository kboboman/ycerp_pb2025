detail(height=796 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes key=yes name=estimate_no dbname="estimate_head.estimate_no" )
 column=(type=datetime updatewhereclause=yes name=estimate_date dbname="estimate_head.estimate_date" )
 column=(type=char(1) updatewhereclause=yes name=esti_flag dbname="estimate_head.esti_flag" initial="N" values="완결	Y/미결	N/보류	B/" )
 column=(type=char(10) updatewhereclause=yes name=emp_no dbname="estimate_head.emp_no" )
 column=(type=decimal(4) updatewhereclause=yes name=esti_amount dbname="estimate_head.esti_amount" initial="0" )
 column=(type=decimal(4) updatewhereclause=yes name=esti_tax dbname="estimate_head.esti_tax" initial="0" )
 column=(type=decimal(4) updatewhereclause=yes name=esti_total dbname="estimate_head.esti_total" initial="0" )
 column=(type=char(60) updatewhereclause=yes name=rem dbname="estimate_head.rem" )
 column=(type=char(1) updatewhereclause=yes name=vat_flag dbname="estimate_head.vat_flag" initial="Y" values="	Y/	N" )
 column=(type=datetime updatewhereclause=yes name=input_date dbname="estimate_head.input_date" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="estimate_head.user_id" )
 column=(type=char(10) updatewhereclause=yes name=approve_team dbname="estimate_head.approve_team" )
 column=(type=char(10) updatewhereclause=yes name=approve_top dbname="estimate_head.approve_top" )
 column=(type=char(60) update=yes updatewhereclause=yes name=team_desc dbname="estimate_head.team_desc" )
 column=(type=char(60) update=yes updatewhereclause=yes name=top_desc dbname="estimate_head.top_desc" )
 column=(type=char(1) updatewhereclause=yes name=protect dbname="protect" initial="Y" )
 column=(type=char(30) updatewhereclause=yes name=basis_head_item_name dbname="basis_head.item_name" )
 column=(type=char(4) updatewhereclause=yes name=estimate_head_cust_no dbname="estimate_head.cust_no" )
 column=(type=char(11) updatewhereclause=yes name=estimate_head_scene_code dbname="estimate_head.scene_code" )
 column=(type=char(60) updatewhereclause=yes name=estimate_head_cust_name dbname="estimate_head.cust_name" )
 column=(type=char(60) updatewhereclause=yes name=estimate_head_scene_desc dbname="estimate_head.scene_desc" )
 column=(type=char(1) updatewhereclause=yes name=estimate_head_esti_case dbname="estimate_head.esti_case" values="단가견적	Y/단가견적	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=sale_succ dbname="estimate_head.sale_succ" values="수주성공	Y/수주성공	N" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"estimate_head~" )  TABLE(NAME=~"basis_head~" ) COLUMN(NAME=~"estimate_head.estimate_no~") COLUMN(NAME=~"estimate_head.estimate_date~") COLUMN(NAME=~"estimate_head.esti_flag~") COLUMN(NAME=~"estimate_head.emp_no~") COLUMN(NAME=~"estimate_head.esti_amount~") COLUMN(NAME=~"estimate_head.esti_tax~") COLUMN(NAME=~"estimate_head.esti_total~") COLUMN(NAME=~"estimate_head.rem~") COLUMN(NAME=~"estimate_head.vat_flag~") COLUMN(NAME=~"estimate_head.input_date~") COLUMN(NAME=~"estimate_head.user_id~") COLUMN(NAME=~"estimate_head.approve_team~") COLUMN(NAME=~"estimate_head.approve_top~") COLUMN(NAME=~"estimate_head.team_desc~") COLUMN(NAME=~"estimate_head.top_desc~") COMPUTE(NAME=~"protect = ''~") COLUMN(NAME=~"basis_head.item_name~") COLUMN(NAME=~"estimate_head.cust_no~") COLUMN(NAME=~"estimate_head.scene_code~") COLUMN(NAME=~"estimate_head.cust_name~") COLUMN(NAME=~"estimate_head.scene_desc~") COLUMN(NAME=~"estimate_head.esti_case~") COLUMN(NAME=~"estimate_head.sale_succ~")    JOIN (LEFT=~"estimate_head.system_no~"    OP =~"=~"RIGHT=~"basis_head.item_no~"    OUTER1 =~"estimate_head.system_no~" )WHERE(    EXP1 =~"estimate_head.estimate_no~"   OP =~"=~"    EXP2 =~":est_no~" ) ) ARG(NAME = ~"est_no~" TYPE = string) " update="estimate_head" updatewhere=0 updatekeyinplace=yes arguments=(("est_no", string)) )
