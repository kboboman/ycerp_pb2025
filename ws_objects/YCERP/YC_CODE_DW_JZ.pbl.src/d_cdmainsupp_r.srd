footer(height=1 color="536870912" )
detail(height=77 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="item.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="item.qa" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item.item_name" )
 column=(type=char(10) updatewhereclause=yes name=item_loc_no dbname="item.loc_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=supplier dbname="item.supplier" )
 column=(type=char(30) updatewhereclause=yes name=supp_supp_name dbname="supp.supp_name" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"item~" )  TABLE(NAME=~"supp~" ) COLUMN(NAME=~"item.item_no~") COLUMN(NAME=~"item.qa~") COLUMN(NAME=~"item.item_name~") COLUMN(NAME=~"item.loc_no~") COLUMN(NAME=~"item.supplier~") COLUMN(NAME=~"supp.supp_name~")    JOIN (LEFT=~"item.supplier~"    OP =~"=~"RIGHT=~"supp.supp_no~"    OUTER1 =~"item.supplier~" )) ORDER(NAME=~"item.item_no~" ASC=yes )  ORDER(NAME=~"item.qa~" ASC=yes ) " )
