 retrieve="SELECT chk           = 'N'
     , order_no      = a.order_no       
     , cust_no       = a.cust_no        
     , scene_code    = a.scene_code     
     , order_date    = a.order_date     
     , due_date      = a.due_date       
     , estimate_no   = a.estimate_no    
     , sale_flag     = a.sale_flag      
     , curr_code     = a.curr_code      
     , cust_po_no    = a.cust_po_no     
     , cust_po_date  = a.cust_po_date   
     , ship_flag     = a.ship_flag      
     , fob           = a.fob            
     , salesman      = a.salesman       
     , confirm_flag  = a.confirm_flag   
     , confirm_user  = a.confirm_user   
     , confirm_date  = a.confirm_date   

     , tax_sign      = a.tax_sign       
     , sale_tax      = a.sale_tax       
     , sale_amount   = a.sale_amount    
     , open_close    = a.open_close     
     , close_type    = a.close_type     
     , close_date    = a.close_date     
     , shipto_addr   = a.shipto_addr    
     , rem           = a.rem            
     , revision_no   = a.revision_no    
     , revision_date = a.revision_date  
     , input_date    = a.input_date     
     , login_id      = a.login_id       
     , tel_no        = a.tel_no         
     , ship_case     = a.ship_case      
     , rem1          = a.rem1           
     , rem2          = a.rem2           
     , plan_date     = a.plan_date      
     , shipamt_case  = a.shipamt_case   
     , area_no       = a.area_no        
     , ysp_confirm   = a.ysp_confirm    
     , ysp_qty       = a.ysp_qty        
     , color         = a.color          
     , type          = a.type           
     , class         = a.class          
     , ysp_qty2      = a.ysp_qty2       
     , jupsu_flag    = a.jupsu_flag     
     , jupsu_date    = a.jupsu_date     

     , order_no1     = b.order_no       
     , seq_no        = b.seq_no
     , erp_name      = g.item_name         
     , item_no       = b.item_no        
     , item_nm       = space(60)        
     , qa            = b.qa             
     , uom           = b.uom            
     , order_qty     = b.order_qty      
     , price         = b.price          
     , price_m       = 0
     , acc_qty       = b.acc_qty        
     , saledet_text  = b.saledet_text   
     , action        = b.action         
     , sol_qty       = b.sol_qty        
     , loc_no        = b.loc_no         
     , issue_qty     = b.issue_qty      
     , rlse_date     = b.rlse_date      
     , rlse_qty      = b.rlse_qty       
     , remdet        = b.rem            
     , plan_qty      = b.plan_qty       
     , plan_close    = b.plan_close     
     , colordet      = b.color          
     , price_be      = b.price_be       
     , do_rem        = b.do_rem         
     , stock_qty     = b.stock_qty      
     , stock_issue   = b.stock_issue    
     , stock_do      = b.stock_do       
     , price_last    = b.price_last     
     , danjung       = b.danjung        
     , jungrang      = b.jungrang 
     , chulgo_qty    = b.chulgo_qty      
     , err_text      = space(50)
  FROM shopdet B
       LEFT OUTER JOIN shop      A ON a.order_no = b.order_no
       LEFT OUTER JOIN groupitem G ON b.item_no  = g.item_no
 WHERE a.order_date between :as_sdate AND :as_edate

" arguments=(("as_sdate", string),("as_edate", string))  sort="order_no D seq_no A " )
