detail(height=68 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=user_id dbname="salehp.user_id" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="login.user_name" )
 column=(type=char(15) updatewhereclause=yes name=salehp_hp dbname="salehp.hp_no" )
 column=(type=char(255) updatewhereclause=yes name=phone_no dbname="phone_no" )
 retrieve="  SELECT a.user_id
       , b.user_name
       , a.hp_no
       ,	phone_no = replace(rtrim(a.hp_no),'-','')
    FROM SALEHP a
         LEFT OUTER JOIN LOGIN b ON a.user_id = b.user_id AND b.use_flag = 'Y'
   WHERE a.hp_no    LIKE '01%'
   ORDER BY b.user_name

" )
