			messagebox('오류1','select수행중 오류가 발생하였습니다.',exclamation!)
			return false
		end if
		if ls_flag = "M" then
			UPDATE coilorderdet SET proc_flag ="P"  // 외주발주중
			 WHERE order_no = :ls_product_no;
			if sqlca.sqlcode < 0 then
				rollback;
				messagebox('오류18','item수행중 오류가 발생하였습니다.',exclamation!)
				return false
			end if
				
