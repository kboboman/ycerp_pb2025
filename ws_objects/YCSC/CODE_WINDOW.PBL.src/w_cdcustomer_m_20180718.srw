	messagebox('확인', '권한이 없습니다. 전산실에 문의 하십시요.')
	return
end if

string ls_cust_no
long  ll_row

if messagebox("저장","저장하시겠습니까?",information!,okcancel!,1) = 2 then
	return
end if

ls_cust_no = tab_1.tabpage_4.st_2.text
