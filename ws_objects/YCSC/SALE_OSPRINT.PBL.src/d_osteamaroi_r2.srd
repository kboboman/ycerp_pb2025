$PBExportHeader$d_osteamaroi_r2.srd
$PBExportComments$국내판매부 팀별 매출실적집계(2005/05/25,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=yes )
header(height=520 color="536870912" )
summary(height=124 color="553648127" )
footer(height=0 color="536870912" )
detail(height=92 color="536870912" )
table(column=(type=char(1) updatewhereclause=yes name=team_group dbname="TEAM_GROUP" )
 column=(type=char(8) updatewhereclause=yes name=tgroup_nm dbname="TGROUP_NM" )
 column=(type=char(1) updatewhereclause=yes name=tteam dbname="TTEAM" )
 column=(type=char(10) updatewhereclause=yes name=tteam_nm dbname="TTEAM_NM" )
 column=(type=char(5) updatewhereclause=yes name=login_team_code dbname="TEAM_CODE" )
 column=(type=char(10) updatewhereclause=yes name=login_rank_no dbname="RANK_NO" )
 column=(type=char(30) updatewhereclause=yes name=team_team_name dbname="TEAM_NAME" )
 column=(type=char(13) updatewhereclause=yes name=login_user_name dbname="USER_NAME" )
 column=(type=char(20) updatewhereclause=yes name=login_rank dbname="RANK" )
 column=(type=long updatewhereclause=yes name=cyear dbname="CYEAR" )
 column=(type=long updatewhereclause=yes name=cmon dbname="CMON" )
 column=(type=decimal(6) updatewhereclause=yes name=pre_yinv dbname="PRE_YINV" )
 column=(type=decimal(6) updatewhereclause=yes name=cur_ayinv dbname="CUR_AYINV" )
 column=(type=char(1) updatewhereclause=yes name=tteam dbname="TTEAM" )
 column=(type=decimal(6) updatewhereclause=yes name=cur_amninv dbname="CUR_AMNINV" )
 column=(type=decimal(6) updatewhereclause=yes name=cur_inv dbname="CUR_INV" )
 column=(type=decimal(6) updatewhereclause=yes name=cur_aminv dbname="CUR_AMINV" )
 column=(type=decimal(6) updatewhereclause=yes name=cur_minv dbname="CUR_MINV" )
 column=(type=decimal(6) updatewhereclause=yes name=cur_amcoll dbname="CUR_AMCOLL" )
 column=(type=decimal(6) updatewhereclause=yes name=cur_mcoll dbname="CUR_MCOLL" )
 column=(type=decimal(0) updatewhereclause=yes name=last_day dbname="LAST_DAY" )
 column=(type=decimal(0) updatewhereclause=yes name=bm_jan dbname="BM_JAN" )
 column=(type=decimal(0) updatewhereclause=yes name=m_jan dbname="M_JAN" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="USER_ID" )
 column=(type=char(10) updatewhereclause=yes name=user_id2 dbname="USER_ID2" )
 column=(type=decimal(0) updatewhereclause=yes name=bsale_amt dbname="BSALE_AMT" )
 retrieve="
  SELECT TEAM_GROUP  = AA.TEAM_GROUP 
       , TGROUP_NM   = (CASE AA.TEAM_GROUP
                           WHEN '1'  THEN '영업본부'
                           WHEN '3'  THEN '영업관리'
                           ELSE           '기타' 
                        END)
       , TTEAM       = AA.TTEAM    
       , TTEAM_NM    = (CASE AA.TTEAM
                           WHEN '1'  THEN '영업 1본부'
                           WHEN '2'  THEN '영업 2본부'
                           WHEN '3'  THEN '영업 3본부'
                           WHEN '4'  THEN '시화+채권'
                           ELSE           '기타'
                        END)
       , TEAM_CODE   = AA.TEAM_CODE      
       , RANK_NO     = AA.RANK_NO        

       , TEAM_NAME   = AA.TEAM_NAME      
       , USER_NAME   = AA.USER_NAME      
       , RANK        = AA.RANK           
       , CYEAR       = AA.CYEAR          
       , CMON        = AA.CMON           
       , PRE_YINV    = AA.PRE_YINV       
       , CUR_AYINV   = AA.CUR_AYINV      
       , TTEAM       = AA.TTEAM          
       , CUR_AMNINV  = AA.CUR_AMNINV     
       , CUR_INV     = AA.CUR_INV        
       , CUR_AMINV   = AA.CUR_AMINV      
       , CUR_MINV    = AA.CUR_MINV       
       , CUR_AMCOLL  = AA.CUR_AMCOLL     
       , CUR_MCOLL   = AA.CUR_MCOLL      
       , LAST_DAY    = 000000000000000   
       , BM_JAN      = AA.BM_JAN         
       , M_JAN       = AA.M_JAN          
       , USER_ID     = AA.USER_ID        
       , USER_ID2    = AA.USER_ID2       
       , BSALE_AMT   = AA.BSALE_AMT      
  FROM (
        SELECT TEAM_GROUP = (CASE WHEN UT.TEAM_CODE = '74000' THEN '1' 
                                  WHEN UT.TEAM_CODE = '75000' THEN '3' 
                                  WHEN UT.TEAM_CODE = '79000' THEN '3' 
                                  ELSE '1' 
                             END)       
             , TTEAM      = (CASE UT.TEAM_CODE  
                                WHEN '71000' THEN '1' /*영업1팀   */
                                WHEN '73000' THEN '1' /*특판1팀   */
                                WHEN '76000' THEN '1' /*중부호남  */
                                WHEN '77000' THEN '1' /*서부점    */
                                WHEN '78000' THEN '1' /*특판2팀   */
                                WHEN '74000' THEN '2' /*동부점    */
                                WHEN '72000' THEN '3' /*영업2팀   */
                                WHEN '75000' THEN '4' /*시화점    */
                                WHEN '79000' THEN '4' /*채권팀    */
                                ELSE              '5' 
                             END)
             , TEAM_CODE  = UT.TEAM_CODE   
             , RANK_NO    = UT.RANK_NO  

             , TEAM_NAME  = UT.TEAM_NAME
             , USER_NAME  = UT.USER_NAME
             , RANK       = UT.RANK     
             , CYEAR      = :AI_YEAR    
             , CMON       = :AI_MON     
             , PRE_YINV   = SUM((OPEOM_A.INV_01  + OPEOM_A.INV_02  + OPEOM_A.INV_03  + OPEOM_A.INV_04  + OPEOM_A.INV_05  + OPEOM_A.INV_06   + 
                                 OPEOM_A.INV_07  + OPEOM_A.INV_08  + OPEOM_A.INV_09  + OPEOM_A.INV_10  + OPEOM_A.INV_11  + OPEOM_A.INV_12)  / 1.1) / 1000
             , CUR_AYINV  = SUM((CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03 + CUST_AIM.INV_04 + CUST_AIM.INV_05 + CUST_AIM.INV_06  + 
                                 CUST_AIM.INV_07 + CUST_AIM.INV_08 + CUST_AIM.INV_09 + CUST_AIM.INV_10 + CUST_AIM.INV_11 + CUST_AIM.INV_12) / 1.1) / 1000
             , CUR_AMNINV = SUM((CASE :AI_MON 
                                    WHEN 01 THEN CUST_AIM.INV_01
                                    WHEN 02 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02
                                    WHEN 03 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03
                                    WHEN 04 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03 + CUST_AIM.INV_04
                                    WHEN 05 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03 + CUST_AIM.INV_04 + CUST_AIM.INV_05
                                    WHEN 06 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03 + CUST_AIM.INV_04 + CUST_AIM.INV_05 + CUST_AIM.INV_06
                                    WHEN 07 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03 + CUST_AIM.INV_04 + CUST_AIM.INV_05 + CUST_AIM.INV_06 + CUST_AIM.INV_07
                                    WHEN 08 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03 + CUST_AIM.INV_04 + CUST_AIM.INV_05 + CUST_AIM.INV_06 + CUST_AIM.INV_07 + CUST_AIM.INV_08
                                    WHEN 09 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03 + CUST_AIM.INV_04 + CUST_AIM.INV_05 + CUST_AIM.INV_06 + CUST_AIM.INV_07 + CUST_AIM.INV_08 + CUST_AIM.INV_09
                                    WHEN 10 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03 + CUST_AIM.INV_04 + CUST_AIM.INV_05 + CUST_AIM.INV_06 + CUST_AIM.INV_07 + CUST_AIM.INV_08 + CUST_AIM.INV_09 + CUST_AIM.INV_10
                                    WHEN 11 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03 + CUST_AIM.INV_04 + CUST_AIM.INV_05 + CUST_AIM.INV_06 + CUST_AIM.INV_07 + CUST_AIM.INV_08 + CUST_AIM.INV_09 + CUST_AIM.INV_10 + CUST_AIM.INV_11
                                    WHEN 12 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03 + CUST_AIM.INV_04 + CUST_AIM.INV_05 + CUST_AIM.INV_06 + CUST_AIM.INV_07 + CUST_AIM.INV_08 + CUST_AIM.INV_09 + CUST_AIM.INV_10 + CUST_AIM.INV_11 + CUST_AIM.INV_12 
                                 END) / 1.1) / 1000
             , CUR_INV    = SUM((CASE :AI_MON  
                                    WHEN 01 THEN OPEOM_B.INV_01
                                    WHEN 02 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02
                                    WHEN 03 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02 + OPEOM_B.INV_03
                                    WHEN 04 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02 + OPEOM_B.INV_03 + OPEOM_B.INV_04
                                    WHEN 05 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02 + OPEOM_B.INV_03 + OPEOM_B.INV_04 + OPEOM_B.INV_05
                                    WHEN 06 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02 + OPEOM_B.INV_03 + OPEOM_B.INV_04 + OPEOM_B.INV_05 + OPEOM_B.INV_06
                                    WHEN 07 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02 + OPEOM_B.INV_03 + OPEOM_B.INV_04 + OPEOM_B.INV_05 + OPEOM_B.INV_06 + OPEOM_B.INV_07
                                    WHEN 08 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02 + OPEOM_B.INV_03 + OPEOM_B.INV_04 + OPEOM_B.INV_05 + OPEOM_B.INV_06 + OPEOM_B.INV_07 + OPEOM_B.INV_08
                                    WHEN 09 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02 + OPEOM_B.INV_03 + OPEOM_B.INV_04 + OPEOM_B.INV_05 + OPEOM_B.INV_06 + OPEOM_B.INV_07 + OPEOM_B.INV_08 + OPEOM_B.INV_09
                                    WHEN 10 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02 + OPEOM_B.INV_03 + OPEOM_B.INV_04 + OPEOM_B.INV_05 + OPEOM_B.INV_06 + OPEOM_B.INV_07 + OPEOM_B.INV_08 + OPEOM_B.INV_09 + OPEOM_B.INV_10
                                    WHEN 11 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02 + OPEOM_B.INV_03 + OPEOM_B.INV_04 + OPEOM_B.INV_05 + OPEOM_B.INV_06 + OPEOM_B.INV_07 + OPEOM_B.INV_08 + OPEOM_B.INV_09 + OPEOM_B.INV_10 + OPEOM_B.INV_11
                                    WHEN 12 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02 + OPEOM_B.INV_03 + OPEOM_B.INV_04 + OPEOM_B.INV_05 + OPEOM_B.INV_06 + OPEOM_B.INV_07 + OPEOM_B.INV_08 + OPEOM_B.INV_09 + OPEOM_B.INV_10 + OPEOM_B.INV_11 + OPEOM_B.INV_12 
                                 END) / 1.1) / 1000
             , CUR_AMINV  = SUM((CASE :AI_MON  
                                    WHEN 01 THEN CUST_AIM.MOD_01
                                    WHEN 02 THEN CUST_AIM.MOD_02
                                    WHEN 03 THEN CUST_AIM.MOD_03
                                    WHEN 04 THEN CUST_AIM.MOD_04
                                    WHEN 05 THEN CUST_AIM.MOD_05
                                    WHEN 06 THEN CUST_AIM.MOD_06
                                    WHEN 07 THEN CUST_AIM.MOD_07
                                    WHEN 08 THEN CUST_AIM.MOD_08
                                    WHEN 09 THEN CUST_AIM.MOD_09
                                    WHEN 10 THEN CUST_AIM.MOD_10
                                    WHEN 11 THEN CUST_AIM.MOD_11
                                    WHEN 12 THEN CUST_AIM.MOD_12 
                                 END) / 1.1) / 1000
             , CUR_MINV   = SUM((CASE :AI_MON  
                                    WHEN 01 THEN OPEOM_B.INV_01
                                    WHEN 02 THEN OPEOM_B.INV_02
                                    WHEN 03 THEN OPEOM_B.INV_03
                                    WHEN 04 THEN OPEOM_B.INV_04
                                    WHEN 05 THEN OPEOM_B.INV_05
                                    WHEN 06 THEN OPEOM_B.INV_06
                                    WHEN 07 THEN OPEOM_B.INV_07
                                    WHEN 08 THEN OPEOM_B.INV_08
                                    WHEN 09 THEN OPEOM_B.INV_09
                                    WHEN 10 THEN OPEOM_B.INV_10
                                    WHEN 11 THEN OPEOM_B.INV_11
                                    WHEN 12 THEN OPEOM_B.INV_12 
                                 END) / 1.1) / 1000
             , CUR_AMCOLL = SUM((CASE :AI_MON  
                                    WHEN 01 THEN CUST_AIM.DEL_01
                                    WHEN 02 THEN CUST_AIM.DEL_02
                                    WHEN 03 THEN CUST_AIM.DEL_03
                                    WHEN 04 THEN CUST_AIM.DEL_04
                                    WHEN 05 THEN CUST_AIM.DEL_05
                                    WHEN 06 THEN CUST_AIM.DEL_06
                                    WHEN 07 THEN CUST_AIM.DEL_07
                                    WHEN 08 THEN CUST_AIM.DEL_08
                                    WHEN 09 THEN CUST_AIM.DEL_09
                                    WHEN 10 THEN CUST_AIM.DEL_10
                                    WHEN 11 THEN CUST_AIM.DEL_11
                                    WHEN 12 THEN CUST_AIM.DEL_12 
                                 END)) / 1000
             , CUR_MCOLL  = SUM((CASE :AI_MON  
                                    WHEN 01 THEN OPEOM_B.COLL_01
                                    WHEN 02 THEN OPEOM_B.COLL_02
                                    WHEN 03 THEN OPEOM_B.COLL_03
                                    WHEN 04 THEN OPEOM_B.COLL_04
                                    WHEN 05 THEN OPEOM_B.COLL_05
                                    WHEN 06 THEN OPEOM_B.COLL_06
                                    WHEN 07 THEN OPEOM_B.COLL_07
                                    WHEN 08 THEN OPEOM_B.COLL_08
                                    WHEN 09 THEN OPEOM_B.COLL_09
                                    WHEN 10 THEN OPEOM_B.COLL_10
                                    WHEN 11 THEN OPEOM_B.COLL_11
                                    WHEN 12 THEN OPEOM_B.COLL_12 
                                 END)) / 1000
             , BM_JAN     = 000000000000000  
             , M_JAN      = 000000000000000  
             , USER_ID    = MIN(UT.USER_ID)  
             , USER_ID2   = MIN(UT.USER_ID2) 
             , BSALE_AMT  = 000000000000000  
          FROM CUSTOMER inner join (SELECT USER_ID
													, USER_ID2  = USER_ID 
													, TEAM_CODE = (CASE  WHEN LOGIN.TEAM_CODE = '71000' OR LOGIN.TEAM_CODE = '72000' OR LOGIN.TEAM_CODE = '73000' OR LOGIN.TEAM_CODE = '74000' OR
																					  LOGIN.TEAM_CODE = '75000' OR LOGIN.TEAM_CODE = '76000' OR LOGIN.TEAM_CODE = '77000' OR LOGIN.TEAM_CODE = '78000' OR LOGIN.TEAM_CODE = '79000' 
																					  THEN LOGIN.TEAM_CODE 
																				ELSE      '99000' 
																		END)
													, TEAM_NAME = (CASE  WHEN LOGIN.TEAM_CODE = '71000' OR LOGIN.TEAM_CODE = '72000' OR LOGIN.TEAM_CODE = '73000' OR LOGIN.TEAM_CODE = '74000' OR
																					  LOGIN.TEAM_CODE = '75000' OR LOGIN.TEAM_CODE = '76000' OR LOGIN.TEAM_CODE = '77000' OR LOGIN.TEAM_CODE = '78000' OR LOGIN.TEAM_CODE = '79000'
																					  THEN RTRIM(TEAM.TEAM_NAME )
																				ELSE      '기타' 
																		END)
													, USER_NAME = (CASE  WHEN LOGIN.USER_ID   = 'W_POS'  THEN '기타'
																				WHEN LOGIN.USER_ID   = 'USE_NO' THEN '길병학'
																				WHEN LOGIN.USER_ID   = 'killby' THEN '길병학'
																				WHEN LOGIN.TEAM_CODE = '71000' OR LOGIN.TEAM_CODE = '72000' OR LOGIN.TEAM_CODE = '73000' OR LOGIN.TEAM_CODE = '74000' OR
																					  LOGIN.TEAM_CODE = '75000' OR LOGIN.TEAM_CODE = '76000' OR LOGIN.TEAM_CODE = '77000' OR LOGIN.TEAM_CODE = '78000' OR LOGIN.TEAM_CODE = '79000'
																					  THEN RTRIM(LOGIN.USER_NAME )
																				ELSE      '공장,현금판매' 
																		END)
													, RANK_NO   = ISNULL((CASE WHEN LOGIN.USER_ID   = 'W_POS'  THEN '999'
																						WHEN LOGIN.USER_ID   = 'USE_NO' THEN '120'
																						WHEN LOGIN.USER_ID   = 'killby' THEN '120'
																						WHEN LOGIN.TEAM_CODE = '71000' OR LOGIN.TEAM_CODE = '72000' OR LOGIN.TEAM_CODE = '73000' OR LOGIN.TEAM_CODE = '74000' OR
																							  LOGIN.TEAM_CODE = '75000' OR LOGIN.TEAM_CODE = '76000' OR LOGIN.TEAM_CODE = '77000' OR LOGIN.TEAM_CODE = '78000' OR LOGIN.TEAM_CODE = '79000' 
																							  THEN LOGIN.RANK_NO 
																						ELSE      '00' 
																				 END),'00')
													, RANK      = ISNULL((CASE WHEN LOGIN.USER_ID   = 'USE_NO' THEN '대리'
																						WHEN LOGIN.USER_ID   = 'killby' THEN '대리'
																						WHEN LOGIN.TEAM_CODE = '71000' OR LOGIN.TEAM_CODE = '72000' OR LOGIN.TEAM_CODE = '73000' OR LOGIN.TEAM_CODE = '74000' OR
																							  LOGIN.TEAM_CODE = '75000' OR LOGIN.TEAM_CODE = '76000' OR LOGIN.TEAM_CODE = '77000' OR LOGIN.TEAM_CODE = '78000' OR LOGIN.TEAM_CODE = '79000' 
																							  THEN LOGIN.RANK 
																						ELSE '外' 
																				 END),'')
											  FROM LOGIN left outer join TEAM on LOGIN.TEAM_CODE = TEAM.TEAM_CODE
											 WHERE LOGIN.USE_FLAG           LIKE :AS_USE_FLAG
												AND (SUBSTRING(LOGIN.TEAM_CODE,1,1) = '7' OR SUBSTRING(LOGIN.TEAM_CODE,1,1) = '9')
											) UT on CUSTOMER.SALESMAN = UT.USER_ID           
                                     left outer join CUST_AIM on CUSTOMER.CUST_NO = CUST_AIM.CUST_CODE and DATEPART(YEAR,CUST_AIM.TAR_YEAR) = :AI_YEAR
                                     left outer join OPEOM OPEOM_A on CUSTOMER.CUST_NO = OPEOM_A.CUST_NO and DATEPART(YEAR,OPEOM_A.EOM_YEAR)  = :AI_YEAR - 1
							left outer join OPEOM OPEOM_B on CUSTOMER.CUST_NO = OPEOM_B.CUST_NO and DATEPART(YEAR,OPEOM_B.EOM_YEAR)  = :AI_YEAR
         WHERE ( CUSTOMER.CUST_FLAG               = 'N' )
           AND ( CUSTOMER.CUST_TYPE              <> 'E' )
           AND ( CUSTOMER.CUST_NO                <> 'U580' )
           AND ( CUSTOMER.SALESMAN             LIKE '%' ) 
           AND ( CUSTOMER.CREDIT_LEVEL           <> 'Z' )
         GROUP BY UT.TEAM_CODE, UT.TEAM_NAME, UT.USER_NAME, UT.RANK_NO, UT.RANK
         
      /*---------------------*/      
       UNION
      /*---------------------*/      
       SELECT TEAM_GROUP = '3'    
            , TTEAM      = '4'
            , TEAM_CODE  = '75000'     
            , RANK_NO    = '0'     
                         
            , TEAM_NAME  = '시화점'  
            , USER_NAME  = '내부업체' /*CUSTOMER.CUST_NAME*/
            , RANK       = ''      
            , CYEAR      = :AI_YEAR
            , CMON       = :AI_MON 
            , PRE_YINV   = SUM((OPEOM_A.INV_01  + OPEOM_A.INV_02  + OPEOM_A.INV_03  + OPEOM_A.INV_04  + OPEOM_A.INV_05  + OPEOM_A.INV_06  + 
                                OPEOM_A.INV_07  + OPEOM_A.INV_08  + OPEOM_A.INV_09  + OPEOM_A.INV_10  + OPEOM_A.INV_11  + OPEOM_A.INV_12  ) / 1.1) / 1000
            , CUR_AYINV  = SUM((CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03 + CUST_AIM.INV_04 + CUST_AIM.INV_05 + CUST_AIM.INV_06 + 
                                CUST_AIM.INV_07 + CUST_AIM.INV_08 + CUST_AIM.INV_09 + CUST_AIM.INV_10 + CUST_AIM.INV_11 + CUST_AIM.INV_12 ) / 1.1) / 1000
            , CUR_AMNINV = SUM((CASE :AI_MON 
                                   WHEN 01 THEN CUST_AIM.INV_01
                                   WHEN 02 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02
                                   WHEN 03 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03
                                   WHEN 04 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03 + CUST_AIM.INV_04
                                   WHEN 05 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03 + CUST_AIM.INV_04 + CUST_AIM.INV_05
                                   WHEN 06 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03 + CUST_AIM.INV_04 + CUST_AIM.INV_05 + CUST_AIM.INV_06
                                   WHEN 07 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03 + CUST_AIM.INV_04 + CUST_AIM.INV_05 + CUST_AIM.INV_06 + CUST_AIM.INV_07
                                   WHEN 08 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03 + CUST_AIM.INV_04 + CUST_AIM.INV_05 + CUST_AIM.INV_06 + CUST_AIM.INV_07 + CUST_AIM.INV_08
                                   WHEN 09 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03 + CUST_AIM.INV_04 + CUST_AIM.INV_05 + CUST_AIM.INV_06 + CUST_AIM.INV_07 + CUST_AIM.INV_08 + CUST_AIM.INV_09
                                   WHEN 10 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03 + CUST_AIM.INV_04 + CUST_AIM.INV_05 + CUST_AIM.INV_06 + CUST_AIM.INV_07 + CUST_AIM.INV_08 + CUST_AIM.INV_09 + CUST_AIM.INV_10
                                   WHEN 11 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03 + CUST_AIM.INV_04 + CUST_AIM.INV_05 + CUST_AIM.INV_06 + CUST_AIM.INV_07 + CUST_AIM.INV_08 + CUST_AIM.INV_09 + CUST_AIM.INV_10 + CUST_AIM.INV_11
                                   WHEN 12 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03 + CUST_AIM.INV_04 + CUST_AIM.INV_05 + CUST_AIM.INV_06 + CUST_AIM.INV_07 + CUST_AIM.INV_08 + CUST_AIM.INV_09 + CUST_AIM.INV_10 + CUST_AIM.INV_11 + CUST_AIM.INV_12 
                                END) / 1.1) / 1000
            , CUR_INV    = SUM((CASE :AI_MON  
                                   WHEN 01 THEN OPEOM_B.INV_01
                                   WHEN 02 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02
                                   WHEN 03 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02 + OPEOM_B.INV_03
                                   WHEN 04 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02 + OPEOM_B.INV_03 + OPEOM_B.INV_04
                                   WHEN 05 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02 + OPEOM_B.INV_03 + OPEOM_B.INV_04 + OPEOM_B.INV_05
                                   WHEN 06 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02 + OPEOM_B.INV_03 + OPEOM_B.INV_04 + OPEOM_B.INV_05 + OPEOM_B.INV_06
                                   WHEN 07 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02 + OPEOM_B.INV_03 + OPEOM_B.INV_04 + OPEOM_B.INV_05 + OPEOM_B.INV_06 + OPEOM_B.INV_07
                                   WHEN 08 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02 + OPEOM_B.INV_03 + OPEOM_B.INV_04 + OPEOM_B.INV_05 + OPEOM_B.INV_06 + OPEOM_B.INV_07 + OPEOM_B.INV_08
                                   WHEN 09 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02 + OPEOM_B.INV_03 + OPEOM_B.INV_04 + OPEOM_B.INV_05 + OPEOM_B.INV_06 + OPEOM_B.INV_07 + OPEOM_B.INV_08 + OPEOM_B.INV_09
                                   WHEN 10 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02 + OPEOM_B.INV_03 + OPEOM_B.INV_04 + OPEOM_B.INV_05 + OPEOM_B.INV_06 + OPEOM_B.INV_07 + OPEOM_B.INV_08 + OPEOM_B.INV_09 + OPEOM_B.INV_10
                                   WHEN 11 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02 + OPEOM_B.INV_03 + OPEOM_B.INV_04 + OPEOM_B.INV_05 + OPEOM_B.INV_06 + OPEOM_B.INV_07 + OPEOM_B.INV_08 + OPEOM_B.INV_09 + OPEOM_B.INV_10 + OPEOM_B.INV_11
                                   WHEN 12 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02 + OPEOM_B.INV_03 + OPEOM_B.INV_04 + OPEOM_B.INV_05 + OPEOM_B.INV_06 + OPEOM_B.INV_07 + OPEOM_B.INV_08 + OPEOM_B.INV_09 + OPEOM_B.INV_10 + OPEOM_B.INV_11 + OPEOM_B.INV_12 
                                END) / 1.1) / 1000
            , CUR_AMINV  = SUM((CASE :AI_MON  
                                   WHEN 01 THEN CUST_AIM.MOD_01
                                   WHEN 02 THEN CUST_AIM.MOD_02
                                   WHEN 03 THEN CUST_AIM.MOD_03
                                   WHEN 04 THEN CUST_AIM.MOD_04
                                   WHEN 05 THEN CUST_AIM.MOD_05
                                   WHEN 06 THEN CUST_AIM.MOD_06
                                   WHEN 07 THEN CUST_AIM.MOD_07
                                   WHEN 08 THEN CUST_AIM.MOD_08
                                   WHEN 09 THEN CUST_AIM.MOD_09
                                   WHEN 10 THEN CUST_AIM.MOD_10
                                   WHEN 11 THEN CUST_AIM.MOD_11
                                   WHEN 12 THEN CUST_AIM.MOD_12 
                               END) / 1.1) / 1000
            , CUR_MINV   = SUM((CASE :AI_MON  
                                   WHEN 01 THEN OPEOM_B.INV_01
                                   WHEN 02 THEN OPEOM_B.INV_02
                                   WHEN 03 THEN OPEOM_B.INV_03
                                   WHEN 04 THEN OPEOM_B.INV_04
                                   WHEN 05 THEN OPEOM_B.INV_05
                                   WHEN 06 THEN OPEOM_B.INV_06
                                   WHEN 07 THEN OPEOM_B.INV_07
                                   WHEN 08 THEN OPEOM_B.INV_08
                                   WHEN 09 THEN OPEOM_B.INV_09
                                   WHEN 10 THEN OPEOM_B.INV_10
                                   WHEN 11 THEN OPEOM_B.INV_11
                                   WHEN 12 THEN OPEOM_B.INV_12 
                                END) / 1.1) / 1000
            , CUR_AMCOLL = SUM((CASE :AI_MON  
                                   WHEN 01 THEN CUST_AIM.DEL_01
                                   WHEN 02 THEN CUST_AIM.DEL_02
                                   WHEN 03 THEN CUST_AIM.DEL_03
                                   WHEN 04 THEN CUST_AIM.DEL_04
                                   WHEN 05 THEN CUST_AIM.DEL_05
                                   WHEN 06 THEN CUST_AIM.DEL_06
                                   WHEN 07 THEN CUST_AIM.DEL_07
                                   WHEN 08 THEN CUST_AIM.DEL_08
                                   WHEN 09 THEN CUST_AIM.DEL_09
                                   WHEN 10 THEN CUST_AIM.DEL_10
                                   WHEN 11 THEN CUST_AIM.DEL_11
                                   WHEN 12 THEN CUST_AIM.DEL_12 
                                END)) / 1000
            , CUR_MCOLL  = SUM((CASE :AI_MON  
                                   WHEN 01 THEN OPEOM_B.COLL_01
                                   WHEN 02 THEN OPEOM_B.COLL_02
                                   WHEN 03 THEN OPEOM_B.COLL_03
                                   WHEN 04 THEN OPEOM_B.COLL_04
                                   WHEN 05 THEN OPEOM_B.COLL_05
                                   WHEN 06 THEN OPEOM_B.COLL_06
                                   WHEN 07 THEN OPEOM_B.COLL_07
                                   WHEN 08 THEN OPEOM_B.COLL_08
                                   WHEN 09 THEN OPEOM_B.COLL_09
                                   WHEN 10 THEN OPEOM_B.COLL_10
                                   WHEN 11 THEN OPEOM_B.COLL_11
                                   WHEN 12 THEN OPEOM_B.COLL_12 
                                END)) / 1000
            , BM_JAN     = 000000000000000  
            , M_JAN      = 000000000000000  
            , USER_ID    = 'YCIN1'          
            , USER_ID2   = 'YCIN1'          
            , BSALE_AMT  = 000000000000000  
         FROM CUSTOMER  inner join  
             (SELECT USER_ID
                    , USER_ID2  = 'YCIN1'
                    , TEAM_CODE = (CASE  WHEN LOGIN.TEAM_CODE = '71000' OR LOGIN.TEAM_CODE = '72000' OR LOGIN.TEAM_CODE = '73000' OR LOGIN.TEAM_CODE = '74000' OR
                                              LOGIN.TEAM_CODE = '75000' OR LOGIN.TEAM_CODE = '76000' OR LOGIN.TEAM_CODE = '77000' OR LOGIN.TEAM_CODE = '78000' OR LOGIN.TEAM_CODE = '79000'
                                              THEN LOGIN.TEAM_CODE 
                                         ELSE '99000' 
                                   END)
                    , TEAM_NAME = (CASE  WHEN LOGIN.TEAM_CODE = '71000' OR LOGIN.TEAM_CODE = '72000' OR LOGIN.TEAM_CODE = '73000' OR LOGIN.TEAM_CODE = '74000' OR
                                              LOGIN.TEAM_CODE = '75000' OR LOGIN.TEAM_CODE = '76000' OR LOGIN.TEAM_CODE = '77000' OR LOGIN.TEAM_CODE = '78000' OR LOGIN.TEAM_CODE = '79000'
                                              THEN RTRIM(TEAM.TEAM_NAME)
                                         ELSE '기타' 
                                   END)   
                    , USER_NAME = (CASE  WHEN LOGIN.USER_ID   = 'USE_NO' THEN '길병학'
                                         WHEN LOGIN.TEAM_CODE = '71000' OR LOGIN.TEAM_CODE = '72000' OR LOGIN.TEAM_CODE = '73000' OR LOGIN.TEAM_CODE = '74000' OR
                                              LOGIN.TEAM_CODE = '75000' OR LOGIN.TEAM_CODE = '76000' OR LOGIN.TEAM_CODE = '77000' OR LOGIN.TEAM_CODE = '78000' OR LOGIN.TEAM_CODE = '79000'
                                              THEN RTRIM(LOGIN.USER_NAME)
                                         ELSE '공장,현금판매' 
                                   END) 
                    , RANK_NO   = ISNULL((CASE WHEN LOGIN.TEAM_CODE = '71000' OR LOGIN.TEAM_CODE = '72000' OR LOGIN.TEAM_CODE = '73000' OR LOGIN.TEAM_CODE = '74000' OR
                                                    LOGIN.TEAM_CODE = '75000' OR LOGIN.TEAM_CODE = '76000' OR LOGIN.TEAM_CODE = '77000' OR LOGIN.TEAM_CODE = '78000' OR LOGIN.TEAM_CODE = '79000' 
                                                    THEN LOGIN.RANK_NO 
                                               ELSE '00' 
                                          END),'00')
                    , RANK      = ISNULL((CASE WHEN LOGIN.TEAM_CODE = '71000' OR LOGIN.TEAM_CODE = '72000' OR LOGIN.TEAM_CODE = '73000' OR LOGIN.TEAM_CODE = '74000' OR
                                                    LOGIN.TEAM_CODE = '75000' OR LOGIN.TEAM_CODE = '76000' OR LOGIN.TEAM_CODE = '77000' OR LOGIN.TEAM_CODE = '78000' OR LOGIN.TEAM_CODE = '79000' 
                                                    THEN LOGIN.RANK 
                                               ELSE '外' 
                                          END),'')
                 FROM LOGIN left outer join TEAM on LOGIN.TEAM_CODE = TEAM.TEAM_CODE
                WHERE LOGIN.USE_FLAG          LIKE :AS_USE_FLAG
                  	AND (SUBSTRING(LOGIN.TEAM_CODE,1,1) = '7' OR SUBSTRING(LOGIN.TEAM_CODE,1,1) = '9')
              ) UT on CUSTOMER.SALESMAN = UT.USER_ID
              left outer join CUST_AIM on CUSTOMER.CUST_NO = CUST_AIM.CUST_CODE and  DATEPART(YEAR,CUST_AIM.TAR_YEAR) = :AI_YEAR
              left outer join OPEOM OPEOM_A on CUSTOMER.CUST_NO = OPEOM_A.CUST_NO and DATEPART(YEAR,OPEOM_A.EOM_YEAR)  = :AI_YEAR - 1 
              left outer join OPEOM OPEOM_B  on CUSTOMER.CUST_NO = OPEOM_B.CUST_NO and DATEPART(YEAR,OPEOM_B.EOM_YEAR)  = :AI_YEAR
        WHERE ( CUSTOMER.CUST_FLAG               = 'N' ) 
          AND ( CUSTOMER.CUST_TYPE              <> 'E' )
          AND ( CUSTOMER.SALESMAN             LIKE :AS_USERID )
          AND ( CUSTOMER.CREDIT_LEVEL            = 'Z' )
          AND ( CUSTOMER.CUST_NO                IN ('N002','K023','S396','H479','N014'))
        GROUP BY UT.TEAM_CODE, UT.TEAM_NAME, UT.USER_NAME
   
      /*---------------------*/      
       UNION
      /*---------------------*/      
       SELECT TEAM_GROUP = '3'    
            , TTEAM      = '4'
            , TEAM_CODE  = '75000'     
            , RANK_NO    = '0'     
                         
            , TEAM_NAME  = '시화점'  
            , USER_NAME  = '송천산업' /*CUSTOMER.CUST_NAME*/
            , RANK       = ''      
            , CYEAR      = :AI_YEAR
            , CMON       = :AI_MON 
            , PRE_YINV   = SUM((OPEOM_A.INV_01  + OPEOM_A.INV_02  + OPEOM_A.INV_03  + OPEOM_A.INV_04  + OPEOM_A.INV_05  + OPEOM_A.INV_06  + 
                                OPEOM_A.INV_07  + OPEOM_A.INV_08  + OPEOM_A.INV_09  + OPEOM_A.INV_10  + OPEOM_A.INV_11  + OPEOM_A.INV_12  ) / 1.1) / 1000
            , CUR_AYINV  = SUM((CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03 + CUST_AIM.INV_04 + CUST_AIM.INV_05 + CUST_AIM.INV_06 + 
                                CUST_AIM.INV_07 + CUST_AIM.INV_08 + CUST_AIM.INV_09 + CUST_AIM.INV_10 + CUST_AIM.INV_11 + CUST_AIM.INV_12 ) / 1.1) / 1000
            , CUR_AMNINV = SUM((CASE :AI_MON 
                                   WHEN 01 THEN CUST_AIM.INV_01
                                   WHEN 02 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02
                                   WHEN 03 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03
                                   WHEN 04 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03 + CUST_AIM.INV_04
                                   WHEN 05 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03 + CUST_AIM.INV_04 + CUST_AIM.INV_05
                                   WHEN 06 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03 + CUST_AIM.INV_04 + CUST_AIM.INV_05 + CUST_AIM.INV_06
                                   WHEN 07 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03 + CUST_AIM.INV_04 + CUST_AIM.INV_05 + CUST_AIM.INV_06 + CUST_AIM.INV_07
                                   WHEN 08 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03 + CUST_AIM.INV_04 + CUST_AIM.INV_05 + CUST_AIM.INV_06 + CUST_AIM.INV_07 + CUST_AIM.INV_08
                                   WHEN 09 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03 + CUST_AIM.INV_04 + CUST_AIM.INV_05 + CUST_AIM.INV_06 + CUST_AIM.INV_07 + CUST_AIM.INV_08 + CUST_AIM.INV_09
                                   WHEN 10 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03 + CUST_AIM.INV_04 + CUST_AIM.INV_05 + CUST_AIM.INV_06 + CUST_AIM.INV_07 + CUST_AIM.INV_08 + CUST_AIM.INV_09 + CUST_AIM.INV_10
                                   WHEN 11 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03 + CUST_AIM.INV_04 + CUST_AIM.INV_05 + CUST_AIM.INV_06 + CUST_AIM.INV_07 + CUST_AIM.INV_08 + CUST_AIM.INV_09 + CUST_AIM.INV_10 + CUST_AIM.INV_11
                                   WHEN 12 THEN CUST_AIM.INV_01 + CUST_AIM.INV_02 + CUST_AIM.INV_03 + CUST_AIM.INV_04 + CUST_AIM.INV_05 + CUST_AIM.INV_06 + CUST_AIM.INV_07 + CUST_AIM.INV_08 + CUST_AIM.INV_09 + CUST_AIM.INV_10 + CUST_AIM.INV_11 + CUST_AIM.INV_12 
                                END) / 1.1) / 1000
            , CUR_INV    = SUM((CASE :AI_MON  
                                   WHEN 01 THEN OPEOM_B.INV_01
                                   WHEN 02 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02
                                   WHEN 03 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02 + OPEOM_B.INV_03
                                   WHEN 04 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02 + OPEOM_B.INV_03 + OPEOM_B.INV_04
                                   WHEN 05 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02 + OPEOM_B.INV_03 + OPEOM_B.INV_04 + OPEOM_B.INV_05
                                   WHEN 06 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02 + OPEOM_B.INV_03 + OPEOM_B.INV_04 + OPEOM_B.INV_05 + OPEOM_B.INV_06
                                   WHEN 07 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02 + OPEOM_B.INV_03 + OPEOM_B.INV_04 + OPEOM_B.INV_05 + OPEOM_B.INV_06 + OPEOM_B.INV_07
                                   WHEN 08 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02 + OPEOM_B.INV_03 + OPEOM_B.INV_04 + OPEOM_B.INV_05 + OPEOM_B.INV_06 + OPEOM_B.INV_07 + OPEOM_B.INV_08
                                   WHEN 09 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02 + OPEOM_B.INV_03 + OPEOM_B.INV_04 + OPEOM_B.INV_05 + OPEOM_B.INV_06 + OPEOM_B.INV_07 + OPEOM_B.INV_08 + OPEOM_B.INV_09
                                   WHEN 10 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02 + OPEOM_B.INV_03 + OPEOM_B.INV_04 + OPEOM_B.INV_05 + OPEOM_B.INV_06 + OPEOM_B.INV_07 + OPEOM_B.INV_08 + OPEOM_B.INV_09 + OPEOM_B.INV_10
                                   WHEN 11 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02 + OPEOM_B.INV_03 + OPEOM_B.INV_04 + OPEOM_B.INV_05 + OPEOM_B.INV_06 + OPEOM_B.INV_07 + OPEOM_B.INV_08 + OPEOM_B.INV_09 + OPEOM_B.INV_10 + OPEOM_B.INV_11
                                   WHEN 12 THEN OPEOM_B.INV_01 + OPEOM_B.INV_02 + OPEOM_B.INV_03 + OPEOM_B.INV_04 + OPEOM_B.INV_05 + OPEOM_B.INV_06 + OPEOM_B.INV_07 + OPEOM_B.INV_08 + OPEOM_B.INV_09 + OPEOM_B.INV_10 + OPEOM_B.INV_11 + OPEOM_B.INV_12 
                                END) / 1.1) / 1000
            , CUR_AMINV  = SUM((CASE :AI_MON  
                                   WHEN 01 THEN CUST_AIM.MOD_01
                                   WHEN 02 THEN CUST_AIM.MOD_02
                                   WHEN 03 THEN CUST_AIM.MOD_03
                                   WHEN 04 THEN CUST_AIM.MOD_04
                                   WHEN 05 THEN CUST_AIM.MOD_05
                                   WHEN 06 THEN CUST_AIM.MOD_06
                                   WHEN 07 THEN CUST_AIM.MOD_07
                                   WHEN 08 THEN CUST_AIM.MOD_08
                                   WHEN 09 THEN CUST_AIM.MOD_09
                                   WHEN 10 THEN CUST_AIM.MOD_10
                                   WHEN 11 THEN CUST_AIM.MOD_11
                                   WHEN 12 THEN CUST_AIM.MOD_12 
                               END) / 1.1) / 1000
            , CUR_MINV   = SUM((CASE :AI_MON  
                                   WHEN 01 THEN OPEOM_B.INV_01
                                   WHEN 02 THEN OPEOM_B.INV_02
                                   WHEN 03 THEN OPEOM_B.INV_03
                                   WHEN 04 THEN OPEOM_B.INV_04
                                   WHEN 05 THEN OPEOM_B.INV_05
                                   WHEN 06 THEN OPEOM_B.INV_06
                                   WHEN 07 THEN OPEOM_B.INV_07
                                   WHEN 08 THEN OPEOM_B.INV_08
                                   WHEN 09 THEN OPEOM_B.INV_09
                                   WHEN 10 THEN OPEOM_B.INV_10
                                   WHEN 11 THEN OPEOM_B.INV_11
                                   WHEN 12 THEN OPEOM_B.INV_12 
                                END) / 1.1) / 1000
            , CUR_AMCOLL = SUM((CASE :AI_MON  
                                   WHEN 01 THEN CUST_AIM.DEL_01
                                   WHEN 02 THEN CUST_AIM.DEL_02
                                   WHEN 03 THEN CUST_AIM.DEL_03
                                   WHEN 04 THEN CUST_AIM.DEL_04
                                   WHEN 05 THEN CUST_AIM.DEL_05
                                   WHEN 06 THEN CUST_AIM.DEL_06
                                   WHEN 07 THEN CUST_AIM.DEL_07
                                   WHEN 08 THEN CUST_AIM.DEL_08
                                   WHEN 09 THEN CUST_AIM.DEL_09
                                   WHEN 10 THEN CUST_AIM.DEL_10
                                   WHEN 11 THEN CUST_AIM.DEL_11
                                   WHEN 12 THEN CUST_AIM.DEL_12 
                                END)) / 1000
            , CUR_MCOLL  = SUM((CASE :AI_MON  
                                   WHEN 01 THEN OPEOM_B.COLL_01
                                   WHEN 02 THEN OPEOM_B.COLL_02
                                   WHEN 03 THEN OPEOM_B.COLL_03
                                   WHEN 04 THEN OPEOM_B.COLL_04
                                   WHEN 05 THEN OPEOM_B.COLL_05
                                   WHEN 06 THEN OPEOM_B.COLL_06
                                   WHEN 07 THEN OPEOM_B.COLL_07
                                   WHEN 08 THEN OPEOM_B.COLL_08
                                   WHEN 09 THEN OPEOM_B.COLL_09
                                   WHEN 10 THEN OPEOM_B.COLL_10
                                   WHEN 11 THEN OPEOM_B.COLL_11
                                   WHEN 12 THEN OPEOM_B.COLL_12 
                                END)) / 1000
            , BM_JAN     = 000000000000000  
            , M_JAN      = 000000000000000  
            , USER_ID    = 'YCIN1'          
            , USER_ID2   = 'YCIN1'          
            , BSALE_AMT  = 000000000000000  
         FROM CUSTOMER   inner join
             (SELECT USER_ID
                    , USER_ID2  = 'YCIN1'
                    , TEAM_CODE = '75000'
                    , TEAM_NAME = (CASE  WHEN LOGIN.TEAM_CODE = '71000' OR LOGIN.TEAM_CODE = '72000' OR LOGIN.TEAM_CODE = '73000' OR LOGIN.TEAM_CODE = '74000' OR
                                              LOGIN.TEAM_CODE = '75000' OR LOGIN.TEAM_CODE = '76000' OR LOGIN.TEAM_CODE = '77000' OR LOGIN.TEAM_CODE = '78000' OR LOGIN.TEAM_CODE = '79000'
                                              THEN RTRIM(TEAM.TEAM_NAME)
                                         ELSE '기타' 
                                   END)   
                    , USER_NAME = '송천산업' 
                    , RANK_NO   = '00'
                    , RANK      = ''
                 FROM LOGIN left outer join TEAM on LOGIN.TEAM_CODE = TEAM.TEAM_CODE
                WHERE LOGIN.USE_FLAG          LIKE :AS_USE_FLAG
                  AND (SUBSTRING(LOGIN.TEAM_CODE,1,1) = '7' OR SUBSTRING(LOGIN.TEAM_CODE,1,1) = '9')
              ) UT  on CUSTOMER.SALESMAN = UT.USER_ID          
            left outer join CUST_AIM on CUSTOMER.CUST_NO = CUST_AIM.CUST_CODE and DATEPART(YEAR,CUST_AIM.TAR_YEAR) = :AI_YEAR
            left outer join OPEOM OPEOM_A on CUSTOMER.CUST_NO = OPEOM_A.CUST_NO and DATEPART(YEAR,OPEOM_A.EOM_YEAR)  = :AI_YEAR - 1
            left outer join OPEOM OPEOM_B  on CUSTOMER.CUST_NO = OPEOM_B.CUST_NO and  DATEPART(YEAR,OPEOM_B.EOM_YEAR)  = :AI_YEAR
        WHERE ( CUSTOMER.SALESMAN             LIKE :AS_USERID )
               AND ( CUSTOMER.CUST_NO                 = 'U580' )
        GROUP BY UT.TEAM_CODE, UT.TEAM_NAME, UT.USER_NAME
   ) AA
   WHERE AA.TEAM_GROUP   LIKE :AS_GROUP
   ORDER BY AA.TEAM_GROUP, AA.TTEAM, AA.TEAM_CODE, AA.RANK_NO 
/*
19981214 S396   (주)유창금속
19981214 N002   (주)세화내장건설
