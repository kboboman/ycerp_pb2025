table(column=(type=long update=yes updatewhereclause=yes identity=yes name=cust_diary_id dbname="cust_diary.id" )
 column=(type=datetime update=yes updatewhereclause=yes name=diary_date dbname="cust_diary.diary_date" )
 column=(type=char(4) update=yes updatewhereclause=yes name=cust_no dbname="cust_diary.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(50) updatewhereclause=yes name=interview dbname="cust_diary.interview" )
 column=(type=char(255) update=yes updatewhereclause=yes name=contents dbname="contents" )
 column=(type=char(10) update=yes updatewhereclause=yes name=salesman dbname="cust_diary.salesman" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="login.user_name" )
 column=(type=long update=yes updatewhereclause=yes name=mileage dbname="cust_diary.mileage" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="cust_diary.user_id" )
 column=(type=char(10) updatewhereclause=yes name=input_name dbname="input_name" )
 column=(type=char(1) updatewhereclause=yes name=sw_modify dbname="sw_modify" )
 retrieve="  SELECT a.id
       , a.diary_date   
       , a.cust_no   
       , cust_name = isnull(c.cust_name, '신규개척')
       , a.interview
       , contents  = replace(convert(varchar(4099),a.contents), char(13) + char(10), ' | ')
       , a.salesman
       , l.user_name    
       , a.mileage
       , a.user_id
       , input_name = u.user_name
       , sw_modify  = 'X'  
    FROM cust_diary A
         LEFT OUTER JOIN customer C  ON a.cust_no  = c.cust_no
         LEFT OUTER JOIN login    L  ON a.salesman = l.user_id
         LEFT OUTER JOIN login    U  ON a.user_id  = u.user_id
   WHERE ( a.diary_date  BETWEEN :as_sdate AND :as_edate )
     AND ( :as_custno <> '%' AND a.cust_no    = :as_custno
           OR
           :as_custno  = '%' AND a.cust_no LIKE :as_custno
         )
     AND ( :as_salesman <> '%' AND a.salesman    = :as_salesman
           OR
           :as_salesman  = '%' AND a.salesman LIKE :as_salesman
         )
" arguments=(("as_salesman", string),("as_custno", string),("as_sdate", string),("as_edate", string))  sort="diary_date D cust_name A user_name A mileage D " )
