release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=88 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(11) updatewhereclause=yes name=scene_code dbname="scene_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=char(20) updatewhereclause=yes name=project_nm dbname="project_nm" )
 column=(type=datetime updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=datetime updatewhereclause=yes name=edate dbname="edate" )
 column=(type=char(20) updatewhereclause=yes name=owner dbname="owner" )
 retrieve="SELECT cust_no    = a.cust_no
     , cust_name  = b.cust_name
     , scene_code = a.scene_code
     , scene_desc = a.scene_desc
     , project_nm = a.project_nm
     , sdate      = a.start_date
     , edate      = a.end_date
     , owner      = a.owner
  FROM scene a
       LEFT OUTER JOIN customer b  ON a.cust_no = b.cust_no
 WHERE a.cust_no  = :as_custno
 ORDER BY a.input_date desc
" arguments=(("as_custno", string)) )
