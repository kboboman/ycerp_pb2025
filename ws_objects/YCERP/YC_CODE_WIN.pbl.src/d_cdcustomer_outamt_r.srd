 column=(type=char(4) updatewhereclause=yes name=customer_outamt_cust_no dbname="Customer_OUTAMT.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=datetime updatewhereclause=yes name=customer_outamt_sys_date dbname="Customer_OUTAMT.sys_date" )
 column=(type=char(40) updatewhereclause=yes name=customer_outamt_outamt dbname="Customer_OUTAMT.outamt" )
 column=(type=decimal(0) updatewhereclause=yes name=customer_outamt_c_rate dbname="Customer_OUTAMT.c_rate" )
 column=(type=decimal(0) updatewhereclause=yes name=customer_outamt_y_rate dbname="Customer_OUTAMT.y_rate" )
 column=(type=char(40) updatewhereclause=yes name=customer_outamt_y_amt dbname="Customer_OUTAMT.y_amt" )
 column=(type=decimal(0) updatewhereclause=yes name=customer_outamt_s_rate dbname="Customer_OUTAMT.s_rate" )
 column=(type=char(40) updatewhereclause=yes name=customer_outamt_s_amt dbname="Customer_OUTAMT.s_amt" )
 column=(type=char(40) updatewhereclause=yes name=customer_outamt_etc_date dbname="Customer_OUTAMT.etc_date" )
 retrieve="  SELECT user_name   = login.user_name
       , Customer_OUTAMT.cust_no   
       , cust_name   = customer.cust_name
       , Customer_OUTAMT.sys_date   
       , Customer_OUTAMT.outamt   
       , Customer_OUTAMT.c_rate   
       , Customer_OUTAMT.y_rate   
       , Customer_OUTAMT.y_amt   
       , Customer_OUTAMT.s_rate   
       , Customer_OUTAMT.s_amt   
       , Customer_OUTAMT.etc_date  
    FROM Customer_OUTAMT
         LEFT OUTER JOIN customer ON Customer_OUTAMT.cust_no = Customer.cust_no
         LEFT OUTER JOIN login    ON Customer.salesman = login.user_id
   WHERE ((:as_custno   = '%' ) OR
          (:as_custno  <> '%' AND Customer_OUTAMT.cust_no = :as_custno)
         )
" arguments=(("as_custno", string)) )
