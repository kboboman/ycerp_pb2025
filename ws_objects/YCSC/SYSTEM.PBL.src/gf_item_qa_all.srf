$PBExportHeader$gf_item_qa_all.srf
global type gf_item_qa_all from function_object
end type

forward prototypes
global subroutine gf_item_qa_all ()
end prototypes

global subroutine gf_item_qa_all ();
open(w_load)
gs_ds_itemall.setfilter('')
gs_ds_itemall.retrieve()
gs_ds_itemall.SaveAs( ".\ItemAll.txt", text!, FALSE)
commit;

gs_ds_qaall.setfilter('')
gs_ds_qaall.retrieve()
gs_ds_qaall.SaveAs(".\QaAll.txt", text!, FALSE)
commit;
close(w_load)

end subroutine

