footer(height=0 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=cust_no dbname="customer.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 retrieve="  SELECT customer.cust_no,   
         customer.cust_name  
    FROM customer  with(nolock)
   WHERE customer.open_close <> 'C'   
   ORDER BY customer.cust_no ASC   
" filter="( mid ( cust_name, 1, 2) >= '다' and mid(cust_name,1,2) < '라')  or ( ( left(cust_name,1) = '(' ) and ( mid ( cust_name, pos(cust_name,')') + 1, 2) >= '다' AND mid ( cust_name, pos(cust_name,')') + 1,2) < '라'))" sort="cust_name A " )
