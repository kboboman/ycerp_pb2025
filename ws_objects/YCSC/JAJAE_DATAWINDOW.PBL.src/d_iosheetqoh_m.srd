 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"groupitem~" )  TABLE(NAME=~"location~" )  TABLE(NAME=~"supp~" )  TABLE(NAME=~"sheetmst~" ) COLUMN(NAME=~"sheetmst.sheet_no~") COLUMN(NAME=~"sheetmst.loc_no~") COLUMN(NAME=~"sheetmst.item_no~") COLUMN(NAME=~"sheetmst.qa~") COLUMN(NAME=~"sheetmst.rcpt_date~") COLUMN(NAME=~"sheetmst.unit_qty~") COLUMN(NAME=~"sheetmst.cnt~") COLUMN(NAME=~"sheetmst.qcnt~") COLUMN(NAME=~"sheetmst.color_no~") COLUMN(NAME=~"sheetmst.supp_no~") COLUMN(NAME=~"sheetmst.flag~") COLUMN(NAME=~"sheetmst.porder_no~") COLUMN(NAME=~"sheetmst.pseq_no~") COLUMN(NAME=~"sheetmst.open_close~") COLUMN(NAME=~"sheetmst.rem~") COLUMN(NAME=~"sheetmst.rcpt_qty~") COLUMN(NAME=~"groupitem.item_name~") COLUMN(NAME=~"location.loc_name~") COLUMN(NAME=~"supp.supp_name~")    JOIN (LEFT=~"sheetmst.loc_no~"    OP =~"=~"RIGHT=~"location.loc_no~"    OUTER1 =~"sheetmst.loc_no~" )    JOIN (LEFT=~"sheetmst.supp_no~"    OP =~"=~"RIGHT=~"supp.supp_no~"    OUTER1 =~"sheetmst.supp_no~" )    JOIN (LEFT=~"sheetmst.item_no~"    OP =~"=~"RIGHT=~"groupitem.item_no~" )WHERE(    EXP1 =~"sheetmst.loc_no~"   OP =~"like~"    EXP2 =~":as_loc~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"sheetmst.open_close~"   OP =~"in~"    EXP2 =~":as_oc~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"groupitem.item_name~"   OP =~"like~"    EXP2 =~":as_item~" ) ) ARG(NAME = ~"as_loc~" TYPE = string)  ARG(NAME = ~"as_item~" TYPE = string)  ARG(NAME = ~"as_oc~" TYPE = stringlist) " update="sheetmst" updatewhere=0 updatekeyinplace=no arguments=(("as_loc", string),("as_item", string),("as_oc", stringlist))  sort="sheetmst_item_no A sheetmst_qa A " )
