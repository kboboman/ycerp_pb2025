$PBExportHeader$d_mpsale2_r.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=item_no dbname="saledet.item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="groupitem.item_name" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="saledet.uom" )
 column=(type=decimal(2) updatewhereclause=yes name=order_qty dbname="order_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=acc_qty dbname="acc_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=price dbname="price" )
 retrieve="  SELECT saledet.item_no,   
         groupitem.item_name,   
         saledet.uom,   
         order_qty = SUM(saledet.order_qty),   
         acc_qty   = SUM(saledet.acc_qty),   
         price     = SUM(saledet.price)            
    FROM sale,   
         saledet,   
         groupitem,   
         customer  
   WHERE ( sale.order_no    = saledet.order_no  ) and  
         ( saledet.item_no  = groupitem.item_no ) and  
         ( sale.cust_no     = customer.cust_no  ) and  
         ( ( sale.open_close         = 'O'     ) AND  
           ( sale.order_date   between :as_date1 and :as_date2 ) AND  
           ( customer.salesman    like :as_ret ) 
         )
   GROUP BY saledet.item_no,   
         groupitem.item_name,   
         saledet.uom               
 
" arguments=(("as_date1", date),("as_date2", date),("as_ret", string))  sort="item_name A " )
