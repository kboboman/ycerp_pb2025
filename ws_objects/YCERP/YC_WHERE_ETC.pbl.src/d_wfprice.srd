release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=88 color="536870912" )
table(column=(type=char(1) updatewhereclause=yes name=seq dbname="seq" )
 column=(type=decimal(4) updatewhereclause=yes name=price dbname="custscene.price" )
 retrieve="
  SELECT seq  = convert(char(1), '1'), price 
    FROM custscene
   WHERE ( cust_no    = :as_cust_no  )
     AND ( scene_code = :as_scene_no )
     AND ( item_no    = :as_item_no  )
     AND ( qa         = :as_com_qa   )
  
  UNION ALL
  SELECT seq  = convert(char(1), '2'), price 
    FROM custitem
   WHERE ( cust_no    = :as_cust_no  )
     AND ( item_no    = :as_item_no  )
     AND ( qa         = :as_com_qa   )
  
  UNION ALL
  SELECT seq  = convert(char(1), '3'), price_a 
    FROM item
   WHERE ( item_no    = :as_item_no  )
     AND ( qa         = :as_com_qa1  )
" arguments=(("as_scene_no", string),("as_cust_no", string),("as_com_qa", string),("as_item_no", string),("as_com_qa1", string))  sort="seq A " )
text(band=header alignment="2" text="SEQ" border="6" color="0" x="9" y="8" height="60" width="160" html.valueishtml="0"  name=seq_t visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="67108864" )
