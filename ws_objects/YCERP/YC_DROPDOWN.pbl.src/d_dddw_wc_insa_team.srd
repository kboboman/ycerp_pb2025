$PBExportComments$인사팀과 연동되는 작업장 ddddw
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=92 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=work_no dbname="work_no" )
 column=(type=char(10) updatewhereclause=yes name=work_name dbname="work_name" )
 column=(type=char(5) updatewhereclause=yes name=insa_team dbname="insa_team" )
 retrieve="select 
	 work_no		work_no	
	,work_name 	work_name
	,insa_team	insa_team
from 
	wc 
where 
	insa_team is not null 
and 
	use_yn = 'N' 
and 
	area_no like :as_area_no
and 
	right(rtrim(work_no),2) = '00'
order by 
	area_no, work_no" arguments=(("as_area_no", string)) )
