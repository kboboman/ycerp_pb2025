release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=68 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes key=yes name=work_no dbname="wc.work_no" )
 column=(type=char(10) updatewhereclause=yes name=work_name dbname="wc.work_name" )
 column=(type=char(1) updatewhereclause=yes name=work_type dbname="wc.work_type" initial=" " )
 column=(type=char(10) updatewhereclause=yes name=work_manager dbname="wc.work_manager" initial=" " )
 column=(type=long updatewhereclause=yes name=capacity dbname="wc.capacity" initial=" " )
 column=(type=char(20) updatewhereclause=yes name=work_pos dbname="wc.work_pos" initial=" " )
 column=(type=long updatewhereclause=yes name=work_per dbname="wc.work_per" )
 column=(type=char(1) updatewhereclause=yes name=use_yn dbname="wc.use_yn" )
 retrieve="  SELECT wc.work_no,   
         wc.work_name,   
         wc.work_type,   
         wc.work_manager,   
         wc.capacity,   
         wc.work_pos,   
         wc.work_per,   
         wc.use_yn  
    FROM wc   
" update="wc" updatewhere=0 updatekeyinplace=no )
column(band=detail id=1 alignment="0" tabsequence=32766 border="0" color="0~tif ( use_yn = ~"N~" OR right(work_no,2) = ~"00~", rgb(255, 0, 0), rgb(0, 0, 0) )" x="9" y="4" height="60" width="155" format="[general]" html.valueishtml="0"  name=work_no visible="1" edit.limit=0 edit.case=any edit.focusrectangle=no edit.autoselect=no edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="0" background.color="536870912~tif ( right(work_no, 2) = ~"00~", rgb(255, 255, 100), rgb(255, 255, 255) )" )
column(band=detail id=2 alignment="0" tabsequence=32766 border="0" color="0~tif ( use_yn = ~"N~" OR right(work_no,2) = ~"00~", rgb(255, 0, 0), rgb(0, 0, 0) )" x="169" y="4" height="60" width="672" format="[general]" html.valueishtml="0"  name=work_name visible="1" edit.limit=20 edit.case=any edit.autoselect=yes edit.autohscroll=yes edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="0" background.color="536870912~tif ( right(work_no, 2) = ~"00~", rgb(255, 255, 100), rgb(255, 255, 255) )" )
column(band=detail id=8 alignment="2" tabsequence=0 border="0" color="0~tif ( use_yn = ~"N~" OR right(work_no,2) = ~"00~", rgb(255, 0, 0), rgb(0, 0, 0) )" x="841" y="4" height="60" width="87" html.valueishtml="0"  name=use_yn visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="0" background.color="536870912~tif ( right(work_no, 2) = ~"00~", rgb(255, 255, 100), rgb(255, 255, 255) )" )
