$PBExportComments$저장소현재고 DropDownDataWindow(1998/02/06 - 김구현)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=88 color="8421504" )
detail(height=88 color="553648127" )
table(column=(type=char(10) updatewhereclause=yes name=b_item_no dbname="itemloc.ITEM_NO" )
 column=(type=char(60) updatewhereclause=yes name=d_item_name dbname="itemloc.ITEM_NAME" )
 column=(type=char(20) updatewhereclause=yes name=b_qa dbname="itemloc.QA" )
 column=(type=char(10) updatewhereclause=yes name=loc_no dbname="itemloc.LOC_NO" )
 column=(type=char(30) updatewhereclause=yes name=loc_name dbname="itemloc.LOC_NAME" )
 column=(type=decimal(4) updatewhereclause=yes name=stock_qty dbname="itemloc.STOCK_QTY" )
 retrieve="SELECT    B.ITEM_NO, 
                   D.ITEM_NAME, 
                   B.QA,
                   B.LOC_NO,
                   C.LOC_NAME,
                   B.QOH STOCK_QTY                  
 FROM     ITEMLOC B WITH(NOLOCK) INNER JOIN LOCATION C WITH(NOLOCK) ON B.LOC_NO = C.LOC_NO
					                                         INNER JOIN GROUPITEM D WITH( NOLOCK) ON B.ITEM_NO = D.ITEM_NO
  WHERE B.ITEM_NO       = :AS_ITEM_NO
   AND      B.QA                  = :AS_QA
   AND      ISNULL(B.QOH,0) > 0" arguments=(("as_item_no", string),("as_qa", string))  sort="loc_no A " )
