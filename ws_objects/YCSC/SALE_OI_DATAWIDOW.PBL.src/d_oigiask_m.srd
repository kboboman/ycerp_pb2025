 column=(type=datetime update=yes updatewhereclause=yes name=log_date dbname="ask_head.log_date" )
 column=(type=char(1) updatewhereclause=yes name=ship_close dbname="ask_head.ship_close" initial="O" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"ask_head~" ) COLUMN(NAME=~"ask_head.ask_date~") COLUMN(NAME=~"ask_head.ask_loc~") COLUMN(NAME=~"ask_head.ask_user~") COLUMN(NAME=~"ask_head.rem~") COLUMN(NAME=~"ask_head.ask_no~") COLUMN(NAME=~"ask_head.proc_flag~") COLUMN(NAME=~"ask_head.act_user~") COLUMN(NAME=~"ask_head.act_date~") COLUMN(NAME=~"ask_head.f_area~") COLUMN(NAME=~"ask_head.t_area~") COLUMN(NAME=~"ask_head.log_date~") COLUMN(NAME=~"ask_head.ship_close~")WHERE(    EXP1 =~"ask_head.ask_no~"   OP =~"=~"    EXP2 =~":aa~" ) ) ARG(NAME = ~"aa~" TYPE = string) " update="ask_head" updatewhere=1 updatekeyinplace=no arguments=(("aa", string)) )
