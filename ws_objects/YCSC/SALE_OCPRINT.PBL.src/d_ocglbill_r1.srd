 column=(type=char(10) updatewhereclause=yes name=c_end dbname="c_end" )
 column=(type=datetime updatewhereclause=yes name=glbilldet_start_date dbname="glbilldet.start_date" )
 column=(type=datetime updatewhereclause=yes name=glbill_set_date dbname="glbill.set_date" )
 column=(type=char(12) updatewhereclause=yes name=glbill_bill_no dbname="glbill.bill_no" )
 column=(type=char(12) updatewhereclause=yes name=glbilldet_billdet_no dbname="glbilldet.billdet_no" )
 column=(type=char(10) updatewhereclause=yes name=c_start dbname="c_start" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"customer~" )  TABLE(NAME=~"glbill~" )  TABLE(NAME=~"glbilldet~" ) COLUMN(NAME=~"glbill.close_date~") COLUMN(NAME=~"glbill.bill_class~") COLUMN(NAME=~"glbill.bill_amount~") COLUMN(NAME=~"customer.cust_name~") COLUMN(NAME=~"glbill.draft~") COLUMN(NAME=~"glbilldet.billdet_vcno~") COLUMN(NAME=~"glbilldet.det_class~") COLUMN(NAME=~"glbilldet.amount~") COLUMN(NAME=~"glbilldet.close_date~") COLUMN(NAME=~"glbilldet.bank_code~") COLUMN(NAME=~"glbilldet.bill_area~") COLUMN(NAME=~"glbilldet.draft~") COMPUTE(NAME=~"'          ' c_end~") COLUMN(NAME=~"glbilldet.start_date~") COLUMN(NAME=~"glbill.set_date~") COLUMN(NAME=~"glbill.bill_no~") COLUMN(NAME=~"glbilldet.billdet_no~") COMPUTE(NAME=~"'          ' c_start~")    JOIN (LEFT=~"glbill.vc_no~"    OP =~"=~"RIGHT=~"glbilldet.vc_no~"    OUTER1 =~"glbill.vc_no~" )    JOIN (LEFT=~"glbill.cust_no~"    OP =~"=~"RIGHT=~"customer.cust_no~" )WHERE(    EXP1 =~"glbill.bill_class~"   OP =~"in~"    EXP2 =~":asa_class~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"glbill.set_flag~"   OP =~"in~"    EXP2 =~":asa_flag~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"glbill.close_date~"   OP =~"between~"    EXP2 =~":ad_start and :ad_end~" ) ) ARG(NAME = ~"asa_class~" TYPE = stringlist)  ARG(NAME = ~"asa_flag~" TYPE = stringlist)  ARG(NAME = ~"ad_start~" TYPE = date)  ARG(NAME = ~"ad_end~" TYPE = date) " arguments=(("asa_class", stringlist),("asa_flag", stringlist),("ad_start", date),("ad_end", date)) )
