$PBExportHeader$d_iractio_s.srd
$PBExportComments$실사차이보고서(2000/09/02,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=char(30) updatewhereclause=yes name=loc_name dbname="loc_name" )
 column=(type=decimal(4) updatewhereclause=yes name=qoh dbname="qoh" initial="0" )
 column=(type=decimal(2) updatewhereclause=yes name=eom_qoh dbname="eom_qoh" )
 column=(type=char(26) updatewhereclause=yes name=title dbname="title" )
 retrieve="SELECT item_no     
     , qa          
     , item_name   
     , uom      
     , loc_name 
     , qoh     = isnull(SUM(eom_qoh),0)   /* 실사수량 */
     , eom_qoh = isnull(SUM(cineoym.eom_qoh),0) - isnull(SUM(cineoym.def_qty),0)
     , title    
   FROM ( 
        SELECT ineoym.item_no                       
             , ineoym.qa                            
             , groupitem.item_name                  
             , uom     = dbo.uf_getuom(groupitem.uom)   
             , eom_qoh = ineoym.qoh              
             , def_qty = 0                       
             , loc_name                          
             , title   =  convert(char(4),:as_year) + '년 ' + convert(char(2), :as_mon) + '월 실사차이보고서'
          FROM ineoym    (nolock)
             , groupitem (nolock)
             , location  (nolock)
         WHERE ( ineoym.item_no      = groupitem.item_no            ) 
           AND ( ineoym.item_no      < 'PZZZ'                       ) 
           AND ( ineoym.item_no NOT IN ('GZZZMISZZZ', 'GCYZZZZZZZ') ) /* 기타(Y.S.P), 전월착오분 */
           AND ( use_flag           <> 'C'                          )  
           AND ( ineoym.loc_no       = location.loc_no              )   
           AND ( ( ineoym.loc_no     = :as_loc                      ) AND  
                 ( ineoym.cyear      = :as_year                     ) AND  
                 ( ineoym.cmon       = :as_mon                      ) AND  
                 ( NOT(groupitem.uom = 'M2' AND groupitem.item_no like 'PCY%')         ) AND
               /*( left(ineoym.item_no, 2) <> 'M1' AND left(ineoym.item_no, 2) <> 'M3' ) AND*/
                 ( ineoym.item_no  LIKE :as_item AND groupitem.item_name like :as_name ) 
               )          
               
        UNION ALL
        SELECT item_no = inaudit.inaudit_item                   
             , inaudit.qa                                       
             , groupitem.item_name                              
             , uom     = dbo.uf_getuom(groupitem.uom)               
             , eom_qoh = 0                                   
             , def_qty = inaudit.rcpt_qty - inaudit.issue_qty
             , loc_name
             , title   = convert(char(4),:as_year) + '년 ' + convert(char(2), :as_mon) + '월 실사차이보고서'
          FROM inaudit    (nolock)
             , location   (nolock)
             , groupitem  (nolock)
         WHERE ( ( DATEPART(year,  inaudit.inaudit_date) = :as_year ) AND  
                 ( DATEPART(month, inaudit.inaudit_date) = :as_mon  )  ) 
           AND ( inaudit.inaudit_type       in ('RX', 'IX')  ) 
         /*AND ( inaudit.inaudit_item NOT LIKE 'M1%' AND inaudit.inaudit_item NOT LIKE 'M3%' )*/
           AND ( inaudit.inaudit_item     LIKE :as_item          )   
           AND ( inaudit.loc_no              = :as_loc           )   
           AND ( inaudit.loc_no              = location.loc_no   )   
           AND ( inaudit.inaudit_item        = groupitem.item_no )   
           AND ( NOT(groupitem.uom = 'M2'  and groupitem.item_no like 'PCY%') )
           AND ( groupitem.item_no      < 'PZZZ'                       ) 
           AND ( groupitem.item_no NOT IN ('GZZZMISZZZ', 'GCYZZZZZZZ') ) /* 기타(Y.S.P), 전월착오분 */
           AND ( use_flag              <> 'C'                          )  
           AND ( groupitem.item_name LIKE :as_name                     ) 
        ) cineoym 
    GROUP BY item_no, qa, item_name, uom, loc_name, title
" arguments=(("as_loc", string),("as_year", string),("as_mon", string),("as_item", string),("as_name", string))  sort="item_name A qa A " )
