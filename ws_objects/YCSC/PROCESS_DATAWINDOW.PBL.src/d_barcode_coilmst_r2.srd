$PBExportComments$10 x 3 코일 속(분리)
release 8;
datawindow(units=3 timer_interval=0 color=1073741824 processing=2 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 0 print.margin.right = 0 print.margin.top = 0 print.margin.bottom = 0 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no label.name="Pin Fed Address 3.5x.94  4097,4145/63/77" label.width=10000 label.height=5000 label.rows=1 label.rows.spacing=0 label.columns=1 label.columns.spacing=0 label.topdown=no label.sheet=no label.shape=roundrectangle label.ellipse_height=0 label.ellipse_width=0 )
detail(height=5000 color="536870912" )
table(column=(type=char(6) updatewhereclause=yes name=swid dbname="swid" )
 column=(type=long updatewhereclause=yes name=cnt dbname="cnt" )
 column=(type=long updatewhereclause=yes name=unit_qty dbname="unit_qty" )
 column=(type=char(37) updatewhereclause=yes name=thin dbname="thin" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=long updatewhereclause=yes name=length dbname="length" )
 column=(type=char(20) updatewhereclause=yes name=coilsfcday_coil_no dbname="coil_no" )
 retrieve="SELECT swid = convert(varchar(6), convert (decimal (5,1), substring(coilmst.qa,5,4) + '.' 
					+ substring(coilmst.qa, 10,1))),   
       cnt = coilmst.qcnt,
		 unit_qty = coilmst.unit_qty,
			thin = convert(varchar(6), convert (decimal (3,2), substring(coilmst.qa,1,1) + '.' 
					+ substring(coilmst.qa, 2,2))) + ' * ' 
					+ convert(varchar(6), convert (decimal (5,1), substring(coilmst.qa,5,4) + '.' 
								+ substring(coilmst.qa, 10,1))) + ' * ' 
					+ convert(varchar(8),coilmst.unit_qty) + ' * '
					+ convert(varchar(8), convert(integer,coilmst.length)),   
		 groupitem.item_name,
		 length = coilmst.length,
		 coil_no = coilmst.coil_no
  FROM coilmst,
		 groupitem
 WHERE ( coilmst.item_no = groupitem.item_no ) and
		 ( coilmst.coil_no = :as_coil ) and
		 ( coilmst.loc_no = :as_loc ) 

" arguments=(("as_coil", string),("as_loc", string)) )
