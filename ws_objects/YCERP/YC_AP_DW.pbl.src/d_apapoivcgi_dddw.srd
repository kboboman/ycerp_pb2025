$PBExportHeader$d_apapoivcgi_dddw.srd
$PBExportComments$자재지불관리 지불 타수어음 선택 dropdowndatawindow(1999/05/24, 이인호)
release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=decimal(0) updatewhereclause=yes name=bill_amount dbname="apbill.bill_amount" )
 column=(type=datetime updatewhereclause=yes name=close_date dbname="apbill.close_date" )
 column=(type=datetime updatewhereclause=yes name=start_date dbname="apbill.start_date" )
 column=(type=char(6) updatewhereclause=yes name=bank_code dbname="apbill.bank_code" )
 column=(type=char(20) updatewhereclause=yes name=bill_area dbname="apbill.bill_area" )
 column=(type=char(12) updatewhereclause=yes name=vc_no dbname="apbill.vc_no" )
 column=(type=char(20) updatewhereclause=yes name=draft dbname="apbill.draft" )
 column=(type=char(12) updatewhereclause=yes name=bill_no dbname="apbill.bill_no" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"apbill~" ) COLUMN(NAME=~"apbill.bill_amount~") COLUMN(NAME=~"apbill.close_date~") COLUMN(NAME=~"apbill.start_date~") COLUMN(NAME=~"apbill.bank_code~") COLUMN(NAME=~"apbill.bill_area~") COLUMN(NAME=~"apbill.vc_no~") COLUMN(NAME=~"apbill.draft~") COLUMN(NAME=~"apbill.bill_no~")WHERE(    EXP1 =~"( apbill.bill_class~"   OP =~"=~"    EXP2 =~"'R' )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( apbill.set_flag~"   OP =~"=~"    EXP2 =~"'N' )~" ) ) " )
column(band=detail id=8 alignment="0" tabsequence=0 border="0" color="0" x="9" y="4" height="64" width="384"  name=bill_no  font.face="굴림체" font.height="-10" font.weight="400"  font.family="2" font.pitch="2" font.charset="129" background.mode="2" background.color="16777215" )
htmltable(border="1" cellpadding="0" cellspacing="0" generatecss="no" nowrap="yes")