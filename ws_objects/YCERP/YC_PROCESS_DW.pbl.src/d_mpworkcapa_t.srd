footer(height=0 color="536870912" )
detail(height=0 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=routtempnew_work_date dbname="routtempnew.WORK_DATE" )
 column=(type=decimal(4) updatewhereclause=yes name=cworkcapa dbname="WORKCAPA" )
 retrieve="  SELECT ROUTTEMPNEW.WORK_DATE
       , WORKCAPA = SUM( PLAN_QTY * (CASE CONVERT( INT, (ROUTTEMPNEW.SETUP_TIME + ROUTTEMPNEW.WORK_TIME) ) / 60 
                                          WHEN 0       THEN 1 
                                          ELSE CONVERT( INT, (ROUTTEMPNEW.SETUP_TIME + ROUTTEMPNEW.WORK_TIME) ) / 60  
                                     END) )   
    FROM ROUTTEMPNEW
       , WC  
   WHERE ( ROUTTEMPNEW.WC_NO       = WC.WORK_NO ) 
     AND ( ( ROUTTEMPNEW.WC_NO     = :ARG_WC  ) AND  
           ( ROUTTEMPNEW.PLAN_FLAG = 'Y'      ) AND  
           ( ROUTTEMPNEW.WORK_DATE BETWEEN :ARG_DATE1 AND :ARG_DATE2 ) AND  
           ( ROUTTEMPNEW.AREA_NO   = :AS_AREA ) 
         )   
   GROUP BY ROUTTEMPNEW.WORK_DATE   
" arguments=(("arg_wc", string),("arg_date1", date),("arg_date2", date),("as_area", string))  sort="routtempnew_work_date A " )
