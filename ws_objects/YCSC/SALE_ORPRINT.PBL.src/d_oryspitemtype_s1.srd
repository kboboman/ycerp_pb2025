$PBExportHeader$d_oryspitemtype_s1.srd
$PBExportComments$YSP TYPE별 수주현황(2003/03/12,임기천)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no  crosstab.dynamic = yes grid.lines=0 grid.columnmove=no selected.mouse=no )
header[1](height=64 color="536870912" )
header[2](height=80 color="536870912" )
summary(height=80 color="536870912" )
footer(height=0 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa1 dbname="qa1" )
 column=(type=number updatewhereclause=yes name=flag dbname="flag" )
 column=(type=number updatewhereclause=yes name=qty dbname="qty" )
 retrieve="SELECT groupitem.item_name,
		substring(groupitem.item_no, 1, 6),
			qa1 = substring(saledet.qa, 1,3),
			mon = right('00' + rtrim(convert(char(2), datepart(month, sale.order_date))) ,2) +~"월~",
         qty = case when groupitem.item_no = 'PCYSYSEBZZ' then sum(saledet.order_qty) / 2 else sum(saledet.order_qty) end, 
			flag = case substring(groupitem.item_no, 1, 6) when 'PCYSZ1' then 1 when 'PCYSZ2' then 2 
																		when 'PCYSZ3' then 3 else 4 end
    FROM sale,   
         saledet,
			groupitem	
   WHERE ( sale.order_no = saledet.order_no) and  
			( sale.order_no like ~"B%~" ) AND 
         ( sale.order_date between :ad_start and :ad_end ) and
         ( saledet.item_no = groupitem.item_no ) and  
         ( (( saledet.item_no like 'PCYSYS%' ) or ( saledet.item_no like 'GCYSYS%' ) or ( saledet.item_no like 'PCYSZ%' )) )
group by sale.order_date, groupitem.item_no, groupitem.item_name, saledet.qa
order by sale.order_date,  groupitem.item_no, groupitem.item_name, saledet.qa" arguments=(("ad_start", date),("ad_end", date))  sort="item_name A qa1 A flag A " )
group(level=1 header.height=8 trailer.height=80 by=("flag" ) header.color="536870912" trailer.color="536870912" )
group(level=2 header.height=0 trailer.height=80 by=("item_name" ) header.color="536870912" trailer.color="536870912" )
compute(band=header[1] alignment="0" expression="string( ad_start, 'yyyy/mm' ) + trim('~~ ')  +  string(  ad_end, 'yyyy/mm' ) "border="0" color="0" x="9" y="0" height="60" width="603" format="[general]" html.valueishtml="0"  name=compute_1 visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
text(band=header[2] alignment="0" text="품명" border="0" color="0" x="9" y="16" height="60" width="599" html.valueishtml="0"  name=item_name_t visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="12632256" )
text(band=header[2] alignment="0" text="규격" border="0" color="0" x="617" y="16" height="60" width="137" html.valueishtml="0"  name=qa1_t visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="12632256" )
text(band=header[2] alignment="0" text="@mon" border="0" color="0" x="777" y="16" height="60" width="425" html.valueishtml="0"  name=qty_t visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="12632256" )
text(band=header[2] alignment="2" text="수량합계" border="0" color="0" x="1211" y="16" height="60" width="466" html.valueishtml="0"  name=grand_sum_qty_t visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="12639424" )
column(band=detail id=3 alignment="1" tabsequence=32766 border="0" color="16777215" x="763" y="4" height="72" width="5" format="[general]" html.valueishtml="0"  name=flag visible="1" edit.limit=0 edit.case=any edit.focusrectangle=no edit.autoselect=yes edit.autohscroll=yes edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
compute(band=detail alignment="1" expression="crosstabsum(1)"border="0" color="0" x="1211" y="4" height="72" width="466" format="#,##0.00" html.valueishtml="0"  name=grand_sum_qty visible="1"  font.face="굴림체" font.height="-10" font.weight="700"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="12639424" )
column(band=detail id=4 alignment="1" tabsequence=32766 border="0" color="0" x="777" y="4" height="72" width="425" format="#,##0.00" html.valueishtml="0"  name=qty visible="1" edit.limit=0 edit.case=any edit.focusrectangle=no edit.autoselect=no edit.autohscroll=yes edit.imemode=0 crosstab.repeat=yes  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
column(band=detail id=2 alignment="0" tabsequence=32766 border="0" color="0" x="617" y="4" height="72" width="137" format="[general]" html.valueishtml="0"  name=qa1 visible="1" edit.limit=6 edit.case=any edit.focusrectangle=no edit.autoselect=no edit.autohscroll=yes edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
column(band=detail id=1 alignment="0" tabsequence=32766 border="0" color="0" x="9" y="4" height="72" width="599" format="[general]" html.valueishtml="0"  name=item_name visible="1" edit.limit=60 edit.case=any edit.focusrectangle=no edit.autoselect=no edit.autohscroll=yes edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
text(band=trailer.2 alignment="1" text="~"소계~"" border="0" color="0" x="9" y="4" height="72" width="599" html.valueishtml="0"  name=t_1 visible="1"  font.face="굴림체" font.height="-10" font.weight="700"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="15780518" )
compute(band=trailer.2 alignment="1" expression="sum(qty for group 2)"border="0" color="0" x="777" y="4" height="72" width="425" format="#,##0.00" html.valueishtml="0"  name=compute_2 visible="1"  font.face="굴림체" font.height="-10" font.weight="700"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="15780518" )
compute(band=trailer.2 alignment="1" expression="sum(grand_sum_qty for group 2)"border="0" color="0" x="1211" y="4" height="72" width="466" format="#,##0.00" html.valueishtml="0"  name=compute_3 visible="1"  font.face="굴림체" font.height="-10" font.weight="700"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="15780518" )
compute(band=trailer.1 alignment="1" expression="sum(grand_sum_qty for group 1)"border="0" color="0" x="1211" y="4" height="72" width="466" format="#,##0.00" html.valueishtml="0"  name=compute_4 visible="1"  font.face="굴림체" font.height="-10" font.weight="700"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="12639424" )
compute(band=trailer.1 alignment="1" expression="case( flag when 1 then '~"일체형 합계~"' when 2 then '~"U형 합계~"' when 3 then '~"분리형 합계~"'when 4 then '~"기타 합계~"' )"border="0" color="0" x="9" y="4" height="72" width="599" format="[general]" html.valueishtml="0"  name=compute_5 visible="1"  font.face="굴림체" font.height="-10" font.weight="700"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="12639424" )
compute(band=trailer.1 alignment="1" expression="sum(qty for group 1)"border="0" color="0" x="777" y="4" height="72" width="425" format="#,##0.00" html.valueishtml="0"  name=compute_6 visible="1"  font.face="굴림체" font.height="-10" font.weight="700"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="12639424" )
text(band=summary alignment="1" text="~"총계~"" border="0" color="8388608" x="9" y="4" height="72" width="599" html.valueishtml="0"  name=t_2 visible="1"  font.face="굴림체" font.height="-10" font.weight="700"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="79741120" )
compute(band=summary alignment="1" expression="sum(qty for all )"border="0" color="8388608" x="777" y="4" height="72" width="425" format="#,##0.00" html.valueishtml="0"  name=compute_7 visible="1"  font.face="굴림체" font.height="-10" font.weight="700"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="79741120" )
compute(band=summary alignment="1" expression="sum(grand_sum_qty for all )"border="0" color="8388608" x="1211" y="4" height="72" width="466" format="#,##0.00" html.valueishtml="0"  name=compute_8 visible="1"  font.face="굴림체" font.height="-10" font.weight="700"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="79741120" )
 crosstab(band = foreground  crosstabonly = yes 
 columns = "mon" rows = "item_name, qa1, flag" values = "sum(qty for crosstab)" sourcenames = "item_name, compute_0002, qa1, mon, qty, flag")
sparse(names="item_name	qa1")htmltable(border="1" )
