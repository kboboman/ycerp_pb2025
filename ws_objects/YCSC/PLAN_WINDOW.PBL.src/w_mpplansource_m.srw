event clicked;long ll_row

ll_row = dw3.getrow()
if ll_row < 1 then return

gs_where lst_where

int ls_a
ls_a = dw3.GetClickedColumn()

lst_where.str1 = trim(dw3.object.item_no[ll_row])
lst_where.str2 = trim(dw3.object.qa[ll_row])
