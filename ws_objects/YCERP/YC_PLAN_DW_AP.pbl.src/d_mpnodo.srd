release 8;
datawindow(units=0 timer_interval=0 color=67108864 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=912 color="536870912" )
table(column=(type=char(14) update=yes updatewhereclause=yes key=yes name=order_no dbname="ORDER_NO" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=seq_no dbname="SEQ_NO" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="ITEM_NO" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="QA" )
 column=(type=char(100) update=yes updatewhereclause=yes name=rem dbname="REM" )
 column=(type=char(8) update=yes updatewhereclause=yes name=do_plan_date dbname="do_plan_DATE" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=do_plan_qty dbname="do_plan_qty" )
 retrieve="SELECT	sale_nodo.ORDER_NO,
			sale_nodo.SEQ_NO,
			saledet.ITEM_NO,
			saledet.QA,
			sale_nodo.REM,
			sale_nodo.do_plan_DATE,
			sale_nodo.do_plan_qty
  FROM	sale_nodo inner join saledet on sale_nodo.order_no = saledet.order_no and sale_nodo.seq_no = saledet.seq_no
 WHERE	sale_nodo.ORDER_NO  =  :ag_order_no
   AND    sale_nodo.seq_no = :ag_seq_no
   AND	saledet.ITEM_NO   =  :ag_item_no
   AND	saledet.QA        =  :ag_qa" update="sale_nodo" updatewhere=0 updatekeyinplace=no arguments=(("ag_order_no", string),("ag_seq_no", number),("ag_item_no", string),("ag_qa", string)) )
