 column=(type=char(100) updatewhereclause=yes name=proc10 dbname="custdiary.proc10" )
 column=(type=char(1) updatewhereclause=yes name=process_flag dbname="custdiary.process_flag" initial="N" )
 column=(type=char(1) updatewhereclause=yes name=check2 dbname="custdiary.check2" )
 column=(type=char(1) updatewhereclause=yes name=urgent dbname="custdiary.urgent" initial="N" values="	Y/	N" )
 column=(type=datetime updatewhereclause=yes name=sys_date dbname="custdiary.sys_date" )
 column=(type=char(10) updatewhereclause=yes name=approve_team dbname="custdiary.approve_team" )
 column=(type=datetime updatewhereclause=yes name=check_date dbname="custdiary.check_date" )
 column=(type=char(10) updatewhereclause=yes name=approve_top dbname="custdiary.approve_top" )
 column=(type=char(1) updatewhereclause=yes name=chk_team dbname="chk_team" )
 column=(type=char(30) updatewhereclause=yes name=team_team_name dbname="team.team_name" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name dbname="login.user_name" )
 retrieve="  SELECT custdiary.diary_date,   
         custdiary.emp_no,   
         custdiary.seq_no,   
         custdiary.team_code,   
         custdiary.cust_no,   
         custdiary.cust_name,   
         custdiary.bdcust_no,   
         custdiary.bdcust_name,   
         custdiary.start_time,   
         custdiary.end_time,   
         custdiary.desc1,   
         custdiary.desc2,   
         custdiary.desc3,   
         custdiary.desc4,   
         custdiary.desc5,   
         custdiary.desc6,   
         custdiary.desc7,   
         custdiary.desc8,   
         custdiary.desc9,   
         custdiary.desc10,   
         custdiary.proc1,   
         custdiary.proc2,   
         custdiary.proc3,   
         custdiary.proc4,   
         custdiary.proc5,   
         custdiary.proc6,   
         custdiary.proc7,   
         custdiary.proc8,   
         custdiary.proc9,   
         custdiary.proc10,   
         custdiary.process_flag,   
         custdiary.check2,   
         custdiary.urgent,   
         custdiary.sys_date,   
         custdiary.approve_team,   
         custdiary.check_date,   
         custdiary.approve_top,   
         chk_team = ( case when ( custdiary.approve_team is null ) or (  custdiary.approve_team = '') then 'N' else 'Y' end ),
			team.team_name,   
			login.user_name  
    FROM custdiary left outer join login on custdiary.emp_no = login.user_id
			                left outer join team on custdiary.team_code = team.team_code
   WHERE ( convert(varchar(10),diary_date , 112) + rtrim(emp_no) + convert(varchar, seq_no) in (:as_no) )" arguments=(("as_no", stringlist))  sort="team_team_name A login_user_name A diary_date A " )
