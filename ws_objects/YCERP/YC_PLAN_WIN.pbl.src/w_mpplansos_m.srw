integer x = 2455
integer y = 568
integer width = 142
integer height = 88
integer taborder = 90
integer textsize = -10
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string picturename = "c:\bmp\delete.bmp"
alignment htextalign = left!
end type

event clicked;// 행삭제
string ls_sosno, ls_sdate, ls_edate
long	 ll_row, ll_cnt, ll_max

ls_sdate = em_1.text
ls_edate = em_2.text

for ll_row = 1 to dw6.rowcount()
	if dw6.object.chk[ll_row] = "Y" then
		ll_cnt = ll_cnt + 1
	end if
next		
if MessageBox("삭제",string(ll_cnt) + " 행 삭제 하시겠습니까?",question!,okcancel!,2) = 2 then RETURN

ll_cnt = 0
ll_max = dw6.rowcount()

dw6.setredraw( false )
for ll_row = dw6.rowcount() to 1 step -1
	if dw6.object.chk[ll_row] = "Y" then
		ll_cnt = ll_cnt + 1
		dw6.deleterow( ll_row )
	end if
next
dw6.setredraw( true )
cbx_all.checked = false

if ll_max = ll_cnt then		// 행전체 삭제됨
	ls_sosno = dw5.object.sos_no[1]
	if MessageBox("삭제","신청번호 : " + ls_sosno + "~n~n삭제 하시겠습니까?",question!,okcancel!,1) = 1 then	
		dw5.deleterow(1)
		if wf_update1(dw5,"N") = false then
			RETURN
		else
			MessageBox("확인","신청번호 : " + ls_sosno + "~n~n삭제 완료.")
		end if
		
		dw4.retrieve( ls_sdate, ls_edate )	// 신청목록 조회
	end if
else
	MessageBox("확인", string(ll_cnt) + " 건 행삭제 하였습니다.")
end if		

end event

