detail(height=72 color="536870912" )
table(column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=datetime updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=datetime updatewhereclause=yes name=edate dbname="edate" )
 column=(type=datetime updatewhereclause=yes name=do_do_date dbname="do.do_date" )
 column=(type=char(20) updatewhereclause=yes name=dodet_qa dbname="dodet.qa" )
 column=(type=char(20) updatewhereclause=yes name=dodet_coil_no dbname="dodet.coil_no" )
 column=(type=long updatewhereclause=yes name=dodet_cnt dbname="dodet.cnt" )
 column=(type=decimal(4) updatewhereclause=yes name=coilmst_unit_qty dbname="sheetmst.unit_qty" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(1) updatewhereclause=yes name=coilmst_etc_no dbname="etc_no" )
 retrieve="  SELECT groupitem.item_name                              
       , sdate = convert(smalldatetime, :ad_start, 111)   
       , edate = convert(smalldatetime, :ad_end, 111)     
       , do.do_date                                       
       , dodet.qa                                         
       , dodet.coil_no                                    
       , dodet.cnt                                        
       , sheetmst.unit_qty                                 
       , customer.cust_name                            
       , etc_no = ''
FROM dodet with(nolock) inner join groupitem with(nolock) on  dodet.item_no = groupitem.item_no
								  inner join do with(nolock) on dodet.do_no = do.do_no
								  inner join sheetmst with(nolock) on dodet.coil_no = sheetmst.sheet_no and dodet.loc_no = sheetmst.loc_no
								  inner join customer with(nolock) on do.cust_no = customer.cust_no
WHERE ( ( do.do_date    BETWEEN :ad_start AND :ad_end ) AND  
                 ( sheetmst.flag       = :as_flag              ) AND  
                 ( dodet.coil_no  IS NOT NULL                  ) 
               )    
" arguments=(("ad_start", date),("ad_end", date),("as_flag", string))  sort="do_do_date A groupitem_item_name A mid(dodet_qa, 5, 6) A dodet_qa A " )
group(level=1 header.height=80 trailer.height=68 by=("do_do_date" ) header.color="15780518" trailer.color="79741120" )
group(level=2 header.height=0 trailer.height=76 by=("groupitem_item_name" ) header.color="536870912" trailer.color="536870912" )
