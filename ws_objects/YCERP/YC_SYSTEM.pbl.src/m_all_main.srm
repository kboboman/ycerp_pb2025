global type m_all_main from menu
mf mf
mo mo
mi mi
mm mm
mt mt
mw mw
ma ma
end type
global m_all_main m_all_main

type variables
PowerObject ipo_parent
String is_prog_id, is_mode

end variables

forward prototypes
public function string mf_getid ()
public function string mf_gettext ()
public subroutine mf_setid (string as_prog_id)
public subroutine mf_setobj (powerobject apo_obj)
public subroutine mf_settext (string as_menu_nm)
end prototypes

public function string mf_getid ();// Function Name : mf_getid
// Return Type   : String
// Access        : Public
Return is_prog_id
end function

public function string mf_gettext ();// Function Name : mf_gettext
// Return Type   : String
// Access        : Public
Return This.Text
end function

public subroutine mf_setid (string as_prog_id);// Function Name : mf_setid
// Return Type   : None
// Access        : Public
// Argument Name : as_prog_id
// Argument Type : string
// Pass By       : value

is_prog_id = as_prog_id
end subroutine

public subroutine mf_setobj (powerobject apo_obj);// Function Name : mf_setobj
// Return Type   : None
// Access        : Public
// Argument Name : apo_obj
// Argument Type : powerobject
// Pass By       : value
ipo_parent = apo_obj
end subroutine

public subroutine mf_settext (string as_menu_nm);// Function Name : mf_settext
// Return Type   : None
// Access        : Public
// Argument Name : as_menu_nm
// Argument Type : string
// Pass By       : value
This.Text = as_menu_nm
end subroutine

on m_all_main.create
m_all_main=this
call super::create
this.mf=create mf
this.mo=create mo
this.mi=create mi
this.mm=create mm
this.mt=create mt
this.mw=create mw
this.ma=create ma
this.Item[UpperBound(this.Item)+1]=this.mf
this.Item[UpperBound(this.Item)+1]=this.mo
this.Item[UpperBound(this.Item)+1]=this.mi
this.Item[UpperBound(this.Item)+1]=this.mm
this.Item[UpperBound(this.Item)+1]=this.mt
this.Item[UpperBound(this.Item)+1]=this.mw
this.Item[UpperBound(this.Item)+1]=this.ma
end on

on m_all_main.destroy
call super::destroy
destroy(this.mf)
destroy(this.mo)
destroy(this.mi)
destroy(this.mm)
destroy(this.mt)
destroy(this.mw)
destroy(this.ma)
end on

event clicked;
//
end event

type mf from menu within m_all_main
m_sales m_sales
mf0 mf0
end type

on mf.create
call super::create
this.text = "파일(&F)"
this.m_sales=create m_sales
this.mf0=create mf0
this.Item[UpperBound(this.Item)+1]=this.m_sales
this.Item[UpperBound(this.Item)+1]=this.mf0
end on

on mf.destroy
call super::destroy
destroy(this.m_sales)
destroy(this.mf0)
end on

type m_sales from menu within mf
end type

event clicked;//
OpenSheet(w_o_process,parentwindow,6, original!)

end event

on m_sales.create
call super::create
this.text = "물류업무 프로세서"
end on

on m_sales.destroy
call super::destroy
end on

type mf0 from menu within mf
end type

on mf0.create
call super::create
this.text = "시스템 종료(&E)"
end on

on mf0.destroy
call super::destroy
end on

event clicked;halt close
end event

