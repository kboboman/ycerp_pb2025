 retrieve="  SELECT inaudit.id,   
         inaudit.inaudit_time,   
         inaudit.inaudit_date,   
         inaudit.inaudit_item,   
         inaudit.qa,   
         inaudit.loc_no,   
         inaudit.inaudit_type,   
         inaudit.order_no,   
         inaudit.rcpt_qty,   
         inaudit.issue_qty,   
         inaudit.cost,   
         inaudit.destination,   
         inaudit.serial_id,   
         inaudit.rem,   
         inaudit.unit_qty,   
         inaudit.cnt,   
         inaudit.com_qty,   
         inaudit.user_id  
    FROM inaudit   
" update="inaudit" updatewhere=0 updatekeyinplace=no )
