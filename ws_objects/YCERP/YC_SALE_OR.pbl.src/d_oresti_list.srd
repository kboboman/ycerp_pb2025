table(column=(type=char(14) update=yes updatewhereclause=yes name=estimate_no dbname="estimate_det.estimate_no" )
 column=(type=long update=yes updatewhereclause=yes name=seq_no dbname="estimate_det.seq_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="estimate_det.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="estimate_det.qa" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="estimate_det.uom" )
 column=(type=long updatewhereclause=yes name=qoh dbname="qoh" )
 column=(type=decimal(3) update=yes updatewhereclause=yes name=order_qty dbname="estimate_det.order_qty" initial="0" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=acc_qty dbname="estimate_det.acc_qty" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=unit_cost dbname="estimate_det.unit_cost" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=item_amt dbname="estimate_det.item_amt" initial="0" )
 column=(type=char(30) update=yes updatewhereclause=yes name=rem dbname="estimate_det.rem" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="GroupItem.item_name" )
 retrieve="  SELECT estimate_det.estimate_no
       , estimate_det.seq_no
       , estimate_det.item_no
       , estimate_det.qa
       , estimate_det.uom
       , qoh   = 0
       , estimate_det.order_qty
       , estimate_det.acc_qty
       , estimate_det.unit_cost
       , estimate_det.item_amt
       , estimate_det.rem
       , groupitem.item_name
    FROM estimate_det LEFT OUTER JOIN groupitem ON estimate_det.item_no  = groupitem.item_no
   WHERE ( estimate_det.estimate_no = :as_estino       )    
" arguments=(("as_estino", string))  sort="seq_no A " )
