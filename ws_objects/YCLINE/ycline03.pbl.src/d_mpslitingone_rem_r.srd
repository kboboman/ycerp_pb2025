detail(height=264 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=coilorderdet_order_no dbname="coilorderdet.order_no" )
 column=(type=char(40) updatewhereclause=yes name=coilorderdet_rem dbname="coilorderdet.rem" )
 column=(type=char(40) updatewhereclause=yes name=rem1 dbname="rem1" )
 column=(type=char(40) updatewhereclause=yes name=rem2 dbname="rem2" )
 column=(type=char(40) updatewhereclause=yes name=rem3 dbname="rem3" )
 column=(type=char(40) updatewhereclause=yes name=rem4 dbname="rem4" )
 column=(type=char(40) updatewhereclause=yes name=rem5 dbname="rem5" )
 retrieve="SELECT coilorderdet.order_no   
     , coilorderdet.rem     
     , coilorderdet.rem1    
     , coilorderdet.rem2    
     , coilorderdet.rem3    
     , coilorderdet.rem4    
     , coilorderdet.rem5
  FROM coilmst        
     , coilorder      
     , coilorderdet   
     , coilsliting    
     , groupitem  
 WHERE ( coilorderdet.order_no = coilsliting.order_no         )   
   and ( coilorder.order_no    = coilorderdet.coilorder_order )   
   and ( coilorderdet.coil_no  = coilmst.coil_no              )   
   and ( coilmst.item_no       = groupitem.item_no            )   
   and ( coilorderdet.loc_no   = coilmst.loc_no               )   
   and ( coilorderdet.order_no = :as_order_no                 )
" arguments=(("as_order_no", string)) )
