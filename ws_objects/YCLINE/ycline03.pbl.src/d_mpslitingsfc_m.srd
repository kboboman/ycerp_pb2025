 column=(type=long updatewhereclause=yes name=coilorderdet_div dbname="coilorderdet.div" values="없음	1/2등분	2/3등분	3/4등분	4/5등분	5/" )
 column=(type=long updatewhereclause=yes name=coilmst_length dbname="coilmst.length" )
 column=(type=char(60) updatewhereclause=yes name=witem_name dbname="groupitem.item_name" )
 column=(type=char(20) updatewhereclause=yes name=coilmst_qa dbname="coilmst.qa" )
 column=(type=long updatewhereclause=yes name=wunit dbname="wunit" )
 column=(type=char(14) update=yes updatewhereclause=yes key=yes name=order_no dbname="coilsfcday.order_no" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=seq dbname="coilsfcday.seq" )
 column=(type=datetime update=yes updatewhereclause=yes key=yes name=sfc_date dbname="coilsfcday.sfc_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=wc_no dbname="coilsfcday.wc_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=wc_place dbname="coilsfcday.wc_place" )
 column=(type=char(10) update=yes updatewhereclause=yes name=supp_no dbname="coilsfcday.supp_no" )
 column=(type=decimal(1) update=yes updatewhereclause=yes name=w_wid dbname="coilsfcday.w_wid" )
 column=(type=decimal(1) update=yes updatewhereclause=yes name=wid dbname="coilsfcday.wid" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="coilsfcday.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="coilsfcday.qa" )
 column=(type=long update=yes updatewhereclause=yes name=unit_qty dbname="coilsfcday.unit_qty" )
 column=(type=long update=yes updatewhereclause=yes name=cnt dbname="coilsfcday.cnt" )
 column=(type=char(4) update=yes updatewhereclause=yes name=color_no dbname="coilsfcday.color_no" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=length dbname="coilsfcday.length" )
 column=(type=char(1) update=yes updatewhereclause=yes name=proc_flag dbname="coilsfcday.proc_flag" )
 column=(type=char(30) update=yes updatewhereclause=yes name=rem dbname="coilsfcday.rem" )
 column=(type=char(1) update=yes updatewhereclause=yes name=sheet dbname="coilsfcday.sheet" )
 column=(type=char(1) update=yes updatewhereclause=yes name=work_type dbname="coilsfcday.work_type" values="등분	D/합체	S/" )
 column=(type=long updatewhereclause=yes name=coilorderdet_cnt dbname="coilorderdet.cnt" )
 column=(type=char(10) update=yes updatewhereclause=yes name=loc_no dbname="coilsfcday.loc_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=wloc_no dbname="coilsfcday.wloc_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=w_coil_no dbname="coilsfcday.w_coil_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=coil_no dbname="coilsfcday.coil_no" )
 column=(type=char(2) updatewhereclause=yes name=etc_no dbname="coilmst.etc_no" )
 column=(type=number update=yes updatewhereclause=yes name=qc_chk1 dbname="qc_chk1" )
 column=(type=number update=yes updatewhereclause=yes name=qc_chk2 dbname="qc_chk2" )
 column=(type=number update=yes updatewhereclause=yes name=qc_chk3 dbname="qc_chk3" )
 retrieve="  SELECT groupitem_a.item_name,   
         coilmst.loc_no,   
         coilorderdet.coilorder_order,   
         coilorderdet.order_seq,   
         coilorderdet.div,   
         coilmst.length,   
         groupitem_b.item_name,   
         coilmst.qa,   
         wunit = coilmst.unit_qty * coilmst.cnt,   
         coilsfcday.order_no,   
         coilsfcday.seq,   
         coilsfcday.sfc_date,   
         coilsfcday.wc_no,   
         coilsfcday.wc_place,   
         coilsfcday.supp_no,   
         coilsfcday.w_wid,   
         coilsfcday.wid,   
         coilsfcday.item_no,   
         coilsfcday.qa,   
         coilsfcday.unit_qty,   
         coilsfcday.cnt,   
         coilsfcday.color_no,   
         coilsfcday.length,   
         coilsfcday.proc_flag,   
         coilsfcday.rem,   
         coilsfcday.sheet,   
         coilsfcday.work_type,   
         coilorderdet.cnt,   
         coilsfcday.loc_no,   
         coilsfcday.wloc_no,   
         coilsfcday.w_coil_no,   
         coilsfcday.coil_no,   
         coilmst.etc_no,
			coilsfcday.qc_chk1,  
			coilsfcday.qc_chk2,
			coilsfcday.qc_chk3
    FROM coilsfcday,   
         groupitem groupitem_a,   
         coilmst,   
         coilorderdet,   
         groupitem groupitem_b  
   WHERE ( coilsfcday.item_no = groupitem_a.item_no ) and  
         ( coilsfcday.order_no = coilorderdet.order_no ) and  
         ( coilmst.item_no = groupitem_b.item_no ) and  
         ( coilsfcday.w_coil_no = coilmst.coil_no ) and  
         ( coilsfcday.wloc_no = coilmst.loc_no ) and  
			( coilsfcday.order_no = :as_order_no )
ORDER BY coilorderdet.coilorder_order ASC,   
         coilorderdet.order_seq ASC   
" update="coilsfcday" updatewhere=0 updatekeyinplace=no arguments=(("as_order_no", string))  sort="coilorder_order A order_seq A order_no A seq A " )
