$PBExportComments$물품반납 현황(2004/06/04, 정갑용)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=0 HTMLDW=no print.documentname="" print.orientation = 1 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=416 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(20) updatewhereclause=yes name=retdet_qa dbname="retdet.qa" )
 column=(type=char(2) updatewhereclause=yes name=retdet_uom dbname="retdet.uom" )
 column=(type=decimal(2) updatewhereclause=yes name=acc_qty dbname="retdet.acc_qty" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene.scene_desc" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name dbname="login.user_name" )
 column=(type=char(14) updatewhereclause=yes name=ret_ret_no dbname="ret.ret_no" )
 column=(type=datetime updatewhereclause=yes name=c_date dbname="c_date" )
 column=(type=datetime updatewhereclause=yes name=c_start dbname="c_start" )
 column=(type=datetime updatewhereclause=yes name=c_end dbname="c_end" )
 column=(type=datetime updatewhereclause=yes name=ret_ret_date dbname="ret.ret_date" )
 retrieve="SELECT groupitem.item_name,
		retdet.qa,   
		retdet.uom,   
		retdet.acc_qty,
		customer.cust_name,
		scene.scene_desc,
		login.user_name,
		ret.ret_no,
		c_date = convert(smalldatetime, substring(ret.ret_no, 3,8), 111),
		c_start = convert(smalldatetime, :ad_sdate, 111),   
		c_end = convert(smalldatetime, :ad_edate, 111),
		ret.ret_date
FROM retdet,   
		groupitem,
		ret,
		customer,
		scene,
		login
WHERE ( retdet.item_no = groupitem.item_no ) and  
		( retdet.ret_no = ret.ret_no ) and
		( ret.ret_date between :ad_sdate and :ad_edate ) and
		( ret.cust_no = customer.cust_no ) and
		( ret.spot_code = scene.scene_code ) and
		( customer.salesman = login.user_id ) and
		( retdet.acc_qty > 0 )" arguments=(("ad_sdate", date),("ad_edate", date))  sort="groupitem_item_name A retdet_qa A " )
