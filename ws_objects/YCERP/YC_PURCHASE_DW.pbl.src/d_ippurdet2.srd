 column=(type=decimal(4) update=yes updatewhereclause=yes name=order_qty dbname="purdet.order_qty" initial="0 " )
 column=(type=datetime update=yes updatewhereclause=yes name=rlse_date dbname="purdet.rlse_date" initial=" " )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=price dbname="purdet.price" initial="0 " )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="purdet.uom" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=rlse_qty dbname="purdet.rlse_qty" initial="0 " )
 column=(type=char(30) update=yes updatewhereclause=yes name=rem dbname="purdet.rem" initial=" " )
 column=(type=char(20) update=yes updatewhereclause=yes name=rcpt_loc dbname="purdet.rcpt_loc" )
 column=(type=char(1) update=yes updatewhereclause=yes name=pur_type dbname="purdet.pur_type" )
