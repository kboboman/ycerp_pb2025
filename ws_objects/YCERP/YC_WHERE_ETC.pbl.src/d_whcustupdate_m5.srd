table(column=(type=datetime updatewhereclause=yes name=mps_start_date dbname="mps.start_date" )
 column=(type=char(20) updatewhereclause=yes name=wc_work_name dbname="wc.work_name" )
 column=(type=long updatewhereclause=yes name=mpsdet_operation dbname="mpsdet.operation" )
 column=(type=long updatewhereclause=yes name=mpsdet_division dbname="mpsdet.division" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
