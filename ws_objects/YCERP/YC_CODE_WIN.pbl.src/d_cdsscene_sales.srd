table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=scene_code dbname="SSceneSALES.scene_code" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=user_id dbname="SSceneSALES.user_id" )
 column=(type=datetime update=yes updatewhereclause=yes name=sys_date dbname="SSceneSALES.sys_date" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 retrieve="  SELECT SSceneSALES.scene_code
       , SSceneSALES.user_id
       , SSceneSALES.sys_date  
       , scene_desc  = SScene.scene_desc
    FROM SSceneSALES   
         LEFT OUTER JOIN SScene ON SSceneSALES.scene_code = SScene.scene_code
   WHERE ((:as_scene   = '%' AND SSceneSALES.scene_code LIKE :as_scene) OR
          (:as_scene  <> '%' AND SSceneSALES.scene_code    = :as_scene)
         )" update="SSceneSALES" updatewhere=1 updatekeyinplace=no arguments=(("as_scene", string)) )
