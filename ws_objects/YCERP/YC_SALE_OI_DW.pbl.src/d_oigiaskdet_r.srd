table(column=(type=datetime updatewhereclause=yes name=ask_head_ask_date dbname="ask_head.ask_date" )
 column=(type=char(30) updatewhereclause=yes name=location_loc_name_a dbname="loc_name_a" )
 column=(type=char(10) updatewhereclause=yes name=login_userk dbname="userK" )
 column=(type=char(50) updatewhereclause=yes name=ask_head_rem dbname="ask_head.rem" )
 column=(type=char(12) updatewhereclause=yes name=ask_head_ask_no dbname="ask_head.ask_no" )
 column=(type=char(1) updatewhereclause=yes name=ask_head_proc_flag dbname="ask_head.proc_flag" values="처리완료	Y/접수중	N/부분	P/" )
 column=(type=char(10) updatewhereclause=yes name=login_usert dbname="userT" )
 column=(type=datetime updatewhereclause=yes name=ask_head_act_date dbname="ask_head.act_date" )
 column=(type=char(20) updatewhereclause=yes name=area_areaf dbname="areaF" )
 column=(type=char(20) updatewhereclause=yes name=area_areat dbname="areaT" )
 column=(type=datetime updatewhereclause=yes name=ask_head_log_date dbname="ask_head.log_date" )
 column=(type=char(1) updatewhereclause=yes name=ask_head_ship_close dbname="ask_head.ship_close" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="ask_det.seq_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="ask_det.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="ask_det.qa" )
 column=(type=char(30) updatewhereclause=yes name=location_loc_name dbname="location.loc_name" )
 column=(type=decimal(2) updatewhereclause=yes name=ask_qty dbname="ask_det.ask_qty" initial="0" )
 column=(type=decimal(2) updatewhereclause=yes name=rlse_qty dbname="ask_det.rlse_qty" initial="0" )
 column=(type=char(50) updatewhereclause=yes name=rem dbname="ask_det.rem" )
 column=(type=char(1) updatewhereclause=yes name=rlse_flag dbname="ask_det.rlse_flag" initial="N" values="완료	Y/진행	N/" )
 column=(type=datetime updatewhereclause=yes name=rlse_date dbname="ask_det.rlse_date" initial="today()" )
 column=(type=decimal(2) updatewhereclause=yes name=issue_qty dbname="ask_det.issue_qty" initial="0" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="GroupItem.item_name" )
 column=(type=char(14) updatewhereclause=yes name=sale_no dbname="ask_det.sale_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 retrieve="  SELECT ask_head.ask_date   
       , loc_name_a   = LA.loc_name    
       , userK        = loginA.user_name   
       , ask_head.rem   
       , ask_head.ask_no   
       , ask_head.proc_flag   
       , userT        = loginB.user_name   
       , ask_head.act_date   
       , areaF        = areaA.area_name  
       , areaT        = areaB.area_name 
       , ask_head.log_date   
       , ask_head.ship_close
       , ask_det.seq_no   
       , ask_det.item_no   
       , ask_det.qa   
       , location.loc_name   
       , ask_det.ask_qty   
       , ask_det.rlse_qty   
       , ask_det.rem   
       , ask_det.rlse_flag   
       , ask_det.rlse_date   
       , ask_det.issue_qty   
       , groupitem.item_name   
       , ask_det.sale_no    
       , cust_name    = dbo.uf_getcustname(ask_det.sale_no)
    FROM ask_head with(nolock) inner join ask_det with(nolock) on ask_head.ask_no     = ask_det.ask_no
                                 inner join groupitem with(nolock) ON ask_det.item_no     = groupitem.item_no    
                                 left outer join location with(nolock) on ask_det.loc_no     = location.loc_no
                                 left outer join location LA  with(nolock) on ask_head.ask_loc  = LA.loc_no
                                 left outer join  area areaA with(nolock) on ask_head.f_area     = areaA.area_no 
                                 left outer join  area areaB with(nolock) on ask_head.t_area     = areaB.area_no     
                                 left outer join  login loginA with(nolock) on ask_head.ask_user =  loginA.user_id 
                                 left outer join  login loginB with(nolock) on ask_head.act_user  =  loginB.user_id
   WHERE ( ask_head.ask_no  LIKE :as_askno  )
/*
    FROM ask_head
       , ask_det   
       , groupitem
       , location
       , location LA
       , area areaA
       , area areaB
       , login loginA
       , login loginB 
   WHERE ( ask_head.ask_no  LIKE :as_askno         )
     AND ( ask_head.ask_no     = ask_det.ask_no    )
     AND ( ask_head.f_area    *= areaA.area_no     )
     AND ( ask_head.t_area    *= areaB.area_no     )
     AND ( ask_head.ask_user  *= loginA.user_id    )
     AND ( ask_head.act_user  *= loginB.user_id    )
     AND ( ask_det.item_no     = groupitem.item_no )
     AND ( ask_det.loc_no     *= location.loc_no   )
     AND ( ask_head.ask_loc   *= LA.loc_no         )


*/" arguments=(("as_askno", string)) )
