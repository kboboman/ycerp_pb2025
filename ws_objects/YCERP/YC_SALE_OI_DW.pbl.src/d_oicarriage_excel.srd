release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=co_cd dbname="CO_CD" )
 column=(type=char(1) updatewhereclause=yes name=tr_cd dbname="TR_CD" )
 column=(type=char(50) updatewhereclause=yes name=tr_nm dbname="TR_NM" )
 column=(type=char(1) updatewhereclause=yes name=attr_nm dbname="ATTR_NM" )
 column=(type=char(1) updatewhereclause=yes name=tr_fg dbname="TR_FG" )
 column=(type=char(20) updatewhereclause=yes name=reg_nb dbname="REG_NB" )
 column=(type=char(1) updatewhereclause=yes name=ppl_nb dbname="PPL_NB" )
 column=(type=char(10) updatewhereclause=yes name=ceo_nm dbname="CEO_NM" )
 column=(type=char(20) updatewhereclause=yes name=business dbname="business" )
 column=(type=char(20) updatewhereclause=yes name=jongmok dbname="jongmok" values="개별화물	개별화물/트럭	트럭/화물운송	화물운송/화물	화물/개별용달	개별용달/" )
 column=(type=char(1) updatewhereclause=yes name=zip dbname="ZIP" )
