 column=(type=char(5) update=yes updatewhereclause=yes name=qa4 dbname="itemqa_pattern.qa4" )
 column=(type=char(3) updatewhereclause=yes name=qa1_org dbname="qa1_org" )
 column=(type=char(4) updatewhereclause=yes name=qa2_org dbname="qa2_org" )
 column=(type=char(4) updatewhereclause=yes name=qa3_org dbname="qa3_org" )
 column=(type=char(5) updatewhereclause=yes name=qa4_org dbname="qa4_org" )
 column=(type=char(1) update=yes updatewhereclause=yes name=use_yn dbname="itemqa_pattern.use_yn" values="사용	Y/불가	N/" )
 column=(type=datetime update=yes updatewhereclause=yes name=sys_date dbname="itemqa_pattern.sys_date" )
 retrieve="  SELECT itemqa_pattern.item_no,
         groupitem.item_name,   
         itemqa_pattern.qa,   
         itemqa_pattern.uom,   
         itemqa_pattern.chk1,   
         itemqa_pattern.qa1,   
         itemqa_pattern.chk2,   
         itemqa_pattern.qa2,   
         itemqa_pattern.chk3,   
         itemqa_pattern.qa3,   
         itemqa_pattern.chk4,   
         itemqa_pattern.qa4,   

         qa1_org = itemqa_pattern.qa1,   
         qa2_org = itemqa_pattern.qa2,   
         qa3_org = itemqa_pattern.qa3,   
         qa4_org = itemqa_pattern.qa4,   

         itemqa_pattern.use_yn,   
         itemqa_pattern.sys_date  
    FROM itemqa_pattern
         LEFT OUTER JOIN groupitem  ON itemqa_pattern.item_no = groupitem.item_no
" update="itemqa_pattern" updatewhere=1 updatekeyinplace=no  sort="item_name A qa A " )
