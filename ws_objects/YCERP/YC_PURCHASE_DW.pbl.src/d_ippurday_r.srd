$PBExportComments$원자재구매일보_출력(1998/04/29,이인호)
release 5;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no )
header(height=457 color="536870912" )
summary(height=81 color="536870912" )
footer(height=1 color="536870912" )
detail(height=89 color="553648127" )
table(column=(type=char(30) updatewhereclause=yes name=supp_supp_name dbname="supp.supp_name" )
 column=(type=char(60) updatewhereclause=yes name=item_item_name dbname="item.item_name" )
 column=(type=char(20) updatewhereclause=yes name=inaudit_qa dbname="inaudit.qa" )
 column=(type=char(2) updatewhereclause=yes name=purdet_uom dbname="purdet.uom" initial=" " )
 column=(type=decimal(2) updatewhereclause=yes name=inaudit_rcpt_qty dbname="inaudit.rcpt_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=inaudit_cost dbname="inaudit.cost" )
 column=(type=char(30) updatewhereclause=yes name=inaudit_rem dbname="inaudit.rem" )
 column=(type=char(10) updatewhereclause=yes name=inaudit_inaudit_item dbname="inaudit.inaudit_item" )
 column=(type=char(2) updatewhereclause=yes name=citem_type dbname="item_type" )
 column=(type=decimal(6) updatewhereclause=yes name=camt dbname="amt" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"inaudit~" )  TABLE(NAME=~"item~" )  TABLE(NAME=~"pur~" )  TABLE(NAME=~"purdet~" )  TABLE(NAME=~"supp~" ) COLUMN(NAME=~"supp.supp_name~") COLUMN(NAME=~"item.item_name~") COLUMN(NAME=~"inaudit.qa~") COLUMN(NAME=~"purdet.uom~") COLUMN(NAME=~"inaudit.rcpt_qty~") COLUMN(NAME=~"inaudit.cost~") COLUMN(NAME=~"inaudit.rem~") COLUMN(NAME=~"inaudit.inaudit_item~") COMPUTE(NAME=~"substring(inaudit_item,2,1) item_type~") COMPUTE(NAME=~"(inaudit.cost * inaudit.rcpt_qty) amt~")    JOIN (LEFT=~"pur.order_no~"    OP =~"=~"RIGHT=~"purdet.order_no~" )    JOIN (LEFT=~"purdet.item_no~"    OP =~"=~"RIGHT=~"inaudit.inaudit_item~" )    JOIN (LEFT=~"inaudit.order_no~"    OP =~"=~"RIGHT=~"purdet.order_no~" )    JOIN (LEFT=~"pur.supp_no~"    OP =~"=~"RIGHT=~"supp.supp_no~" )    JOIN (LEFT=~"purdet.item_no~"    OP =~"=~"RIGHT=~"item.item_no~" )) "  sort="citem_type A supp_supp_name A item_item_name A inaudit_qa A " )
group(level=1 header.height=1 trailer.height=85 by=("citem_type" ) header.color="553648127" trailer.color="536870912" )
