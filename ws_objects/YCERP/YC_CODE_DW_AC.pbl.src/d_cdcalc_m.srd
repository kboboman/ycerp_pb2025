table(column=(type=long update=yes updatewhereclause=yes key=yes name=calcd_seq dbname="itemcalcd.calcd_seq" )
 column=(type=char(1) update=yes updatewhereclause=yes name=thin dbname="itemcalcd.thin" )
 column=(type=char(1) update=yes updatewhereclause=yes name=wid dbname="itemcalcd.wid" )
 column=(type=long update=yes updatewhereclause=yes name=wid_add dbname="itemcalcd.wid_add" )
 column=(type=char(1) update=yes updatewhereclause=yes name=mul dbname="itemcalcd.mul" )
 column=(type=char(1) update=yes updatewhereclause=yes name=high dbname="itemcalcd.high" )
 column=(type=long update=yes updatewhereclause=yes name=high_add dbname="itemcalcd.high_add" )
 column=(type=long update=yes updatewhereclause=yes name=wid_high_add dbname="itemcalcd.wid_high_add" )
 column=(type=char(1) update=yes updatewhereclause=yes name=len dbname="itemcalcd.len" )
 column=(type=char(1) update=yes updatewhereclause=yes name=div10 dbname="div10" )
 column=(type=long update=yes updatewhereclause=yes name=all_div dbname="itemcalcd.all_div" )
 column=(type=char(1) update=yes updatewhereclause=yes name=cnt dbname="itemcalcd.cnt" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=cnt_mul dbname="itemcalcd.cnt_mul" )
 column=(type=char(70) update=yes updatewhereclause=yes name=total_text dbname="itemcalcd.total_text" )
 retrieve="  SELECT itemcalcd.calcd_seq      
       , itemcalcd.thin           
       , itemcalcd.wid            
       , itemcalcd.wid_add        
       , itemcalcd.mul            
       , itemcalcd.high           
       , itemcalcd.high_add       
       , itemcalcd.wid_high_add   
       , itemcalcd.len            
       , itemcalcd.div10          
       , itemcalcd.all_div        
       , itemcalcd.cnt            
       , itemcalcd.cnt_mul        
       , itemcalcd.total_text     
    FROM itemcalcd                
" update="itemcalcd" updatewhere=1 updatekeyinplace=no )
