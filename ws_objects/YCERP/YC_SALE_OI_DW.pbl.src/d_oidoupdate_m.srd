table(column=(type=char(14) updatewhereclause=yes key=yes name=do_no dbname="dodet.do_no" )
 column=(type=long updatewhereclause=yes key=yes name=oi_no dbname="dodet.oi_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="dodet.seq_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="dodet.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="dodet.qa" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa_cust dbname="dodet.qa_cust" )
 column=(type=decimal(2) updatewhereclause=yes name=ship_qty dbname="dodet.ship_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=price dbname="dodet.price" )
 column=(type=decimal(2) updatewhereclause=yes name=aroi_qty dbname="dodet.aroi_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=dodet_stock_qty dbname="dodet.stock_qty" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="dodet.uom" )
 column=(type=char(14) updatewhereclause=yes name=sale_no dbname="dodet.sale_no" )
 column=(type=decimal(4) updatewhereclause=yes name=rate_cash dbname="dodet.rate_cash" )
 column=(type=char(50) updatewhereclause=yes name=rem dbname="dodet.rem" )
 column=(type=char(3) updatewhereclause=yes name=do_curr_code dbname="do.curr_code" )
 column=(type=long updatewhereclause=yes name=sort_qty dbname="sort_qty" )
 column=(type=char(12) updatewhereclause=yes name=do_rem dbname="dodet.do_rem" )
 column=(type=char(20) updatewhereclause=yes name=coil_no dbname="dodet.coil_no" )
 column=(type=long updatewhereclause=yes name=cnt dbname="dodet.cnt" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="GroupItem.item_name" )
 column=(type=char(1) updatewhereclause=yes name=source dbname="GroupItem.source" )
 column=(type=char(10) updatewhereclause=yes name=loc_no dbname="dodet.loc_no" )
 column=(type=char(1) updatewhereclause=yes name=sale_tax_sign dbname="sale.tax_sign" )
 column=(type=char(1) updatewhereclause=yes name=round dbname="customer.round" )
 retrieve="  SELECT DISTINCT dodet.do_no,   
         dodet.oi_no,   
         dodet.seq_no,   
         dodet.item_no,   
         dodet.qa,   
         dodet.qa_cust,   
         dodet.ship_qty,   
         dodet.price,   
         dodet.aroi_qty,   
         dodet.stock_qty,
         dodet.uom,   
         dodet.sale_no,   
         dodet.rate_cash,   
         dodet.rem,   
         do.curr_code,   
         sort_qty = case when dodet.price > 0 then 0 else 1 end,   
         dodet.do_rem,   
         dodet.coil_no,   
         dodet.cnt,   
         groupitem.item_name,   
         groupitem.source,   
         dodet.loc_no,   
         sale.tax_sign,   
         customer.round
    from dodet with(nolock) inner join do with(nolock) on dodet.do_no = do.do_no
				  inner join groupitem with(nolock) on dodet.item_no = groupitem.item_no
				  inner join customer with(nolock) on do.cust_no = customer.cust_no
				  left outer join sale with(nolock) on dodet.sale_no = sale.order_no
where  ( ( dodet.do_no = :aa ) )    
/*
    FROM dodet,   
         do,   
         groupitem,   
         sale  ,   
         customer  
   WHERE ( dodet.sale_no *= sale.order_no) and  
         ( dodet.do_no = do.do_no ) and  
         ( do.cust_no = customer.cust_no ) and  
         ( dodet.item_no = groupitem.item_no ) and  
         ( ( dodet.do_no = :aa ) )    

*/" update="dodet" updatewhere=0 updatekeyinplace=yes arguments=(("aa", string))  sort="sort_qty A oi_no A " )
