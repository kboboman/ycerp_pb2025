text(band=header alignment="2" text="월말잔액" border="6" color="33554432" x="3022" y="8" height="128" width="503" html.valueishtml="0"  name=mmoutin_t visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="12639424" )
