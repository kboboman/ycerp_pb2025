table(column=(type=char(10) updatewhereclause=yes key=yes name=user_id dbname="login.user_id" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="login.user_name" )
 column=(type=char(5) updatewhereclause=yes name=team_code dbname="login.team_code" )
 column=(type=char(10) updatewhereclause=yes name=rank_no dbname="login.rank_no" )
 retrieve="  SELECT login.user_id,   
         login.user_name,
			login.team_code,
			login.rank_no
    FROM login   
where use_flag ='Y'
and substring(team_code,1,1) = '7'
and team_code <> '70000'


" update="login" updatewhere=0 updatekeyinplace=no  sort="team_code A rank_no A user_name A " )
