release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no  crosstab.dynamic = yes grid.lines=0 grid.columnmove=no selected.mouse=no )
header[1](height=72 color="536870912" )
header[2](height=80 color="536870912" )
summary(height=80 color="8421504" )
footer(height=0 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=number updatewhereclause=yes name=weight dbname="weight" )
 retrieve="  SELECT DISTINCT insp.insp_date   
       , groupitem.item_name   
       , inspdet.qa   
       , inspdet.unit_qty   
       , inspdet.cnt   
       , weight = inspdet.unit_qty * inspdet.cnt
       , sdate = convert(smalldatetime, :ad_start, 111)   
       , edate = convert(smalldatetime, :ad_end, 111)   
       , inspdet.coil_no   
       , supp.supp_name   
       , coilmst.etc_no
       , inspdet.price
    FROM supp   
       , coilmst   
       , insp   
       , inspdet   
       , groupitem  
   WHERE ( insp.insp_no      = inspdet.insp_no   )   
     AND ( insp.supp_no      = supp.supp_no      )   
     AND ( inspdet.coil_no   = coilmst.coil_no   )   
     AND ( inspdet.item_no   = coilmst.item_no   )   
     AND ( inspdet.item_no   = groupitem.item_no )   
     AND ( insp.insp_date BETWEEN :ad_start AND :ad_end  )
     AND ( coilmst.flag      = 'W'               )   
     AND ( ( inspdet.pur_no  LIKE :as_area + '%' ) or
           ( :as_area = 'S'   AND inspdet.pur_no like 'PUR%')
         )  
" arguments=(("ad_start", date),("ad_end", date),("as_area", string))  sort="item_name A qa A " )
group(level=1 header.height=0 trailer.height=84 by=("item_name" ) header.color="536870912" trailer.color="12639424" )
