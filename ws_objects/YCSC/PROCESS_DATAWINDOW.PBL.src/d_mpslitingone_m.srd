table(column=(type=char(14) update=yes updatewhereclause=yes key=yes name=order_no dbname="coilorderdet.order_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=coil_no dbname="coilorderdet.coil_no" )
 column=(type=decimal(1) update=yes updatewhereclause=yes name=wid dbname="coilorderdet.wid" )
 column=(type=decimal(1) update=yes updatewhereclause=yes name=los_width dbname="coilorderdet.los_width" )
 column=(type=long update=yes updatewhereclause=yes name=los_qty dbname="coilorderdet.los_qty" )
 column=(type=char(40) update=yes updatewhereclause=yes name=rem dbname="coilorderdet.rem" )
 column=(type=char(1) update=yes updatewhereclause=yes name=work_type dbname="coilorderdet.work_type" initial="D" values="등분	D/합체	S/" )
 column=(type=char(10) updatewhereclause=yes name=coilmst_item_no dbname="coilmst.item_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=long updatewhereclause=yes name=coilmst_qcnt dbname="coilmst.qcnt" )
 column=(type=long updatewhereclause=yes name=coilmst_unit_qty dbname="coilmst.unit_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=rt dbname="rt" )
 column=(type=long update=yes updatewhereclause=yes name=cnt dbname="coilorderdet.cnt" )
 column=(type=char(1) update=yes updatewhereclause=yes name=proc_flag dbname="coilorderdet.proc_flag" initial="O" values="생산계획	O/작업지시	M/작업지시	P/입고완료	C/" )
 column=(type=datetime update=yes updatewhereclause=yes name=order_date dbname="coilorderdet.order_date" )
 column=(type=long update=yes updatewhereclause=yes name=div dbname="coilorderdet.div" initial="1" values="없슴	1/2등분	2/3등분	3/4등분	4/5등분	5/" )
 column=(type=char(10) updatewhereclause=yes name=coilmst_loc_no dbname="coilmst.loc_no" )
 column=(type=long updatewhereclause=yes name=coilmst_length dbname="coilmst.length" )
 column=(type=long update=yes updatewhereclause=yes name=tot_qty dbname="coilorderdet.tot_qty" initial="0" )
 column=(type=char(10) update=yes updatewhereclause=yes name=loc_no dbname="coilorderdet.loc_no" )
 column=(type=char(2) updatewhereclause=yes name=coilmst_etc_no dbname="coilmst.etc_no" )
 column=(type=char(40) update=yes updatewhereclause=yes name=rem1 dbname="rem1" )
 column=(type=char(40) update=yes updatewhereclause=yes name=rem2 dbname="rem2" )
 column=(type=char(40) update=yes updatewhereclause=yes name=rem3 dbname="rem3" )
 column=(type=char(40) update=yes updatewhereclause=yes name=rem4 dbname="rem4" )
 column=(type=char(40) update=yes updatewhereclause=yes name=rem5 dbname="rem5" )
 retrieve="  SELECT coilorderdet.order_no    
       , coilorderdet.coil_no     
       , coilorderdet.wid         
       , coilorderdet.los_width   
       , coilorderdet.los_qty     
       , coilorderdet.rem         
       , coilorderdet.work_type   
       , coilmst.item_no          
       , groupitem.item_name      
       , coilmst.qcnt             
       , coilmst.unit_qty         
       , rt     = convert (decimal (3,2) , substring(qa,1,1) + ~".~" + substring(qa, 2,2))
       , coilorderdet.cnt          
       , coilorderdet.proc_flag    
       , coilorderdet.order_date   
       , coilorderdet.div          
       , coilmst.loc_no            
       , coilmst.length            
       , coilorderdet.tot_qty      
       , coilorderdet.loc_no       
       , coilmst.etc_no      
       , coilorderdet.rem1   
       , coilorderdet.rem2   
       , coilorderdet.rem3   
       , coilorderdet.rem4   
       , coilorderdet.rem5  
    FROM coilorderdet   
       , coilmst        
       , groupitem  
   WHERE ( coilorderdet.coil_no = coilmst.coil_no   )   
     AND ( coilmst.item_no      = groupitem.item_no )   
     AND ( coilorderdet.loc_no  = coilmst.loc_no    )   
     AND ( ( coilorderdet.order_no = :as_order ) )    
" update="coilorderdet" updatewhere=0 updatekeyinplace=no arguments=(("as_order", string)) )
