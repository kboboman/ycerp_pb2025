 column=(type=char(80) updatewhereclause=yes name=custinfo_guar_addr dbname="custinfo.guar_addr" )
 column=(type=char(10) updatewhereclause=yes name=custinfo_fob dbname="custinfo.fob" )
 column=(type=char(30) updatewhereclause=yes name=custinfo_bank_code dbname="custinfo.bank_code" )
 column=(type=char(50) updatewhereclause=yes name=custinfo_license_name dbname="custinfo.license_name" )
 column=(type=long updatewhereclause=yes name=custinfo_bill_self dbname="custinfo.bill_self" )
 column=(type=long updatewhereclause=yes name=custinfo_bill_other dbname="custinfo.bill_other" )
 column=(type=char(1) updatewhereclause=yes name=custinfo_curr_tran dbname="custinfo.curr_tran" values="유	Y/무	N/" )
 column=(type=char(80) updatewhereclause=yes name=custinfo_main_co dbname="custinfo.main_co" )
 column=(type=datetime updatewhereclause=yes name=custinfo_set_date dbname="custinfo.set_date" )
 column=(type=long updatewhereclause=yes name=custinfo_emp_qty dbname="custinfo.emp_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=custinfo_work_limit dbname="custinfo.work_limit" )
 column=(type=char(40) updatewhereclause=yes name=custinfo_cap_brief dbname="custinfo.cap_brief" )
 column=(type=char(20) updatewhereclause=yes name=custinfo_cap_family dbname="custinfo.cap_family" )
 column=(type=char(80) updatewhereclause=yes name=custinfo_rem1 dbname="custinfo.rem1" )
 column=(type=char(80) updatewhereclause=yes name=custinfo_rem2 dbname="custinfo.rem2" )
 column=(type=char(80) updatewhereclause=yes name=custinfo_rem3 dbname="custinfo.rem3" )
 column=(type=char(80) updatewhereclause=yes name=custinfo_rem4 dbname="custinfo.rem4" )
 column=(type=char(1) updatewhereclause=yes name=custinfo_pl_case dbname="custinfo.pl_case" values="자가	Y/임대	N/" )
 column=(type=decimal(0) updatewhereclause=yes name=custinfo_pl_cost dbname="custinfo.pl_cost" )
 column=(type=char(40) updatewhereclause=yes name=custinfo_security dbname="custinfo.security" )
 column=(type=decimal(0) updatewhereclause=yes name=custinfo_estab dbname="custinfo.estab" )
 column=(type=char(30) updatewhereclause=yes name=custinfo_pre_cust dbname="custinfo.pre_cust" )
 column=(type=decimal(2) updatewhereclause=yes name=custinfo_land dbname="custinfo.land" )
 column=(type=decimal(2) updatewhereclause=yes name=custinfo_build dbname="custinfo.build" )
 column=(type=char(5) updatewhereclause=yes name=custinfo_m_dept dbname="custinfo.m_dept" )
 column=(type=char(10) updatewhereclause=yes name=custinfo_m_sabun dbname="custinfo.m_sabun" )
 column=(type=datetime updatewhereclause=yes name=custinfo_m_date dbname="custinfo.m_date" )
 retrieve="  SELECT customer.cust_no,   
         customer.cust_name,   
         customer.register_no,   
         customer.captain_name,   
         customer.resident_card,   
         customer.addr,   
         customer.business,   
         customer.bus_cord,   
         customer.bus_rep,   
         customer.bus_addr,   
         customer.bus_tel,   
         customer.tel_no,   
         customer.fax_no,   
         customer.industry_type,   
         customer.industry_code,   
         customer.cust_type,   
         customer.shipto_addr,   
         customer.terms,   
         customer.credit_level,   
         customer.credit_limit,   
         customer.curr_code,   
         customer.balance_amt,   
         customer.bill_amount,   
         customer.start_date,   
         customer.buyer1,   
         customer.buyer2,   
         customer.pre_salesman,   
         customer.salesman,   
         customer.last_tn_date,   
         customer.open_close,   
         customer.level_grade,   
         custinfo.guarentee,   
         custinfo.guar_card,   
         custinfo.guar_addr,   
         custinfo.fob,   
         custinfo.bank_code,   
         custinfo.license_name,   
         custinfo.bill_self,   
         custinfo.bill_other,   
         custinfo.curr_tran,   
         custinfo.main_co,   
         custinfo.set_date,   
         custinfo.emp_qty,   
         custinfo.work_limit,   
         custinfo.cap_brief,   
         custinfo.cap_family,   
         custinfo.rem1,   
         custinfo.rem2,   
         custinfo.rem3,   
         custinfo.rem4,   
         custinfo.pl_case,   
         custinfo.pl_cost,   
         custinfo.security,   
         custinfo.estab,   
         custinfo.pre_cust,   
         custinfo.land,   
         custinfo.build,   
         custinfo.m_dept,   
         custinfo.m_sabun,   
         custinfo.m_date  
    FROM customer,   
         custinfo  
   WHERE ( customer.cust_no = custinfo.cust_no )    
"  sort="cust_no A " )
