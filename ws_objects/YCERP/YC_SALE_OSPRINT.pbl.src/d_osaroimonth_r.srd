$PBExportComments$물품별 월 매출집계 DISPLAY(1998/05/15, 정재수)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="79416533" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=80 color="553648127" )
table(column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=decimal(4) updatewhereclause=yes name=aroiinv_gl_cur_rate dbname="gl_cur_rate" )
 column=(type=char(3) updatewhereclause=yes name=aroiinv_curr_code dbname="curr_code" )
 column=(type=decimal(2) updatewhereclause=yes name=ship_qty dbname="ship_qty" )
 column=(type=long updatewhereclause=yes name=aroi_dc_rate dbname="dc_rate" )
 column=(type=decimal(4) updatewhereclause=yes name=rate_cash dbname="rate_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=ori_amount dbname="ori_amount" )
 retrieve="  SELECT item_no    = a.item_no
       , item_name  = a.item_name
       , qa         = a.qa
       , uom        = a.uom
       , gl_cur_rate= a.gl_cur_rate
       , curr_code  = a.curr_code
       , ship_qty   = sum(a.ship_qty)
       , dc_rate    = sum(a.dc_rate)
       , rate_cash  = sum(a.rate_cash)
       , ori_amount = sum(a.ori_amount)
    FROM (
         SELECT aroi.item_no
              , qa         = (case aroi.uom when 'M' then left(qa, 13) when 'M2' then left(qa, 3) when 'SS' then left(qa, 3) else qa end)
              , aroi.uom
              , aroiinv.gl_cur_rate
              , groupitem.item_name
              , aroi.dc_rate
              , aroiinv.curr_code
              , ship_qty   = aroi.ship_qty
              , rate_cash  = aroi.rate_cash
              , ori_amount = aroi.ori_amount
              , oi_date    = aroiinv.oi_date   
           FROM aroiinv
                LEFT OUTER JOIN aroi      ON aroiinv.aroiinv_no = aroi.aroiinv_no
                LEFT OUTER JOIN customer  ON aroiinv.cust_no    = customer.cust_no 
                LEFT OUTER JOIN groupitem ON aroi.item_no       = groupitem.item_no
          WHERE ((:as_area   = '%' ) OR
                 (:as_area  <> '%' AND aroiinv.inv_area  = :as_area ) 
                )
            AND ( aroiinv.sale_flag     IN ( :asa_flag )  )
            AND ( datepart(year,  aroiinv.oi_date) = :al_year  ) 
            AND ( datepart(month, aroiinv.oi_date) = :al_month )
            AND ( aroiinv.delete_flag    = 'N' )  
            AND ( customer.salesman   LIKE :as_userid )
         ) A
   GROUP BY a.item_no
          , a.item_name
          , a.qa
          , a.uom
          , a.gl_cur_rate
          , a.curr_code
" arguments=(("as_area", string),("asa_flag", stringlist),("al_year", number),("al_month", number),("as_userid", string))  sort="item_no A qa A " )
group(level=1 header.height=0 trailer.height=80 by=("item_no" ) header.color="536870912" trailer.color="536870912" )
