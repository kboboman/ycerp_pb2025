a_no~"    OP =~"=~"RIGHT=~"area.area_no~"    OUTER1 =~"sale.area_no~" )WHERE(    EXP1 =~"sale.order_no~"   OP =~"=~"    EXP2 =~":as_order_no~" ) ) ARG(NAME = ~"as_order_no~" TYPE = string) " arguments=(("as_order_no", string)) )
