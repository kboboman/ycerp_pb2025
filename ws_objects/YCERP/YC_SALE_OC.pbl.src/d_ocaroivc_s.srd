$PBExportHeader$d_ocaroivc_s.srd
$PBExportComments$판매수금관리 수금번호선택(1998/04/20, 정재수)
release 8;
datawindow(units=0 timer_interval=0 color=79219928 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(12) updatewhereclause=yes key=yes name=vc_no dbname="aroivc.vc_no" )
 column=(type=decimal(4) updatewhereclause=yes name=amount dbname="aroivc.amount" )
 column=(type=char(1) updatewhereclause=yes name=open_close dbname="aroivc.open_close" )
 retrieve="  SELECT aroivc.vc_no,   
         aroivc.amount,   
         aroivc.open_close  
    FROM aroivc  
   WHERE ( aroivc.cust_no = :as_cust_no ) AND  
         ( aroivc.delete_key = 'N' )    
" update="aroivc" updatewhere=0 updatekeyinplace=no arguments=(("as_cust_no", string))  sort="vc_no D " )
text(band=header alignment="2" text="수금액" border="6" color="0" x="782" y="8" height="68" width="599" html.valueishtml="0"  name=amount_t visible="1"  font.face="굴림체" font.height="-11" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="12639424" )
