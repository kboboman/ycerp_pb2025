 retrieve="  SELECT customer.cust_no,   
         customer.cust_name,   
         customer.register_no,   
         customer.captain_name,   
         customer.resident_card,   
         customer.cap_birthday,   
         customer.addr,   
         customer.business,   
         customer.bus_cord,   
         customer.bus_rep,   
         customer.bus_addr,   
         customer.bus_tel,   
         customer.tel_no,   
         customer.fax_no,   
         customer.industry_type,   
         customer.industry_code,   
         customer.cust_type,   
         customer.shipto_addr,   
         customer.terms,   
         customer.price_level,   
         customer.credit_level,   
         customer.credit_limit,   
         customer.curr_code,   
         customer.balance_amt,   
         customer.bill_amount,   
         customer.start_date,   
         customer.buyer1,   
         customer.buyer2,   
         customer.pre_salesman,   
         customer.salesman,   
         customer.last_tn_date,   
         customer.open_close,   
         customer.level_grade,   
         customer.cust_flag,   
         customer.round,
			customer.buyer1_hp,
			customer.credit_day,
         customer.addr1,   
         customer.addr2,   
         customer.addr3,   
         customer.bus_addr1,   
         customer.bus_addr2,   
         customer.bus_addr3,   
         customer.shipto_addr1,   
         customer.shipto_addr2,   
         customer.shipto_addr3,
         c_addr = customer.addr,   
         c_bus_addr = customer.bus_addr,
         c_shipto_addr = customer.shipto_addr,
			customer.sale_control,
         customer.vat_user,   
         customer.vat_phone,   
         customer.vat_email,
         customer.collect_ymd,
         customer.icube_no,
			c_salesman = (select isnull(user_name,'') from login where user_id = customer.salesman),
			customer.contract_day,
			customer.contract_yn,
			customer.joint_head,
			customer.jointor,
			customer.joint_amt,
			customer.dambo_rem,
			customer.dambo_ymd,
			customer.dambo_amt,
			customer.dambo_bigo,
			scene_phone = (case when customer.scene_phone is null or customer.scene_phone = '' then 'N' else customer.scene_phone end)
    FROM customer  
   WHERE customer.cust_no = :as_custno    

" update="customer" updatewhere=0 updatekeyinplace=no arguments=(("as_custno", string)) )
