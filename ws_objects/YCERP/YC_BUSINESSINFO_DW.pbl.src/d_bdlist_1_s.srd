table(column=(type=char(20) updatewhereclause=yes name=bdinfodet_project dbname="bdinfodet.project" )
 column=(type=char(34) updatewhereclause=yes name=bd_positon dbname="bd_positon" )
 column=(type=char(4) updatewhereclause=yes name=bdinfodet_buildingcom dbname="bdinfodet.buildingcom" )
 column=(type=long updatewhereclause=yes name=bdinfodet_square dbname="bdinfodet.square" )
 column=(type=char(4) updatewhereclause=yes name=bdinfodet_master dbname="bdinfodet.master" )
 column=(type=char(4) updatewhereclause=yes name=bdinfodet_builder dbname="bdinfodet.builder" )
 column=(type=datetime updatewhereclause=yes name=bdinfodet_makedate dbname="bdinfodet.makedate" )
 column=(type=char(4) updatewhereclause=yes name=bdinfodet_designoffice dbname="bdinfodet.designoffice" )
 column=(type=char(7) updatewhereclause=yes name=bdinfodet_floors dbname="bdinfodet.floors" )
 column=(type=datetime updatewhereclause=yes name=bdinfodet_constructiondate dbname="bdinfodet.constructiondate" )
 column=(type=datetime updatewhereclause=yes name=bdinfodet_completiondate dbname="bdinfodet.completiondate" )
 column=(type=char(3) updatewhereclause=yes name=bdinfodet_build_prog dbname="bdinfodet.build_prog" )
 column=(type=char(15) updatewhereclause=yes name=bdinfodet_builderman dbname="bdinfodet.builderman" )
 column=(type=char(15) updatewhereclause=yes name=bdinfodet_builderphone dbname="bdinfodet.builderphone" )
 column=(type=char(10) updatewhereclause=yes name=bdinfodet_person dbname="bdinfodet.person" )
 column=(type=char(20) updatewhereclause=yes name=bdinfodet_rem dbname="bdinfodet.rem" )
 column=(type=char(10) updatewhereclause=yes name=bdinfodet_build_no dbname="bdinfodet.build_no" )
 column=(type=decimal(0) updatewhereclause=yes name=bdinfodet_seq dbname="bdinfodet.seq" )
 column=(type=char(1) updatewhereclause=yes name=designoffice_c dbname="designoffice_c" )
 column=(type=char(1) updatewhereclause=yes name=buildingcom_c dbname="buildingcom_c" )
 column=(type=char(1) updatewhereclause=yes name=builder_c dbname="builder_c" )
 retrieve="SELECT bdinfodet.project,   
		bd_positon = (  SELECT city_name FROM bdcity where city_code = bdinfodet.city ) + bdinfodet.dong,   
		bdinfodet.buildingcom,
		bdinfodet.square,
		bdinfodet.master,
		bdinfodet.builder,
		bdinfodet.makedate,
		bdinfodet.designoffice,
		bdinfodet.floors,
		bdinfodet.constructiondate,
		bdinfodet.completiondate,
		bdinfodet.build_prog,
		bdinfodet.builderman,
		bdinfodet.builderphone,
		bdinfodet.person,
		bdinfodet.rem,
		bdinfodet.build_no,
		bdinfodet.seq,
		designoffice_c = case when bdinfodet.designoffice is null or rtrim(bdinfodet.designoffice) =  '' then '' else 'V' end,
		buildingcom_c = case when bdinfodet.buildingcom is null or rtrim(bdinfodet.buildingcom) =  '' then '' else 'V' end,
		builder_c = (select case when count(builder) > 0 then 'V' else '' end  from bdinfodet_sale2 where build_no =  bdinfodet.build_no and seq = bdinfodet.seq)
    FROM bdinfo,   
         bdinfodet
   WHERE ( bdinfodet.build_no = bdinfo.build_no ) and  
         ( bdinfodet.std_chk = '1' ) AND  
         ( bdinfodet.project like '%' )

"  sort="bdinfodet_project A bd_positon A " )
