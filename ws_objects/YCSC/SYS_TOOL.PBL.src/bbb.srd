 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"d_proposition_det~" )  TABLE(NAME=~"D_DOCUMENT_HD~" )  TABLE(NAME=~"U_INSA_BASE~" ) COLUMN(NAME=~"d_proposition_det.D_DO_NO~") COLUMN(NAME=~"U_INSA_BASE.U_NAME_KOR~") COLUMN(NAME=~"d_proposition_det.D_TITLE~") COLUMN(NAME=~"d_proposition_det.D_COMPLETE~") COLUMN(NAME=~"d_proposition_det.D_GRADE~") COLUMN(NAME=~"d_proposition_det.D_CONTENT~") COLUMN(NAME=~"d_proposition_det.D_FILEPATH~") COLUMN(NAME=~"d_proposition_det.D_FILESIZE~") COLUMN(NAME=~"d_proposition_det.D_USR_INFO~") COLUMN(NAME=~"d_proposition_det.D_FILENAME~") COMPUTE(NAME=~"d_proposition_det.D_TITLE1~") COLUMN(NAME=~"D_DOCUMENT_HD.D_DO_DATE~")    JOIN (LEFT=~"d_proposition_det.D_DO_NO~"    OP =~"=~"RIGHT=~"D_DOCUMENT_HD.D_DO_NO~" )    JOIN (LEFT=~"D_DOCUMENT_HD.D_SABUN~"    OP =~"=~"RIGHT=~"U_INSA_BASE.U_SABUN~" )WHERE(    EXP1 =~"( ( U_INSA_BASE.U_NAME_KOR~"   OP =~"like~"    EXP2 =~"'%' )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( d_proposition_det.D_DO_NO~"   OP =~"like~"    EXP2 =~"'po2007%')~"    LOGIC =~"And~" ) WHERE(    EXP1 =~"( D_DOCUMENT_HD.D_DO_DATE~"   OP =~">=~"    EXP2 =~":aa ) )~" ) ) ORDER(NAME=~"d_proposition_det.D_DO_NO~" ASC=yes ) ARG(NAME = ~"aa~" TYPE = string) " arguments=(("aa", string)) )
