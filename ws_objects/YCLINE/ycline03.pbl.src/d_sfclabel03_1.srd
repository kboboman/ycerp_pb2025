table(column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(18) updatewhereclause=yes name=thin dbname="thin" )
 column=(type=long updatewhereclause=yes name=coilsfcday_unit_qty dbname="coilsfcday.unit_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=coilsfcday_length dbname="coilsfcday.length" )
 column=(type=char(4) updatewhereclause=yes name=coilsfcday_color_no dbname="coilsfcday.color_no" )
 column=(type=char(18) updatewhereclause=yes name=onecoil dbname="onecoil" )
 column=(type=long updatewhereclause=yes name=coilorderdet_tot_qty dbname="coilorderdet.tot_qty" )
 column=(type=char(20) updatewhereclause=yes name=coilsfcday_coil_no dbname="coilsfcday.coil_no" )
 column=(type=char(2) updatewhereclause=yes name=item_no dbname="item_no" values="무도장	0/YC-001	1/YC-003	3/YC-004	4/국방색	A/검정	B/흑백	C/백색	D/펜시	F/골드	G/회색	H/도장아이보리	I/지정색	J/카파	K/라미네이트	L/밀러	M/무정전	N/롤아이보리	R/실버	S/T-Bar 백색	W/기타	Z/" )
 retrieve="select   groupitem.item_name,
			thin = substring(coilmst.qa,1,1) + '.' + substring(coilmst.qa, 2,2) + ' * ' 
					+ convert(varchar(8),coilsfcday.wid),
			coilsfcday.unit_qty,
			coilsfcday.length, 
			coilsfcday.color_no,
			onecoil = ( substring(coilmst.qa,1,1) + '.' + substring(coilmst.qa, 2,2) + ' * ' 
						+ convert(varchar(8),coilorderdet.wid) ),
			coilorderdet.tot_qty,
         coilsfcday.coil_no,
			item_no = right(rtrim(coilsfcday.item_no),1)
 from coilorderdet, 
		coilsfcday, 
		coilmst, 
		groupitem
where coilorderdet.order_no = coilsfcday.order_no 
  and coilsfcday.w_coil_no = coilmst.coil_no 
  and coilsfcday.wloc_no = coilmst.loc_no 
  and coilsfcday.item_no = groupitem.item_no
  and coilsfcday.SHEET <> 'L'
  and coilsfcday.order_no = :as_order_no
  and coilsfcday.seq = :ai_seq" arguments=(("as_order_no", string),("ai_seq", number)) )
