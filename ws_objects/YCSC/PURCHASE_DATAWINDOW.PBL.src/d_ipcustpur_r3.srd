$PBExportHeader$d_ipcustpur_r3.srd
$PBExportComments$거래처별구매내역보고서(물품규격집계)(2000/11/11,이인호)
release 8;
datawindow(units=0 timer_interval=60000 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=752 color="536870912" )
summary(height=88 color="536870912" )
footer(height=0 color="536870912" )
detail(height=84 color="536870912" )
table(column=(type=char(30) updatewhereclause=yes name=supp_supp_name dbname="supp.supp_name" )
 column=(type=char(1) updatewhereclause=yes name=groupitem_insp_flag dbname="GroupItem.insp_flag" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(2) updatewhereclause=yes name=groupitem_uom dbname="GroupItem.uom" )
 column=(type=char(20) updatewhereclause=yes name=inspdet_qa dbname="inspdet.qa" )
 column=(type=decimal(2) updatewhereclause=yes name=qty dbname="qty" )
 column=(type=decimal(4) updatewhereclause=yes name=cqty dbname="cqty" )
 column=(type=datetime updatewhereclause=yes name=s dbname="s" )
 column=(type=datetime updatewhereclause=yes name=e dbname="e" )
 column=(type=decimal(6) updatewhereclause=yes name=ccost dbname="ccost" )
 column=(type=decimal(8) updatewhereclause=yes name=camt dbname="camt" )
 column=(type=decimal(6) updatewhereclause=yes name=ship_amount dbname="ship_amount" )
 retrieve="  SELECT supp.supp_name                                    
       , insp_flag                                      
       , groupitem.item_name                               
       , groupitem.uom                                     
       , inspdet.qa  
       , qty   = isnull(sum(rcpt_qty), 0)                  
       , cqty  = isnull(sum(comqty),   0)                    
       , s     = convert(smalldatetime, :arg_date1, 111)   
       , e     = convert(smalldatetime, :arg_date2, 111)   
       , ccost = isnull(sum(ROUND(comqty * inspdet.price, 0, 1) ), 0) / isnull(sum(comqty), 0)
       , camt  = isnull(sum(case when supp.round = 'Y' then ROUND(comqty * inspdet.price, 0, 0) 
                                 else ROUND(comqty * inspdet.price, 0, 1) 
                            end), 0)
       , ship_amount = sum(isnull(b.ship_amount,0))
   FROM groupitem   
       , insp        
       , purdet      
       , supp
       , inspdet left outer join        
        (
				  SELECT insp_no     = a.insp_no
						 , oi_no       = min(a.oi_no)
						 , ship_amount = avg(a.ship_amount)
					 FROM (
							SELECT inspdet.insp_no
								  , inspdet.oi_no
								  , ship_amount = insp.ship_amount
							  FROM inspdet     
								  , insp        
							 WHERE ( insp.insp_no             = inspdet.insp_no )   
								AND ( insp.insp_date     BETWEEN :arg_date1 AND :arg_date2 )
						  ) A
					 GROUP BY a.insp_no
         ) B  on  inspdet.insp_no = b.insp_no AND inspdet.oi_no = b.oi_no
   WHERE ( groupitem.item_no = inspdet.item_no )   
     AND ( insp.insp_no      = inspdet.insp_no )   
     AND ( inspdet.pur_no    = purdet.order_no )   
     AND ( inspdet.seq_no    = purdet.seq_no   )   
     AND ( insp.supp_no      = supp.supp_no    )       
     AND ( ( insp.supp_no        LIKE :arg_supp                  ) AND  
           ( insp.insp_date   BETWEEN :arg_date1 AND :arg_date2  ) AND  
           ( ( insp.area_no      LIKE left(:as_area,1) + '%'        ) or
             ( left(:as_area,1) = 'S' AND inspdet.pur_no LIKE 'PUR%')
           )
         )    
   GROUP BY supp.supp_name     ,   
            insp_flag          ,
            groupitem.item_name,   
            groupitem.uom      ,   
            inspdet.qa   

/*
    FROM groupitem   
       , inspdet     
       , insp        
       , purdet      
       , supp  
       , (
				  SELECT insp_no     = a.insp_no
						 , oi_no       = min(a.oi_no)
						 , ship_amount = avg(a.ship_amount)
					 FROM (
							SELECT inspdet.insp_no
								  , inspdet.oi_no
								  , ship_amount = insp.ship_amount
							  FROM inspdet     
								  , insp        
							 WHERE ( insp.insp_no             = inspdet.insp_no )   
								AND ( insp.insp_date     BETWEEN :arg_date1 AND :arg_date2 )
						  ) A
					 GROUP BY a.insp_no
         ) B 
   WHERE ( groupitem.item_no = inspdet.item_no )   
     AND ( insp.insp_no      = inspdet.insp_no )   
     AND ( inspdet.pur_no    = purdet.order_no )   
     AND ( inspdet.seq_no    = purdet.seq_no   )   
     AND ( insp.supp_no      = supp.supp_no    )   
     AND ( inspdet.insp_no *= b.insp_no AND inspdet.oi_no *= b.oi_no)
     AND ( ( insp.supp_no        LIKE :arg_supp                  ) AND  
           ( insp.insp_date   BETWEEN :arg_date1 AND :arg_date2  ) AND  
           ( ( insp.area_no      LIKE left(:as_area,1) + '%'        ) or
             ( left(:as_area,1) = 'S' AND inspdet.pur_no LIKE 'PUR%')
           )
         )    
   GROUP BY supp.supp_name     ,   
            insp_flag          ,
            groupitem.item_name,   
            groupitem.uom      ,   
            inspdet.qa   
*/" arguments=(("arg_supp", string),("arg_date1", date),("arg_date2", date),("as_area", string))  sort="groupitem_insp_flag A groupitem_item_name A inspdet_qa A " )
