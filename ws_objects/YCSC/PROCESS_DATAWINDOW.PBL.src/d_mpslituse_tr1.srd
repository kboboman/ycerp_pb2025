detail(height=68 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=coilsfcday_sfc_date dbname="sfc_date" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=coil_no dbname="coil_no" )
 column=(type=char(20) updatewhereclause=yes name=coilmst_qa dbname="qa" )
 column=(type=decimal(4) updatewhereclause=yes name=qty dbname="qty" )
 column=(type=long updatewhereclause=yes name=coilmst_cnt dbname="cnt" )
 column=(type=char(10) updatewhereclause=yes name=wc_name dbname="wc_name" )
 column=(type=datetime updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=datetime updatewhereclause=yes name=edate dbname="edate" )
 column=(type=char(1) updatewhereclause=yes name=flag dbname="flag" values="원코일 현황	W/스리팅 현황	S/" )
 column=(type=datetime updatewhereclause=yes name=sfc_date dbname="sfc_date" )
 retrieve="  SELECT DISTINCT sfc_date = coilsfcday.sfc_date   
       , item_name = groupitem.item_name           
       , coil_no   = coilsfcday.w_coil_no          
       , qa        = coilmst.qa                    
       , qty       = coilmst.unit_qty              
       , cnt       = coilmst.cnt                   
       , wc_name   = wc.work_name                  
       , sdate     = convert(smalldatetime, :ad_start, 111)   
       , edate     = convert(smalldatetime, :ad_end,   111)
       , flag      = 'W'  
       , sfc_date  = coilsfcday.sfc_date
    FROM coilsfcday inner join coilmst on coilsfcday.w_coil_no = coilmst.coil_no and coilsfcday.wloc_no = coilmst.loc_no
                                  inner join groupitem on coilmst.item_no = groupitem.item_no
                                  inner join wc on coilsfcday.wc_no = wc.work_no   
     WHERE ( coilsfcday.sfc_date   BETWEEN :ad_start AND :ad_end ) 
     AND ( :as_area                    = 'S0001'               )
  UNION ALL
  SELECT DISTINCT sfc_date = coilsfcday.sfc_date              
       , item_name = groupitem.item_name                      
       , coil_no   = coilordersum.coil_no                     
       , qa        = coilmst.qa                               
       , qty       = coilmst.unit_qty                         
       , cnt       = coilmst.cnt                              
       , wc_name   = wc.work_name                             
       , sdate     = convert(smalldatetime, :ad_start, 111)   
       , edate     = convert(smalldatetime, :ad_end, 111)  
       , flag      = 'W'    
       , sfc_date  = coilsfcday.sfc_date
    FROM coilsfcday inner join coilordersum on  coilsfcday.order_no = coilordersum.order_no
                                  inner join coilmst on coilordersum.coil_no = coilmst.coil_no and coilordersum.loc_no = coilmst.loc_no
                                  inner join groupitem on coilmst.item_no = groupitem.item_no
                                  inner join wc on coilsfcday.wc_no = wc.work_no
   WHERE ( coilsfcday.sfc_date    BETWEEN :ad_start AND :ad_end ) 
     AND ( :as_area                     = 'S0001'               )

  UNION ALL
  SELECT sfc_date  = convert(datetime, convert(char(10), sfcuse.use_date,121) )
       , item_name = groupitem.item_name   
       , coil_no   = sfcuse.coil_no        
       , qa        = sfcuse.qa             
       , qty       = sfcuse.unit_qty       
       , cnt       = sfcuse.cnt            
       , wc_name   = wc.work_name          
       , sdate     = convert(smalldatetime, :ad_start, 111)   
       , edate     = convert(smalldatetime, :ad_end,   111)
       , flag      = 'S'  
       , sfc_date  = sfcuse.use_date
    FROM sfcuse inner join groupitem on sfcuse.item_no = groupitem.item_no
                            left outer join wc  on sfcuse.wc_no = wc.work_no
   WHERE ( ( sfcuse.use_date  BETWEEN convert(datetime,  :ad_start +' 00:00:00' ) and convert(datetime,  :ad_end + ' 23:59:59' ) ) and
                     ( sfcuse.coil_no        is not null              ) ) 
           and ( sfcuse.area_no               = :as_area          )" arguments=(("ad_start", date),("ad_end", date),("as_area", string))  sort="flag D coilsfcday_sfc_date A groupitem_item_name A coilmst_qa A qty A " )
