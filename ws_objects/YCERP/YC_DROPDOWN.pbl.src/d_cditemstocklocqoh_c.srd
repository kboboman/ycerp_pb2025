column(band=detail id=3 alignment="2" tabsequence=32766 border="0" color="0" x="1303" y="4" height="60" width="169" format="[general]" html.valueishtml="0"  name=cat visible="1" edit.limit=0 edit.case=any edit.focusrectangle=no edit.autoselect=no edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
