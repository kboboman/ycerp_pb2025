table(column=(type=char(12) update=yes updatewhereclause=yes key=yes name=vc_no dbname="glbill.vc_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=bill_class dbname="glbill.bill_class" values="받을어음	R/지급어음	P/교환어음	C/만기어음	E/부도어음	D/" )
 column=(type=char(4) update=yes updatewhereclause=yes name=cust_no dbname="glbill.cust_no" )
 column=(type=datetime update=yes updatewhereclause=yes name=close_date dbname="glbill.close_date" )
 column=(type=datetime update=yes updatewhereclause=yes name=start_date dbname="glbill.start_date" )
 column=(type=char(6) update=yes updatewhereclause=yes name=bank_code dbname="glbill.bank_code" )
 column=(type=char(20) update=yes updatewhereclause=yes name=bill_area dbname="glbill.bill_area" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=bill_amount dbname="glbill.bill_amount" )
 column=(type=char(1) update=yes updatewhereclause=yes name=set_flag dbname="glbill.set_flag" initial="N" values="	Y/	N" )
 column=(type=datetime update=yes updatewhereclause=yes name=set_date dbname="glbill.set_date" )
 column=(type=char(20) update=yes updatewhereclause=yes name=draft dbname="glbill.draft" )
 column=(type=char(40) update=yes updatewhereclause=yes name=rem dbname="glbill.rem" )
 column=(type=char(10) update=yes updatewhereclause=yes name=set_user dbname="glbill.set_user" )
 column=(type=char(12) update=yes updatewhereclause=yes key=yes name=bill_no dbname="glbill.bill_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=set_view dbname="glbill.set_view" values="	Y/	N" )
 retrieve="  SELECT glbill.vc_no,   
         glbill.bill_class,   
         glbill.cust_no,   
         glbill.close_date,   
         glbill.start_date,   
         glbill.bank_code,   
         glbill.bill_area,   
         glbill.bill_amount,   
         glbill.set_flag,   
         glbill.set_date,   
         glbill.draft,   
         glbill.rem,   
         glbill.set_user,   
         glbill.bill_no ,
         glbill.set_view 
    FROM glbill  
   WHERE ( glbill.vc_no = :as_vc_no ) AND  
         ( glbill.bill_no = :as_bill_no )    
" update="glbill" updatewhere=1 updatekeyinplace=yes arguments=(("as_vc_no", string),("as_bill_no", string)) )
