 retrieve="  SELECT custdiary.diary_date,   
         custdiary.emp_no,   
         custdiary.seq_no,   
         custdiary.team_code,   
         custdiary.cust_no,   
         custdiary.cust_name,   
         custdiary.bdcust_no,   
         custdiary.bdcust_name,   
         custdiary.start_time,   
         custdiary.end_time,   
         custdiary.desc1,   
         custdiary.desc2,   
         custdiary.desc3,   
         custdiary.desc4,   
         custdiary.desc5,   
         custdiary.desc6,   
         custdiary.desc7,   
         custdiary.desc8,   
         custdiary.desc9,   
         custdiary.desc10,   
         custdiary.proc1,   
         custdiary.proc2,   
         custdiary.proc3,   
         custdiary.proc4,   
         custdiary.proc5,   
         custdiary.proc6,   
         custdiary.proc7,   
         custdiary.proc8,   
         custdiary.proc9,   
         custdiary.proc10,   
         custdiary.process_flag,   
         custdiary.check2,   
         custdiary.urgent,   
         custdiary.sys_date,   
         custdiary.approve_team,   
         custdiary.check_date,   
         custdiary.approve_top,   
         chk_team = ( case when ( custdiary.approve_team is null ) or (  custdiary.approve_team = '') then ~"N~" else ~"Y~" end )  
    FROM custdiary  
   WHERE ( ( custdiary.diary_date = :ad_diary ) AND  
         ( custdiary.emp_no = :as_userid )  AND  
         ( custdiary.seq_no = :as_seq ) )    

" update="custdiary" updatewhere=0 updatekeyinplace=no arguments=(("as_userid", string),("ad_diary", date),("as_seq", number)) )
