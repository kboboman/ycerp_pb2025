detail(height=76 color="536870912" )
table(column=(type=char(4) update=yes updatewhereclause=yes key=yes name=color_code dbname="color.color_code" )
 column=(type=char(10) update=yes updatewhereclause=yes name=color_name dbname="color.color_name" )
 column=(type=char(60) update=yes updatewhereclause=yes name=color_lname dbname="color.color_lname" )
 column=(type=char(4) update=yes updatewhereclause=yes name=cat1 dbname="color.cat1" )
 column=(type=char(4) update=yes updatewhereclause=yes name=cat2 dbname="color.cat2" )
 column=(type=char(255) update=yes updatewhereclause=yes name=color_bigo dbname="color.color_bigo" )
 column=(type=long update=yes updatewhereclause=yes name=r dbname="color.R" )
 column=(type=long update=yes updatewhereclause=yes name=g dbname="color.G" )
 column=(type=long update=yes updatewhereclause=yes name=b dbname="color.B" )
 column=(type=char(50) update=yes updatewhereclause=yes name=maker dbname="color.maker" )
 column=(type=char(20) update=yes updatewhereclause=yes name=color_type dbname="color.color_type" )
 column=(type=char(50) update=yes updatewhereclause=yes name=product_no dbname="color.product_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=sample_no dbname="color.sample_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=handle dbname="handle" initial="N" values="	Y/	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=use_yn dbname="color.use_yn" initial="Y" values="	Y/	N" )
 column=(type=datetime update=yes updatewhereclause=yes name=sys_date dbname="color.sys_date" initial="getdate()" )
 column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" )
 retrieve="  SELECT color.color_code,   
         color.color_name,   
         color.color_lname,   
         color.cat1,   
         color.cat2,   
         color.color_bigo,   
         color.R,   
         color.G,   
         color.B,   
         color.maker,   
         color.color_type,   
         color.product_no,   
         color.sample_no,   
         handle = color.handle,
         color.use_yn,
         color.sys_date,
         chk    = 'N'
    FROM color   
" update="color" updatewhere=1 updatekeyinplace=no  sort="use_yn D cat1 A cat2 A color_lname A " )
