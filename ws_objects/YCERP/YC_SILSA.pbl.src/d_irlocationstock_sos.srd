detail(height=88 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=loc_no dbname="loc_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_nm dbname="item_nm" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(255) updatewhereclause=yes name=cdate dbname="cdate" )
 column=(type=decimal(2) updatewhereclause=yes name=in_qty dbname="in_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=out_qty dbname="out_qty" )
 column=(type=long updatewhereclause=yes name=qoh dbname="qoh" )
 column=(type=long updatewhereclause=yes name=base_qty dbname="base_qty" )
 column=(type=char(2) updatewhereclause=yes name=iotype dbname="iotype" )
 column=(type=char(17) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(30) updatewhereclause=yes name=bigo dbname="bigo" )
 column=(type=datetime updatewhereclause=yes name=ctime dbname="ctime" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 retrieve="
SELECT loc_no    = a.loc_no  
     , item_no   = a.item_no 
     , item_nm   = b.item_name
     , qa        = a.qa      
     , cdate     = a.cdate
     , in_qty    = a.in_qty
     , out_qty   = a.out_qty
     , qoh       = a.qoh
     , base_qty  = 0
     , iotype    = a.iotype
     , cust_no   = a.order_no
     , bigo      = a.bigo
     , ctime     = a.ctime
     , user_name = c.user_name
  FROM (
       /*=============================================================================================================*/
       /* 지점재고                                                                                                    */
       /*=============================================================================================================*/
       SELECT loc_no    = a.loc_no
            , item_no   = a.inaudit_item
            , qa        = a.qa
            , cdate     = replace( convert(char(10),a.inaudit_date,111), '/', '') 
            , ctime     = a.inaudit_time
            , in_qty    = a.rcpt_qty
            , out_qty   = a.issue_qty
            , qoh       = 0
            , iotype    = a.inaudit_type
            , bigo      = a.rem
            , order_no  = a.order_no
            , user_id   = a.user_id
            , tbl_name  = 'INEODAY_LOC'
         FROM INAUDIT_LOC a WITH (NOLOCK)
        WHERE a.loc_no   = :as_locno
          AND a.inaudit_date = replace(convert(char(10), :as_sdate, 111),'/','')
       ) A
       LEFT OUTER JOIN groupitem B  ON a.item_no = b.item_no
       LEFT OUTER JOIN login     C  ON a.user_id = c.user_id
" arguments=(("as_locno", string),("as_sdate", string))  sort="loc_no A item_nm A qa A " )
