GF_USEPROGRAM( gs_userid, THIS.ClassName(), "O", string(gf_today(),'yyyy/mm/dd'), THIS.Title )
//=============================================================================================

///////////////////////////////////////////////////////////////////////////////////////////////////
st_vertical1.of_set_leftobject(dw_2)
st_vertical1.of_set_rightobject(dw_1)
st_vertical1.of_set_minsize(250, 250)

st_vertical2.of_set_leftobject(dw_1)
st_vertical2.of_set_rightobject(dw_14)
st_vertical2.of_set_minsize(250, 250)

tab_1.tabpage_7.st_vertical3.of_set_leftobject( tab_1.tabpage_7.dw_12 )
tab_1.tabpage_7.st_vertical3.of_set_rightobject(tab_1.tabpage_7.dw_10 )
tab_1.tabpage_7.st_vertical3.of_set_minsize(250, 250)

st_horizontal.of_set_topobject(dw_2)
st_horizontal.of_set_topobject(dw_1)
st_horizontal.of_set_topobject(dw_14)
st_horizontal.of_set_bottomobject(tab_1)
st_horizontal.of_set_minsize(250, 250)
///////////////////////////////////////////////////////////////////////////////////////////////////

ddlb_fld.reset()
ddlb_dwtitles.reset()
ddlb_dwtitles.visible = false

pb_compute.visible = false
pb_5.enabled       = false
dw_9.visible       = false
dw_13.visible      = false
dw_15.visible      = false
dw_16.visible      = false
dw_jaego.visible   = false
tab_1.tabpage_4.cb_18.enabled = false	// 수주물품별 재고현황(NEW) 가져오기

if GF_PERMISSION("발주등록_관리", gs_userid) = "Y" then	
else
	pb_insert.enabled = false
	pb_delete.enabled = false
	pb_save.enabled   = false
end if

dw3  = tab_1.tabpage_1.dw_3		// 발주서내역
dw4  = tab_1.tabpage_2.dw_4		// 외주가공내역
dw5  = tab_1.tabpage_3.dw_5		// 외주구매내역
dw6  = tab_1.tabpage_4.dw_6		// 수주내역
dw7  = tab_1.tabpage_5.dw_7		// 부족자재내역
dw8  = tab_1.tabpage_6.dw_8		// 자재가공내역
dw10 = tab_1.tabpage_7.dw_10		// 외주스리팅
dw12 = tab_1.tabpage_7.dw_12		// SHEET가공
dw17 = tab_1.tabpage_8.dw_17		// 수주내역(rout)

// TriggerEvent는 실행안됨(복사한 데이터가 넘어올때까지 기다림)
this.PostEvent('ue_1')

//// 수주물품별 재고현황(복사 값)
//if dw_jaego.rowcount() > 0 then
//	tab_1.selecttab(4)	// 수주내역
//	tab_1.tabpage_4.cb_18.enabled = true
//end if

end event

event resize;call super::resize;//
long ll_width, ll_height

gb_3.width   = newwidth  - (gb_3.x * 2)

if ib_first = false then
	dw_2.width  = 2520
	ib_first    = true
else
	dw_2.height  = dw_2.height
end if

st_vertical1.x      = dw_2.x + dw_2.width
st_vertical1.height = dw_2.height

dw_1.x       = st_vertical1.x + st_vertical1.width
dw_1.height  = dw_2.height

st_vertical2.x      = dw_1.x + dw_1.width
st_vertical2.height = dw_1.height

dw_14.x      = st_vertical2.x + st_vertical2.width
dw_14.width  = newwidth  - dw_14.x - gb_3.x
dw_14.height = dw_2.height

st_horizontal.y      = dw_2.y + dw_2.height
st_horizontal.width  = newwidth  - (gb_3.x * 2)

//
tab_1.width  = newwidth  - (gb_3.x * 2)
tab_1.height = newheight - tab_1.y - gb_3.x

ll_width     = tab_1.tabpage_1.width
ll_height    = tab_1.tabpage_1.height - tab_1.tabpage_1.dw_3.y 

tab_1.tabpage_1.dw_3.width  = ll_width 		// 발주서내역
tab_1.tabpage_1.dw_3.height = ll_height

tab_1.tabpage_2.dw_4.width  = tab_1.tabpage_1.dw_3.width  	// 외주가공내역
tab_1.tabpage_2.dw_4.height = tab_1.tabpage_1.dw_3.height

tab_1.tabpage_3.dw_5.width  = tab_1.tabpage_1.dw_3.width  	// 외주구매내역
tab_1.tabpage_3.dw_5.height = tab_1.tabpage_1.dw_3.height

tab_1.tabpage_4.dw_6.width  = tab_1.tabpage_1.dw_3.width  	// 수주내역
tab_1.tabpage_4.dw_6.height = tab_1.tabpage_1.dw_3.height

tab_1.tabpage_5.dw_7.width  = tab_1.tabpage_1.dw_3.width  	// 부족자재내역
tab_1.tabpage_5.dw_7.height = tab_1.tabpage_1.dw_3.height

tab_1.tabpage_6.dw_8.width  = tab_1.tabpage_1.dw_3.width  	// 자재가공내역
tab_1.tabpage_6.dw_8.height = tab_1.tabpage_1.dw_3.height

//
ll_width    = tab_1.width - (tab_1.tabpage_7.dw_12.width + tab_1.tabpage_7.dw_10.width) / 2
tab_1.tabpage_7.dw_12.height = tab_1.tabpage_1.dw_3.height	// SHEET가공

tab_1.tabpage_7.st_vertical3.x      = tab_1.tabpage_7.dw_12.x + tab_1.tabpage_7.dw_12.width 
tab_1.tabpage_7.st_vertical3.height = tab_1.tabpage_7.dw_12.height

tab_1.tabpage_7.dw_10.width  = tab_1.width - (tab_1.tabpage_7.dw_12.width + 64) // 외주스리팅
tab_1.tabpage_7.dw_10.height = tab_1.tabpage_1.dw_3.height


tab_1.tabpage_8.dw_17.width  = tab_1.tabpage_1.dw_3.width  	// 수주내역
tab_1.tabpage_8.dw_17.height = tab_1.tabpage_1.dw_3.height
end event

type pb_save from w_inheritance`pb_save within w_ippurchasenew_m
integer x = 4279
integer y = 60
end type

event pb_save::clicked;// 저장
//==GF_USEPROGRAM(프로그램 사용현황)==============================================================
GF_USEPROGRAM( gs_userid, Parent.ClassName(), "S", string(gf_today(),'yyyy/mm/dd'), Parent.Title )
//================================================================================================

dwItemStatus l_status
datetime ldt_date
string ls_order, ls_num, ls_subcon
long   ll_row, i, ll_count1 = 0 , ll_count2 = 0, ll_rowcount, ll_seq
int    li_num, li_exist
real   lr_qty, lr_oldqty, l_amount
string ls_item, ls_qa, ls_string, ls_like, ls_chk
string ls_yyyymm, ls_supp_no


dw_1.accepttext()
dw3.accepttext()
dw8.accepttext()

if dw_1.rowcount() < 1 then RETURN

debugbreak()

ls_supp_no = dw_1.object.supp_no[1]
ls_yyyymm  = LeftA(string(dw_1.object.order_date[1]),4)+MidA(string(dw_1.object.order_date[1]),6,2)

l_status = dw_1.GetItemStatus(1,0, Primary!)
if l_status = newmodified! then 
	if isnull(dw_1.object.supp_no[1]) or trim(dw_1.object.supp_no[1]) = '' then
		dw_1.setcolumn('supp_no')
		dw_1.setfocus()
		RETURN
	end if
else
	ls_order = dw_1.object.order_no[1]
	if trim(dw_1.object.po_print[1]) = 'Y' then
		MessageBox("경고", "발주확정 상태에서는 수정 불가능합니다.~r~r'확정취소 관리'에서 작업 후 진행하시기 바랍니다.", Exclamation!)
		RETURN
	else
		setnull(ls_chk)
		SELECT po_print INTO :ls_chk FROM pur WHERE order_no = :ls_order;
		if ls_chk = 'Y' then
			MessageBox("경고", "재조회 후 작업 하십시요,~r~n'발주확정' 상태는 수정이 불가능합니다.", Exclamation!)
			RETURN
		end if
	end if
end if

for i = 1 to dw3.rowcount()
	l_status = dw3.GetItemStatus(i,0, Primary!)
	if l_status <> NotModified! then
		ls_item = trim(dw3.GetItemString(i, "item_no")) 
		ls_qa   = trim(dw3.GetItemString(i, "qa"))
		SELECT count(*) INTO :li_exist FROM item WHERE item_no = :ls_item AND qa = :ls_qa;

		
		if sqlca.sqlcode = 100 or li_exist = 0 then
			/* jowonsuk 2018.07.02 추가 작업 */		
			if GF_ITEMINSERT(ls_item, ls_qa) = false then
			else
				MessageBox('확인','규격이 추가되었습니다')
			end if
			
			SELECT count(*) INTO :li_exist FROM item WHERE item_no = :ls_item AND qa = :ls_qa;			
			
			if sqlca.sqlcode = 100 or li_exist = 0 then			
				MessageBox('오류1','발주서 상세의 ' + string(i) + ' 번째 물품과 규격이 미등록 상태입니다.',exclamation!)
				RETURN				
			end if
		end if
	end if
next

for i = 1 to dw8.rowcount()
	l_status = dw8.GetItemStatus(i,0, Primary!)
	if l_status <> NotModified! then
		ls_item = trim(dw8.GetItemString(i, "item_no")) 
		ls_qa   = trim(dw8.GetItemString(i, "qa"))
		SELECT count(*) INTO :li_exist FROM item WHERE item_no = :ls_item	AND qa = :ls_qa;
		if sqlca.sqlcode = 100 or li_exist = 0 then
			MessageBox('오류2','자재가공내역상세의 ' + string(i) + ' 번째 가공물품이 잘못되었습니다',exclamation!)
			RETURN
		end if
		
		ls_item = trim(dw8.GetItemString(i, "assy_item")) 
		ls_qa   = trim(dw8.GetItemString(i, "assy_qa"))
		SELECT count(*) INTO :li_exist FROM item WHERE item_no = :ls_item	AND qa = :ls_qa;
		if sqlca.sqlcode = 100 or li_exist = 0 then
			MessageBox('오류3','자재가공내역상세의 ' + string(i) + ' 번째 가공물품이 잘못되었습니다',exclamation!)
			RETURN
		end if
	end if
next
ll_count1 = wf_modifycount(dw_1)
ll_count2 = wf_modifycount(dw3)

////////////////////////////////////////////////
if dw_1.rowcount() < 1 then GOTO aaa
////////////////////////////////////////////////

ll_count1 += ll_count2
if ll_count1 > 0 then
	dw_1.object.revision_no[1]   = dw_1.object.revision_no[1] + 1
	dw_1.object.revision_date[1] = wf_today()
end if

dw_1.accepttext()
dw3.accepttext()
l_status = dw_1.GetItemStatus(1,0, Primary!)
if l_status = newmodified! then 
	if dw3.rowcount() < 1 then RETURN

//	ls_order  = dw_1.object.order_no[1]
   /*2019-09-06 JOWONSUK 발주시 현재 99개가 MAX임, 99->999개로 가능 토록 변경 2019.09.10부터 변경 하도록 */
   if string(gf_today() ,'yyyymmdd')  >= '20190910' then
		
		ldt_date  = dw_1.object.order_date[1]
		ls_string = LeftA(dw_area.object.area[1],1) + string(ldt_date,'yymmdd')
		ls_like   = ls_string + '%'
		
		setnull(ls_order)
		
		SELECT MAX(order_no) INTO :ls_order FROM pur WHERE order_no LIKE :ls_like; 
		
		if isnull(ls_order) then
			ls_string = ls_string + '001'
		else
			li_num    = integer(RightA(trim(ls_order),3))
			li_num++
			ls_num    = RightA('00000' + string(li_num),3)
			ls_string = ls_string + ls_num
		end if				
		
   else		
		
		ldt_date  = dw_1.object.order_date[1]
		ls_string = LeftA(dw_area.object.area[1],1) + "P" + string(ldt_date,'yymmdd')
		ls_like   = ls_string + '%'
		
		setnull(ls_order)
		
		SELECT MAX(order_no) INTO :ls_order FROM pur WHERE order_no LIKE :ls_like; 
		
		if isnull(ls_order) then
			ls_string = ls_string + '01'
		else
			li_num    = integer(RightA(trim(ls_order),2))
			li_num++
			ls_num    = RightA('00000' + string(li_num),2)
			ls_string = ls_string + ls_num
		end if		
		
   end if

//   ldt_date  = dw_1.object.order_date[1]
//   ls_string = left(dw_area.object.area[1],1) + "P" + string(ldt_date,'yymmdd')
//   ls_like   = ls_string + '%'
//	
//   setnull(ls_order)
//	
//   SELECT MAX(order_no) INTO :ls_order FROM pur WHERE order_no LIKE :ls_like; 
//	
//   if isnull(ls_order) then
//	   ls_string = ls_string + '01'
//   else
//	   li_num    = integer(right(trim(ls_order),2))
//	   li_num++
//	   ls_num    = right('00000' + string(li_num),2)
//	   ls_string = ls_string + ls_num
//   end if
	
	// 발주번호 중복체크 
	SELECT count(*) INTO :li_exist FROM pur WHERE order_no = :ls_string;
	if li_exist > 0 then
		MessageBox('오류','발주번호( ' + ls_string + ' ) 중복체크 오류가 발생하였습니다.~r~n' + &
		           '발주서는 일자별로 100건을 초과할 수 없습니다.',exclamation!)
		RETURN
	end if
	
	dw_1.object.order_no[1] = ls_string
	dw_1.object.area_no[1]  = dw_area.object.area[1]
	ll_row = dw3.rowcount()
	for i = 1 to ll_row
		 dw3.object.order_no[i] = ls_string
	next
end if

/// 확인불가 ///////////////////////////////
dw_9.dataobject = 'd_prslitcon_h'
dw_9.settransobject(sqlca)
////////////////////////////////////////////

ls_subcon   = trim(dw_1.object.subcon[1])
ll_rowcount = dw3.deletedcount()
for i = 1 to ll_rowcount
	if WF_DeleteProc(ls_subcon,i) = false then RETURN
next

ll_rowcount = dw3.rowcount()
for i = 1 to ll_rowcount
   l_status = dw3.GetItemStatus(i,0, Primary!)
	
	if l_status = notmodified! then continue
	
	/* 2019.02.07 jowonsuk 시작*/	
	ls_item = trim(dw3.GetItemString(i, "item_no")) 
	ls_qa   = trim(dw3.GetItemString(i, "qa"))
	lr_qty  = dw3.GetItemNumber(i, "order_qty")
	l_amount = dw3.GetItemNumber(i, "price")
	/* 2019.02.07 jowonsuk 끝*/	
		
	if l_status = newmodified! then
		// 구매'N'/ 수입'L'
		// 발주구분 : 외주구매'Y'/자재가공'J'/외주가공'P'/외주스리팅가공시'C'의 처리.
		if (ls_subcon = 'Y' or ls_subcon = 'J' or ls_subcon = 'P' or ls_subcon = 'C') then
			if WF_OutProc(ls_subcon, i) = false then 
		  		rollback;
				MessageBox('오류','저장오류!',exclamation!)
				RETURN
			end if
		end if
	elseif l_status = datamodified! then
		ls_order = trim(dw3.GetItemString(i, "order_no"))
		ll_seq   = dw3.GetItemNumber(i, "seq_no")
		SELECT order_qty INTO :lr_oldqty FROM purdet WHERE order_no = :ls_order AND seq_no = :ll_seq;
	   if sqlca.sqlcode <> 0 then
		   rollback;
		   MessageBox('오류20','purdet검색중 오류가 발생하였습니다.',exclamation!)
		   RETURN
	   end if
		
		lr_qty = lr_qty - lr_oldqty
	end if	
	
	UPDATE item 
	   SET pur_reserved = pur_reserved + :lr_qty
	 WHERE item_no = :ls_item AND qa = :ls_qa;
	if sqlca.sqlcode < 0 then
		rollback;
		MessageBox('오류21','item수행중 오류가 발생하였습니다.',exclamation!)
		RETURN
	end if
	
	/* 2019.02.07 jowonsuk */
	update supplier_unit_det 
		set amount = :l_amount
	from supplier_unit_det A INNER JOIN (
															select supp_no, max(ver) ver
															  from supplier_unit
															where  yyyymm <= :ls_yyyymm
																 and use_yn = 'Y'
															 group by supp_no
													) B  on a.supp_no = b.supp_no and a.ver = b.ver
	where   a.supp_no = :ls_supp_no
		and  a.item_no = :ls_item
		and  a.qa = :ls_qa
		and  isnull(a.amount,0) <> :l_amount;
	
	
	if sqlca.sqlcode < 0 then
		rollback;
		MessageBox('오류22','거래처 단가 update 중 오류가 발생하였습니다.',exclamation!)
		RETURN
	end if
	/* 2019.02.07 jowonsuk */
	
next

aaa:
if dw_1.rowcount() < 1 then RETURN

if dw3.rowcount() < 1 then		// 상세품목 없으면 헤더삭제
	dw_1.deleterow(0)
else	
	///////////////////////////////////////////////
	// 발주 저장시 자동 확정처리로 변경.
	///////////////////////////////////////////////
	dw_1.object.po_print[1] = 'Y'
	///////////////////////////////////////////////	
end if

if WF_Update2( dw_1, dw3, "Y" ) = false then
	dw_1.object.po_print[1] = 'N'
else
	ls_order = trim(dw3.object.order_no[dw3.getrow()])
	dw3.retrieve( ls_order )
	if dw12.rowcount() > 0 then dw12.reset()
end if

pb_5.enabled = true		// 발주서내역으로 이동


end event

type dw_1 from w_inheritance`dw_1 within w_ippurchasenew_m
integer x = 2025
integer y = 424
integer width = 2450
integer height = 888
integer taborder = 80
string dataobject = "d_ippur_m"
boolean hscrollbar = false
boolean vscrollbar = false
end type

event dw_1::itemchanged;long   ll_row, ll_rows
string ls_curr,ls_subcon, ls_supp, ls_addr, ls_clause, ls_where ,ls_tel_no

this.accepttext()

choose case dwo.name
	case "supp_no"
		ls_supp = trim(data)
		if isnull(ls_supp) or ls_supp = "" then
		else
			SELECT currency_type, addr, round, tel_no 
			  INTO :ls_curr, :ls_addr, :is_round, :ls_tel_no 
			  FROM supp
			 WHERE supp_no = :ls_supp;
			
			if sqlca.sqldbcode = 0 then
				this.object.shipto_addr[1] = ls_addr
				this.object.shipto_tel[1]  = ls_tel_no
				this.object.curr_code[1]   = ls_curr
				
				ls_clause = " where supp_no = '" + ls_supp + "'"
				ls_where  = 'DataWindow.Table.Select="'  + is_select + ls_clause + '"'
				
				if dw3.dataobject = "d_ippurdet" then		// 일반발주 
					dw3.getchild('draw_no',idwc_draw)
					idwc_draw.Modify(ls_where)
					idwc_draw.settransobject(sqlca)
					ll_rows = idwc_draw.retrieve()
				else
					// 외주가공, 스리팅
				end if
			end if
		end if
		
	case "subcon"
		if data = 'N' or data = 'L' or data = 'W' then
			tab_1.tabpage_1.pb_3.enabled = true
			tab_1.tabpage_1.pb_4.enabled = true
		else
			tab_1.tabpage_1.pb_3.enabled = false
			tab_1.tabpage_1.pb_4.enabled = false
		end if
end choose

end event

event dw_1::retrieveend;string ls_sub

pb_delete.enabled = true
pb_save.enabled   = true
tab_1.tabpage_1.cb_15.enabled = false
tab_1.tabpage_1.cb_16.enabled = false

if this.rowcount() < 1 then return

ls_sub = this.object.subcon[1]
if ls_sub = "C" then	
   if GF_PERMISSION("발주등록_관리", gs_userid) = "Y" then	
	else
		pb_delete.enabled = false
		pb_save.enabled   = false
	end if

	tab_1.tabpage_1.pb_3.enabled = false // 외주구매내역
	tab_1.tabpage_1.pb_4.enabled = false // 수주내역
else
	tab_1.tabpage_1.pb_3.enabled = true
	tab_1.tabpage_1.pb_4.enabled = true
end if

//st_bug.text = "dw_1.retrieveend......."
end event

event dw_1::rbuttondown;CHOOSE CASE dwo.name
	CASE 'order_date'
		openWithParm(w_calendar, message.stringparm)
		if message.stringparm <> 'N' then
			this.object.order_date[row] = datetime(date(message.stringparm))
		end if
END CHOOSE
this.accepttext()

end event

event dw_1::clicked;call super::clicked;//
string  ls_orderno

if isnull(row) OR row < 1 then RETURN

ls_orderno  = trim(this.object.order_no[1])

if isnull(ls_orderno) OR ls_orderno = "" then
	choose case dwo.name
		case "b_supply"
//			dw_15.width   = 3173
			if dw_15.visible = true then
				dw_15.visible = false
			else
				dw_15.width   = 4813
				dw_15.height  = 1500
				dw_15.x       = (Parent.width  - dw_15.width ) / 2
				dw_15.y       = (Parent.height - dw_15.height) / 2
				
				dw_15.visible = true
				dw_15.retrieve()
				
			end if
	end choose
end if

end event

