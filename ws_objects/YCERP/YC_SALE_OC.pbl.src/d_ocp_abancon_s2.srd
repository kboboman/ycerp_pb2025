$PBExportComments$제품폐기등록 디테일(2003/05/30이규배)
release 8;
datawindow(units=0 timer_interval=0 color=67108864 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=aban_no dbname="itemabandet.aban_no" )
 column=(type=long updatewhereclause=yes name=seq dbname="itemabandet.seq" )
 column=(type=char(10) updatewhereclause=yes name=loc_no dbname="itemabandet.loc_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="itemabandet.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="itemabandet.qa" )
 column=(type=decimal(4) updatewhereclause=yes name=qty dbname="itemabandet.qty" initial="0" )
 column=(type=decimal(4) updatewhereclause=yes name=price dbname="itemabandet.price" initial="0" )
 column=(type=decimal(0) updatewhereclause=yes name=amount dbname="itemabandet.amount" initial="0" )
 column=(type=char(1) updatewhereclause=yes name=flag dbname="itemabandet.flag" initial="O" values="등록	O/폐기	Y/마감	C/" )
 column=(type=char(50) updatewhereclause=yes name=bigo dbname="itemabandet.bigo" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="groupitem.uom" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="groupitem.item_name" )
 retrieve="  SELECT itemabandet.aban_no,   
         itemabandet.seq,   
         itemabandet.loc_no,   
         itemabandet.item_no,   
         itemabandet.qa,   
         itemabandet.qty,   
         itemabandet.price,   
         itemabandet.amount,   
         itemabandet.flag,   
         itemabandet.bigo,   
         groupitem.uom,   
         groupitem.item_name  
    FROM itemabandet,   
         groupitem  
   WHERE ( itemabandet.item_no = groupitem.item_no ) and  
         ( ( itemabandet.aban_no = :as_aban_no )   
         )    
" arguments=(("as_aban_no", string)) )
