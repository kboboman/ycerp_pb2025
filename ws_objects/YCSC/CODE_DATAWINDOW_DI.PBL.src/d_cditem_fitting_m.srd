table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="item_fitting.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=qa dbname="item_fitting.qa" )
 column=(type=char(10) update=yes updatewhereclause=yes name=loc_no dbname="item_fitting.loc_no" )
 column=(type=char(50) update=yes updatewhereclause=yes name=rem dbname="item_fitting.rem" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item.item_name" )
 retrieve="  SELECT a.item_no,   
         a.qa,   
         a.loc_no,   
         a.rem,
			b.item_name  
    FROM item_fitting   a,
			item				b
   WHERE a.item_no = b.item_no
	AND	a.qa = b.qa
  " update="item_fitting" updatewhere=0 updatekeyinplace=no  sort="item_name A qa A " )
