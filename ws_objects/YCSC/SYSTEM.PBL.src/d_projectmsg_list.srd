table(column=(type=long updatewhereclause=yes identity=yes name=id dbname="ID" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="CUST_NO" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="CUST_NAME" )
 column=(type=char(11) updatewhereclause=yes name=scene_code dbname="SCENE_CODE" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="SCENE_DESC" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="USER_NAME" )
 column=(type=char(14) updatewhereclause=yes name=order_no dbname="ORDER_NO" )
 column=(type=char(2) updatewhereclause=yes name=cat dbname="CAT" values="납기//생산	1/재고	2/품질	3/출고	4/" )
 column=(type=char(1) updatewhereclause=yes name=status dbname="STATUS" values="접수	1/진행	2/완료	3/" )
 column=(type=char(100) updatewhereclause=yes name=item_no dbname="ITEM_NO" )
 column=(type=char(10) updatewhereclause=yes name=flogin dbname="FLOGIN" )
 column=(type=char(10) updatewhereclause=yes name=fuser dbname="FUSER" )
 column=(type=datetime updatewhereclause=yes name=msgdate dbname="MSGDATE" )
 column=(type=char(4099) updatewhereclause=yes name=msg dbname="MSG" )
 column=(type=char(1) updatewhereclause=yes name=del dbname="DEL" )
 column=(type=long updatewhereclause=yes name=cnt dbname="CNT" )
 retrieve="SELECT ID         = AA.ID
     , CUST_NO    = AA.CUST_NO
     , CUST_NAME  = AA.CUST_NAME
     , SCENE_CODE = AA.SCENE_CODE
     , SCENE_DESC = AA.SCENE_DESC
     , USER_NAME  = AA.USER_NAME
     , ORDER_NO   = AA.ORDER_NO
     , CAT        = AA.CAT
     , STATUS     = AA.STATUS
     , ITEM_NO    = AA.ITEM_NO
     , FLOGIN     = AA.FLOGIN
     , FUSER      = AA.FUSER
     , MSGDATE    = AA.MSGDATE
     , MSG        = AA.MSG
     , DEL        = AA.DEL
     , CNT        = ISNULL(BB.CNT,0)
  FROM (
        SELECT ID         =  A.ID
             , CUST_NO    =  A.CUST_NO
             , CUST_NAME  =  B.CUST_NAME
             , SCENE_CODE =  A.SCENE_CODE
             , SCENE_DESC =  C.SCENE_DESC
             , USER_NAME  =  D.USER_NAME
             , ORDER_NO   =  A.ORDER_NO
             , CAT        =  A.CAT
             , STATUS     =  A.STATUS
             , ITEM_NO    =  A.ITEM_NO
             , FLOGIN     =  A.FLOGIN
             , FUSER      =  E.USER_NAME
             , MSGDATE    =  A.MSGDATE
             , MSG        =  A.MSG
             , DEL        =  A.DEL
          FROM PROJECTMSG A
               LEFT OUTER JOIN CUSTOMER B  ON A.CUST_NO  = B.CUST_NO
               LEFT OUTER JOIN SCENE    C  ON A.CUST_NO  = C.CUST_NO  AND A.SCENE_CODE  = C.SCENE_CODE
               LEFT OUTER JOIN LOGIN    D  ON A.SALESMAN = D.USER_ID
               LEFT OUTER JOIN LOGIN    E  ON A.FLOGIN   = E.USER_ID
         WHERE A.CUST_NO  IS NOT NULL
           AND A.DEL       = 'N'
       ) AA
       LEFT OUTER JOIN 
       (
        SELECT PKID, CNT = COUNT(*) 
          FROM PROJECTMSGDET 
         WHERE TLOGIN    LIKE :as_userid
         GROUP BY PKID 
       )  BB 
       ON AA.ID      = BB.PKID
   ORDER BY AA.MSGDATE DESC

" arguments=(("as_userid", string))  sort="msgdate D " )
