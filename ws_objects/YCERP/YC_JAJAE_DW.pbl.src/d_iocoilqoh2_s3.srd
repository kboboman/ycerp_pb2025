$PBExportHeader$d_iocoilqoh2_s3.srd
$PBExportComments$코일 당월 입출 현황(YSP사업부)(2004/02/24, 이인호)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="553648127" )
footer(height=68 color="12639424" )
detail(height=76 color="536870912" )
table(column=(type=char(2) updatewhereclause=yes name=sort1 dbname="sort1" )
 column=(type=char(1) updatewhereclause=yes name=sort dbname="sort" )
 column=(type=datetime updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=char(255) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=decimal(2) updatewhereclause=yes name=bal_qty dbname="bal_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=drcpt_qty dbname="drcpt_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=rcpt_qty dbname="rcpt_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=dused_qty dbname="dused_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=used_qty dbname="used_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=qoh dbname="qoh" )
 retrieve="   SELECT sort1
        , sort      = a.sort
        , sdate     = convert(smalldatetime, :ad_date, 111)
        , item_name = replace(A.item_name,'스리팅 ','')
        , bal_qty   = ( sum(A.qoh) - isnull(sum(A.lrcpt_qty), 0) + isnull(sum(A.lused_qty), 0) 
                                   - isnull(sum(A.drcpt_qty), 0) + isnull(sum(A.dused_qty), 0) )   /*전일재고*/
        , drcpt_qty = isnull(sum(A.drcpt_qty), 0)                                                  /*당일입고*/
        , rcpt_qty  = isnull(sum(A.rcpt_qty) , 0) - isnull(sum(A.lrcpt_qty), 0)                    /*당월입고 누계*/
        , dused_qty = isnull(sum(A.dused_qty), 0)                                                  /*당일사용*/
        , used_qty  = isnull(sum(A.used_qty) , 0) - isnull(sum(A.lused_qty), 0)                    /*당월사용 누계*/
        , qoh       = ( sum(A.qoh) - isnull(sum(A.lrcpt_qty), 0) + isnull(sum(A.lused_qty), 0) )   /*당일재고*/
     FROM (
          SELECT sort1     = substring(groupitem.item_no, 3, 1)
               , sort      = dbo.uf_getcoilsort(inspdet.item_no) /*당일 입고*/
               , item_name = groupitem.item_name  
               , drcpt_qty = isnull(sum(inspdet.comqty), 0)
               , rcpt_qty  = 0
               , dused_qty = 0
               , used_qty  = 0
               , lrcpt_qty = 0
               , lused_qty = 0
               , qoh       = 0
            FROM insp      with (nolock)
               , inspdet   with (nolock)
               , groupitem with (nolock)  
               , supp  
           WHERE ( insp.insp_no     = inspdet.insp_no   )   
             AND ( inspdet.item_no  = groupitem.item_no )   
             AND ( insp.supp_no     = supp.supp_no      )   
             AND ( insp.insp_flag   = 'W'               )   
             AND ( insp.insp_date   = :ad_date          )   
             AND ( inspdet.loc_no  IN ('WS00000006', 'WW04') )
           GROUP BY substring(groupitem.item_no, 3, 1), inspdet.item_no, item_name
          
          UNION ALL
          
          SELECT sort1     = substring(groupitem.item_no, 3, 1)
               , sort      = dbo.uf_getcoilsort(inspdet.item_no) /* 당월입고 누계*/
               , item_name = groupitem.item_name  
               , drcpt_qty = 0
               , rcpt_qty  = isnull(sum(inspdet.comqty), 0)
               , dused_qty = 0
               , used_qty  = 0
               , lrcpt_qty = 0
               , lused_qty = 0
               , qoh       = 0
            FROM insp      with (nolock)
               , inspdet   with (nolock)
               , groupitem with (nolock)  
               , supp      with (nolock)
           WHERE ( insp.insp_no    = inspdet.insp_no        )   
             AND ( inspdet.item_no = groupitem.item_no      )   
             AND ( insp.supp_no    = supp.supp_no           )   
             AND ( insp.insp_flag  = 'W'                    )   
             AND ( datepart(year,insp.insp_date) = :ai_year )   
             AND ( datepart(month,insp.insp_date) = :ai_mon )   
             AND ( inspdet.loc_no  IN ('WS00000006', 'WW04') )
           GROUP BY substring(groupitem.item_no, 3, 1), inspdet.item_no, item_name
          
          UNION ALL
          
          SELECT sort1     = substring(groupitem.item_no, 3, 1)
               , sort      = dbo.uf_getcoilsort(sfcuse.item_no) /*당일 사용 1*/
               , item_name = groupitem.item_name
               , drcpt_qty = 0
               , rcpt_qty  = 0
               , dused_qty = isnull(sum(( isnull(sfcuse.unit_qty, 0) * isnull(sfcuse.cnt, 0) ) - (  isnull(sfcuse.rem_qty, 0) ) - ( isnull(sfcret.unit_qty, 0) )), 0)
               , used_qty  = 0
               , lrcpt_qty = 0
               , lused_qty = 0
               , qoh       = 0
FROM sfcuse with(nolock) INNER JOIN  groupitem with(nolock) ON sfcuse.item_no = groupitem.item_no
            			                            left outer join sfcret with(nolock) on    sfcuse.use_date = sfcret.ret_date
                                                                                                				and  sfcuse.coil_no = sfcret.wcoil_no 
                                                                                                				and sfcuse.loc_no = sfcret.loc_no               
      where ( 
                     ( sfcuse.use_date   = :ad_date        ) AND  
                     ( sfcuse.coil_no   is not null        )                   
                   ) AND ( sfcuse.loc_no IN ('WS00000006', 'WW04') )
           GROUP BY substring(groupitem.item_no, 3, 1), sfcuse.item_no, item_name                                                                                                        
/*               
            FROM groupitem with (nolock)
               , sfcuse    with (nolock)
               , sfcret    with (nolock)
           WHERE ( sfcuse.item_no      = groupitem.item_no)
             AND ( ( sfcuse.use_date   = :ad_date        ) AND  
                   ( sfcuse.coil_no   is not null        ) AND 
                   ( sfcuse.use_date  *= sfcret.ret_date ) AND 
                   ( sfcuse.coil_no   *= sfcret.wcoil_no ) AND 
                   ( sfcuse.loc_no    *= sfcret.loc_no   ) 
                 )
             AND ( sfcuse.loc_no IN ('WS00000006', 'WW04') )
           GROUP BY substring(groupitem.item_no, 3, 1), sfcuse.item_no, item_name
*/          
          UNION ALL
          
          SELECT sort1     = substring(groupitem.item_no, 3, 1)
               , sort      = dbo.uf_getcoilsort(coilsubuse.item_no) /*당일 사용 2*/
               , item_name = groupitem.item_name
               , drcpt_qty = 0
               , rcpt_qty  = 0
               , dused_qty = isnull(sum(( isnull(coilsubuse.unit_qty, 0) * isnull(coilsubuse.cnt, 0) ) - (  isnull(coilsubuse.rem_qty, 0) )), 0)
               , used_qty  = 0
               , lrcpt_qty = 0
               , lused_qty = 0
               , qoh       = 0
            FROM groupitem  with (nolock)
               , coilsubuse with (nolock)
           WHERE ( coilsubuse.item_no  = groupitem.item_no )  
             and ( coilsubuse.use_date = :ad_date          )
             and ( coilsubuse.loc_no   IN ('WS00000006', 'WW04') )
           GROUP BY substring(groupitem.item_no, 3, 1), coilsubuse.item_no, item_name 
          
          UNION ALL
          
          SELECT sort1     = substring(groupitem.item_no, 3, 1)
               , sort      = dbo.uf_getcoilsort(dodet.item_no) /*당일 사용 3*/
               , item_name = groupitem.item_name
               , drcpt_qty = 0
               , rcpt_qty  = 0
               , dused_qty = isnull(sum( isnull(dodet.ship_qty, 0) ), 0)
               , used_qty  = 0
               , lrcpt_qty = 0
               , lused_qty = 0
               , qoh       = 0
            FROM groupitem  with (nolock)
               , dodet      with (nolock)
               , do         with (nolock)
           WHERE ( dodet.item_no  = groupitem.item_no )   
             and ( dodet.coil_no is not null          )   
             and ( dodet.do_no    = do.do_no          )   
             and ( do.do_date     = :ad_date          )   
             and ( dodet.loc_no   IN ('WS00000006', 'WW04') )
           GROUP BY substring(groupitem.item_no, 3, 1), dodet.item_no, item_name
          
          UNION ALL
          
          SELECT sort1     = substring(groupitem.item_no, 3, 1)
               , sort      = dbo.uf_getcoilsort(sfcuse.item_no) /* 당월사용 누계 1*/
               , item_name = groupitem.item_name
               , drcpt_qty = 0
               , rcpt_qty  = 0
               , dused_qty = 0
               , used_qty  = isnull(sum(( isnull(sfcuse.unit_qty, 0) * isnull(sfcuse.cnt, 0) ) - (  isnull(sfcuse.rem_qty, 0) ) - ( isnull(sfcret.unit_qty, 0) )), 0)
               , lrcpt_qty = 0
               , lused_qty = 0
               , qoh       = 0
		 FROM sfcuse with(nolock) INNER JOIN  groupitem with(nolock) ON sfcuse.item_no = groupitem.item_no
		                                              left outer join sfcret with(nolock) on    sfcuse.use_date = sfcret.ret_date
                                                                                                  				and  sfcuse.coil_no = sfcret.wcoil_no 
                                                                                                  				and sfcuse.loc_no = sfcret.loc_no                
    where ( ( datepart(year,sfcuse.use_date)  = :ai_year ) AND  
                   ( datepart(month,sfcuse.use_date) = :ai_mon  ) AND  
                   ( sfcuse.coil_no  is not null                )      
                 )
             AND ( sfcuse.loc_no IN ('WS00000006', 'WW04') )
           GROUP BY substring(groupitem.item_no, 3, 1), sfcuse.item_no, item_name                                                                                                          
/*               
            FROM groupitem with (nolock)
               , sfcuse    with (nolock)
               , sfcret    with (nolock)
           WHERE ( sfcuse.item_no     = groupitem.item_no       ) 
             AND ( ( datepart(year,sfcuse.use_date)  = :ai_year ) AND  
                   ( datepart(month,sfcuse.use_date) = :ai_mon  ) AND  
                   ( sfcuse.coil_no  is not null                ) AND 
                   ( sfcuse.use_date *= sfcret.ret_date         ) AND 
                   ( sfcuse.coil_no  *= sfcret.wcoil_no         ) AND 
                   (sfcuse.loc_no    *= sfcret.loc_no           ) 
                 )
             AND ( sfcuse.loc_no IN ('WS00000006', 'WW04') )
           GROUP BY substring(groupitem.item_no, 3, 1), sfcuse.item_no, item_name
*/           
          
          UNION ALL
          
          SELECT sort1     = substring(groupitem.item_no, 3, 1)
               , sort      = dbo.uf_getcoilsort(coilsubuse.item_no) /* 당월사용 누계 2*/
               , item_name = groupitem.item_name
               , drcpt_qty = 0
               , rcpt_qty  = 0
               , dused_qty = 0
               , used_qty  = isnull(sum(( isnull(coilsubuse.unit_qty, 0) * isnull(coilsubuse.cnt, 0) ) - (  isnull(coilsubuse.rem_qty, 0) )), 0)
               , lrcpt_qty = 0
               , lused_qty = 0
               , qoh       = 0
            FROM groupitem  with (nolock)
               , coilsubuse with (nolock)
           WHERE ( coilsubuse.item_no = groupitem.item_no         )   
             AND ( datepart(year,coilsubuse.use_date)  = :ai_year )   
             AND ( datepart(month,coilsubuse.use_date) = :ai_mon  ) 
             AND ( coilsubuse.loc_no IN ('WS00000006', 'WW04') )
           GROUP BY substring(groupitem.item_no, 3, 1), coilsubuse.item_no, item_name 
           
          UNION ALL
          
          SELECT sort1     = substring(groupitem.item_no, 3, 1)
               , sort      = dbo.uf_getcoilsort(dodet.item_no) /* 당월사용 누계 3*/
               , item_name = groupitem.item_name
               , drcpt_qty = 0
               , rcpt_qty  = 0
               , dused_qty = 0
               , used_qty  = isnull(sum( isnull(dodet.ship_qty, 0) ), 0)
               , lrcpt_qty = 0
               , lused_qty = 0
               , qoh       = 0
            FROM groupitem with (nolock)
               , dodet     with (nolock)
               , do        with (nolock)
           WHERE ( dodet.item_no  = groupitem.item_no   )   
             AND ( dodet.coil_no is not null            )   
             AND ( dodet.do_no    = do.do_no            )   
             AND ( datepart(year,do.do_date) = :ai_year )   
             AND ( datepart(month,do.do_date) = :ai_mon ) 
             AND ( dodet.loc_no IN ('WS00000006', 'WW04') )
           GROUP BY substring(groupitem.item_no, 3, 1), dodet.item_no, item_name
          
          UNION ALL
          
          SELECT sort1     = substring(groupitem.item_no, 3, 1)
               , sort      = dbo.uf_getcoilsort(inspdet.item_no)  /* 이후 일자 입고 */
               , item_name = groupitem.item_name  
               , drcpt_qty = 0
               , rcpt_qty  = 0
               , dused_qty = 0
               , used_qty  = 0
               , lrcpt_qty = isnull(sum(inspdet.comqty), 0)
               , lused_qty = 0
               , qoh       = 0
            FROM insp      with (nolock)
               , inspdet   with (nolock)
               , groupitem with (nolock)
               , supp      with (nolock)
           WHERE ( insp.insp_no    = inspdet.insp_no   )   
             AND ( inspdet.item_no = groupitem.item_no )   
             AND ( insp.supp_no    = supp.supp_no      )   
             AND ( insp.insp_flag  = 'W'               )   
             AND ( insp.insp_date  > :ad_date          ) 
             AND ( inspdet.loc_no IN ('WS00000006', 'WW04') )
           GROUP BY substring(groupitem.item_no, 3, 1), inspdet.item_no, item_name
          
          UNION ALL
          
          SELECT sort1     = substring(groupitem.item_no, 3, 1)
               , sort      = dbo.uf_getcoilsort(sfcuse.item_no) /*이후 일자 사용 1 */
               , item_name = groupitem.item_name
               , drcpt_qty = 0
               , rcpt_qty  = 0
               , dused_qty = 0
               , used_qty  = 0
               , lrcpt_qty = 0
               , lused_qty = isnull(sum(( isnull(sfcuse.unit_qty, 0) * isnull(sfcuse.cnt, 0) ) - (  isnull(sfcuse.rem_qty, 0) ) - ( isnull(sfcret.unit_qty, 0) )), 0)
               , qoh       = 0
		 FROM sfcuse with(nolock) INNER JOIN  groupitem with(nolock) ON sfcuse.item_no = groupitem.item_no
 		                                               left outer join sfcret with(nolock) on    sfcuse.use_date = sfcret.ret_date
                                                                                                    				and  sfcuse.coil_no = sfcret.wcoil_no 
                                                                                                    				and  sfcuse.loc_no = sfcret.loc_no       
   where ( ( sfcuse.use_date  > :ad_date         ) AND  
                   ( sfcuse.coil_no  is not null         )                    
                 )
             AND ( sfcuse.loc_no IN ('WS00000006', 'WW04') )
          GROUP BY substring(groupitem.item_no, 3, 1), sfcuse.item_no, item_name                                                                                                            
/*               
            FROM groupitem with (nolock)
               , sfcuse    with (nolock)
               , sfcret    with (nolock)
           WHERE ( sfcuse.item_no     = groupitem.item_no)
             AND ( ( sfcuse.use_date  > :ad_date         ) AND  
                   ( sfcuse.coil_no  is not null         ) AND
                   ( sfcuse.use_date *= sfcret.ret_date  ) AND
                   ( sfcuse.coil_no  *= sfcret.wcoil_no  ) AND
                   ( sfcuse.loc_no   *= sfcret.loc_no    ) 
                 )
             AND ( sfcuse.loc_no IN ('WS00000006', 'WW04') )
          GROUP BY substring(groupitem.item_no, 3, 1), sfcuse.item_no, item_name
*/          
          UNION ALL
          
          SELECT sort1     = substring(groupitem.item_no, 3, 1)
               , sort      = dbo.uf_getcoilsort(coilsubuse.item_no) /*이후 일자 사용 2 */
               , item_name = groupitem.item_name
               , drcpt_qty = 0
               , rcpt_qty  = 0
               , dused_qty = 0
               , used_qty  = 0
               , lrcpt_qty = 0
               , lused_qty = isnull(sum(( isnull(coilsubuse.unit_qty, 0) * isnull(coilsubuse.cnt, 0) ) - (  isnull(coilsubuse.rem_qty, 0) )), 0)
               , qoh       = 0
            FROM groupitem  with (nolock)
               , coilsubuse with (nolock)
           WHERE ( coilsubuse.item_no   = groupitem.item_no ) 
             AND ( coilsubuse.use_date  > :ad_date          ) 
             AND ( coilsubuse.loc_no   IN ('WS00000006', 'WW04') )
           GROUP BY substring(groupitem.item_no, 3, 1), coilsubuse.item_no, item_name 
          
          UNION ALL
          
          SELECT sort1     = substring(groupitem.item_no, 3, 1)
               , sort      = dbo.uf_getcoilsort(dodet.item_no) /* 이후 사용 3 */
               , item_name = groupitem.item_name
               , drcpt_qty = 0
               , rcpt_qty  = 0
               , dused_qty = 0
               , used_qty  = 0
               , lrcpt_qty = 0
               , lused_qty = isnull(sum( isnull(dodet.ship_qty, 0) ), 0)
               , qoh       = 0
            FROM groupitem with (nolock)
               , dodet     with (nolock)
               , do        with (nolock)
           WHERE ( dodet.item_no  = groupitem.item_no)   
             and ( dodet.coil_no is not null         )   
             and ( dodet.do_no    = do.do_no         )   
             and ( do.do_date     > :ad_date         ) 
             and ( dodet.loc_no  IN ('WS00000006', 'WW04') )
           GROUP BY substring(groupitem.item_no, 3, 1), dodet.item_no, item_name
          
          UNION ALL
          
          SELECT sort1     = substring(groupitem.item_no, 3, 1)
               , sort      = dbo.uf_getcoilsort(coilmst.item_no) /* 현재고*/
               , item_name = groupitem.item_name
               , drcpt_qty = 0
               , rcpt_qty  = 0
               , dused_qty = 0
               , used_qty  = 0
               , lrcpt_qty = 0
               , lused_qty = 0
               , qoh       = isnull(sum(coilmst.unit_qty * coilmst.qcnt), 0)
            FROM groupitem with (nolock)
               , coilmst   with (nolock)
           WHERE ( coilmst.item_no     = groupitem.item_no       )   
             AND ( substring(coilmst.item_no, 3, 1) IN ('S','A') )   
             AND ( coilmst.open_close <> 'C'                     )   
             AND ( coilmst.loc_no     IN ('WS00000006', 'WW04') ) 
             AND NOT EXISTS ( SELECT * FROM lossitem WHERE loss_item = coilmst.item_no)
           GROUP BY substring(groupitem.item_no, 3, 1),coilmst.item_no, item_name 
       ) A
   GROUP BY sort1, a.sort, replace(A.item_name,'스리팅 ','')
   HAVING isnull(sum(a.qoh), 0) <> 0
" filter=" qoh <> 0"arguments=(("ai_year", number),("ai_mon", number),("ad_date", date))  sort="sort1 D sort A item_name A " )
group(level=1 header.height=0 trailer.height=72 by=("sort1" ) header.color="536870912" trailer.color="15780518" )
group(level=2 header.height=0 trailer.height=72 by=("sort" ) header.color="536870912" trailer.color="12632256" )
text(band=header alignment="2" text="품명" border="6" color="33554432" x="9" y="12" height="60" width="978" html.valueishtml="0"  name=item_name_t visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="67108864" )
