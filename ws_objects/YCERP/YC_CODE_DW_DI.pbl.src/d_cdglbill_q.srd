$PBExportHeader$d_cdglbill_q.srd
$PBExportComments$어음내역조회(1998/3/24,성삼지)
release 8;
datawindow(units=0 timer_interval=0 color=79220952 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=84 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(1) updatewhereclause=yes name=seq dbname="SEQ" )
 column=(type=char(4) updatewhereclause=yes name=glbill_cust_no dbname="CUST_NO" )
 column=(type=char(4) updatewhereclause=yes name=bill_class dbname="BILL_CLASS" values="받을	R/지급	P/교환	C/만기	E/부도	D/" )
 column=(type=char(12) updatewhereclause=yes name=bill_no dbname="BILL_NO" )
 column=(type=char(20) updatewhereclause=yes name=draft dbname="DRAFT" )
 column=(type=char(10) updatewhereclause=yes name=close_date dbname="CLOSE_DATE" )
 column=(type=char(20) updatewhereclause=yes name=bank_name dbname="BANK_NAME" )
 column=(type=char(20) updatewhereclause=yes name=bill_area dbname="BILL_AREA" )
 column=(type=decimal(0) updatewhereclause=yes name=bill_amount dbname="BILL_AMOUNT" )
 column=(type=char(1) updatewhereclause=yes name=set_flag dbname="SET_FLAG" )
 column=(type=char(18) updatewhereclause=yes name=billdet_vcno dbname="BILLDET_VCNO" )
 column=(type=char(40) updatewhereclause=yes name=rem dbname="REM" )
 column=(type=char(8) updatewhereclause=yes name=det_class dbname="DET_CLASS" )
 column=(type=decimal(0) updatewhereclause=yes name=amount dbname="AMOUNT" )
 retrieve="SELECT AA.SEQ
     , AA.CUST_NO
     , AA.BILL_CLASS
     , AA.BILL_NO
     , AA.DRAFT
     , AA.CLOSE_DATE
     , AA.BANK_NAME
     , AA.BILL_AREA
     , AA.BILL_AMOUNT
     , AA.SET_FLAG
     , AA.BILLDET_VCNO
     , AA.REM
     , AA.DET_CLASS
     , AA.AMOUNT    
  FROM (
       SELECT seq = '1'
            , a.cust_no
            , bill_class=(case when a.bill_class = 'R' then '받을'
                               when a.bill_class = 'P' then '지급'
                               when a.bill_class = 'C' then '교환'
                               when a.bill_class = 'E' then '만기'
                               when a.bill_class = 'D' then '부도'
                               else a.bill_class
                          end)
            , a.bill_no
            , a.draft
            , close_date  = convert(char(10),a.close_date,111)
            , c.bank_name
            , a.bill_area
            , a.bill_amount
            , a.set_flag
            , billdet_vcno = ''
            , rem          = ''
            , det_class    = ''
            , amount       = 0
         FROM GLBILL A
              LEFT OUTER JOIN BANK C  ON A.BANK_CODE = C.BANK_CODE
        WHERE A.CUST_NO      = :aa
          AND A.BILL_CLASS  <> 'E'

       UNION 
       SELECT '2'
            , a.cust_no
            , bill_class=(case when a.bill_class = 'A' then '전체'
                               when a.bill_class = 'R' then '받을'
                               when a.bill_class = 'P' then '지급'
                               when a.bill_class = 'C' then '교환'
                               when a.bill_class = 'E' then '만기'
                               when a.bill_class = 'D' then '부도'
                               else a.bill_class
                          end)
            , b.bill_no
            , a.draft
            , ''
            , ''
            , ''
            , 0
            , ''
            , billdet_vcno = substring(b.billdet_vcno,2,4) + '/' + substring(b.billdet_vcno,6,2) + '/' + substring(b.billdet_vcno,8,2)
            , b.rem
            , det_class = (case when b.det_class = 'B' then '어음'
                                when b.det_class = 'C' then '부도대'
                                when b.det_class = 'D' then '교환대'
                                when b.det_class = 'E' then '수입이자'
                                when b.det_class = 'F' then '물품대'
                                when b.det_class = 'G' then '상계'
                                when b.det_class = 'R' then '환불'
                           end)
            , amount = isnull(b.amount,0)
         FROM GLBILL A
              RIGHT OUTER JOIN GLBILLDET B  ON A.VC_NO = B.VC_NO AND A.BILL_NO = B.BILL_NO
        WHERE A.CUST_NO    = :aa
       ) AA
   ORDER BY BILL_CLASS, BILL_NO, SEQ, CLOSE_DATE DESC
" arguments=(("aa", string)) )
