type dw_5 from datawindow within tabpage_1
event editchanged pbm_dwnchanging
event itemchanged pbm_dwnitemchange
integer x = 9
integer y = 8
integer width = 4347
integer height = 2240
integer taborder = 1
string dataobject = "d_cdcustomer_m1"
boolean controlmenu = true
boolean border = false
boolean livescroll = true
end type

event itemchanged;//
this.accepttext()
tab_1.tabpage_2.dw_4.object.custinfo_cust_no[row]   = this.object.cust_no[row]
tab_1.tabpage_2.dw_4.object.customer_cust_name[row] = this.object.cust_name[row]

tab_1.tabpage_3.dw_6.object.cust_no[row]   = this.object.cust_no[row]
tab_1.tabpage_3.dw_6.object.eom_year[row]  = wf_today()
tab_1.tabpage_3.dw_6.object.make_date[row] = wf_today()
tab_1.tabpage_3.dw_6.object.make_user[row] = gs_userid
tab_1.tabpage_4.dw_8.object.cust_no[row]   = this.object.cust_no[row]
//tab_1.tabpage_3.dw_6.object.name[row]    = this.object.cust_name[row]

tab_1.tabpage_4.st_2.text = this.object.cust_no[row]
tab_1.tabpage_4.st_3.text = this.object.cust_name[row]
tab_1.tabpage_3.st_5.text = this.object.cust_no[row]
tab_1.tabpage_3.st_6.text = this.object.cust_name[row]

string  ls_tmp2, ls_tmp3, ls_credit_day, ls_custgroup, ls_custno
string  ls_addrold, ls_bus_addrold, ls_shipto_addrold, ls_colllevel, ls_colllevel_org
decimal ld_rotate

choose case dwo.name
	case 'addr1','addr2','addr3'		// 사업자주소(우편번호, 시도명, 읍면동)
		if isnull(this.object.addr2[row]) or trim(this.object.addr2[row]) = '' then
			ls_tmp2 = '' 
		else
			ls_tmp2 = this.object.addr2[row]
		end if
		if isnull(this.object.addr3[row]) or trim(this.object.addr3[row]) = '' then
			ls_tmp3 = ''
		else 
			ls_tmp3 = this.object.addr3[row]
		end if
		this.object.addr[row] = ls_tmp2 + ' ' + ls_tmp3

	case 'bus_addr1','bus_addr2','bus_addr3'		// 실채무자주소
		if isnull(this.object.bus_addr2[row]) or trim(this.object.bus_addr2[row]) = '' then
			ls_tmp2 = '' 
		else
			ls_tmp2 = this.object.bus_addr2[row]
		end if
		if isnull(this.object.bus_addr3[row]) or trim(this.object.bus_addr3[row]) = '' then
			ls_tmp3 = ''
		else 
			ls_tmp3 = this.object.bus_addr3[row]
		end if
		this.object.bus_addr[row] = ls_tmp2 + ' ' + ls_tmp3							

	case 'shipto_addr1','shipto_addr2','shipto_addr3'		// 운송처주소
		if isnull(this.object.shipto_addr2[row]) or trim(this.object.shipto_addr2[row]) = '' then
			ls_tmp2 = '' 
		else
			ls_tmp2 = this.object.shipto_addr2[row]
		end if
		if isnull(this.object.shipto_addr3[row]) or trim(this.object.shipto_addr3[row]) = '' then
			ls_tmp3 = ''
		else 
			ls_tmp3 = this.object.shipto_addr3[row]
		end if
		this.object.shipto_addr[row] = ls_tmp2 + ' ' + ls_tmp3
		
	case 'sale_control'
		choose case data
			case 'A'
				tab_1.tabpage_1.st_salecontrol.text = '수주,수주확정,출고 통제'
			case 'Y'
				tab_1.tabpage_1.st_salecontrol.text = '수주,출고 통제'
			case 'N'
				tab_1.tabpage_1.st_salecontrol.text = '통제해제'
			case else
				tab_1.tabpage_1.st_salecontrol.text = ''
		end choose
		
	case 'credit_day'
		if Not IsNumber(this.object.credit_day[row]) then
         MessageBox("오류","숫자만 입력하세요")
			return 1	
      end if
		
	case 'cust_group'
		ls_custgroup = data
		if isnull(ls_custgroup) or ls_custgroup = "" then
		else
			SELECT cust_no INTO :ls_custno FROM customer WHERE cust_no = :ls_custgroup AND open_close = 'O';
			if sqlca.sqlcode = 100 or isnull(ls_custno) or ls_custno = "" then
				MessageBox("오류","거래처 그룹코드를 입력하세요")
				return 1	
			end if
		end if
		
	case "rotate"
		ld_rotate = dec(data)
		
		ls_colllevel_org = this.object.colllevel[row]
		
		choose case ld_rotate
			case 0.0 to 3.0
				ls_colllevel = "A"
				
			case 3.1 to 5.0
				ls_colllevel = "B"

			case 5.1 to 8.0
				ls_colllevel = "C"

			case 8.1 to 12
				ls_colllevel = "D"

			case IS > 12
				ls_colllevel = "E"
		end choose
		
		this.object.colllevel[row] = LeftA(ls_colllevel,1) + RightA(ls_colllevel_org,1)
end choose

end event

event buttonclicked;//
if dwo.name = 'b_1' then
	open(w_cdcustlevel_w)
end if
end event

event doubleclicked;//
string ls_custno

if row < 1 then RETURN

ls_custno = this.object.cust_no[1]
if isnull(ls_custno) or ls_custno = "" then RETURN

choose case dwo.name
	case "addr2", "addr3", "c_addr"
		this.object.c_addr.visible = "0"	// false
		this.object.haddr[1] = is_addr2 + " " + is_addr3
		
		gs_zipcodes1 = "w_cdcustomer_m"
		gs_zipcodes2 = "addr1"
		Open (w_cdzipcode_s) 
		if this.object.c_addr.visible = "1"	then	// true then
		else
			this.setcolumn( "addr3" )
			this.setfocus()
		end if
	
	case "bus_addr2", "bus_addr3", "c_bus_addr"
		this.object.c_bus_addr.visible = "0"	// false
		this.object.hbus_addr[1] = is_busaddr2 + " " + is_busaddr3

		gs_zipcodes1 = "w_cdcustomer_m"
		gs_zipcodes2 = "bus_addr1"
		Open (w_cdzipcode_s) 
		if this.object.c_bus_addr.visible = "1"	then	// true then
		else
			this.setcolumn( "bus_addr3" )
			this.setfocus()
		end if
	
	case "shipto_addr2", "shipto_addr3", "c_shipto_addr"
		this.object.c_shipto_addr.visible = "0"	// false
		this.object.hshipto_addr[1] = is_shipaddr2 + " " + is_shipaddr3

		gs_zipcodes1 = "w_cdcustomer_m"
		gs_zipcodes2 = "shipto_addr1"
		Open (w_cdzipcode_s) 
		if this.object.c_shipto_addr.visible = "1"	then	// true then
		else
			this.setcolumn( "shipto_addr3" )
			this.setfocus()
		end if
end choose


end event

event retrieveend;//
string ls_custno, ls_rem

if this.rowcount() < 1 then RETURN

ls_custno = tab_1.tabpage_1.dw_5.object.cust_no[1]
if isnull(ls_custno) or ls_custno = "" then
end if

tab_1.tabpage_1.dw_5.object.c_addr.visible = true
tab_1.tabpage_1.dw_5.object.c_bus_addr.visible = true
tab_1.tabpage_1.dw_5.object.c_shipto_addr.visible = true

// 이전주소 저장
is_addr1     = tab_1.tabpage_1.dw_5.object.addr1[1]
is_addr2     = tab_1.tabpage_1.dw_5.object.addr2[1]
is_addr3     = tab_1.tabpage_1.dw_5.object.addr3[1]
is_busaddr1  = tab_1.tabpage_1.dw_5.object.bus_addr1[1]
is_busaddr2  = tab_1.tabpage_1.dw_5.object.bus_addr2[1]
is_busaddr3  = tab_1.tabpage_1.dw_5.object.bus_addr3[1]
is_shipaddr1 = tab_1.tabpage_1.dw_5.object.shipto_addr1[1]
is_shipaddr2 = tab_1.tabpage_1.dw_5.object.shipto_addr2[1]
is_shipaddr3 = tab_1.tabpage_1.dw_5.object.shipto_addr3[1]

tab_1.tabpage_1.dw_rem_i.insertrow(0)

SELECT top 1 isnull(rem,'') INTO :ls_rem
  FROM customer_det
 WHERE cust_no = :ls_custno
 ORDER BY idate DESC, seq DESC;

is_rem_old = ls_rem
tab_1.tabpage_1.dw_rem_i.object.rem[1] = ls_rem

is_sale_control = tab_1.tabpage_1.dw_5.object.sale_control[1]
if isnull(is_sale_control) then is_sale_control = 'N'

end event

event clicked;//
choose case dwo.name
	case "c_addr"
end choose
end event

event rbuttondown;//
gs_zipcode ls_zipcode
string   ls_roadzip, ls_zips, ls_addr, ls_zip[], ls_address[]

gs_calendar lstr_calendar

if row < 1 then RETURN

SELECT item_cd INTO :ls_roadzip FROM CodeMST WHERE type = '우편번호' AND use_yn = 'Y';
if isnull(ls_roadzip) OR ls_roadzip = "" then ls_roadzip = "ROAD"

choose case dwo.name
	case "addr1"
		OpenWithParm(w_postcode_daum, ls_zipcode)
		ls_zipcode = Message.PowerObjectParm
		if ls_zipcode.chk <> "N" then
			ls_zips  = ls_zipcode.zipcode
			ls_addr  = ls_zipcode.address
			
			GF_Split(ls_zips, "|", ls_zip)
			GF_Split(ls_addr, "|", ls_address)

			if ls_roadzip = "ROAD" then
				this.object.addr1[1]   = ls_zip[1]
				this.object.addr2[1]   = ls_address[1]
				this.object.addr3[1]   = ""
				this.object.c_addr[1]  = ls_address[1]
			else
				this.object.addr1[1]   = ls_zip[2]
				this.object.addr2[1]   = ls_address[2]
				this.object.addr3[1]   = ""
				this.object.c_addr[1]  = ls_address[2]
			end if
		end if		

	case "bus_addr1"
		OpenWithParm(w_postcode_daum, ls_zipcode)
		ls_zipcode = Message.PowerObjectParm
		if ls_zipcode.chk <> "N" then
			ls_zips  = ls_zipcode.zipcode
			ls_addr  = ls_zipcode.address
			
			GF_Split(ls_zips, "|", ls_zip)
			GF_Split(ls_addr, "|", ls_address)

			if ls_roadzip = "ROAD" then
				this.object.bus_addr1[1]   = ls_zip[1]
				this.object.bus_addr2[1]   = ls_address[1]
				this.object.bus_addr3[1]   = ""
				this.object.c_bus_addr[1]  = ls_address[1]
			else
				this.object.bus_addr1[1]   = ls_zip[2]
				this.object.bus_addr2[1]   = ls_address[2]
				this.object.bus_addr3[1]   = ""
				this.object.c_bus_addr[1]  = ls_address[2]
			end if
		end if		

	case "shipto_addr1"
		OpenWithParm(w_postcode_daum, ls_zipcode)
		ls_zipcode = Message.PowerObjectParm
		if ls_zipcode.chk <> "N" then
			ls_zips  = ls_zipcode.zipcode
			ls_addr  = ls_zipcode.address
			
			GF_Split(ls_zips, "|", ls_zip)
			GF_Split(ls_addr, "|", ls_address)

			if ls_roadzip = "ROAD" then
				this.object.shipto_addr1[1]    = ls_zip[1]
				this.object.shipto_addr2[1]    = ls_address[1]
				this.object.shipto_addr3[1]    = ""
				this.object.c_shipto_addr1[1]  = ls_address[1]
			else
				this.object.shipto_addr1[1]    = ls_zip[2]
				this.object.shipto_addr2[1]    = ls_address[2]
				this.object.shipto_addr3[1]    = ""
				this.object.c_shipto_addr1[1]  = ls_address[2]
			end if
		end if		
end choose		

end event

