$PBExportHeader$d_cditemcost_t1.srd
$PBExportComments$거래처별, 현장별 표준단가 관리 조회데이타윈도우(1998/03/16, 정재수)
release 8;
datawindow(units=0 timer_interval=0 color=67108864 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" values="	Y/	N" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="itemcost.item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="groupitem.item_name" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="groupitem.uom" )
 retrieve="  SELECT DISTINCT chk = ~"N~"
       , itemcost.item_no
       , groupitem.item_name
       , groupitem.uom  
    FROM groupitem
       , itemcost  
   WHERE ( groupitem.item_no  = itemcost.item_no ) 
     and ( groupitem.use_flag = ~"Y~" )    
"  sort="item_name A " )
