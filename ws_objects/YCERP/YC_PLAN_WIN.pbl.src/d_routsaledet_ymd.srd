table(column=(type=char(20) updatewhereclause=yes name=거래처 dbname="거래처" )
 column=(type=char(20) updatewhereclause=yes name=현장 dbname="현장" )
 column=(type=char(20) updatewhereclause=yes name=수주번호 dbname="수주번호" )
 column=(type=number updatewhereclause=yes name=순번 dbname="순번" )
 column=(type=char(20) updatewhereclause=yes name=품목 dbname="품목" )
 column=(type=char(20) updatewhereclause=yes name=규격 dbname="규격" )
 column=(type=char(20) updatewhereclause=yes name=작업1 dbname="작업1" )
 column=(type=char(20) updatewhereclause=yes name=상태1 dbname="상태1" )
 column=(type=char(20) updatewhereclause=yes name=작업2 dbname="작업2" )
 column=(type=char(20) updatewhereclause=yes name=상태2 dbname="상태2" )
 column=(type=char(20) updatewhereclause=yes name=작업3 dbname="작업3" )
 column=(type=char(20) updatewhereclause=yes name=상태3 dbname="상태3" )
 column=(type=number updatewhereclause=yes name=납기 dbname="납기" )
 retrieve="  SELECT '거래처'   = a.cust_name
       , '현장'     = a.scene_desc
       , '품목'     = g.item_name
       , '규격'     = a.qa19 
       , '수주번호' = a.order_no
       , '순번'     = a.seq_no
       , '년'       = year(b1.napgi_date)
       , '월'       = month(b1.napgi_date)
       , '십'       = cast(substring(convert(char(10),b1.napgi_date,111),9,1) as int)
       , '일'       = cast(right(convert(char(10),b1.napgi_date,111),1) as int)
       , '납기'     = (case when b1.napgi_date >= b1.work_date  then 1
                            when b1.work_date  >= b2.work_date  then 2
                            when b2.work_date  >= b3.work_date  then 3
                            when b3.work_date  >= b1.napgi_date then 4
                            else 5
                       end)

       , '작업1'    = w1.work_name
       , '상태1'    = b1.process_flag
       , '수량1'    = b1.plan_qty
  
       , '작업2'    = w2.work_name
       , '상태2'    = b2.process_flag
       , '수량2'    = b2.plan_qty
  
       , '작업3'    = w3.work_name
       , '상태3'    = b3.process_flag
       , '수량3'    = b3.plan_qty
    FROM (
          SELECT a.user_name
               , a.cust_name
               , a.scene_desc
               , a.order_no
               , a.seq_no
               , a.item_no
               , a.qa   
               , a.qa19 
               , wc1 = max((case when r.operation = 1 then r.wc_no else null end))
               , wc2 = max((case when r.operation = 2 then r.wc_no else null end))
               , wc3 = max((case when r.operation = 3 then r.wc_no else null end))
            FROM (
                  SELECT l.user_name
                       , c.cust_name
                       , s.scene_desc
                       , a.order_no
                       , a.seq_no
                       , a.item_no
                       , qa   = left(a.qa ,14) + '00000'
                       , qa19 = a.qa
                    FROM saledet A
                         LEFT OUTER JOIN sale       B ON a.order_no   = b.order_no
                         LEFT OUTER JOIN customer   C ON b.cust_no    = c.cust_no
                         LEFT OUTER JOIN scene      S ON b.scene_code = s.scene_code
                         LEFT OUTER JOIN login      L ON c.salesman   = l.user_id
                   WHERE b.order_date  BETWEEN '2014/12/01' AND '2014/12/19'
/*                     AND b.open_close       <> 'C'	한도초과 */
                       AND b.open_close       = 'O'
                   /*AND b.tracking          = 'Y'*/
                 ) A
                 LEFT OUTER JOIN rout R ON a.item_no = r.item_no AND a.qa = r.qa
           GROUP BY a.user_name, a.cust_name, a.scene_desc, a.order_no, a.seq_no, a.item_no, a.qa, a.qa19
         ) A
         LEFT OUTER JOIN groupitem  G ON a.item_no = g.item_no
         LEFT OUTER JOIN wc        W1 ON a.wc1     = w1.work_no
         LEFT OUTER JOIN wc        W2 ON a.wc2     = w2.work_no
         LEFT OUTER JOIN wc        W3 ON a.wc3     = w3.work_no
         LEFT OUTER JOIN (
              SELECT area_no, work_date, sale_no, seq_no, napgi_date, rem, wc_no, operation, order_qty, plan_qty
                   , process_flag = (case r.process_flag when 'N' then '불가' when 'Y' then '가능' 
                                                         when 'P' then '진행' when 'E' then '완료' else '마감' 
                                     end)
                FROM routtempnew R
               WHERE r.work_date >= '2014/12/01' AND operation = 1
         ) B1 ON a.order_no = b1.sale_no AND a.seq_no = b1.seq_no AND a.wc1 = b1.wc_no
         LEFT OUTER JOIN (
              SELECT area_no, work_date, sale_no, seq_no, napgi_date, rem, wc_no, operation, plan_qty
                   , process_flag = (case r.process_flag when 'N' then '불가' when 'Y' then '가능' 
                                                         when 'P' then '진행' when 'E' then '완료' else '마감' 
                                     end)
                FROM routtempnew R
               WHERE r.work_date >= '2014/12/01' AND operation = 2
         ) B2 ON a.order_no = b2.sale_no AND a.seq_no = b2.seq_no AND a.wc2 = b2.wc_no
         LEFT OUTER JOIN (
              SELECT area_no, work_date, sale_no, seq_no, napgi_date, rem, wc_no, operation, plan_qty
                   , process_flag = (case r.process_flag when 'N' then '불가' when 'Y' then '가능' 
                                                         when 'P' then '진행' when 'E' then '완료' else '마감' 
                                     end)
                FROM routtempnew R
               WHERE r.work_date >= '2014/12/01' AND operation = 3
         ) B3 ON a.order_no = b3.sale_no AND a.seq_no = b3.seq_no AND a.wc3 = b3.wc_no
   WHERE b1.napgi_date is not null
"  sort="거래처 A 현장 A 수주번호 A 순번 A 품목 A 규격 A 작업1 A 상태1 A 작업2 A 상태2 A 작업3 A 상태3 A " )
