text(band=header alignment="2" text="당월입고누계" border="6" color="0" x="1833" y="12" height="60" width="402" html.valueishtml="0"  name=rcpt_qty_t visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="67108864" )
