table(column=(type=char(10) updatewhereclause=yes name=itemloc_loc_no dbname="itemloc_loc_no" )
 column=(type=char(30) updatewhereclause=yes name=loc_name dbname="loc_name" )
 column=(type=char(10) updatewhereclause=yes name=itemloc_item_no dbname="itemloc_item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=itemloc_qa dbname="itemloc_qa" )
 column=(type=decimal(4) updatewhereclause=yes name=itemloc_balbf dbname="itemloc_balbf" )
 column=(type=decimal(4) updatewhereclause=yes name=itemloc_receipt_qty dbname="itemloc_receipt_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=itemloc_issue_qty dbname="itemloc_issue_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=itemloc_qoh dbname="itemloc_qoh" )
 column=(type=decimal(4) updatewhereclause=yes name=ineoym_rcptqty dbname="ineoym_rcptqty" )
 column=(type=decimal(4) updatewhereclause=yes name=ineoym_issueqty dbname="ineoym_issueqty" )
 column=(type=decimal(4) updatewhereclause=yes name=ineoym_qoh dbname="ineoym_qoh" )
 column=(type=decimal(4) updatewhereclause=yes name=ineoday_rcptqty dbname="ineoday_rcptqty" )
 column=(type=decimal(4) updatewhereclause=yes name=ineoday_issueqty dbname="ineoday_issueqty" )
 retrieve="SELECT itemloc_loc_no      = a.loc_no
     , loc_name            = l.loc_name
     , itemloc_item_no     = a.item_no
     , item_name           = g.item_name
     , itemloc_qa          = a.qa
     , itemloc_balbf       = a.balbf
     , itemloc_receipt_qty = a.receipt_qty
     , itemloc_issue_qty   = a.issue_qty
     , itemloc_qoh         = a.qoh
     , ineoym_rcptqty      = b.ineoym_rcptqty
     , ineoym_issueqty     = b.ineoym_issueqty
     , ineoym_qoh          = b.ineoym_qoh
     , ineoday_rcptqty     = b.ineoday_rcptqty
     , ineoday_issueqty    = b.ineoday_issueqty
  FROM itemloc A /* 저장소 재고 */
       LEFT OUTER JOIN (
            SELECT cyear
                 , cmon
                 , ineoym.loc_no
                 , ineoym.item_no
                 , ineoym.qa
                 , ineoym_rcptqty   = ineoym.rcpt_qty
                 , ineoym_issueqty  = ineoym.issue_qty
                 , ineoym_qoh       = ineoym.qoh
                 , ineoday_rcptqty  = a.rcpt_qty
                 , ineoday_issueqty = a.issue_qty
              FROM ineoym (nolock) /* 월별재고 */
                   LEFT OUTER JOIN (
											SELECT loc_no, cdate = substring(cdate,1,6), item_no, qa, rcpt_qty = sum(rcpt_qty), issue_qty = sum(issue_qty)
											  FROM ineoday (nolock) /* 일별재고 */
											 WHERE cdate between :as_sdate and :as_edate
												AND ( loc_no   = :as_locno  )
											 GROUP BY loc_no, substring(cdate,1,6), item_no, qa
                  							 ) a  ON ineoym.loc_no = a.loc_no AND ineoym.item_no = a.item_no AND ineoym.qa = a.qa
             WHERE ineoym.cyear = :as_year and ineoym.cmon = :as_month
               AND ( ineoym.loc_no   = :as_locno )
       ) B ON a.loc_no = b.loc_no AND a.item_no = b.item_no AND a.qa = b.qa
       LEFT OUTER JOIN groupitem G  ON a.item_no = g.item_no
       LEFT OUTER JOIN location  L  ON a.loc_no  = l.loc_no
 WHERE a.loc_no = :as_locno
" arguments=(("as_locno", string),("as_year", string),("as_month", string),("as_sdate", string),("as_edate", string)) )
