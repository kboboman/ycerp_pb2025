type cb_6 from commandbutton within w_whitemlocqohmulti_w2_20220504
integer x = 2569
integer y = 1408
integer width = 379
integer height = 80
integer taborder = 150
integer textsize = -10
integer weight = 400
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "▼ 추가"
end type

event clicked;//
long    ll_row, ll_cnt, ll_dw1row, ll_dw1rowcount, ll_dw2row
long    ll_lenth, ll_x, ll_y, ll_ysp_val
string  ls_exist, ls_use, ls_item, ls_qa, ls_ysp_calctype, ls_orderdate, ls_yspstart
boolean lb_yspcheck, lb_yspstart = false
decimal lr_order_qty

dw_1.setredraw( false )
dw_1.accepttext()
dw3.accepttext()

if istr_where.chk = 'M' then
else
	dw_1.reset()
end if

//////////////////////////////
// YSP수주자동계산 적용일자 //
//////////////////////////////
SELECT item_cd INTO :ls_yspstart FROM codemst WHERE type = 'YSP수주자동계산' AND use_yn = 'Y';
//ls_orderdate = string(dw_2.object.order_date[1],"yyyy/mm/dd")
ls_orderdate = istr_where.str8[1]
if ls_orderdate >= ls_yspstart then
	lb_yspstart = true
else
	lb_yspstart = false
end if
//////////////////////////////

ll_dw1rowcount = dw_1.rowcount()
// TAB_1 선택품목 가져오기
choose case tab_1.SelectedTab
	case 1 		// 품목검색
		ll_dw2row = dw2.getrow()
		for ll_row = dw3.GetSelectedRow(0) to dw3.rowcount()
			if dw3.IsSelected(ll_row) = true then
				//////////////////////////////////////////////////
				// 수주입력상 중복검사 불필요(2012/02/21)
				// 출고 송장발행시 오류발생 확인필요
				//////////////////////////////////////////////////
				// ls_exist = 'N'
				// for ll_dw1row = 1 to ll_dw1rowcount
				// 	if dw2.object.item_no[ll_dw2row] = dw_1.object.item_no[ll_dw1row] and &
				// 		dw3.object.qa[ll_row] = dw_1.object.qa[ll_dw1row] then
				// 		ls_exist = 'Y'
				// 		exit
				// 	end if
				// next
				// if ls_exist = 'Y' then continue
	
				ls_item = dw2.object.item_no[ll_dw2row]
				ls_qa   = dw3.object.qa[ll_row]
				
				ll_cnt  = dw_1.insertrow(0)
				dw_1.object.item_no[ll_cnt]   = ls_item
				dw_1.object.qa[ll_cnt]        = ls_qa
				dw_1.object.uom[ll_cnt]       = dw2.object.uom[ll_dw2row]
				dw_1.object.source[ll_cnt]    = dw2.object.source[ll_dw2row]
				dw_1.object.loc_no[ll_cnt]    = is_loc
				dw_1.object.item_name[ll_cnt] = dw2.object.item_name[ll_dw2row]
				dw_1.object.qoh[ll_cnt]       = dw3.object.qoh[ll_row]
				

				SELECT ysp_calctype INTO :ls_ysp_calctype FROM groupitem WHERE item_no = :ls_item ;
				
				/////////////////////////////////////////////////////////////////
				// YSP수주자동계산(주문수량)
				/////////////////////////////////////////////////////////////////
				if lb_yspstart = true then
					if UPPER(LeftA(ls_item,4)) = 'PCYS' then
						// lb_check = wf_item_no_check(ls_item)
						SELECT ysp_calctype INTO :ls_ysp_calctype FROM groupitem WHERE item_no = :ls_item ;
						if isnull(ls_ysp_calctype) or ls_ysp_calctype = "" then
						else
							if RightA(ls_qa,5) = "00000" then
								MessageBox("확인","YSP수주자동계산 품목의 규격4 오류 입니다.[" + ls_qa + "]",Exclamation!)
								return
							else
								ll_x     = long(MidA(ls_qa,  5, 4))
								ll_y     = long(MidA(ls_qa, 10, 4))
								ll_lenth = long(MidA(ls_qa, 15, 5))						
								choose case ls_ysp_calctype
									case "1"
										ll_ysp_val = 12
									case "2", "3"
										ll_ysp_val = 10
									case "4"
										ll_ysp_val = 8
								end choose
								
								/////////////////////////////////////////////////////////////////
								// 소숫점 세자리 반올림((규격2 + :ll_ysp_val + 규격3) X 규격4) //
								/////////////////////////////////////////////////////////////////
								//lr_order_qty = ceiling(truncate((ll_x + ll_ysp_val + ll_y) * ll_lenth / 1000000, 3) * 100 ) / 100
								lr_order_qty = Round((ll_x + ll_ysp_val + ll_y) * ll_lenth / 1000000, 2)
							end if
						end if
					end if
				end if
					
				if lb_yspstart = true then
					if (isnull(ls_ysp_calctype) or ls_ysp_calctype = "") then
					else
						dw_1.object.order_qty[ll_cnt] = lr_order_qty		// YSP수주자동계산 값			
					end if			
				end if
				/////////////////////////////////////////////////////////////////
			end if
		next
		dw3.SelectRow(0, false)

		
	case 2		// 수주품목으로 검색
		for ll_row = 1 to dw5.rowcount()
			if dw5.IsSelected(ll_row) = true then
				//////////////////////////////////////////////////
				// 수주입력상 중복검사 불필요(2012/02/21)
				// 출고 송장발행시 오류발생 확인필요
				//////////////////////////////////////////////////
				// ls_exist = 'N'
				// for ll_dw1row = 1 to ll_dw1rowcount
				// 	if dw5.object.item_no[ll_row] = dw_1.object.item_no[ll_dw1row] and &
				// 		dw5.object.qa[ll_row] = dw_1.object.qa[ll_dw1row] then
				// 		ls_exist = 'Y'
				// 		exit
				// 	end if
				// next
				// if ls_exist = 'Y' then continue
				//////////////////////////////////////////////////
				
				ls_item = dw5.object.item_no[ll_row]
				ls_qa   = dw5.object.qa[ll_row]
		
				ll_cnt  = dw_1.insertrow(0)
				dw_1.object.item_no[ll_cnt]   = ls_item
				dw_1.object.qa[ll_cnt]        = ls_qa
				dw_1.object.uom[ll_cnt]       = dw5.object.uom[ll_row]
				dw_1.object.loc_no[ll_cnt]    = is_loc
				dw_1.object.item_name[ll_cnt] = dw5.object.item_name[ll_row]
				dw_1.object.qoh[ll_cnt]       = dw5.object.qoh[ll_row]
	
				if tab_1.tabpage_2.rb_sale.checked = true then
					dw_1.object.sale_no[ll_cnt]   = dw5.object.order_no[ll_row]
					dw_1.object.cust_name[ll_cnt] = dw5.object.cust_name[ll_row]
					dw_1.object.order_qty[ll_cnt] = dw5.object.order_qty[ll_row]
					dw_1.object.price[ll_cnt]     = dw5.object.price[ll_row]
				end if
			end if
		next
		dw5.SelectRow(0, false)

		
	case 3		// 출고품목으로 검색
		for ll_row = 1 to dw8.rowcount()
			if dw8.IsSelected(ll_row) = true then
				//////////////////////////////////////////////////
				// 수주입력상 중복검사 불필요(2012/02/21)
				// 출고 송장발행시 오류발생 확인필요
				//////////////////////////////////////////////////
				// ls_exist = 'N'
				// for ll_dw1row = 1 to ll_dw1rowcount
				// 	if dw5.object.item_no[ll_row] = dw_1.object.item_no[ll_dw1row] and &
				// 		dw5.object.qa[ll_row] = dw_1.object.qa[ll_dw1row] then
				// 		ls_exist = 'Y'
				// 		exit
				// 	end if
				// next
				// if ls_exist = 'Y' then continue
				//////////////////////////////////////////////////
				
				ls_item = dw8.object.item_no[ll_row]
				ls_qa   = dw8.object.qa[ll_row]

				ll_cnt  = dw_1.insertrow(0)
				dw_1.object.item_no[ll_cnt]   = ls_item
				dw_1.object.qa[ll_cnt]        = ls_qa
				dw_1.object.uom[ll_cnt]       = dw8.object.uom[ll_row]
				dw_1.object.loc_no[ll_cnt]    = is_loc
				dw_1.object.item_name[ll_cnt] = dw8.object.item_name[ll_row]
				dw_1.object.qoh[ll_cnt]       = dw8.object.qoh[ll_row]
	
				//if tab_1.tabpage_2.rb_sale.checked = true then		// 출고검색
					//dw_1.object.sale_no[ll_cnt]   = dw8.object.order_no[ll_row]
					dw_1.object.cust_name[ll_cnt] = dw8.object.cust_name[ll_row]
					dw_1.object.order_qty[ll_cnt] = dw8.object.order_qty[ll_row]
					dw_1.object.price[ll_cnt]     = dw8.object.price[ll_row]
				//end if
			end if
		next
		dw8.SelectRow(0, false)		
end choose

cbx_2.checked = false
dw_1.scrolltorow(ll_cnt)
dw_1.setredraw( true )


end event

