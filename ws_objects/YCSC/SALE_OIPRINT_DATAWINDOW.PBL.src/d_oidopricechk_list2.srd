table(column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(11) updatewhereclause=yes name=do_spot_code dbname="do.spot_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene.scene_desc" )
 column=(type=char(10) updatewhereclause=yes name=dodet_item_no dbname="dodet.item_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(14) updatewhereclause=yes name=do_do_no dbname="do.do_no" )
 column=(type=long updatewhereclause=yes name=dodet_oi_no dbname="dodet.oi_no" )
 column=(type=datetime updatewhereclause=yes name=do_do_date dbname="do.do_date" )
 column=(type=datetime updatewhereclause=yes name=do_issue_date dbname="do.issue_date" )
 column=(type=datetime updatewhereclause=yes name=do_ship_date dbname="do.ship_date" )
 column=(type=long updatewhereclause=yes name=datecalc dbname="datecalc" )
 column=(type=char(20) updatewhereclause=yes name=dodet_qa dbname="dodet.qa" )
 column=(type=char(2) updatewhereclause=yes name=dodet_uom dbname="dodet.uom" )
 column=(type=decimal(2) updatewhereclause=yes name=dodet_ship_qty dbname="dodet.ship_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=com_qty dbname="com_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=price dbname="price" )
 column=(type=char(30) updatewhereclause=yes name=loc_name dbname="loc_name" )
 retrieve="  SELECT customer.cust_name       
       , do.spot_code     
       , scene.scene_desc  
       , dodet.item_no    
       , g.item_name      
       , do.do_no         
       , dodet.oi_no      
       , do.do_date       
       , do.issue_date
       , do.ship_date
       , datecalc    = DATEDIFF(month, do.issue_date, do.do_date) 
       , dodet.qa         
       , dodet.uom        
       , dodet.ship_qty
       , com_qty = dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty)
       , price   = dodet.price
       , loc_name= location.loc_name
    FROM dodet          
         LEFT OUTER JOIN do          ON dodet.do_no   = do.do_no 
         LEFT OUTER JOIN customer    ON do.cust_no    = customer.cust_no
         LEFT OUTER JOIN groupitem G ON dodet.item_no = g.item_no
         LEFT OUTER JOIN scene       ON do.spot_code  = scene.scene_code
         LEFT OUTER JOIN location    ON dodet.loc_no  = location.loc_no
   WHERE (do.do_date BETWEEN :ad_sdate + ' 00:00:00' AND :ad_edate + ' 23:59:59')
     AND ((:as_salesman   = '%' AND customer.salesman LIKE :as_salesman) OR
          (:as_salesman  <> '%' AND customer.salesman    = :as_salesman)
         )
     AND ((:as_itemname   = '%' AND g.item_name       LIKE :as_itemname) OR
          (:as_itemname  <> '%' AND g.item_name          = :as_itemname)
         )
     AND (dodet.price     = :al_price)
     AND ((:as_inside     = '%' ) OR
          (:as_inside    <> '%' AND customer.cust_no NOT IN (SELECT item_cd FROM codemst WHERE type = '내부업체' AND use_yn = 'Y') )
         )

" arguments=(("as_salesman", string),("as_itemname", string),("al_price", number),("ad_sdate", date),("ad_edate", date),("as_inside", string))  sort="customer_cust_name A scene_scene_desc A do_do_no A dodet_oi_no A " )
