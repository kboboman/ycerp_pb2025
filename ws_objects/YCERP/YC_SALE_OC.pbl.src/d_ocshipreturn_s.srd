$PBExportComments$인수증관리
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="10789024" )
detail(height=80 color="536870912" )
table(column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" values="	Y/	N" )
 column=(type=char(14) updatewhereclause=yes name=do_no dbname="do_no" )
 column=(type=char(1) updatewhereclause=yes name=ship_flag dbname="ship_flag" values="착불	C/부담	B/대여	D/시화방문	M/화곡방문	H/반월방문	Y/공사원가	A/재료원가	R/" )
 column=(type=decimal(0) updatewhereclause=yes name=ship_amount dbname="ship_amount" )
 column=(type=char(60) updatewhereclause=yes name=driver dbname="driver" )
 column=(type=char(1) updatewhereclause=yes name=shipamt_case dbname="shipamt_case" values="현금	C/외상	R/" )
 column=(type=char(10) updatewhereclause=yes name=car_name dbname="car_name" )
 column=(type=char(40) updatewhereclause=yes name=cargo_name dbname="cargo_name" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=char(1) updatewhereclause=yes name=ship_close dbname="ship_close" values="	C/	O" )
 column=(type=decimal(4) updatewhereclause=yes name=do_cash dbname="do_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=do_rate dbname="do_rate" )
 column=(type=decimal(4) updatewhereclause=yes name=do_total dbname="do_total" )
 column=(type=datetime updatewhereclause=yes name=ship_date dbname="ship_date" )
 column=(type=datetime updatewhereclause=yes name=log_date dbname="log_date" )
 column=(type=char(10) updatewhereclause=yes name=close_user dbname="close_user" )
 column=(type=char(180) updatewhereclause=yes name=sale_no dbname="sale_no" )
 column=(type=char(5) updatewhereclause=yes name=budam_desc dbname="budam_desc" )
 column=(type=char(50) updatewhereclause=yes name=car_gbn dbname="car_gbn" )
 column=(type=char(10) updatewhereclause=yes name=salesman dbname="salesman" )
 column=(type=char(10) updatewhereclause=yes name=area dbname="area" )
 column=(type=char(10) updatewhereclause=yes name=loc_no dbname="loc_no" )
 column=(type=char(1) updatewhereclause=yes name=sortkey dbname="sortkey" )
 retrieve="  SELECT DISTINCT
         chk         = isnull(do_scan.scan_yn,'N')
       , do_no       = do.do_no                                         
       , ship_flag   = do.ship_flag                                     
       , ship_amount = do.ship_amount                                   
       , driver      = isnull(do.driver,'')
       , shipamt_case= do.shipamt_case                                  
       , car_name    = docar.name                                       
       , cargo_name  = docar.cargo_name                                 
       , cust_name   = customer.cust_name                               
       , scene_desc  = scene.scene_desc                                 
       , ship_close  = do.ship_close                                    
       , do_cash     = do.do_cash                                       
       , do_rate     = do.do_rate                                       
       , do_total    = do.do_total                                      
       , ship_date   = do.ship_date                                     
       , log_date    = do.log_date                        
       , close_user  = do.close_user                                 
       , sale_no     = dbo.uf_getdosaleno(do.do_no)        
       , budam_desc  = do.budam_desc                    
       , car_gbn     = (SELECT item_nm FROM codemst WHERE type = 'car_gbn' AND item_cd = do.car_gbn)
       , salesman    = login.user_name
       , area        = do.area_no
       , loc_no      = dodet.loc_no
       , sortkey     = 'A'
    FROM do         
         LEFT OUTER JOIN dodet    ON do.do_no          = dodet.do_no 
         LEFT OUTER JOIN customer ON do.cust_no        = customer.cust_no 
         LEFT OUTER JOIN scene    ON do.spot_code      = scene.scene_code 
         LEFT OUTER JOIN docar    ON do.driver         = docar.driver     
         LEFT OUTER JOIN login    ON customer.salesman = login.user_id    
         LEFT OUTER JOIN do_scan  ON do.do_no          = do_scan.do_no   
   WHERE ( do.do_no      LIKE :as_area  + '%' )
     AND ( dodet.loc_no  LIKE :as_locno + '%' )
     AND ((:as_driver  = '%' AND do.driver  LIKE :as_driver) OR
          (:as_driver <> '%' AND do.driver     = :as_driver)
         )
     AND ( convert(char(10),do.ship_date,111)    BETWEEN :as_sdate AND :as_edate ) 
     AND ( do.ship_flag    IN ('D' , 'B', 'A', 'R') )

  UNION ALL

  SELECT DISTINCT
         chk         = isnull(do_scan.scan_yn,'N')
       , ask_no      = ask_head.ask_no                                  
       , ship_flag   = 'B'                               
       , ship_amount = ask_head.ship_amount                             
       , driver      = isnull(ask_head.driver,'')
       , shipamt_case= ''                             
       , car_name    = docar.name                                       
       , cargo_name  = docar.cargo_name                                 
       , cust_name   = '(주)유창'                        
       , scene_desc  = '시화사업장'                     
       , ship_close  = ask_head.ship_close                           
       , do_cash     = 0
       , do_rate     = 0
       , do_total    = 0
       , ship_date   = ask_head.ship_date                               
       , log_date    = ask_head.ship_date               
       , close_user  = ask_head.close_user                           
       , sale_no     = ''                                            
       , budam_desc  = ''                               
       , car_gbn     = ''  
       , salesman    = ''
       , area        = ''
       , loc_no      = ask_det.loc_no
       , sortkey     = 'B'
    FROM ask_head
         LEFT OUTER JOIN ask_det  ON ask_head.ask_no = ask_det.ask_no
         LEFT OUTER JOIN docar    ON ask_head.driver = docar.driver
         LEFT OUTER JOIN do_scan  ON ask_head.ask_no = do_scan.do_no   
   WHERE ( :as_area  = 'S' ) 
     AND ( convert(char(10),ask_head.ship_date,111)  BETWEEN :as_sdate AND :as_edate ) 
     AND ((:as_driver  = '%' AND ask_head.driver  LIKE :as_driver) OR
          (:as_driver <> '%' AND ask_head.driver     = :as_driver)
         )
" arguments=(("as_area", string),("as_locno", string),("as_sdate", string),("as_edate", string),("as_driver", string))  sort="sortkey A do_no A " )
