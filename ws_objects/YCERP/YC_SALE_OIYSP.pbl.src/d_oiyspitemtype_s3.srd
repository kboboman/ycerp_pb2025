$PBExportComments$YSP TYPE별 실적현황(판매단가)(2000/03/06,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no  crosstab.dynamic = yes grid.lines=0 grid.columnmove=no selected.mouse=no )
header[1](height=72 color="536870912" )
header[2](height=72 color="536870912" )
header[3](height=76 color="536870912" )
summary(height=84 color="536870912" )
footer(height=0 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa1 dbname="qa1" )
 column=(type=number updatewhereclause=yes name=qty dbname="qty" )
 column=(type=number updatewhereclause=yes name=amt dbname="amt" )
 retrieve="  SELECT groupitem.item_name,
			qa1 = substring(dodet.qa, 1,3),
			mon = right('00' + convert(char(2), datepart(month, do.do_date)) ,2),
         qty = sum(dodet.ship_qty),
         amt = sum( dodet.ship_qty  *  dodet.price )
    FROM do,   
         dodet,
			groupitem	
   WHERE ( do.do_no = dodet.do_no) and  
			( do.do_no like ~"B%~" ) AND 
         ( do.do_date between :ad_start and :ad_end ) and
         ( dodet.item_no = groupitem.item_no ) and  
         ( not(( dodet.item_no like 'PCYSYS%' ) or ( dodet.item_no like 'GCYSYS%' ) or ( dodet.item_no like 'PCYSZ%' )) )
group by do.do_date, groupitem.item_name,dodet.qa
order by do.do_date, groupitem.item_name,dodet.qa

" arguments=(("ad_start", date),("ad_end", date))  sort="item_name A qa1 A " )
group(level=1 header.height=0 trailer.height=84 by=("item_name" ) header.color="536870912" trailer.color="536870912" )
