event resize;call super::resize;//
gb_2.width  = newwidth  - (gb_2.x * 2)
gb_5.width  = newwidth  - (gb_5.x * 2)

dw_1.width  = newwidth  - (gb_2.x * 2)
dw_1.height = newheight - dw_1.y - gb_2.x

tab_1.width  = dw_1.width  * 0.7
tab_1.height = dw_1.height * 0.7
tab_1.x      = ( dw_1.width  - tab_1.width  ) / 2
tab_1.y      = ( dw_1.height - tab_1.height ) / 2 + dw_1.y

tab_1.tabpage_1.dw_4.width  = tab_1.width  - 73
tab_1.tabpage_1.dw_4.height = tab_1.height - 236

tab_1.tabpage_2.dw_5.width  = tab_1.tabpage_1.dw_4.width
tab_1.tabpage_2.dw_5.height = tab_1.tabpage_1.dw_4.height

tab_1.tabpage_3.dw_6.width  = tab_1.tabpage_1.dw_4.width
tab_1.tabpage_3.dw_6.height = tab_1.tabpage_1.dw_4.height

tab_1.tabpage_4.dw_7.width  = tab_1.tabpage_1.dw_4.width
tab_1.tabpage_4.dw_7.height = tab_1.tabpage_1.dw_4.height

tab_1.tabpage_5.dw_8.width  = tab_1.tabpage_1.dw_4.width
tab_1.tabpage_5.dw_8.height = tab_1.tabpage_1.dw_4.height

tab_1.tabpage_6.dw_9.width  = tab_1.tabpage_1.dw_4.width
tab_1.tabpage_6.dw_9.height = tab_1.tabpage_1.dw_4.height

tab_1.tabpage_7.dw_10.width  = tab_1.tabpage_1.dw_4.width
tab_1.tabpage_7.dw_10.height = tab_1.tabpage_1.dw_4.height

