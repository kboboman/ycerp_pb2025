 retrieve="  SELECT opeom.cust_no   
       , opeom.eom_year   
       , opeom.balbf_amount
       , opeom.inv_01   
       , opeom.inv_02   
       , opeom.inv_03   
       , opeom.inv_04   
       , opeom.inv_05   
       , opeom.inv_06   
       , opeom.inv_07   
       , opeom.inv_08   
       , opeom.inv_09   
       , opeom.inv_10   
       , opeom.inv_11   
       , opeom.inv_12   
       , opeom.coll_01   
       , opeom.coll_02   
       , opeom.coll_03   
       , opeom.coll_04   
       , opeom.coll_05   
       , opeom.coll_06   
       , opeom.coll_07   
       , opeom.coll_08   
       , opeom.coll_09   
       , opeom.coll_10   
       , opeom.coll_11   
       , opeom.coll_12   
       , opeom.make_date 
       , opeom.make_user 
       , pavg   = dbo.UF_GetPreviousAVG( :aa, :bb )
    FROM opeom  
   WHERE ( opeom.cust_no = :aa ) 
     AND ( datepart(year,opeom.eom_year) = :bb )    
" update="opeom" updatewhere=1 updatekeyinplace=no arguments=(("aa", string),("bb", number)) )
