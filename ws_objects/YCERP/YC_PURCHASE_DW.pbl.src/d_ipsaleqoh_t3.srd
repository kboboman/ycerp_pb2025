table(column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=char(10) updatewhereclause=yes name=assembly dbname="assembly" )
 column=(type=char(60) updatewhereclause=yes name=assembly_name dbname="assembly_name" )
 column=(type=char(2) updatewhereclause=yes name=assembly_uom dbname="assembly_uom" )
 column=(type=char(20) updatewhereclause=yes name=assy_qa dbname="assy_qa" )
 column=(type=char(10) updatewhereclause=yes name=wc_no dbname="wc_no" )
 column=(type=char(10) updatewhereclause=yes name=work_name dbname="work_name" )
 column=(type=long updatewhereclause=yes name=operation dbname="operation" )
 column=(type=decimal(4) updatewhereclause=yes name=qoh dbname="qoh" )
 column=(type=char(14) updatewhereclause=yes name=order_no dbname="order_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="seq_no" )
 column=(type=char(50) updatewhereclause=yes name=saledet_rem dbname="rem" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=decimal(2) updatewhereclause=yes name=saledetqty dbname="saledetqty" )
 column=(type=decimal(4) updatewhereclause=yes name=pur_qty dbname="pur_qty" )
 column=(type=char(4) updatewhereclause=yes name=color dbname="color" )
 column=(type=char(1) updatewhereclause=yes name=rout_count dbname="rout_count" values="유	Y/무	N/" )
 retrieve="  SELECT saledet.item_no                  
       , saledet.qa                       
       , groupitem.item_name              
       , groupitem.uom        
       
       , rout.assembly
       , a.item_name assembly_name
	  , a.uom assembly_uom
/*       , rout.assy_qa  2019-12-27 jowonsuk 수정 */
       , (case when rout.represent = 'Y' then saledet.qa else rout.assy_qa end ) assy_qa
       , rout.wc_no
       , wc.work_name
       , rout.operation       
       , qoh        = isnull(item.qoh, 0)  
       , saledet.order_no                 
       , saledet.seq_no                
       , saledet.rem                   
       , customer.cust_name               
       , saledetqty = saledet.order_qty
       , pur_qty    = isnull(sum(purdet.order_qty), 0 )
       , color      = saledet.color
	  , isnull(( select ( case when item_no is  null then 'N' else 'Y' end ) from item with(nolock) WHERE  item.item_no = rout.assembly and item.qa =  saledet.qa ), 'N' ) rout_count
    FROM saledet WITH(NOLOCK) inner join  sale WITH(NOLOCK) on saledet.order_no  = sale.order_no
                                                                                                   AND  sale.open_close        = 'O'  
                                                                                                   AND sale.confirm_flag     IN ('T', 'Y')
                                                                                                   AND ( sale.order_no    LIKE :as_order   )  
                                     inner join customer WITH(NOLOCK) on sale.cust_no           = customer.cust_no      
                                     inner join  groupitem WITH(NOLOCK)  on saledet.item_no = groupitem.item_no                                     
                                     left outer join purdet WITH(NOLOCK) on saledet.order_no  = purdet.sale_no    AND  saledet.seq_no  = purdet.sale_seq  
							left outer join  item  WITH(NOLOCK)   on saledet.item_no  = item.item_no and saledet.qa   = item.qa
/*                                     left outer join rout with(nolock) on item .item_no = rout.item_no and item.qa1 = rout.qa 2019-12-27 jowonsuk 수정 */
							left outer join v_rout_represent rout on item .item_no = rout.item_no and item.qa1 = (case when rout.represent = 'Y' then item.qa1 else rout.qa end ) 
                                     left outer join groupitem a with(NOLOCK) on  rout.assembly = a.item_no 
                                     left outer join wc with(nolock) on rout.wc_no = wc.work_no              
   GROUP BY saledet.item_no    
                   , saledet.qa            
                   , groupitem.item_name   
                   , groupitem.uom         
                   , qoh                
                   , saledet.order_no      
                   , saledet.seq_no     
                   , saledet.rem        
                   , customer.cust_name    
                   , saledet.order_qty
                   , saledet.color
                   , rout.assembly
                   , a.item_name                   
                   , (case when rout.represent = 'Y' then saledet.qa else rout.assy_qa end )
                   , rout.wc_no      
                   , wc.work_name         
                   , rout.operation
			   , a.uom" arguments=(("as_loc", string),("as_order", string))  sort="work_name A assembly_name A assy_qa A " )
