release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=68 color="536870912" )
footer(height=0 color="536870912" )
detail(height=68 color="536870912" )
table(column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene.scene_desc" )
 column=(type=datetime updatewhereclause=yes name=sale_due_date dbname="sale.due_date" initial=" " )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" initial=" " )
 column=(type=char(20) updatewhereclause=yes name=saledet_qa dbname="saledet.qa" )
 column=(type=char(2) updatewhereclause=yes name=saledet_uom dbname="saledet.uom" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_order_qty dbname="saledet.order_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_acc_qty dbname="saledet.acc_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=saledet_price dbname="saledet.price" )
 column=(type=char(14) updatewhereclause=yes name=sale_order_no dbname="sale.order_no" initial=" " )
 column=(type=datetime updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=datetime updatewhereclause=yes name=edate dbname="edate" )
 retrieve="  SELECT customer.cust_name,   
         scene.scene_desc,   
         sale.due_date,   
         groupitem.item_name,   
         saledet.qa,   
         saledet.uom,   
         saledet.order_qty,   
         saledet.acc_qty,   
         saledet.price,   
         sale.order_no,   
         sdate = convert(smalldatetime,  :as_start, 111),   
         edate = convert(smalldatetime, :as_end, 111) 
    FROM sale,   
         saledet,   
         customer,   
         scene,   
         groupitem  
   WHERE ( customer.cust_no *= scene.cust_no) and  
         ( sale.scene_code *= scene.scene_code) and  
         ( sale.order_no = saledet.order_no ) and  
         ( sale.cust_no = customer.cust_no ) and  
         ( saledet.item_no = groupitem.item_no ) and  
         ( customer.salesman like :as_ret ) and  
         ( ( sale.open_close = 'O' ) AND  
         ( sale.order_date between :as_start and :as_end ) )   
ORDER BY customer.cust_name ASC,   
         scene.scene_desc ASC,   
         sale.due_date ASC   
" arguments=(("as_start", date),("as_end", date),("as_ret", string))  sort="customer_cust_name A scene_scene_desc A sale_due_date A groupitem_item_name A saledet_qa A sale_order_no A " )
group(level=1 header.height=0 trailer.height=68 by=("customer_cust_name" , "scene_scene_desc" ) header.color="536870912" trailer.color="536870912" )
