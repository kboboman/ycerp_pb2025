$PBExportHeader$d_routcheckdet_list.srd
$PBExportComments$공정관리상세
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=72 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(14) update=yes updatewhereclause=yes key=yes name=sale_no dbname="RoutCheckDET.sale_no" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=seq_no dbname="RoutCheckDET.seq_no" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=seq dbname="RoutCheckDET.seq" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=job dbname="RoutCheckDET.job" )
 column=(type=char(10) updatewhereclause=yes name=work_name dbname="wc.work_name" )
 column=(type=datetime update=yes updatewhereclause=yes name=job_in dbname="RoutCheckDET.job_in" )
 column=(type=datetime update=yes updatewhereclause=yes name=job_inchk dbname="RoutCheckDET.job_inchk" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=job_qty dbname="RoutCheckDET.job_qty" )
 column=(type=datetime update=yes updatewhereclause=yes name=sys_date dbname="RoutCheckDET.sys_date" )
 column=(type=decimal(2) updatewhereclause=yes name=order_qty dbname="order_qty" )
 retrieve="  SELECT RoutCheckDET.sale_no   
       , RoutCheckDET.seq_no   
       , RoutCheckDET.seq   
       , RoutCheckDET.job   
       , wc.work_name
       , RoutCheckDET.job_in   
       , RoutCheckDET.job_inchk   
       , RoutCheckDET.job_qty  
       , RoutCheckDET.sys_date  
       , order_qty   = saledet.order_qty
    FROM RoutCheckDET   
         LEFT OUTER JOIN wc      ON RoutCheckDET.job = wc.work_no
         LEFT OUTER JOIN saledet ON RoutCheckDET.sale_no = saledet.order_no AND RoutCheckDET.seq_no = saledet.seq_no
   WHERE RoutCheckDET.sale_no = :as_saleno
     AND RoutCheckDET.seq_no  = :ai_seqno
     AND RoutCheckDET.job     = :as_job   
" update="RoutCheckDET" updatewhere=0 updatekeyinplace=no arguments=(("as_saleno", string),("ai_seqno", number),("as_job", string))  sort="sale_no A seq_no A seq D " )
