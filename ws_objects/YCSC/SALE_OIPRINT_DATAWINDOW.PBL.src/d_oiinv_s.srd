 column=(type=char(10) update=yes updatewhereclause=yes name=login_id dbname="aroiinv.login_id" )
 column=(type=char(40) update=yes updatewhereclause=yes name=rem dbname="aroiinv.rem" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=dc dbname="aroiinv.dc" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=decimal(0) updatewhereclause=yes name=dc_rate dbname="aroiinv.dc_rate" )
 column=(type=decimal(0) updatewhereclause=yes name=discount dbname="aroiinv.discount" )
 column=(type=char(3) updatewhereclause=yes name=inv_area dbname="aroiinv.inv_area" )
 retrieve="  SELECT aroiinv.aroiinv_no,   
         aroiinv.cust_no,   
         aroiinv.sale_flag,   
         aroiinv.register_no,   
         aroiinv.inv_type,   
         aroiinv.oi_date,   
         aroiinv.curr_code,   
         aroiinv.gl_cur_rate,   
         aroiinv.aroiinv_cash,   
         aroiinv.aroiinv_rate,   
         aroiinv.ship_cost,   
         aroiinv.printed,   
         aroiinv.open_close,   
         aroiinv.close_date,   
         aroiinv.delete_flag,   
         aroiinv.sys_date,   
         aroiinv.login_id,   
         aroiinv.rem,   
         aroiinv.dc,   
         customer.cust_name,   
         aroiinv.dc_rate,   
         aroiinv.discount,   
         aroiinv.inv_area  
    FROM aroiinv,   
         customer  
   WHERE ( aroiinv.cust_no = customer.cust_no )    
" )
