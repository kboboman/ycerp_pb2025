footer(height=76 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(30) updatewhereclause=yes name=supp_name dbname="supp_name" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=datetime updatewhereclause=yes name=insp_date dbname="insp_date" )
 column=(type=decimal(4) updatewhereclause=yes name=totamount dbname="totamount" )
 column=(type=decimal(6) updatewhereclause=yes name=ship_amount dbname="ship_amount" )
 column=(type=char(14) updatewhereclause=yes name=insp_no dbname="insp_no" )
 column=(type=long updatewhereclause=yes name=oi_no dbname="oi_no" )
 column=(type=char(14) updatewhereclause=yes name=dono dbname="dono" )
 column=(type=long updatewhereclause=yes name=doseq dbname="doseq" )
 column=(type=decimal(0) updatewhereclause=yes name=doshipamt dbname="doshipamt" )
 column=(type=char(1) updatewhereclause=yes name=doshipflag dbname="doshipflag" )
 column=(type=char(14) updatewhereclause=yes name=sale_no dbname="sale_no" )
 column=(type=long updatewhereclause=yes name=sale_seq dbname="sale_seq" )
 retrieve="  SELECT DISTINCT supp_name   = supp.supp_name        
       , cust_name   = (case when patindex('%/%',purdet.cust_name) > 0 
                                  then substring(purdet.cust_name,1, patindex('%/%',purdet.cust_name) - 1)
                             else purdet.cust_name
                        end)
       , scene_desc  = c.scene_desc          
       , insp_date   = insp.insp_date        
       , totamount   = insp.insp_cash /*(case when supp.round = 'N' 
                                  then CEILING(inspdet.comqty * inspdet.price)
                             else round( inspdet.comqty * inspdet.price, 0) 
                        end)*/
       , ship_amount = b.ship_amount         
       , insp_no     = inspdet.insp_no       
       , oi_no       = inspdet.oi_no         
       , dono        = dodet.do_no
       , doseq       = dodet.oi_no
       , doshipamt   = (SELECT ship_amount FROM do WHERE do_no = dodet.do_no )
       , doshipflag  = (SELECT ship_flag   FROM do WHERE do_no = dodet.do_no )
       , sale_no     = purdet.sale_no
       , sale_seq    = purdet.sale_seq
    FROM inspdet  with (nolock)
         LEFT OUTER JOIN insp      with (nolock) ON insp.insp_no    = inspdet.insp_no
         LEFT OUTER JOIN purdet    with (nolock) ON inspdet.pur_no  = purdet.order_no AND inspdet.seq_no = purdet.seq_no
         LEFT OUTER JOIN pur       with (nolock) ON inspdet.pur_no  = pur.order_no
         LEFT OUTER JOIN supp      with (nolock) ON insp.supp_no    = supp.supp_no
         LEFT OUTER JOIN ( /* 운반비 집계 */
              SELECT insp_no     = a.insp_no
                   , oi_no       = min(a.oi_no)
                   , ship_amount = avg(a.ship_amount)
                FROM (
                     SELECT inspdet.insp_no
                          , inspdet.oi_no
                          , ship_amount = insp.ship_amount
                       FROM inspdet with (nolock) 
                          , insp    with (nolock) 
                      WHERE ( insp.insp_no         = inspdet.insp_no )   
                        AND ( insp.ship_flag       = 'D' )
                        AND ( insp.insp_date BETWEEN :ad_date1 AND :ad_date2 )
                     ) A
               GROUP BY a.insp_no
         ) B ON inspdet.insp_no = b.insp_no AND inspdet.oi_no = b.oi_no
         
         LEFT OUTER JOIN ( /* 출고내역 */
              SELECT a.sale_no, a.seq_no, do_no = max(a.do_no), oi_no = max(a.oi_no), prt_date = max(a.prt_date)
                FROM (
                     SELECT do.do_no, dodet.oi_no, do.prt_date, dodet.sale_no, dodet.seq_no
                       FROM dodet with (nolock)
                            LEFT OUTER JOIN do with (nolock) ON dodet.do_no = do.do_no
                      WHERE do.do_date >= dateadd(month, -2, :ad_date1)  /* 이월반영 */
                     ) A
               GROUP BY a.sale_no, a.seq_no
         ) DODET ON purdet.sale_no = dodet.sale_no AND purdet.sale_seq = dodet.seq_no

         LEFT OUTER JOIN ( /* 현장명 */
              SELECT sale_no     = a.sale_no
                   , sale_seq    = a.sale_seq
                   , scene_desc  = scene.scene_desc
                FROM (
                     SELECT sale_no     = purdet.sale_no
                          , sale_seq    = purdet.sale_seq
                       FROM inspdet with (nolock) 
                            LEFT OUTER JOIN insp   with (nolock) ON inspdet.insp_no = insp.insp_no
                            LEFT OUTER JOIN purdet with (nolock) ON inspdet.pur_no  = purdet.order_no AND inspdet.seq_no = purdet.seq_no
                      WHERE ( insp.insp_date     BETWEEN :ad_date1 AND :ad_date2 )
                     ) A
                     LEFT OUTER JOIN sale  with (nolock) ON a.sale_no = sale.order_no
                     LEFT OUTER JOIN scene with (nolock) ON sale.scene_code = scene.scene_code
               WHERE scene.scene_desc IS NOT NULL
         ) C ON purdet.sale_no = c.sale_no AND purdet.sale_seq = c.sale_seq
   WHERE ( insp.insp_date     BETWEEN :ad_date1 AND :ad_date2  )
     AND ( ( :as_supp  = '%'      AND insp.supp_no   LIKE :as_supp ) or
           ( :as_supp <> '%'      AND insp.supp_no      = :as_supp )
         )
     AND ( ( :as_area  = 'S'      AND inspdet.pur_no LIKE 'PUR%'   ) or
           ( :as_area  = '%'      AND insp.area_no   LIKE '%'      ) or
           ( inspdet.pur_no      LIKE :as_area + '%'               ) 
         ) 
     AND b.ship_amount <> 0
   ORDER BY purdet.cust_name, inspdet.insp_no
" arguments=(("as_supp", string),("ad_date1", date),("ad_date2", date),("as_area", string))  sort="supp_name A insp_date A sale_no A " )
