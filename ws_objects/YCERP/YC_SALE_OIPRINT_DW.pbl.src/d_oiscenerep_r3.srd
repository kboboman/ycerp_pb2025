compute(band=detail alignment="1" expression="if(left( dodet_item_no  ,1) = 'P' and mid( dodet_item_no , 3,1) = 'Y' and (mid( dodet_item_no , 7,1) = 'A' or mid( dodet_item_no , 7,1) = 'B' or mid( dodet_item_no , 7,1) = 'C' or mid( dodet_item_no , 7,1) = 'D' or left(dodet_item_no, 5) = 'PCYSZ'),  dodet_ship_qty , if( dodet_uom  = 'M2' or dodet_uom = 'SS' ,truncate( long(mid(  dodet_qa  ,5,4)) * long(mid(  dodet_qa ,10,4)) *     dodet_ship_qty  / 1000000 + 0.00001 *  if (dodet_ship_qty < 0 , -1, 1), 2), if( dodet_uom  = 'M', if (dodet_ship_qty < 0 , truncate(long(mid( dodet_qa , 15,5)) *  dodet_ship_qty / 1000 - 0.00001,2), truncate(long(mid( dodet_qa , 15,5)) * dodet_ship_qty  / 1000 + 0.00001 *  if (dodet_ship_qty < 0 , -1, 1),2)) ,    dodet_ship_qty  )))"border="0" color="0" x="4494" y="4" height="60" width="425" format="#,##0.00" html.valueishtml="0"  name=c_acc_qty visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
