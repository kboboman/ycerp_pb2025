summary(height=68 color="15780518" )
footer(height=0 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_order_qty dbname="saledet.order_qty" )
 column=(type=char(14) updatewhereclause=yes name=saledet_order_no dbname="saledet.order_no" )
 column=(type=decimal(2) updatewhereclause=yes name=dodet_ship_qty dbname="dodet.ship_qty" )
 column=(type=char(14) updatewhereclause=yes name=dodet_do_no dbname="dodet.do_no" )
 column=(type=decimal(4) updatewhereclause=yes name=dodet_price dbname="price" )
 column=(type=decimal(6) updatewhereclause=yes name=amt dbname="amt" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 column=(type=datetime updatewhereclause=yes name=saledet_start_date dbname="start_date" )
 column=(type=datetime updatewhereclause=yes name=saledet_end_date dbname="end_date" )
 column=(type=long updatewhereclause=yes name=saledet_seq_no dbname="saledet.seq_no" )
 retrieve="  SELECT groupitem.item_name   
       , saledet.order_qty     
       , saledet.order_no      
       , dodet.ship_qty        
       , dodet.do_no           
       , price      = isnull(dodet.price, 0)
       , amt        = dodet.ship_qty * isnull(dodet.price, 0)
       , customer.cust_name    
       , scene.scene_desc      
       , start_date = convert(smalldatetime, :ad_start, 111)   
       , end_date   = convert(smalldatetime, :ad_end,   111)   
       , saledet.seq_no  

FROM DODET with(nolock) inner join do with(nolock) on dodet.do_no         = do.do_no  
                                                                inner join groupitem with(nolock) on dodet.item_no       = groupitem.item_no
                                                                left outer join saledet with(nolock) on dodet.sale_no = saledet.order_no and dodet.seq_no = saledet.seq_no
                                                                left outer  join scene with(nolock) on do.cust_no    = scene.cust_no and do.spot_code     = scene.scene_code
                                                                left outer join customer with(nolock)  on do.cust_no = customer.cust_no
                                                                left outer join custyspitem with(nolock) on  dodet.item_no = custyspitem.item_no  and  dodet.item_no = custyspitem.qa
  WHERE  ( do.area_no       LIKE :as_area          )  
     AND  ( do.do_date    BETWEEN :ad_start AND :ad_end )       
     AND  ( 
                     ( :as_flag = 'A'           ) OR
                     ( :as_flag = 'P' AND     ( ( dodet.item_no LIKE 'PCYSYS____' ) or ( dodet.item_no LIKE 'GCYSYS____' ) or ( dodet.item_no LIKE 'PCYSZ____'  ) ) ) OR
                      (:as_flag = 'Q' AND NOT ( ( dodet.item_no LIKE 'PCYSYS____' ) OR ( dodet.item_no LIKE 'GCYSYS____' ) OR ( dodet.item_no LIKE 'PCYSZ____'  ) ) ) 
                  )
/*
   FROM dodet     
       , do           
       , saledet      
       , groupitem    
       , customer     
       , scene  
   WHERE ( dodet.do_no         = do.do_no          )  
     AND ( dodet.sale_no      *= saledet.order_no  )  
     AND ( dodet.seq_no       *= saledet.seq_no    )  
     AND ( dodet.item_no       = groupitem.item_no )  
     AND ( do.area_no       LIKE :as_area          )  
     AND ( do.cust_no         *= customer.cust_no  )  
     AND ( do.spot_code       *= scene.scene_code  )  
     AND ( do.do_date    BETWEEN :ad_start AND :ad_end )       
     AND ( (:as_flag = 'A'           ) OR
           (:as_flag = 'P' AND     ( ( dodet.item_no LIKE 'PCYSYS%' ) 
                                  or ( dodet.item_no LIKE 'GCYSYS%' ) 
                                  or ( dodet.item_no LIKE 'PCYSZ%'  ) 
                                   ) ) OR
           (:as_flag = 'Q' AND NOT ( ( dodet.item_no LIKE 'PCYSYS%' ) 
                                  or ( dodet.item_no LIKE 'GCYSYS%' ) 
                                  or ( dodet.item_no LIKE 'PCYSZ%'  ) 
                                    ) 
           ) 
         )
*/" arguments=(("as_area", string),("ad_start", date),("ad_end", date),("as_flag", string))  sort="customer_cust_name A scene_scene_desc A saledet_order_no A saledet_seq_no A dodet_do_no A " )
group(level=1 header.height=0 trailer.height=68 by=("customer_cust_name" ) header.color="536870912" trailer.color="12639424" )
group(level=2 header.height=0 trailer.height=0 by=("customer_cust_name" , "scene_scene_desc" ) header.color="536870912" trailer.color="536870912" )
