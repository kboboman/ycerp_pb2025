release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=char(1) updatewhereclause=yes name=seq dbname="seq" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(4) updatewhereclause=yes name=bill_class dbname="bill_class" )
 column=(type=char(12) updatewhereclause=yes name=bill_no dbname="bill_no" )
 column=(type=char(20) updatewhereclause=yes name=draft dbname="draft" )
 column=(type=char(10) updatewhereclause=yes name=close_date dbname="close_date" )
 column=(type=char(20) updatewhereclause=yes name=bank_name dbname="bank_name" )
 column=(type=char(20) updatewhereclause=yes name=bill_area dbname="bill_area" )
 column=(type=decimal(4) updatewhereclause=yes name=bill_amount dbname="bill_amount" )
 column=(type=char(18) updatewhereclause=yes name=acct_date dbname="acct_date" )
 column=(type=char(50) updatewhereclause=yes name=rem dbname="rem" )
 column=(type=char(8) updatewhereclause=yes name=det_class dbname="det_class" )
 column=(type=decimal(4) updatewhereclause=yes name=amount dbname="amount" )
 column=(type=char(18) updatewhereclause=yes name=vcno_date dbname="vcno_date" )
 column=(type=char(1) updatewhereclause=yes name=set_view dbname="set_view" )
 column=(type=decimal(0) updatewhereclause=yes name=billamount dbname="billamount" )
 retrieve="SELECT seq         = aa.seq         
     , cust_no     = aa.cust_no     
     , bill_class  = aa.bill_class  
     , bill_no     = aa.bill_no     
     , draft       = aa.draft       
     , close_date  = aa.close_date  
     , bank_name   = aa.bank_name   
     , bill_area   = aa.bill_area   
     , bill_amount = aa.bill_amount 
     , acct_date   = aa.acct_date   
     , rem         = aa.rem         
     , det_class   = aa.det_class
     , amount      = aa.amount   
     , vcno_date   = aa.vcno_date   
     , set_view    = aa.set_view    
     , billamount  = (SELECT dbo.UF_BillAmount( aa.cust_no ) )
  FROM (
       SELECT seq         = '2'
            , cust_no     = a.cust_no
            , bill_class  = isnull((case when a.bill_class = 'R' then '받을'
                                         when a.bill_class = 'P' then '지급'
                                         when a.bill_class = 'C' then '교환'
                                         when a.bill_class = 'E' then '만기'
                                         when a.bill_class = 'D' and  b.det_class  = 'S' then '대손'
                                         when a.bill_class = 'D' and  b.det_class <> 'S' then '부도'
                                         else a.bill_class
                                    end), '')
            , bill_no     = isnull(b.bill_no, '')
            , draft       = isnull(a.draft,   '')
            , close_date  = convert(char(10),a.close_date,111)
            , bank_name   = c.bank_name
            , bill_area   = a.bill_area
            , bill_amount = 0
            , acct_date   = convert(char(10),b.acct_date,111)
            , rem         = b.rem
            , det_class   = (case when b.det_class = 'B' then '어음'
                                  when b.det_class = 'C' then '부도입금'
                                  when b.det_class = 'D' then '교환대'
                                  when b.det_class = 'E' then '수입이자'
                                  when b.det_class = 'F' then '물품대'
                                  when b.det_class = 'G' then '상계'
                                  when b.det_class = 'R' then '환불'
                                  when b.det_class = 'S' then '대손상각'
                                  when b.det_class = 'V' then '대손세액'
                                  else b.det_class
                             end)
            , amount      = isnull(b.amount,0) /*2017/02/24 한미란 요청 (case when b.det_class = 'C' then b.amount * -1
                                  else isnull(b.amount,0)
                             end)*/
            , vcno_date   = substring(b.billdet_vcno,2,4) + '/' + substring(b.billdet_vcno,6,2) + '/' + substring(b.billdet_vcno,8,2)
            , set_view    = isnull(a.set_view,'')
         FROM glbill A with (nolock) 
              RIGHT OUTER JOIN glbilldet B with (nolock) ON a.vc_no = b.vc_no AND a.bill_no = b.bill_no
              LEFT  OUTER JOIN bank      C with (nolock) ON a.bank_code  = c.bank_code
        WHERE b.det_class IN ( 'C', 'S', 'V' )
          AND b.bill_no   IN (
                             /* GLBILL 에서(받을,부도,지급어음 미지급분을 선별, 부도잔액 ZERO 제외(상각분은 제외) */ 
                             SELECT aa.bill_no
                               FROM (
                                    SELECT cust_no      = a.cust_no
                                         , bill_class   = isnull((case when a.bill_class = 'R' then '받을'
                                                                       when a.bill_class = 'P' then '지급'
                                                                       when a.bill_class = 'C' then '교환'
                                                                       when a.bill_class = 'E' then '만기'
                                                                       when a.bill_class = 'D' then '부도'
                                                                       else a.bill_class
                                                                  end), '')
                                         , bill_no      = isnull(a.bill_no, '')
                                         , draft        = isnull(a.draft,   '')
                                         , close_date   = convert(char(10),a.close_date,111)
                                         , bank_name    = c.bank_name
                                         , bill_area    = a.bill_area
                                         , bill_amount  = a.bill_amount
                                      FROM glbill A with (nolock) 
                                           LEFT OUTER JOIN bank c with (nolock) ON a.bank_code = c.bank_code
                                     WHERE a.cust_no        = :as_custno
                                       AND (a.bill_class   IN ('R','D')) /*받을,부도*/
                                        OR (a.bill_class    = 'P' AND convert(char(10),a.close_date,111) >= convert(char(10),getdate(),111) ) /*지급 만기일 존재*/
                                    ) AA
                             
                                    LEFT OUTER JOIN
                                    (
                                    SELECT cust_no      = cust_no
                                         , bill_class   = isnull(bill_class, '')
                                         , bill_no      = isnull(bill_no,    '')
                                         , det_class    = sum(isnull(det_class,0))
                                         , amount       = sum(aa.amount)
                                      FROM (
                                           SELECT cust_no    = a.cust_no
                                                , bill_class = (case when a.bill_class = 'R' then '받을'
                                                                     when a.bill_class = 'P' then '지급'
                                                                     when a.bill_class = 'C' then '교환'
                                                                     when a.bill_class = 'E' then '만기'
                                                                     when a.bill_class = 'D' then '부도'
                                                                     else a.bill_class
                                                                end)
                                                , bill_no    = isnull(a.bill_no, '')
                                                , det_class  = (case when b.det_class = 'B' then 0
                                                                     when b.det_class = 'C' then 0
                                                                     when b.det_class = 'D' then 0
                                                                     when b.det_class = 'E' then 0
                                                                     when b.det_class = 'F' then 0
                                                                     when b.det_class = 'G' then 0
                                                                     when b.det_class = 'R' then 0
                                                                     when b.det_class = 'S' then 1
                                                                end)
                                                , amount     = isnull(b.amount,0)
                                             FROM glbill A with (nolock) 
                                                  LEFT OUTER JOIN glbilldet B with (nolock) ON a.vc_no = b.vc_no AND a.bill_no = b.bill_no
                                            WHERE a.cust_no     = :as_custno
                                              AND (a.bill_class   IN ('R','D')) /*받을,부도*/
                                               OR (a.bill_class    = 'P' AND convert(char(10),a.close_date,111) >= convert(char(10),getdate(),111) ) /*지급 만기일 존재*/
                                            ) AA
                                        GROUP BY cust_no, bill_class, bill_no
                                    ) BB  
                                   ON aa.cust_no     = bb.cust_no  AND aa.bill_no  = bb.bill_no
                                WHERE (aa.bill_amount      <> bb.amount)
                                   OR (aa.bill_amount       = bb.amount  AND bb.det_class > 0)
                             /* GLBILL 에서(받을,부도,지급어음 미지급분을 선별, 부도잔액 ZERO 제외(상각분은 제외) */         
                             ) /* END OF IN () */

      /*----------------*/
       UNION  /*어음관리*/
      /*----------------*/
       SELECT seq         = '3'
            , cust_no     = a.cust_no    
            , bill_class  = isnull(a.bill_class, '')
            , bill_no     = isnull(a.bill_no,    '')
            , draft       = isnull(a.draft,      '')
            , close_date  = null
            , bank_name   = a.bank_name  
            , bill_area   = a.bill_area  
            , bill_amount = a.bill_amount
            , acct_date   = a.acct_date  
            , rem         = a.rem        
            , det_class   = a.det_class  
            , amount      = a.amount     
            , vcno_date   = a.vcno_date  
            , set_view    = ''
         FROM (
              SELECT cust_no     = a.cust_no         
                   , bill_class  = isnull((case when a.vc_type = 'R' and  a.rcpt_type     IN ('G','R','M','N') then '대손'
                                                when a.vc_type = 'R' and  a.rcpt_type NOT IN ('G','R','M','N') then '수금'
                                                when a.vc_type = 'P' then '지불'
                                                when a.vc_type = 'S' then '대손'
                                                else a.vc_type
                                           end), '')
                   , bill_no     = isnull(a.cheque_no,'')
                   , draft       = isnull(a.large,    '')
                   , close_date  = convert(char(10),a.oi_date,111)
                   , bank_name   = isnull(d.bank_name,'')
                   , bill_area   = isnull(a.branch,'')
                   , bill_amount = a.amount         
                   , vcno_date   = substring(a.vc_no,1,4) + '/' + substring(a.vc_no,5,2) + '/' + substring(a.vc_no,7,2)
                   , acct_date   = substring(a.vc_no,1,4) + '/' + substring(a.vc_no,5,2) + '/' + substring(a.vc_no,7,2)
                   , rem         = a.rem            
                   , det_class   = (case when a.rcpt_type = 'C' then '현금'      
                                         when a.rcpt_type = 'B' then '어음'     
                                         when a.rcpt_type = 'A' then '예금'     
                                         when a.rcpt_type = 'D' then 'D/C'      
                                         when a.rcpt_type = 'S' then '상계'     
                                         when a.rcpt_type = 'E' then '잡이익'   
                                         when a.rcpt_type = 'P' then '처리어음' 
                                         when a.rcpt_type = 'Z' then '기타'     
                                         when a.rcpt_type = 'F' then '하자보수' 
                                         when a.rcpt_type = 'G' then '대손상각' 
                                         when a.rcpt_type = 'R' then '대손이익' 
                                         when a.rcpt_type = 'M' then '대손입금' 
                                         when a.rcpt_type = 'N' then '대손어음' 
                                         else a.rcpt_type
                                    end)
                   , amount      = (case when a.rcpt_type = 'M' then a.amount * -1
                                         when a.rcpt_type = 'N' then a.amount * -1
                                         else a.amount
                                    end)
                FROM aroivc a with (nolock) 
                     LEFT OUTER JOIN bank   d with (nolock) ON a.bank_code = d.bank_code
               WHERE a.cust_no     = :as_custno
                 AND a.rcpt_type  IN ('G', 'M') /* 대손들('G','R','M','N') */
                 AND a.delete_key  = 'N'
                 AND a.amount      > 0
              ) A
       ) AA
" arguments=(("as_custno", string))  sort="seq D bill_no A acct_date A " )
