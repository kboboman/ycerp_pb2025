 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"scene~" ) COLUMN(NAME=~"scene.cust_no~") COLUMN(NAME=~"scene.scene_code~") COLUMN(NAME=~"scene.scene_desc~") COLUMN(NAME=~"scene.scene_charge~") COLUMN(NAME=~"scene.start_date~") COLUMN(NAME=~"scene.end_date~") COLUMN(NAME=~"scene.scene_tel~") COLUMN(NAME=~"scene.scene_scale~") COLUMN(NAME=~"scene.scene_addr~") COLUMN(NAME=~"scene.rem~")WHERE(    EXP1 =~"scene.cust_no~"   OP =~"=~"    EXP2 =~":as_cust~" ) ) ARG(NAME = ~"as_cust~" TYPE = string) " arguments=(("as_cust", string))  sort="scene_desc A " )
