footer(height=0 color="536870912" )
detail(height=160 color="536870912" )
table(column=(type=char(17) update=yes updatewhereclause=yes name=order_no dbname="mps.order_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=wc_no dbname="mps.wc_no" )
 column=(type=datetime update=yes updatewhereclause=yes name=start_date dbname="mps.start_date" )
 column=(type=datetime update=yes updatewhereclause=yes name=order_date dbname="mps.order_date" )
 column=(type=datetime update=yes updatewhereclause=yes name=due_date dbname="mps.due_date" )
 column=(type=char(1) update=yes updatewhereclause=yes name=open_close dbname="mps.open_close" values="확정	P/생성	A/마감	C/" )
 column=(type=datetime update=yes updatewhereclause=yes name=close_date dbname="mps.close_date" )
 column=(type=long update=yes updatewhereclause=yes name=revision_no dbname="mps.revision_no" )
 column=(type=datetime update=yes updatewhereclause=yes name=revision_date dbname="mps.revision_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=planner dbname="mps.planner" )
 column=(type=char(30) update=yes updatewhereclause=yes name=rem dbname="mps.rem" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=work_time dbname="mps.work_time" )
 column=(type=char(20) updatewhereclause=yes name=wc_work_name dbname="wc.work_name" initial=" " )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"mps~" )  TABLE(NAME=~"wc~" ) COLUMN(NAME=~"mps.order_no~") COLUMN(NAME=~"mps.wc_no~") COLUMN(NAME=~"mps.start_date~") COLUMN(NAME=~"mps.order_date~") COLUMN(NAME=~"mps.due_date~") COLUMN(NAME=~"mps.open_close~") COLUMN(NAME=~"mps.close_date~") COLUMN(NAME=~"mps.revision_no~") COLUMN(NAME=~"mps.revision_date~") COLUMN(NAME=~"mps.planner~") COLUMN(NAME=~"mps.rem~") COLUMN(NAME=~"mps.work_time~") COLUMN(NAME=~"wc.work_name~")    JOIN (LEFT=~"mps.wc_no~"    OP =~"=~"RIGHT=~"wc.work_no~" )WHERE(    EXP1 =~"mps.order_no~"   OP =~"=~"    EXP2 =~":as_orderno~" ) ) ARG(NAME = ~"as_orderno~" TYPE = string) " arguments=(("as_orderno", string)) )
