 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"ycboard~" ) COLUMN(NAME=~"ycboard.id_seq~") COLUMN(NAME=~"ycboard.rid~") COLUMN(NAME=~"ycboard.level~") COLUMN(NAME=~"ycboard.user_id~") COLUMN(NAME=~"ycboard.user_date~") COLUMN(NAME=~"ycboard.title~") COLUMN(NAME=~"ycboard.passwd~") COLUMN(NAME=~"ycboard.ret_cnt~") COLUMN(NAME=~"ycboard.board_text~")WHERE(    EXP1 =~"ycboard.id_seq~"   OP =~"=~"    EXP2 =~":ai_seq~" ) ) ARG(NAME = ~"ai_seq~" TYPE = number) " update="ycboard" updatewhere=0 updatekeyinplace=yes arguments=(("ai_seq", number)) )
