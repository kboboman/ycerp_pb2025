$PBExportComments$월의 일별수금 내역
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=260 color="536870912" )
summary(height=92 color="536870912" )
footer(height=0 color="536870912" )
detail(height=88 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=day dbname="day" )
 column=(type=decimal(4) updatewhereclause=yes name=amount dbname="amount" )
 retrieve="select 
	substring(convert(char(8), oi_date,112),7,2) day, sum(amount) amount
from 
	aroivc
where   
	oi_date BETWEEN convert(datetime,  :as_yyyymm+'01' +' 00:00:00' ) and convert(datetime,  convert(char(10), dateadd(day,-1, dateadd( month, 1, convert(datetime, :as_yyyymm+'01' ))) , 112 ) +  ' 23:59:59')
and 
	cust_no = :as_cust_no
and
	delete_key = 'N'
group by 
	substring(convert(char(8), oi_date,112),7,2)

" arguments=(("as_yyyymm", string),("as_cust_no", string)) )
