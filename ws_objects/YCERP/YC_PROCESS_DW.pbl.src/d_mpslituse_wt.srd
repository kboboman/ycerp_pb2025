table(column=(type=datetime updatewhereclause=yes name=coilsfcday_sfc_date dbname="sfc_date" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=coil_no dbname="coil_no" )
 column=(type=char(20) updatewhereclause=yes name=coilmst_qa dbname="qa" )
 column=(type=long updatewhereclause=yes name=qty dbname="qty" )
 column=(type=long updatewhereclause=yes name=coilmst_cnt dbname="cnt" )
 column=(type=char(30) updatewhereclause=yes name=wc_name dbname="wc_name" )
 column=(type=datetime updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=datetime updatewhereclause=yes name=edate dbname="edate" )
 column=(type=char(1) updatewhereclause=yes name=flag dbname="flag" values="사	I/외	O/" )
 column=(type=char(2) updatewhereclause=yes name=coilmst_etc_no dbname="coilmst.etc_no" )
 column=(type=char(1) updatewhereclause=yes name=as_flag dbname="as_flag" )
 retrieve="  SELECT DISTINCT sfc_date  = coilsfcday.sfc_date    
       , item_name = groupitem.item_name    
       , coil_no   = coilsfcday.w_coil_no   
       , qa        = coilmst.qa             
       , qty       = coilmst.unit_qty       
       , cnt       = coilmst.cnt            
       , wc_name   = wc.work_name           
       , sdate     = convert(smalldatetime, :ad_start, 111)   
       , edate     = convert(smalldatetime, :ad_end,   111)
       , flag      = 'I'
       , coilmst.etc_no 
       , as_flag   = :as_flag
    FROM groupitem    
       , coilsfcday   
       , coilmst      
       , wc  
   WHERE ( coilsfcday.w_coil_no       = coilmst.coil_no       )   
     and ( coilmst.item_no            = groupitem.item_no     )   
     and ( coilsfcday.wc_no           = wc.work_no            )   
     and ( coilsfcday.sfc_date  BETWEEN :ad_start AND :ad_end )    
         
  UNION
  SELECT DISTINCT sfc_date = coilsfcday.sfc_date              
       , item_name = groupitem.item_name                      
       , coil_no   = coilordersum.coil_no                     
       , qa        = coilmst.qa                               
       , qty       = coilmst.unit_qty                         
       , cnt       = coilmst.cnt                              
       , wc_name   = wc.work_name                             
       , sdate     = convert(smalldatetime, :ad_start, 111)   
       , edate     = convert(smalldatetime, :ad_end,   111)  
       , flag      = 'I'
       , coilmst.etc_no
       , as_flag   = :as_flag
    FROM groupitem      
       , coilsfcday   
       , coilordersum  
       , coilmst        
       , wc  
   WHERE ( coilsfcday.order_no        = coilordersum.order_no )   
     and ( coilordersum.coil_no       = coilmst.coil_no       )   
     and ( coilmst.item_no            = groupitem.item_no     )   
     and ( coilsfcday.wc_no           = wc.work_no            )   
     and ( coilsfcday.sfc_date  BETWEEN :ad_start AND :ad_end )
     
  UNION
  SELECT DISTINCT sfc_date = inaudit.inaudit_date          
       , item_name = groupitem.item_name                      
       , coil_no   = coilmst.coil_no                          
       , qa        = coilmst.qa                               
       , qty       = coilmst.unit_qty                         
       , cnt       = coilmst.cnt                              
       , wc_name   = supp.supp_name                           
       , sdate     = convert(smalldatetime, :ad_start, 111)   
       , edate     = convert(smalldatetime, :ad_end,   111)  
       , flag      = 'O'
       , coilmst.etc_no
       , as_flag   = :as_flag
    FROM inaudit     
       , coilmst     
       , groupitem   
       , supp  
   WHERE ( inaudit.serial_id          = coilmst.coil_no   )   
     AND ( inaudit.inaudit_item       = groupitem.item_no )   
     AND ( inaudit.destination        = supp.supp_no      )   
     AND ( ( inaudit_type             = 'IO'                  ) AND
           ( coilmst.flag             = 'W'                   ) AND  
           ( inaudit_date       BETWEEN :ad_start AND :ad_end ) 
         )    
" arguments=(("ad_start", date),("ad_end", date),("as_flag", string))  sort="coilsfcday_sfc_date A groupitem_item_name A coilmst_qa A qty A " )
