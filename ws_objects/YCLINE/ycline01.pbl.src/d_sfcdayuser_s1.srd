$PBExportHeader$d_sfcdayuser_s1.srd
$PBExportComments$일자별 작업장 작업자 추가
release 8;
datawindow(units=0 timer_interval=0 color=67108864 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no rows_per_detail = 10 )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=user_name dbname="sfcdayuser.user_name" )
 retrieve="  SELECT login.user_name  
    FROM sfcdayuser,   
         (
              SELECT user_id, user_name FROM login
              UNION ALL
              SELECT user_id = sabun, user_name = name_kor
                FROM v_insabase
               WHERE ((:as_area = 'S0001' AND acc_cd = '01') OR
                      (:as_area = 'T0001' AND acc_cd = '06')
                     )
         ) login
   WHERE ( sfcdayuser.user_id  = login.user_id ) 
     AND ( sfcdayuser.area_no  = :as_area      ) 
     AND ( sfcdayuser.wc_no    = :as_wc        ) 
     AND ( sfcdayuser.sfc_date = :ad_date      ) 
" arguments=(("as_area", string),("as_wc", string),("ad_date", date)) )
text(band=detail alignment="2" text="작업자:" border="6" color="16777215" x="14" y="4" height="64" width="315" html.valueishtml="0"  name=t_1 visible="1"  font.face="굴림" font.height="-10" font.weight="700"  font.family="1" font.pitch="2" font.charset="129" background.mode="2" background.color="128" )
htmltable(border="1" )
htmlgen(clientevents="1" clientvalidation="1" clientcomputedfields="1" clientformatting="0" clientscriptable="0" generatejavascript="1" netscapelayers="0" )
