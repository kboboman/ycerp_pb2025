release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=496 color="536870912" )
summary(height=92 color="536870912" )
footer(height=0 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(3) updatewhereclause=yes name=plan_div dbname="v_bdplan_yearqty.plan_div" )
 column=(type=char(3) updatewhereclause=yes name=plan_spec dbname="v_bdplan_yearqty.plan_spec" )
 column=(type=char(4) updatewhereclause=yes name=p_date dbname="p_date" )
 column=(type=decimal(0) updatewhereclause=yes name=qty dbname="qty" )
 column=(type=decimal(0) updatewhereclause=yes name=quantity dbname="quantity" )
 retrieve="select p.plan_div, p.plan_spec
     , substring( convert( char(4), p.plan_date, 112), 1, 4) p_date
     , sum(p.plan_qty) qty
     , sum(d.quantity) quantity
from v_bdplan_yearqty p,
     v_bdinfodet_yearqty d
where p.plan_div = d.div
  and p.plan_spec = d.spec
  and ( substring( convert( char(4), p.plan_date, 112), 1, 4)
    = substring( convert( char(4), d.fixeddate, 112), 1, 4) )
and  substring( convert( char(4), p.plan_date, 112),1,4) = :as_year
group by p.plan_div, p.plan_spec
       , substring( convert( char(4), p.plan_date, 112), 1, 4)

" arguments=(("as_year", string)) )
