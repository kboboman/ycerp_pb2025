 retrieve="  SELECT bpeom.supp_no,   
         bpeom.eom_year,   
         bpeom.balbf_amount,   
         bpeom.inv_01,   
         bpeom.inv_02,   
         bpeom.inv_03,   
         bpeom.inv_04,   
         bpeom.inv_05,   
         bpeom.inv_06,   
         bpeom.inv_07,   
         bpeom.inv_08,   
         bpeom.inv_09,   
         bpeom.inv_10,   
         bpeom.inv_11,   
         bpeom.inv_12,   
         bpeom.coll_01,   
         bpeom.coll_02,   
         bpeom.coll_03,   
         bpeom.coll_04,   
         bpeom.coll_05,   
         bpeom.coll_06,   
         bpeom.coll_07,   
         bpeom.coll_08,   
         bpeom.coll_09,   
         bpeom.coll_10,   
         bpeom.coll_11,   
         bpeom.coll_12,   
         bpeom.make_date,   
         bpeom.make_user  
    FROM bpeom  
   WHERE ( bpeom.area_no  = :arg_area ) 
     AND ( bpeom.supp_no  = :aa ) 
     AND ( bpeom.eom_year = :bb )    
" arguments=(("arg_area", string),("aa", string),("bb", number)) )
