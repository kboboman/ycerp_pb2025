$PBExportComments$자동생산계획 취소(2001/11/13,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=sale_no dbname="routtempnew.sale_no" initial="NO_SALE" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="routtempnew.seq_no" initial="0" )
 column=(type=char(1) updatewhereclause=yes name=suju_type dbname="routtempnew.suju_type" initial="N" values="Y.S.P	Y/시화	E/" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="routtempnew.item_no" initial="NO_ITEM" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="routtempnew.qa" initial="NO_QA" )
 column=(type=char(4) updatewhereclause=yes name=item_color dbname="routtempnew.item_color" initial="0000" )
 column=(type=decimal(4) updatewhereclause=yes name=order_qty dbname="routtempnew.order_qty" initial="0" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" initial=" " )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene.scene_desc" )
 retrieve="PBSELECT( VERSION(400) DISTINCT ()TABLE(NAME=~"routtempnew~" )  TABLE(NAME=~"groupitem~" )  TABLE(NAME=~"customer~" )  TABLE(NAME=~"scene~" ) COLUMN(NAME=~"routtempnew.sale_no~") COLUMN(NAME=~"routtempnew.seq_no~") COLUMN(NAME=~"routtempnew.suju_type~") COLUMN(NAME=~"routtempnew.item_no~") COLUMN(NAME=~"routtempnew.qa~") COLUMN(NAME=~"routtempnew.item_color~") COLUMN(NAME=~"routtempnew.order_qty~") COLUMN(NAME=~"groupitem.item_name~") COLUMN(NAME=~"customer.cust_name~") COLUMN(NAME=~"scene.scene_desc~")    JOIN (LEFT=~"routtempnew.cust_no~"    OP =~"=~"RIGHT=~"customer.cust_no~"    OUTER1 =~"routtempnew.cust_no~" )    JOIN (LEFT=~"routtempnew.scene_code~"    OP =~"=~"RIGHT=~"scene.scene_code~"    OUTER1 =~"routtempnew.scene_code~" )    JOIN (LEFT=~"routtempnew.item_no~"    OP =~"=~"RIGHT=~"groupitem.item_no~" )WHERE(    EXP1 =~"routtempnew.plan_flag~"   OP =~"=~"    EXP2 =~"'N'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"routtempnew.sale_no~"   OP =~"like~"    EXP2 =~":as_sale~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"groupitem.item_name~"   OP =~"like~"    EXP2 =~":as_name~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"routtempnew.item_no~"   OP =~"like~"    EXP2 =~":as_item~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"routtempnew.area_no~"   OP =~"=~"    EXP2 =~":as_area~" ) ) ORDER(NAME=~"routtempnew.sale_no~" ASC=yes )  ORDER(NAME=~"routtempnew.seq_no~" ASC=yes ) ARG(NAME = ~"as_sale~" TYPE = string)  ARG(NAME = ~"as_name~" TYPE = string)  ARG(NAME = ~"as_item~" TYPE = string)  ARG(NAME = ~"as_area~" TYPE = string) " arguments=(("as_sale", string),("as_name", string),("as_item", string),("as_area", string)) )
