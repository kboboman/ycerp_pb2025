$PBExportHeader$d_apbitemtot_r4.srd
$PBExportComments$조업자재 입고현황(전체)_건수
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=552 color="536870912" )
summary(height=76 color="536870912" )
footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=part_name dbname="part_name" )
 column=(type=char(30) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=long updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(30) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(4) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=char(4) updatewhereclause=yes name=com_uom dbname="com_uom" )
 column=(type=char(30) updatewhereclause=yes name=supp_name dbname="supp_name" )
 column=(type=char(10) updatewhereclause=yes name=cstart dbname="cstart" )
 column=(type=char(10) updatewhereclause=yes name=cend dbname="cend" )
 column=(type=long updatewhereclause=yes name=qty dbname="ship_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=c_qty dbname="c_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=c_price dbname="c_price" )
 column=(type=decimal(4) updatewhereclause=yes name=c_amt dbname="c_amt" )
 column=(type=decimal(5) updatewhereclause=yes name=c_rate dbname="c_rate" )
 column=(type=decimal(5) updatewhereclause=yes name=c_tot dbname="c_tot" )
 column=(type=long updatewhereclause=yes name=cnt dbname="cnt" )
 retrieve="  SELECT part_name = d.part_name
       , item_name = b.item_name   
       , item_no   = a.item_no      
       , qa        = a.qa           
       , uom       = a.uom             
       , com_uom   = a.uom             
       , supp_name = c.supp_name
       , cstart    = (case when :as_start = ''  then '          ' else :as_start   end)
       , cend      = (case when :as_end   = ''  then '          ' else :as_end     end)
       , ship_qty  = count(a.qa)
       , c_qty     = sum(a.qty)
       , c_price   = sum(a.cost)
       , c_amt     = sum(a.amount)
       , c_rate    = sum(a.amount * 0.1)
       , c_tot     = sum(a.amount + (a.amount * 0.1))
       , cnt       = count(a.qa)
    FROM binitem A
         LEFT OUTER JOIN bitem B ON a.item_no = b.item_no 
         LEFT OUTER JOIN bsupp C ON a.supp_no = c.supp_no  
         LEFT OUTER JOIN bpart D ON a.part_code = d.part_no
   WHERE ( convert(char(10),a.in_date,111)  BETWEEN :as_start AND :as_end )
     AND ( a.supp_no           LIKE :as_supp      )
   GROUP BY d.part_name
          , b.item_name   
          , a.item_no      
          , a.qa           
          , a.uom             
          , c.supp_name
          , a.cost
   ORDER BY d.part_name, b.item_name, a.qa, c.supp_name           
" arguments=(("as_start", string),("as_end", string),("as_supp", string)) )
