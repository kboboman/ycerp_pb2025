detail(height=80 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=user_id dbname="user_id" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=approval_name dbname="approval_name" )
 column=(type=char(10) update=yes updatewhereclause=yes name=approval1 dbname="approval1" )
 column=(type=char(10) update=yes updatewhereclause=yes name=approval2 dbname="approval2" )
 column=(type=char(10) update=yes updatewhereclause=yes name=approval3 dbname="approval3" )
