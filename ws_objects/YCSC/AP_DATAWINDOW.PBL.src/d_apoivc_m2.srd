$PBExportHeader$d_apoivc_m2.srd
$PBExportComments$자재지불등록(1999/05/24, 이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=88 color="536870912" )
summary(height=0 color="536870912" )
footer(height=68 color="15780518" )
detail(height=72 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=apoiinv_oi_date dbname="apoiinv.oi_date" )
 column=(type=char(12) update=yes updatewhereclause=yes key=yes name=apoiinv_apoiinv_no dbname="apoiinv.apoiinv_no" )
 column=(type=decimal(4) updatewhereclause=yes name=apoiinv_apoiinv_cash dbname="apoiinv.apoiinv_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=apoiinv_apoiinv_rate dbname="apoiinv.apoiinv_rate" )
 column=(type=decimal(0) updatewhereclause=yes name=apoiinv_dc dbname="apoiinv.dc" )
 column=(type=char(30) updatewhereclause=yes name=supp_supp_name dbname="supp.supp_name" )
 column=(type=char(1) update=yes updatewhereclause=yes name=apoiinv_open_close dbname="apoiinv.open_close" values="	T/	O" )
 retrieve="  SELECT apoiinv.oi_date        
       , apoiinv.apoiinv_no     
       , apoiinv.apoiinv_cash   
       , apoiinv.apoiinv_rate   
       , apoiinv.dc             
       , supp.supp_name         
       , apoiinv.open_close  
    FROM apoiinv
       , supp  
   WHERE ( apoiinv.supp_no          = supp.supp_no ) 
     AND ( apoiinv.supp_no          = :as_supp_no  ) 
     AND ( apoiinv.open_close       = 'O'          )   
     AND ( apoiinv.delete_flag      = 'N'          )   
     AND ( apoiinv.oi_date    between :ad_start and :ad_end )
" update="apoiinv" updatewhere=0 updatekeyinplace=no arguments=(("as_supp_no", string),("ad_start", date),("ad_end", date)) )
