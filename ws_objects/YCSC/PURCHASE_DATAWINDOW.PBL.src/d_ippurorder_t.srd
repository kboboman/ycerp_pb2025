table(column=(type=char(10) updatewhereclause=yes name=purdet_order_no dbname="purdet.order_no" )
 column=(type=char(10) updatewhereclause=yes name=purdet_item_no dbname="purdet.item_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(20) updatewhereclause=yes name=purdet_qa dbname="purdet.qa" )
 column=(type=datetime updatewhereclause=yes name=purdet_due_date dbname="purdet.due_date" )
 column=(type=decimal(4) updatewhereclause=yes name=purdet_order_qty dbname="purdet.order_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=purdet_com_qty dbname="purdet.com_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=purdet_price dbname="purdet.price" )
 column=(type=char(2) updatewhereclause=yes name=purdet_uom dbname="purdet.uom" )
 column=(type=char(2) updatewhereclause=yes name=purdet_com_uom dbname="purdet.com_uom" )
 column=(type=char(17) updatewhereclause=yes name=purdet_product_no dbname="purdet.product_no" )
 column=(type=char(30) updatewhereclause=yes name=purdet_rcpt_loc dbname="rcpt_loc" )
 column=(type=char(30) updatewhereclause=yes name=supp_supp_name dbname="supp.supp_name" )
 column=(type=decimal(4) updatewhereclause=yes name=purdet_rlse_qty dbname="purdet.rlse_qty" )
 column=(type=long updatewhereclause=yes name=purdet_cnt dbname="purdet.cnt" )
 column=(type=datetime updatewhereclause=yes name=s dbname="s" )
 column=(type=datetime updatewhereclause=yes name=e dbname="e" )
 column=(type=char(10) updatewhereclause=yes name=pur_area_no dbname="pur.area_no" )
 retrieve="  SELECT purdet.order_no       
       , purdet.item_no        
       , groupitem.item_name   
       , purdet.qa             
       , purdet.due_date       
       , purdet.order_qty      
       , purdet.com_qty        
       , purdet.price          
       , purdet.uom            
       , purdet.com_uom        
       , purdet.product_no     
       , rcpt_loc  = (SELECT isnull(loc_name,'') FROM location WHERE loc_no = purdet.rcpt_loc)
       , supp.supp_name        
       , purdet.rlse_qty       
       , purdet.cnt         
       , s         = convert(smalldatetime, :ad_sdate, 111)
       , e         = convert(smalldatetime, :ad_edate, 111)  
       , pur.area_no
    FROM pur         
       , purdet      
       , groupitem  
       , supp  
   WHERE ( purdet.item_no       = groupitem.item_no )   
     AND ( purdet.order_no      = pur.order_no      )   
     AND ( pur.supp_no          = supp.supp_no      )   
     AND ( pur.order_date BETWEEN :ad_sdate AND :ad_edate ) 
     AND ( ( :as_supp <> '%'  and pur.supp_no      = :as_supp ) OR
           ( :as_supp  = '%'  and pur.supp_no   LIKE '%'      )
         )
     AND ( ( :as_area   = 'S' and pur.order_no LIKE 'PUR%'   ) or  
           ( :as_area   = '%' and pur.area_no  LIKE '%'      ) or
           ( pur.order_no    LIKE :as_area + '%'             )
         )
   ORDER BY purdet.order_no ASC   
" arguments=(("as_supp", string),("ad_sdate", date),("ad_edate", date),("as_area", string))  sort="supp_supp_name A groupitem_item_name A purdet_qa A purdet_order_no A purdet_due_date A " )
group(level=1 header.height=0 trailer.height=76 by=("supp_supp_name" ) header.color="536870912" trailer.color="12639424" )
