$PBExportHeader$d_osaroicheck_r2.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=84 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(14) updatewhereclause=yes name=do_no dbname="do_no" )
 column=(type=decimal(4) updatewhereclause=yes name=do_total dbname="do_total" )
 column=(type=decimal(4) updatewhereclause=yes name=c_amt dbname="c_amt" )
 column=(type=decimal(4) updatewhereclause=yes name=c_vat dbname="c_vat" )
 column=(type=decimal(1) updatewhereclause=yes name=ship_amount dbname="ship_amount" )
 retrieve="  SELECT cust_no     = do.cust_no
       , cust_name   = c.cust_name
       , do_no       = do.do_no
       , do_total    = do.do_total
       , c_amt       = isnull(d.c_amt,0)
       , c_vat       = isnull(d.c_vat,0)
       , ship_amount = (case when isnull(d.c_amt,0) = 0 then 0
                             else isnull(e.ship_amount,0)
                        end)
    FROM do 
         LEFT OUTER JOIN customer  C ON do.cust_no    = c.cust_no
         LEFT OUTER JOIN ( /* 계산서금액 */
              SELECT dodet.do_no   
                   , c_amt     = sum((case when do.do_rate = 0 then dodet.aroi_qty * dodet.price
                                           else dodet.aroi_qty * dodet.price * 1.1
                                      end) + dodet.rate_cash)
                FROM dodet
                     LEFT OUTER JOIN do ON dodet.do_no   = do.do_no
               WHERE ( do.cust_no        = :as_custno     )
                 AND ( dodet.ship_qty    = dodet.aroi_qty )
                 AND ( substring(convert(char(10), do.do_date, 121), 1, 7)  = :as_yyyymm ) 
                 AND ( do.sale_flag      = 'D'  ) 
               GROUP BY dodet.do_no
         ) B ON do.do_no = b.do_no

         LEFT OUTER JOIN (
              SELECT aroi.do_no   
                   , c_amt  = sum(aroi.ori_amount)
                   , c_vat  = sum(aroi.rate_cash)
                FROM aroi
                     LEFT OUTER JOIN aroiinv ON aroi.aroiinv_no = aroiinv.aroiinv_no
               WHERE ( aroiinv.cust_no  = :as_custno ) 
                 AND ( substring(convert(char(10), aroiinv.oi_date, 121), 1, 7)  = :as_yyyymm )
                 AND ( aroiinv.delete_flag  = 'N' )
                 AND ( aroiinv.open_close in ('O', 'T') ) 
               GROUP BY aroi.do_no
         ) D ON do.do_no = d.do_no

         LEFT OUTER JOIN (
              SELECT DISTINCT do.do_no
                   , ship_amount  = (case when do.do_rate = 0 then do.ship_amount
                                          else do.ship_amount * 1.1
                                     end)
                FROM dodet   
                     LEFT OUTER JOIN do ON dodet.do_no = do.do_no
               WHERE ( do.cust_no      = :as_custno ) 
                 AND ( substring(convert(char(10), do.do_date, 121), 1, 7)  = :as_yyyymm ) 
                 AND ( do.ship_amount <> 0   ) 
                 AND ( do.ship_flag    = 'D' )     
         ) E ON do.do_no = e.do_no
   WHERE ( do.cust_no = :as_custno )
     AND ( substring(convert(char(10), do.do_date, 121), 1, 7)  = :as_yyyymm )
" arguments=(("as_custno", string),("as_yyyymm", string))  sort="do_no A " )
