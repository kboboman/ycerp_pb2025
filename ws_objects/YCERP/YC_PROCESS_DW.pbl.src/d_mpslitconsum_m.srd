table(column=(type=char(10) updatewhereclause=yes name=coilmst_item_no dbname="coilmst.item_no" )
 column=(type=long updatewhereclause=yes name=unit_qty dbname="coilmst.unit_qty" )
 column=(type=char(14) update=yes updatewhereclause=yes name=order_no dbname="coilordersum.order_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=coil_no dbname="coilordersum.coil_no" )
 column=(type=decimal(1) update=yes updatewhereclause=yes name=wid dbname="coilordersum.wid" )
 column=(type=long update=yes updatewhereclause=yes name=cnt dbname="coilordersum.cnt" )
 column=(type=char(30) update=yes updatewhereclause=yes name=rem dbname="coilordersum.rem" )
 column=(type=char(10) update=yes updatewhereclause=yes name=loc_no dbname="coilordersum.loc_no" )
 column=(type=long updatewhereclause=yes name=coilmst_qcnt dbname="coilmst.qcnt" )
 column=(type=char(2) updatewhereclause=yes name=coilmst_etc_no dbname="coilmst.etc_no" )
 retrieve="  SELECT coilmst.item_no         
       , coilmst.unit_qty        
       , coilordersum.order_no   
       , coilordersum.coil_no    
       , coilordersum.wid        
       , coilordersum.cnt        
       , coilordersum.rem        
       , coilordersum.loc_no     
       , coilmst.qcnt            
       , coilmst.etc_no  
    FROM coilordersum   
       , coilmst        
       , coilorder      
       , coilorderdet  
   WHERE ( coilordersum.coil_no   = coilmst.coil_no              )   
     AND ( coilorderdet.order_no  = coilordersum.order_no        )   
     AND ( coilorder.order_no     = coilorderdet.coilorder_order )   
     AND ( coilordersum.loc_no    = coilmst.loc_no               )   
     AND ( ( coilorder.order_no   = :as_order ) )    
" arguments=(("as_order", string)) )
