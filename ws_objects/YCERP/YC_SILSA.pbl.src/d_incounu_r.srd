$PBExportHeader$d_incounu_r.srd
$PBExportComments$담당자별실사품목(2001/09/11,이인호)
release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=456 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=user_id dbname="incounu.user_id" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="incounu.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="incounu.qa" )
 column=(type=char(10) updatewhereclause=yes name=loc_no dbname="incounu.loc_no" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name dbname="login.user_name" )
 column=(type=char(30) updatewhereclause=yes name=location_loc_name dbname="location.loc_name" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 retrieve="  SELECT incounu.user_id,   
         incounu.item_no,   
         incounu.qa,   
         incounu.loc_no,   
         login.user_name,   
         location.loc_name,   
         groupitem.item_name  
    FROM incounu,   
         login,   
         location,   
         groupitem  
   WHERE ( incounu.user_id = login.user_id ) and  
         ( incounu.loc_no = location.loc_no ) and  
         ( incounu.item_no = groupitem.item_no ) and  
         ( incounu.user_id = :as_user )    
" arguments=(("as_user", string))  sort="item_no A qa A loc_no A " )
