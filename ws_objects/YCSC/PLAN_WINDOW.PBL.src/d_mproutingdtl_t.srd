release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=84 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=item_no dbname="wc.item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="groupitem.item_name" )
 column=(type=char(10) updatewhereclause=yes name=wc_no dbname="wc.wc_no" )
 column=(type=char(10) updatewhereclause=yes name=work_name dbname="wc.work_name" )
 retrieve="  SELECT distinct a.item_no
       , gi.item_name
       , a.wc_no
       , wc.work_name
    FROM (
         SELECT item_no, wc_no, qa
           FROM rout
          WHERE item_no  = :as_itemno
            AND rout.operation = 1
          GROUP BY item_no, wc_no, qa
        /*ORDER BY item_no, wc_no, qa*/
         ) a    
        LEFT OUTER JOIN (
             SELECT item_no, wc_no, cnt = count(qa)
               FROM rout
              WHERE item_no  = :as_itemno
                AND rout.operation = 1
              GROUP BY item_no, wc_no
        )   b    ON a.item_no = b.item_no AND a.wc_no = b.wc_no
        LEFT OUTER JOIN wc            ON a.wc_no    = wc.work_no
        LEFT OUTER JOIN groupitem gi  ON a.item_no  = gi.item_no
    ORDER BY a.item_no, a.wc_no
" arguments=(("as_itemno", string)) )
