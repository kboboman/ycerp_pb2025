 column=(type=long updatewhereclause=yes name=qoh dbname="qoh" )
 retrieve="  SELECT sampdet.samp_no,   
         sampdet.seq_no,   
         sampdet.item_no,   
         sampdet.qa,   
         sampdet.uom,   
         sampdet.loc_no,   
         sampdet.issue_qty,   
         sampdet.price,   
         groupitem.item_name,   
         sampdet.rem ,
			qoh = 0 
    FROM sampdet LEFT OUTER JOIN groupitem ON sampdet.item_no = groupitem.item_no
	where sampdet.samp_no = :as_samp_no
" update="sampdet" updatewhere=0 updatekeyinplace=no arguments=(("as_samp_no", string)) )
