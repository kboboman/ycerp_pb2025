$PBExportHeader$d_item_paint_r.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=68 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=88 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=item_no dbname="item.item_no" )
 column=(type=char(255) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="item.qa" )
 column=(type=char(50) updatewhereclause=yes name=paint_no dbname="item.paint_no" )
 column=(type=char(50) updatewhereclause=yes name=paint_name dbname="item.paint_name" )
 column=(type=char(50) updatewhereclause=yes name=paint_company dbname="item.paint_company" )
 column=(type=char(1) updatewhereclause=yes name=glossy_yn dbname="item.glossy_yn" values="유광	1/무광	2/" )
 column=(type=char(80) updatewhereclause=yes name=rem dbname="item.rem" )
 retrieve="select item.item_no,
           replace(item.item_name, '체 도료', '') item_name,
           item.qa,
		item.paint_no,
		item.paint_name,
		item.paint_company,
		item.glossy_yn,
		item.rem
from item inner join groupitem on item.item_no = groupitem.item_no
where groupitem.p4 = '0'
and item.use_flag = 'Y'
"  sort="item_name A paint_company A paint_name A qa A " )
