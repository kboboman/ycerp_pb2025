table(column=(type=char(14) update=yes updatewhereclause=yes key=yes name=sale_no dbname="sale_no" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=seq_no dbname="seq_no" )
 column=(type=datetime update=yes updatewhereclause=yes name=order_date dbname="order_date" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=datetime updatewhereclause=yes name=napgi_date dbname="napgi_date" )
 column=(type=long updatewhereclause=yes name=napgi_chk dbname="napgi_chk" )
 column=(type=decimal(2) updatewhereclause=yes name=order_qty dbname="order_qty" )
 column=(type=char(10) update=yes updatewhereclause=yes name=job1 dbname="job1" )
 column=(type=char(10) updatewhereclause=yes name=w1nm dbname="w1nm" )
 column=(type=char(10) update=yes updatewhereclause=yes name=job2 dbname="job2" )
 column=(type=char(10) updatewhereclause=yes name=w2nm dbname="w2nm" )
 column=(type=char(10) update=yes updatewhereclause=yes name=job3 dbname="job3" )
 column=(type=char(10) updatewhereclause=yes name=w3nm dbname="w3nm" )
 column=(type=char(50) updatewhereclause=yes name=sd_rem dbname="sd_rem" )
 retrieve="  SELECT sale_no    = rc.sale_no
       , seq_no     = rc.seq_no
       , order_date = rc.order_date
       , user_name  = l.user_name
       , cust_name  = c.cust_name
       , scene_desc = s1.scene_desc
       , item_no    = sd.item_no
       , item_name  = g.item_name
       , qa         = sd.qa 

       , napgi_date = s.due_date
       , napgi_chk  = datediff(d, s.order_date, s.due_date)
       , order_qty  = sd.order_qty

       , job1       = rc.job1
       , w1nm       = w1.work_name

       , job2       = rc.job2
       , w2nm       = w2.work_name

       , job3       = rc.job3
       , w3nm       = w3.work_name

       , sd_rem     = sd.rem
    FROM routcheck RC
         LEFT OUTER JOIN sale      S ON rc.sale_no   = s.order_no
         LEFT OUTER JOIN saledet  SD ON rc.sale_no   = sd.order_no AND rc.seq_no = sd.seq_no
         LEFT OUTER JOIN customer  C ON s.cust_no    = c.cust_no
         LEFT OUTER JOIN login     L ON c.salesman   = l.user_id
         LEFT OUTER JOIN groupitem G ON sd.item_no   = g.item_no
         LEFT OUTER JOIN scene    S1 ON s.scene_code = s1.scene_code
         LEFT OUTER JOIN wc       W1 ON rc.job1      = w1.work_no
         LEFT OUTER JOIN wc       W2 ON rc.job2      = w2.work_no
         LEFT OUTER JOIN wc       W3 ON rc.job3      = w3.work_no
         LEFT OUTER JOIN ( 
              SELECT a.user_name
                   , a.cust_name
                   , a.scene_desc
                   , a.order_no
                   , a.seq_no
                   , a.item_no
                   , a.qa   
                   , a.qa19 
                   , wc1 = max((case when r.operation = 1 then r.wc_no else null end))
                   , wc2 = max((case when r.operation = 2 then r.wc_no else null end))
                   , wc3 = max((case when r.operation = 3 then r.wc_no else null end))
                FROM (
                      SELECT l.user_name
                           , c.cust_name
                           , s.scene_desc
                           , a.order_no
                           , a.seq_no
                           , a.item_no
                           , qa   = left(a.qa ,14) + '00000'
                           , qa19 = a.qa
                        FROM saledet A
                             LEFT OUTER JOIN sale       B ON a.order_no   = b.order_no
                             LEFT OUTER JOIN customer   C ON b.cust_no    = c.cust_no
                             LEFT OUTER JOIN scene      S ON b.scene_code = s.scene_code
                             LEFT OUTER JOIN login      L ON c.salesman   = l.user_id
                       WHERE (b.order_date between :as_sdate AND :as_edate)
/*                         AND (b.open_close       <> 'C') 한도초과*/
                           AND (b.open_close       = 'O')
                         AND (b.tracking          = 'Y')
                         AND (a.order_qty - a.rlse_qty > 0 )
                         AND ((:as_custno  = '%' AND b.cust_no    LIKE '%') OR
                              (:as_custno <> '%' AND b.cust_no       = :as_custno)
                             )
                         AND ((:as_scene   = '%' AND b.scene_code LIKE '%') OR
                              (:as_scene  <> '%' AND b.scene_code    = :as_scene )
                             )
                         AND NOT EXISTS (SELECT * FROM routcheck WHERE sale_no = a.order_no AND seq_no = a.seq_no AND del_yn = 'Y')
                     ) A
                     LEFT OUTER JOIN rout R ON a.item_no = r.item_no AND a.qa = r.qa
               GROUP BY a.user_name, a.cust_name, a.scene_desc, a.order_no, a.seq_no, a.item_no, a.qa, a.qa19
         ) A  ON rc.sale_no = a.order_no AND rc.seq_no = a.seq_no
   WHERE rc.order_date between :as_sdate AND :as_edate
     AND ((:as_work1 <> 'Y' )  OR
          (:as_work1  = 'Y' AND 
           NOT ((w1.work_name = '' OR w1.work_name LIKE '성형%' OR w1.work_name LIKE '화성%') AND w2.work_name = '')
          )
         )
" update="routcheck" updatewhere=0 updatekeyinplace=no arguments=(("as_custno", string),("as_scene", string),("as_sdate", string),("as_edate", string),("as_work1", string))  sort="cust_name A scene_desc A item_name A qa A sale_no A seq_no A " )
