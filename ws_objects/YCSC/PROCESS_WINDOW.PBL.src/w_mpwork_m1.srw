destroy(this.cb_7)
destroy(this.cbx_2)
end on

type cb_17 from commandbutton within tabpage_2
integer x = 4055
integer y = 8
integer width = 562
integer height = 84
integer taborder = 220
boolean bringtotop = true
integer textsize = -10
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "생산품목 전개도"
end type

event clicked;string ls_orderno, ls_itemno, ls_itemnm, ls_qa, ls_color, ls_bigo // 품목, 규격, 색상
long   ll_qty, ll_seq, ll_row, ll_dw6cnt

if IsValid(w_m_main) then 
	OpenSheet(w_mpplansource_m,  w_m_main, 5, original!)
elseif IsValid(w_all_main) then 
	OpenSheet(w_mpplansource_m,  w_all_main, 5, original!)
end if

IF MessageBox("확인","작업일보 실적내용을 '생산품목 전개도' 복사 하시겠습니까?", Exclamation!, OKCancel!, 1) = 2 THEN
	RETURN
END IF

w_mpplansource_m.setredraw(false)
w_mpplansource_m.tab_1.selecttab(2)
w_mpplansource_m.pb_retrieve.PostEvent(Clicked!)

ll_dw6cnt = w_mpplansource_m.dw6.rowcount()
for ll_row = 1 to dw4.rowcount()
	ll_dw6cnt = ll_dw6cnt + 1
	w_mpplansource_m.dw6.object.seq_no[ll_dw6cnt]  = ll_dw6cnt
	w_mpplansource_m.dw6.object.sale_no[ll_dw6cnt] = dw4.object.sale_no[ll_row]
	w_mpplansource_m.dw6.object.seq[ll_dw6cnt]     = dw4.object.seq_no[ll_row]
	
	ls_orderno = dw4.object.sale_no[ll_row]
	if isnull(ls_orderno) or ls_orderno = "" then
		w_mpplansource_m.dw6.deleterow(ll_row)
	else
		ll_seq     = w_mpplansource_m.dw6.object.seq[ll_row]    
		SELECT A.ITEM_NO, B.ITEM_NAME, A.QA, C.COLOR_NAME, A.REM, A.ORDER_QTY
		  INTO :ls_itemno, :ls_itemnm, :ls_qa, :ls_color, :ls_bigo, :ll_qty
		  FROM SALEDET A
				 LEFT OUTER JOIN GROUPITEM B   ON A.ITEM_NO  = B.ITEM_NO
				 LEFT OUTER JOIN COLOR     C   ON A.COLOR    = C.COLOR_CODE
		 WHERE A.ORDER_NO  = :ls_orderno
			AND A.SEQ_NO    = :ll_seq;

		w_mpplansource_m.dw6.object.item_no[ll_dw6cnt]   = ls_itemno
		w_mpplansource_m.dw6.object.item_name[ll_dw6cnt] = ls_itemnm
		w_mpplansource_m.dw6.object.qa[ll_dw6cnt]        = ls_qa       
		w_mpplansource_m.dw6.object.color[ll_dw6cnt]     = ls_color    
		
		w_mpplansource_m.dw6.object.b1_drawno[ll_dw6cnt]  = ""
		w_mpplansource_m.dw6.object.b1_qa1[ll_dw6cnt]     = 0
		w_mpplansource_m.dw6.object.b1_qa2[ll_dw6cnt]     = 0
		w_mpplansource_m.dw6.object.b1_qa3[ll_dw6cnt]     = 0
		w_mpplansource_m.dw6.object.b1_qa4[ll_dw6cnt]     = 0
		w_mpplansource_m.dw6.object.qty[ll_dw6cnt]        = ll_qty
		w_mpplansource_m.dw6.object.b1_qa5[ll_dw6cnt]     = 0
		w_mpplansource_m.dw6.object.b1_qa6[ll_dw6cnt]     = 0
		w_mpplansource_m.dw6.object.b1_qa7[ll_dw6cnt]     = 0
		w_mpplansource_m.dw6.object.b1_qa8[ll_dw6cnt]     = 0
		w_mpplansource_m.dw6.object.b1_cuts[ll_dw6cnt]    = 0
		w_mpplansource_m.dw6.object.b1_rem[ll_dw6cnt]     = ""
		
		w_mpplansource_m.dw6.object.p1_qa1[ll_dw6cnt]     = 0
		w_mpplansource_m.dw6.object.p1_qa2[ll_dw6cnt]     = 0
		w_mpplansource_m.dw6.object.p1_face[ll_dw6cnt]    = 0
		w_mpplansource_m.dw6.object.p1_rem[ll_dw6cnt]     = ls_bigo
		w_mpplansource_m.dw6.object.p1_refcolor[ll_dw6cnt]= ""
		w_mpplansource_m.dw6.object.p1_keyno[ll_dw6cnt]   = ""		
	end if	
next

w_mpplansource_m.setredraw(true)

end event

