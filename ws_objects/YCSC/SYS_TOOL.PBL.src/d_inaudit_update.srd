 column=(type=char(10) update=yes updatewhereclause=yes name=user_id dbname="inaudit.user_id" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"inaudit~" ) COLUMN(NAME=~"inaudit.inaudit_time~") COLUMN(NAME=~"inaudit.inaudit_date~") COLUMN(NAME=~"inaudit.inaudit_item~") COLUMN(NAME=~"inaudit.qa~") COLUMN(NAME=~"inaudit.loc_no~") COLUMN(NAME=~"inaudit.inaudit_type~") COLUMN(NAME=~"inaudit.order_no~") COLUMN(NAME=~"inaudit.rcpt_qty~") COLUMN(NAME=~"inaudit.issue_qty~") COLUMN(NAME=~"inaudit.cost~") COLUMN(NAME=~"inaudit.destination~") COLUMN(NAME=~"inaudit.serial_id~") COLUMN(NAME=~"inaudit.rem~") COLUMN(NAME=~"inaudit.unit_qty~") COLUMN(NAME=~"inaudit.cnt~") COLUMN(NAME=~"inaudit.com_qty~") COLUMN(NAME=~"inaudit.user_id~")WHERE(    EXP1 =~"inaudit.inaudit_date~"   OP =~">=~"    EXP2 =~":ad_date~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"inaudit.inaudit_item~"   OP =~"=~"    EXP2 =~":as_item~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"inaudit.qa~"   OP =~"=~"    EXP2 =~":as_qa~" ) ) ARG(NAME = ~"ad_date~" TYPE = date)  ARG(NAME = ~"as_item~" TYPE = string)  ARG(NAME = ~"as_qa~" TYPE = string) " update="inaudit" updatewhere=1 updatekeyinplace=no arguments=(("ad_date", date),("as_item", string),("as_qa", string))  sort="inaudit_date A inaudit_time A loc_no A " )
