table(column=(type=char(5) updatewhereclause=yes name=team_code dbname="team.team_code" )
 column=(type=char(30) updatewhereclause=yes name=team_name dbname="team.team_name" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"team~" ) COLUMN(NAME=~"team.team_code~") COLUMN(NAME=~"team.team_name~")WHERE(    EXP1 =~"team.parent_code~"   OP =~"=~"    EXP2 =~":as_team~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"team.team_code~"   OP =~"<>~"    EXP2 =~"'00000'~" ) ) ARG(NAME = ~"as_team~" TYPE = string) " arguments=(("as_team", string)) )
data(null null ) 
