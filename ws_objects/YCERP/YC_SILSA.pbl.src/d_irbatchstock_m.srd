release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=loc_no dbname="loc_no" )
 column=(type=char(10) updatewhereclause=yes name=batchdate dbname="batchdate" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(8) updatewhereclause=yes name=cat dbname="cat" )
 column=(type=decimal(4) updatewhereclause=yes name=make_qty dbname="make_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=ship_qty dbname="ship_qty" )
 column=(type=long updatewhereclause=yes name=ret_qty dbname="ret_qty" )
 column=(type=long updatewhereclause=yes name=etc_qty dbname="etc_qty" )
 column=(type=char(20) updatewhereclause=yes name=sno dbname="sno" )
 retrieve=" SELECT loc_no     = a.loc_no
      , batchdate  = a.batchdate

      , item_no      = (case when a.item_no = 'GAZSMCBB00' then 'GAZSCTBB00' else a.item_no end) /* MINOR CHANNEL CLIP BEES => C/T CLIP 피스 */ 
      , item_name    = (case when g.item_name = 'MINOR CHANNEL CLIP BEES' then 'C/T CLIP 피스' else g.item_name end)

      , qa         = a.qa
      , cat        = a.cat
      , make_qty   = a.make_qty
      , ship_qty   = a.ship_qty
      , ret_qty    = a.ret_qty 
      , etc_qty    = a.etc_qty 
      , sno        = a.sno
   FROM (
        /*===================================================*/
        /* 입고 */
        /*===================================================*/
        SELECT cat        = '생산입고'
             , loc_no     = s.loc_no
             , batchdate  = convert(char(10), s.sfc_date, 111)
             , item_no    = s.assembly
             , qa         = s.assembly_qa
             , before_qty = 0
             , make_qty   = s.make_qty
             , ship_qty   = 0
             , ret_qty    = 0
             , etc_qty    = 0
             , sno        = s.order_no
          FROM sfcday S with(nolock)
               LEFT OUTER JOIN wc W with(nolock) ON s.wc_no   = w.work_no
         WHERE s.loc_no    = :as_locno
           AND s.sfc_date  between :as_sdate + ' 00:00:00.000' AND :as_sdate + ' 23:59:59.999'

        UNION ALL

        SELECT cat        = '구매입고'
             , loc_no     = d.loc_no
             , batchdate  = convert(char(10),h.insp_date,111)
             , item_no    = (case when d.item_no = 'GAZSMCBB00' then 'GAZSCTBB00' else d.item_no end)
             , qa         = d.qa     
             , before_qty = 0
             , make_qty   = isnull(d.rcpt_qty, 0)
             , ship_qty   = 0
             , ret_qty    = 0
             , etc_qty    = 0
             , sno        = d.insp_no
          FROM inspdet D with(nolock)
               LEFT OUTER JOIN insp  H with(nolock) ON d.insp_no = h.insp_no
         WHERE d.loc_no   = :as_locno              
           AND h.insp_date = :as_sdate + ' 00:00:00.000'
           
        UNION ALL
        
        SELECT cat        = '요청입고'
             , loc_no     = b.ask_loc   
             , rlse_date  = convert(char(10),a.rlse_date,111)   
             , item_no    = (case when a.item_no = 'GAZSMCBB00' then 'GAZSCTBB00' else a.item_no end)
             , qa         = a.qa   
             , before_qty = 0
             , rcpt_qty   = a.rlse_qty  
             , issue_qty  = 0
             , ret_qty    = 0
             , etc_qty    = 0
             , sno        = a.ask_no
          FROM ask_det A with(nolock)
               LEFT OUTER JOIN ask_head B  with(nolock) ON a.ask_no = b.ask_no
         WHERE b.ask_loc  = :as_locno
           AND a.rlse_date  between :as_sdate + ' 00:00:00.000' AND :as_sdate + ' 23:59:59.999'

        UNION ALL
        
        SELECT cat        = '대체입고'
             , loc_no     = d.tar_loc
             , alter_date = convert(char(10),d.alter_date,111)
             , item_no    = (case when d.tar_item = 'GAZSMCBB00' then 'GAZSCTBB00' else d.tar_item end)
             , qa         = d.tar_qa   
             , before_qty = 0
             , rcpt_qty   = isnull(d.tar_qty, 0)
             , issue_qty  = 0
             , ret_qty    = 0
             , etc_qty    = 0
             , sno        = convert(char(20),d.alter_time,120)
          FROM itemalter D with(nolock)
         WHERE d.alter_date  = :as_sdate + ' 00:00:00'
           AND d.tar_loc   = :as_locno
        
        UNION ALL

        SELECT cat        = '이동입고'
             , loc_no     = b.tar_loc
             , move_date  = convert(char(10),b.move_date,111)
             , item_no    = (case when a.item_no = 'GAZSMCBB00' then 'GAZSCTBB00' else a.item_no end)
             , qa         = a.qa
             , before_qty = 0
             , rcpt_qty   = a.move_qty
             , issue_qty  = 0
             , ret_qty    = 0
             , etc_qty    = 0
             , sno        = a.move_no
          FROM itemmovedet A WITH (NOLOCK)
               LEFT OUTER JOIN itemmove B ON a.move_no = b.move_no
         WHERE b.tar_loc  = :as_locno
           AND b.move_date between :as_sdate + ' 00:00:00.000' AND :as_sdate + ' 23:59:59.999'                  
        
        /*===================================================*/
        /* 출고 */
        /*===================================================*/
        UNION ALL

        SELECT cat        = (case when b.ewol     = 'Y' then '이월출고'
                                  when a.ship_qty < 0   then '반품정리'
                                  else '정상출고'
                             end)
             , loc_no     = a.loc_no
             , do_date    = convert(char(10),b.do_date,111)
             , item_no    = (case when a.item_no = 'GAZSMCBB00' then 'GAZSCTBB00' else a.item_no end)
             , qa         = a.qa      
             , before_qty = 0
             , make_qty   = 0
             , ship_qty   = a.ship_qty
             , ret_qty    = 0
             , etc_qty    = 0
             , sno        = a.do_no
          FROM dodet A with(nolock)
               LEFT OUTER JOIN do  B with(nolock) ON a.do_no   = b.do_no
         WHERE a.loc_no   = :as_locno
           AND b.do_date  = :as_sdate + ' 00:00:00.000'
        
        UNION ALL
        
        SELECT cat        = '요청출고'
             , loc_no     = a.loc_no   
             , rlse_date  = convert(char(10),a.rlse_date,111)   
             , item_no    = (case when a.item_no = 'GAZSMCBB00' then 'GAZSCTBB00' else a.item_no end)
             , qa         = a.qa   
             , before_qty = 0
             , rcpt_qty   = 0   
             , issue_qty  = a.rlse_qty
             , ret_qty    = 0
             , etc_qty    = 0
             , sno        = a.ask_no
          FROM ask_det A with(nolock)
               LEFT OUTER JOIN ask_head B with(nolock) ON a.ask_no = b.ask_no
         WHERE a.loc_no   = :as_locno
           AND a.rlse_date  between :as_sdate + ' 00:00:00.000' AND :as_sdate + ' 23:59:59.999'

        UNION ALL

        SELECT cat        = '대체출고'
             , loc_no     = d.src_loc
             , alter_date = convert(char(10),d.alter_date,111)
             , item_no    = (case when d.src_item = 'GAZSMCBB00' then 'GAZSCTBB00' else d.src_item end)
             , qa         = d.src_qa   
             , before_qty = 0
             , rcpt_qty   = 0   
             , issue_qty  = isnull(d.src_qty, 0)
             , ret_qty    = 0
             , etc_qty    = 0
             , sno        = convert(char(20),d.alter_time,120)
          FROM itemalter D with(nolock)
         WHERE d.alter_date  = :as_sdate + ' 00:00:00'
           AND d.issue_flag  = 'Y'
           AND d.src_loc     = :as_locno

        UNION ALL

        SELECT cat        = '이동출고'
             , loc_no     = b.src_loc                                          
             , move_date  = convert(char(10),b.move_date,111)                 
             , item_no    = (case when a.item_no = 'GAZSMCBB00' then 'GAZSCTBB00' else a.item_no end)
             , qa         = a.qa                                              
             , before_qty = 0
             , rcpt_qty   = 0   
             , issue_qty  = a.move_qty                                        
             , ret_qty    = 0
             , etc_qty    = 0
             , sno        = a.move_no
          FROM itemmovedet A WITH (NOLOCK)                                      
               LEFT OUTER JOIN itemmove B WITH (NOLOCK) ON a.move_no = b.move_no
         WHERE b.src_loc   = :as_locno                                         
           AND b.move_date between :as_sdate + ' 00:00:00.000' AND :as_sdate + ' 23:59:59.999'                  
        ) A
          LEFT OUTER JOIN groupitem G  ON a.item_no = g.item_no
    WHERE a.loc_no    = :as_locno
      AND a.batchdate = :as_sdate
      AND a.item_no   = :as_itemno
      AND a.qa        = :as_qa
     " arguments=(("as_locno", string),("as_sdate", string),("as_itemno", string),("as_qa", string))  sort="item_name A qa A " )
