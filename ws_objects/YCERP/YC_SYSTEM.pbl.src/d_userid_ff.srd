table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=user_id dbname="login.user_id" )
 column=(type=char(8) update=yes updatewhereclause=yes name=password dbname="login.password" )
 column=(type=char(5) update=yes updatewhereclause=yes name=team_code dbname="login.team_code" )
 column=(type=char(20) update=yes updatewhereclause=yes name=rank dbname="login.rank" )
 column=(type=char(10) update=yes updatewhereclause=yes name=user_name dbname="login.user_name" )
 column=(type=char(30) update=yes updatewhereclause=yes name=rem dbname="login.rem" )
 column=(type=char(10) update=yes updatewhereclause=yes name=area_no dbname="login.area_no" )
 column=(type=datetime update=yes updatewhereclause=yes name=pwdchanged dbname="login.pwdchanged" )
 column=(type=char(1) update=yes updatewhereclause=yes name=sysmsg_yn dbname="sysmsg_yn" values="	Y/	N" )
 retrieve="SELECT 
	 login.user_id		user_id
	,login.password   password	
	,login.team_code  team_code 
	,login.rank   		rank
	,login.user_name  user_name	 
	,login.rem			rem   
	,login.area_no		area_no   	   
	,login.pwdchanged	pwdchanged
	,isnull(login.sysmsg_yn,'Y')	sysmsg_yn  
FROM 
	login  
WHERE 
	login.user_id like :as_userid    
" update="login" updatewhere=0 updatekeyinplace=no arguments=(("as_userid", string)) )
