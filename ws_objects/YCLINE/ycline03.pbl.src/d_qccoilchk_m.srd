 retrieve="  SELECT area_no,   
         sfc_date,   
         wc_no,  
         EOS,   
         GR,   
         CB,   
         BR,
			SM,
			wname  
    FROM qccoilchk   
	where area_no = :as_area_no
     and sfc_Date = :adt_sfc_date" update="qccoilchk" updatewhere=0 updatekeyinplace=no arguments=(("as_area_no", string),("adt_sfc_date", date)) )
