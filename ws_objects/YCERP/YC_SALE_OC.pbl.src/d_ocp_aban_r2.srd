 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"itemaban~" )  TABLE(NAME=~"itemabandet~" )  TABLE(NAME=~"groupitem~" )  TABLE(NAME=~"area~" )  TABLE(NAME=~"location~" )  TABLE(NAME=~"login~" ALIAS=~"login_a~" )  TABLE(NAME=~"login~" ALIAS=~"login_b~" )  TABLE(NAME=~"login~" ALIAS=~"login_c~" ) COLUMN(NAME=~"itemaban.aban_no~") COLUMN(NAME=~"itemaban.aban_date~") COLUMN(NAME=~"itemaban.user_date~") COLUMN(NAME=~"itemaban.rem~") COLUMN(NAME=~"itemaban.process_flag~") COLUMN(NAME=~"itemabandet.seq~") COLUMN(NAME=~"itemabandet.item_no~") COLUMN(NAME=~"itemabandet.qa~") COLUMN(NAME=~"itemabandet.qty~") COLUMN(NAME=~"itemabandet.price~") COLUMN(NAME=~"itemabandet.amount~") COLUMN(NAME=~"itemabandet.bigo~") COLUMN(NAME=~"groupitem.item_name~") COLUMN(NAME=~"groupitem.uom~") COLUMN(NAME=~"area.area_name~") COLUMN(NAME=~"location.loc_name~") COLUMN(NAME=~"login_a.user_name~") COLUMN(NAME=~"login_b.user_name~") COLUMN(NAME=~"login_c.user_name~")    JOIN (LEFT=~"itemaban.approve_team~"    OP =~"=~"RIGHT=~"login_a.user_id~"    OUTER1 =~"itemaban.approve_team~" )    JOIN (LEFT=~"itemaban.approve_top~"    OP =~"=~"RIGHT=~"login_b.user_id~"    OUTER1 =~"itemaban.approve_top~" )    JOIN (LEFT=~"itemaban.user_id~"    OP =~"=~"RIGHT=~"login_c.user_id~"    OUTER1 =~"itemaban.user_id~" )   JOIN (LEFT=~"itemaban.aban_no~"    OP =~"=~"RIGHT=~"itemabandet.aban_no~" )    JOIN (LEFT=~"itemabandet.item_no~"    OP =~"=~"RIGHT=~"groupitem.item_no~" )    JOIN (LEFT=~"itemaban.area_no~"    OP =~"=~"RIGHT=~"area.area_no~" )    JOIN (LEFT=~"itemaban.loc_no~"    OP =~"=~"RIGHT=~"location.loc_no~" ) WHERE(    EXP1 =~"itemaban.aban_no~"   OP =~"=~"    EXP2 =~":as_aban~" ) ) ARG(NAME = ~"as_aban~" TYPE = string) " arguments=(("as_aban", string))  sort="itemabandet_seq A " )
