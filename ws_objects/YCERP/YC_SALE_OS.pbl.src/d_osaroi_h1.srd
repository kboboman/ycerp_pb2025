table(column=(type=char(14) updatewhereclause=yes key=yes name=do_no dbname="do.do_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=invoice_print dbname="do.invoice_print" )
 retrieve="PBSELECT( VERSION(400) DISTINCT ()TABLE(NAME=~"do~" )  TABLE(NAME=~"dodet~" ) COLUMN(NAME=~"do.do_no~") COLUMN(NAME=~"do.invoice_print~")    JOIN (LEFT=~"do.do_no~"    OP =~"=~"RIGHT=~"dodet.do_no~" )WHERE(    EXP1 =~"do.cust_no~"   OP =~"=~"    EXP2 =~":as_cust~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"do.do_date~"   OP =~">=~"    EXP2 =~":ad_sdate~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"do.do_date~"   OP =~"<=~"    EXP2 =~":ad_edate~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"dodet.ship_qty~"   OP =~"<>~"    EXP2 =~"dodet.aroi_qty~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"do.sale_flag~"   OP =~"=~"    EXP2 =~":as_sale_flag~" ) ) ARG(NAME = ~"as_cust~" TYPE = string)  ARG(NAME = ~"ad_sdate~" TYPE = date)  ARG(NAME = ~"ad_edate~" TYPE = date)  ARG(NAME = ~"as_sale_flag~" TYPE = string) " update="do" updatewhere=0 updatekeyinplace=yes arguments=(("as_cust", string),("ad_sdate", date),("ad_edate", date),("as_sale_flag", string)) )
column(band=detail id=1 alignment="0" tabsequence=32766 border="2" color="0" x="9" y="4" height="60" width="480" format="[general]"  name=do_no  tag="출고번호" edit.limit=14 edit.case=any edit.autoselect=yes edit.autohscroll=yes  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
column(band=detail id=2 alignment="0" tabsequence=32766 border="2" color="0" x="503" y="4" height="60" width="384" format="[general]"  name=invoice_print  tag="매출유무" edit.limit=1 edit.case=any edit.autoselect=yes edit.autohscroll=yes  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
