integer x = 32
integer y = 424
integer width = 1938
integer height = 888
integer taborder = 110
string dataobject = "d_whpur_s"
boolean hscrollbar = true
boolean livescroll = false
end type

event dw_2::rowfocuschanged;//
string ls_orderno, ls_subcon

if this.getrow() < 1 then RETURN

//cbx_danga.checked = false 

ls_orderno    = trim(this.object.order_no[this.getrow()])
dw_1.retrieve( ls_orderno )

if dw_1.rowcount() > 0 then
	dw_1.object.subcon.protect = true

	ls_subcon = dw_1.object.subcon[1]	
	choose case ls_subcon
		case "C"
			dw3.dataobject = 'd_ippurdet2'
		case else
			dw3.dataobject = 'd_ippurdet'
	end choose
	
	dw3.SetTransObject(sqlca)	
	dw3.retrieve( ls_orderno )
end if

dw_14.retrieve( ls_orderno )

end event

event dw_2::retrieveend;//
string ls_orderno, ls_subcon

if this.getrow() < 1 then return

if this.rowcount() = 1 then 
	ls_orderno = trim(this.object.order_no[this.getrow()])
	if dw_1.retrieve( ls_orderno ) > 0 then
		dw_1.object.subcon.protect = true
	end if
	
	ls_subcon = dw_1.object.subcon[1]	// 발주구분
	choose case ls_subcon
		case "C"		// 외주스리팅/SHEET
			dw3.dataobject = 'd_ippurdet2'
		case else
			dw3.dataobject = 'd_ippurdet'
	end choose
	
	dw3.settransobject(sqlca)
	dw3.retrieve( ls_orderno )
end if

end event

event dw_2::clicked;call super::clicked;//
