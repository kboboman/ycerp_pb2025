$PBExportHeader$d_cdsheet_os_c.srd
$PBExportComments$SHEET리스트(open_close ='O' and 'S')(2002/01/03,이인호)
release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=sheet_no dbname="sheetmst.sheet_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="sheetmst.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="sheetmst.qa" )
 column=(type=char(10) updatewhereclause=yes name=loc_no dbname="sheetmst.loc_no" )
 column=(type=long updatewhereclause=yes name=qcnt dbname="sheetmst.qcnt" )
 column=(type=decimal(4) updatewhereclause=yes name=unit_qty dbname="sheetmst.unit_qty" )
 column=(type=char(30) updatewhereclause=yes name=loc_name dbname="location.loc_name" )
 column=(type=char(1) updatewhereclause=yes name=open_close dbname="sheetmst.open_close" values="재고	O/외주	S/" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"location~" )  TABLE(NAME=~"sheetmst~" ) COLUMN(NAME=~"sheetmst.sheet_no~") COLUMN(NAME=~"sheetmst.item_no~") COLUMN(NAME=~"sheetmst.qa~") COLUMN(NAME=~"sheetmst.loc_no~") COLUMN(NAME=~"sheetmst.qcnt~") COLUMN(NAME=~"sheetmst.unit_qty~") COLUMN(NAME=~"location.loc_name~") COLUMN(NAME=~"sheetmst.open_close~")    JOIN (LEFT=~"sheetmst.loc_no~"    OP =~"=~"RIGHT=~"location.loc_no~" )WHERE(    EXP1 =~"sheetmst.open_close~"   OP =~"=~"    EXP2 =~"~~~"O~~~"~"    LOGIC =~"or~" ) WHERE(    EXP1 =~"sheetmst.open_close~"   OP =~"=~"    EXP2 =~"~~~"S~~~"~" ) ) " )
