 column=(type=datetime update=yes updatewhereclause=yes name=issue_date dbname="sudodet.issue_date" initial="0" )
 column=(type=char(1) update=yes updatewhereclause=yes name=sudo_type dbname="sudodet.sudo_type" initial="A" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=out_qty dbname="sudodet.out_qty" )
 column=(type=long update=yes updatewhereclause=yes name=operation dbname="sudodet.operation" )
 column=(type=char(14) update=yes updatewhereclause=yes name=sudodet_sale_no dbname="sudodet.sale_no" )
 column=(type=long update=yes updatewhereclause=yes name=sudodet_seq_no dbname="sudodet.seq_no" )
 column=(type=char(50) update=yes updatewhereclause=yes name=rem dbname="sudodet.rem" )
 column=(type=char(4) update=yes updatewhereclause=yes name=sudodet_color dbname="sudodet.color" )
 column=(type=char(1) update=yes updatewhereclause=yes name=sudodet_out_type dbname="sudodet.out_type" )
 column=(type=char(10) update=yes updatewhereclause=yes name=issue_loc dbname="sudodet.issue_loc" )
 column=(type=char(20) update=yes updatewhereclause=yes name=issue_lot dbname="sudodet.issue_lot" )
 column=(type=char(10) update=yes updatewhereclause=yes name=area_no dbname="sudodet.area_no" )
 column=(type=char(60) updatewhereclause=yes name=itemname1 dbname="GroupItem.item_name" )
 column=(type=char(60) updatewhereclause=yes name=itemname2 dbname="GroupItem.item_name" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="cust_name" )
 retrieve="  SELECT DISTINCT groupitem_a.uom,   
         sudodet.order_no,   
         sudodet.wc_no,   
         sudodet.item_no,   
         sudodet.qa,   
         sudodet.due_date,   
         sudodet.rcpt_qty,   
         sudodet.component,   
         sudodet.component_qa,   
         sudodet.comp_uom,   
         sudodet.plan_qty,   
         sudodet.issue_qty,   
         sudodet.issue_date,   
         sudodet.sudo_type,   
         sudodet.out_qty,   
         sudodet.operation,   
         sudodet.sale_no,   
         sudodet.seq_no,   
         sudodet.rem,   
         sudodet.color,   
         sudodet.out_type,   
         sudodet.issue_loc,   
         sudodet.issue_lot,   
         sudodet.area_no,   
         groupitem_a.item_name,   
         groupitem_b.item_name,   
         cust_name = dbo.uf_getcustname(sudodet.sale_no) 
    FROM sudodet left outer join  groupitem groupitem_a on sudodet.item_no = groupitem_a.item_no
					    left outer join 	 groupitem groupitem_b on sudodet.component = groupitem_b.item_no
         				    left outer join sale  on sudodet.sale_no = sale.order_no
   WHERE ( 
				( sudodet.sudo_type in ('A') ) AND  
/*         			( sale.open_close <> 'C' )		 한도초과 */
         			( sale.open_close = 'O' )
			    ) and   
		         ( sudodet.area_no = :as_area ) 
/*
    FROM sudodet,   
         groupitem groupitem_a,   
         groupitem groupitem_b,   
         sale  
   WHERE ( sudodet.item_no *= groupitem_a.item_no) and  
         ( sudodet.component *= groupitem_b.item_no) and  
         ( sudodet.sale_no *= sale.order_no ) and  
         ( ( sudodet.sudo_type in ('A') ) AND  
         ( sale.open_close <> 'C' ) ) and   
         ( sudodet.area_no = :as_area ) 
*/
" update="sudodet" updatewhere=0 updatekeyinplace=yes arguments=(("as_area", string)) )
