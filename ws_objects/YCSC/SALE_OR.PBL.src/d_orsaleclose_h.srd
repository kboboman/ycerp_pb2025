release 6;
datawindow(units=0 timer_interval=0 color=79219928 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=char(14) update=yes updatewhereclause=yes key=yes name=order_no dbname="sale.order_no" initial=" " )
 column=(type=char(1) update=yes updatewhereclause=yes name=open_close dbname="sale.open_close" initial=" " )
 column=(type=char(1) update=yes updatewhereclause=yes name=close_type dbname="sale.close_type" initial=" " )
 column=(type=datetime update=yes updatewhereclause=yes name=close_date dbname="sale.close_date" initial=" " )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"sale~" ) COLUMN(NAME=~"sale.order_no~") COLUMN(NAME=~"sale.open_close~") COLUMN(NAME=~"sale.close_type~") COLUMN(NAME=~"sale.close_date~")WHERE(    EXP1 =~"sale.order_date~"   OP =~"<=~"    EXP2 =~":econfirm_date~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"sale.confirm_flag~"   OP =~"=~"    EXP2 =~"'Y'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"sale.open_close~"   OP =~"=~"    EXP2 =~"'O'~" ) ) ARG(NAME = ~"econfirm_date~" TYPE = date) " update="sale" updatewhere=0 updatekeyinplace=no arguments=(("econfirm_date", date))  sort="order_no A " )
column(band=detail id=1 alignment="0" tabsequence=32766 border="2" color="0" x="9" y="4" height="60" width="448" format="[general]"  name=order_no  tag="판매주문번호" edit.limit=14 edit.case=any edit.autoselect=yes edit.autohscroll=yes edit.displayonly=yes  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="553648127" )
column(band=detail id=2 alignment="0" tabsequence=32766 border="0" color="0" x="457" y="0" height="60" width="32" format="[general]"  name=open_close edit.limit=0 edit.case=any edit.autoselect=yes  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="553648127" )
column(band=detail id=3 alignment="0" tabsequence=32766 border="0" color="0" x="489" y="0" height="60" width="32" format="[general]"  name=close_type edit.limit=0 edit.case=any edit.autoselect=yes  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="553648127" )
column(band=detail id=4 alignment="0" tabsequence=32766 border="0" color="0" x="521" y="0" height="60" width="955" format="[shortdate] [time]"  name=close_date editmask.mask="yyyy/mm/dd hh" editmask.focusrectangle=no  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="553648127" )
