table(column=(type=char(10) updatewhereclause=yes name=담당자 dbname="담당자" )
 column=(type=char(4) updatewhereclause=yes name=거래처 dbname="거래처" )
 column=(type=char(50) updatewhereclause=yes name=거래처명 dbname="거래처명" )
 column=(type=char(11) updatewhereclause=yes name=현장 dbname="현장" )
 column=(type=char(40) updatewhereclause=yes name=현장명 dbname="현장명" )
 column=(type=char(50) updatewhereclause=yes name=현장구분 dbname="현장구분" )
 column=(type=char(10) updatewhereclause=yes name=현장관리자 dbname="현장관리자" )
 column=(type=char(10) updatewhereclause=yes name=지역 dbname="지역" )
 column=(type=char(20) updatewhereclause=yes name=공사명 dbname="공사명" )
 column=(type=char(20) updatewhereclause=yes name=건설사 dbname="건설사" )
 column=(type=char(80) updatewhereclause=yes name=특기사항 dbname="특기사항" )
 column=(type=datetime updatewhereclause=yes name=공사시작 dbname="공사시작" )
 column=(type=datetime updatewhereclause=yes name=공사마감 dbname="공사마감" )
 column=(type=char(15) updatewhereclause=yes name=전화번호 dbname="전화번호" )
 column=(type=char(15) updatewhereclause=yes name=보조연락 dbname="보조연락" )
 column=(type=char(40) updatewhereclause=yes name=공사규모 dbname="공사규모" )
 column=(type=char(80) updatewhereclause=yes name=현장주소 dbname="현장주소" )
 column=(type=datetime updatewhereclause=yes name=입력일자 dbname="입력일자" )
 column=(type=datetime updatewhereclause=yes name=등록일자 dbname="등록일자" )
 column=(type=char(10) updatewhereclause=yes name=등록자 dbname="등록자" )
 retrieve="  SELECT '담당자'      = login.user_name
			 , '거래처'      = scene.cust_no   
			 , '거래처명'    = customer.cust_name   
			 , '현장'        = scene.scene_code   
			 , '현장명'      = scene.scene_desc   
			 , '현장구분'    = (  select a.item_nm
								    from codemst a
								  where a.type = '현장구분'
								      and a.use_yn = 'Y'
									 and a.item_cd = scene.gubun )
			 , '현장관리자'  = scene.scene_charge   
			 , '지역'        = scene.area_nm   
			 , '공사명'      = scene.project_nm   
			 , '건설사'      = scene.owner          
			 , '특기사항'    = isnull(scene.rem,'')   
			 , '공사시작'    = isnull(scene.start_date,'')   
			 , '공사마감'    = isnull(scene.end_date,'')   
			 , '전화번호'    = scene.scene_tel   
			 , '보조연락'    = scene.scene_telcap   
			 , '공사규모'    = isnull(scene.scene_scale,'')   
			 , '현장주소'    = isnull(scene.scene_addr,'')   
			 , '입력일자'    = scene.input_date  
			 , '등록일자'    = scene.gen_date  
			 , '등록자'      = l2.user_name 
    FROM scene
         LEFT OUTER JOIN customer ON scene.cust_no  = customer.cust_no
         LEFT OUTER JOIN login    ON customer.salesman = login.user_id
         LEFT OUTER JOIN login L2 ON scene.user_id  = l2.user_id
   WHERE ( scene.gen_date between :ad_sdate + ' 00:00:00' AND :ad_edate + ' 23:59:59' )
" arguments=(("ad_sdate", date),("ad_edate", date))  sort="거래처명 A 현장명 A " )
