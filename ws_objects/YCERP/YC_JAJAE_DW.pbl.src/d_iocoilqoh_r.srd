footer(height=80 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes key=yes name=coilmst_coil_no dbname="coilmst.coil_no" )
 column=(type=decimal(1) updatewhereclause=yes name=coilmst_wid dbname="coilmst.wid" )
 column=(type=char(10) updatewhereclause=yes name=coilmst_item_no dbname="coilmst.item_no" )
 column=(type=char(20) updatewhereclause=yes name=coilmst_qa dbname="coilmst.qa" )
 column=(type=char(10) updatewhereclause=yes key=yes name=coilmst_loc_no dbname="coilmst.loc_no" )
 column=(type=datetime updatewhereclause=yes name=coilmst_rcpt_date dbname="coilmst.rcpt_date" )
 column=(type=long updatewhereclause=yes name=coilmst_unit_qty dbname="coilmst.unit_qty" )
 column=(type=long updatewhereclause=yes name=coilmst_length dbname="coilmst.length" )
 column=(type=long updatewhereclause=yes name=coilmst_cnt dbname="coilmst.cnt" )
 column=(type=long updatewhereclause=yes name=coilmst_qcnt dbname="coilmst.qcnt" )
 column=(type=char(4) updatewhereclause=yes name=coilmst_color_no dbname="coilmst.color_no" )
 column=(type=char(10) updatewhereclause=yes name=coilmst_supp_no dbname="coilmst.supp_no" )
 column=(type=char(1) updatewhereclause=yes name=coilmst_flag dbname="coilmst.flag" values="원코일	W/스리팅	S/" )
 column=(type=char(14) updatewhereclause=yes name=coilmst_porder_no dbname="coilmst.porder_no" )
 column=(type=long updatewhereclause=yes name=coilmst_pseq_no dbname="coilmst.pseq_no" )
 column=(type=char(1) updatewhereclause=yes name=coilmst_open_close dbname="coilmst.open_close" values="재고	O/계획	M/작업지시	P/외주가공	S/사용완료	C/" )
 column=(type=char(40) updatewhereclause=yes name=coilmst_rem dbname="coilmst.rem" )
 column=(type=char(1) update=yes updatewhereclause=yes name=long_stock_yn dbname="coilmst.long_stock_yn" values="	Y/	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=use_yn dbname="use_yn" values="	Y/	N" )
 column=(type=char(20) updatewhereclause=yes name=pcoil_no dbname="pcoil_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=char(30) updatewhereclause=yes name=groupitem_loc_name dbname="GroupItem.loc_name" )
 column=(type=char(30) updatewhereclause=yes name=location_supp_name dbname="coilmst.supp_name" )
 column=(type=char(2) updatewhereclause=yes name=supp_etc_no dbname="supp.etc_no" )
 column=(type=decimal(4) updatewhereclause=yes name=coilmst_price dbname="coilmst.price" )
 column=(type=decimal(4) updatewhereclause=yes name=inspdet_unit_qty dbname="inspdet.unit_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=inspdet_comqty dbname="inspdet.comqty" )
 column=(type=char(3) updatewhereclause=yes name=inspdet_coil_grp dbname="inspdet.coil_grp" )
 column=(type=char(1) updatewhereclause=yes name=groupitem_pcoil_supp_name dbname="GroupItem.pcoil_supp_name" )
 retrieve="  SELECT coilmst.coil_no     
       , coilmst.wid         
       , coilmst.item_no     
       , coilmst.qa          
       , coilmst.loc_no      
       , coilmst.rcpt_date   
       , coilmst.unit_qty    
       , coilmst.length      
       , coilmst.cnt         
       , coilmst.qcnt        
       , coilmst.color_no    
       , coilmst.supp_no     
       , coilmst.flag        
       , coilmst.porder_no   
       , coilmst.pseq_no     
       , coilmst.open_close  
       , coilmst.rem         
       , coilmst.long_stock_yn
       , coilmst.use_yn
/*       , ( case when coilmst.pcoil_no = '원코일' then '' 
                    when coilmst.pcoil_no = '구매입고' then '' 
	      else coilmst.pcoil_no end ) pcoil_no*/
	  , dbo.uf_pcoil_no(coilmst.coil_no) pcoil_no				
       , groupitem.item_name 
       , location.loc_name   
       , supp.supp_name      
       , coilmst.etc_no      
       , inspdet.price       
       , inspdet.unit_qty
       , inspdet.comqty
       , groupitem.coil_grp
       , '' pcoil_supp_name 
    FROM coilmst with(nolock)  
         INNER JOIN groupitem with(nolock) ON coilmst.item_no = groupitem.item_no
/*         INNER JOIN location with(nolock)  ON coilmst.loc_no  = location.loc_no*/
	 INNER JOIN (
		
							  SELECT A.LOC_NO, A.LOC_NAME
							  FROM
							  (
											SELECT :as_loc GUBUN, 'N' WORK_CHK, 'N' STOCK_CHK, LOC_NO, LOC_NAME FROM LOCATION
											WHERE RTRIM(LTRIM(LOC_NO)) LIKE :as_loc
											UNION ALL
											SELECT :as_loc GUBUN, 'Y' WORK_CHK, :as_stock_chk STOCK_CHK,  LOC_NO, LOC_NAME FROM LOCATION
											WHERE LOC_NO <> 'WW01'
												 AND RTRIM(LTRIM(LOC_NO)) LIKE :as_loc                          
											UNION ALL
											SELECT 'WW01' GUBUN, 'Y' WORK_CHK, :as_stock_chk STOCK_CHK,  LOC_NO, LOC_NAME FROM LOCATION
											WHERE LOC_NO = 'WW01'                
											UNION ALL
											SELECT 'WW01' GUBUN, 'Y' WORK_CHK, :as_stock_chk STOCK_CHK, LOC_NO, LOC_NAME FROM LOCATION
											WHERE LOC_TYPE = 'W'
											UNION ALL
											SELECT :as_loc GUBUN,  :as_work_chk  WORK_CHK, 'Y' STOCK_CHK,  LOC_NO, LOC_NAME FROM LOCATION
											WHERE LOC_NO <> 'WW01'
												 AND RTRIM(LTRIM(LOC_NO)) LIKE :as_loc                          
											UNION ALL
											SELECT 'WW01' GUBUN, :as_work_chk WORK_CHK, 'Y' STOCK_CHK,  LOC_NO, LOC_NAME FROM LOCATION
											WHERE LOC_NO = 'WW01'                
											UNION ALL
											SELECT 'WW01' GUBUN, :as_work_chk WORK_CHK, 'Y' STOCK_CHK,  LOC_NO, LOC_NAME FROM LOCATION
											WHERE LOC_NO = 'WS00000003'
							  ) A
							 WHERE A.GUBUN = :as_loc
									AND A.WORK_CHK = :as_work_chk
									AND A.STOCK_CHK = :as_stock_chk
				) location   ON coilmst.loc_no  = location.loc_no
         LEFT OUTER JOIN supp with(nolock)      ON coilmst.supp_no = supp.supp_no
         LEFT OUTER JOIN inspdet  with(nolock) ON coilmst.coil_no = inspdet.coil_no AND coilmst.item_no = inspdet.item_no	
   WHERE ( RTRIM(LTRIM(coilmst.item_no))    LIKE :as_item          )
     AND ( RTRIM(LTRIM(coilmst.flag))       LIKE :as_flag          )
     AND ( coilmst.open_close   IN ( :as_oc )        )
 /*    AND ( ( :as_work_chk  = 'N' AND :as_stock_chk  = 'N'  AND coilmst.loc_no  LIKE :as_loc )   
        OR ( :as_work_chk  = 'Y' AND ( ( :as_loc <> 'WW01' AND coilmst.loc_no  LIKE :as_loc ) OR
                                       ( :as_loc  = 'WW01' AND coilmst.loc_no  LIKE :as_loc OR ( coilmst.loc_no IN ( SELECT loc_no FROM location where  loc_type = 'W' ) ) ) 
                                     ) 
           ) 
        OR ( :as_stock_chk = 'Y' AND ( ( :as_loc <> 'WW01' AND coilmst.loc_no  LIKE :as_loc ) OR
                                       ( :as_loc  = 'WW01' AND coilmst.loc_no  LIKE :as_loc OR ( coilmst.loc_no = 'WS00000003' ) )
                                     ) 
           )
         )
*/				
    AND ( RTRIM(LTRIM(groupitem.coil_grp)) LIKE :as_coil )	
/*
     AND ((:as_coil  = '%' AND groupitem.coil_grp LIKE :as_coil ) OR
          (:as_coil <> '%' AND groupitem.coil_grp    = :as_coil )
         )	
*/
     AND ( NOT EXISTS ( SELECT * FROM lossitem WHERE loss_item = coilmst.item_no ) )
/*
    FROM coilmst             
       , groupitem           
       , location            
       , supp                
       , inspdet             
   WHERE ( coilmst.item_no       = groupitem.item_no )
     AND ( coilmst.loc_no        = location.loc_no   )
     AND ( coilmst.supp_no      *= supp.supp_no      )
     AND ( coilmst.coil_no      *= inspdet.coil_no   )
     AND ( coilmst.item_no    LIKE :as_item          )
     AND ( coilmst.flag       LIKE :as_flag          )
     AND ( coilmst.open_close   IN ( :as_oc )        )
     AND ( ( :as_work_chk  = 'N' AND :as_stock_chk  = 'N'  AND coilmst.loc_no  LIKE :as_loc )   
        OR ( :as_work_chk  = 'Y' AND ( ( :as_loc <> 'WW01' AND coilmst.loc_no  LIKE :as_loc ) OR
                                       ( :as_loc  = 'WW01' AND coilmst.loc_no  LIKE :as_loc OR ( coilmst.loc_no IN ( SELECT loc_no FROM location where  loc_type = 'W' ) ) ) 
                                     ) 
           ) 
        OR ( :as_stock_chk = 'Y' AND ( ( :as_loc <> 'WW01' AND coilmst.loc_no  LIKE :as_loc ) OR
                                       ( :as_loc  = 'WW01' AND coilmst.loc_no  LIKE :as_loc OR ( coilmst.loc_no = 'WS00000003' ) )
                                     ) 
           )
         )
     AND ((:as_coil  = '%' AND groupitem.coil_grp LIKE :as_coil ) OR
          (:as_coil <> '%' AND groupitem.coil_grp    = :as_coil )
         )
     AND ( NOT EXISTS ( SELECT * FROM lossitem WHERE loss_item = coilmst.item_no ) )
*/" update="coilmst" updatewhere=0 updatekeyinplace=no arguments=(("as_coil", string),("as_loc", string),("as_item", string),("as_flag", string),("as_oc", stringlist),("as_work_chk", string),("as_stock_chk", string))  sort="mid(coilmst_item_no,3,1) A coilmst_item_no A coilmst_qa A coilmst_unit_qty A coilmst_coil_no A coilmst_loc_no A " )
group(level=1 header.height=0 trailer.height=72 by=("mid(coilmst_item_no,3,1) + mid(coilmst_item_no,2,1)" ) header.color="536870912" trailer.color="15780518" )
group(level=2 header.height=0 trailer.height=68 by=("coilmst_item_no" ) header.color="536870912" trailer.color="12639424" )
