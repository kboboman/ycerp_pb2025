table(column=(type=char(10) updatewhereclause=yes name=inaudit_loc_no dbname="inaudit.loc_no" )
 column=(type=char(30) updatewhereclause=yes name=location_loc_name dbname="location.loc_name" )
 column=(type=char(2) updatewhereclause=yes name=inaudit_inaudit_type dbname="inaudit.inaudit_type" )
 column=(type=char(20) updatewhereclause=yes name=iotype_remarks dbname="iotype.remarks" )
