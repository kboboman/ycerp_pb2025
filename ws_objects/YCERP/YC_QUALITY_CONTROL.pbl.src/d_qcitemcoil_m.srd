$PBExportHeader$d_qcitemcoil_m.srd
$PBExportComments$품목별코일규격관리(2005/06/09, 이인호)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="itemcoil.item_no" )
 column=(type=char(1) updatewhereclause=yes name=use_flag dbname="use_flag" values="가능	Y/불가	C/" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=qa dbname="itemcoil.qa" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=seq_no dbname="itemcoil.seq_no" initial="0" )
 column=(type=char(10) update=yes updatewhereclause=yes name=coil_item dbname="itemcoil.coil_item" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=thick dbname="itemcoil.thick" initial="0.00" )
 column=(type=decimal(1) update=yes updatewhereclause=yes name=width dbname="itemcoil.width" initial="0" )
 column=(type=decimal(3) update=yes updatewhereclause=yes name=weight dbname="itemcoil.weight" )
 column=(type=char(1) update=yes updatewhereclause=yes name=wc_place dbname="itemcoil.wc_place" values="사내	I/외주	O/" )
 column=(type=char(10) update=yes updatewhereclause=yes name=supp_no dbname="itemcoil.supp_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=rem1 dbname="itemcoil.rem1" )
 column=(type=char(50) update=yes updatewhereclause=yes name=rem2 dbname="itemcoil.rem2" )
 retrieve="  SELECT itemcoil.item_no
       , use_flag   = g.use_flag     
       , item_name  = g.item_name
       , itemcoil.qa          
       , itemcoil.seq_no      
       , itemcoil.coil_item   
       , itemcoil.thick       
       , itemcoil.width       
       , itemcoil.weight       
       , itemcoil.wc_place    
       , itemcoil.supp_no     
       , itemcoil.rem1        
       , itemcoil.rem2  
    FROM itemcoil
         LEFT OUTER JOIN groupitem G ON itemcoil.item_no = g.item_no" update="itemcoil" updatewhere=0 updatekeyinplace=no  sort="use_flag D item_name A qa A seq_no A " )
