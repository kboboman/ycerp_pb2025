summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=sale_cust_no dbname="sale.cust_no" )
 column=(type=char(7) updatewhereclause=yes name=order_date dbname="order_date" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name dbname="login.user_name" )
 column=(type=char(10) updatewhereclause=yes name=sale_salesman dbname="sale.salesman" )
 retrieve="SELECT DISTINCT a.cust_no
     , order_date = convert(char(7), a.order_date,111)
     , b.user_name 
     , a.salesman
  FROM SALE a
       LEFT OUTER JOIN LOGIN b  ON a.salesman = b.user_id
 WHERE a.cust_no  = :as_custno
 ORDER BY order_date desc
" arguments=(("as_custno", string)) )
