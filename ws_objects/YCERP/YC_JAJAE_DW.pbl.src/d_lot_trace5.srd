table(column=(type=char(20) updatewhereclause=yes name=coil_no dbname="coil_no" )
 column=(type=char(13) update=yes updatewhereclause=yes name=move_no dbname="move_no" )
 column=(type=long update=yes updatewhereclause=yes name=seq dbname="seq" )
 column=(type=char(30) updatewhereclause=yes name=loc_name dbname="loc_name" )
 column=(type=datetime updatewhereclause=yes name=move_date dbname="move_date" )
 column=(type=char(20) update=yes updatewhereclause=yes name=lot_no dbname="lot_no" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=cnt dbname="cnt" initial="0" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="qa" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=move_qty dbname="move_qty" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 retrieve="  SELECT coil_no    = itemmovedet.lot_no
       , move_no    = itemmovedet.move_no    
       , seq        = itemmovedet.seq        
       , loc_name   = location.loc_name      
       , move_date  = itemmove.move_date     
       , lot_no     = itemmovedet.lot_no     
       , cnt        = itemmovedet.cnt        
       , item_name  = groupitem.item_name    
       , qa         = itemmovedet.qa         
       , move_qty   = itemmovedet.move_qty    
       , uom        = groupitem.uom          
    FROM itemmovedet 
         LEFT OUTER JOIN itemmove  ON itemmovedet.move_no = itemmove.move_no
         LEFT OUTER JOIN groupitem ON itemmovedet.item_no = groupitem.item_no
         LEFT OUTER JOIN location  ON itemmove.tar_loc    = location.loc_no
   WHERE itemmovedet.lot_no  = :as_lotno
   " arguments=(("as_lotno", string))  sort="seq A " )
