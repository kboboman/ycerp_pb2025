$PBExportHeader$d_osaroi_s.srd
$PBExportComments$매출관리 운송비선택 (199805/14, 정재수)
release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=char(12) update=yes updatewhereclause=yes name=do_inv_no dbname="do.inv_no" )
 column=(type=char(14) updatewhereclause=yes key=yes name=do_do_no dbname="do.do_no" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=ship_amount dbname="do.ship_amount" )
 column=(type=char(1) updatewhereclause=yes name=pick dbname="pick" values="	Y/	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=do_shipamt_case dbname="do.shipamt_case" initial="R" values="현금	C/외상	R/" )
 column=(type=decimal(0) updatewhereclause=yes name=calc_amt dbname="calc_amt" )
 retrieve="  SELECT DISTINCT do.inv_no
       , do.do_no
       , do.ship_amount
       , pick   = 'N'
       , do.shipamt_case  
       , calc_amt  = (case when do.shipamt_case = 'R' then do.ship_amount else 0 end)
    FROM dodet,   
         do  
   WHERE ( dodet.do_no = do.do_no ) and  
         ( ( do.cust_no = :as_cust_no ) AND  
         ( do.do_date >= :ad_sdate ) AND  
         ( do.do_date <= :ad_edate ) AND  
         ( do.inv_no is null ) AND  
         ( do.sale_flag = :as_sale_flag ) AND  
         ( do.ship_amount <> 0 ) AND  
         ( do.ship_flag = 'D' ) )    
" update="do" updatewhere=0 updatekeyinplace=yes arguments=(("as_cust_no", string),("ad_sdate", date),("ad_edate", date),("as_sale_flag", string)) )
