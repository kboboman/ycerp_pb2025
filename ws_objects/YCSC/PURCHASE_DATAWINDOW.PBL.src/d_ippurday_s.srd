table(column=(type=datetime updatewhereclause=yes name=inaudit_date dbname="inaudit.inaudit_date" )
 retrieve="PBSELECT( VERSION(400) DISTINCT ()TABLE(NAME=~"inaudit~" ) COLUMN(NAME=~"inaudit.inaudit_date~")WHERE(    EXP1 =~"inaudit.inaudit_date~"   OP =~"between~"    EXP2 =~":as_start and :as_end~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"inaudit.inaudit_type~"   OP =~"=~"    EXP2 =~"'RI'~" ) ) ORDER(NAME=~"inaudit.inaudit_date~" ASC=no) ARG(NAME = ~"as_start~" TYPE = date)  ARG(NAME = ~"as_end~" TYPE = date) " arguments=(("as_start", date),("as_end", date)) )
text(band=header alignment="2" text="입고 일자"border="0" color="0" x="5" y="4" height="61" width="321"  name=inaudit_date_t  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="-127" background.mode="2" background.color="15780518" )
column(band=detail id=1 alignment="0" tabsequence=32766 border="0" color="0" x="5" y="4" height="61" width="321" format="[shortdate] [time]"  name=inaudit_date  tag="입출고일자" accelerator=" " edit.name="ymd1" editmask.mask="yyyy/mm/dd" editmask.focusrectangle=no  font.face="굴림체" font.height="-10" font.weight="400"  font.family="2" font.pitch="2" font.charset="-127" background.mode="0" background.color="16777215~tif (getrow() = currentrow(), RGB(254,252,175), 78682240)" )
