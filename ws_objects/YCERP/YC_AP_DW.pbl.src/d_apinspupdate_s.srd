$PBExportComments$수정및삭제가능한입고번호(1998/5/21,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=67108864 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=84 color="536870912" )
summary(height=0 color="536870912" )
footer(height=84 color="8421504" )
detail(height=84 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes key=yes name=insp_no dbname="insp.insp_no" )
 column=(type=datetime updatewhereclause=yes name=insp_date dbname="insp.insp_date" )
 column=(type=char(1) updatewhereclause=yes name=invoice_print dbname="insp.invoice_print" )
 retrieve="  SELECT insp.insp_no
       , insp.insp_date
       , invoice_print
    FROM insp  
   WHERE ( insp.supp_no = :as_supp ) AND  
         ( insp.insp_date between :ad_start and :ad_end )  AND  
         ( ( insp.insp_no like :as_area + ~"%~" ) ) 
  
" update="insp" updatewhere=0 updatekeyinplace=no arguments=(("as_supp", string),("ad_start", date),("ad_end", date),("as_area", string))  sort="insp_no A " )
