event pb_delete::clicked;int li_index

li_index = tab_1.SelectedTab
choose case li_index
	case 1	// 작업일보대상항목
	case 2	// 작업일보등록
		dw4.deleterow(0)

	case 3	// 사용 자재등록
		dw5.deleterow(0)
		if dw5.getrow() < 1 then return
		dw5.triggerevent(rowfocuschanged!)

	case 4	// 자재반납
		dw6.deleterow(0)

	case 5	// 작업자투입
		dw9.deleterow(0)
//		// 작업자 투입현황 저장
//		if wf_update1(dw9,"N") = false then
//			MessageBox("확인","작업자 삭제중 오류가 발생했습니다.",exclamation!)
//		end if		  

	case 6	// 비 가동시간
end choose

end event

