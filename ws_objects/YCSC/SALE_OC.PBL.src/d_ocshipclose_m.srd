$PBExportComments$운반비마감관리 (2002/08/28,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="10789024" )
detail(height=80 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes key=yes name=do_do_no dbname="do.do_no" )
 column=(type=char(1) updatewhereclause=yes name=do_ship_flag dbname="do.ship_flag" values="착불	C/부담	B/대여	D/시화방문	M/화곡방문	H/반월방문	Y/공사원가	A/재료원가	R/" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=ship_amount dbname="do.ship_amount" )
 column=(type=char(12) updatewhereclause=yes name=do_driver dbname="do.driver" )
 column=(type=char(1) updatewhereclause=yes name=do_shipamt_case dbname="do.shipamt_case" values="현금	C/외상	R/" )
 column=(type=char(10) updatewhereclause=yes name=docar_name dbname="docar.name" )
 column=(type=char(40) updatewhereclause=yes name=docar_cargo_name dbname="docar.cargo_name" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 column=(type=char(1) update=yes updatewhereclause=yes name=ship_close dbname="do.ship_close" values="	C/	O" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=do_cash dbname="do.do_cash" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=do_rate dbname="do.do_rate" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=do_total dbname="do.do_total" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_cash dbname="do_do_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_rate dbname="do_do_rate" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_total dbname="do_do_total" )
 column=(type=datetime updatewhereclause=yes name=do_ship_date dbname="do.ship_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=close_user dbname="do.close_user" )
 column=(type=char(12) updatewhereclause=yes name=do_inv_no dbname="do.inv_no" )
 column=(type=char(10) updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=char(10) updatewhereclause=yes name=edate dbname="edate" )
 retrieve="  SELECT do.do_no             
       , do.ship_flag         
       , do.ship_amount       
       , do.driver            
       , do.shipamt_case      
       , docar.name            
       , docar.cargo_name     
       , customer.cust_name   
       , scene.scene_desc     
       , do.ship_close        
       , do.do_cash           
       , do.do_rate           
       , do.do_total       
       , do_do_cash  = do.do_cash - isnull(do.ship_amount, 0 )      
       , do_do_rate  = do.do_rate - isnull(do.ship_amount, 0 ) * 0.1
       , do_do_total = do.do_cash - isnull(do.ship_amount, 0 ) + (do.do_rate - isnull(do.ship_amount, 0) * 0.1)
       , do.ship_date    
       , do.close_user
       , do.inv_no    
       , sdate       = (case when :as_sdate = '' then '          ' else :as_sdate end)
       , edate       = (case when :as_edate = '' then '          ' else :as_edate end)
    FROM  do LEFT OUTER JOIN scene ON  do.spot_code   = scene.scene_code
                       LEFT OUTER JOIN docar ON  do.driver           = docar.driver
	                  INNER JOIN customer ON  do.cust_no  = customer.cust_no
   WHERE (( do.do_no         like :as_area + '%'        ) AND  
          ( convert(char(10),do.ship_date,111)  between :as_sdate and :as_edate ) AND  
          ( do.ship_flag       in ('D' , 'B' , 'A')     ) AND  
          ( do.ship_close       = :as_flag              ) 
         )    " update="do" updatewhere=0 updatekeyinplace=no arguments=(("as_area", string),("as_sdate", string),("as_edate", string),("as_flag", string))  sort="do_driver A do_ship_flag A do_do_no A docar_name A " )
