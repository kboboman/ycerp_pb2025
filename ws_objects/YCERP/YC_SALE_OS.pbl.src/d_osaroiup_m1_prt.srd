$PBExportComments$판매매출갱신 및 취소(1998/04/15, 정재수)
release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=80 color="536870912" )
summary(height=0 color="553648127" )
footer(height=80 color="553648127" )
detail(height=80 color="536870912" )
table(column=(type=char(12) update=yes updatewhereclause=yes key=yes name=aroiinv_no dbname="aroi.aroiinv_no" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=seq_no dbname="aroi.seq_no" )
 column=(type=char(14) update=yes updatewhereclause=yes name=do_no dbname="aroi.do_no" )
 column=(type=long update=yes updatewhereclause=yes name=oi_no dbname="aroi.oi_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="aroi.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="aroi.qa" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="aroi.uom" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=ship_qty dbname="aroi.ship_qty" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=price dbname="aroi.price" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=rate_cash dbname="aroi.rate_cash" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=ori_amount dbname="aroi.ori_amount" )
 column=(type=char(14) update=yes updatewhereclause=yes name=sale_no dbname="aroi.sale_no" )
 column=(type=char(30) update=yes updatewhereclause=yes name=rem dbname="aroi.rem" )
 column=(type=decimal(4) updatewhereclause=yes name=price_a dbname="a_price" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=decimal(2) updatewhereclause=yes name=a_qty dbname="a_qty" initial="0" )
 column=(type=long update=yes updatewhereclause=yes name=dc_rate dbname="aroi.dc_rate" )
 column=(type=long updatewhereclause=yes name=c_dc dbname="c_dc" )
 retrieve="  SELECT aroi.aroiinv_no,   
         aroi.seq_no,   
         aroi.do_no,   
         aroi.oi_no,   
         aroi.item_no,   
         aroi.qa,   
         aroi.uom,   
         aroi.ship_qty,   
         aroi.price,   
         aroi.rate_cash,   
         aroi.ori_amount,   
         aroi.sale_no,   
         aroi.rem,   
         a_price  = itemcost.price,   
         groupitem.item_name,   
         a_qty = aroi.ship_qty,   
         aroi.dc_rate,   
         00 c_dc
    FROM groupitem,   
         aroi,   
         itemcost  
   WHERE ( aroi.item_no = itemcost.item_no ) and  
         ( ( aroi.aroiinv_no = :as_aroiinv_no ) )    
			and aroi.item_no = groupitem.item_no
			and aroi.item_no = itemcost.item_no
			and (case when groupitem.uom = ~"M~" then substring(aroi.qa, 1, 13) 
						 when groupitem.uom = ~"M2~" then substring(aroi.qa, 1, 3) 
						 else aroi.qa end) = itemcost.qa" update="aroi" updatewhere=0 updatekeyinplace=no arguments=(("as_aroiinv_no", string))  sort="seq_no A " )
