compute(band=detail alignment="0" expression="if( saledet_uom ='M2' or trim( saledet_uom) = 'M', 'EA',  saledet_uom )"border="0" color="0" x="3863" y="4" height="60" width="142" format="[general]" html.valueishtml="0"  name=compute_1 visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="16777215" )
compute(band=detail alignment="1" expression=" saledet_order_qty  -  saledet_rlse_qty "border="0" color="0" x="5874" y="4" height="60" width="425" format="#,##0.00" html.valueishtml="0"  name=bal_qty visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="16777215" )
compute(band=detail alignment="1" expression="if(left(  saledet_item_no ,1) = 'P' and mid(  saledet_item_no , 3,1) = 'Y' and (mid(  saledet_item_no , 7,1) = 'A' or mid(  saledet_item_no , 7,1) = 'B' or mid(  saledet_item_no , 7,1) = 'C' or mid(  saledet_item_no , 7,1) = 'D' or left(saledet_item_no, 5) = 'PCYSZ'),   bal_qty , if(  saledet_uom = 'M2' or saledet_uom = 'SS' ,truncate( long(mid(   saledet_qa ,5,4)) * long(mid(   saledet_qa ,10,4)) *      bal_qty / 1000000, 2), if(  saledet_uom = 'M', if ( bal_qty < 0 , truncate(long(mid(  saledet_qa , 15,5)) *   bal_qty / 1000 - 0.00001,2),   truncate(long(mid(  saledet_qa , 15,5)) *   bal_qty / 1000 + 0.00001,2)) ,  bal_qty )))"border="0" color="0" x="6309" y="4" height="60" width="471" format="#,##0" html.valueishtml="0"  name=range visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="16777215" )
