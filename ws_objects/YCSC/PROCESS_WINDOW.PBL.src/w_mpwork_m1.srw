type dw_6 from datawindow within tabpage_4
event ue_1 pbm_custom01
integer y = 100
integer width = 4521
integer height = 1972
integer taborder = 50
boolean bringtotop = true
string dataobject = "d_mpsfcret_m"
boolean hscrollbar = true
boolean vscrollbar = true
boolean hsplitscroll = true
boolean livescroll = true
borderstyle borderstyle = stylelowered!
end type

event ue_1;this.accepttext()
long ll_row
string ls_coil, ls_chkcoil, ls_maxcoil, ls_item, ls_loc, ls_chk
int li_pos, li_len
dec{1} ld_wid

ll_row = this.getrow()
ls_coil = this.object.coil_no[ll_row]
ls_item = this.object.item_no[ll_row]
ls_loc = this.object.loc_no[ll_row]
ld_wid = this.object.wid[ll_row]
ls_chkcoil = trim(ls_coil) + "%"
li_len = LenA(trim(ls_coil))
if MidA(ls_item, 4, 1) = "1" then
	select max(coil_no) into :ls_maxcoil from coilmst
	 where coil_no like :ls_chkcoil;
else
	select max(sheet_no) into :ls_maxcoil from sheetmst
	 where sheet_no like :ls_chkcoil;
end if
	
ls_chk = MidA(ls_maxcoil, li_len +1 , 1)
if isnull(ls_chk) or trim(ls_chk) = '' then
	if MidA(ls_maxcoil, li_len , 1) = '-' then
		ls_chkcoil = trim(ls_maxcoil) + "1"
	else
		ls_chkcoil = trim(ls_maxcoil) + "-1"
	end if
else
	if MidA(ls_maxcoil, li_len +2, 1) <> '-' then
		ls_chkcoil = LeftA(ls_maxcoil, li_len + 1) + &
						+ string (integer(MidA(ls_maxcoil,li_len + 2, 1)) + 1)
	else
		ls_chkcoil = LeftA(trim(ls_maxcoil), li_len + 1) + "1"
	end if
end if

this.object.coil_no[ll_row] = ls_chkcoil

end event

event clicked;if row < 1 then return
this.scrolltorow(row)
this.accepttext()
end event

event doubleclicked;string ls_item,ls_qa ,ls_loc

CHOOSE CASE dwo.name
	CASE 'item_no','qa',"item_item_name"
			if wf_itemselect(dw6,'S',row) = true then
			end if
//			parent.cb_8.triggerevent(clicked!)
//			dw_2.accepttext()
//			ls_item = this.object.item_no[row]
//			ls_qa = this.object.qa[row]
//			ls_loc = dw_2.object.loc_no[1]
//			if mid(ls_item, 4, 1) = "1" then
//				wf_coildddw(dw6, ls_item, ls_qa,ls_loc )
//			elseif mid(ls_item, 4, 1) = "2" then
//				wf_sheetdddw(dw6, ls_item, ls_qa,ls_loc)
//			else
//				wf_cleardddw(dw6)
//			end if
END CHOOSE
end event

event itemchanged;string ls_item, ls_qa, ls_uom, ls_wid, ls_wid2, ls_len, ls_loc
long ll_row

this.accepttext()
dw_2.accepttext()
ll_row = this.getrow()
ls_item = trim(this.object.item_no[ll_row])
ls_qa = trim(this.object.qa[ll_row])
ls_loc = trim(dw_2.object.loc_no[1])
choose case dwo.name
	case 'item_no', 'qa'
		select item_name, uom into :ls_item, :ls_uom from groupitem
		where item_no = :ls_item;
		if sqlca.sqlcode = 100 then 
			return 1
		end if
		
		if MidA(ls_item, 4, 1) = "1" then
			wf_coildddw(dw6, ls_item, ls_qa, ls_loc )
		elseif MidA(ls_item, 4, 1) = "2" then
			wf_sheetdddw(dw6, ls_item, ls_qa, ls_loc)
		else
			wf_cleardddw(dw6)
		end if
		
		this.object.item_item_name[ll_row] = ls_item
		ls_item = trim(this.object.item_no[ll_row])
		this.object.uom[ll_row] = trim(ls_uom)
		if this.object.coil_no[ll_row] <> "" and not isnull(this.object.coil_no[ll_row]) then
			this.object.wid[ll_row] = dec(MidA(ls_qa,5,4)) + dec("0." + MidA(ls_qa,10,1))
		end if
	case 'coil_no'
		this.getchild('coil_no',idwc_coil6)
		if idwc_coil6.rowcount() > 0 then
			if MidA(ls_item, 4, 1) = "1" then //coil
				this.object.wcoil_no[ll_row] = trim(idwc_coil6.getitemstring(idwc_coil6.getrow(),'coil_no'))
				this.object.loc_no[ll_row] = trim(idwc_coil6.getitemstring(idwc_coil6.getrow(),'loc_no'))
				this.object.wid[ll_row] = idwc_coil6.getitemnumber(idwc_coil6.getrow(),'wid')
				this.object.etc_no[ll_row] = idwc_coil6.getitemstring(idwc_coil6.getrow(),'coilmst_etc_no')
				if this.object.unit_qty[ll_row] > 0 then
				else
					this.object.unit_qty[ll_row] = idwc_coil6.getitemnumber(idwc_coil6.getrow(),'unit_qty')
				end if
		
				this.object.wunit_qty[ll_row] = this.object.unit_qty[ll_row]
				this.object.wlen[ll_row] =  idwc_coil6.getitemnumber(idwc_coil6.getrow(),'length')
		
				this.object.coil_type[ll_row] = idwc_coil6.getitemstring(idwc_coil6.getrow(),'flag')
				if this.object.cnt[ll_row] > 0 then
				else
					this.object.cnt[ll_row] = idwc_coil6.getitemnumber(idwc_coil6.getrow(),'qcnt')
				end if
				if this.object.ret_qty[ll_row] > 0 then
				else
					this.object.ret_qty[ll_row] = this.object.unit_qty[ll_row] * this.object.cnt[ll_row]
				end if
				if this.object.wunit_qty[ll_row] > 0 then
					this.object.length[ll_row] =  this.object.unit_qty[ll_row] &
														/ this.object.wunit_qty[ll_row] &
														* this.object.wlen[ll_row]
				end if
			elseif MidA(ls_item, 4, 1) = "2" then
				this.object.wcoil_no[ll_row] = trim(idwc_coil6.getitemstring(idwc_coil6.getrow(),'sheet_no'))
				this.object.loc_no[ll_row] = trim(idwc_coil6.getitemstring(idwc_coil6.getrow(),'loc_no'))
				if this.object.unit_qty[ll_row] > 0 then
				else
					this.object.unit_qty[ll_row] = idwc_coil6.getitemnumber(idwc_coil6.getrow(),'unit_qty')
				end if
				if this.object.ret_qty[ll_row] > 0 then
				else
					this.object.ret_qty[ll_row] = this.object.unit_qty[ll_row] * this.object.cnt[ll_row]
				end if
			end if
		end if
		this.postevent('ue_1')
		  
	case 'unit_qty', 'cnt'
		this.object.ret_qty[ll_row] = this.object.unit_qty[ll_row] * this.object.cnt[ll_row]
		if this.object.wunit_qty[ll_row] > 0 then
			this.object.length[ll_row] =  this.object.unit_qty[ll_row] &
												/ this.object.wunit_qty[ll_row] &
												* this.object.wlen[ll_row]
		end if
	case 'wid'
		ls_wid = trim(string(integer(truncate(this.object.wid[ll_row],0)),"0000"))
		if isnull(ls_wid) or trim(ls_wid) = '' then
			ls_wid2 ='0000'
		end if
		ls_qa = MidA(this.object.qa[ll_row],1,4) + ls_wid + "X" + MidA(this.object.qa[ll_row],10,10)
		this.object.qa[ll_row] = ls_qa
	case 'length'
		if MidA(ls_item, 4, 1) = "2" then
			ls_len = trim(string(integer(truncate(this.object.length[ll_row],0)),"0000"))
			if isnull(ls_len) or trim(ls_len) = '' then
				ls_len ='0000'
			end if
			ls_qa = MidA(this.object.qa[ll_row],1,9) + ls_len + "X00000"
			this.object.qa[ll_row] = ls_qa
		end if
end choose
return 0
end event

event itemerror;string ls_null, ls_item, ls_qa

choose case dwo.name
	case 'item_no'
		setnull(ls_null)
		this.object.qa[row] =ls_null
		this.object.item_item_name[row] =ls_null
end choose
return 2
end event

event rowfocuschanged;this.accepttext()
long ll_row
string ls_item, ls_qa, ls_null, ls_loc
	
this.accepttext()
dw_2.accepttext()
ll_row = this.getrow()
if ll_row < 1 then return
dwItemStatus l_status

l_status = this.GetItemStatus(ll_row,0, Primary!)

if l_status = New! or l_status = NewModified!  then

	ls_item = this.object.item_no[ll_row]
	ls_qa = this.object.qa[ll_row]
	ls_loc = dw_2.object.loc_no[1]
	
	if MidA(ls_item, 4, 1) = "1" then
		wf_coildddw(dw6, ls_item, ls_qa, ls_loc )
	elseif MidA(ls_item, 4, 1) = "2" then
		wf_sheetdddw(dw6, ls_item, ls_qa, ls_loc)
	else
		wf_cleardddw(dw6)
	end if
end if
end event

event losefocus;this.accepttext()
end event

