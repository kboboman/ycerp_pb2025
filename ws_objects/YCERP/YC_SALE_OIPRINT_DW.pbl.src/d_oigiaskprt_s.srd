table(column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=datetime updatewhereclause=yes name=ask_head_ask_date dbname="ask_head.ask_date" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=char(20) updatewhereclause=yes name=ask_det_qa dbname="ask_det.qa" )
 column=(type=decimal(2) updatewhereclause=yes name=ask_det_rlse_qty dbname="ask_det.rlse_qty" )
 column=(type=char(10) updatewhereclause=yes name=ask_head_t_area dbname="ask_head.t_area" )
 column=(type=char(30) updatewhereclause=yes name=area_area_name dbname="area_name" )
 column=(type=datetime updatewhereclause=yes name=c_start dbname="c_start" )
 column=(type=datetime updatewhereclause=yes name=c_end dbname="c_end" )
 column=(type=char(14) updatewhereclause=yes name=ask_det_sale_no dbname="ask_det.sale_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(50) updatewhereclause=yes name=scene_name dbname="scene_name" )
 column=(type=char(50) updatewhereclause=yes name=ask_det_rem dbname="ask_det.rem" )
 retrieve="  SELECT groupitem.item_name   
       , ask_head.ask_date   
       , uom = dbo.uf_getuom(groupitem.uom)   
       , ask_det.qa   
       , ask_det.rlse_qty   
       , ask_head.t_area   
       , area_name  = location.loc_name
       , c_start    = convert(smalldatetime, :as_sdate, 111)   
       , c_end      = convert(smalldatetime, :as_edate, 111)
		 , ask_det.sale_no
       , cust_name  = dbo.uf_getcustname(ask_det.sale_no)
		 , scene_name = dbo.uf_getscenename(ask_det.sale_no)   
       , ask_det.rem
    FROM ask_det   
       , ask_head   
       , groupitem   
       , location  
   WHERE ( ask_det.ask_no   = ask_head.ask_no   )
     AND ( ask_det.item_no  = groupitem.item_no ) 
     AND ( ask_head.ask_loc = location.loc_no   )
     AND (( ask_det.rlse_qty   > 0 ) AND  
          ( ask_head.f_area like :as_area ) AND  
          ( ask_head.ask_date     between :as_sdate + ' 00:00:00.000' and :as_edate + ' 23:59:59.999' ) 
         )
" arguments=(("as_area", string),("as_sdate", string),("as_edate", string))  sort="ask_head_ask_date A cust_name A scene_name A groupitem_item_name A ask_det_qa A " )
