global type m_b_main from menu
m_manage m_manage
m_retrieve m_retrieve
m_code m_code
m_utility m_utility
m_window m_window
end type
global m_b_main m_b_main

on m_b_main.create
m_b_main=this
call super::create
this.m_manage=create m_manage
this.m_retrieve=create m_retrieve
this.m_code=create m_code
this.m_utility=create m_utility
this.m_window=create m_window
this.Item[UpperBound(this.Item)+1]=this.m_manage
this.Item[UpperBound(this.Item)+1]=this.m_retrieve
this.Item[UpperBound(this.Item)+1]=this.m_code
this.Item[UpperBound(this.Item)+1]=this.m_utility
this.Item[UpperBound(this.Item)+1]=this.m_window
end on

on m_b_main.destroy
call super::destroy
destroy(this.m_manage)
destroy(this.m_retrieve)
destroy(this.m_code)
destroy(this.m_utility)
destroy(this.m_window)
end on

