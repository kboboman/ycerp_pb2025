boolean livescroll = true
end type

type cbx_4 from checkbox within w_ippurchasenew_m
integer x = 4270
integer y = 1148
integer width = 352
integer height = 64
boolean bringtotop = true
integer textsize = -10
integer weight = 400
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
long textcolor = 33554432
long backcolor = 67108864
string text = "최근단가"
end type

event clicked;//

String ls_supp, ls_item, ls_qa
Long   ll_row
Dec    ld_price
	
//setpointer(hourglass!)
ls_supp = trim(dw_1.object.supp_no[dw_1.getrow()])             // 매입처
if ls_supp = '' or isnull(ls_supp) then
	MessageBox("매입처", "매입처를 선택 하세요.")
	return
end if 

For ll_row = 1 To tab_1.tabpage_1.dw_3.rowcount()
	ls_item = tab_1.tabpage_1.dw_3.object.item_no[ll_row]         // 품목
	ls_qa   = tab_1.tabpage_1.dw_3.object.qa[ll_row]              // 규격

   if cbx_4.Checked = false then
		// 매입처 단가
      SELECT SUPPLIER.AMOUNT INTO :ld_price
        FROM SUPPLIER
       WHERE SUPPLIER.SUPP_NO  = :ls_supp 
         AND SUPPLIER.ITEM_NO  = :ls_item
         AND SUPPLIER.QA       = :ls_qa ;   			

		tab_1.tabpage_1.dw_3.object.price[ll_row]  = ld_price
	else
		// 최근단가 
		  SELECT TOP 1 MAX(A.PRICE)   AS PRICE  INTO :ld_price
			  FROM INSPDET A
					 LEFT OUTER JOIN INSP B 
					   ON A.INSP_NO    = B.INSP_NO
					  AND A.ITEM_NO    = :ls_item  
					  AND A.QA         = :ls_qa
			 WHERE B.SUPP_NO         = :ls_supp
			   AND A.PRICE          <> 0
			 GROUP BY CONVERT(CHAR(10), B.INSP_DATE, 111)
			 ORDER BY CONVERT(CHAR(10), B.INSP_DATE, 111) DESC ;
				  
		tab_1.tabpage_1.dw_3.object.price[ll_row]  = ld_price
	end if
Next

if cbx_4.Checked = false then
	messagebox("단가", "매입처 기준단가를 적용 하였습니다.")
else
	messagebox("단가", "최근 단가를 적용 하였습니다.")
end if

end event

