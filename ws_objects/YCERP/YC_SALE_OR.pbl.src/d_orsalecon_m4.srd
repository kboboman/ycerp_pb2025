footer(height=0 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=sale_no dbname="mpsdet.sale_no" )
 column=(type=char(17) updatewhereclause=yes name=order_no dbname="mpsdet.order_no" )
 retrieve="  SELECT mpsdet.sale_no,   
         mpsdet.order_no  
    FROM mpsdet  
   WHERE mpsdet.order_no = :as_order_no    
" arguments=(("as_order_no", string)) )
