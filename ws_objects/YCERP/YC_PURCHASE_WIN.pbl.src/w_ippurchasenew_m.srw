type pb_print from w_inheritance`pb_print within w_ippurchasenew_m
integer x = 3895
integer y = 60
integer taborder = 170
end type

event pb_print::clicked;//
dwItemStatus l_status
w_repsuper   w_print

string ls_order, ls_flag
long   ll_row, ll_mod, i, ll_max, ll_cnt

if dw_1.rowcount() < 1 then RETURN

l_status = dw_1.GetItemStatus(1,0, Primary!)
if l_status = new! OR l_status = newModified! OR &		
	dw_1.object.order_no[1] = "" OR isnull(dw_1.object.order_no[1]) then
	MessageBox("경고", "저장/확정한후에 발주서를 출력을 하십시요.", Exclamation!)
	RETURN
end if

//==GF_USEPROGRAM(프로그램 사용현황)==============================================================
GF_USEPROGRAM( gs_userid, Parent.ClassName(), "P", string(gf_today(),'yyyy/mm/dd'), Parent.Title )
//================================================================================================

ls_order = dw_1.object.order_no[1]
ls_flag  = dw_1.object.subcon[1]
choose case ls_flag
	case "P"		// 외주가공
		dw_9.dataobject = 'd_ippurchase_r2'
		
	case "J"		// 자재가공
		dw_9.dataobject = 'd_ippurchase_r3'
		
   case "C"		// 외주스리팅
		dw_9.dataobject = 'd_ippurchase_r4'

	case else	// 
		dw_9.dataobject = 'd_ippurchase_r'
end choose
dw_9.settransobject(sqlca)
dw_9.retrieve( ls_order )

ll_row = dw_9.rowcount()
choose case ls_flag
	case "P", "J", "C"
		ll_max = 8
	case else
		ll_max = 12
end choose
ll_mod = Mod(ll_row, ll_max)

//20070110 d_ippurchase_r의 cham 필드가 pur_cham이라
if ll_mod <> 0 then
	for i = 1 to ll_max - ll_mod
		ll_cnt = dw_9.insertrow(0)

		dw_9.object.mak[ll_cnt] = dw_9.object.mak[ll_cnt - 1]	 
		if dw_9.dataobject = 'd_ippurchase_r' OR dw_9.dataobject = 'd_ippurchase_r2' OR &
		   dw_9.dataobject = 'd_ippurchase_r3' then
			 dw_9.object.supply_addr[ll_cnt]  = dw_9.object.supply_addr[ll_cnt - 1]	 	
			 dw_9.object.supply_tel[ll_cnt]   = dw_9.object.supply_tel[ll_cnt - 1]	 	
			 dw_9.object.cham[ll_cnt]         = dw_9.object.cham[ll_cnt - 1]	 	
		elseif dw_9.dataobject = 'd_ippurchase_r4' then
			 dw_9.object.supply_addr[ll_cnt]  = dw_9.object.supply_addr[ll_cnt - 1]	 	
			 dw_9.object.supply_tel[ll_cnt]   = dw_9.object.supply_tel[ll_cnt - 1]	 	
			 dw_9.object.pur_cham[ll_cnt]     = dw_9.object.pur_cham[ll_cnt - 1]	 	
		end if			
	next
end if

i_print.st_datawindow  = dw_9
i_print.st_print_sheet = " 프린트용지 : A4"
i_print.st_print_desc  = " 이 프로그램은 발주서를 출력합니다." 

if dw_9.dataobject = 'd_ippurchase_r' then
	gs_print_control  = 'DataWindow.Print.Orientation=1 DataWindow.Print.Paper.Size=9 Datawindow.Zoom=95'
else
	gs_print_control  = 'DataWindow.Print.Orientation=1 DataWindow.Print.Paper.Size=9 Datawindow.Zoom=100'
end if
opensheetwithparm(w_print, i_print,parentwindow(), 1, Original!)

end event

