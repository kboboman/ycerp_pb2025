$PBExportHeader$d_customer_det_list.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=84 color="536870912" )
summary(height=0 color="536870912" )
footer(height=92 color="8421504" )
detail(height=96 color="536870912"  height.autosize=yes)
table(column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=datetime updatewhereclause=yes name=idate dbname="idate" )
 column=(type=long updatewhereclause=yes name=seq dbname="seq" )
 column=(type=char(50) updatewhereclause=yes name=rem dbname="rem" )
 column=(type=char(10) updatewhereclause=yes name=iuser dbname="iuser" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(10) updatewhereclause=yes name=saler_user dbname="saler_user" )
 column=(type=char(10) updatewhereclause=yes name=area_no dbname="area_no" )
 retrieve="  SELECT cust_no   = a.cust_no
       , cust_name = a.cust_name
       , idate     = a.idate
       , seq       = a.seq
       , rem       = a.rem
       , iuser     = a.iuser
       , user_name = a.user_name
       , saler_user= a.saler_user
       , area_no   = a.area_no
    FROM (
         SELECT cust_no   = cd.cust_no
              , cust_name = c.cust_name
              , idate     = cd.idate
              , seq       = cd.seq
              , rem       = cd.rem
              , iuser     = cd.iuser
              , user_name = l.user_name
              , saler_user= ae.saler_user
              , area_no   = l.area_no
           FROM customer_det cd 
                LEFT OUTER JOIN customer       c ON cd.cust_no = c.cust_no
                LEFT OUTER JOIN login          l ON cd.iuser   = l.user_id
                LEFT OUTER JOIN aroiinv_esero ae ON c.salesman = ae.id
          WHERE convert(char(10), cd.idate, 111) BETWEEN :as_sdate AND :as_edate
         ) A
   WHERE ((:as_areano <> '%' AND a.area_no    = :as_areano and ((:as_custno <> '%' AND a.cust_no    = :as_custno) or
                                                                (:as_custno  = '%' AND a.cust_no LIKE :as_custno) 
                                                               )) or
          (:as_areano  = '%' AND a.area_no LIKE :as_areano and ((:as_custno <> '%' AND a.cust_no    = :as_custno) or
                                                                (:as_custno  = '%' AND a.cust_no LIKE :as_custno) 
                                                               ))  
         )
   ORDER BY a.idate desc, a.seq DESC
" arguments=(("as_sdate", string),("as_edate", string),("as_custno", string),("as_areano", string)) )
