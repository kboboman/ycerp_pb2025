table(column=(type=decimal(4) updatewhereclause=yes name=balance_amt dbname="supp.balance_amt" initial="0" )
 column=(type=decimal(4) updatewhereclause=yes name=bill_amount dbname="supp.bill_amount" initial="0" )
 column=(type=char(12) update=yes updatewhereclause=yes key=yes name=vc_no dbname="apoivc.vc_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=supp_no dbname="apoivc.supp_no" )
 column=(type=datetime update=yes updatewhereclause=yes name=oi_date dbname="apoivc.oi_date" )
 column=(type=char(1) update=yes updatewhereclause=yes name=paid_type dbname="apoivc.paid_type" initial="C" values="현금	C/어음	B/예금	A/D//C	D/상계	S/잡이익	E/처리어음	P/기타	Z/하자보수	F/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=vc_type dbname="apoivc.vc_type" initial="P" values="지불	P/수금	R/" )
 column=(type=char(3) update=yes updatewhereclause=yes name=curr_code dbname="apoivc.curr_code" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=gl_curr_rate dbname="apoivc.gl_curr_rate" initial="1" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=amount dbname="apoivc.amount" initial="0" )
 column=(type=char(6) update=yes updatewhereclause=yes name=bank_code dbname="apoivc.bank_code" )
 column=(type=char(20) update=yes updatewhereclause=yes name=branch dbname="apoivc.branch" )
 column=(type=datetime update=yes updatewhereclause=yes name=cheque_start dbname="apoivc.cheque_start" )
 column=(type=datetime update=yes updatewhereclause=yes name=cheque_end dbname="apoivc.cheque_end" )
 column=(type=char(20) update=yes updatewhereclause=yes name=large dbname="apoivc.large" )
 column=(type=char(10) update=yes updatewhereclause=yes name=salesman dbname="apoivc.salesman" )
 column=(type=datetime update=yes updatewhereclause=yes name=sys_date dbname="apoivc.sys_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=login_id dbname="apoivc.login_id" )
 column=(type=char(1) update=yes updatewhereclause=yes name=open_close dbname="apoivc.open_close" initial="O" )
 column=(type=datetime update=yes updatewhereclause=yes name=close_date dbname="apoivc.close_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=close_user dbname="apoivc.close_user" )
 column=(type=char(1) update=yes updatewhereclause=yes name=delete_key dbname="apoivc.delete_key" initial="N" )
 column=(type=char(50) update=yes updatewhereclause=yes name=rem dbname="apoivc.rem" )
 column=(type=char(1) update=yes updatewhereclause=yes name=bill_type dbname="apoivc.bill_type" initial="A" values="자수	J/타수	T/" )
 column=(type=char(1) updatewhereclause=yes name=set_flag dbname="apbill.set_flag" )
 column=(type=char(12) update=yes updatewhereclause=yes name=cheque_no dbname="apoivc.cheque_no" )
 column=(type=char(12) updatewhereclause=yes name=a_bill_no dbname="a_bill_no" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"supp~" )  TABLE(NAME=~"apbill~" )  TABLE(NAME=~"apoivc~" ) COLUMN(NAME=~"supp.balance_amt~") COLUMN(NAME=~"supp.bill_amount~") COLUMN(NAME=~"apoivc.vc_no~") COLUMN(NAME=~"apoivc.supp_no~") COLUMN(NAME=~"apoivc.oi_date~") COLUMN(NAME=~"apoivc.paid_type~") COLUMN(NAME=~"apoivc.vc_type~") COLUMN(NAME=~"apoivc.curr_code~") COLUMN(NAME=~"apoivc.gl_curr_rate~") COLUMN(NAME=~"apoivc.amount~") COLUMN(NAME=~"apoivc.bank_code~") COLUMN(NAME=~"apoivc.branch~") COLUMN(NAME=~"apoivc.cheque_start~") COLUMN(NAME=~"apoivc.cheque_end~") COLUMN(NAME=~"apoivc.large~") COLUMN(NAME=~"apoivc.salesman~") COLUMN(NAME=~"apoivc.sys_date~") COLUMN(NAME=~"apoivc.login_id~") COLUMN(NAME=~"apoivc.open_close~") COLUMN(NAME=~"apoivc.close_date~") COLUMN(NAME=~"apoivc.close_user~") COLUMN(NAME=~"apoivc.delete_key~") COLUMN(NAME=~"apoivc.rem~") COLUMN(NAME=~"apoivc.bill_type~") COLUMN(NAME=~"apbill.set_flag~") COLUMN(NAME=~"apoivc.cheque_no~") COMPUTE(NAME=~"a_bill_no = cheque_no~")    JOIN (LEFT=~"apoivc.vc_no~"    OP =~"=~"RIGHT=~"apbill.vc_no~"    OUTER1 =~"apoivc.vc_no~" )    JOIN (LEFT=~"apoivc.supp_no~"    OP =~"=~"RIGHT=~"supp.supp_no~" )WHERE(    EXP1 =~"( ( apoivc.vc_no~"   OP =~"=~"    EXP2 =~":as_vc_no ) )~" ) ) ARG(NAME = ~"as_vc_no~" TYPE = string) " update="apoivc" updatewhere=0 updatekeyinplace=no arguments=(("as_vc_no", string)) )
