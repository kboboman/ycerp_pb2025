detail(height=156 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=scene_cust_no dbname="scene.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(11) updatewhereclause=yes name=scene_scene_code dbname="scene.scene_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene.scene_desc" )
 column=(type=char(10) updatewhereclause=yes name=scene_scene_charge dbname="scene.scene_charge" )
 column=(type=char(10) updatewhereclause=yes name=scene_area_nm dbname="scene.area_nm" )
 column=(type=char(20) updatewhereclause=yes name=scene_project_nm dbname="scene.project_nm" )
 column=(type=char(20) updatewhereclause=yes name=scene_owner dbname="scene.owner" )
 column=(type=datetime updatewhereclause=yes name=scene_start_date dbname="start_date" )
 column=(type=datetime updatewhereclause=yes name=scene_end_date dbname="end_date" )
 column=(type=char(15) updatewhereclause=yes name=scene_scene_tel dbname="scene.scene_tel" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_scale dbname="scene_scale" )
 column=(type=char(80) updatewhereclause=yes name=scene_scene_addr dbname="scene_addr" )
 column=(type=char(80) updatewhereclause=yes name=scene_rem dbname="rem" )
 column=(type=char(10) updatewhereclause=yes name=input_date dbname="input_date" )
 retrieve="  SELECT scene.cust_no                                
       , customer.cust_name                           
       , scene.scene_code                             
       , scene.scene_desc                             
       , scene.scene_charge                           
       , scene.area_nm                                
       , scene.project_nm                             
       , scene.owner                                  
       , start_date  = isnull(scene.start_date,'')     
       , end_date    = isnull(scene.end_date,'')       
       , scene.scene_tel                              
       , scene_scale = isnull(scene.scene_scale,'')   
       , scene_addr  = isnull(scene.scene_addr,'')     
       , rem         = isnull(scene.rem,'')                
       , input_date  = convert(char(10),scene.input_date,111)
    FROM customer
       , scene  
   WHERE ( scene.cust_no = customer.cust_no )
     AND ( scene.input_date BETWEEN :ad_sdate AND :ad_edate )
" arguments=(("ad_sdate", date),("ad_edate", date)) )
