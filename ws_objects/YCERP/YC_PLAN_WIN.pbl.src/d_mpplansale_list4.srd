table(column=(type=char(17) update=yes updatewhereclause=yes name=plan_no dbname="mpsdet.plan_no" )
 column=(type=char(17) update=yes updatewhereclause=yes name=order_no dbname="mpsdet.order_no" initial=" " )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="mpsdet.item_no" initial=" " )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="mpsdet.uom" initial=" " )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=order_qty dbname="mpsdet.order_qty" initial="0" )
 column=(type=decimal(4) updatewhereclause=yes name=cqty dbname="cqty" )
 column=(type=datetime update=yes updatewhereclause=yes name=due_date dbname="mpsdet.due_date" initial="today" )
 column=(type=long update=yes updatewhereclause=yes name=priority dbname="mpsdet.priority" initial="1" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="mpsdet.qa" )
 column=(type=char(10) update=yes updatewhereclause=yes name=wc_no dbname="mpsdet.wc_no" )
 column=(type=char(14) update=yes updatewhereclause=yes name=sale_no dbname="mpsdet.sale_no" initial="NONE" )
 column=(type=long update=yes updatewhereclause=yes name=seq_no dbname="mpsdet.seq_no" initial="0" )
 column=(type=char(1) update=yes updatewhereclause=yes name=suju_type dbname="mpsdet.suju_type" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=work_time dbname="mpsdet.work_time" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=setup_time dbname="mpsdet.setup_time" initial="0" )
 column=(type=char(1) update=yes updatewhereclause=yes name=rcpt_type dbname="mpsdet.rcpt_type" initial="N" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=rcpt_qty dbname="mpsdet.rcpt_qty" initial="0" )
 column=(type=datetime update=yes updatewhereclause=yes name=napgi_date dbname="mpsdet.napgi_date" )
 column=(type=char(4) update=yes updatewhereclause=yes name=item_color dbname="mpsdet.item_color" )
 column=(type=char(4) update=yes updatewhereclause=yes name=cust_no dbname="mpsdet.cust_no" initial="NONE" )
 column=(type=char(11) update=yes updatewhereclause=yes name=scene_code dbname="mpsdet.scene_code" initial="NONE" )
 column=(type=long update=yes updatewhereclause=yes name=work_per dbname="mpsdet.work_per" )
 column=(type=long update=yes updatewhereclause=yes name=division dbname="mpsdet.division" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="GroupItem.item_name" initial=" " )
 column=(type=char(50) update=yes updatewhereclause=yes name=rem dbname="mpsdet.rem" )
 column=(type=long update=yes updatewhereclause=yes name=operation dbname="mpsdet.operation" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 column=(type=datetime updatewhereclause=yes name=order_date dbname="mps.order_date" )
 retrieve="  SELECT mpsdet.plan_no        
       , mpsdet.order_no       
       , mpsdet.item_no        
       , mpsdet.uom            
       , mpsdet.order_qty 
       , cqty   = dbo.uf_getqty(mpsdet.item_no, mpsdet.qa, mpsdet.uom, mpsdet.order_qty)
       , mpsdet.due_date       
       , mpsdet.priority       
       , mpsdet.qa             
       , mpsdet.wc_no          
       , mpsdet.sale_no        
       , mpsdet.seq_no         
       , mpsdet.suju_type      
       , mpsdet.work_time      
       , mpsdet.setup_time     
       , mpsdet.rcpt_type      
       , mpsdet.rcpt_qty       
       , mpsdet.napgi_date     
       , mpsdet.item_color     
       , mpsdet.cust_no        
       , mpsdet.scene_code     
       , mpsdet.work_per       
       , mpsdet.division       
       , groupitem.item_name   
       , mpsdet.rem            
       , mpsdet.operation      
       , customer.cust_name    
       , scene.scene_desc  
       , mps.order_date
    FROM mpsdet with(nolock)
         LEFT OUTER JOIN mps   with(nolock)    ON mpsdet.order_no   = mps.order_no      
         LEFT OUTER JOIN groupitem with(nolock) ON mpsdet.item_no    = groupitem.item_no
         LEFT OUTER JOIN customer with(nolock) ON mpsdet.cust_no    = customer.cust_no
         LEFT OUTER JOIN scene  with(nolock)   ON mpsdet.scene_code = scene.scene_code
   WHERE ( mps.order_date  between :as_sdate AND :as_edate )   
" arguments=(("as_sdate", string),("as_edate", string))  sort="order_date A priority A item_no A qa A " )
group(level=1 header.height=0 trailer.height=72 by=("order_date" , "item_no" , "left ( qa, 13)" ) header.color="536870912" trailer.color="536870912" )
