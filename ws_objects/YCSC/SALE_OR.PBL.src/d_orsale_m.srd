 column=(type=char(11) update=yes updatewhereclause=yes name=scene_code dbname="sale.scene_code" initial=" " )
 column=(type=datetime update=yes updatewhereclause=yes name=order_date dbname="sale.order_date" initial=" " )
 column=(type=datetime update=yes updatewhereclause=yes name=due_date dbname="sale.due_date" initial="today()" )
 column=(type=char(14) update=yes updatewhereclause=yes name=estimate_no dbname="sale.estimate_no" initial=" " )
 column=(type=char(1) update=yes updatewhereclause=yes name=sale_flag dbname="sale.sale_flag" initial="D" values="내수	D/수출	E/LC	L/" )
