$PBExportComments$판매수주관리 수주번호선택(1998/04/02, 정재수)
release 8;
datawindow(units=0 timer_interval=0 color=79219928 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=72 color="536870912" )
summary(height=0 color="536870912" )
footer(height=64 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(4) update=yes updatewhereclause=yes name=cust_no dbname="orexceed.cust_no" )
 column=(type=char(8) update=yes updatewhereclause=yes name=start_date dbname="orexceed.start_date" )
 column=(type=char(8) update=yes updatewhereclause=yes name=end_date dbname="orexceed.end_date" )
 column=(type=char(1) updatewhereclause=yes name=orexceed_use_yn dbname="orexceed.use_yn" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=orexceed_limit_amt dbname="orexceed.limit_amt" )
 column=(type=char(50) update=yes updatewhereclause=yes name=orexceed_bigo dbname="orexceed.bigo" )
 column=(type=datetime update=yes updatewhereclause=yes name=input_date dbname="orexceed.input_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=input_id dbname="orexceed.input_id" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name dbname="login.user_name" )
 retrieve="select  
	 orexceed.cust_no
	,orexceed.start_date
	,orexceed.end_date
	,orexceed.use_yn
	,orexceed.limit_amt     
	,orexceed.bigo
	,orexceed.input_date
	,orexceed.input_id
	,login.user_name
from 
	orexceed left outer join login on orexceed.input_id = login.user_id
where 
	orexceed.cust_no = :as_custno
" arguments=(("as_custno", string))  sort="start_date D end_date D " )
