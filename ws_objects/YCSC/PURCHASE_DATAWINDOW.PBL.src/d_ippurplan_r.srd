$PBExportHeader$d_ippurplan_r.srd
$PBExportComments$원재료 구매 계획보고서(2002/06/21, 이인호)
release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=640 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=84 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=plan_year dbname="purplan.plan_year" )
 column=(type=char(2) updatewhereclause=yes name=plan_mon dbname="purplan.plan_mon" )
 column=(type=char(1) updatewhereclause=yes name=plan_flag dbname="purplan.plan_flag" )
 column=(type=long updatewhereclause=yes name=seq dbname="purplan.seq" )
 column=(type=decimal(3) updatewhereclause=yes name=thin dbname="purplan.thin" )
 column=(type=long updatewhereclause=yes name=preplan_qty dbname="purplan.preplan_qty" )
 column=(type=long updatewhereclause=yes name=plan_qty dbname="purplan.plan_qty" )
 column=(type=long updatewhereclause=yes name=supp1 dbname="purplan.supp1" )
 column=(type=long updatewhereclause=yes name=supp2 dbname="purplan.supp2" )
 column=(type=long updatewhereclause=yes name=supp3 dbname="purplan.supp3" )
 column=(type=long updatewhereclause=yes name=supp4 dbname="purplan.supp4" )
 column=(type=long updatewhereclause=yes name=supp5 dbname="purplan.supp5" )
 column=(type=long updatewhereclause=yes name=supp6 dbname="purplan.supp6" )
 column=(type=char(50) updatewhereclause=yes name=rem dbname="purplan.rem" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="purplan.user_id" )
 column=(type=char(10) updatewhereclause=yes name=confirm1 dbname="purplan.confirm1" )
 column=(type=char(10) updatewhereclause=yes name=confirm2 dbname="purplan.confirm2" )
 column=(type=char(10) updatewhereclause=yes name=confirm3 dbname="purplan.confirm3" )
 column=(type=char(4) updatewhereclause=yes name=year dbname="year" )
 column=(type=char(2) updatewhereclause=yes name=mon dbname="mon" )
 column=(type=char(20) updatewhereclause=yes name=name dbname="name" )
 retrieve="  SELECT purplan.plan_year,   
         purplan.plan_mon,   
         purplan.plan_flag,   
         purplan.seq,   
         purplan.thin,   
         purplan.preplan_qty,   
         purplan.plan_qty,   
         purplan.supp1,   
         purplan.supp2,   
         purplan.supp3,   
         purplan.supp4,   
         purplan.supp5,   
         purplan.supp6,   
         purplan.rem,   
         purplan.user_id,   
         purplan.confirm1,   
         purplan.confirm2,   
         purplan.confirm3,
			year = convert(char(4),:as_year),
			mon = convert(char(2),:as_mon),
			name = convert(varchar(20),case :as_flag when 'G' then 'GI COIL' when 'C' then '칼라 COIL' WHEN 'A' THEN 'AL COIL' END)  
    FROM purplan  
   WHERE ( purplan.plan_year = :as_year ) AND  
         ( purplan.plan_mon = :as_mon ) AND  
         ( purplan.plan_flag = :as_flag )    
" arguments=(("as_year", string),("as_mon", string),("as_flag", string))  sort="plan_year A plan_mon A plan_flag A seq A " )
