 column=(type=long update=yes updatewhereclause=yes key=yes name=seq dbname="yc_com_resource_user.seq" initial="0" )
 column=(type=char(20) update=yes updatewhereclause=yes name=user_nm dbname="yc_com_resource_user.user_nm" )
