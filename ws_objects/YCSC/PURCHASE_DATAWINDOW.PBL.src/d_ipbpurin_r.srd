$PBExportHeader$d_ipbpurin_r.srd
$PBExportComments$조업자재 구매일보(1999/06/07, 이인호)
release 8;
datawindow(units=3 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 635 print.margin.right = 635 print.margin.top = 635 print.margin.bottom = 635 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=793 color="536870912" )
footer(height=0 color="536870912" )
detail(height=582 color="553648127"  height.autosize=yes)
table(column=(type=datetime updatewhereclause=yes name=in_date dbname="in_date" )
 column=(type=char(10) updatewhereclause=yes name=area_no dbname="area_no" )
 column=(type=long updatewhereclause=yes name=seq dbname="seq" )
 column=(type=char(3) updatewhereclause=yes name=supp_no dbname="supp_no" )
 column=(type=long updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(30) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(4) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=decimal(2) updatewhereclause=yes name=qty dbname="qty" )
 column=(type=decimal(2) updatewhereclause=yes name=cost dbname="cost" )
 column=(type=decimal(4) updatewhereclause=yes name=amount dbname="amount" )
 column=(type=char(1) updatewhereclause=yes name=part_code dbname="part_code" )
 column=(type=datetime updatewhereclause=yes name=sys_date dbname="sys_date" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="user_id" )
 column=(type=char(30) updatewhereclause=yes name=bsupp_supp_name dbname="bsupp_supp_name" )
 column=(type=char(30) updatewhereclause=yes name=bitem_item_name dbname="bitem_item_name" )
 column=(type=char(62) updatewhereclause=yes name=rem dbname="rem" )
 column=(type=char(11) updatewhereclause=yes name=item_class dbname="item_class" )
 retrieve="  SELECT in_date = binitem.in_date,   
         area_no = binitem.area_no,   
         seq = binitem.seq,   
         supp_no = binitem.supp_no,   
         item_no = binitem.item_no,   
         qa = rtrim(binitem.qa),   
         uom = binitem.uom,   
         qty = binitem.qty,   
         cost = binitem.cost,   
         amount = binitem.amount,   
         part_code = binitem.part_code,   
         sys_date = binitem.sys_date,   
         user_id = binitem.user_id,   
         bsupp_supp_name = bsupp.supp_name,
         bitem_item_name = bitem.item_name,   
         rem = case when isnull(binitem.rem, '') <> '' then rtrim('※' + binitem.rem) end,
		   item_class = '조 업 자 재'
	FROM binitem LEFT OUTER JOIN bitem ON binitem.item_no = bitem.item_no LEFT OUTER JOIN bsupp ON binitem.supp_no = bsupp.supp_no  
   WHERE ( binitem.in_date between :arg_sdate and :arg_edate ) AND  
         ( binitem.area_no = :arg_area )    

" arguments=(("arg_sdate", date),("arg_edate", date),("arg_area", string))  sort="in_date A bsupp_supp_name A bitem_item_name A qa A seq A " )
