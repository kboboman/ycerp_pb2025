$PBExportComments$수주별작업진행관리(수주번호)(1999/06/04,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=1090519039 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=order_no dbname="sale.order_no" initial=" " )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene.scene_desc" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"sale~" )  TABLE(NAME=~"customer~" )  TABLE(NAME=~"scene~" ) COLUMN(NAME=~"sale.order_no~") COLUMN(NAME=~"customer.cust_name~") COLUMN(NAME=~"scene.scene_desc~")    JOIN (LEFT=~"sale.cust_no~"    OP =~"=~"RIGHT=~"customer.cust_no~"    OUTER1 =~"sale.cust_no~" )    JOIN (LEFT=~"sale.scene_code~"    OP =~"=~"RIGHT=~"scene.scene_code~"    OUTER1 =~"sale.scene_code~" )WHERE(    EXP1 =~"sale.order_date~"   OP =~"between~"    EXP2 =~":ad_date and :ad_date1~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"sale.cust_no~"   OP =~"like~"    EXP2 =~":as_cust~" ) ) ORDER(NAME=~"sale.order_no~" ASC=no) ARG(NAME = ~"ad_date~" TYPE = date)  ARG(NAME = ~"ad_date1~" TYPE = date)  ARG(NAME = ~"as_cust~" TYPE = string) " arguments=(("ad_date", date),("ad_date1", date),("as_cust", string))  sort="order_no D " )
