$PBExportHeader$coil_list01.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no rows_per_detail = 3 )
header(height=68 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=344 color="536870912" )
table(column=(type=char(30) updatewhereclause=yes name=coilmst_loc_name dbname="coilmst.loc_name" )
 column=(type=char(20) updatewhereclause=yes name=coil_no dbname="coilmst.coil_no" )
 column=(type=char(22) updatewhereclause=yes name=barc dbname="barc" )
 retrieve="  SELECT loc_name, coilmst.coil_no,   
         barc = '*' + rtrim(coil_no) + '*'  
    FROM coilmst, LOCATION
   WHERE coilmst.open_close = 'O'   and
			item_no not in ( select loss_item from lossitem)
AND coilmst.LOC_NO = location.loc_no
and coilmst.loc_no like 'F%'
            
"  sort="coilmst_loc_name A coil_no A " )
