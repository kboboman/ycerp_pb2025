 column=(type=char(10) updatewhereclause=yes name=supp_supp_no dbname="supp.supp_no" )
 retrieve="PBSELECT( VERSION(400) DISTINCT ()TABLE(NAME=~"insp~" )  TABLE(NAME=~"inspdet~" )  TABLE(NAME=~"supp~" ) COLUMN(NAME=~"supp.supp_name~") COLUMN(NAME=~"supp.supp_no~")    JOIN (LEFT=~"insp.insp_no~"    OP =~"=~"RIGHT=~"inspdet.insp_no~" )    JOIN (LEFT=~"insp.supp_no~"    OP =~"=~"RIGHT=~"supp.supp_no~" )WHERE(    EXP1 =~"inspdet.rcpt_qty~"   OP =~">~"    EXP2 =~"inspdet.apoi_qty~" ) ) "  sort="supp_supp_name A " )
column(band=detail id=1 alignment="0" tabsequence=32766 border="0" color="0" x="5" y="4" height="60" width="992" format="[general]"  name=supp_supp_name  tag="상호" edit.limit=30 edit.case=any edit.autoselect=yes edit.autohscroll=yes  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
