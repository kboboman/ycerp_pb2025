$PBExportComments$코일수불현황조회(스리팅)(2001/05/08,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=68 color="12639424" )
detail(height=72 color="536870912" )
table(column=(type=char(1) updatewhereclause=yes name=flag dbname="flag" )
 column=(type=datetime updatewhereclause=yes name=coilsfcday_sfc_date dbname="sfc_date" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=coil_no dbname="coil_no" )
 column=(type=char(20) updatewhereclause=yes name=coilmst_qa dbname="qa" )
 column=(type=decimal(4) updatewhereclause=yes name=qty dbname="qty" )
 column=(type=long updatewhereclause=yes name=coilmst_cnt dbname="cnt" )
 column=(type=char(30) updatewhereclause=yes name=wc_name dbname="wc_name" )
 column=(type=datetime updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=datetime updatewhereclause=yes name=edate dbname="edate" )
 column=(type=char(1) updatewhereclause=yes name=sort dbname="sort" )
 column=(type=char(1) updatewhereclause=yes name=flag dbname="flag" )
 retrieve="  SELECT flag = 'I',
			sfc_date = coilsfcday.sfc_date,   
         item_name = groupitem.item_name,   
         coil_no = coilsfcday.coil_no,   
         qa = coilsfcday.qa,   
         qty = coilsfcday.unit_qty,   
         cnt = coilsfcday.cnt,   
         wc_name = wc.work_name  ,   
         sdate = convert(smalldatetime, :ad_start, 111),   
         edate = convert(smalldatetime, :ad_end, 111),
			sort = '1',
			flag = '1'  
    FROM    coilsfcday inner join groupitem on coilsfcday.item_no = groupitem.item_no 
                                     left outer join wc on coilsfcday.wc_no = wc.work_no   
   WHERE ( ( coilsfcday.sfc_date between :ad_start and :ad_end ) )    
union
  SELECT flag = 'O',
			sfc_date = insp.insp_date,   
         item_name = groupitem.item_name,   
         coil_no = inspdet.coil_no,   
         qa = inspdet.qa,   
         qty = inspdet.unit_qty,   
         cnt = inspdet.cnt,   
         wc_name = supp.supp_name ,   
         sdate = convert(smalldatetime, :ad_start, 111),   
         edate = convert(smalldatetime, :ad_end, 111),
			sort = '2',
			flag = '1'  
    FROM  insp inner join inspdet on insp.insp_no = inspdet.insp_no
                         inner join groupitem on  inspdet.item_no = groupitem.item_no
                         inner join supp on insp.supp_no = supp.supp_no
                         inner join pur on inspdet.pur_no = pur.order_no
   WHERE ( ( insp.insp_date between :ad_start and :ad_end ) AND  
         ( pur.subcon = 'C' ) )    

" arguments=(("ad_start", date),("ad_end", date))  sort="flag D coilsfcday_sfc_date A groupitem_item_name A coilmst_qa A qty A " )
