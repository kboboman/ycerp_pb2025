$PBExportComments$물품반품관리상세(1998/5/24,성삼지)
release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=160 color="536870912" )
summary(height=0 color="536870912" )
footer(height=156 color="8421504" )
detail(height=168 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes key=yes name=ret_no dbname="retdet.ret_no" )
 column=(type=long updatewhereclause=yes key=yes name=ret_seq dbname="retdet.ret_seq" )
 column=(type=char(14) updatewhereclause=yes name=sale_no dbname="retdet.sale_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="retdet.seq_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="retdet.item_no" )
 column=(type=char(4) updatewhereclause=yes name=color dbname="retdet.color" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="retdet.qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="retdet.uom" )
 column=(type=decimal(2) updatewhereclause=yes name=ret_qty dbname="retdet.ret_qty" initial="0" )
 column=(type=decimal(2) updatewhereclause=yes name=acc_qty dbname="retdet.acc_qty" initial="0" )
 column=(type=char(1) updatewhereclause=yes name=acc_degree dbname="retdet.acc_degree" )
 column=(type=char(40) updatewhereclause=yes name=decision_desc dbname="retdet.decision_desc" )
 column=(type=char(40) updatewhereclause=yes name=rem dbname="retdet.rem" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(10) updatewhereclause=yes name=loc_no dbname="retdet.loc_no" )
 column=(type=decimal(4) updatewhereclause=yes name=saledet_price dbname="saledet.price" initial="0" )
 column=(type=char(1) updatewhereclause=yes name=acc_chk dbname="acc_chk" initial="Y" values="	Y/	N" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=retdet_price dbname="retdet.price" initial="0" )
 column=(type=char(1) updatewhereclause=yes name=ret_process_flag dbname="ret.process_flag" initial="D" )
 column=(type=decimal(0) updatewhereclause=yes name=price dbname="price" initial="0" )
 column=(type=char(1) updatewhereclause=yes name=round dbname="customer.round" )
 retrieve="  SELECT retdet.ret_no,   
         retdet.ret_seq,   
         retdet.sale_no,   
         retdet.seq_no,   
         retdet.item_no,   
         retdet.color,   
         retdet.qa,   
         retdet.uom,   
         retdet.ret_qty,   
         retdet.acc_qty,   
         retdet.acc_degree,   
         retdet.decision_desc,   
         retdet.rem,   
         groupitem.item_name,   
         retdet.loc_no,   
         saledet.price,   
         acc_chk = ( case when ret.process_flag = ~"I~" then ~"N~" when ret.process_flag = ~"P~" then ~"N~" else ~"Y~" end ),   
         retdet.price,   
         ret.process_flag,   
         price = dbo.uf_getretprice(retdet.sale_no, retdet.seq_no),   
         customer.round  
    FROM retdet,   
         groupitem,   
         ret,   
         customer,   
         saledet  
   WHERE ( retdet.item_no = groupitem.item_no ) and  
         ( retdet.ret_no = ret.ret_no ) and  
         ( ret.cust_no = customer.cust_no ) and  
         ( retdet.sale_no = saledet.order_no ) and  
         ( retdet.seq_no = saledet.seq_no ) and  
			( retdet.loc_no is not null ) and
         ( ( retdet.ret_no = :as_order ) )    
                     " update="retdet" updatewhere=0 updatekeyinplace=yes arguments=(("as_order", string))  sort="ret_seq A " )
