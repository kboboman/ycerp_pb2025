$PBExportComments$구매거래처관리(1998/02/09,곽용덕)
release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=1628 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=supp_no dbname="supp.supp_no" )
 column=(type=char(12) update=yes updatewhereclause=yes name=register_no dbname="supp.register_no" )
 column=(type=char(30) update=yes updatewhereclause=yes name=supp_name dbname="supp.supp_name" )
 column=(type=char(10) update=yes updatewhereclause=yes name=captain_name dbname="supp.captain_name" )
 column=(type=char(80) update=yes updatewhereclause=yes name=addr dbname="supp.addr" )
 column=(type=char(10) update=yes updatewhereclause=yes name=contact dbname="supp.contact" )
 column=(type=char(10) update=yes updatewhereclause=yes name=position dbname="supp.position" )
 column=(type=char(15) update=yes updatewhereclause=yes name=tel_no dbname="supp.tel_no" )
 column=(type=char(30) update=yes updatewhereclause=yes name=rem dbname="supp.rem" )
 column=(type=char(10) update=yes updatewhereclause=yes name=buyer dbname="supp.buyer" )
 column=(type=char(20) update=yes updatewhereclause=yes name=industry_type dbname="supp.industry_type" )
 column=(type=char(20) update=yes updatewhereclause=yes name=industry_code dbname="supp.industry_code" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=credit_limit dbname="supp.credit_limit" initial="0" )
 column=(type=long update=yes updatewhereclause=yes name=terms dbname="supp.terms" initial="0" )
 column=(type=char(20) update=yes updatewhereclause=yes name=fob dbname="supp.fob" )
 column=(type=datetime update=yes updatewhereclause=yes name=last_tran_date dbname="supp.last_tran_date" initial="today" )
 column=(type=char(3) update=yes updatewhereclause=yes name=currency_type dbname="supp.currency_type" )
 column=(type=char(15) update=yes updatewhereclause=yes name=fax_no dbname="supp.fax_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=subcon dbname="supp.subcon" values="Y. 외주업체	Y/N. 내수업체	N/L. 수입업체	L/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=type dbname="supp.type" values=" 	 /A.입고시 외주제품수불	A/B.입고시 외주스리팅코일사용	B/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=round dbname="supp.round" initial="N" values="원단위미만 반올림	Y/원단위미만 반올림	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=yspsub_flag dbname="supp.yspsub_flag" values="YSP외주실적업체	Y/YSP외주실적업체	N" )
 column=(type=char(2) update=yes updatewhereclause=yes name=set_sdate dbname="supp.set_sdate" values="말	말/01	01/02	02/03	03/04	04/05	05/06	06/07	07/08	08/09	09/10	10/11	11/12	12/13	13/14	14/15	15/16	16/17	17/18	18/19	19/20	20/21	21/22	22/23	23/24	24/25	25/26	26/27	27/28	28/29	29/30	30/31	31/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=use_yn dbname="use_yn" initial="N" values="	N/	Y" )
 retrieve="  SELECT supp.supp_no,   
         supp.register_no,   
         supp.supp_name,   
         supp.captain_name,   
         supp.addr,   
         supp.contact,   
         supp.position,   
         supp.tel_no,   
         supp.rem,   
         supp.buyer,   
         supp.industry_type,   
         supp.industry_code,   
         supp.credit_limit,   
         supp.terms,   
         supp.fob,   
         supp.last_tran_date,   
         supp.currency_type,   
         supp.fax_no,   
         supp.subcon,   
         supp.type,   
         supp.round,   
         supp.yspsub_flag,   
         supp.set_sdate  ,
         use_yn  = supp.use_yn
    FROM supp  
   WHERE ( supp.supp_no = :as_supp )    
" update="supp" updatewhere=1 updatekeyinplace=no arguments=(("as_supp", string)) )
