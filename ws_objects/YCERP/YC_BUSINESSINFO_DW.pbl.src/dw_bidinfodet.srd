 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"bdinfo~" )  TABLE(NAME=~"bdinfodet~" ) COLUMN(NAME=~"bdinfodet.build_no~") COLUMN(NAME=~"bdinfodet.seq~") COLUMN(NAME=~"bdinfodet.status~") COLUMN(NAME=~"bdinfodet.completiondate~") COLUMN(NAME=~"bdinfodet.predate~") COLUMN(NAME=~"bdinfodet.workarea~") COLUMN(NAME=~"bdinfodet.bulidingphone~") COLUMN(NAME=~"bdinfodet.buildingcom~") COLUMN(NAME=~"bdinfodet.floors~") COLUMN(NAME=~"bdinfodet.city~") COLUMN(NAME=~"bdinfodet.dong~") COLUMN(NAME=~"bdinfodet.spec~") COLUMN(NAME=~"bdinfodet.master~") COLUMN(NAME=~"bdinfodet.quantity~") COLUMN(NAME=~"bdinfodet.designoffice~") COLUMN(NAME=~"bdinfodet.square~") COLUMN(NAME=~"bdinfodet.project~") COLUMN(NAME=~"bdinfodet.person~") COLUMN(NAME=~"bdinfodet.sitedate~") COLUMN(NAME=~"bdinfodet.biddate~") COLUMN(NAME=~"bdinfodet.conkind~") COLUMN(NAME=~"bdinfodet.actcash~") COLUMN(NAME=~"bdinfodet.offcash~") COLUMN(NAME=~"bdinfodet.partcom~") COLUMN(NAME=~"bdinfodet.bidcash~") COLUMN(NAME=~"bdinfodet.lastcom~") COLUMN(NAME=~"bdinfodet.rem~") COLUMN(NAME=~"bdinfodet.salequantity~") COLUMN(NAME=~"bdinfodet.bid_chk~") COLUMN(NAME=~"bdinfodet.etmt_chk~") COLUMN(NAME=~"bdinfodet.std_chk~")    JOIN (LEFT=~"bdinfodet.build_no~"    OP =~"=~"RIGHT=~"bdinfo.build_no~" )WHERE(    EXP1 =~"bdinfo.build_no~"   OP =~"=~"    EXP2 =~":arg_build_no~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"bdinfodet.bid_chk~"   OP =~"=~"    EXP2 =~"'1'~" ) ) ARG(NAME = ~"arg_build_no~" TYPE = string) " update="bdinfodet" updatewhere=0 updatekeyinplace=no arguments=(("arg_build_no", string)) )
