table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="itemloc.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=qa dbname="itemloc.qa" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=loc_no dbname="itemloc.loc_no" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=balbf dbname="itemloc.balbf" initial="0.0000" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=receipt_qty dbname="itemloc.receipt_qty" initial="0.0000" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=issue_qty dbname="itemloc.issue_qty" initial="0.0000" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=qoh dbname="itemloc.qoh" initial="0.0000" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=reserved dbname="itemloc.reserved" initial="0.0000" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=balbf_fifo_cost dbname="itemloc.balbf_fifo_cost" initial="0.0000" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"itemloc~" ) COLUMN(NAME=~"itemloc.item_no~") COLUMN(NAME=~"itemloc.qa~") COLUMN(NAME=~"itemloc.loc_no~") COLUMN(NAME=~"itemloc.balbf~") COLUMN(NAME=~"itemloc.receipt_qty~") COLUMN(NAME=~"itemloc.issue_qty~") COLUMN(NAME=~"itemloc.qoh~") COLUMN(NAME=~"itemloc.reserved~") COLUMN(NAME=~"itemloc.balbf_fifo_cost~")WHERE(    EXP1 =~"itemloc.item_no~"   OP =~"=~"    EXP2 =~":as_item~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"itemloc.qa~"   OP =~"=~"    EXP2 =~":as_qa~" ) ) ARG(NAME = ~"as_item~" TYPE = string)  ARG(NAME = ~"as_qa~" TYPE = string) " update="itemloc" updatewhere=1 updatekeyinplace=no arguments=(("as_item", string),("as_qa", string)) )
