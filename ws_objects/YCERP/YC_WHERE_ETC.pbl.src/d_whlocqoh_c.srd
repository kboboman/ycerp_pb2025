table(column=(type=decimal(4) updatewhereclause=yes name=qoh dbname="itemloc.qoh" initial=" " )
 column=(type=char(30) updatewhereclause=yes name=location_loc_name dbname="location.loc_name" )
 column=(type=char(10) updatewhereclause=yes name=itemloc_loc_no dbname="itemloc.loc_no" initial=" " )
 column=(type=char(10) updatewhereclause=yes name=location_area_no dbname="location.area_no" )
 retrieve="  SELECT itemloc.qoh,   
         location.loc_name,   
         itemloc.loc_no,
         location.area_no  
    FROM itemloc,   
         location  
   WHERE ( itemloc.loc_no = location.loc_no )    
"  sort="itemloc_loc_no A " )
