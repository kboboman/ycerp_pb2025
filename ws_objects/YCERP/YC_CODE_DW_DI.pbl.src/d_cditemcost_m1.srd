$PBExportHeader$d_cditemcost_m1.srd
$PBExportComments$물품별 표준단가(1998/3/14, 성삼지)
release 8;
datawindow(units=0 timer_interval=0 color=67108864 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="itemcost.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=qa dbname="itemcost.qa" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="itemcost.uom" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=old_price dbname="itemcost.old_price" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=price dbname="itemcost.price" )
 column=(type=char(30) update=yes updatewhereclause=yes name=rem dbname="itemcost.rem" )
 column=(type=datetime update=yes updatewhereclause=yes name=tran_date dbname="itemcost.tran_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=user_id dbname="itemcost.user_id" )
 column=(type=char(1) update=yes updatewhereclause=yes name=upda_chk dbname="itemcost.upda_chk" values="	Y/	N" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=price_min dbname="itemcost.price_min" )
 column=(type=datetime update=yes updatewhereclause=yes name=min_date dbname="itemcost.min_date" initial="getdtae()" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="groupitem.item_name" )
 column=(type=long updatewhereclause=yes name=cust_cnt dbname="cust_cnt" )
 column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" values="	Y/	N" )
 retrieve="  SELECT itemcost.item_no     
       , itemcost.qa          
       , itemcost.uom         
       , itemcost.old_price   
       , itemcost.price       
       , itemcost.rem         
       , itemcost.tran_date   
       , itemcost.user_id     
       , itemcost.upda_chk  
       , itemcost.price_min  
       , itemcost.min_date  
       , groupitem.item_name
       , cust_cnt = isnull(custitem.cnt,0)
       , chk      = 'N'
    FROM itemcost
         LEFT OUTER JOIN groupitem  ON itemcost.item_no = groupitem.item_no  
         LEFT OUTER JOIN (
              SELECT item_no, qa, cnt = count(cust_no)  FROM custitem GROUP BY item_no, qa
         ) custitem   ON itemcost.item_no = custitem.item_no AND itemcost.qa = custitem.qa
   WHERE itemcost.item_no = :as_itemno    
" update="itemcost" updatewhere=1 updatekeyinplace=no arguments=(("as_itemno", string))  sort="item_name A qa A uom A " )
