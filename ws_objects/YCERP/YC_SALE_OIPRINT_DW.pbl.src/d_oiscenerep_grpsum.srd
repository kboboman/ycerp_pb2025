detail(height=80 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(11) updatewhereclause=yes name=do_spot_code dbname="spot_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene_desc" )
 column=(type=char(14) updatewhereclause=yes name=do_do_no dbname="do_no" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_total dbname="do_total" )
 retrieve="  SELECT cust_no      = a.cust_no
       , cust_name    = a.cust_name
       , spot_code    = a.spot_code    
       , scene_desc   = a.scene_desc    
       , do_no        = a.do_no        
       , do_total     = SUM(a.do_cash)      
    FROM (
         SELECT cust_no    = do.cust_no
              , cust_name  = customer.cust_name
              , spot_code  = do.spot_code   
              , scene_desc = scene.scene_desc   
              , do_no      = do.do_no   
              , do_cash    = do.do_cash
           FROM scene_grpdtl
              , do      
              , scene   
              , customer  
          WHERE ((:as_project   = '%') OR
                 (:as_project  <> '%' AND scene_grpdtl.project = :as_project)
                )
            AND ( scene_grpdtl.scene_code = do.spot_code )
            AND ( do.cust_no    = scene.cust_no     )   
            AND ( do.spot_code  = scene.scene_code  )   
            AND ( do.cust_no    = customer.cust_no  )   
            AND ( do.spot_code IS NOT NULL          )    
            AND ( do.do_date       BETWEEN :ad_sdate AND :ad_edate )
            AND ( customer.salesman   LIKE :as_salesman )
        ) A
  GROUP BY a.cust_no
         , a.cust_name
         , a.spot_code    
         , a.scene_desc    
         , a.do_no        
" arguments=(("as_project", string),("ad_sdate", date),("ad_edate", date),("as_salesman", string))  sort="cust_name A scene_scene_desc A do_do_no A " )
