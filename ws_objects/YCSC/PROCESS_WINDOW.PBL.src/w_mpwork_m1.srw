      dw9.object.work1[ll_dw9row]    = "0"
      dw9.object.work2[ll_dw9row]    = "0"
      dw9.object.work3[ll_dw9row]    = "0"
      dw9.object.bigo[ll_dw9row]     = ls_bigo		
	end if
next
