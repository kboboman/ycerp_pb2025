$PBExportComments$운반비변경요청서 (2002/08/28,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="553648127" )
footer(height=72 color="8421504" )
detail(height=152 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=area_name dbname="area_name" )
 column=(type=datetime updatewhereclause=yes name=doship_doship_date dbname="doship.doship_date" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene.scene_desc" )
 column=(type=char(180) updatewhereclause=yes name=sale_no dbname="sale_no" )
 column=(type=char(14) updatewhereclause=yes name=doshipdet_do_no dbname="doshipdet.do_no" )
 column=(type=char(60) updatewhereclause=yes name=doshipdet_ship_reason1 dbname="doshipdet.ship_reason1" )
 column=(type=char(60) updatewhereclause=yes name=doshipdet_ship_reason2 dbname="doshipdet.ship_reason2" )
 column=(type=char(60) updatewhereclause=yes name=doshipdet_ship_reason3 dbname="doshipdet.ship_reason3" )
 column=(type=decimal(0) updatewhereclause=yes name=do_ship_amount dbname="do.ship_amount" )
 retrieve="  SELECT area_name = (case :as_area when '%' then '전체사업장' else area.area_name end)   
       , doship.doship_date   
       , customer.cust_name   
       , scene.scene_desc     
       , sale_no = DBO.uf_getdosaleno(doshipdet.do_no)   
       , doshipdet.do_no   
       , ship_reason1
       , ship_reason2
       , ship_reason3
       , do.ship_amount
    FROM doshipdet   
       , do       
       , customer    
       , scene    
       , doship   
       , area           
   WHERE ( doshipdet.do_no              = do.do_no         )   
     AND ( do.cust_no                   = customer.cust_no )   
     AND ( do.spot_code                 = scene.scene_code )   
     AND ( doshipdet.doship_no          = doship.doship_no )   
     AND ( doship.area_no               = area.area_no     )   
     AND ( doship.area_chk              = 'Y'              )   
     AND ( doshipdet.new_shipflag       = 'B'              )   
     AND ( convert(char(10),doship.doship_date,111)     between :as_sdate and :as_edate ) 
     AND ( doship.process_flag       like :as_flag   )  
     AND ( doship.area_no            like :as_area   )  
         
  UNION ALL
  
  SELECT area_name = (case :as_area when '%' then '전체사업장' else area.area_name end) 
       , doshipetc.etc_date   
       , customer.cust_name   
       , scene.scene_desc     
       , doshipetc.sale_no    
       , doshipetc.do_no      
       , doshipetc.rem      
       , rem2              
       , rem3              
       , doshipetc.ship_amount
    FROM doshipetc   
       , customer    
       , scene    
       , area     
   WHERE ( doshipetc.cust_no        = customer.cust_no      )   
     AND ( doshipetc.scene_code     = scene.scene_code      )   
     AND ( doshipetc.ship_flag      = 'B'                   )   
     AND ( doshipetc.area_chk       = 'Y'                   )   
     AND ( doshipetc.etc_area       = area.area_no          )   
     AND ( convert(char(10),doshipetc.etc_date,111)   between :as_sdate and :as_edate )   
     AND ( doshipetc.etc_flag    like :as_flag              )  
     AND ( doshipetc.etc_area    like :as_area              )      
" arguments=(("as_sdate", string),("as_edate", string),("as_flag", string),("as_area", string))  sort="area_name A doship_doship_date A customer_cust_name A scene_scene_desc A sale_no A " )
