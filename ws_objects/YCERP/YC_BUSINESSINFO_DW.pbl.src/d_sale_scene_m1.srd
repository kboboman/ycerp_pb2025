table(column=(type=decimal(0) update=yes updatewhereclause=yes key=yes identity=yes name=personal_id dbname="msale_personal_connection.personal_id" )
 column=(type=char(20) update=yes updatewhereclause=yes name=name dbname="msale_personal_connection.name" )
 column=(type=char(20) update=yes updatewhereclause=yes name=tel dbname="msale_personal_connection.tel" )
 column=(type=char(2) update=yes updatewhereclause=yes name=kind dbname="msale_personal_connection.kind" values="건설사	01/설계사	02/감리처	03/시공업체	04/시행사	05/" )
 column=(type=char(40) update=yes updatewhereclause=yes name=company dbname="msale_personal_connection.company" )
 column=(type=char(4) update=yes updatewhereclause=yes name=company_code dbname="msale_personal_connection.company_code" )
 column=(type=char(20) update=yes updatewhereclause=yes name=level dbname="msale_personal_connection.level" )
 column=(type=char(20) update=yes updatewhereclause=yes name=job dbname="msale_personal_connection.job" )
 column=(type=char(100) update=yes updatewhereclause=yes name=personal_story dbname="msale_personal_connection.personal_story" )
 column=(type=char(8) update=yes updatewhereclause=yes name=write_date dbname="msale_personal_connection.write_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=write_user_id dbname="msale_personal_connection.write_user_id" )
 column=(type=char(1) update=yes updatewhereclause=yes name=important_level dbname="msale_personal_connection.important_level" values="상	1/중	2/하	3/" )
 column=(type=char(10) updatewhereclause=yes name=v_msale_all_user_write_user_name dbname="V_MSALE_ALL_USER.write_user_name" )
 column=(type=char(8) update=yes updatewhereclause=yes name=modify_date dbname="msale_personal_connection.modify_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=modify_user_id dbname="msale_personal_connection.modify_user_id" )
 column=(type=char(30) update=yes updatewhereclause=yes name=email dbname="msale_personal_connection.email" )
 column=(type=char(10) updatewhereclause=yes name=v_msale_all_user_modify_user_name dbname="V_MSALE_ALL_USER.modify_user_name" )
 retrieve="select    MSALE_PERSONAL_CONNECTION.personal_id,
              MSALE_PERSONAL_CONNECTION.name,
              MSALE_PERSONAL_CONNECTION.tel,
              MSALE_PERSONAL_CONNECTION.kind,
              MSALE_PERSONAL_CONNECTION.company,
              MSALE_PERSONAL_CONNECTION.company_code,
              MSALE_PERSONAL_CONNECTION.level,
              MSALE_PERSONAL_CONNECTION.job,
              MSALE_PERSONAL_CONNECTION.personal_story,
              MSALE_PERSONAL_CONNECTION.write_date,
              MSALE_PERSONAL_CONNECTION.write_user_id,
              MSALE_PERSONAL_CONNECTION.important_level,
              b.user_name write_user_name,
              MSALE_PERSONAL_CONNECTION.modify_date,
              MSALE_PERSONAL_CONNECTION.modify_user_id,
		    MSALE_PERSONAL_CONNECTION.email,
              c.user_name modify_user_name
from MSALE_PERSONAL_CONNECTION left outer join V_MSALE_ALL_USER b on MSALE_PERSONAL_CONNECTION.write_user_id = b.user_id
								  left outer join V_MSALE_ALL_USER c on MSALE_PERSONAL_CONNECTION.modify_user_id = c.user_id
                                            inner join MSALE_PERSONAL_CONNECTION_SCENE  on MSALE_PERSONAL_CONNECTION.personal_id = MSALE_PERSONAL_CONNECTION_SCENE.personal_id
where MSALE_PERSONAL_CONNECTION_SCENE.scene_code = :as_scene_code
" update="MSALE_PERSONAL_CONNECTION" updatewhere=0 updatekeyinplace=no arguments=(("as_scene_code", string)) )
