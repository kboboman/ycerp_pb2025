event clicked;//
String ls_item
Long   ll_row, ll_idx, lY
datawindow dwfind

if rb_5.checked = true then
	dwfind = dw15
elseif rb_3.checked = true then
	dwfind = dw7
else
	dwfind = dw10
end if

lY = dwfind.getrow()
ls_item = trim(tab_1.tabpage_4.sle_1.text)
if lY > 0 and lY < dwfind.rowcount() then
	for ll_row = 1 to dwfind.rowcount()
		IF ls_item = dwfind.object.item_nm[ll_row] THEN
			dwfind.scrolltorow(ll_row)
			dwfind.SelectRow(0,  false)
			dwfind.SelectRow(ll_row, true)			
		end if
	next
end if

end event

