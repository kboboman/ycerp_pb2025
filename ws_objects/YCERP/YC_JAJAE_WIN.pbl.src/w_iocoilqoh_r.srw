event dw_2::itemchanged;//
DatawindowChild ldwc_item
string ls_cat

debugbreak()

this.accepttext()

this.getchild("item_no", ldwc_item)
ldwc_item.settransobject(sqlca)

is_loc  = trim(this.object.loc_no[1])
is_item = trim(this.object.item_no[1])
is_flag = trim(this.object.flag[1])
if dwo.name = 'flag' then
	if data = 'S' then
		dw_1.dataobject = 'd_iocoilqoh_r1'
	else
		dw_1.dataobject = 'd_iocoilqoh_r'
	end if
	dw_1.settransobject(sqlca)
			
	ls_cat = this.object.flag[1]
	if isnull(ls_cat) or ls_cat = "" then
	else
		if ls_cat = "%" then
			ls_cat = ""
		else
			ls_cat = "cat = '" + ls_cat + "'"
		end if
		ldwc_item.SetFilter( ls_cat )			
		ldwc_item.Filter()
	end if	
end if

ddlb_dwtitles.reset()
ddlb_dwtitles.visible = false
GF_DWTitle2ddlb( dw_1, ddlb_fld, ddlb_dwtitles )

end event

event dw_2::itemfocuschanged;call super::itemfocuschanged;//
DatawindowChild ldwc_loc
string ls_cat, ls_colname, ls_shipqty
long   ll_len

this.getchild("loc_no", ldwc_loc)
ldwc_loc.settransobject(sqlca)

choose case dwo.name
	case 'loc_no'
		ls_colname = ldwc_loc.getitemstring(ldwc_loc.getrow(), "loc_name")
		ll_len     = LenA(ls_colname)
		this.SelectText( 1, LenA( ls_colname ) )
		this.SetFocus()
end choose

end event

