table(column=(type=char(10) updatewhereclause=yes name=itemloc_item_no dbname="itemloc.item_no" initial=" " )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" initial=" " )
 column=(type=char(20) updatewhereclause=yes name=itemloc_qa dbname="itemloc.qa" )
 column=(type=char(2) updatewhereclause=yes name=groupitem_uom dbname="groupitem.uom" initial=" " )
 column=(type=decimal(4) updatewhereclause=yes name=qoh dbname="qoh" )
 column=(type=decimal(4) updatewhereclause=yes name=reserved dbname="reserved" )
 column=(type=char(10) updatewhereclause=yes name=itemjaego_item_no dbname="itemjaego.item_no" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"itemloc~" )  TABLE(NAME=~"itemjaego~" )  TABLE(NAME=~"groupitem~" )  TABLE(NAME=~"location~" ) COLUMN(NAME=~"itemloc.item_no~") COLUMN(NAME=~"groupitem.item_name~") COLUMN(NAME=~"itemloc.qa~") COLUMN(NAME=~"groupitem.uom~") COMPUTE(NAME=~"sum(itemloc.qoh) qoh~") COMPUTE(NAME=~"sum(itemloc.reserved) reserved~") COLUMN(NAME=~"itemjaego.item_no~")    JOIN (LEFT=~"itemloc.item_no~"    OP =~"=~"RIGHT=~"itemjaego.item_no~"    OUTER1 =~"itemloc.item_no~" )    JOIN (LEFT=~"itemloc.qa~"    OP =~"=~"RIGHT=~"itemjaego.qa~"    OUTER1 =~"itemloc.qa~" )    JOIN (LEFT=~"itemloc.item_no~"    OP =~"=~"RIGHT=~"groupitem.item_no~" )    JOIN (LEFT=~"itemloc.loc_no~"    OP =~"=~"RIGHT=~"location.loc_no~" )WHERE(    EXP1 =~"location.loc_type~"   OP =~"=~"    EXP2 =~"'N'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"itemloc.item_no~"   OP =~"like~"    EXP2 =~":arg_str~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"groupitem.item_name~"   OP =~"like~"    EXP2 =~":arg_name~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"itemjaego.area_no~"   OP =~"=~"    EXP2 =~":as_area~" )  GROUP(NAME=~"itemloc.item_no~") GROUP(NAME=~"itemloc.qa~") GROUP(NAME=~"itemjaego.item_no~") GROUP(NAME=~"groupitem.item_no~") GROUP(NAME=~"groupitem.uom~") GROUP(NAME=~"groupitem.item_name~")) ORDER(NAME=~"itemloc.item_no~" ASC=yes )  ORDER(NAME=~"itemloc.qa~" ASC=yes ) ARG(NAME = ~"arg_str~" TYPE = string)  ARG(NAME = ~"arg_name~" TYPE = string)  ARG(NAME = ~"as_area~" TYPE = string) " filter="isNull( itemjaego_item_no )" arguments=(("arg_str", string),("arg_name", string),("as_area", string)) )
