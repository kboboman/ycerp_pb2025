event rowfocuschanged;This.SelectRow(0, False)
This.ScrollToRow(currentrow)
This.SelectRow(currentrow, True)

end event

event clicked;if row < 1 then return
this.SelectRow(0,  false)
this.SelectRow(row, true)

this.scrolltorow(row)
end event

type dw_15 from datawindow within tabpage_4
integer x = 626
integer y = 344
integer width = 2958
integer height = 1028
integer taborder = 22
boolean bringtotop = true
string title = "집계"
string dataobject = "d_whitemret_r_allrpt"
boolean hscrollbar = true
boolean vscrollbar = true
boolean hsplitscroll = true
boolean livescroll = true
borderstyle borderstyle = stylelowered!
end type

event clicked;//
is_dw  = this.classname()
GF_DWTitle2ddlb( this, ddlb_fld, ddlb_dwtitles )
GF_DWClick2Info(this, ddlb_fld, ddlb_op, sle_value, row, dwo.name, ddlb_dwtitles)
//
if row < 1 then return

this.SelectRow(0,  false)
this.SelectRow(row, true)

string ls_item, ls_qa, ls_value
long   ll_row

choose case dwo.name
	case "item_no"
		ls_value = this.object.item_no[row]
	case "item_nm"
		ls_value = this.object.item_nm[row]
	case "qa"
		ls_value = this.object.qa[row]
	case "cdate"
		ls_value = this.object.cdate[row]
	case "key_no"
		ls_value = this.object.key_no[row]
end choose
tab_1.tabpage_4.sle_1.text = ls_value


ls_item = this.object.item_no[row]
ls_qa   = this.object.qa[row]
if row > 0 and row < this.rowcount() then
	this.scrolltorow(row)

	ls_item = this.object.item_no[row]
	ls_qa   = this.object.qa[row]
	for ll_row = 1 to dw7.rowcount()
		if ls_item = dw7.object.item_no[ll_row] and ls_qa = dw7.object.qa[ll_row] then
			dw7.scrolltorow(ll_row)
		end if
	next
end if

end event

