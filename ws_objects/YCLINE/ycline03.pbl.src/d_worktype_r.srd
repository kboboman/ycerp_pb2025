release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=84 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=coilorder_order_no dbname="coilorder.order_no" )
 column=(type=char(14) updatewhereclause=yes name=coilorderdet_order_no dbname="coilorderdet.order_no" )
 column=(type=long updatewhereclause=yes name=coilorderdet_order_seq dbname="coilorderdet.order_seq" )
 column=(type=char(20) updatewhereclause=yes name=coilorderdet_coil_no dbname="coilorderdet.coil_no" )
 column=(type=char(80) updatewhereclause=yes name=summary dbname="summary" )
 column=(type=long updatewhereclause=yes name=coilorderdet_div dbname="coilorderdet.div" initial="0" values=" 2 등분	2/ 3 등분	3/ 4 등분	4/ 5 등분	5/" )
 column=(type=char(1) updatewhereclause=yes name=coilorderdet_work_type dbname="coilorderdet.work_type" )
 retrieve="SELECT distinct coilorder.order_no   
     , coilorderdet.order_no         
     , coilorderdet.order_seq        
     , coilorderdet.coil_no          
     , summary = dbo.uf_getcoilunitqty(coilorderdet.order_no, coilorderdet.work_type)
     , coilorderdet.div
     , coilorderdet.work_type
  FROM coilmst        
     , coilorder      
     , coilorderdet   
     , coilsliting    
     , groupitem  
 WHERE ( coilorderdet.order_no = coilsliting.order_no         )   
   and ( coilorder.order_no    = coilorderdet.coilorder_order )   
   and ( coilorderdet.coil_no  = coilmst.coil_no              )   
   and ( coilmst.item_no       = groupitem.item_no            )   
   and ( coilorderdet.loc_no   = coilmst.loc_no               )   
   and ( coilorderdet.order_no = :as_order_no                 )
" arguments=(("as_order_no", string)) )
