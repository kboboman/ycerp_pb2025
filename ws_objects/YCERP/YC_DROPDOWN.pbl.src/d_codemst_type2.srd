$PBExportComments$CODEMST 타입별
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=item_cd dbname="item_cd" )
 column=(type=char(50) updatewhereclause=yes name=item_nm dbname="item_nm" )
 column=(type=long updatewhereclause=yes name=sort dbname="sort" )
 column=(type=char(50) updatewhereclause=yes name=type dbname="type" )
 column=(type=char(255) updatewhereclause=yes name=bigo dbname="bigo" )
 retrieve="  SELECT item_cd = rtrim(item_cd)
       , item_nm = rtrim(item_nm)
       , sort    = sort
       , type    = rtrim(type)
       , bigo    = replace(rtrim(bigo),'-','')
    FROM codemst   
   WHERE type   LIKE :as_type AND use_yn = 'Y'
   ORDER BY sort
" arguments=(("as_type", string))  sort="sort A " )
compute(band=footer alignment="2" expression="rowcount()"border="0" color="0" x="178" y="4" height="72" width="850" format="#,##0" html.valueishtml="0"  name=compute_1 visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="553648127" )
column(band=detail id=1 alignment="2" tabsequence=32766 border="0" color="33554432" x="9" y="4" height="72" width="160" format="[general]" html.valueishtml="0"  name=item_cd visible="1" edit.limit=20 edit.case=any edit.focusrectangle=no edit.autoselect=yes edit.autohscroll=yes edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
column(band=detail id=2 alignment="0" tabsequence=32766 border="0" color="33554432" x="178" y="4" height="72" width="850" format="[general]" html.valueishtml="0"  name=item_nm visible="1" edit.limit=50 edit.case=any edit.focusrectangle=no edit.autoselect=yes edit.autohscroll=yes edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
