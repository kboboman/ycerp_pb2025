 column=(type=long updatewhereclause=yes name=sfcret_cnt dbname="sfcret.cnt" )
 column=(type=long updatewhereclause=yes name=sfcret_length dbname="sfcret.length" )
 column=(type=char(1) updatewhereclause=yes name=sfcret_coil_type dbname="sfcret.coil_type" )
 column=(type=char(17) updatewhereclause=yes name=sfcret_order_no dbname="sfcret.order_no" )
 column=(type=char(30) updatewhereclause=yes name=sfcret_rem dbname="sfcret.rem" )
 column=(type=char(20) update=yes updatewhereclause=yes name=sfcret_wcoil_no dbname="sfcret.wcoil_no" )
 column=(type=char(20) updatewhereclause=yes name=ccoil dbname="ccoil" )
 column=(type=char(20) updatewhereclause=yes name=coilmst_coil_no dbname="coilmst.coil_no" )
 retrieve="  SELECT sfcret.*,
   		ccoil = ( substring(sfcret.coil_no, 1, datalength(rtrim(sfcret.coil_no)) - 2)),
         coilmst.coil_no
    FROM sfcret left outer join coilmst on (substring(sfcret.coil_no, 1, datalength(rtrim(sfcret.coil_no)) - 2)) = coilmst.coil_no
   WHERE ( sfcret.coil_no is not null ) 
order by sfcret.ret_date desc" update="sfcret" updatewhere=0 updatekeyinplace=no  sort="sfcret_wcoil_no A sfcret_ret_date D sfcret_seq_no A " )
