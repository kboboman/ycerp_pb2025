m_inaudittype m_inaudittype
m_-1 m_-1
m_quit m_quit
m_exit m_exit
end type

on m_manage.create
call super::create
this.text = "관리(&Manage)"
this.m_reg=create m_reg
this.m_auth=create m_auth
this.m_codemst_m=create m_codemst_m
this.m_-=create m_-
this.m_user=create m_user
this.m_globals_m=create m_globals_m
this.m_cdteam=create m_cdteam
this.m_1=create m_1
this.m_직급코드관리=create m_직급코드관리
this.m_-4=create m_-4
this.m_magam_m=create m_magam_m
this.m_inaudittype=create m_inaudittype
this.m_-1=create m_-1
this.m_quit=create m_quit
this.m_exit=create m_exit
this.Item[UpperBound(this.Item)+1]=this.m_reg
this.Item[UpperBound(this.Item)+1]=this.m_auth
this.Item[UpperBound(this.Item)+1]=this.m_codemst_m
this.Item[UpperBound(this.Item)+1]=this.m_-
this.Item[UpperBound(this.Item)+1]=this.m_user
this.Item[UpperBound(this.Item)+1]=this.m_globals_m
this.Item[UpperBound(this.Item)+1]=this.m_cdteam
this.Item[UpperBound(this.Item)+1]=this.m_1
this.Item[UpperBound(this.Item)+1]=this.m_직급코드관리
this.Item[UpperBound(this.Item)+1]=this.m_-4
this.Item[UpperBound(this.Item)+1]=this.m_magam_m
this.Item[UpperBound(this.Item)+1]=this.m_inaudittype
this.Item[UpperBound(this.Item)+1]=this.m_-1
this.Item[UpperBound(this.Item)+1]=this.m_quit
this.Item[UpperBound(this.Item)+1]=this.m_exit
end on

on m_manage.destroy
call super::destroy
destroy(this.m_reg)
destroy(this.m_auth)
destroy(this.m_codemst_m)
destroy(this.m_-)
destroy(this.m_user)
destroy(this.m_globals_m)
destroy(this.m_cdteam)
destroy(this.m_1)
destroy(this.m_직급코드관리)
destroy(this.m_-4)
destroy(this.m_magam_m)
destroy(this.m_inaudittype)
destroy(this.m_-1)
destroy(this.m_quit)
destroy(this.m_exit)
end on

