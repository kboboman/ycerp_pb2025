 retrieve="SELECT 	    a.scene_code,
                    a.scene_name,
                    a.con_code,
                    b.con_name,
                    a.order_name,
                    a.design_name,
                    a.audit_name,
                    a.interior_name,
                    a.design_date,
                    a.completaion_date,
                    (case when a.process = 'A' then '설계중'
                                 when a.process = 'B' then '착공'
                                 when a.process = 'C' then '터파기'
                                 when a.process = 'D' then '지하골조'
                                 when a.process = 'E' then '지상골조(저층)'
                                 when a.process = 'F' then '입찰예정'
                                 when a.process = 'G' then '수장결정'
                                 when a.process = 'H' then '공사수주(종결)'
                                 when a.process = 'I'   then '영업이관(종결)'
                      end ) process_name,
                    ( case   when  a.scale_level = 'B'  then '대'
                                  when a.scale_level = 'M' then '중'
                                  when a.scale_level = 'S'  then '소'
                       end ) scale_level_name,
                    a.scale_detail,
                    a.site,
                    a.yc_spec,
                    a.person1,
                    d.user_name person1_user_name,
                    a.person2,
                    a.person3,
                    a.erp_scene_code,
                    (case when isnull(c.write_date, a.modify_date) =  convert(char(10), getdate(), 112) then '오늘' else convert(char(10), convert(datetime, isnull(c.write_date, a.modify_date) ), 102) end) write_date,
                    isnull(a.ceo_yn, 'N') ceo_yn,
       		   ( CASE WHEN isnull(A.SALE_END_YN,'Y') = 'N' then '종결' else ( case when a.important_level = 'F' then '긴급'
																								 when a.important_level = 'N' then '중간'
																								 when a.important_level = 'S' then '여유'
																					  			end )
                                                                                                                           end ) important_level,
				  f.work,
				 a.scale_detail scale_detail,
				  G.interior_name1,
				  G.wall1, 
				  G.ceilling1, 
				  G.pilotis1,
				  G.etc1,
				  G.salesman1,
				  G.interior_name2,
				  G.wall2, 
				  G.ceilling2, 
				  G.pilotis2,
				  G.etc2,
				  G.salesman2,
				  G.interior_name3,
				  G.wall3, 
				  G.ceilling3, 
				  G.pilotis3,        
				  G.etc3,
				  G.salesman3,
				  G.interior_name4,
				  G.wall4, 
				  G.ceilling4, 
				  G.pilotis4,                
				  G.etc4,
				  G.salesman4,
				  G.interior_name5,
				  G.wall5, 
				  G.ceilling5, 
				  G.pilotis5,                        
				  G.etc5,
				  G.salesman5,
				  G.interior_name6,
				  G.wall6, 
				  G.ceilling6, 
				  G.pilotis6,                                
				  G.etc6,
				  G.salesman6,
				  G.interior_name7,
				  G.wall7, 
				  G.ceilling7, 
				  G.pilotis7,
				  G.etc7,
				  G.salesman7,
                       (case when :as_project_code = '%' then '전체' else h.project_name end )  project_name
FROM SALE_SCENE a with(nolock) inner join construction b with(nolock) on  a.con_code = b.con_code
											 left outer join (
																	 select  a.scene_code, a.write_date, max(a.seq) seq
																	 from sale_scene_history a with(nolock) inner join (
																																			select  scene_code, 
																																					  max(write_date) write_date
																																			from sale_scene_history with(nolock)
																																			  where ISNULL(chk, 'N') = 'Y'
																																			group by scene_code
																																	 ) b on a.scene_code = b.scene_code and a.write_date = b.write_date
																	 where ISNULL(a.chk, 'N') = 'Y'
																	 group by  a.scene_code, a.write_date
															 ) c on a.scene_code = c.scene_code
											  left outer join LOGIN D WITH(NOLOCK) ON A.PERSON1 = D.USER_ID
											  left outer join  (
																	 select a.scene_code, 
																				  a.write_date,
																				  a.seq,
																				  a.work
																	 from sale_scene_history a with(nolock) inner join
																	 (
																		  select a.scene_code, a.write_date, max(a.seq) seq
																		  from sale_scene_history a with(nolock) inner join     (
																																					select scene_code, max(write_date) write_date
																																					from sale_scene_history with(nolock)
																																					where ISNULL(chk,'N') = 'Y'
																																						and write_date between :as_fr_date and :as_to_date
																																					group by scene_code
																																			  ) b on a.scene_code = b.scene_code and a.write_date = b.write_date
																		  where ISNULL(a.chk,'N') = 'Y'
																			  and a.write_date between :as_fr_date and :as_to_date
																		  group by a.scene_code, a.write_date
																	 ) b on a.scene_code = b.scene_code and a.write_date = b.write_date and a.seq = b.seq
															 ) f on a.scene_code = f.scene_code
											left outer join (

																	 select  a.scene_code,
																				max(a.interior_name1) interior_name1,
																				max(a.wall1) wall1, 
																				max(a.ceilling1) ceilling1, 
																				max(a.pilotis1) pilotis1,
																				max(a.etc1) etc1,
																				max(a.salesman1) salesman1,
																				max(a.interior_name2) interior_name2,
																				max(a.wall2) wall2, 
																				max(a.ceilling2) ceilling2, 
																				max(a.pilotis2) pilotis2,
																				max(a.etc2) etc2,
																				max(a.salesman2) salesman2,                                        
																				max(a.interior_name3) interior_name3,
																				max(a.wall3) wall3, 
																				max(a.ceilling3) ceilling3, 
																				max(a.pilotis3) pilotis3,
																				max(a.etc3) etc3,
																				max(a.salesman3) salesman3,                                        
																				max(a.interior_name4) interior_name4,
																				max(a.wall4) wall4, 							
																				max(a.ceilling4) ceilling4, 
																				max(a.pilotis4) pilotis4,
																				max(a.etc4) etc4,
																				max(a.salesman4) salesman4,                                        
																				max(a.interior_name5) interior_name5,
																				max(a.wall5) wall5, 
																				max(a.ceilling5) ceilling5, 
																				max(a.pilotis5) pilotis5,
																				max(a.etc5) etc5,
																				max(a.salesman5) salesman5,                                        
																				max(a.interior_name6) interior_name6,
																				max(a.wall6) wall6, 
																				max(a.ceilling6) ceilling6, 
																				max(a.pilotis6) pilotis6,
																				max(a.etc6) etc6,
																				max(a.salesman6) salesman6,                                        
																				max(a.interior_name7) interior_name7,
																				max(a.wall7) wall7, 
																				max(a.ceilling7) ceilling7, 
																				max(a.pilotis7) pilotis7,
																				max(a.etc7) etc7,
																				max(a.salesman7) salesman7                                        
																	 from 
																	 (
																				  select   scene_code,
																						  interior_name interior_name1, 
																						 wall wall1, 
																						ceilling ceilling1, 
																						pilotis pilotis1,  
																				 		etc etc1,
                                            														salesman salesman1,
																						null interior_name2,  
																						null wall2,
																						null ceilling2, 
																						null pilotis2,
																				 		null etc2,
                                            														null salesman2,                                            
																						null interior_name3,  
																						null wall3,
																						null ceilling3, 
																						null pilotis3,
																				 		null etc3,
                                           														null salesman3,                                            
																						null interior_name4,  
																						null wall4,
																						null ceilling4, 
																						null pilotis4,
																				 		null etc4,
                                            														null salesman4,                                            
																						null interior_name5,  
																						null wall5,
																						null ceilling5, 
																						null pilotis5,
																				 		null etc5,
                                            														null salesman5,                                            
																						null interior_name6,  
																						null wall6,
																						null ceilling6, 
																						null pilotis6,
																				 		null etc6,
                                            														null salesman6,                                            
																						null interior_name7,  
																						null wall7,
																						null ceilling7, 
																						null pilotis7,
																				 		null etc7,
                                            														null salesman7                                     
																				  from sale_scene_interior
																				  where seq = 1
																				  union all
																				  select  scene_code,
																						 null interior_name1, 
																						 null wall1, 
																						 null ceilling1, 
																						null pilotis1,
																				 		null etc1,
                                            														null salesman1,
																						interior_name interior_name2, 
																						wall wall2, 
																						ceilling ceilling2, 
																						pilotis pilotis2,
																				 		etc etc2,
                                            														salesman salesman2,                                            
																						null interior_name3,  
																						null wall3,
																						null ceilling3, 
																						null pilotis3,
																				 		null etc3,
                                            														null salesman3,                                            
																						null interior_name4,  
																						null wall4,
																						null ceilling4, 
																						null pilotis4,
																				 		null etc4,
                                           														null salesman4,                                            
																						null interior_name5,  
																						null wall5,
																						null ceilling5, 
																						null pilotis5,
																				 		null etc5,
                                           														null salesman5,                                            
																						null interior_name6,  
																						null wall6,
																						null ceilling6, 
																						null pilotis6,
																				 		null etc6,
                                            														null salesman6,                                            
																						null interior_name7,  
																						null wall7,
																						null ceilling7, 
																						null pilotis7,
																				 		null etc7,
                                            														null salesman7                                            
																				  from sale_scene_interior
																				  where seq = 2
																				  union all
																				  select  scene_code,
																						null interior_name1, 
																						null wall1, 
																						null ceilling1, 
																						null pilotis1,
																				 		null etc1,
                                            														null salesman1,                                            
																						null interior_name2, 
																						null wall2, 
																						null ceilling2, 
																						null pilotis2,
																				 		null etc2,
                                            														null salesman2,                                            
																						interior_name interior_name3, 
																						wall wall3, 
																						ceilling ceilling3, 
																						pilotis pilotis3,
																				 		etc etc3,
                                            														salesman salesman3,
																						null interior_name4,  
																						null wall4,
																						null ceilling4, 
																						null pilotis4,
																				 		null etc4,
                                            														null salesman4,
																						null interior_name5,  
																						null wall5,
																						null ceilling5, 
																						null pilotis5,
																				 		null etc5,
                                            														null salesman5,                                            
																						null interior_name6,  
																						null wall6,
																						null ceilling6, 
																						null pilotis6,
																				 		null etc6,
                                            														null salesman6,                                            
																						null interior_name7,  
																						null wall7,
																						null ceilling7, 
																						null pilotis7,
																				 		null etc7,
                                            														null salesman7
																				  from sale_scene_interior
																				  where seq = 3
																				  union all
																				  select  scene_code,
																						null interior_name1, 
																						null wall1, 
																						null ceilling1, 
																						null pilotis1,
																				 		null etc1,
                                           														null salesman1,                                            
																						null interior_name2, 
																						null wall2, 
																						null ceilling2, 
																						null pilotis2,
																				 		null etc2,
                                            														null salesman2,                                            
																						null interior_name3,  
																						null wall3,
																						null ceilling3, 
																						null pilotis3,
																				 		null etc3,
                                            														null salesman3,                                            
																						interior_name interior_name4,  
																						wall wall4,
																						ceilling ceilling4, 
																						pilotis pilotis4,
																				 		etc etc4,
                                            														salesman salesman4,                                            
																						null interior_name5,  
																						null wall5,
																						null ceilling5, 
																						null pilotis5,
																				 		null etc5,
                                            														null salesman5,                                            
																						null interior_name6,  
																						null wall6,
																						null ceilling6, 
																						null pilotis6,
																				 		null etc6,
                                            														null salesman6,                                            
