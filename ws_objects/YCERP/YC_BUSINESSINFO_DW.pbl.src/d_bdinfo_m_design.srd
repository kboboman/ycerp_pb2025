 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"bdinfo~" )  TABLE(NAME=~"bdinfodet~" ) COLUMN(NAME=~"bdinfodet.build_no~") COLUMN(NAME=~"bdinfodet.seq~") COLUMN(NAME=~"bdinfodet.floors~") COLUMN(NAME=~"bdinfodet.city~") COLUMN(NAME=~"bdinfodet.master~") COLUMN(NAME=~"bdinfodet.quantity~") COLUMN(NAME=~"bdinfodet.designoffice~") COLUMN(NAME=~"bdinfodet.square~") COLUMN(NAME=~"bdinfodet.project~") COLUMN(NAME=~"bdinfodet.person~") COLUMN(NAME=~"bdinfodet.dong~") COLUMN(NAME=~"bdinfodet.designman~") COLUMN(NAME=~"bdinfodet.designphone~") COLUMN(NAME=~"bdinfodet.fixeddate~") COLUMN(NAME=~"bdinfodet.design_prog~") COLUMN(NAME=~"bdinfodet.sale_prog~") COLUMN(NAME=~"bdinfodet.div~") COLUMN(NAME=~"bdinfodet.makedate~") COLUMN(NAME=~"bdinfodet.dsexpdate~") COLUMN(NAME=~"bdinfodet.std_chk~") COLUMN(NAME=~"bdinfodet.etmt_chk~") COLUMN(NAME=~"bdinfodet.bid_chk~")    JOIN (LEFT=~"bdinfodet.build_no~"    OP =~"=~"RIGHT=~"bdinfo.build_no~" )WHERE(    EXP1 =~"( bdinfo.build_no~"   OP =~"=~"    EXP2 =~":arg_build_no )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"(bdinfodet.seq~"   OP =~"=~"    EXP2 =~":an_seq )~" ) ) ARG(NAME = ~"arg_build_no~" TYPE = string)  ARG(NAME = ~"an_seq~" TYPE = number) " update="bdinfodet" updatewhere=1 updatekeyinplace=yes arguments=(("arg_build_no", string),("an_seq", number))  sort="bdinfodet_build_no A bdinfodet_seq A " )
