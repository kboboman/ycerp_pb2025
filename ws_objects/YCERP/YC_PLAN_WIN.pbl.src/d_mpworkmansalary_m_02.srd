 column=(type=decimal(4) updatewhereclause=yes name=plan_qty dbname="plan_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=make_qty dbname="make_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=plan_qty_convert dbname="plan_qty_convert" )
 column=(type=decimal(4) updatewhereclause=yes name=make_qty_convert dbname="make_qty_convert" )
 column=(type=char(12) updatewhereclause=yes name=input_user dbname="input_user" )
 column=(type=datetime updatewhereclause=yes name=input_date dbname="input_date" )
 column=(type=char(12) updatewhereclause=yes name=update_user dbname="update_user" )
 column=(type=datetime updatewhereclause=yes name=update_date dbname="update_date" )
 retrieve="select
	 a.work_day		work_day			
	,a.seq			seq				
	,a.order_no		order_no			
	,a.area_no		area_no			        
	,a.area_name	area_name		        
	,a.work_no		work_no			
	,a.work_nm		work_nm	
	,a.item_no		item_no
	,a.qa				qa	
	,a.assembly		assembly			
	,a.assembly_qa assembly_qa 		        
	,a.uom 			uom 			        
	,a.plan_qty 	plan_qty 			
	,a.make_qty		make_qty			
	,a.plan_qty_convert		plan_qty_convert	        
	,a.make_qty_convert		make_qty_convert	        
	,a.input_user 	input_user 		        
	,a.input_date 	input_date 		        
	,a.update_user update_user 		        
	,a.update_date update_date 		        
from
	sfcworkman_prod_performance a
where
	a.work_day	= :as_day
order by
	a.area_no, a.work_no, a.item_no " arguments=(("as_day", string)) )
