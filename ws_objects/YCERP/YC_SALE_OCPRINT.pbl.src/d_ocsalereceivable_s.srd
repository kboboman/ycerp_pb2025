release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=144 color="67108864" )
summary(height=0 color="12632256" )
footer(height=84 color="8421504" )
detail(height=84 color="536870912" )
table(column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(1) updatewhereclause=yes name=credit_level dbname="credit_level" )
 column=(type=decimal(2) updatewhereclause=yes name=inv_amt dbname="inv_amt" )
 column=(type=decimal(2) updatewhereclause=yes name=inv_rem dbname="inv_rem" )
 column=(type=decimal(2) updatewhereclause=yes name=invrate dbname="invrate" )
 column=(type=decimal(6) updatewhereclause=yes name=pinv_avr dbname="pinv_avr" )
 column=(type=decimal(6) updatewhereclause=yes name=cinv_avr dbname="cinv_avr" )
 column=(type=decimal(15) updatewhereclause=yes name=inv_inc dbname="inv_inc" )
 column=(type=decimal(2) updatewhereclause=yes name=pinv_rem dbname="pinv_rem" )
 column=(type=decimal(18) updatewhereclause=yes name=rem_inc dbname="rem_inc" )
 column=(type=char(1) updatewhereclause=yes name=inv2_mon dbname="inv2_mon" )
 column=(type=char(1) updatewhereclause=yes name=coll2_mon dbname="coll2_mon" )
 column=(type=char(1) updatewhereclause=yes name=inv3_mon dbname="inv3_mon" )
 column=(type=char(1) updatewhereclause=yes name=coll3_mon dbname="coll3_mon" )
 column=(type=long updatewhereclause=yes name=cyear dbname="cyear" )
 column=(type=long updatewhereclause=yes name=cmon dbname="cmon" )
 column=(type=char(5) updatewhereclause=yes name=clevel dbname="clevel" )
 column=(type=char(10) updatewhereclause=yes name=cuser dbname="cuser" )
 column=(type=long updatewhereclause=yes name=crate dbname="crate" )
 column=(type=char(21) updatewhereclause=yes name=c3mon dbname="c3mon" )
 column=(type=char(10) updatewhereclause=yes name=salesman dbname="salesman" )
 retrieve="  SELECT cust_name    = a.cust_name                                                            
       , cust_no      = a.cust_no                                                              
       , credit_level = a.credit_level                                                         
       , inv_amt      = a.inv_amt                                     /* 당월매출 */     
       , inv_rem      = a.inv_rem                                     /* 월말 미수잔액 */
       , invrate      = a.invrate                                     /* 회전율 */       
       , pinv_avr     = a.pinv_avr                                    /* 평균매출전년 */ 
       , cinv_avr     = a.cinv_avr                                    /* 평균매출당년 */
       , inv_inc      = (case when isnull( a.inv_inc3, a.inv_inc4 - a.inv_inc5 ) = 0 then 0
                              else ( a.inv_inc1  - a.inv_inc2 ) / isnull( a.inv_inc3, a.inv_inc4 - a.inv_inc5 )
                         end)                                         /* 매출신장율 */  
       , pinv_rem     = a.pinv_rem                                    /* 전년미수잔액 */ 
       , rem_inc      = (case when isnull( a.rem_inc2, a.rem_inc3 ) = 0 then 0
                              else a.rem_inc1 / isnull( a.rem_inc2, a.rem_inc3 )
                         end)                                         /* 미수채권증감율 = 월말 미수잔액 - 전년미수잔액 / 전년미수잔액(월말 미수잔액 - 전년미수잔액)*/ 
       , inv2_mon     = a.inv2_mon                                    /* 최근2개월매출유무 */  
       , coll2_mon    = a.coll2_mon                                   /* 최근2개월수금유무 */  
       , inv3_mon     = a.inv3_mon                                    /* 최근3개월매출유무 */  
       , coll3_mon    = a.coll3_mon                                   /* 최근3개월수금유무 */  

       , cyear        = a.cyear              
       , cmon         = a.cmon               
       , clevel       = a.clevel             
       , cuser        = a.cuser              
       , crate        = a.crate              
       , c3mon        = a.c3mon              
       , salesman     = a.salesman           
    FROM (
         SELECT cust_name    = c.cust_name                                                     
              , cust_no      = c.cust_no                                                       
              , credit_level = c.credit_level                                                  
              , inv_amt      = isnull(dbo.uf_getopeom_inv(  c.cust_no, :ai_year, :ai_mon)  ,0)           /* 당월매출 */     
              , inv_rem      = isnull(dbo.uf_getopeom_Srem( c.cust_no, :ai_year, :ai_mon)  ,0)           /* 월말 미수잔액 */
              , invrate      = isnull(dbo.uf_getopeom_rate( c.cust_no, :ai_year, :ai_mon)  ,0)           /* 회전율 */       
              , pinv_avr     = isnull(dbo.uf_getopeom_Sinv( c.cust_no, (:ai_year -1), 12)  ,0) / 12      /* 평균매출전년 */ 
              , cinv_avr     = isnull(dbo.uf_getopeom_Sinv( c.cust_no, :ai_year, :ai_mon)  ,0) / :ai_mon /* 평균매출당년 */
            /*, inv_inc0     = ( dbo.uf_getopeom_Sinv( c.cust_no, :ai_year,      :ai_mon) / :ai_mon  - ( dbo.uf_getopeom_Sinv( c.cust_no, (:ai_year -1), 12) / 12 ) )
                      / isnull( ( dbo.uf_getopeom_Sinv( c.cust_no, (:ai_year -1),      12) / 12 )
                              , ( dbo.uf_getopeom_Sinv( c.cust_no, :ai_year,      :ai_mon) / :ai_mon  - ( dbo.uf_getopeom_Sinv( c.cust_no, (:ai_year -1), 12) / 12 ) )
                              )*/ /* 매출신장율 */                                                                                       
              , inv_inc1     = dbo.uf_getopeom_Sinv( c.cust_no, :ai_year,      :ai_mon) / :ai_mon
              , inv_inc2     = dbo.uf_getopeom_Sinv( c.cust_no, (:ai_year -1), 12)      / 12
              , inv_inc3     = dbo.uf_getopeom_Sinv( c.cust_no, (:ai_year -1),      12) / 12
              , inv_inc4     = dbo.uf_getopeom_Sinv( c.cust_no, :ai_year,      :ai_mon) / :ai_mon
              , inv_inc5     = dbo.uf_getopeom_Sinv( c.cust_no, (:ai_year -1), 12)      / 12 
              , pinv_rem     = isnull(copeom.balbf_amount, 0)                                            /* 전년미수잔액 */ 
            /*, rem_inc0     = dbo.uf_getopeom_Srem( c.cust_no, :ai_year, :ai_mon) - isnull(copeom.balbf_amount, 0)
                             / isnull( copeom.balbf_amount, dbo.uf_getopeom_Srem( c.cust_no, :ai_year, :ai_mon ) - copeom.balbf_amount )*/ /* 미수채권증감율 */ 
              , rem_inc1     = dbo.uf_getopeom_Srem( c.cust_no, :ai_year, :ai_mon ) - isnull(copeom.balbf_amount, 0) /* 월말 미수잔액 - 전년미수잔액 */
              , rem_inc2     = copeom.balbf_amount                                                       /* 전년미수잔액 */
              , rem_inc3     = dbo.uf_getopeom_Srem( c.cust_no, :ai_year, :ai_mon ) - copeom.balbf_amount /* 월말 미수잔액 - 전년미수잔액 */

              , inv2_mon     = dbo.uf_getopeom_2mon( c.cust_no, :ai_year, :ai_mon, 'I')              /* 최근2개월매출유무 */ 
              , coll2_mon    = dbo.uf_getopeom_2mon( c.cust_no, :ai_year, :ai_mon, 'C')              /* 최근2개월수금유무 */ 
              , inv3_mon     = dbo.uf_getopeom_3mon( c.cust_no, :ai_year, :ai_mon, 'I')              /* 최근3개월매출유무 */ 
              , coll3_mon    = dbo.uf_getopeom_3mon( c.cust_no, :ai_year, :ai_mon, 'C')              /* 최근3개월수금유무 */ 

              , cyear        = :ai_year                                                                       
              , cmon         = :ai_mon                                                                        
              , clevel       = (case when :as_level = '%' then '전 체' else :as_level           end)          
              , cuser        = (case when :as_user  = '%' then '전 체' else login.user_name     end)          
              , crate        = :ai_rate                                                                       
              , c3mon        = (case when :as_3mon  = 'A' then '전체'  else '3개월 수금/매출無' end) + '업체' 
              , salesman     = login.user_name                                                       /* 비고 (미수잔액에는 부도어음 미수채권 포함) */ 
           FROM customer  c                                                  
                LEFT OUTER JOIN opeom copeom  ON c.cust_no  = copeom.cust_no 
                LEFT OUTER JOIN login         ON c.salesman = login.user_id  
          WHERE c.open_close             = 'O'                               
            AND c.cust_flag              = 'N'                               
            AND c.credit_level        LIKE :as_level                         
            AND datepart(year, copeom.eom_year) = :ai_year                   
            AND dbo.uf_getopeom_rate( c.cust_no, :ai_year, :ai_mon) >= :ai_rate
            AND ( :as_user = '%' or (:as_user <> '%' and c.salesman  = :as_user) )
            AND ( :as_3mon = 'A' or ( :as_3mon = '3' and                          
                                      dbo.uf_getopeom_3mon( c.cust_no, :ai_year, :ai_mon, 'C') = 'N' and 
                                      dbo.uf_getopeom_3mon( c.cust_no, :ai_year, :ai_mon, 'I') = 'N' 
                                    ) 
                )
         ) A
         " filter="inv_amt <> 0 or inv_rem <> 0 or pinv_avr <> 0 or cinv_avr  <> 0 or pinv_rem  <> 0"arguments=(("ai_year", number),("ai_mon", number),("as_level", string),("as_user", string),("ai_rate", number),("as_3mon", string))  sort="cust_name A " )
