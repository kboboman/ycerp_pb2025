release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=88 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=char(6) update=yes updatewhereclause=yes key=yes name=project dbname="scene_grp.project" )
 column=(type=char(11) update=yes updatewhereclause=yes key=yes name=scene_code dbname="scene_grpdtl.scene_code" )
 column=(type=char(4) update=yes updatewhereclause=yes name=cust_no dbname="scene_grpdtl.cust_no" )
 column=(type=char(40) update=yes updatewhereclause=yes name=scene_desc dbname="scene_grpdtl.scene_desc" )
 column=(type=char(30) updatewhereclause=yes name=project_name dbname="scene_grp.project_name" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 retrieve="  SELECT scene_grp.project
       , scene_grpdtl.scene_code
       , scene_grpdtl.cust_no
       , scene_grpdtl.scene_desc
       , scene_grp.project_name
       , cust_name = c.cust_name
    FROM scene_grpdtl
         LEFT OUTER JOIN scene_grp  ON scene_grpdtl.project = scene_grp.project
         LEFT OUTER JOIN customer C ON scene_grpdtl.cust_no = c.cust_no   
   WHERE ((:as_project   = '%' AND scene_grp.project LIKE :as_project) OR
          (:as_project  <> '%' AND scene_grp.project    = :as_project)
         )
" update="scene_grpdtl" updatewhere=0 updatekeyinplace=no arguments=(("as_project", string))  sort="project A scene_code A " )
