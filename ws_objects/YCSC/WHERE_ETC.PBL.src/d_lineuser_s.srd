release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=88 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=char(5) updatewhereclause=yes name=team_parent_code dbname="team.PARENT_CODE" )
 column=(type=char(5) updatewhereclause=yes name=login_team_code dbname="login.TEAM_CODE" )
 column=(type=char(30) updatewhereclause=yes name=p_name dbname="P_NAME" )
 column=(type=char(30) updatewhereclause=yes name=t_name dbname="T_NAME" )
 column=(type=char(20) updatewhereclause=yes name=rank dbname="login.RANK" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="login.USER_ID" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="login.USER_NAME" )
 retrieve="  SELECT B.PARENT_CODE
       , A.TEAM_CODE
       , P_NAME = RTRIM(C.TEAM_NAME)
       , T_NAME = RTRIM(B.TEAM_NAME)
       , A.RANK
       , A.USER_ID  
       , A.USER_NAME
    FROM LOGIN A
         LEFT OUTER JOIN TEAM B  ON A.TEAM_CODE   = B.TEAM_CODE
         LEFT OUTER JOIN TEAM C  ON B.PARENT_CODE = C.TEAM_CODE
   WHERE A.TEAM_CODE  BETWEEN '93000' AND '96999' 
     AND A.USE_FLAG         = 'Y'
     AND ( A.USER_ID   NOT IN ( SELECT USER_ID FROM SFCDAYUSER
                                 WHERE AREA_NO    = :AS_AREA
                                   AND WC_NO      = :AS_WC
                                   AND SFC_DATE   = :AD_DATE ) 
         )    
   ORDER BY B.PARENT_CODE , A.TEAM_CODE , A.USER_NAME" arguments=(("as_area", string),("as_wc", string),("ad_date", date))  sort="user_name A " )
