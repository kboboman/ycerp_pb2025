release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=496 color="536870912" )
summary(height=72 color="536870912" )
footer(height=148 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(30) updatewhereclause=yes name=loc_name dbname="LOC_NAME" )
 column=(type=char(30) updatewhereclause=yes name=dt dbname="DT" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="ITEM_NO" )
 column=(type=char(60) updatewhereclause=yes name=item_nm dbname="ITEM_NM" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="QA" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="UOM" )
 column=(type=datetime updatewhereclause=yes name=sdate dbname="SDATE" )
 column=(type=datetime updatewhereclause=yes name=edate dbname="EDATE" )
 column=(type=decimal(4) updatewhereclause=yes name=m_iqty dbname="M_IQTY" )
 column=(type=decimal(4) updatewhereclause=yes name=a_iqty dbname="A_IQTY" )
 column=(type=decimal(2) updatewhereclause=yes name=v_iqty dbname="V_IQTY" )
 column=(type=decimal(2) updatewhereclause=yes name=r_iqty dbname="R_IQTY" )
 column=(type=decimal(2) updatewhereclause=yes name=n_iqty dbname="N_IQTY" )
 column=(type=decimal(2) updatewhereclause=yes name=w_iqty dbname="W_IQTY" )
 column=(type=decimal(2) updatewhereclause=yes name=d_oqty dbname="D_OQTY" )
 column=(type=decimal(4) updatewhereclause=yes name=a_oqty dbname="A_OQTY" )
 column=(type=decimal(2) updatewhereclause=yes name=v_oqty dbname="V_OQTY" )
 column=(type=decimal(4) updatewhereclause=yes name=p_oqty dbname="P_OQTY" )
 column=(type=decimal(4) updatewhereclause=yes name=w_oqty dbname="W_OQTY" )
 column=(type=decimal(4) updatewhereclause=yes name=u_oqty dbname="U_OQTY" )
 column=(type=decimal(4) updatewhereclause=yes name=j_oqty dbname="J_OQTY" )
 retrieve="SELECT LOC_NAME    = L.LOC_NAME
     , DT          = CONVERT(VARCHAR, S.DT, 112)
     , ITEM_NO     = Y.ITEM_NO
     , ITEM_NM     = Y.ITEM_NM
     , QA          = Y.QA
     , UOM         = Y.UOM
     , SDATE       = CONVERT(SMALLDATETIME, :AS_FROM, 111)
     , EDATE       = CONVERT(SMALLDATETIME, :AS_TO, 111)
     , M_IQTY      = S.M_IQTY  /*(생산)입고*/
     , A_IQTY      = S.A_IQTY  /*대체(입고)*/
     , V_IQTY      = S.V_IQTY  /*저장소이동(입고)*/
     , R_IQTY      = S.R_IQTY  /*반품(입고)*/
     , N_IQTY      = S.N_IQTY  /*무상(입고)*/
     , W_IQTY      = S.W_IQTY  /*가공(입고)*/
                       
     , D_OQTY      = S.D_OQTY  /*정상(출고)*/
     , A_OQTY      = S.A_OQTY  /*대체(출고)*/
     , V_OQTY      = S.V_OQTY  /*저장소이동(출고)*/
     , P_OQTY      = S.P_OQTY  /*폐기*/
     , W_OQTY      = S.W_OQTY  /*가공(출고)*/
     , U_OQTY      = S.U_OQTY  /*작업일보사용*/
     , J_OQTY      = S.J_OQTY  /*(재고생산)출고*/
  FROM (
         SELECT CONVERT(VARCHAR, D.SFC_DATE, 112) AS DT,
                D.ASSEMBLY    AS ITEM_NO,
                D.ASSEMBLY_QA AS QA,
                D.MAKE_QTY    AS M_IQTY, /*(생산)입고*/
                0             AS A_IQTY,
                0             AS V_IQTY,
                0             AS R_IQTY,
                0             AS N_IQTY,
                0             AS W_IQTY,
                0             AS D_OQTY,
                0             AS A_OQTY,
                0             AS V_OQTY,
                0             AS P_OQTY,
                0             AS W_OQTY,
                0             AS U_OQTY,
                0             AS J_OQTY,
                0             AS QOH
           FROM SFCDAY D
          WHERE CONVERT(CHAR(10),D.SFC_DATE,111)  BETWEEN :AS_FROM AND :AS_TO
            AND D.LOC_NO         = :AS_LOC_NO
            AND D.ASSEMBLY       = :AS_ITEM_NO
            AND D.ASSEMBLY_QA    = :AS_QA
            
         UNION ALL
         SELECT CONVERT(VARCHAR, D.ALTER_DATE, 112) AS DT,
                D.TAR_ITEM    AS ITEM_NO,
                D.TAR_QA      AS QA,
                0             AS M_IQTY,
                D.TAR_QTY     AS A_IQTY,/*대체입고*/
                0             AS V_IQTY,
                0             AS R_IQTY,
                0             AS N_IQTY,
                0             AS W_IQTY,
                0             AS D_OQTY,
                0             AS A_OQTY,
                0             AS V_OQTY,
                0             AS P_OQTY,
                0             AS W_OQTY,
                0             AS U_OQTY,
                0             AS J_OQTY,
                0             AS QOH
           FROM ITEMALTER D
          WHERE CONVERT(CHAR(10),D.ALTER_DATE,111) BETWEEN :AS_FROM AND :AS_TO
            AND D.TAR_LOC  = :AS_LOC_NO
            AND D.TAR_ITEM = :AS_ITEM_NO
            AND D.TAR_QA   = :AS_QA
            
         UNION ALL
         SELECT CONVERT(VARCHAR, D.RLSE_DATE, 112) AS DT,
                D.ITEM_NO     AS ITEM_NO,
                D.QA          AS QA,
                0             AS M_IQTY,
                0             AS A_IQTY,
                D.RLSE_QTY    AS V_IQTY,/*저장소이동(입고)*/
                0             AS R_IQTY,
                0             AS N_IQTY,
                0             AS W_IQTY,
                0             AS D_OQTY,
                0             AS A_OQTY,
                0             AS V_OQTY,
                0             AS P_OQTY,
                0             AS W_OQTY,
                0             AS U_OQTY,
                0             AS J_OQTY,
                0             AS QOH
           FROM ASK_HEAD H,
                ASK_DET  D
          WHERE H.ASK_NO   = D.ASK_NO
            AND CONVERT(CHAR(10),D.RLSE_DATE,111) BETWEEN :AS_FROM AND :AS_TO
            AND H.ASK_LOC  = :as_loc_no
            AND D.ITEM_NO  = :as_item_no
            AND D.QA       = :as_qa
            
         UNION ALL
         SELECT CONVERT(VARCHAR, H.ISSUE_DATE, 112) AS DT,
                D.ITEM_NO     AS ITEM_NO,
                D.QA          AS QA,
                0             AS M_IQTY,
                0             AS A_IQTY,
                0             AS V_IQTY,
                D.SHIP_QTY    AS R_IQTY,/*반품(입고)*/
                0             AS N_IQTY,
                0             AS W_IQTY,
                0             AS D_OQTY,
                0             AS A_OQTY,
                0             AS V_OQTY,
                0             AS P_OQTY,
                0             AS W_OQTY,
                0             AS U_OQTY,
                0             AS J_OQTY,
                0             AS QOH
           FROM DO H,
                DODET D
          WHERE CONVERT(CHAR(10),H.ISSUE_DATE,111) BETWEEN :AS_FROM AND :AS_TO
            AND H.DO_NO   = D.DO_NO
            AND H.DO_CASE = 'D'
            AND D.LOC_NO  = :as_loc_no
            AND D.ITEM_NO = :as_item_no
            AND D.QA      = :as_qa
            
         UNION ALL
         SELECT CONVERT(VARCHAR, H.RET_DATE, 112) AS DT,
                D.ITEM_NO     AS ITEM_NO,
                D.QA          AS QA,
                0             AS M_IQTY,
                0             AS A_IQTY,
                0             AS V_IQTY,
                0             AS R_IQTY,
                D.FREE_QTY    AS N_IQTY,/*무상(입고)*/
                0             AS W_IQTY,
                0             AS D_OQTY,
                0             AS A_OQTY,
                0             AS V_OQTY,
                0             AS P_OQTY,
                0             AS W_OQTY,
                0             AS U_OQTY,
                0             AS J_OQTY,
                0             AS QOH
           FROM RET    H,
                RETDET D
          WHERE CONVERT(CHAR(10),H.RET_DATE,111)    BETWEEN :AS_FROM AND :AS_TO
            AND H.RET_NO  = D.RET_NO
            AND H.PROCESS_FLAG NOT IN ('O', 'Y')
            AND D.LOC_NO  = :as_loc_no
            AND D.ITEM_NO = :as_item_no
            AND D.QA      = :as_qa
            
         UNION ALL
         SELECT CONVERT(VARCHAR, H.INSP_DATE, 112) AS DT,
                D.ITEM_NO AS ITEM_NO,
                D.QA      AS QA,
                0 AS M_IQTY,
                0 AS A_IQTY,
                0 AS V_IQTY,
                0 AS R_IQTY,
                0 AS N_IQTY,
                D.RCPT_QTY AS W_IQTY,/*가공입고*/
                0 AS D_OQTY,
                0 AS A_OQTY,
                0 AS V_OQTY,
                0 AS P_OQTY,
                0 AS W_OQTY,
                0 AS U_OQTY,
                0 AS J_OQTY,
                0 AS QOH
           FROM INSP H,
                INSPDET D
          WHERE CONVERT(CHAR(10),H.INSP_DATE,111) BETWEEN :AS_FROM AND :AS_TO
            AND H.INSP_NO = D.INSP_NO
            AND D.LOC_NO  = :as_loc_no
            AND D.ITEM_NO = :as_item_no
            AND D.QA      = :as_qa
            
         UNION ALL
         SELECT CONVERT(VARCHAR, H.ISSUE_DATE, 112) AS DT,
                D.ITEM_NO AS ITEM_NO,
                D.QA      AS QA,
                0 AS M_IQTY,
                0 AS A_IQTY,
                0 AS V_IQTY,
                0 AS R_IQTY,
                0 AS N_IQTY,
                0 AS W_IQTY,
                D.SHIP_QTY AS D_OQTY,/*출고(정상)*/
                0 AS A_OQTY,
                0 AS V_OQTY,
                0 AS P_OQTY,
                0 AS W_OQTY,
                0 AS U_OQTY,
                0 AS J_OQTY,
                0 AS QOH
           FROM DO H,
                DODET D
          WHERE CONVERT(CHAR(10),H.ISSUE_DATE,111) BETWEEN :AS_FROM AND :AS_TO
            AND H.DO_NO    = D.DO_NO
            AND H.DO_CASE IN ('A', 'B')
            AND D.LOC_NO   = :as_loc_no
            AND D.ITEM_NO  = :as_item_no
            AND D.QA       = :as_qa
            
         UNION ALL
         SELECT CONVERT(VARCHAR, D.ALTER_DATE, 112) AS DT,
                D.SRC_ITEM AS ITEM_NO,
                D.SRC_QA   AS QA,
                0 AS M_IQTY,
                0 AS A_IQTY,
                0 AS V_IQTY,
                0 AS R_IQTY,
                0 AS N_IQTY,
                0 AS W_IQTY,
                0 AS D_OQTY,
                D.SRC_QTY AS A_OQTY,/*대체출고*/
                0 AS V_OQTY,
                0 AS P_OQTY,
                0 AS W_OQTY,
                0 AS U_OQTY,
                0 AS J_OQTY,
                0 AS QOH
           FROM ITEMALTER D
          WHERE CONVERT(CHAR(10),D.ALTER_DATE,111) BETWEEN :AS_FROM AND :AS_TO
            AND D.SRC_LOC  = :as_loc_no
            AND D.SRC_ITEM = :as_item_no
            AND D.SRC_QA   = :as_qa
            
         UNION ALL
         SELECT CONVERT(VARCHAR, D.RLSE_DATE, 112) AS DT,
                D.ITEM_NO AS ITEM_NO,
                D.QA      AS QA,
                0 AS M_IQTY,
                0 AS A_IQTY,
                0 AS V_IQTY,
                0 AS R_IQTY,
                0 AS N_IQTY,
                0 AS W_IQTY,
                0 AS D_OQTY,
                0 AS A_OQTY,
                D.RLSE_QTY AS V_OQTY,/*저장소이동(출고)*/
                0 AS P_OQTY,
                0 AS W_OQTY,
                0 AS U_OQTY,
                0 AS J_OQTY,
                0 AS QOH
           FROM ASK_HEAD H,
                ASK_DET D
          WHERE H.ASK_NO = D.ASK_NO
            AND CONVERT(CHAR(10),D.RLSE_DATE,111) BETWEEN :AS_FROM AND :AS_TO
            AND D.LOC_NO  = :as_loc_no
            AND D.ITEM_NO = :as_item_no
            AND D.QA      = :as_qa
            
         UNION ALL
         SELECT H.aban_date AS DT,
                D.ITEM_NO AS ITEM_NO,
                D.qa    AS QA,
                0 AS M_IQTY,
                0 AS A_IQTY,
                0 AS V_IQTY,
                0 AS R_IQTY,
                0 AS N_IQTY,
                0 AS W_IQTY,
                0 AS D_OQTY,
                0 AS A_OQTY,
                0 AS V_OQTY,
                D.QTY AS P_OQTY,/*폐기*/
                0 AS W_OQTY,
                0 AS U_OQTY,
                0 AS J_OQTY,
                0 AS QOH
           FROM ITEMABAN H
              , ITEMABANDET D
          WHERE CONVERT(CHAR(10),H.ABAN_DATE,111) BETWEEN :AS_FROM AND :AS_TO
            AND H.LOC_NO   = :AS_LOC_NO
            AND D.ITEM_NO  = :AS_ITEM_NO
            AND D.QA       = :AS_QA
            AND H.ABAN_NO  = D.ABAN_NO
                
         UNION ALL
         SELECT CONVERT(VARCHAR, D.ISSUE_DATE, 112) AS DT,
                D.COMPONENT    AS ITEM_NO,
                D.COMPONENT_QA AS QA,
                0 AS M_IQTY,
                0 AS A_IQTY,
                0 AS V_IQTY,
                0 AS R_IQTY,
                0 AS N_IQTY,
                0 AS W_IQTY,
                0 AS D_OQTY,
                0 AS A_OQTY,
                0 AS V_OQTY,
                0 AS P_OQTY,
                D.ISSUE_QTY AS W_OQTY,/*가공출고*/
                0 AS U_OQTY,
                0 AS J_OQTY,
                0 AS QOH
           FROM SUDODET D
          WHERE CONVERT(CHAR(10),D.ISSUE_DATE,111) BETWEEN :AS_FROM AND :AS_TO
            AND D.ISSUE_LOC     = :as_loc_no
            AND D.COMPONENT     = :as_item_no
            AND D.COMPONENT_QA  = :as_qa
            
         UNION ALL
         SELECT CONVERT(VARCHAR, D.USE_DATE, 112) AS DT,
                D.ITEM_NO AS ITEM_NO,
                D.QA      AS QA,
                0 AS M_IQTY,
                0 AS A_IQTY,
                0 AS V_IQTY,
                0 AS R_IQTY,
                0 AS N_IQTY,
                0 AS W_IQTY,
                0 AS D_OQTY,
                0 AS A_OQTY,
                0 AS V_OQTY,
                0 AS P_OQTY,
                0 AS W_OQTY,
                D.USE_QTY AS U_OQTY,/*작업일보사용*/
                0 AS J_OQTY,
                0 AS QOH
           FROM SFCUSE D
          WHERE CONVERT(CHAR(10),D.USE_DATE,111) BETWEEN :AS_FROM AND :AS_TO
            AND D.LOC_NO  = :as_loc_no
            AND D.ITEM_NO = :as_item_no
            AND D.QA      = :as_qa
            
         UNION ALL
         SELECT CONVERT(VARCHAR, D.ORDER_DT, 112) AS DT,
                D.ASSY_ITEM AS ITEM_NO,
                D.ASSY_QA   AS QA,
                0 AS M_IQTY,
                0 AS A_IQTY,
                0 AS V_IQTY,
                0 AS R_IQTY,
                0 AS N_IQTY,
                0 AS W_IQTY,
                0 AS D_OQTY,
                0 AS A_OQTY,
                0 AS V_OQTY,
                0 AS P_OQTY,
                0 AS W_OQTY,
                0 AS U_OQTY,
                D.OUT_QTY AS J_OQTY,/*(재고생산)출고*/
                0 AS QOH
           FROM JAJAESUDO D
          WHERE CONVERT(CHAR(10),D.ORDER_DT,111)  BETWEEN :AS_FROM AND :AS_TO
            AND D.ISSUE_LOC  = :as_loc_no
            AND D.ASSY_ITEM  = :as_item_no
            AND D.ASSY_QA    = :as_qa
       ) S,
       (
         SELECT I.ITEM_NO   AS ITEM_NO,
                I.QA        AS QA,
                I.ITEM_NAME AS ITEM_NM,
                I.UOM       AS UOM
           FROM ITEM I
          WHERE I.ITEM_NO = :as_item_no
            AND I.QA      = :as_qa
       ) Y,
       (
         SELECT LOC_NO, LOC_NAME
           FROM LOCATION
          WHERE LOCATION.LOC_NO = :AS_LOC_NO
       ) L       
 WHERE Y.ITEM_NO       = S.ITEM_NO
   AND Y.QA            = S.QA
   AND L.LOC_NO        = :as_loc_no
 ORDER BY L.LOC_NAME, Y.ITEM_NO, Y.QA, CONVERT(VARCHAR, S.DT, 112)
" arguments=(("as_from", string),("as_to", string),("as_loc_no", string),("as_item_no", string),("as_qa", string)) )
