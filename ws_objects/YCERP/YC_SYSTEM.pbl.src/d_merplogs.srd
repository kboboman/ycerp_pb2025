$PBExportHeader$d_merplogs.srd
$PBExportComments$mERP 로그
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=88 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" values="	Y/	N" )
 column=(type=long update=yes updatewhereclause=yes key=yes identity=yes name=id dbname="id" )
 column=(type=char(10) update=yes updatewhereclause=yes name=uid dbname="uid" )
 column=(type=char(10) updatewhereclause=yes name=uname dbname="uname" )
 column=(type=char(10) update=yes updatewhereclause=yes name=olduid dbname="olduid" )
 column=(type=char(10) updatewhereclause=yes name=oname dbname="oname" )
 column=(type=char(10) update=yes updatewhereclause=yes name=sysdate dbname="sysdate" )
 column=(type=char(5) updatewhereclause=yes name=hhmm dbname="hhmm" )
 column=(type=char(50) update=yes updatewhereclause=yes name=pgmdesc dbname="pgmdesc" )
 column=(type=long update=yes updatewhereclause=yes name=tcnt dbname="tcnt" )
 column=(type=char(4099) updatewhereclause=no name=agent dbname="agent" )
 column=(type=char(50) updatewhereclause=yes name=raddr dbname="raddr" )
 retrieve="SELECT chk     = 'N'
     , id      = a.id                                    
     , uid     = a.uid                                   
     , uname   = rtrim(l.user_name)                      
     , olduid  = a.olduid                                
     , oname   = isnull(u.user_name,'')                  
     , sysdate = convert(char(10),a.sysdate,111)         
     , hhmm    = convert(char(5), a.sysdate,108)         
     , pgmdesc = a.pgmdesc                               
     , tcnt    = a.tcnt                                  
     , agent   = isnull(a.http_user_agent,'')            
     , raddr   = isnull(a.remote_addr,'')                
  FROM mERPLOGS a                                        
       LEFT OUTER JOIN login l  ON a.uid    = l.user_id     
       LEFT OUTER JOIN login u  ON a.olduid = u.user_id  
 WHERE a.sysdate  between :as_sdate and :as_edate" update="mERPLOGS" updatewhere=0 updatekeyinplace=no arguments=(("as_sdate", string),("as_edate", string))  sort="sysdate D hhmm D " )
group(level=1 header.height=0 trailer.height=88 by=("sysdate" ) header.color="536870912" trailer.color="12639424" )
