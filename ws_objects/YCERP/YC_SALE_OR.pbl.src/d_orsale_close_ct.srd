$PBExportHeader$d_orsale_close_ct.srd
$PBExportComments$수수마감요청 집계
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no  crosstab.dynamic = yes grid.lines=0 grid.columnmove=no selected.mouse=no )
header[1](height=0 color="536870912" )
header[2](height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(20) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(20) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=number updatewhereclause=yes name=order_no dbname="order_no" )
 retrieve="  SELECT order_no     = sc.order_no   
       , cust_no      = sc.cust_no
       , cust_name    = c.cust_name
       , scene_code   = sc.scene_code
       , scene_desc   = s.scene_desc
       , user_id      = sc.user_id   
       , user_name    = l1.user_name
       , input_date   = sc.input_date   
       , recv_id      = sc.recv_id
       , recv_name    = l3.user_name
       , accept_user  = sc.accept_user  
       , accept_name  = l2.user_name
       , accept_date  = sc.accept_date  
       , open_close   = sale.open_close
       , close_type   = sale.close_type
       , close_date   = sale.close_date
       , ret_time     = datediff(mi, sc.input_date, sc.accept_date)
    FROM sale_close SC
         LEFT OUTER JOIN login L1   ON sc.user_id     = l1.user_id
         LEFT OUTER JOIN login L2   ON sc.accept_user = l2.user_id
         LEFT OUTER JOIN login L3   ON sc.recv_id     = l3.user_id
         LEFT OUTER JOIN customer C ON sc.cust_no     = c.cust_no  
         LEFT OUTER JOIN SCENE    S ON sc.scene_code  = s.scene_code
         LEFT OUTER JOIN sale       ON sc.order_no    = sale.order_no
   WHERE (sc.input_date  between :as_sdate + ' 00:00:00.000' AND :as_edate + ' 23:59:59.999')
" arguments=(("as_sdate", string),("as_edate", string))  sort="user_name A cust_name A scene_desc A " )
group(level=1 header.height=0 trailer.height=80 by=("user_name" ) header.color="536870912" trailer.color="12639424" )
