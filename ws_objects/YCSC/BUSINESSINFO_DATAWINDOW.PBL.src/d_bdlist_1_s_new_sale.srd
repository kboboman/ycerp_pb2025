detail(height=88 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=build_no dbname="build_no" )
 column=(type=decimal(0) update=yes updatewhereclause=yes key=yes name=seq dbname="seq" )
 column=(type=char(4) update=yes updatewhereclause=yes key=yes name=builder dbname="builder" )
 column=(type=char(15) update=yes updatewhereclause=yes name=builderman dbname="builderman" )
 column=(type=char(15) update=yes updatewhereclause=yes name=builderphone dbname="builderphone" )
 column=(type=char(10) update=yes updatewhereclause=yes name=person dbname="person" )
 column=(type=char(50) update=yes updatewhereclause=yes name=build_prog dbname="build_prog" )
 retrieve="  SELECT bdinfodet_sale1.build_no,   
         bdinfodet_sale1.seq,   
         bdinfodet_sale1.builder,   
         bdinfodet_sale1.builderman,   
         bdinfodet_sale1.builderphone,   
         bdinfodet_sale1.person,   
         bdinfodet_sale1.build_prog  
    FROM bdinfodet_sale1,
         bdinfo,   
         bdinfodet
   WHERE ( bdinfodet.build_no = bdinfo.build_no ) and  
         ( bdinfodet.build_no = bdinfodet_sale1.build_no ) and
         ( bdinfodet.seq = bdinfodet_sale1.seq ) and
         ( bdinfodet.std_chk = '1' ) AND  
         ( bdinfodet.seq = :an_seq )

" update="bdinfodet_sale1" updatewhere=0 updatekeyinplace=no arguments=(("an_seq", number)) )
