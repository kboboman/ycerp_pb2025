table(column=(type=char(8) updatewhereclause=yes name=car_carriage_car_status dbname="car_status" )
 column=(type=char(8) updatewhereclause=yes name=yymmdd dbname="yymmdd" )
 column=(type=char(8) update=yes updatewhereclause=yes key=yes name=cardate dbname="car_carriage.cardate" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=car_seq dbname="car_carriage.car_seq" )
 column=(type=char(4) updatewhereclause=yes name=customer_cust_no dbname="customer.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(11) update=yes updatewhereclause=yes key=yes name=a_scene_code dbname="car_carriage.scene_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 column=(type=char(20) update=yes updatewhereclause=yes name=owner_reg dbname="car_carriage.owner_reg" )
 column=(type=char(10) update=yes updatewhereclause=yes name=owner_name dbname="car_carriage.owner_name" )
 column=(type=char(20) update=yes updatewhereclause=yes name=business dbname="car_carriage.business" )
 column=(type=char(20) update=yes updatewhereclause=yes name=jongmok dbname="car_carriage.jongmok" values="개별화물	개별화물/트럭	트럭/화물운송	화물운송/화물	화물/개별용달	개별용달/" )
 column=(type=char(60) update=yes updatewhereclause=yes name=owner_addr dbname="car_carriage.owner_addr" )
 column=(type=char(13) update=yes updatewhereclause=yes name=owner_tel dbname="car_carriage.owner_tel" )
 column=(type=char(20) update=yes updatewhereclause=yes name=owner_bank_no dbname="car_carriage.owner_bank_no" )
 column=(type=char(40) update=yes updatewhereclause=yes name=owner_bank_master dbname="car_carriage.owner_bank_master" )
 column=(type=char(20) update=yes updatewhereclause=yes name=owner_bank_name dbname="car_carriage.owner_bank_name" )
 column=(type=char(20) updatewhereclause=yes name=driver_name dbname="car_carriage.driver_name" )
 column=(type=char(12) updatewhereclause=yes name=car_no dbname="car_carriage.car_no" )
 column=(type=char(50) update=yes updatewhereclause=yes name=car_cust_name dbname="car_carriage.car_cust_name" )
 column=(type=char(14) updatewhereclause=yes name=car_carriage_do_no dbname="car_carriage.do_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=carriage_length dbname="car_carriage.carriage_length" )
 column=(type=char(1) update=yes updatewhereclause=yes name=slip_yn dbname="car_carriage.slip_yn" values="	Y/	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=tax_yn dbname="car_carriage.tax_yn" values="	Y/	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=receipt_yn dbname="car_carriage.receipt_yn" values="	Y/	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=shipamt_yn dbname="car_carriage.shipamt_yn" values="	Y/	N" )
 column=(type=decimal(0) updatewhereclause=yes name=st_car_amt dbname="car_carriage.st_car_amt" )
 column=(type=decimal(0) updatewhereclause=yes name=ship_amount dbname="car_carriage.ship_amount" )
 column=(type=char(180) updatewhereclause=yes name=order_no dbname="order_no" )
 retrieve="SELECT (case when a.car_status = '03' then '작성전'
                        when  a.car_status = '04' then  '엑셀작성'
                end) car_status,
              substring(a.cardate,5,4) yymmdd,
		   a.cardate,
              a.car_seq,
              c.cust_no,
              c.cust_name, 
              a.scene_code,
              b.scene_desc,
              a.owner_reg, 
              a.owner_name, 
              a.business, 
              a.jongmok, 
              a.owner_addr, 
              a.owner_tel, 
              a.owner_bank_no,               
              a.owner_bank_master,
              a.owner_bank_name,
              a.driver_name,
              a.car_no,
              a.car_cust_name,
		    a.do_no,
		    a.carriage_length,
              a.slip_yn,
              a.tax_yn,
              a.receipt_yn,
              a.shipamt_yn,
		   a.st_car_amt,
		   a.ship_amount,
		   dbo.uf_get_dosaleno(a.do_no) order_no
FROM car_carriage a inner join scene b on a.scene_code = b.scene_code
                                     inner join customer c on b.cust_no = c.cust_no
							inner join do d on a.do_no = d.do_no
where convert(char(8),d.do_date,112) between :ls_fr_date  and :ls_to_date
    and a.car_status in ( '03', '04' )
    and a.do_no is not null" update="car_carriage" updatewhere=0 updatekeyinplace=no arguments=(("ls_fr_date", string),("ls_to_date", string))  sort="yymmdd A scene_scene_desc A car_no A " )
