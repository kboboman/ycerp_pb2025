global type gf_chk_stringdate from function_object
end type

forward prototypes
global function integer gf_chk_stringdate (string as_dt)
end prototypes

global function integer gf_chk_stringdate (string as_dt);//ISDATE(날짜값)
//결과값
//날짜형식이 맞으면 : 1
//날짜형식이 아니라면 : 0
long ll_rslt

select 
	isdate(:as_dt)
into
	:ll_rslt
from
	dual
using sqlca;


return ll_rslt
end function

