$PBExportHeader$d_mpcust_r.srd
$PBExportComments$고객별 생산계획조회보고서(1998/05/07,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=192 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="536870912" )
detail(height=72 color="553648127" )
table(column=(type=datetime updatewhereclause=yes name=routtempnew_work_date dbname="RoutTempNew.work_date" )
 column=(type=long updatewhereclause=yes name=routtempnew_division dbname="RoutTempNew.division" )
 column=(type=char(10) updatewhereclause=yes name=routtempnew_wc_no dbname="RoutTempNew.wc_no" )
 column=(type=long updatewhereclause=yes name=routtempnew_operation dbname="RoutTempNew.operation" )
 column=(type=char(14) updatewhereclause=yes name=routtempnew_sale_no dbname="RoutTempNew.sale_no" )
 column=(type=long updatewhereclause=yes name=routtempnew_seq_no dbname="RoutTempNew.seq_no" )
 column=(type=datetime updatewhereclause=yes name=routtempnew_napgi_date dbname="RoutTempNew.napgi_date" )
 column=(type=decimal(4) updatewhereclause=yes name=routtempnew_order_qty dbname="RoutTempNew.order_qty" )
 column=(type=char(10) updatewhereclause=yes name=routtempnew_assy_item dbname="RoutTempNew.assy_item" )
 column=(type=char(20) updatewhereclause=yes name=routtempnew_assy_qa dbname="RoutTempNew.assy_qa" )
 column=(type=char(2) updatewhereclause=yes name=routtempnew_uom dbname="RoutTempNew.uom" )
 column=(type=char(2) updatewhereclause=yes name=cuom dbname="cuom" )
 column=(type=decimal(4) updatewhereclause=yes name=routtempnew_plan_qty dbname="RoutTempNew.plan_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=routtempnew_make_qty dbname="RoutTempNew.make_qty" )
 column=(type=char(50) updatewhereclause=yes name=routtempnew_rem dbname="RoutTempNew.rem" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 column=(type=char(10) updatewhereclause=yes name=color_color_name dbname="color.color_name" )
 column=(type=char(10) updatewhereclause=yes name=wc_work_name dbname="wc.work_name" )
 column=(type=char(4) updatewhereclause=yes name=pri dbname="pri" )
 column=(type=char(17) updatewhereclause=yes name=planno dbname="planno" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=datetime updatewhereclause=yes name=sale_order_date dbname="sale.order_date" )
 retrieve="  SELECT routtempnew.work_date,   
         routtempnew.division,   
         routtempnew.wc_no,   
         routtempnew.operation,   
         routtempnew.sale_no,   
         routtempnew.seq_no,   
         routtempnew.napgi_date,   
         routtempnew.order_qty,   
         routtempnew.assy_item,   
         routtempnew.assy_qa,   
         routtempnew.uom,   
         cuom = dbo.uf_getuom(routtempnew.uom),   
         routtempnew.plan_qty,   
         routtempnew.make_qty,   
         routtempnew.rem,   
         customer.cust_name,   
         scene.scene_desc,   
         color.color_name,   
         wc.work_name,   
         pri = (case when mpsdet.priority is null then '미' 
					else (case when mpsdet.mpsorder_order is null then right(  '  ' + convert(char(2), mpsdet.priority), 2 ) 
									else right(  '  ' + convert(char(2), mpsdet.order_seq), 2 ) end ) end ),   
         planno = ( case when mpsdet.order_no is null then 'ZZZZZZZZZZZZZZZZZ' 
							else (case when mpsdet.mpsorder_order is null then mpsdet.order_no 
									else mpsdet.mpsorder_order end ) end),   
         groupitem.item_name,   
         sale.order_date
    FROM routtempnew left outer join customer on routtempnew.cust_no = customer.cust_no
                                       left outer join scene on routtempnew.scene_code = scene.scene_code
                                       left outer join color on routtempnew.item_color = color.color_code
                                       inner join wc on routtempnew.wc_no = wc.work_no
                                       left outer join mpsdet on   routtempnew.sale_no = mpsdet.sale_no
                                                                          and  routtempnew.seq_no = mpsdet.seq_no
                                                                          and  routtempnew.division = mpsdet.division
                                                                          and  routtempnew.operation = mpsdet.operation
                                                                          and  routtempnew.wc_no = mpsdet.wc_no
                                       inner join sale on routtempnew.sale_no = sale.order_no
                                                            and sale.order_date between :as_start and :as_end
                                       left outer join groupitem  on routtempnew.assy_item = groupitem.item_no
   WHERE (  ( routtempnew.cust_no = :as_cust) and  
                     ( routtempnew.scene_code like :as_scene) and  
                     ( routtempnew.plan_flag like :as_flag ) and
			               ( routtempnew.area_no = :as_area) )    
/*
    FROM routtempnew,   
         customer,   
         scene,   
         color,   
         wc,   
         mpsdet,   
         sale,   
         groupitem  
   WHERE ( routtempnew.cust_no *= customer.cust_no) and  
         ( routtempnew.scene_code *= scene.scene_code) and  
         ( routtempnew.cust_no *= scene.cust_no) and  
         ( routtempnew.item_color *= color.color_code) and  
         ( routtempnew.sale_no *= mpsdet.sale_no) and  
         ( routtempnew.seq_no *= mpsdet.seq_no) and  
         ( routtempnew.division *= mpsdet.division) and  
         ( routtempnew.operation *= mpsdet.operation) and  
         ( routtempnew.assy_item *= groupitem.item_no) and  
         ( routtempnew.wc_no *= mpsdet.wc_no) and  
         ( routtempnew.wc_no = wc.work_no ) and  
         ( routtempnew.sale_no = sale.order_no ) and  
         ( ( routtempnew.cust_no = :as_cust) and  
         ( routtempnew.scene_code like :as_scene) and  
         ( sale.order_date between :as_start and :as_end ) AND  
         ( routtempnew.plan_flag like :as_flag ) and
			( routtempnew.area_no = :as_area) )    
*/
" arguments=(("as_cust", string),("as_scene", string),("as_start", date),("as_end", date),("as_flag", string),("as_area", string))  sort="customer_cust_name A routtempnew_work_date A routtempnew_wc_no A planno A pri A routtempnew_napgi_date A routtempnew_operation A routtempnew_sale_no A routtempnew_seq_no A routtempnew_assy_qa A " )
