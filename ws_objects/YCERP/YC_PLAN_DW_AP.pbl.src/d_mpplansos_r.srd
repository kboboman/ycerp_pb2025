footer(height=0 color="536870912" )
detail(height=104 color="536870912" )
table(column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=char(20) updatewhereclause=yes name=metrial dbname="metrial" )
 column=(type=char(20) updatewhereclause=yes name=pgm_no dbname="pgm_no" )
 column=(type=char(60) updatewhereclause=yes name=assembly dbname="assembly" )
 column=(type=long updatewhereclause=yes name=w1 dbname="w1" )
 column=(type=long updatewhereclause=yes name=w2 dbname="w2" )
 column=(type=long updatewhereclause=yes name=h1 dbname="h1" )
 column=(type=long updatewhereclause=yes name=h2 dbname="h2" )
 column=(type=long updatewhereclause=yes name=qty dbname="qty" )
 column=(type=long updatewhereclause=yes name=width dbname="width" )
 column=(type=long updatewhereclause=yes name=height dbname="height" )
 column=(type=char(14) updatewhereclause=yes name=sale_no dbname="sale_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="seq_no" )
 column=(type=char(50) updatewhereclause=yes name=salerem dbname="salerem" )
 column=(type=char(60) updatewhereclause=yes name=askrem dbname="askrem" )
 column=(type=char(60) updatewhereclause=yes name=rem dbname="rem" )
 column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" )
 column=(type=char(14) updatewhereclause=yes name=sos_no dbname="sos_no" )
 column=(type=long updatewhereclause=yes name=seq dbname="seq" )
 column=(type=char(50) updatewhereclause=yes name=subject dbname="subject" )
 column=(type=char(255) updatewhereclause=yes name=bigo dbname="bigo" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(11) updatewhereclause=yes name=scene_code dbname="scene_code" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(4) updatewhereclause=yes name=color dbname="color" )
 retrieve="  SELECT cust_name  = c.cust_name
       , scene_desc = s.scene_desc
       , metrial    = itemsosdet.metrial
       , pgm_no     = itemsosdet.pgm_no
       , assembly   = itemsosdet.assembly
       , w1         = itemsosdet.w1
       , w2         = itemsosdet.w2
       , h1         = itemsosdet.h1
       , h2         = itemsosdet.h2
       , qty        = itemsosdet.qty   
       , width      = itemsosdet.width
       , height     = itemsosdet.height
       , sale_no    = itemsosdet.sale_no   
       , seq_no     = itemsosdet.seq_no
       , salerem    = sd.rem
       , askrem     = itemsosdet.askrem
       , rem        = itemsosdet.rem
       , chk        = 'N'   

       , sos_no     = itemsosdet.sos_no   
       , seq        = itemsosdet.seq   
       , subject    = itemsos.subject
       , bigo       = replace(itemsos.bigo, char(13) + char(10), ' | ')
       , cust_no    = sale.cust_no
       , scene_code = sale.scene_code
       , item_no    = itemsosdet.item_no   
       , item_name  = groupitem.item_name
       , qa         = itemsosdet.qa   
       , color      = itemsosdet.color   
    FROM itemsosdet
         LEFT OUTER JOIN itemsos    (nolock) ON itemsosdet.sos_no   = itemsos.sos_no
         LEFT OUTER JOIN sale       (nolock) ON itemsosdet.sale_no  = sale.order_no
         LEFT OUTER JOIN saledet SD (nolock) ON itemsosdet.sale_no  = sd.order_no AND itemsosdet.seq_no = sd.seq_no
         LEFT OUTER JOIN customer C (nolock) ON sale.cust_no        = c.cust_no
         LEFT OUTER JOIN scene    S (nolock) ON sale.scene_code     = s.scene_code
         LEFT OUTER JOIN groupitem  (nolock) ON itemsosdet.item_no  = groupitem.item_no
   WHERE itemsosdet.sale_no   = :as_saleno       
" arguments=(("as_saleno", string))  sort="sale_no A seq A " )
