$PBExportHeader$d_sysusercnt_r2.srd
$PBExportComments$프로그램사용현황레포트(2001/08/23,이대준)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=348 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(5) updatewhereclause=yes name=syswindow_module_id dbname="syswindow.module_id" )
 column=(type=char(20) updatewhereclause=yes name=sysmodule_module_name dbname="sysmodule.module_name" )
 column=(type=char(30) updatewhereclause=yes name=syswindow_window_id dbname="syswindow.window_id" )
 column=(type=char(80) updatewhereclause=yes name=syswindow_window_name dbname="syswindow.window_name" )
 column=(type=char(1) updatewhereclause=yes name=flag dbname="sysusercnt.flag" values="조회	R/저장	S/출력	P/" )
 column=(type=long updatewhereclause=yes name=cnt dbname="cnt" )
 column=(type=datetime updatewhereclause=yes name=start_date dbname="start_date" )
 column=(type=datetime updatewhereclause=yes name=end_date dbname="end_date" )
 retrieve="  SELECT distinct syswindow.module_id,
			sysmodule.module_name,
			syswindow.window_id,   
         syswindow.window_name,   
         sysusercnt.flag,   
         cnt = sum(sysusercnt.use_count),
         start_date = convert(smalldatetime, :ad_start, 111),   
         end_date = convert(smalldatetime, :ad_end, 111)
     FROM syswindow LEFT OUTER JOIN sysusercnt on syswindow.window_id = sysusercnt.window_id
		                        inner join sysmodule on syswindow.module_id = sysmodule.module_id
   WHERE sysusercnt.use_day between  :ad_start and :ad_end 
     and  sysusercnt.user_id not in ('root','1999010s', '1999010h','1999010b','ldj')
group by syswindow.module_id,
			sysmodule.module_name,
			syswindow.window_id,   
         syswindow.window_name,   
         sysusercnt.flag  
" arguments=(("ad_start", date),("ad_end", date))  sort="sysmodule_module_name A syswindow_window_name A flag A " )
group(level=1 header.height=0 trailer.height=4 by=("sysmodule_module_name" , "syswindow_window_name" ) header.color="536870912" trailer.color="536870912" )
