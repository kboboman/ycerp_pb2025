end choose
end event

type pb_4 from picturebutton within tabpage_5
integer x = 3278
integer y = 24
integer width = 1093
integer height = 84
integer taborder = 90
integer textsize = -9
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "작업자투입 저장"
boolean originalsize = true
vtextalign vtextalign = vcenter!
end type

event clicked;// 작업자투입 저장
long ll_row, ll_del

ll_del = 0
dw9.accepttext()
dw9.setredraw(false)
for ll_row = dw9.rowcount() to 1 step -1
	string ls_work1, ls_work2, ls_work3
	
	ls_work1 = dw9.object.work1[ll_row] 
	ls_work2 = dw9.object.work2[ll_row] 
	ls_work3 = dw9.object.work3[ll_row] 
   if ls_work1 = "0" and ls_work2 = "0" and ls_work3 = "0" then
		ll_del = ll_del + 1
		dw9.scrolltorow(ll_row)			
		dw9.deleterow(ll_row)
	end if
next
dw9.setredraw(true)

if ll_del > 0 then
	if MessageBox("확인","투입인원 중 구분설정 안된 작업자는 삭제 후 저장합니다.", Exclamation!, OKCancel!, 1) = 2 THEN
		return
	end if
end if


IF MessageBox("확인","저장하시겠습니까?", Exclamation!, OKCancel!, 1) = 2 THEN
	RETURN
END IF

// 작업자 투입현황 저장
if wf_update1(dw9,"Y") = false then
	MessageBox('확인','작업자투입 저장중 오류가 발생했습니다.',exclamation!)
	return
end if
end event

