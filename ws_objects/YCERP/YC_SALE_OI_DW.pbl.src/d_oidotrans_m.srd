 column=(type=char(1) update=yes updatewhereclause=yes name=tprice_level dbname="DOTRANS.tprice_level" )
 column=(type=char(20) update=yes updatewhereclause=yes name=tcaptain_name dbname="DOTRANS.tcaptain_name" )
