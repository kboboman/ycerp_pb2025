 column=(type=char(1) update=yes updatewhereclause=yes name=ship_case dbname="fitdet.ship_case" )
 column=(type=char(60) update=yes updatewhereclause=yes name=tel dbname="fitdet.tel" )
 column=(type=char(60) update=yes updatewhereclause=yes name=rem dbname="fitdet.rem" )
