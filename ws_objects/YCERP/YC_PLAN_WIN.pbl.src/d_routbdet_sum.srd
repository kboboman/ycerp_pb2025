release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=72 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(5) updatewhereclause=yes name=rout_no1 dbname="rout_b.rout_no1" )
 column=(type=char(5) updatewhereclause=yes name=rout_no2 dbname="rout_b.rout_no2" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="rout_b.item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="rout_b.item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="rout_b.qa" )
 column=(type=decimal(2) updatewhereclause=yes name=order_qty dbname="order_qty" )
 column=(type=char(30) updatewhereclause=yes name=assembly dbname="rout_bdet.assembly" )
 column=(type=char(50) updatewhereclause=yes name=assy_qa dbname="rout_bdet.assy_qa" )
 column=(type=char(20) updatewhereclause=yes name=rout01 dbname="rout_bdet.rout01" )
 column=(type=char(20) updatewhereclause=yes name=rout02 dbname="rout_bdet.rout02" )
 column=(type=char(20) updatewhereclause=yes name=rout03 dbname="rout_bdet.rout03" )
 column=(type=char(20) updatewhereclause=yes name=rout04 dbname="rout_bdet.rout04" )
 column=(type=char(20) updatewhereclause=yes name=rout05 dbname="rout_bdet.rout05" )
 column=(type=char(20) updatewhereclause=yes name=rout06 dbname="rout_bdet.rout06" )
 column=(type=char(20) updatewhereclause=yes name=rout07 dbname="rout_bdet.rout07" )
 column=(type=char(20) updatewhereclause=yes name=rout08 dbname="rout_bdet.rout08" )
 column=(type=char(20) updatewhereclause=yes name=rout09 dbname="rout_bdet.rout09" )
 column=(type=char(20) updatewhereclause=yes name=rout10 dbname="rout_bdet.rout10" )
 column=(type=char(20) updatewhereclause=yes name=rout11 dbname="rout_bdet.rout11" )
 retrieve="  SELECT a.rout_no1, a.rout_no2, b.item_no, b.item_name, b.qa, order_qty = sum(b.order_qty)
       , c.assembly, c.assy_qa, c.rout01, c.rout02, c.rout03, c.rout04, c.rout05, c.rout06, c.rout07, c.rout08, c.rout09, c.rout10, c.rout11
    FROM rout_b A
         LEFT OUTER JOIN (
              SELECT sd.item_no, g.item_name, sd.qa, sd.order_no, sd.seq_no, sd.order_qty, c.cust_name, d.scene_desc
                FROM ( /* 수주품목중 절곡품만 */
                     SELECT order_no, cust_no, scene_code FROM sale 
                      WHERE order_date   BETWEEN :as_sdate AND :as_edate
                        AND open_close = 'O' AND confirm_flag  = 'Y'
                     ) S 
                     LEFT OUTER JOIN saledet  SD ON s.order_no   = sd.order_no
                     LEFT OUTER JOIN customer  C ON s.cust_no    = c.cust_no
                     LEFT OUTER JOIN scene     D ON s.scene_code = d.scene_code
                     LEFT OUTER JOIN groupitem G ON sd.item_no   = g.item_no
               WHERE exists (SELECT DISTINCT r.item_no 
                               FROM rout R 
                              WHERE wc_no = 'B01' AND r.item_no = sd.item_no
                            )
         ) B ON a.item_no = b.item_no AND a.qa = b.qa
         LEFT OUTER JOIN rout_bdet C ON a.rout_no1 = c.rout_no
   WHERE b.order_no IS NOT NULL
   GROUP BY a.rout_no1, a.rout_no2, b.item_no, b.item_name, b.qa
       , c.assembly, c.assy_qa, c.rout01, c.rout02, c.rout03, c.rout04, c.rout05, c.rout06, c.rout07, c.rout08, c.rout09, c.rout10, c.rout11

" arguments=(("as_sdate", string),("as_edate", string))  sort="assembly A assy_qa A " )
