$PBExportHeader$d_mpitemtot_t.srd
$PBExportComments$제품별 출고집계표(1998/12/10,조현춘)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=152 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=char(2) updatewhereclause=yes name=com_uom dbname="com_uom" )
 column=(type=char(30) updatewhereclause=yes name=work_name dbname="work_name" )
 column=(type=char(4) updatewhereclause=yes name=cat_name dbname="cat_name" )
 column=(type=char(10) updatewhereclause=yes name=cstart dbname="cstart" )
 column=(type=char(10) updatewhereclause=yes name=cend dbname="cend" )
 column=(type=decimal(2) updatewhereclause=yes name=qty dbname="ship_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=c_qty dbname="c_qty" )
 column=(type=decimal(6) updatewhereclause=yes name=c_price dbname="c_price" )
 column=(type=decimal(8) updatewhereclause=yes name=c_amt dbname="c_amt" )
 column=(type=decimal(4) updatewhereclause=yes name=c_rate dbname="c_rate" )
 column=(type=decimal(4) updatewhereclause=yes name=c_tot dbname="c_tot" )
 retrieve="   SELECT item_name = a.item_name         
        , item_no   = a.item_no
        , qa        = a.qa     
        , uom       = a.uom                  
        , com_uom   = a.com_uom                  
        , work_name = a.work_name
        , cat_name  = (case when :as_category = '%' then '전체'
                            when :as_category = 'I' then '사내'
                            when :as_category = 'O' then '외주'
                       end)
        , cstart    = (case when :as_start = ''  then '          ' else :as_start      end)
        , cend      = (case when :as_end   = ''  then '          ' else :as_end        end)
        , ship_qty  = a.ship_qty
        , c_qty     = a.c_qty   
        , c_price   = a.c_price
        , c_amt     = a.c_amt
        , c_rate    = a.c_rate
        , c_tot     = a.c_tot
     FROM (
          SELECT item_name = a.item_name         
               , item_no   = a.item_no
               , qa        = a.qa     
               , uom       = a.uom                  
               , com_uom   = a.com_uom                  
               , work_name = a.work_name
               , ship_qty  = SUM(ship_qty)
               , c_qty     = SUM(c_qty)   
               , c_price   = SUM(c_price)
               , c_amt     = SUM(c_amt)
               , c_rate    = SUM(c_rate)
               , c_tot     = SUM(c_tot)
            FROM (
                 /* 외주스리팅 W원자재 B부자재 S상품 Y외주가공 */
                 SELECT work_no   = supp.supp_no
                      , work_name = (case when :as_wcno = '%' then '전 체' else supp.supp_name end)                                      
                      , item_name = groupitem.item_name                               
                      , item_no   = inspdet.item_no                               
                      , qa        = inspdet.qa  
                      , uom       = groupitem.uom                                     
                      , com_uom   = purdet.com_uom
                      , ship_qty  = sum(rcpt_qty)                  
                      , c_qty     = sum(comqty)                    
                      /* 외주가공금액 
                      , c_price   = (case when sum(comqty) = 0 then
                                               sum(ROUND(comqty * inspdet.price, 0, 1)) / sum(comqty)
                                          else 0
                                     end)
                      */
                      /* 원코일 입고금액 */
                      , c_price   = (case when sum(comqty) = 0 then
                                               sum(ROUND(comqty * inspdet.price, 0, 1)) / sum(comqty)
                                          else 0
                                     end)
                      , c_amt     = sum(case when supp.round = 'Y' then ROUND(comqty * inspdet.price, 0, 0) 
                                             else ROUND(comqty * inspdet.price, 0, 1) 
                                        end)
                      , c_rate    = sum(insp.insp_rate)
                      , c_tot     = sum(insp.insp_total)
                   FROM groupitem   
                      , inspdet     
                      , insp        
                      , purdet      
                      , supp  
                  WHERE ( groupitem.item_no = inspdet.item_no )   
                    AND ( insp.insp_no      = inspdet.insp_no )   
                    AND ( inspdet.pur_no    = purdet.order_no )   
                    AND ( inspdet.seq_no    = purdet.seq_no   )   
                    AND ( insp.supp_no      = supp.supp_no    )   
                    AND ( purdet.cust_name  = '외주스리팅'    )
                    AND ( ( insp.supp_no        LIKE :as_wcno              ) and  
                          ( insp.insp_date   BETWEEN :as_start AND :as_end ) and  
                          ( ( insp.area_no      LIKE left(:as_area,1) + '%'         ) or
                            ( left(:as_area,1) = 'S' AND inspdet.pur_no LIKE 'PUR%' )
                          )
                        )
                    AND ( insp.insp_flag    = 'Y' AND (:as_category = 'O' or :as_category = '%') )
                  GROUP BY supp.supp_no
                         , (case when :as_wcno = '%' then '전 체' else supp.supp_name end)      
                         , groupitem.item_name 
                         , inspdet.item_no 
                         , inspdet.qa   
                         , groupitem.uom       
                         , purdet.com_uom
          
                 UNION ALL
          
                 /* 스리팅 작업일보 현황 */
                 SELECT work_no    = f.work_no
                      , work_name  = (case when :as_wcno = '%' then '전 체' else f.work_name end)
                      , item_name  = e.item_name                                  
                      , item_no    = a.item_no                                   
                      , qa         = a.qa
                      , uom        = e.uom                                        
                      , com_uom    = ''
                      , ship_qty   = a.cnt               /* 스리팅수량 */                   
                      , c_qty      = a.unit_qty * a.cnt  /* 총단중 */
                      , c_price    = g.price             /* 입고단가 */
                      , c_amt      = g.price * g.comqty  /* 입고금액 */
                      , c_rate     = g.rate_cash         /* 부가세 */
                      , c_tot      = (g.price * g.comqty + g.rate_cash) /* 합계금액 */
                   FROM coilsfcday a
                      , coilorder  b     /* 코일작업 */
                      , coilorderdet c   /* 코일작업상세 */
                      , coilmst    d
                      , groupitem  e     
                      , wc         f     /* 저장소 */
                      , inspdet    g     /* 입고 */
                  WHERE ( a.order_no         = c.order_no        )        
                    AND ( b.order_no         = c.coilorder_order )        
                    AND ( c.coil_no          = d.coil_no         )        
                    AND ( a.item_no          = e.item_no         )        
                    AND ( a.wc_no            = f.work_no              ) 
                    AND ( d.coil_no          = g.coil_no              ) 
                    AND ( d.loc_no          <> 'WS00000003'           ) /* 코일장기저장소 */
                    AND ( a.sfc_date   BETWEEN :as_start  and :as_end )
                    AND ( a.wc_no         LIKE :as_wcno               ) /* 작업위치 */
                    AND ((:as_category   = '%' and b.wc_place  LIKE :as_category) or
                         (:as_category   = 'I' and b.wc_place     = :as_category)
                        )
                 ) A
           GROUP BY a.item_name
                  , a.item_no      
                  , a.qa   
                  , a.uom           
                  , a.com_uom           
                  , a.work_name
          ) A
          " arguments=(("as_area", string),("as_start", string),("as_end", string),("as_wcno", string),("as_category", string))  sort="item_name A qa A uom A " )
group(level=1 header.height=0 trailer.height=68 by=("item_no" ) header.color="536870912" trailer.color="536870912" )
