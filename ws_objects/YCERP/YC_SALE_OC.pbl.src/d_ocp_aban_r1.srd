detail(height=72 color="536870912" )
table(column=(type=char(8) update=yes updatewhereclause=yes name=aban_dt dbname="p_aban.aban_dt" )
 column=(type=char(2) update=yes updatewhereclause=yes name=seq dbname="p_aban.seq" )
 column=(type=char(10) update=yes updatewhereclause=yes name=pos_cd dbname="p_aban.pos_cd" values="시화저장소	WS00000000/반월저장소	WS00000006/서울화곡저장소	WS00000007/" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="p_aban.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=size dbname="p_aban.size" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=qty dbname="p_aban.qty" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=price dbname="p_aban.price" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=amount dbname="p_aban.amount" )
 column=(type=char(1) update=yes updatewhereclause=yes name=flag dbname="p_aban.flag" values="등록	N/폐기	Y/취소	C/" )
 column=(type=char(60) update=yes updatewhereclause=yes name=bigo dbname="p_aban.bigo" )
 column=(type=char(10) update=yes updatewhereclause=yes name=reg_nm dbname="p_aban.reg_nm" )
 column=(type=char(8) update=yes updatewhereclause=yes name=reg_dt dbname="p_aban.reg_dt" )
 column=(type=char(60) updatewhereclause=yes name=item_item_name dbname="item.item_name" )
 retrieve="  SELECT p_aban.aban_dt,
         p_aban.seq,
         p_aban.pos_cd,
         p_aban.item_no,
         p_aban.size,  
         p_aban.qty,
         p_aban.price,
         p_aban.amount,
         p_aban.flag,
         p_aban.bigo,
         p_aban.reg_nm,
         p_aban.reg_dt,
         item.item_name
    FROM p_aban,
         item
   WHERE p_aban.item_no = item.item_no
	  AND p_aban.size = item.qa
	  AND p_aban.aban_dt BETWEEN :ls_from_dt AND :ls_to_dt
	  AND p_aban.flag LIKE :ls_gubun + '%'
" arguments=(("ls_from_dt", string),("ls_to_dt", string),("ls_gubun", string)) )
