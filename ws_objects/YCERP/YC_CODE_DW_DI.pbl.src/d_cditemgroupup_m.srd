table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="groupitem.item_no" initial="PZZZ000ZZZ" )
 column=(type=char(60) update=yes updatewhereclause=yes name=item_name dbname="groupitem.item_name" )
 column=(type=char(10) update=yes updatewhereclause=yes name=user_id dbname="groupitem.user_id" )
