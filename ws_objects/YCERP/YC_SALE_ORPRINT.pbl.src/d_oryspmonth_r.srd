$PBExportHeader$d_oryspmonth_r.srd
$PBExportComments$YSP 월별 수주물량집계(2003/09/05,정갑용)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="15780518" )
detail(height=76 color="536870912"  height.autosize=yes)
table(column=(type=datetime updatewhereclause=yes name=ad_start dbname="ad_start" )
 column=(type=datetime updatewhereclause=yes name=ad_end dbname="ad_end" )
 column=(type=char(80) updatewhereclause=yes name=t_title dbname="t_title" )
 column=(type=char(14) updatewhereclause=yes name=sale_order_no dbname="sale.order_no" )
 column=(type=char(91) updatewhereclause=yes name=name dbname="name" )
 column=(type=datetime updatewhereclause=yes name=sale_due_date dbname="sale.due_date" )
 column=(type=long updatewhereclause=yes name=sale_class dbname="sale.class" )
 column=(type=char(1) updatewhereclause=yes name=sale_type dbname="sale.type" values="일체형	A/분리형	P/U형	U/기타	E/" )
 column=(type=char(10) updatewhereclause=yes name=color_color_name dbname="color.color_name" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=decimal(2) updatewhereclause=yes name=sale_ysp_qty dbname="sale.ysp_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=ysp_qty2 dbname="sale.ysp_qty2" )
 column=(type=decimal(4) updatewhereclause=yes name=sale_sale_amount dbname="sale.sale_amount" )
 column=(type=char(244) updatewhereclause=yes name=bigo dbname="bigo" )
 column=(type=datetime updatewhereclause=yes name=sale_order_date dbname="sale.order_date" )
 column=(type=char(4) updatewhereclause=yes name=sale_cust_no dbname="sale.cust_no" )
 column=(type=char(11) updatewhereclause=yes name=sale_scene_code dbname="sale.scene_code" )
 column=(type=char(4) updatewhereclause=yes name=sale_color dbname="sale.color" )
 column=(type=char(1) updatewhereclause=yes name=c_flag dbname="c_flag" )
 retrieve="  SELECT ad_start = convert(smalldatetime, :ad_month_s, 111)
       , ad_end   = convert(smalldatetime, :ad_month_e, 111)
       , t_title  = convert(varchar(80), :as_title)
       , sale.order_no
       , name     = customer.cust_name + '/' + scene.scene_desc
       , sale.due_date
       , sale.class
       , sale.type
       , color.color_name
       , uom      = 'M2'
       , sale.ysp_qty
       , sale.ysp_qty2
       , sale.sale_amount
       , bigo     = rtrim(sale.rem) 
						+ (case when sale.rem is null or rtrim(sale.rem) = '' then '' else char(13) + char(10) end)
         			+ rtrim(sale.rem1) 
						+ (case when sale.rem1 is null or rtrim(sale.rem1) = '' then '' else char(13) + char(10) end)
         			+ rtrim(sale.rem2)
       , sale.order_date
       , sale.cust_no
       , sale.scene_code
       , sale.color
       , c_flag   = dbo.uf_getsalestatus2(sale.order_no)
    FROM sale 
         LEFT OUTER JOIN customer ON sale.cust_no = customer.cust_no 
         LEFT OUTER JOIN scene    ON sale.scene_code = scene.scene_code 
         LEFT OUTER JOIN color    ON sale.color = color.color_code
   WHERE ( sale.ysp_confirm  = 'Y' ) 
     and ( sale.area_no      = :as_area_no ) 
/*     and ( sale.open_close  <> 'C' ) 	한도초과*/ 
     and ( sale.open_close  = 'O' )
     and ( sale.order_date between :ad_month_s and :ad_month_e ) 
   ORDER BY sale.order_no
" arguments=(("as_area_no", string),("ad_month_s", date),("ad_month_e", date),("as_title", string)) )
