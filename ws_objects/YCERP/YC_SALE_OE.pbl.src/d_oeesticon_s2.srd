 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"estimate_det~" )  TABLE(NAME=~"groupitem~" ) COLUMN(NAME=~"estimate_det.estimate_no~") COLUMN(NAME=~"estimate_det.seq_no~") COLUMN(NAME=~"estimate_det.item_no~") COLUMN(NAME=~"estimate_det.qa~") COLUMN(NAME=~"estimate_det.uom~") COLUMN(NAME=~"estimate_det.order_qty~") COLUMN(NAME=~"estimate_det.acc_qty~") COLUMN(NAME=~"estimate_det.unit_cost~") COLUMN(NAME=~"estimate_det.item_amt~") COLUMN(NAME=~"estimate_det.rem~") COLUMN(NAME=~"groupitem.item_name~")    JOIN (LEFT=~"estimate_det.item_no~"    OP =~"=~"RIGHT=~"groupitem.item_no~"    OUTER1 =~"estimate_det.item_no~" )WHERE(    EXP1 =~"( ( estimate_det.estimate_no~"   OP =~"=~"    EXP2 =~":est_no ) )~" ) ) ARG(NAME = ~"est_no~" TYPE = string) " arguments=(("est_no", string)) )
