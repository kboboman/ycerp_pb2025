release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=supp_no dbname="suppprc.supp_no" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="suppprc.item_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=qa dbname="suppprc.qa" )
 column=(type=datetime update=yes updatewhereclause=yes key=yes name=i_date dbname="suppprc.i_date" )
 column=(type=decimal(3) update=yes updatewhereclause=yes name=prc dbname="suppprc.prc" )
 retrieve="  SELECT s.supp_no,
         s.item_no,
			g.item_name,
         s.qa,
         s.i_date,
         s.prc
    FROM suppprc s, groupitem g
	where s.item_no = g.item_no
	and	s.supp_no = :as_supp_no

" update="suppprc" updatewhere=1 updatekeyinplace=yes arguments=(("as_supp_no", string)) )
