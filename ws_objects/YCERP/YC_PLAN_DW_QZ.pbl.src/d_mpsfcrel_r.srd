compute(band=detail alignment="0" expression="'(' + case( daynumber(start_date)  when 1 then ~"일요일~" 
                                                     when 2 then ~"월요일~"
                                                     when 3 then ~"화요일~"
                                                     when 4 then ~"수요일~"
                                                     when 5 then ~"목요일~"
                                                     when 6 then ~"금요일~"
                                                     when 7 then ~"토요일~"
) +')'"border="0" color="0" x="1042" y="124" height="68" width="311" format="[general]" html.valueishtml="0"  name=compute_1 visible="1"  font.face="굴림" font.height="-11" font.weight="700"  font.family="1" font.pitch="2" font.charset="129" background.mode="2" background.color="16777215" )
