column(band=detail id=10 alignment="0" tabsequence=32766 border="0" color="33554432" x="663" y="8" height="72" width="507" format="[general]" html.valueishtml="0"  name=key_no visible="1" edit.limit=17 edit.case=any edit.focusrectangle=no edit.autoselect=yes edit.autohscroll=yes edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
