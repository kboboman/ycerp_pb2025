compute(band=detail alignment="1" expression="if(left(  aroi_qa ,1) = 'P' and mid(  aroi_item_no , 3,1) = 'Y' and (mid(  aroi_item_no , 7,1) = 'A' or mid(  aroi_item_no , 7,1) = 'B' or mid( aroi_item_no , 7,1) = 'C' or mid( aroi_item_no , 7,1) = 'D' or left(aroi_item_no, 5) = 'PCYSZ'),  aroi_ship_qty , if( aroi_uom  = 'M2' or aroi_uom = 'SS' ,truncate( long(mid(  aroi_qa  ,5,4)) * long(mid( aroi_qa ,10,4)) *    aroi_ship_qty / 1000000, 2), if( aroi_uom  = 'M',if(   aroi_ship_qty < 0 , truncate(long(mid(   aroi_qa , 15,5)) *    aroi_ship_qty / 1000 - 0.00001,2), truncate(long(mid(   aroi_qa , 15,5)) *   aroi_ship_qty / 1000 + 0.00001,2)) ,      aroi_ship_qty )))"border="0" color="0" x="4229" y="76" height="60" width="384" format="#,##0.00" html.valueishtml="0"  name=compute_3 visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
