 column=(type=char(1) updatewhereclause=yes name=doshipdet_new_shipflag dbname="doshipdet.new_shipflag" values="착불	C/대여	D/부담	B/공사	A/재료	R/" )
 column=(type=char(50) updatewhereclause=yes name=doshipdet_ship_reason1 dbname="doshipdet.ship_reason1" )
 column=(type=decimal(0) updatewhereclause=yes name=do_ship_amount dbname="do.ship_amount" )
 column=(type=char(12) updatewhereclause=yes name=do_driver dbname="do.driver" )
 column=(type=char(10) updatewhereclause=yes name=docar_name dbname="docar.name" )
 column=(type=char(40) updatewhereclause=yes name=docar_cargo_name dbname="docar.cargo_name" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene.scene_desc" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name_b dbname="login.user_name" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name_c dbname="login.user_name" )
 column=(type=char(20) updatewhereclause=yes name=area_area_name dbname="area.area_name" )
 column=(type=char(50) updatewhereclause=yes name=doshipdet_ship_reason2 dbname="doshipdet.ship_reason2" )
 column=(type=char(50) updatewhereclause=yes name=doshipdet_ship_reason3 dbname="doshipdet.ship_reason3" )
 column=(type=char(180) updatewhereclause=yes name=sale_no dbname="sale_no" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"customer~" )  TABLE(NAME=~"scene~" )  TABLE(NAME=~"login~" ALIAS=~"login_a~" )  TABLE(NAME=~"doship~" )  TABLE(NAME=~"doshipdet~" )  TABLE(NAME=~"do~" )  TABLE(NAME=~"docar~" )  TABLE(NAME=~"login~" ALIAS=~"login_b~" )  TABLE(NAME=~"login~" ALIAS=~"login_c~" )  TABLE(NAME=~"area~" ) COLUMN(NAME=~"login_a.user_name~") COLUMN(NAME=~"doship.doship_no~") COLUMN(NAME=~"doship.doship_date~") COLUMN(NAME=~"doship.approve_team~") COLUMN(NAME=~"doship.approve_top~") COLUMN(NAME=~"doship.user_id~") COLUMN(NAME=~"doship.user_date~") COLUMN(NAME=~"doship.area_no~") COLUMN(NAME=~"doship.rem~") COLUMN(NAME=~"doship.process_flag~") COLUMN(NAME=~"doshipdet.doship_no~") COLUMN(NAME=~"doshipdet.seq~") COLUMN(NAME=~"doshipdet.do_no~") COLUMN(NAME=~"doshipdet.old_shipflag~") COLUMN(NAME=~"doshipdet.new_shipflag~") COLUMN(NAME=~"doshipdet.ship_reason1~") COLUMN(NAME=~"do.ship_amount~") COLUMN(NAME=~"do.driver~") COLUMN(NAME=~"docar.name~") COLUMN(NAME=~"docar.cargo_name~") COLUMN(NAME=~"customer.cust_name~") COLUMN(NAME=~"scene.scene_desc~") COLUMN(NAME=~"login_b.user_name~") COLUMN(NAME=~"login_c.user_name~") COLUMN(NAME=~"area.area_name~") COLUMN(NAME=~"doshipdet.ship_reason2~") COLUMN(NAME=~"doshipdet.ship_reason3~") COMPUTE(NAME=~"sale_no = DBO.uf_getdosaleno(do.do_no)~")    JOIN (LEFT=~"do.spot_code~"    OP =~"=~"RIGHT=~"scene.scene_code~"    OUTER1 =~"do.spot_code~" )    JOIN (LEFT=~"do.driver~"    OP =~"=~"RIGHT=~"docar.driver~"    OUTER1 =~"do.driver~" )    JOIN (LEFT=~"doship.approve_team~"    OP =~"=~"RIGHT=~"login_b.user_id~"    OUTER1 =~"doship.approve_team~" )    JOIN (LEFT=~"doship.approve_top~"    OP =~"=~"RIGHT=~"login_c.user_id~"    OUTER1 =~"doship.approve_top~" )    JOIN (LEFT=~"doship.doship_no~"    OP =~"=~"RIGHT=~"doshipdet.doship_no~" )    JOIN (LEFT=~"doshipdet.do_no~"    OP =~"=~"RIGHT=~"do.do_no~" )    JOIN (LEFT=~"do.cust_no~"    OP =~"=~"RIGHT=~"customer.cust_no~" )    JOIN (LEFT=~"doship.user_id~"    OP =~"=~"RIGHT=~"login_a.user_id~" )    JOIN (LEFT=~"doship.area_no~"    OP =~"=~"RIGHT=~"area.area_no~" )WHERE(    EXP1 =~"doship.doship_no~"   OP =~"=~"    EXP2 =~":as_ship~" ) ) ARG(NAME = ~"as_ship~" TYPE = string) " arguments=(("as_ship", string)) )
