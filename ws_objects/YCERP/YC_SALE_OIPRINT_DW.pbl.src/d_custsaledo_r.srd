$PBExportHeader$d_custsaledo_r.srd
$PBExportComments$거래처별 수주출고 현황
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=88 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(11) updatewhereclause=yes name=scene_code dbname="scene_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=char(14) updatewhereclause=yes name=order_no dbname="order_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="seq_no" )
 column=(type=decimal(2) updatewhereclause=yes name=order_qty dbname="order_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=acc_qty dbname="acc_qty" )
 column=(type=datetime updatewhereclause=yes name=input_date dbname="input_date" )
 column=(type=char(1) updatewhereclause=yes name=open_close dbname="open_close" values="	O/마감	C/" )
 column=(type=char(14) updatewhereclause=yes name=do_no dbname="do_no" )
 column=(type=decimal(2) updatewhereclause=yes name=ship_qty dbname="ship_qty" )
 column=(type=decimal(5) updatewhereclause=yes name=do_acc_qty dbname="do_acc_qty" )
 column=(type=char(10) updatewhereclause=yes name=issue_date dbname="issue_date" )
 retrieve="  SELECT cust_no    = isnull(a.cust_no   , b.cust_no   )
       , cust_name  = isnull(a.cust_name , b.cust_name )
       , scene_code = isnull(a.scene_code, b.scene_code)
       , scene_desc = isnull(a.scene_desc, b.scene_desc)
       , item_no    = isnull(a.item_no   , b.item_no   )
       , item_name  = isnull(a.item_name , b.item_name )
       , qa         = isnull(a.qa        , b.qa        )
       , uom        = isnull(a.uom       , b.uom       )
       
       , order_no   = isnull(a.order_no  , b.sale_no   )
       , seq_no     = isnull(a.seq_no    , b.seq_no    )
       , order_qty  = isnull(a.order_qty , (SELECT order_qty  FROM saledet WHERE order_no = b.sale_no and seq_no = b.seq_no) )
       , acc_qty    = isnull(a.acc_qty   , (SELECT acc_qty    FROM saledet WHERE order_no = b.sale_no and seq_no = b.seq_no) )
       , input_date = isnull(a.input_date, (SELECT input_date FROM sale    WHERE order_no = b.sale_no) )
       , open_close = isnull(a.open_close, (SELECT open_close FROM sale    WHERE order_no = b.sale_no) )

       , do_no      = b.do_no
       , ship_qty   = isnull(b.ship_qty  , 0 )
       , do_acc_qty = isnull(b.acc_qty   , 0 )
       , issue_date = isnull(b.issue_date, '')
    FROM (
         SELECT cust_no    = sale.cust_no
              , cust_name  = customer.cust_name
              , scene_code = sale.scene_code   
              , scene_desc = scene.scene_desc  
              , item_no    = saledet.item_no  
              , item_name  = groupitem.item_name
              , qa         = saledet.qa   
              , uom        = saledet.uom  
              
              , order_no   = sale.order_no   
              , seq_no     = saledet.seq_no   
              , order_qty  = saledet.order_qty  
              , acc_qty    = saledet.acc_qty
              , input_date = sale.input_date
              , open_close = sale.open_close
           FROM saledet with (nolock)       
                LEFT OUTER JOIN sale      with (nolock) ON saledet.order_no = sale.order_no
                LEFT OUTER JOIN customer  with (nolock) ON sale.cust_no     = customer.cust_no
                LEFT OUTER JOIN groupitem with (nolock) ON saledet.item_no  = groupitem.item_no
                LEFT OUTER JOIN scene     with (nolock) ON sale.scene_code  = scene.scene_code
/*          WHERE ( sale.open_close         <>  'C'                   )  한도초과건 jowonsuk 2022-05-25 */
		  WHERE ( sale.open_close         =  'O'                   )
            AND ( sale.order_date   BETWEEN :as_sdate AND :as_edate ) 
            AND ((:as_custno    = '%' ) OR
                 (:as_custno   <> '%' AND sale.cust_no  = :as_custno   ) 
                )
            AND ((:as_salesman  = '%' ) OR
                 (:as_salesman <> '%' AND sale.salesman = :as_salesman ) 
                )
         ) A
         
         FULL JOIN (
              SELECT cust_no    = do.cust_no
                   , cust_name  = customer.cust_name   
                   , scene_code  = do.spot_code   
                   , scene_desc = scene.scene_desc   
                   , do_date    = convert(char(10),do.do_date,111)
                   , item_no    = dodet.item_no
                   , item_name  = groupitem.item_name
                   , qa         = dodet.qa    
                   , uom        = dodet.uom   
            
                   , sale_no    = dodet.sale_no
                   , seq_no     = dodet.seq_no
                   , ship_qty   = dodet.ship_qty   
                   , acc_qty    = round(dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty),2,1)
                   , issue_date = convert(char(10),do.issue_date,111)
            
                   , do_no      = do.do_no   
                   , oi_no      = dodet.oi_no
                FROM dodet  with (nolock)     
                     LEFT OUTER JOIN do        with (nolock) ON dodet.do_no   = do.do_no
                     LEFT OUTER JOIN customer  with (nolock) ON do.cust_no    = customer.cust_no
                     LEFT OUTER JOIN groupitem with (nolock) ON dodet.item_no = groupitem.item_no
                     LEFT OUTER JOIN scene     with (nolock) ON do.spot_code  = scene.scene_code
               WHERE ( do.do_date   BETWEEN :as_sdate AND getdate() )
                 AND ((:as_custno  = '%' ) OR
                      (:as_custno <> '%' AND do.cust_no = :as_custno ) 
                     )
         ) B ON a.order_no = b.sale_no AND a.seq_no = b.seq_no
" arguments=(("as_salesman", string),("as_custno", string),("as_sdate", string),("as_edate", string))  sort="cust_name A scene_desc A order_no A seq_no A " )
