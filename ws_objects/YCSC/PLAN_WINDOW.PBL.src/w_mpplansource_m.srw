event clicked;//
dwitemstatus l_status

if row < 1 or row > this.rowcount() then return

sle_1.text = this.object.sos_no[row]

long   ll_row, ll_count, ll_cnt, ll_max
string ls_sosno
		

if tab_1.SelectedTab <> 2 then return
