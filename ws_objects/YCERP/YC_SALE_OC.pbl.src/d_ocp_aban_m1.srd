footer(height=72 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(14) update=yes updatewhereclause=yes key=yes name=aban_no dbname="itemabandet.aban_no" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=seq dbname="itemabandet.seq" )
 column=(type=char(10) update=yes updatewhereclause=yes name=loc_no dbname="itemabandet.loc_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="itemabandet.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="itemabandet.qa" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=qty dbname="itemabandet.qty" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=price dbname="itemabandet.price" initial="0" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=amount dbname="itemabandet.amount" initial="0" )
 column=(type=char(1) update=yes updatewhereclause=yes name=flag dbname="itemabandet.flag" initial="O" values="등록	O/폐기	Y/마감	C/" )
 column=(type=char(50) update=yes updatewhereclause=yes name=bigo dbname="itemabandet.bigo" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="groupitem.uom" )
 column=(type=char(2) updatewhereclause=yes name=com_uom dbname="com_uom" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="groupitem.item_name" )
 retrieve="  SELECT itemabandet.aban_no,   
         itemabandet.seq,   
         itemabandet.loc_no,   
         itemabandet.item_no,   
         itemabandet.qa,   
         itemabandet.qty,   
         itemabandet.price,   
         itemabandet.amount,   
         itemabandet.flag,   
         itemabandet.bigo,   
         groupitem.uom,   
         com_uom = dbo.uf_getuom(groupitem.uom),   
         groupitem.item_name  
    FROM itemabandet,   
         groupitem  
   WHERE ( itemabandet.item_no = groupitem.item_no ) and  
         ( ( itemabandet.aban_no = :as_aban_no )   
         )    
" update="itemabandet" updatewhere=0 updatekeyinplace=no arguments=(("as_aban_no", string)) )
