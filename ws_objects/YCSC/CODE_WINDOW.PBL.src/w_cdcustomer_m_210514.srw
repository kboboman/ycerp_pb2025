type pb_save from w_inheritance`pb_save within w_cdcustomer_m_210514
integer x = 4229
end type

event pb_save::clicked;//
dwitemstatus l_status, l_status_save, l_status_rem
boolean lb_update_chk = false, lb_mmssend 
string ls_custno, ls_addr1, ls_addr2, ls_addr3, ls_busaddr1, ls_busaddr2, ls_busaddr3
string ls_shipaddr1, ls_shipaddr2, ls_shipaddr3
string ls_register,  ls_saleaddress
long   ll_cnt
string ls_rgno, ls_childnum, ls_icube_no
long	 ll_len


if GF_Permission("판매거래처관리EDIT", gs_userid) = "Y" then
else
	MessageBox('확인', '거래처관리 권한이 없습니다.')
	RETURN
end if

if tab_1.selectedtab = 7 then
	MessageBox("확인", "[[[ 판매거래처 변경작업 실행 ]]] 버튼을 실행하세요.")
	RETURN
end if

if MessageBox("저장","저장하시겠습니까?",information!,okcancel!,1) = 2 then
	RETURN
end if

//==GF_USEPROGRAM(프로그램 사용현황)===========================================================
GF_USEPROGRAM( gs_userid, Parent.ClassName(), "S", string(gf_today(),'yyyy/mm/dd'), Parent.Title )
//=============================================================================================

tab_1.tabpage_2.dw_4.accepttext()
tab_1.tabpage_1.dw_5.accepttext()
tab_1.tabpage_1.dw_rem_i.accepttext()
/*
// 더존코드 검사
ls_icube_no     = trim(tab_1.tabpage_1.dw_5.object.icube_no[1])
if isnull(ls_icube_no) then
	MessageBox("확인", "해당하는 거래처의 회계거래처코드를 등록하시기 바랍니다.")
	//RETURN
end if

// 영업지역 검사
ls_saleaddress  = trim(tab_1.tabpage_1.dw_5.object.sale_address[1])
if isnull(ls_saleaddress) then
	MessageBox("확인", "해당하는 거래처의 영업지역을 등록하시기 바랍니다.")
	RETURN
end if
*/
if tab_1.tabpage_1.dw_5.rowcount() < 1 then 
	MessageBox('오류', '거래처선택 오류, 거래처를 다시 조회후 작업하세요. ')
	RETURN
end if

//=============================================================================================
// 이전주소 저장
//=============================================================================================
ls_custno    = tab_1.tabpage_1.dw_5.object.cust_no[1]
ls_addr1     = tab_1.tabpage_1.dw_5.object.addr1[1]
ls_addr2     = tab_1.tabpage_1.dw_5.object.addr2[1]
ls_addr3     = tab_1.tabpage_1.dw_5.object.addr3[1]
if (ls_addr1 + ls_addr2 + ls_addr3) <> (is_addr1 + is_addr2 + is_addr3) then
	INSERT INTO customer_addrhis ( cust_no, addr_type, zipcode, address )
	VALUES ( :ls_custno, '1', :is_addr1, :is_addr2 + ' ' + :is_addr3 );
	if sqlca.sqlcode <> 0 then
		 MessageBox("이전주소1", "사업장 이전주소 저장 오류입니다.~r~n에러내용: " + sqlca.sqlerrtext, StopSign!, OK!, 1 )
	end if
end if

ls_busaddr1  = tab_1.tabpage_1.dw_5.object.bus_addr1[1]
ls_busaddr2  = tab_1.tabpage_1.dw_5.object.bus_addr2[1]
ls_busaddr3  = tab_1.tabpage_1.dw_5.object.bus_addr3[1]
if (ls_busaddr1 + ls_busaddr2 + ls_busaddr3) <> (is_busaddr1 + is_busaddr2 + is_busaddr3) then
	INSERT INTO customer_addrhis ( cust_no, addr_type, zipcode, address )
	VALUES ( :ls_custno, '2', :is_busaddr1, :is_busaddr2 + ' ' + :is_busaddr3 );
	if sqlca.sqlcode <> 0 then
		 MessageBox("이전주소2", "채무자 이전주소 저장 오류입니다.~r~n에러내용: " + sqlca.sqlerrtext, StopSign!, OK!, 1 )
	end if
end if

ls_shipaddr1 = tab_1.tabpage_1.dw_5.object.shipto_addr1[1]
ls_shipaddr2 = tab_1.tabpage_1.dw_5.object.shipto_addr2[1]
ls_shipaddr3 = tab_1.tabpage_1.dw_5.object.shipto_addr3[1]
if (ls_shipaddr1 + ls_shipaddr2 + ls_shipaddr3) <> (is_shipaddr1 + is_shipaddr2 + is_shipaddr3) then
	INSERT INTO customer_addrhis ( cust_no, addr_type, zipcode, address )
	VALUES ( :ls_custno, '3', :is_shipaddr1, :is_shipaddr2 + ' ' + :is_shipaddr3 );
	if sqlca.sqlcode <> 0 then
		 MessageBox("이전주소3", "운송처 이전주소 저장 오류입니다.~r~n에러내용: " + sqlca.sqlerrtext, StopSign!, OK!, 1 )
	end if
end if
//=============================================================================================


if  LeftA(tab_1.tabpage_1.dw_5.object.cust_no[1], 1) = 'S' or &
    LeftA(tab_1.tabpage_1.dw_5.object.cust_no[1], 1) = 'L' or &
    LeftA(tab_1.tabpage_1.dw_5.object.cust_no[1], 1) = 'K' or &
    LeftA(tab_1.tabpage_1.dw_5.object.cust_no[1], 1) = 'N' or &
    LeftA(tab_1.tabpage_1.dw_5.object.cust_no[1], 1) = 'H' or &
    LeftA(tab_1.tabpage_1.dw_5.object.cust_no[1], 1) = 'I' or &
    LeftA(tab_1.tabpage_1.dw_5.object.cust_no[1], 1) = 'J' or &
    LeftA(tab_1.tabpage_1.dw_5.object.cust_no[1], 1) = 'T' or & 
    LeftA(tab_1.tabpage_1.dw_5.object.cust_no[1], 1) = 'U' or & 
    LeftA(tab_1.tabpage_1.dw_5.object.cust_no[1], 1) = 'V' then
else
	 MessageBox("거래처 등록오류","거래처 코드 첫자는 'S','L','N','H','I','J','K','T','U','V'만 가능합니다!")
	 RETURN	 
end if

tab_1.tabpage_3.dw_6.accepttext()
if (isnull(tab_1.tabpage_1.dw_5.object.register_no[1])   or trim(tab_1.tabpage_1.dw_5.object.register_no[1])   = '') and &
   (isnull(tab_1.tabpage_1.dw_5.object.resident_card[1]) or trim(tab_1.tabpage_1.dw_5.object.resident_card[1]) = '') then
	MessageBox("오류","사업자등록번호나 주민등록번호를 반드시 입력하십시오.")
	RETURN
else
	ls_register = tab_1.tabpage_1.dw_5.object.register_no[1]
	SELECT count(*) INTO :ll_cnt FROM CUSTOMER WHERE register_no   = :ls_register;
	if ll_cnt > 0 then
		if MessageBox("오류","사업자등록번호 중복 입니다.~n~n계속 진행 하시겠습니까?", Exclamation!, YesNo!, 2) = 2 then
			RETURN
		end if
	end if
end if


ls_childnum = tab_1.tabpage_1.dw_5.object.child_number[1]

if isnull(ls_childnum) then
	ls_childnum = '0'
end if

if isnumber(ls_childnum) then // 종사업장 체크
else
	MessageBox("오류","종사업장을 확인하여 주시기 바랍니다.")
	RETURN
end if

ls_rgno     = tab_1.tabpage_1.dw_5.object.register_no[1]
ll_len      = LenA(ls_rgno)
IF ll_len < 12 then // 사업자등록번호 자릿수 체크
	MessageBox("오류","사업자등록번호 자릿수를 확인하여 주시기 바랍니다.")
	RETURN
END IF


setpointer(hourglass!)
if tab_1.tabpage_2.dw_4.rowcount() > 0 then
	if tab_1.tabpage_1.dw_5.rowcount() > 0 then
		if wf_nullchk(tab_1.tabpage_2.dw_4) = false then
			RETURN
		elseif wf_nullchk(tab_1.tabpage_1.dw_5) = false then
			RETURN
		end if
		
		l_status = tab_1.tabpage_1.dw_5.getitemstatus(1, 0, primary!)
		if l_status = newmodified! then
			l_status_save = newmodified!
			lb_update_chk = wf_update3(tab_1.tabpage_2.dw_4, tab_1.tabpage_1.dw_5, tab_1.tabpage_3.dw_6, "Y")
	   else
			//// 판매담당자가 변경될 경우 이전 담당자를 전임판매담당자로 자동 변환/////
         if (isnull(is_salesman) or trim(is_salesman) = '') then
			else
            if is_salesman <> tab_1.tabpage_1.dw_5.object.salesman[1] then
					tab_1.tabpage_1.dw_5.object.pre_salesman[1] = is_salesman
				end if
			end if
			//// 변환 끝 ///	
			lb_update_chk = wf_update2(tab_1.tabpage_2.dw_4, tab_1.tabpage_1.dw_5, "Y")
	   end if
	end if
else
	MessageBox("오류","입력된 정보가 없습니다.")
	RETURN
end if


if lb_update_chk = true then
	string ls_sale_control, ls_cust_no, ls_text
	
	ls_sale_control = tab_1.tabpage_1.dw_5.object.sale_control[1]
	ls_cust_no      = tab_1.tabpage_1.dw_5.object.cust_no[1]
	if isnull(ls_sale_control) then ls_sale_control = 'N'

	string ls_s_sms_yn, ls_s_area_no, ls_s_tel, ls_salerhp, ls_managerhp, ls_smgr, ls_cmgr
	ls_s_tel = 'chulha_t_0'	// 본사

	// 신규 등록시 문자 제외하기
	if l_status_save = newmodified! then
	else
		if is_sale_control <> ls_sale_control then
			if ls_sale_control = 'A' or ls_sale_control = 'Y' then
				ls_text = '매출통제 되었습니다.'
			else
				ls_text = '매출해제 되었습니다.'
			end if
			
			// 매출통제 LOG
			INSERT INTO customer_control_his( cust_cd, log_date, sale_control, gbn, user_id )
			VALUES ( :ls_cust_no, getdate(), :ls_sale_control, '1', :gs_userid );		
	
			string ls_custname, ls_s_scene_desc, ls_s_do_date, ls_saleshp
			string ls_s_scene_tel, ls_s_cust_tel,   ls_message,     ls_sendhp
	
			SELECT b.cust_name
				  , salesman   = replace(substring(ltrim(rtrim(isnull(d.hp_no,''))),1,13), '-', '') /*담당자*/
				  , saler_user = replace((SELECT (case when ae.saler_id is null then ''
																	else (SELECT hp_no from salehp h WHERE h.user_id = ae.saler_id)
															 end)
													 FROM aroiinv_esero ae
													WHERE ae.id = d.user_id ), '-', '') /*여직원*/
				  , apply3     = replace((case when apply3 is null 
																then (SELECT hp_no from salehp h WHERE h.user_id = d.user_id)
														 else d.hp_no
												  end), '-', '') /*결재자*/
				  , smgr       = '01094761231' /*이준복*/ 
				  , cmgr       = '01090853764' /*한미란*/
			  INTO :ls_custname, :ls_saleshp, :ls_salerhp, :ls_managerhp, :ls_smgr, :ls_cmgr
			  FROM customer b
				  , salehp d
			 WHERE b.salesman = d.user_id
				AND b.cust_no  = :ls_cust_no;
	
			ls_message = '[유창]' + ls_custname + '는 ' + ls_text 
	
			SELECT TOP 1 Replace(substring(ltrim(rtrim(isnull(d.hp_no,''))),1,13), '-', '') 
			  INTO :ls_sendhp  /* 발신번호*/
			  FROM salehp d
			 WHERE user_id = :ls_s_tel;
			
			choose case LeftA(ls_saleshp,3)
				case "010", "011", "016", "017", "018", "019"
				case else
					ls_saleshp = ""
			end choose
	

			// 담당자
			GF_MMSSEND( gs_userid, ls_sendhp, ls_saleshp,   '담당자명', ls_message )
			// 본부장
			GF_MMSSEND( gs_userid, ls_sendhp, ls_managerhp, '본부장',   ls_message )
			// 여직원
			GF_MMSSEND( gs_userid, ls_sendhp, ls_salerhp,   '여직원',   ls_message )
			// 영업관리
			GF_MMSSEND( gs_userid, ls_sendhp, ls_smgr,      '영업관리', ls_message )
			// 채권관리
			GF_MMSSEND( gs_userid, ls_sendhp, ls_cmgr,      '채권관리', ls_message )
	
			is_sale_control = ls_sale_control		
		end if
	end if
end if


///////////////////////////////////////////
// 사용불가 제외
///////////////////////////////////////////
long   ll_row
string ls_open, ls_zero, ls_salesman

if cbx_open.checked = true then
	ls_open = "O"
else
	ls_open = "%"
end if

///////////////////////////////////////////
// 잔액제로 제외
///////////////////////////////////////////
if cbx_zero.checked = true then
	ls_zero = "Y"
else
	ls_zero = "%"
end if

// 담당자
ls_salesman = "%"

ll_row = idwc_cust.retrieve( ls_open, ls_zero, ls_salesman )
if ll_row = 0 then MessageBox("확인", "거래처 데이터가 존재하지 않습니다.")
ll_row = idwc_cust_name.retrieve( ls_open, ls_zero, ls_salesman )
if ll_row = 0 then MessageBox("확인", "거래처 데이터가 존재하지 않습니다.")
ll_row = idwc_icube.retrieve( ls_open, ls_salesman )
if ll_row = 0 then MessageBox("확인", "거래처 데이터가 존재하지 않습니다.")
///////////////////////////////////////////

pb_insert.enabled = true

string   ls_rem
integer  li_seq
datetime ldt_today

ls_cust_no = ""
l_status_rem = tab_1.tabpage_1.dw_rem_i.getitemstatus(1, 0, primary!)

if l_status_rem <> NotModified! then
	ls_rem     = tab_1.tabpage_1.dw_rem_i.object.rem[1]
	ls_cust_no = tab_1.tabpage_1.dw_5.object.cust_no[1]
	SELECT top 1 convert(datetime, convert(varchar(10), getdate(), 111))
     INTO :ldt_today
	  FROM login;

	SELECT count(*) + 1 INTO :li_seq
	  FROM customer_det
	 WHERE cust_no = :ls_cust_no AND idate   = :ldt_today;

	if isnull(ls_rem) OR trim(ls_rem) = "" then ls_rem = ""
	
	if is_rem_old <> ls_rem then
		INSERT INTO customer_det (cust_no, idate, seq, rem, iuser) 
		VALUES (:ls_cust_no, getdate(), :li_seq, :ls_rem, :gs_userid);
		COMMIT;
		is_rem_old = ls_rem
	end if
end if

end event

type dw_1 from w_inheritance`dw_1 within w_cdcustomer_m_210514
integer x = 46
