type pb_alltime from picturebutton within tabpage_6
integer x = 27
integer y = 24
integer width = 864
integer height = 96
integer taborder = 110
integer textsize = -10
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "조업시간 산출"
boolean originalsize = true
vtextalign vtextalign = vcenter!
end type

event clicked;// 조업시간 산출
decimal ld_alltime, ld_daytime, ld_overtime, ld_chktime
long    ll_row,    ll_cnt
string  ls_areano, ls_sfcdate, ls_wcno

ls_areano  = dw_area.object.area[1]
ls_sfcdate = string(id_date,"yyyy/mm/dd")
ls_wcno    = dw_2.object.wc_no[1]

ll_row = dw11.rowcount()
if ll_row > 1 then return


if ls_areano = "" or isnull(ls_areano) or ls_sfcdate = "" or isnull(ls_sfcdate) or &
   ls_wcno = ""   or isnull(ls_wcno) then
	MessageBox("확인", ls_sfcdate + "~r~r작업장, 작업일자를 선택하시기 바랍니다." ,exclamation!)
	return
end if


SELECT all_time    = max(a.time1) + max(a.time2) + max(a.time3)
     , ld_daytime  = max(a.time1) + max(a.time2)
	  , ld_overtime = max(a.time3)
  INTO :ld_alltime, :ld_daytime, :ld_overtime
  FROM sfcdayman A                                             
 WHERE a.area_no       = :ls_areano                    
	AND convert(char(10), a.sfc_date,111)  = :ls_areano
	AND a.wc_no         = :ls_wcno                      
 GROUP BY area_no, sfc_date, wc_no;

SELECT count(*) INTO :ll_cnt FROM sfcdaywork WHERE area_no = :ls_areano AND sfc_date = :ls_sfcdate AND wc_no = :ls_wcno;
if ll_cnt = 0 then
	INSERT INTO sfcdaywork ( area_no, sfc_date, wc_no, gettype, all_time, daytime, overtime )
	VALUES ( :ls_areano, :id_date, :ls_wcno, 'A', :ld_alltime, :ld_daytime, :ld_overtime );
	if sqlca.sqlcode < 0 then
		rollback;
		MessageBox("확인", ls_sfcdate + "일 조업시간 산출에서 오류가 발생하였습니다." ,exclamation!)
	else
		commit;
	end if		
end if

dw11.retrieve( ls_areano, string(id_date,"yyyy/mm/dd"), dw_2.object.wc_no[1] )


ld_chktime = dw11.object.all_time[1]
if isnull(ld_chktime) then ld_chktime = 0

dw11.object.all_time.TabSequence = 0
dw11.object.daytime.TabSequence  = 0
dw11.object.overtime.TabSequence = 0
if ld_chktime <> ld_alltime then
	if MessageBox("확인", ls_sfcdate + "일 조업시간이 작업자 투입 시간과 일치하지 않습니다.~n~n" + &
	              "작업자 투입시간(집계값)을 반영합니까?", Exclamation!, OKCancel!, 1) = 1 then
		dw11.object.gettype[1]  = "A"
		dw11.object.all_time[1] = ld_alltime
		dw11.object.daytime[1]  = ld_daytime
		dw11.object.overtime[1] = ld_overtime
	else
		dw11.object.daytime.TabSequence  = 10
		dw11.object.overtime.TabSequence = 20
		dw11.object.gettype[1]  = "M"
		dw11.setcolumn( "daytime" )
		dw11.setfocus()
	end if
else
	if ld_alltime = 0 then		
		MessageBox("확인", ls_sfcdate + "일~n~n조업시간을 등록하시기 바랍니다." ,exclamation!)		
		dw11.object.daytime.TabSequence  = 10
		dw11.object.overtime.TabSequence = 20
		dw11.object.gettype[1]  = "M"
		dw11.setcolumn( "daytime" )
		dw11.setfocus()
	end if
end if

end event

