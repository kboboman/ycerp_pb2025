$PBExportHeader$d_irincoun_s.srd
$PBExportComments$실사목록조회(1998/02/16,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=84 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=itemloc_item_no dbname="itemloc.item_no" )
 column=(type=char(20) updatewhereclause=yes name=itemloc_qa dbname="itemloc.qa" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=decimal(4) updatewhereclause=yes name=qoh dbname="ineoym.qoh" initial="0" )
 column=(type=char(2) updatewhereclause=yes name=groupitem_uom dbname="uom" )
 retrieve="  SELECT itemloc.item_no,   
         itemloc.qa,   
         groupitem.item_name,   
         ineoym.qoh,   
         uom = (case groupitem.uom when 'M'  then 'EA'
						  					 when 'M2' then 'EA'
											 else groupitem.uom
				   end)  
     FROM itemloc left outer join ineoym on itemloc.item_no = ineoym.item_no 
                                            and itemloc.qa = ineoym.qa 
                                            and itemloc.loc_no = ineoym.loc_no
								  and ineoym.cyear = :as_year
								  and ineoym.cmon = :as_mon
                             inner join groupitem on itemloc.item_no = groupitem.item_no
                             inner join location on itemloc.loc_no = location.loc_no
where ( ( itemloc.loc_no = :as_loc ) AND  
             (itemloc.item_no like :as_item AND  
             groupitem.item_name like :as_name) AND  
            itemloc.item_no < 'PZZZ' )    
" arguments=(("as_loc", string),("as_year", string),("as_mon", string),("as_item", string),("as_name", string)) )
