footer(height=64 color="8421504" )
detail(height=64 color="553648127" )
table(column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" values="	Y/	N" )
 column=(type=datetime updatewhereclause=yes name=work_date dbname="routtempnew.work_date" )
 column=(type=long updatewhereclause=yes name=division dbname="routtempnew.division" initial="1" )
 column=(type=char(10) updatewhereclause=yes name=wc_no dbname="wc_no" )
 column=(type=long updatewhereclause=yes name=operation dbname="routtempnew.operation" initial="1" )
 column=(type=char(4) updatewhereclause=yes name=process_flag dbname="process_flag" initial="Y" )
 column=(type=long updatewhereclause=yes name=work_per dbname="routtempnew.work_per" initial="0" )
 column=(type=char(14) updatewhereclause=yes name=sale_no dbname="routtempnew.sale_no" initial="NO_SALE" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="routtempnew.seq_no" initial="0" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="routtempnew.cust_no" )
 column=(type=char(11) updatewhereclause=yes name=scene_code dbname="routtempnew.scene_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene.scene_desc" )
 column=(type=datetime updatewhereclause=yes name=napgi_date dbname="routtempnew.napgi_date" )
 column=(type=char(1) updatewhereclause=yes name=suju_type dbname="routtempnew.suju_type" values="Y.S.P	Y/시화	E/" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="routtempnew.item_no" initial="NO_ITEM" )
 column=(type=char(60) updatewhereclause=yes name=item_name1 dbname="item_name1" initial="NO_ITEM" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="routtempnew.qa" initial="NO_QA" )
 column=(type=char(4) updatewhereclause=yes name=item_color dbname="routtempnew.item_color" initial="0000" )
 column=(type=char(10) updatewhereclause=yes name=color_name dbname="color_name" initial="무도장" )
 column=(type=decimal(4) updatewhereclause=yes name=order_qty dbname="routtempnew.order_qty" initial="0" )
 column=(type=char(10) updatewhereclause=yes name=assy_item dbname="routtempnew.assy_item" )
 column=(type=char(20) updatewhereclause=yes name=assy_qa dbname="routtempnew.assy_qa" )
 column=(type=long updatewhereclause=yes name=bom_no dbname="routtempnew.bom_no" initial="0" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="routtempnew.uom" )
 column=(type=decimal(4) updatewhereclause=yes name=plan_qty dbname="routtempnew.plan_qty" initial="0" )
 column=(type=decimal(4) updatewhereclause=yes name=setup_time dbname="routtempnew.setup_time" initial="0" )
 column=(type=decimal(4) updatewhereclause=yes name=work_time dbname="routtempnew.work_time" initial="0" )
 column=(type=decimal(4) updatewhereclause=yes name=make_qty dbname="routtempnew.make_qty" initial="0" )
 column=(type=char(1) updatewhereclause=yes name=plan_flag dbname="routtempnew.plan_flag" initial="N" )
 column=(type=decimal(4) updatewhereclause=yes name=qpa dbname="routtempnew.qpa" initial="0" )
 column=(type=decimal(4) updatewhereclause=yes name=reserved_qty dbname="routtempnew.reserved_qty" initial="0" )
 column=(type=char(50) updatewhereclause=yes name=routtempnew_rem dbname="routtempnew.rem" )
 column=(type=char(10) updatewhereclause=yes name=routtempnew_area_no dbname="routtempnew.area_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=long updatewhereclause=yes name=pri dbname="pri" )
 column=(type=char(1) updatewhereclause=yes name=sale_open_close dbname="sale.open_close" )
 column=(type=decimal(2) updatewhereclause=yes name=dodet_ship_qty dbname="ship_qty" )
 retrieve="  SELECT chk  = 'N'
       , routtempnew.work_date      
       , routtempnew.division       
       , wc_no     = wc.work_name          
       , routtempnew.operation      
       , process_flag = (case when routtempnew.process_flag = 'Y' then '가능' when routtempnew.process_flag = 'N' then '불가' 
                              when routtempnew.process_flag = 'E' then '완료' when routtempnew.process_flag = 'P' then '진행'
                         end)
       , routtempnew.work_per       
       , routtempnew.sale_no        
       , routtempnew.seq_no         
       , routtempnew.cust_no        
       , routtempnew.scene_code     
       , scene.scene_desc           
       , routtempnew.napgi_date     
       , routtempnew.suju_type      
       , routtempnew.item_no        
       , item_name1 = (case when routtempnew.item_no = 'NO_ITEM' then 'NO_ITEM' else G1.item_name end)
       , routtempnew.qa                  
       , routtempnew.item_color          
       , color_name = color.color_name   
       , routtempnew.order_qty           
       , routtempnew.assy_item           
       , routtempnew.assy_qa              
       , routtempnew.bom_no              
       , routtempnew.uom                 
       , routtempnew.plan_qty            
       , routtempnew.setup_time          
       , routtempnew.work_time           
       , routtempnew.make_qty
       , routtempnew.plan_flag            
       , routtempnew.qpa                 
       , routtempnew.reserved_qty        
       , routtempnew.rem                 
       , routtempnew.area_no             
       , groupitem.item_name             
       , customer.cust_name              
       , pri      = 0                    
       , sale.open_close                 
       , ship_qty = dbo.uf_getdosumqty(routtempnew.sale_no, routtempnew.seq_no)
    FROM routtempnew WITH (NOLOCK)           
         LEFT OUTER JOIN groupitem    WITH (NOLOCK) ON routtempnew.assy_item  = groupitem.item_no
         LEFT OUTER JOIN groupitem G1 WITH (NOLOCK) ON routtempnew.item_no    = G1.item_no
         LEFT OUTER JOIN customer     WITH (NOLOCK) ON routtempnew.cust_no    = customer.cust_no 
         LEFT OUTER JOIN scene        WITH (NOLOCK) ON routtempnew.scene_code = scene.scene_code
         LEFT OUTER JOIN sale         WITH (NOLOCK) ON routtempnew.sale_no    = sale.order_no   
         LEFT OUTER JOIN color        WITH (NOLOCK) ON routtempnew.item_color = color.color_code 
         LEFT OUTER JOIN wc           WITH (NOLOCK) ON routtempnew.wc_no      = wc.work_no 
   WHERE ( routtempnew.area_no       = :as_area           )
     AND ( routtempnew.plan_flag     = 'N'                )
     AND ( routtempnew.process_flag <> 'C'                ) 
     AND ( routtempnew.wc_no         = :as_wcno           )
     AND ( routtempnew.work_date    >= DATEAdd(month, -3, getdate()) )
     AND ( sale.open_close           = 'O'                           ) 
     AND ( sale.order_date          >= DATEAdd(month, -3, getdate()) ) 
     AND NOT EXISTS (SELECT sale_no, seq FROM itemsosdet
                      WHERE itemsosdet.sale_no  = routtempnew.sale_no        
                        AND itemsosdet.seq      = routtempnew.seq_no    
                    )
" arguments=(("as_area", string),("as_wcno", string))  sort="cust_name A scene_desc A sale_no A seq_no A " )
group(level=1 header.height=0 trailer.height=68 by=("if(  wc_no  = 'F19' or  wc_no  = 'F20' or  wc_no  = 'F21' , item_no , left(qa, 13) )" ) header.color="536870912" trailer.color="15780518" )
