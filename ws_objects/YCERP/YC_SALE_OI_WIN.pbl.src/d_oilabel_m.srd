$PBExportHeader$d_oilabel_m.srd
$PBExportComments$출고요청 리스트
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=88 color="553648127" )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=84 color="536870912" )
table(column=(type=char(1) updatewhereclause=yes name=label_check dbname="label_check" values="	Y/	N" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="saledet.item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="GroupItem.item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="saledet.qa" )
 column=(type=decimal(2) updatewhereclause=yes name=order_qty dbname="saledet.order_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=issue_qty dbname="saledet.issue_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=rlse_qty dbname="saledet.rlse_qty" )
 column=(type=char(50) updatewhereclause=yes name=rem dbname="saledet.rem" )
 column=(type=char(8) updatewhereclause=yes name=part_yn dbname="part_yn" )
 column=(type=long updatewhereclause=yes name=qty dbname="saledet.qty" )
 column=(type=char(14) updatewhereclause=yes name=order_no dbname="saledet.order_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="saledet.seq_no" )
 column=(type=long updatewhereclause=yes name=count_number dbname="count_number" )
 column=(type=char(10) updatewhereclause=yes name=color_name dbname="color.color_name" )
 retrieve="          select 'N' label_check,
                          saledet.item_no, 
				     groupitem.item_name,
                          saledet.qa, 
                          saledet.order_qty, 
                          saledet.issue_qty, 
                          saledet.rlse_qty, 
                          saledet.rem, 
                          (case when v_item_fitting.item_no is null then '부속아님' else '부속' end)  part_yn, 
                          null qty,
					saledet.order_no,
					saledet.seq_no,
					isnull(label_item.number,0) count_number,
					color.color_name
          from saledet with(nolock) inner join groupitem with(nolock) on saledet.item_no = groupitem.item_no 
                                                                      left outer join v_item_fitting on saledet.item_no = v_item_fitting.item_no and substring(saledet.qa,1,14)+'00000' = v_item_fitting.qa
													  left outer join (
																					select order_no, seq_no, item_no, qa, count(*) number
																					from label_item with(nolock)
																					where order_no = :as_order_no
																					group by  order_no, seq_no, item_no, qa

																	    ) label_item on saledet.order_no = label_item.order_no 
																			          and   saledet.seq_no = label_item.seq_no 
																					and  saledet.item_no = label_item.item_no 
																					and  saledet.qa          = label_item.qa
													  left outer join  color with(nolock) on   saledet.color  = color.color_code
          where saledet.order_no = :as_order_no" arguments=(("as_order_no", string))  sort="part_yn A order_no A seq_no A " )
