compute(band=detail alignment="1" expression="if ( round = 'Y', if ( do_curr_code = 'WON', if (rlse_acc_qty < 0,  round (price  *  rlse_acc_qty,0), round (price  *  rlse_acc_qty ,0)), round (price * rlse_acc_qty , 2)), if ( do_curr_code = 'WON', if (rlse_acc_qty < 0,  truncate(price  *  rlse_acc_qty - 0.00001,0), truncate(price  *  rlse_acc_qty + 0.00001,0)), if (rlse_acc_qty < 0,  truncate(price * rlse_acc_qty - 0.00001, 2), truncate(price * rlse_acc_qty + 0.00001, 2))))"border="4" color="0" x="2501" y="4" height="60" width="512" format="#,##0.00" html.valueishtml="0"  name=rlse_amount visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="67108864" )
