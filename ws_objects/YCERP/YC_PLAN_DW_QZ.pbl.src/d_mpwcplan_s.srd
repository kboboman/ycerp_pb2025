summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=84 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=work_date dbname="RoutTempNew.work_date" )
 column=(type=long updatewhereclause=yes name=division dbname="RoutTempNew.division" initial="1" )
 column=(type=char(10) updatewhereclause=yes name=wc_no dbname="RoutTempNew.wc_no" )
 column=(type=long updatewhereclause=yes name=operation dbname="RoutTempNew.operation" initial="1" )
 column=(type=char(14) updatewhereclause=yes name=sale_no dbname="RoutTempNew.sale_no" initial="NO_SALE" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="RoutTempNew.seq_no" initial="0" )
 column=(type=datetime updatewhereclause=yes name=napgi_date dbname="RoutTempNew.napgi_date" )
 column=(type=decimal(4) updatewhereclause=yes name=order_qty dbname="RoutTempNew.order_qty" initial="0" )
 column=(type=char(10) updatewhereclause=yes name=assy_item dbname="RoutTempNew.assy_item" )
 column=(type=char(20) updatewhereclause=yes name=assy_qa dbname="RoutTempNew.assy_qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="RoutTempNew.uom" )
 column=(type=char(2) updatewhereclause=yes name=cuom dbname="cuom" )
 column=(type=decimal(4) updatewhereclause=yes name=plan_qty dbname="RoutTempNew.plan_qty" initial="0" )
 column=(type=decimal(4) updatewhereclause=yes name=make_qty dbname="RoutTempNew.make_qty" initial="0" )
 column=(type=char(50) updatewhereclause=yes name=routtempnew_rem dbname="RoutTempNew.rem" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 column=(type=char(10) updatewhereclause=yes name=color_color_name dbname="color.color_name" )
 column=(type=char(10) updatewhereclause=yes name=wc_work_name dbname="wc.work_name" )
 column=(type=char(5) updatewhereclause=yes name=pri dbname="pri" )
 column=(type=char(17) updatewhereclause=yes name=planno dbname="planno" )
 column=(type=char(60) updatewhereclause=yes name=item_name1 dbname="GroupItem.item_name" )
 column=(type=char(1) updatewhereclause=yes name=cflag dbname="cflag" )
 retrieve="  SELECT routtempnew.work_date   
               , routtempnew.division   
               , routtempnew.wc_no   
               , routtempnew.operation   
               , routtempnew.sale_no   
               , routtempnew.seq_no   
               , routtempnew.napgi_date   
               , routtempnew.order_qty   
               , routtempnew.assy_item   
               , routtempnew.assy_qa   
               , routtempnew.uom   
               , cuom = dbo.uf_getuom(routtempnew.uom)   
               , routtempnew.plan_qty   
               , routtempnew.make_qty   
               , routtempnew.rem   
               , customer.cust_name   
               , scene.scene_desc   
               , color.color_name   
               , wc.work_name   
               , pri    = (case when mpsdet.priority is null then '미' 
                                else (case when mpsdet.mpsorder_order is null 
                                                then right(  '  ' + convert(char(3), mpsdet.priority), 3 ) 
                                           else right(  '  ' + convert(char(3), mpsdet.order_seq), 3 ) 
                                      end) 
                             end)   
               , planno = (case when mpsdet.order_no is null then 'ZZZZZZZZZZZZZZZZZ' 
                                        else (case when mpsdet.mpsorder_order is null 
                                                        then mpsdet.order_no 
                                                   else mpsdet.mpsorder_order 
                                              end) 
                                   end)   
               , groupitem.item_name
               , cflag  = :as_flag
FROM routtempnew with(nolock) left outer join mpsdet with(nolock) on  routtempnew.sale_no = mpsdet.sale_no
                                                                                                                   and routtempnew.seq_no = mpsdet.seq_no
                                                                                                                   and routtempnew.division = mpsdet.division
                                                                                                                   and routtempnew.operation  = mpsdet.operation
                                                                                                                   and routtempnew.wc_no = mpsdet.wc_no
                                                           left outer join groupitem with(nolock) on routtempnew.assy_item = groupitem.item_no     
                                                           left outer join customer with(nolock) on routtempnew.cust_no  = customer.cust_no
                                                           left outer join scene with(nolock) on routtempnew.scene_code = scene.scene_code 
                                                                                                               and routtempnew.cust_no = scene.cust_no
                                                           left outer join  color with(nolock) on routtempnew.item_color = color.color_code
                                                           inner join wc with(nolock) on routtempnew.wc_no = wc.work_no
/*        
    FROM routtempnew   
       , customer   
       , scene   
       , color   
       , wc   
       , mpsdet   
       , groupitem  
   WHERE ( routtempnew.cust_no    *= customer.cust_no) 
     and ( routtempnew.scene_code *= scene.scene_code) 
     and ( routtempnew.cust_no    *= scene.cust_no) 
     and ( routtempnew.item_color *= color.color_code) 
     and ( routtempnew.sale_no    *= mpsdet.sale_no) 
     and ( routtempnew.seq_no     *= mpsdet.seq_no) 
     and ( routtempnew.division   *= mpsdet.division) 
     and ( routtempnew.operation  *= mpsdet.operation) 
     and ( routtempnew.assy_item  *= groupitem.item_no) 
     and ( routtempnew.wc_no      *= mpsdet.wc_no) 
     and ( routtempnew.wc_no       = wc.work_no ) 
     */
     where (( wc.work_name             like :as_wc   ) AND  
                  ( routtempnew.work_date between :as_start AND :as_end ) AND  
                  ( routtempnew.plan_flag    like :as_flag ) AND 
                  ( routtempnew.area_no         = :as_area ) 
                 )" arguments=(("as_wc", string),("as_start", date),("as_end", date),("as_flag", string),("as_area", string))  sort="work_date A wc_no A planno A pri A napgi_date A operation A sale_no A seq_no A assy_item A assy_qa A " )
