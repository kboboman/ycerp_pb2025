 column=(type=char(1) update=yes updatewhereclause=yes name=cust_type dbname="customer.cust_type" values="외상업체	A/간이업체	B/개인업체	C/내부업체	D/수출업체	E/부산판매	F/" )
 column=(type=char(80) update=yes updatewhereclause=yes name=shipto_addr dbname="customer.shipto_addr" )
 column=(type=char(10) update=yes updatewhereclause=yes name=terms dbname="customer.terms" )
 column=(type=char(1) update=yes updatewhereclause=yes name=credit_level dbname="customer.credit_level" initial="B" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=credit_limit dbname="customer.credit_limit" initial="0" )
 column=(type=char(3) update=yes updatewhereclause=yes name=curr_code dbname="customer.curr_code" initial="WON" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=balance_amt dbname="customer.balance_amt" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=bill_amount dbname="customer.bill_amount" initial="0" )
 column=(type=datetime update=yes updatewhereclause=yes name=start_date dbname="customer.start_date" )
 column=(type=char(20) update=yes updatewhereclause=yes name=buyer1 dbname="customer.buyer1" )
 column=(type=char(20) update=yes updatewhereclause=yes name=buyer2 dbname="customer.buyer2" )
 column=(type=char(10) update=yes updatewhereclause=yes name=pre_salesman dbname="customer.pre_salesman" )
 column=(type=char(10) update=yes updatewhereclause=yes name=salesman dbname="customer.salesman" )
 column=(type=datetime update=yes updatewhereclause=yes name=last_tn_date dbname="customer.last_tn_date" initial="today()" )
 column=(type=char(1) updatewhereclause=yes name=open_close dbname="customer.open_close" )
 column=(type=char(1) updatewhereclause=yes name=level_grade dbname="customer.level_grade" )
 column=(type=char(20) updatewhereclause=yes name=custinfo_guarentee dbname="custinfo.guarentee" )
