table(column=(type=char(12) updatewhereclause=yes name=aroiinv_no dbname="aroiinv.AROIINV_NO" )
 column=(type=char(20) updatewhereclause=yes name=register_no dbname="aroiinv.REGISTER_NO" )
 column=(type=char(3) updatewhereclause=yes name=inv_area dbname="aroiinv.INV_AREA" )
 column=(type=datetime updatewhereclause=yes name=oi_date dbname="aroiinv.OI_DATE" )
 column=(type=decimal(4) updatewhereclause=yes name=aroiinv_cash dbname="aroiinv.AROIINV_CASH" )
 column=(type=decimal(4) updatewhereclause=yes name=aroiinv_aroiinv_rate dbname="aroiinv.AROIINV_RATE" )
 column=(type=decimal(4) updatewhereclause=yes name=ship_cost dbname="aroiinv.SHIP_COST" )
 column=(type=char(1) updatewhereclause=yes name=esero dbname="aroiinv.ESERO" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.CUST_NAME" )
 column=(type=char(12) updatewhereclause=yes name=vat_no dbname="gltrana.VAT_NO" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="aroiinv.CUST_NO" )
 column=(type=decimal(0) updatewhereclause=yes name=dc dbname="aroiinv.DC" )
 column=(type=decimal(0) updatewhereclause=yes name=aroiinv_dc_rate dbname="aroiinv.DC_RATE" )
 column=(type=decimal(0) updatewhereclause=yes name=aroiinv_discount dbname="aroiinv.DISCOUNT" )
 column=(type=long updatewhereclause=yes name=chk dbname="CHK" values="	0/	1" )
 column=(type=char(1) updatewhereclause=yes name=aroiinv_open_close dbname="aroiinv.OPEN_CLOSE" )
 column=(type=char(12) updatewhereclause=yes name=glreg dbname="GLREG" )
 column=(type=char(10) updatewhereclause=yes name=glsubcode_sub_code dbname="glsubcode.SUB_CODE" )
 retrieve="  SELECT DISTINCT A.AROIINV_NO   
       , A.REGISTER_NO   
       , A.INV_AREA   
       , A.OI_DATE   
       , A.AROIINV_CASH   
       , A.AROIINV_RATE   
       , A.SHIP_COST   
       , A.ESERO   
       , B.CUST_NAME   
       , C.VAT_NO   
       , A.CUST_NO   
       , A.DC   
       , A.DC_RATE   
       , A.DISCOUNT   
       , CHK = 1   
       , A.OPEN_CLOSE  
       , GLREG   = (D.REG1+'-'+D.REG2+'-'+D.REG3)
       , D.SUB_CODE
    FROM AROIINV A
         LEFT OUTER JOIN CUSTOMER  B ON A.CUST_NO     = B.CUST_NO 
         LEFT OUTER JOIN GLTRANA   C ON A.AROIINV_NO  = C.VAT_NO  
         LEFT OUTER JOIN GLSUBCODE D ON D.SUB_CLASS = '01'
          AND SUBSTRING(A.REGISTER_NO,1,3)  = D.REG1
          AND SUBSTRING(A.REGISTER_NO,5,2)  = D.REG2
          AND SUBSTRING(A.REGISTER_NO,8,5)  = D.REG3
          AND A.CUST_NO                     = D.SUB_CODE
   WHERE ( CONVERT(CHAR(7),A.OI_DATE,111)   = :as_yyyymm ) 
     AND ( A.DELETE_FLAG       = 'N' ) 
     AND ( A.OPEN_CLOSE        = :as_openclose ) 
     AND ( A.INV_AREA       LIKE :as_area  )    

/*
-- 매출전표 SELECT --
CODE,    거래처,             전자,          공급가액,               부가세(공),   운반비,    부가세(운),
cust_no, customer_cust_name, aroiinv_esero, aroiinv_cash - tot_dis, aroiinv_rate, ship_cost, truncate(ship_cost * 0.1 + 0.0000001, 0),

합계,
aroiinv_cash + aroiinv_rate + ship_cost + ship_vat - tot_dis,

계산서번호, 계산서일자, 사업장,   사업등록번호, 사업자(회계), 코드
aroiinv_no, oi_date,    inv_area, register_no,  glreg,        glsubcode_sub_code
*/

/*
 사업장 S01 : 시화, H01 : 화곡, Z01 : 대전     
 PART   03,         02,         08
 
 일반공제분
*/
" arguments=(("as_yyyymm", string),("as_openclose", string),("as_area", string)) )
