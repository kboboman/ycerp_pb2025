table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=work_no dbname="work_no" )
 column=(type=datetime update=yes updatewhereclause=yes key=yes name=scan_date dbname="scan_date" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=scan_no dbname="scan_no" )
 column=(type=long update=yes updatewhereclause=yes name=scan_qty dbname="scan_qty" )
