table(column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(14) updatewhereclause=yes name=sale_order_no dbname="sale.order_no" )
 column=(type=datetime updatewhereclause=yes name=sale_due_date dbname="sale.due_date" )
 column=(type=long updatewhereclause=yes name=saledet_seq_no dbname="saledet.seq_no" )
 column=(type=char(20) updatewhereclause=yes name=saledet_qa dbname="saledet.qa" )
 column=(type=char(2) updatewhereclause=yes name=saledet_uom dbname="saledet.uom" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_order_qty dbname="saledet.order_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_acc_qty dbname="saledet.acc_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=saledet_price dbname="saledet.price" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_rlse_qty dbname="saledet.rlse_qty" )
 column=(type=char(30) updatewhereclause=yes name=sale_ship_flag dbname="ship_flag" )
 column=(type=datetime updatewhereclause=yes name=sale_cust_po_date dbname="sale.cust_po_date" )
 column=(type=char(50) updatewhereclause=yes name=saledet_rem dbname="saledet.rem" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene.scene_desc" )
 column=(type=char(10) updatewhereclause=yes name=scene_scene_charge dbname="scene.scene_charge" )
 column=(type=char(15) updatewhereclause=yes name=scene_scene_tel dbname="scene.scene_tel" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name dbname="login.user_name" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name dbname="login.user_name" )
 column=(type=char(10) updatewhereclause=yes name=con_text dbname="con_text" )
 column=(type=char(80) updatewhereclause=yes name=sale_rem dbname="sale.rem" )
 column=(type=char(10) updatewhereclause=yes name=color_color_name dbname="color.color_name" )
 column=(type=char(1) updatewhereclause=yes name=sale_ship_case dbname="sale.ship_case" values="정기화물	J/택배	T/오토바이	A/선박	S/항공	P/기타	E/ 	 /" )
 column=(type=char(80) updatewhereclause=yes name=sale_rem1 dbname="rem1" )
 column=(type=char(80) updatewhereclause=yes name=sale_rem2 dbname="rem2" )
 column=(type=datetime updatewhereclause=yes name=sale_plan_date dbname="sale.plan_date" )
 column=(type=decimal(2) updatewhereclause=yes name=sale_ysp_qty dbname="sale.ysp_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=ysp_qty2 dbname="ysp_qty2" )
 column=(type=char(10) updatewhereclause=yes name=color_color_name dbname="color.color_name" )
 column=(type=char(1) updatewhereclause=yes name=sale_type dbname="sale.type" values="일체형	A/분리형	P/ U-형	U/기타	E/" )
 column=(type=long updatewhereclause=yes name=sale_class dbname="sale.class" )
 retrieve="  SELECT customer.cust_name,   
         sale.order_no,   
         sale.due_date,   
         saledet.seq_no,   
         saledet.qa,   
         saledet.uom,   
         saledet.order_qty,   
         saledet.acc_qty,   
         saledet.price,   
         groupitem.item_name,   
         saledet.rlse_qty,   
         ship_flag = dbo.uf_getshipflag(sale.ship_flag),   
         sale.cust_po_date,   
         saledet.rem,   
         scene.scene_desc,   
         scene.scene_charge,   
         scene.scene_tel,   
         login_a.user_name,   
         login_b.user_name,   
         con_text = ( case when  sale.confirm_flag = ~"Y~" then login_c.user_name else ~"미확정~" end),   
         sale.rem,   
         color_a.color_name,   
         sale.ship_case,   
         sale.rem1,   
         sale.rem2,   
         sale.plan_date,   
         sale.ysp_qty,   
         sale.ysp_qty2,   
         color_b.color_name,   
         sale.type,   
         sale.class  
    FROM sale LEFT OUTER JOIN scene ON sale.scene_code = scene.scene_code 
				  LEFT OUTER JOIN login login_a ON sale.login_id = login_a.user_id  
				  LEFT OUTER JOIN login login_b ON sale.salesman = login_b.user_id  
				  LEFT OUTER JOIN login login_c ON sale.confirm_user = login_c.user_id
			     LEFT OUTER JOIN color color_b ON sale.color = color_b.color_code,   
			saledet LEFT OUTER JOIN color color_a ON saledet.color = color_a.color_code,  
         customer,   
         groupitem  
   WHERE ( sale.order_no = saledet.order_no ) and  
         ( sale.cust_no = customer.cust_no ) and  
         ( saledet.item_no = groupitem.item_no ) and  
         ( ( sale.order_no = :as_order ) )    
" arguments=(("as_order", string))  sort="sale_order_no A saledet_seq_no A " )
