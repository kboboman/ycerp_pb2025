$PBExportHeader$d_mpworkman_ct.srd
$PBExportComments$근태관리 명부집계
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no  crosstab.dynamic = yes grid.lines=0 grid.columnmove=no selected.mouse=no )
header[1](height=0 color="536870912" )
header[2](height=80 color="536870912" )
header[3](height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=work_name dbname="work_name" )
 column=(type=char(20) updatewhereclause=yes name=name_kor dbname="name_kor" )
 column=(type=number updatewhereclause=yes name=man_type dbname="man_type" values="외국	1/	0/" )
 column=(type=char(20) updatewhereclause=yes name=work_stime dbname="work_stime" )
 column=(type=char(20) updatewhereclause=yes name=work_etime dbname="work_etime" )
 column=(type=number updatewhereclause=yes name=calctime dbname="calctime" )
 column=(type=char(20) updatewhereclause=yes name=job_name dbname="job_name" )
 column=(type=char(20) updatewhereclause=yes name=company dbname="company" )
 column=(type=number updatewhereclause=yes name=man_cnt dbname="man_cnt" )
 column=(type=number updatewhereclause=yes name=booking dbname="booking" )
 column=(type=number updatewhereclause=yes name=day_labor dbname="day_labor" )
 column=(type=number updatewhereclause=yes name=man_type_1 dbname="man_type_1" )
 retrieve="  SELECT area_no    = s.area_no   
       , work_no    = s.work_no   
       , work_name  = s.work_nm  
       , work_day   = s.work_day   
       , user_id    = s.user_id   
       , name_kor   = s.name_kor   
       , man_cnt    = 1
       , man_type   = (case when s.man_type = 'F' then 1 else 0 end)
       , day_labor  = (case when s.day_labor= 'Y' then 1 else 0 end)
       , work_stime = convert(char(5),s.work_stime,108)
       , work_etime = convert(char(5),s.work_etime,108)  
       , calctime   = (case when convert(char(8),s.work_stime,108) <= '12:00:00' AND
                                 convert(char(8),s.work_etime,108) >= '13:00:00'  
                                 then (datediff(mi, s.work_stime, s.work_etime) - 60.0) / 60.0    /* 1시간공제 */
                            else datediff(mi, s.work_stime, s.work_etime) / 60.0                  /* 순수시간 */
                       end)
       , booking    = (case when s.booking  = 'Y' then 1 else 0 end)
       , job_no     = s.job_no 
       , job_name   = s.job_name  
       , contents   = s.contents   
       , company    = s.company   
       , sys_date   = s.sys_date  
    FROM sfcworkman S
   WHERE ((:as_area    = '%' AND s.area_no LIKE :as_area) OR
          (:as_area   <> '%' AND s.area_no    = :as_area)
         )
     AND ((:as_workno  = '%' AND s.work_no LIKE :as_workno) OR
          (:as_workno <> '%' AND s.work_no    = :as_workno)
         )
     AND ( s.work_day  between :as_sdate AND :as_edate    )
     AND ( s.absent   IS NULL ) /* 결근 */
" arguments=(("as_area", string),("as_workno", string),("as_sdate", string),("as_edate", string))  sort="work_name A day_labor A man_type A name_kor A work_stime A " )
group(level=1 header.height=0 trailer.height=80 by=("work_name" ) header.color="536870912" trailer.color="12639424" )
