$PBExportComments$자재매입수정 및 취소 세금계산서번호 선택(1999/05/31, 이인호)
release 8;
datawindow(units=0 timer_interval=0 color=79219928 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=68 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=oi_date dbname="apoiinv.oi_date" )
 column=(type=char(12) updatewhereclause=yes name=apoiinv_no dbname="apoiinv.apoiinv_no" )
 column=(type=decimal(4) updatewhereclause=yes name=apoiinv_cash dbname="apoiinv.apoiinv_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=apoiinv_rate dbname="apoiinv.apoiinv_rate" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"apoiinv~" ) COLUMN(NAME=~"apoiinv.oi_date~") COLUMN(NAME=~"apoiinv.apoiinv_no~") COLUMN(NAME=~"apoiinv.apoiinv_cash~") COLUMN(NAME=~"apoiinv.apoiinv_rate~")WHERE(    EXP1 =~"( apoiinv.supp_no~"   OP =~"=~"    EXP2 =~":as_supp_no )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( apoiinv.open_close~"   OP =~"=~"    EXP2 =~"'O' )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( apoiinv.delete_flag~"   OP =~"=~"    EXP2 =~"'N' )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"apoiinv.printed~"   OP =~"=~"    EXP2 =~"'N'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( apoiinv.oi_date~"   OP =~"between~"    EXP2 =~":ad_start and :ad_end)~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"apoiinv.inv_area~"   OP =~"=~"    EXP2 =~":as_area~" ) ) ARG(NAME = ~"as_supp_no~" TYPE = string)  ARG(NAME = ~"ad_start~" TYPE = date)  ARG(NAME = ~"ad_end~" TYPE = date)  ARG(NAME = ~"as_area~" TYPE = string) " arguments=(("as_supp_no", string),("ad_start", date),("ad_end", date),("as_area", string))  sort="oi_date D " )
