 column=(type=char(50) updatewhereclause=yes name=type dbname="CODEMST.type" )
 column=(type=char(1) updatewhereclause=yes name=use_yn dbname="CODEMST.use_yn" )
 retrieve="  SELECT CODEMST.item_cd,   
         CODEMST.item_nm,   
         CODEMST.category,   
         CODEMST.sort,   
         CODEMST.type,   
         CODEMST.use_yn  
    FROM CODEMST   
   WHERE codemst.type    = :as_type" arguments=(("as_type", string))  sort="sort A " )
