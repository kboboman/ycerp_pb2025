 column=(type=char(60) updatewhereclause=yes name=owner_addr_origin dbname="car_carriage.owner_addr_origin" )
 column=(type=char(13) update=yes updatewhereclause=yes name=owner_tel dbname="car_carriage.owner_tel" )
 column=(type=char(13) updatewhereclause=yes name=owner_tel_origin dbname="car_carriage.owner_tel_origin" )
