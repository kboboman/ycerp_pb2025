release 5;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no )
header(height=1 color="536870912" )
summary(height=1 color="536870912" )
footer(height=1 color="536870912" )
detail(height=69 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="groupitem.item_no" )
 column=(type=char(30) update=yes updatewhereclause=yes name=item_name dbname="groupitem.item_name" )
 column=(type=char(1) updatewhereclause=yes name=item_source dbname="item.source" )
 retrieve="PBSELECT( VERSION(400) DISTINCT ()TABLE(NAME=~"groupitem~" )  TABLE(NAME=~"item~" ) COLUMN(NAME=~"groupitem.item_no~") COLUMN(NAME=~"groupitem.item_name~") COLUMN(NAME=~"item.source~")    JOIN (LEFT=~"groupitem.item_no~"    OP =~"=~"RIGHT=~"item.item_no~" )WHERE(    EXP1 =~"item.source~"   OP =~"<>~"    EXP2 =~"'W'~" ) ) " )
column(band=detail id=2 alignment="0" tabsequence=20 border="0" color="0" x="362" y="96" height="61" width="993" format="[general]"  name=item_name edit.limit=30 edit.case=any edit.autoselect=yes edit.autohscroll=yes  font.face="굴림체" font.height="-10" font.weight="400"  font.family="2" font.pitch="2" font.charset="-127" background.mode="1" background.color="536870912" )
column(band=detail id=1 alignment="0" tabsequence=10 border="0" color="0" x="5" y="96" height="61" width="353" format="[general]"  name=item_no edit.limit=10 edit.case=any edit.autoselect=yes edit.autohscroll=yes  font.face="굴림체" font.height="-10" font.weight="400"  font.family="2" font.pitch="2" font.charset="-127" background.mode="1" background.color="536870912" )
compute(band=detail alignment="0" expression=" item_no  +  ~"  ~"  +  item_name "border="0" color="0" x="14" y="4" height="61" width="1495" format="[general]"  name=concat  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="-127" background.mode="2" background.color="16777215" )
