public function boolean wf_itemselect (datawindow arg_dw, string arg_ms, integer ai_row, integer ai_flag)
end prototypes

event ue_1;//
string ls_colx

em_s.text = string(today(), "yyyy/mm/dd")
em_e.text = string(today(), "yyyy/mm/dd")
dw_9.settransobject(sqlca)
dw_9.visible = false

dw4.settransobject(sqlca)
dw5.settransobject(sqlca)
dw6.settransobject(sqlca)
dw7.settransobject(sqlca)
dw8.settransobject(sqlca)

dw3.dataobject = 'd_ippurdet'
dw3.settransobject(sqlca)
dw3.getchild('draw_no',idwc_draw)
idwc_draw.settransobject(sqlca)
is_select = idwc_draw.Describe("DataWindow.Table.Select")

dw_1.getchild('supp_no',idwc_supp)
idwc_supp.settransobject(sqlca)
tab_1.tabpage_2.dw_loc.settransobject(sqlca)
tab_1.tabpage_2.dw_loc.insertrow(0)

dw_area.settransobject(sqlca)
dw_area.insertrow(0)  
dw_area.object.area[1] = gs_area

SELECT def_loc INTO :is_loc FROM area WHERE area_no = :gs_area;
tab_1.tabpage_2.dw_loc.object.loc_no[1] = is_loc
tab_1.tabpage_4.em_3.text  = "HD" + string(today(), "yyyy")		// 수주기본 사업장 
tab_1.tabpage_4.cb_18.text = "수주물품별 재고현황(NEW) " + string(dw_jaego.rowcount()) + " 건 가져오기"

if dw_jaego.rowcount() > 0 then
	tab_1.selecttab(4)	// 수주내역
	pb_insert.triggerevent(clicked!)
	dw_1.setcolumn("supp_no")
	dw_1.setfocus()
	MessageBox("확인","수주물품별 재고현황(NEW) 자동처리 작업입니다.~r~r거래처를 먼저 선택하십시오.")
end if


// 알루미늄, 스틸 비중 읽어오기
SELECT al_rate, st_rate INTO :ia_rate, :is_rate FROM globals;

// 담당자별 거래처유형 필터링
dw_11.settransobject(sqlca)
dw_11.insertrow(0)
if gs_userid = 'bestvic' then	// 최성욱
	DataWindowChild state_child
	dw_11.GetChild('supp_no', state_child)
	state_child.SetTransObject(SQLCA)	
end if

end event

public function boolean wf_move2 ();long ll_rowcount,ll_rowcount1,ll_cnt,ll_find,ll_row,ll_count
string ls_plan,ls_order,ls_uom,ls_supp,ls_qa,ls_item,ls_subcon
string ls_qa1, ls_loc, ls_comp, ls_sale, ls_scene
decimal {4} lr_cost

dw_1.accepttext()
dw4.accepttext()

if dw_1.rowcount() < 1 then 
	MessageBox("오류","발주를 입력하십시오.", Exclamation!)
	dw4.selectrow(0,false)
	return false
end if	

ls_supp = trim(dw_1.object.supp_no[1])

if isnull(ls_supp) or ls_supp=""  then
	MessageBox("오류","발주헤더에 거래처를 입력하십시오.", Exclamation!)
	dw4.selectrow(0,false)
	return false
end if	
dw_1.object.subcon[1] = 'P'
ll_rowcount1 = dw3.rowcount()
ll_rowcount  = dw4.rowcount()

ll_count = 0
for ll_cnt = 1 to ll_rowcount
	if dw4.isselected(ll_cnt) then
      ll_count ++
	end if
next
if ll_count = 0 then
	messagebox('오류','외주가공대상물품을 선택하십시요.',exclamation!)
	return false
end if

for ll_cnt = 1 to ll_rowcount
	if dw4.isselected(ll_cnt) then
		ls_plan = trim(dw4.object.order_no[ll_cnt])
		if ll_rowcount1 < 1 then
			ll_find = 0
		else
		   ll_find = dw3.find("product_no = '" + ls_plan + "'",1,dw3.rowcount())
		end if
		if ll_find = 0 then
			ls_item = trim(dw4.object.item_no[ll_cnt])
			ls_qa   = trim(dw4.object.qa[ll_cnt])
			ls_uom  = trim(dw4.object.groupitem_uom[ll_cnt])
		 	lr_cost = wf_price (ls_supp, ls_item, ls_qa, ls_uom)

			ll_row = dw3.insertrow(0)
			dw3.object.seq_no[ll_row] = ll_row
			dw3.object.price[ll_row] = lr_cost
			dw3.object.cprice[ll_row] = lr_cost
			dw3.object.com_uom[ll_row] = ls_uom
			dw3.object.uom[ll_row] = gf_uom(ls_uom)
			dw3.object.com_qty[ll_row] = gf_getqty(ls_item, ls_qa, ls_uom, dw4.object.plan_qty[ll_cnt])
			if is_round = 'Y' then
				dw3.object.amt[ll_row] = round(dw3.object.com_qty[ll_row] + dw3.object.price[ll_row],0 )
			else
				dw3.object.amt[ll_row] = truncate(dw3.object.com_qty[ll_row] + dw3.object.price[ll_row],0 )
			end if
			dw3.object.order_no[ll_row]   = ls_order
			dw3.object.product_no[ll_row] = ls_plan
			dw3.object.item_no[ll_row]    = ls_item
			
			dw3.object.qa[ll_row]         = ls_qa
         dw3.object.item_item_name[ll_row]  =  dw4.object.itemname1[ll_cnt]
			dw3.object.order_qty[ll_row]  = dw4.object.plan_qty[ll_cnt]
			dw3.object.unit_qty[ll_row] = dw3.object.order_qty[ll_row]
			dw3.object.rlse_date[ll_row]  =  wf_today()
			dw3.object.due_date[ll_row]   =  dw4.object.due_date[ll_cnt]
			dw3.object.sale_no[ll_row]    =  dw4.object.sudodet_sale_no[ll_cnt]
			dw3.object.sale_seq[ll_row]   =  dw4.object.sudodet_seq_no[ll_cnt]
			ls_sale = dw3.object.sale_no[ll_row]
			select scene.scene_desc into :ls_scene from sale, scene
			 where order_no = :ls_sale
			   and scene.scene_code = sale.scene_code;
			if isnull(ls_scene) or trim(ls_scene) = '' then
				ls_scene = ''
			else
				ls_scene = '/' + ls_scene
			end if
			dw3.object.cust_name[ll_row]  =  dw4.object.customer_cust_name[ll_cnt] + ls_scene
			dw3.object.color[ll_row]      =  dw4.object.sudodet_color[ll_cnt]
			dw3.object.sale_rem[ll_row]      =  dw4.object.rem[ll_cnt]
			dw3.object.pur_type[ll_row]   =  'P'
//			dw3.object.coil_no[ll_row]      =  dw4.object.issue_lot[ll_cnt] //원코일번호
//			dw4.RowsMove ( ll_cnt, ll_cnt, Primary!, dw4, 1, Filter! )
//			ll_cnt = ll_cnt - 1
		end if
	end if
next
if wf_update1(dw4,'N') = false then
	return false
end if
messagebox('확인','외주가공대상물품이 이동되었습니다.',information!)
return true

end function

public function boolean wf_move3 ();long ll_rowcount,ll_rowcount1,ll_cnt,ll_find,ll_row,ll_count
string ls_plan,ls_order,ls_uom,ls_supp,ls_qa,ls_item,ls_subcon,ls_qa1, ls_sale, ls_scene
decimal {4} lr_cost

dw_1.accepttext()
dw5.accepttext()

if dw_1.rowcount() < 1 then 
	MessageBox("오류","발주헤더를 입력하십시오.", Exclamation!)
	dw5.selectrow(0,false)
	return false
end if	
ls_supp = trim(dw_1.object.supp_no[1])

if isnull(ls_supp) or ls_supp=""  then
	MessageBox("오류","발주헤더에 거래처를 입력하십시오.", Exclamation!)
	dw5.selectrow(0,false)
	return false
end if	

dw_1.object.subcon[1] = 'Y'
ll_rowcount1 = dw3.rowcount()
ll_rowcount  = dw5.rowcount()

ll_count = 0
for ll_cnt = 1 to ll_rowcount
	if dw5.isselected(ll_cnt) then
      ll_count ++
	end if
next
if ll_count = 0 then
	messagebox('오류','외주구매대상물품을 선택하십시요.',exclamation!)
	return false
end if

for ll_cnt = 1 to ll_rowcount
	if dw5.isselected(ll_cnt) then
		ls_plan = trim(dw5.object.order_no[ll_cnt])
		if ll_rowcount1 < 1 then
			ll_find = 0
		else
		   ll_find = dw3.find("product_no = '" + ls_plan + "'", 1, dw3.rowcount())
		end if
		if ll_find = 0 then
			ls_item = trim(dw5.object.item_no[ll_cnt])
			ls_qa   = trim(dw5.object.qa[ll_cnt])
			ls_uom  = trim(dw5.object.groupitem_uom[ll_cnt])
		 	lr_cost = wf_price (ls_supp, ls_item, ls_qa, ls_uom)
			
         ll_row = dw3.insertrow(0)
			dw3.object.seq_no[ll_row] = ll_row
			dw3.object.price[ll_row] = lr_cost
			dw3.object.cprice[ll_row] = lr_cost
			dw3.object.com_uom[ll_row] = ls_uom
			dw3.object.uom[ll_row] = gf_uom(ls_uom)
			dw3.object.com_qty[ll_row] = gf_getqty(ls_item, ls_qa, ls_uom, dw5.object.plan_qty[ll_cnt])
			if is_round = 'Y' then
				dw3.object.amt[ll_row] = round(dw3.object.com_qty[ll_row] + dw3.object.price[ll_row],0 )
			else
				dw3.object.amt[ll_row] = truncate(dw3.object.com_qty[ll_row] + dw3.object.price[ll_row],0 )
			end if

			dw3.object.order_no[ll_row]   = ls_order
			dw3.object.product_no[ll_row] = ls_plan
			dw3.object.item_no[ll_row]    = ls_item
			dw3.object.qa[ll_row]         = ls_qa
         dw3.object.item_item_name[ll_row]  =  dw5.object.groupitem_item_name[ll_cnt]
			dw3.object.order_qty[ll_row]  = dw5.object.plan_qty[ll_cnt]
			dw3.object.unit_qty[ll_row] = dw3.object.order_qty[ll_row]
			dw3.object.rlse_date[ll_row]   =  wf_today()
			dw3.object.due_date[ll_row]   =  dw5.object.due_date[ll_cnt]
			dw3.object.sale_no[ll_row]    =  dw5.object.sudodet1_sale_no[ll_cnt]
			dw3.object.sale_seq[ll_row]   =  dw5.object.sudodet1_seq_no[ll_cnt]
			ls_sale = dw3.object.sale_no[ll_row]
			select scene.scene_desc into :ls_scene from sale, scene
			 where order_no = :ls_sale
			   and scene.scene_code = sale.scene_code;
			if isnull(ls_scene) or trim(ls_scene) = '' then
				ls_scene = ''
			else
				ls_scene = '/' + ls_scene
			end if
			dw3.object.cust_name[ll_row]  =  dw5.object.customer_cust_name[ll_cnt] + ls_scene
			dw3.object.color[ll_row]      =  dw5.object.sudodet1_color[ll_cnt]	
			dw3.object.sale_rem[ll_row]   =  dw5.object.rem[ll_cnt]
			dw3.object.pur_type[ll_row]   =  'Y'
			dw5.RowsMove ( ll_cnt, ll_cnt, Primary!, dw5, 1, Filter! )
			ll_cnt = ll_cnt - 1
		end if
	end if
next
messagebox('확인','외주구매대상물품이 이동되었습니다.',information!)
return true

end function

public function boolean wf_move4 ();long    ll_rowcount, ll_rowcount1, ll_cnt,  ll_find, ll_row, ll_count
string  ls_plan, ls_order, ls_uom, ls_supp, ls_qa, ls_item, ls_subcon, ls_qa1, ls_scene, ls_sale
decimal {4} lr_cost, lr_qty

dw_1.accepttext()
dw6.accepttext()

if dw_1.rowcount() < 1 then 
	MessageBox("오류","발주헤더를 입력하십시오.", Exclamation!)
	dw6.selectrow(0,false)
	return false
end if	

ls_order  = trim(dw_1.object.order_no[1])
ls_subcon = trim(dw_1.object.subcon[1])

if ls_subcon = "Y" OR ls_subcon = "J" or ls_subcon = "P"  then
	MessageBox("오류","구매발주가 아닙니다.", Exclamation!)
	dw6.selectrow(0,false)
	return false
end if	

ls_supp = trim(dw_1.object.supp_no[1])
if isnull(ls_supp) or ls_supp = "" then
	MessageBox("오류","발주헤더에 거래처를 입력하십시오.", Exclamation!)
	dw6.selectrow(0,false)
	return false
end if	

ll_rowcount1 = dw3.rowcount()
ll_rowcount  = dw6.rowcount()

ll_count = 0
for ll_cnt = 1 to ll_rowcount
	if dw6.isselected(ll_cnt) then
      ll_count ++
	end if
next
if ll_count = 0 then
	messagebox('오류','수주대상물품을 선택하십시요.',exclamation!)
	return false
end if

for ll_cnt = 1 to ll_rowcount
	if dw6.isselected(ll_cnt) then
		if ll_rowcount1 < 1 then
			ll_find = 0
		else
		   ll_find = dw3.find("item_no = '" + ls_item + "' and qa = '" + ls_qa + "'",1,dw3.rowcount())
		end if
		if ll_find = 0 then
			ls_item = trim(dw6.object.item_no[ll_cnt])
			ls_qa   = trim(dw6.object.qa[ll_cnt])
			ls_uom  = trim(dw6.object.uom[ll_cnt])
		 	lr_cost = wf_price(ls_supp, ls_item, ls_qa, ls_uom)

			ll_row = dw3.insertrow(0)
			dw3.object.seq_no[ll_row]   = ll_row
			dw3.object.price[ll_row]    = lr_cost
			dw3.object.cprice[ll_row]   = lr_cost
			dw3.object.com_uom[ll_row]  = dw6.object.uom[ll_cnt]
			dw3.object.uom[ll_row]      = gf_uom(ls_uom)
			dw3.object.order_no[ll_row] = ls_order
			dw3.object.item_no[ll_row]  = ls_item
			dw3.object.qa[ll_row]       = ls_qa
			dw3.object.due_date[ll_row] = wf_today()
         dw3.object.item_item_name[ll_row]  =  dw6.object.item_name[ll_cnt]
			if dw6.object.req_qty[ll_cnt] < 0 then
				lr_qty = dw6.object.req_qty[ll_cnt] * -1
			else
				lr_qty = dw6.object.saledetqty[ll_cnt]
			end if
			
			dw3.object.com_qty[ll_row] = gf_getqty(ls_item, ls_qa, ls_uom, lr_qty)
			if is_round = 'Y' then
				dw3.object.amt[ll_row] = round(dw3.object.com_qty[ll_row] + dw3.object.price[ll_row],0 )
			else
				dw3.object.amt[ll_row] = truncate(dw3.object.com_qty[ll_row] + dw3.object.price[ll_row],0 )
			end if

			setnull(ls_scene)
			dw3.object.sale_no[ll_row]    =  dw6.object.order_no[ll_cnt]
			ls_sale = dw6.object.order_no[ll_cnt]
			dw3.object.sale_seq[ll_row]   =  dw6.object.seq_no[ll_cnt]
			dw3.object.sale_rem[ll_row]   =  dw6.object.saledet_rem[ll_cnt]
			SELECT scene.scene_desc INTO :ls_scene FROM sale, scene
			 WHERE order_no = :ls_sale  AND scene.scene_code = sale.scene_code;
			if isnull(ls_scene) or trim(ls_scene) = '' then
				ls_scene = ''
			else
				ls_scene = '/' + ls_scene
			end if
			dw3.object.cust_name[ll_row] = dw6.object.cust_name[ll_cnt] + ls_scene
			dw3.object.order_qty[ll_row] = lr_qty
//			dw3.object.com_qty[ll_row]   = lr_qty
			dw3.object.unit_qty[ll_row]  = lr_qty
			dw3.object.cnt[ll_row] = 1
			dw3.object.rlse_date[ll_row] = wf_today()
         dw3.object.pur_type[ll_row]  = 'N' 
			dw6.RowsMove ( ll_cnt, ll_cnt, Primary!, dw6, 1, Filter! )
			ll_cnt = ll_cnt - 1
		end if
	end if
next

if ib_auto = true then
else
	MessageBox('확인','수주대상물품이 이동 되었습니다.',information!)
end if
//dw6.selectrow(0,false)
return true

end function

public function boolean wf_move5 ();long ll_rowcount,ll_rowcount1,ll_cnt,ll_find,ll_row,ll_count
string ls_plan,ls_order,ls_uom,ls_supp,ls_qa,ls_item,ls_subcon,ls_qa1
decimal {4} lr_cost

dw_1.accepttext()
dw7.accepttext()

if dw_1.rowcount() < 1 then 
	MessageBox("오류","발주헤더를 입력하십시오.", Exclamation!)
	dw7.selectrow(0,false)
	return false
end if	

ls_order = trim(dw_1.object.order_no[1])
ls_subcon = trim(dw_1.object.subcon[1])

//if ls_subcon = "Y"  then
if ls_subcon = "Y" OR ls_subcon = "J" or ls_subcon = "P"  then
	MessageBox("오류","구매발주가 아닙니다.", Exclamation!)
	dw7.selectrow(0,false)
	return false
end if	

ls_supp = trim(dw_1.object.supp_no[1])

if isnull(ls_supp) or ls_supp=""  then
	MessageBox("오류","발주헤더에 거래처를 입력하십시오.", Exclamation!)
	dw7.selectrow(0,false)
	return false
end if	

ll_rowcount1 = dw3.rowcount()
ll_rowcount  = dw7.rowcount()

ll_count = 0
for ll_cnt = 1 to ll_rowcount
	if dw7.isselected(ll_cnt) then
      ll_count ++
	end if
next
if ll_count = 0 then
	messagebox('오류','부족재고물품을 선택하십시요.',exclamation!)
	return false
end if

for ll_cnt = 1 to ll_rowcount
	if dw7.isselected(ll_cnt) then
		if ll_rowcount1 < 1 then
			ll_find = 0
		else
		   ll_find = dw3.find("item_no = '" + ls_item + "' and qa = '" + ls_qa + "'",1,dw3.rowcount())
		end if
		if ll_find = 0 then
			ls_item = trim(dw7.object.item_no[ll_cnt])
			ls_qa   = trim(dw7.object.qa[ll_cnt])
			ls_uom  = trim(dw7.object.uom[ll_cnt])
		 	lr_cost = wf_price (ls_supp, ls_item, ls_qa, ls_uom)

			ll_row = dw3.insertrow(0)
			dw3.object.seq_no[ll_row] = ll_row
			dw3.object.price[ll_row] = lr_cost
			dw3.object.uom[ll_row] = dw7.object.uom[ll_cnt]
			dw3.object.order_no[ll_row]   = ls_order
			dw3.object.item_no[ll_row]    = ls_item
			dw3.object.qa[ll_row]         = ls_qa
         dw3.object.item_item_name[ll_row]  =  dw7.object.item_name[ll_cnt]
			dw3.object.order_qty[ll_row]  = dw7.object.lessqoh[ll_cnt]
			dw3.object.com_qty[ll_row]  = dw7.object.lessqoh[ll_cnt]
			if is_round = 'Y' then
				dw3.object.amt[ll_row] = round(dw3.object.com_qty[ll_row] + dw3.object.price[ll_row],0 )
			else
				dw3.object.amt[ll_row] = truncate(dw3.object.com_qty[ll_row] + dw3.object.price[ll_row],0 )
			end if

			dw3.object.unit_qty[ll_row] = dw3.object.order_qty[ll_row]
			dw3.object.due_date[ll_row]   =  wf_today()
			dw3.object.rlse_date[ll_row]   =  wf_today()
         dw3.object.pur_type[ll_row]   =  'N'
			dw7.RowsMove ( ll_cnt, ll_cnt, Primary!, dw7, 1, Filter! )
			ll_cnt = ll_cnt - 1
		end if
	end if
next
messagebox('확인','부족재고물품이 이동되었습니다.',information!)
//dw7.selectrow(0,false)
	return true

end function

public function boolean wf_move7 ();long    ll_rowcount1,ll_cnt,ll_find,ll_row,ll_count, ll_cnt2
string  ls_plan,ls_order,ls_uom,ls_supp,ls_qa,ls_item,ls_subcon,ls_qa1
decimal {4} lr_cost
dec{6}  ld_rate

dw_1.accepttext()
dw10.accepttext()
ll_count = 0

setnull(ls_supp)
for ll_cnt2 = 1 to dw12.rowcount()
	dw12.scrolltorow(ll_cnt2)
	ll_count ++
	if dw12.isselected(ll_cnt2) then
		for ll_cnt = 1 to dw10.rowcount()
			ls_supp = trim(dw10.object.coilorder_supp_no[ll_cnt])
			exit
		next
	end if
next

if ll_count = 0 then
	messagebox('오류','외주스리팅가공 대상물품을 선택하십시요.',exclamation!)
	return false
end if

if dw_1.rowcount() < 1 then 
	pb_insert.triggerevent(clicked!)
	dw_1.object.supp_no[1] = ls_supp
else
	if ls_supp <> '' and not isnull(ls_supp) then
		dw_1.object.supp_no[1] = ls_supp
	end if
end if	

ls_supp = trim(dw_1.object.supp_no[1])
if isnull(ls_supp) or ls_supp=""  then
	MessageBox("오류","발주헤더에 거래처를 입력하십시오.", Exclamation!)
	dw12.selectrow(0,false)
	return false
end if	

dw_1.object.subcon[1] = 'C' //외주스리팅가공
ll_rowcount1 = dw3.rowcount()

for ll_cnt = 1 to dw10.rowcount()	
	ls_plan = trim(dw10.object.coilsliting_order_no[ll_cnt])
	if ll_rowcount1 < 1 then
		ll_find = 0
	else
		ll_find = dw3.find("product_no = '" + ls_plan + "'",1,dw3.rowcount())
	end if
	if ll_find = 0 then
		ls_item = trim(dw10.object.coilsliting_item_no[ll_cnt])
		ls_qa   = trim(dw10.object.coilsliting_qa[ll_cnt])
		ls_uom  = trim(dw10.object.groupitem_uom[ll_cnt])
		lr_cost = wf_price (ls_supp, ls_item, ls_qa, ls_uom)

		ll_row  = dw3.insertrow(0)
		dw3.object.seq_no[ll_row]     = ll_row
		dw3.object.price[ll_row]      = lr_cost
		dw3.object.cprice[ll_row]     = lr_cost
		dw3.object.uom[ll_row]        = dw10.object.groupitem_uom[ll_cnt]
		dw3.object.order_no[ll_row]   = ls_order  // 발주번호
		dw3.object.product_no[ll_row] = ls_plan   // 코일생산계획번호
		dw3.object.purdet_serial_no[ll_row] = dw10.object.coilsliting_seq[ll_cnt] // 코일생산계획순번
		dw3.object.item_no[ll_row]    = ls_item
		dw3.object.qa[ll_row]         = ls_qa
		dw3.object.item_item_name[ll_row]  = dw10.object.groupitem_item_name[ll_cnt]
		IF dw10.object.coilsliting_sheet[ll_cnt] = 'C' OR &
		   dw10.object.coilsliting_sheet[ll_cnt] = 'L' then // C; coil , S; sheet
			dw3.object.order_qty[ll_row]  = dw10.object.coilsliting_unit_qty[ll_cnt] &
													* dw10.object.coilsliting_cnt[ll_cnt]
		ELSE
			dw3.object.order_qty[ll_row]  = dw10.object.coilsliting_cnt[ll_cnt]
		end if
		
		dw3.object.unit_qty[ll_row] = dw10.object.coilsliting_unit_qty[ll_cnt]  //단중
		dw3.object.cnt[ll_row]      =  dw10.object.coilsliting_cnt[ll_cnt]  //스리팅갯수
		if dw10.object.groupitem_uom[ll_cnt] = 'SH' then
			if MidA(ls_item, 3, 1 )= 'A' then
				ld_rate = ia_rate
			else
				ld_rate = is_rate
			end if
			dw3.object.com_qty[ll_row] = ld_rate * (real(MidA(ls_qa,1,3)) / 100.0) * (real(MidA(ls_qa,5,4)) / 1000.0) * (real(MidA(ls_qa,10,4)) / 1000.0) * dw3.object.order_qty[ll_row]
			dw3.object.yrate[ll_row]   = ld_rate
			dw3.object.com_uom[ll_row] = 'KG'
		else
			dw3.object.com_uom[ll_row] = dw10.object.groupitem_uom[ll_cnt]
			dw3.object.com_qty[ll_row] = dw10.object.coilsliting_unit_qty[ll_cnt] &
												* dw10.object.coilsliting_cnt[ll_cnt]
		end if
		
		if is_round = 'Y' then
			dw3.object.amt[ll_row] = round(dw3.object.com_qty[ll_row] + dw3.object.price[ll_row],0 )
		else
			dw3.object.amt[ll_row] = truncate(dw3.object.com_qty[ll_row] + dw3.object.price[ll_row],0 )
		end if
		dw3.object.rlse_date[ll_row]  = wf_today()
		dw3.object.due_date[ll_row]   = dw10.object.coilorder_due_date[ll_cnt]
		dw3.object.sale_no[ll_row]    = ''
		dw3.object.sale_seq[ll_row]   = 0
		dw3.object.cust_name[ll_row]  = '외주스리팅'
		dw3.object.color[ll_row]      = ''
		dw3.object.sale_rem[ll_row]   = dw10.object.coilsliting_rem[ll_cnt]
		dw3.object.pur_type[ll_row]   = 'C'
		dw3.object.work_type[ll_row]  = dw10.object.coilsliting_sheet[ll_cnt]
		dw3.object.coil_no[ll_row]    = dw10.object.coilsliting_coil_no[ll_cnt] // 원코일번호
		dw3.object.rcpt_loc[ll_row]   = dw10.object.loc_no[ll_cnt]              // 원코일저장소
    //dw3.object.cnt[ll_row]        = dw10.object.coilsliting_cnt[ll_cnt]     // 스리팅갯수
	 
		dw10.RowsMove ( ll_cnt, ll_cnt, Primary!, dw10, 1, Filter! )
		ll_cnt = ll_cnt - 1
	end if
next

MessageBox('확인','외주스리팅가공 대상물품이 이동되었습니다.',information!)
//dw10.selectrow(0,false)

return true


end function

public function boolean wf_move6 ();long ll_rowcount,ll_rowcount1,ll_cnt,ll_find,ll_row,ll_count
string ls_plan,ls_order,ls_uom,ls_supp,ls_qa,ls_item,ls_subcon,ls_qa1, ls_loc
decimal {4} lr_cost
dec {6} ld_rate

dw_1.accepttext()
dw8.accepttext()

if dw_1.rowcount() < 1 then 
	MessageBox("오류","발주헤더를 입력하십시오.", Exclamation!)
	dw8.selectrow(0,false)
	return false
end if	

ls_supp = trim(dw_1.object.supp_no[1])

if isnull(ls_supp) or ls_supp=""  then
	MessageBox("오류","발주헤더에 거래처를 입력하십시오.", Exclamation!)
	dw8.selectrow(0,false)
	return false
end if	
dw_1.object.subcon[1] = "J"

ll_rowcount1 = dw3.rowcount()
ll_rowcount  = dw8.rowcount()

ls_supp = trim(dw_1.object.supp_no[1])
ll_count = 0
for ll_cnt = 1 to ll_rowcount
	if dw8.isselected(ll_cnt) then
		ls_loc = trim(dw8.object.issue_loc[ll_cnt])
		if ls_loc = '' or isnull(ls_loc) then
			MessageBox("오류","자재가공 대상물품의 출고저장소를 입력하십시오.", Exclamation!)
			tab_1.selecttab(6)
			return false
		end if
      ll_count ++
	end if
next
if ll_count = 0 then
	messagebox('오류','자재가공대상물품을 선택하십시요.',exclamation!)
	return false
end if

for ll_cnt = 1 to ll_rowcount
	if dw8.isselected(ll_cnt) then
		ls_plan = trim(dw8.object.order_no[ll_cnt])
		if ll_rowcount1 < 1 then
			ll_find = 0
		else
		   ll_find = dw3.find("product_no = '" + ls_plan + "'",1,dw3.rowcount())
		end if
		if ll_find = 0 then
			ls_item = trim(dw8.object.item_no[ll_cnt])
			ls_qa   = trim(dw8.object.qa[ll_cnt])
			ls_uom  = trim(dw8.object.uom1[ll_cnt])
		 	lr_cost = wf_price (ls_supp, ls_item, ls_qa, ls_uom)

			ll_row = dw3.insertrow(0)
			dw3.object.seq_no[ll_row] = ll_row
			dw3.object.price[ll_row] = lr_cost
			dw3.object.cprice[ll_row] = lr_cost

			dw3.object.com_uom[ll_row] = ls_uom
			dw3.object.uom[ll_row] = gf_uom(ls_uom)
			dw3.object.order_qty[ll_row]  = dw8.object.order_qty[ll_cnt]
			// 2004/02/25일 추가 분 start
		dw3.object.com_qty[ll_row]  =  dw8.object.order_qty[ll_cnt]
		if dw8.object.uom1[ll_cnt] = 'SH' then
			dw3.object.cnt[ll_row]   =  dw8.object.order_qty[ll_cnt]  //SHEET 장수
			dw3.object.unit_qty[ll_row] = ld_rate * (real(MidA(ls_qa,1,3)) / 100.0) * (real(MidA(ls_qa,5,4)) / 1000.0) * (real(MidA(ls_qa,10,4)) / 1000.0)  //단중
			if MidA(ls_item, 3, 1 )= 'A' then
				ld_rate = ia_rate
			else
				ld_rate = is_rate
			end if
//			dw3.object.com_qty[ll_row] = ld_rate * (real(mid(ls_qa,1,3)) / 100.0) * (real(mid(ls_qa,5,4)) / 1000.0) * (real(mid(ls_qa,10,4)) / 1000.0) * dw3.object.order_qty[ll_row]
			dw3.object.yrate[ll_row]  = ld_rate
		else
			dw3.object.unit_qty[ll_row] = dw8.object.order_qty[ll_cnt]
			dw3.object.cnt[ll_row]   =  1
		end if
			// 2004/02/25일 추가 분 end
//			dw3.object.com_qty[ll_row] = gf_getqty(ls_item, ls_qa, ls_uom, dw8.object.order_qty[ll_cnt])
			if is_round = 'Y' then
				dw3.object.amt[ll_row] = round(dw3.object.com_qty[ll_row] + dw3.object.price[ll_row],0 )
			else
				dw3.object.amt[ll_row] = truncate(dw3.object.com_qty[ll_row] + dw3.object.price[ll_row],0 )
			end if

			dw3.object.order_no[ll_row]   = ls_order
			dw3.object.product_no[ll_row] = ls_plan
			dw3.object.purdet_serial_no[ll_row] = 0
			dw3.object.item_no[ll_row]    = ls_item
			dw3.object.qa[ll_row]         = ls_qa
         dw3.object.item_item_name[ll_row]  =  dw8.object.groupitem_item_name1[ll_cnt]
			dw3.object.due_date[ll_row]   =  wf_today()
			dw3.object.rlse_date[ll_row]  =  wf_today()
   		dw3.object.pur_type[ll_row]   =  'J'
//			dw3.object.coil_no[ll_row]      =  dw8.object.issue_lot[ll_cnt] //원코일번호
//			dw8.RowsMove ( ll_cnt, ll_cnt, Primary!, dw8, 1, Filter! )
//			ll_cnt = ll_cnt - 1
		end if
	end if
next
messagebox('확인','자재가공 대상물품이 이동되었습니다.',information!)
//dw8.selectrow(0,false)
return true
end function

public function boolean wf_outproc (string arg_subcon, long arg_row);long     ll_foundrow, ll_count, li_cnt, ll_row, ll_cnt
datetime ldt_date
string   ls_order, ls_item, ls_qa, ls_destination, ls_newloc, ls_temp, ls_suppname
string   ls_old_time, ls_pur, ls_wcoil, ls_oc, ls_flag, ls_wloc, ls_issue_lot, ls_product_no
real     lr_newqty
dec {1}  ld_w_wid
dec {2}  ld_yrate
dec {3}  lr_sheet_unitqty
int      li_seq, li_wunit_qty, li_wcoilcnt
string   ls_coilorderdet_order[], ls_type


//외주구매'Y' /자재가공'J' /외주가공'P' /외주스리팅가공시'C'의 처리.
dw_1.accepttext()
dw3.accepttext()
dw4.accepttext()

// 외주가공형태 추가 (2001/07/19,이인호)
// J:자재가공 P:외주가공 일때만 적용(inaudit 추가 안함)
//
// A.명송 외주가공 플로우	
//		1. 스리팅 코일 이동
//		2. 제품 생산계획
//			 - 임의 생산계획 작성후 명송에서 받은 작업일보에서 해당 제품 입고
//		3. 스리팅 코일 수불 
//			 - 작업일보에서 잔량 및 사용량 등록
//		4. 수주접수후 외주생산계획작성
//		5. 제품 외주 가공 발주
//			 - 출고되는 스리팅코일은 로트번호없는
//				 스리팅코드로만 외주가공 발주
//		6. 입고
//			 - 제품입고시에 명송에 있는 제품을 사용한것으로 해야함
//
// B. 통일 외주가공 플로우	
//		1. 코일 이동 - 외주발주에 의한 코일이동시 스리팅 수불 안함
//		2. 수주접수후 외주생산계획 작성
//		3. 외주가공발주 
//			 - 출고되는 스리팅코일은 로트번호없는
//				 스리팅코드로만 외주가공 발주
//		4. 입고 - 입고시 스리팅코일의 사용을 추가 해야함	

ls_newloc = trim(dw_1.object.supp_no[1])

setnull(ls_type)
SELECT type INTO :ls_type FROM supp WHERE supp_no = :ls_newloc; 

ls_order      = trim(dw_1.object.order_no[1])
ls_product_no = trim(dw3.object.product_no[arg_row])
ls_coilorderdet_order[1] = ls_product_no
li_seq        = dw3.object.purdet_serial_no[arg_row]  //코일생산계획순번
ldt_date      = wf_today()
ls_old_time   = string(now(),'hh:mm:ss:fff')

choose case arg_subcon
	case 'C' //외주스리팅
		// 원코일 이동은 안한다..
		// 코일 이동은 별도의 "코일이동관리"에서 이동 시킴
		SELECT coil_no, wid, proc_flag,loc_no 
		  INTO :ls_wcoil, :ld_w_wid, :ls_flag, :ls_wloc 
		  FROM coilorderdet
		 WHERE order_no = :ls_product_no;
