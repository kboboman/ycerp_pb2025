$PBExportHeader$d_cdlogin_t_ns_db.srd
$PBExportComments$사용자등록(2000/02/22, 이인호)nd/yc_mail의 db:yoochang의 login table과 yoochang/yc_main의 db:yc.login과의 동기화를 위해서
release 6;
datawindow(units=0 timer_interval=0 color=79741120 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=160 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=160 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=user_id dbname="login.user_id" )
 column=(type=char(8) update=yes updatewhereclause=yes name=password dbname="login.password" )
 column=(type=char(5) update=yes updatewhereclause=yes name=team_code dbname="login.team_code" )
 column=(type=char(30) update=yes updatewhereclause=yes name=rem dbname="login.rem" )
 column=(type=char(10) update=yes updatewhereclause=yes name=user_name dbname="login.user_name" )
 column=(type=char(20) update=yes updatewhereclause=yes name=rank dbname="login.rank" )
 column=(type=char(10) update=yes updatewhereclause=yes name=area_no dbname="login.area_no" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"login~" ) COLUMN(NAME=~"login.user_id~") COLUMN(NAME=~"login.password~") COLUMN(NAME=~"login.team_code~") COLUMN(NAME=~"login.rem~") COLUMN(NAME=~"login.user_name~") COLUMN(NAME=~"login.rank~") COLUMN(NAME=~"login.area_no~")WHERE(    EXP1 =~"login.team_code~"   OP =~"like~"    EXP2 =~":as_team~" ) ) ARG(NAME = ~"as_team~" TYPE = string) " update="login" updatewhere=1 updatekeyinplace=no arguments=(("as_team", string)) )
