 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"customer~" ) COLUMN(NAME=~"customer.cust_no~") COLUMN(NAME=~"customer.cust_name~") COLUMN(NAME=~"customer.captain_name~") COLUMN(NAME=~"customer.addr~") COLUMN(NAME=~"customer.tel_no~") COLUMN(NAME=~"customer.salesman~") COLUMN(NAME=~"customer.buyer1~")WHERE(    EXP1 =~"customer.cust_no~"   OP =~"=~"    EXP2 =~":as_custno~" ) ) ARG(NAME = ~"as_custno~" TYPE = string) " update="customer" updatewhere=0 updatekeyinplace=no arguments=(("as_custno", string)) )
