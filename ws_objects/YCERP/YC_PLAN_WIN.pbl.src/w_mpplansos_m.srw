event pb_delete::clicked;call super::clicked;dwitemstatus l_status
long   ll_row, ll_count, ll_cnt, ll_max
string ls_sosno, ls_divid, ls_sdate, ls_edate
		
if dw5.rowcount() < 1 then RETURN

dw5.accepttext() ; dw6.accepttext()

ls_sdate = em_1.text
ls_edate = em_2.text

l_status = dw5.getitemstatus(1, 0, primary!)
ls_sosno = dw5.object.sos_no[1]

ls_divid = dw5.object.div_id[1]
if ls_divid <> "" then 
	MessageBox("확인","결재 완료된 신청서는 삭제할 수 없습니다!",information!)
	RETURN
end if

if MessageBox("삭제","신청번호 : " + ls_sosno + "~n~n삭제 하시겠습니까?",question!,okcancel!,1) = 2 then	RETURN			

DELETE FROM itemsosdet WHERE sos_no = :ls_sosno;
if sqlca.sqlcode <> 0 then
	ROLLBACK;
	MessageBox("삭제","itemsosdet 삭제 중 오류가 발생 하였습니다.")
	RETURN
end if

dw5.deleterow(1)
dw6.reset()
if wf_update1(dw5, "Y") = false then
	RETURN
end if

//
dw4.retrieve( ls_sdate, ls_edate )	// 신청목록 조회

end event

