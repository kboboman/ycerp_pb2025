release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=tr_senddate dbname="SC_LOG.TR_SENDDATE" )
 column=(type=char(20) updatewhereclause=yes name=tr_phone dbname="SC_LOG.TR_PHONE" )
 column=(type=char(20) updatewhereclause=yes name=tr_callback dbname="SC_LOG.TR_CALLBACK" )
 column=(type=char(160) updatewhereclause=yes name=tr_msg dbname="SC_LOG.TR_MSG" )
 column=(type=char(172) updatewhereclause=yes name=tr_etc6 dbname="TR_ETC6" )
 retrieve="SELECT TR_SENDDATE
     , TR_PHONE
     , TR_CALLBACK
     , TR_MSG
     , TR_ETC6 = RTRIM(LOGIN.USER_NAME) + '[' + TR_ETC6 + ']'
  FROM YC.DBO.SC_LOG
     , LOGIN
 WHERE TR_ETC6  = LOGIN.USER_ID
   AND CONVERT(CHAR(10),TR_SENDDATE,111) BETWEEN :as_sdate AND :as_edate
   AND ( TR_ETC6   = :as_userid  OR (:as_admin = 'Y' and TR_ETC6   LIKE '%') )
 ORDER BY TR_SENDDATE DESC" arguments=(("as_sdate", string),("as_edate", string),("as_userid", string),("as_admin", string)) )
