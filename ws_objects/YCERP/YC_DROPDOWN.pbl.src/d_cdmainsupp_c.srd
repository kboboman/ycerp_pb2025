 retrieve="PBSELECT( VERSION(400) DISTINCT ()TABLE(NAME=~"supp~" )  TABLE(NAME=~"supplier~" ) COLUMN(NAME=~"supplier.supp_no~") COLUMN(NAME=~"supp.supp_name~")    JOIN (LEFT=~"supp.supp_no~"    OP =~"=~"RIGHT=~"supplier.supp_no~" )WHERE(    EXP1 =~"supplier.item_no~"   OP =~"=~"    EXP2 =~":as_supp~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"supplier.qa~"   OP =~"=~"    EXP2 =~":as_qa~" ) ) ARG(NAME = ~"as_supp~" TYPE = string)  ARG(NAME = ~"as_qa~" TYPE = string) " arguments=(("as_supp", string),("as_qa", string)) )
