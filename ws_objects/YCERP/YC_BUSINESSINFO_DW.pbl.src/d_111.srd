table(column=(type=char(10) updatewhereclause=yes name=bdinfodet_person dbname="bdinfodet.person" )
 column=(type=char(4) updatewhereclause=yes name=bdinfodet_lastcom dbname="bdinfodet.lastcom" )
 column=(type=char(10) updatewhereclause=yes name=bdinfodet_sperson dbname="bdinfodet.sperson" )
 column=(type=char(4) updatewhereclause=yes name=bdinfodet_buildingcom dbname="bdinfodet.buildingcom" )
 column=(type=char(20) updatewhereclause=yes name=bdinfodet_project dbname="bdinfodet.project" )
 column=(type=char(3) updatewhereclause=yes name=spec_code dbname="bdinfodet2.spec_code" )
 column=(type=char(3) updatewhereclause=yes name=uom dbname="bdinfodet2.uom" )
 column=(type=decimal(0) updatewhereclause=yes name=quantity dbname="bdinfodet2.quantity" )
 column=(type=decimal(0) updatewhereclause=yes name=bd_1m dbname="bd_1m" )
 column=(type=decimal(0) updatewhereclause=yes name=bd_2m dbname="bd_2m" )
 column=(type=decimal(0) updatewhereclause=yes name=bd_3m dbname="bd_3m" )
 column=(type=decimal(0) updatewhereclause=yes name=bd_4m dbname="bd_4m" )
 column=(type=decimal(0) updatewhereclause=yes name=bd_5m dbname="bd_5m" )
 column=(type=decimal(0) updatewhereclause=yes name=bd_6m dbname="bd_6m" )
 column=(type=decimal(0) updatewhereclause=yes name=bd_7m dbname="bd_7m" )
 column=(type=decimal(0) updatewhereclause=yes name=bd_8m dbname="bd_8m" )
 column=(type=decimal(0) updatewhereclause=yes name=bd_9m dbname="bd_9m" )
 column=(type=decimal(0) updatewhereclause=yes name=bd_10m dbname="bd_10m" )
 column=(type=decimal(0) updatewhereclause=yes name=bd_11m dbname="bd_11m" )
 column=(type=decimal(0) updatewhereclause=yes name=bd_12m dbname="bd_12m" )
 retrieve="  SELECT bdinfodet.person,
			bdinfodet.lastcom,
			bdinfodet.sperson,
			bdinfodet.buildingcom,
			bdinfodet.project,   
			bdinfodet2.spec_code,   
			bdinfodet2.uom,
			bdinfodet2.quantity,   
			bd_1m = max(case when right(bdinfodet2_item.input_ym, 2) = '01' then	bdinfodet2_item.quantity end),
			bd_2m = max(case when right(bdinfodet2_item.input_ym, 2) = '02' then	bdinfodet2_item.quantity end),
			bd_3m = max(case when right(bdinfodet2_item.input_ym, 2) = '03' then	bdinfodet2_item.quantity end),
			bd_4m = max(case when right(bdinfodet2_item.input_ym, 2) = '04' then	bdinfodet2_item.quantity end),
			bd_5m = max(case when right(bdinfodet2_item.input_ym, 2) = '05' then	bdinfodet2_item.quantity end),
			bd_6m = max(case when right(bdinfodet2_item.input_ym, 2) = '06' then	bdinfodet2_item.quantity end),
			bd_7m = max(case when right(bdinfodet2_item.input_ym, 2) = '07' then	bdinfodet2_item.quantity end),
			bd_8m = max(case when right(bdinfodet2_item.input_ym, 2) = '08' then	bdinfodet2_item.quantity end),
			bd_9m = max(case when right(bdinfodet2_item.input_ym, 2) = '09' then	bdinfodet2_item.quantity end),
			bd_10m = max(case when right(bdinfodet2_item.input_ym, 2) = '10' then	bdinfodet2_item.quantity end),
			bd_11m = max(case when right(bdinfodet2_item.input_ym, 2) = '11' then	bdinfodet2_item.quantity end),
			bd_12m = max(case when right(bdinfodet2_item.input_ym, 2) = '12' then	bdinfodet2_item.quantity end)
FROM   bdinfodet inner join bdinfo on bdinfodet.build_no = bdinfo.build_no
    			               inner join bdinfodet2 on   bdinfodet.build_no = bdinfodet2.build_no and bdinfodet.seq = bdinfodet2.seq 
                               left outer join bdinfodet2_item on  bdinfodet2.build_no = bdinfodet2_item.build_no and
                                                                                      bdinfodet2.seq = bdinfodet2_item.seq  and
                                                                                      bdinfodet2.spec_code = bdinfodet2_item.spec_code
   WHERE (	( bdinfo.build_no = :arg_build_no ) AND  
              				( bdinfodet.std_chk = '1' ) AND  
              				( bdinfodet.spec like :as_spec ) AND  
              				( bdinfodet.project like :as_project ) AND  
              				( bdinfodet.sale_prog like :as_flag ) AND  
              				( bdinfodet.fixeddate between :ad_date1 and :ad_date2 ) AND  
              				( bdinfodet.design_prog like :as_dprog ) AND  
              				( bdinfodet.com_prog like :as_cprog ) AND  
              				( bdinfodet.city like :as_city ) AND  
              				(	( bdinfodet.person like :as_person ) OR  
              					( bdinfodet.dperson like :as_dperson ) OR  
              					( bdinfodet.cperson like :as_cperson ) OR  
              					( bdinfodet.bperson like :as_bperson ) OR  
              					( bdinfodet.sperson like :as_sperson )	) AND  
              				(	( bdinfodet.div like :as_div ) OR  
              					( bdinfodet.ddiv like :as_ddiv ) OR  
              					( bdinfodet.cdiv like :as_cdiv ) OR  
              					( bdinfodet.bdiv like :as_bdiv ) OR  
              					( bdinfodet.sdiv like :as_sdiv )	)	) AND    
                       ( bdinfodet.organcd like :as_organcd ) AND
                       ( bdinfodet.designoffice like :as_dcode )     
group by  bdinfodet.person,
			bdinfodet.lastcom,
			bdinfodet.sperson,
			bdinfodet.buildingcom,
			bdinfodet.project,   
			bdinfodet2.spec_code,   
			bdinfodet2.uom,
			bdinfodet2.quantity
/*
			 FROM bdinfo,   
			bdinfodet,   
			bdinfodet2,
			bdinfodet2_item  
   WHERE ( bdinfodet.build_no = bdinfo.build_no ) and  
         ( bdinfodet.build_no = bdinfodet2.build_no ) and
         ( bdinfodet.seq = bdinfodet2.seq ) and
         ( bdinfodet2.build_no *= bdinfodet2_item.build_no ) and
         ( bdinfodet2.seq *= bdinfodet2_item.seq ) and
         ( bdinfodet2.spec_code *= bdinfodet2_item.spec_code ) and
	      (	( bdinfo.build_no = :arg_build_no ) AND  
				( bdinfodet.std_chk = '1' ) AND  
				( bdinfodet.spec like :as_spec ) AND  
				( bdinfodet.project like :as_project ) AND  
				( bdinfodet.sale_prog like :as_flag ) AND  
				( bdinfodet.fixeddate between :ad_date1 and :ad_date2 ) AND  
				( bdinfodet.design_prog like :as_dprog ) AND  
				( bdinfodet.com_prog like :as_cprog ) AND  
				( bdinfodet.city like :as_city ) AND  
				(	( bdinfodet.person like :as_person ) OR  
					( bdinfodet.dperson like :as_dperson ) OR  
					( bdinfodet.cperson like :as_cperson ) OR  
					( bdinfodet.bperson like :as_bperson ) OR  
					( bdinfodet.sperson like :as_sperson )	) AND  
				(	( bdinfodet.div like :as_div ) OR  
					( bdinfodet.ddiv like :as_ddiv ) OR  
					( bdinfodet.cdiv like :as_cdiv ) OR  
					( bdinfodet.bdiv like :as_bdiv ) OR  
					( bdinfodet.sdiv like :as_sdiv )	)	) AND    
         ( bdinfodet.organcd like :as_organcd ) AND
         ( bdinfodet.designoffice like :as_dcode )     
group by  bdinfodet.person,
			bdinfodet.lastcom,
			bdinfodet.sperson,
			bdinfodet.buildingcom,
			bdinfodet.project,   
			bdinfodet2.spec_code,   
			bdinfodet2.uom,
			bdinfodet2.quantity
*/" arguments=(("arg_build_no", string),("as_div", string),("as_spec", string),("as_project", string),("as_flag", string),("ad_date1", string),("ad_date2", string),("as_dprog", string),("as_cprog", string),("as_city", string),("as_person", string),("as_dperson", string),("as_ddiv", string),("as_cperson", string),("as_cdiv", string),("as_bperson", string),("as_bdiv", string),("as_sperson", string),("as_sdiv", string),("as_organcd", string),("as_dcode", string)) )
