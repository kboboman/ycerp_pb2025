$PBExportHeader$d_ipcoilclass_m.srd
$PBExportComments$코일등급관리(2001/05/23,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes key=yes name=coil_no dbname="coilmst.coil_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="coilmst.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="coilmst.qa" )
 column=(type=char(10) updatewhereclause=yes key=yes name=loc_no dbname="coilmst.loc_no" )
 column=(type=datetime updatewhereclause=yes name=rcpt_date dbname="coilmst.rcpt_date" )
 column=(type=long updatewhereclause=yes name=rcpt_qty dbname="coilmst.rcpt_qty" )
 column=(type=long updatewhereclause=yes name=cnt dbname="coilmst.cnt" )
 column=(type=char(10) updatewhereclause=yes name=supp_no dbname="coilmst.supp_no" )
 column=(type=long updatewhereclause=yes name=rcpt_len dbname="coilmst.rcpt_len" )
 column=(type=char(1) update=yes updatewhereclause=yes name=class dbname="coilmst.class" )
 column=(type=char(2) update=yes updatewhereclause=yes name=etc_no dbname="coilmst.etc_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 retrieve="  SELECT coilmst.coil_no,   
         coilmst.item_no,   
         coilmst.qa,   
         coilmst.loc_no,   
         coilmst.rcpt_date,   
         coilmst.rcpt_qty,   
         coilmst.cnt,   
         coilmst.supp_no,   
         coilmst.rcpt_len,   
         coilmst.class,   
         coilmst.etc_no,   
         groupitem.item_name  
    FROM coilmst LEFT OUTER JOIN groupitem ON coilmst.item_no = groupitem.item_no
   WHERE ( (( :as_flag = '%') or ( :as_flag = 'S' )
					and coilmst.loc_no like :as_loc 
					and coilmst.item_no like :as_item
					and coilmst.flag like :as_flag ) 
				or ( :as_flag = 'W'
					and coilmst.loc_no like :as_loc 
					and coilmst.item_no like :as_item
					and coilmst.flag like :as_flag ) 
					and ( coilmst.rcpt_date between :ad_start and :ad_end ) AND  
					( coilmst.flag = 'W' ) )    
/*
    FROM coilmst,   
         groupitem  
   WHERE ( coilmst.item_no *= groupitem.item_no) and  
         ( (( :as_flag = '%') or ( :as_flag = 'S' )
					and coilmst.loc_no like :as_loc 
					and coilmst.item_no like :as_item
					and coilmst.flag like :as_flag ) 
				or ( :as_flag = 'W'
					and coilmst.loc_no like :as_loc 
					and coilmst.item_no like :as_item
					and coilmst.flag like :as_flag ) 
					and ( coilmst.rcpt_date between :ad_start and :ad_end ) AND  
					( coilmst.flag = 'W' ) )    
*/" update="coilmst" updatewhere=0 updatekeyinplace=yes arguments=(("as_loc", string),("as_item", string),("as_flag", string),("ad_start", date),("ad_end", date))  sort="item_no A qa A rcpt_qty A " )
