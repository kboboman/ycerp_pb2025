release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(3) updatewhereclause=yes name=curr_code dbname="curr_code" )
 column=(type=decimal(4) updatewhereclause=yes name=balance_amt dbname="balance_amt" )
 column=(type=decimal(4) updatewhereclause=yes name=bill_amount dbname="bill_amount" )
 column=(type=decimal(2) updatewhereclause=yes name=opeomamt dbname="opeomamt" )
 column=(type=char(50) updatewhereclause=yes name=mgr_type dbname="mgr_type" )
 column=(type=long updatewhereclause=yes name=mgr_sort dbname="mgr_sort" )
 column=(type=char(10) updatewhereclause=yes name=salesman dbname="salesman" )
 column=(type=char(15) updatewhereclause=yes name=icube_no dbname="icube_no" )
 column=(type=char(1) updatewhereclause=yes name=open_close dbname="open_close" )
 column=(type=long updatewhereclause=yes name=credit_cnt dbname="credit_cnt" )
 column=(type=char(10) updatewhereclause=yes name=top_level dbname="top_level" )
 column=(type=char(10) updatewhereclause=yes name=imwon_user_id dbname="imwon_user_id" )
 retrieve="  SELECT cust_no      = a.cust_no
       , cust_name    = a.cust_name
       , curr_code    = a.curr_code
       , balance_amt  = a.balance_amt
       , bill_amount  = a.bill_amount
       , opeomamt     = a.opeomamt
       , mgr_type     = a.mgr_type
       , mgr_sort     = isnull(a.mgr_sort,99)
       , salesman     = a.salesman
       , icube_no     = a.icube_no
       , open_close   = a.open_close
       , credit_cnt   = a.credit_cnt
       , top_level = a.top_level
       , imwon_user_id = a.imwon_user_id
    FROM (
         SELECT c.cust_no
              , c.cust_name
              , c.curr_code
              , c.balance_amt
              , c.bill_amount
              , opeomamt   = d.balbf_amount + 
                           ( d.inv_01  + d.inv_02  + d.inv_03  + d.inv_04  + d.inv_05  + d.inv_06    + 
                             d.inv_07  + d.inv_08  + d.inv_09  + d.inv_10  + d.inv_11  + d.inv_12  ) - 
                           ( d.coll_01 + d.coll_02 + d.coll_03 + d.coll_04 + d.coll_05 + d.coll_06   + 
                             d.coll_07 + d.coll_08 + d.coll_09 + d.coll_10 + d.coll_11 + d.coll_12 )
              , mgr_type   = (SELECT item_nm FROM codemst WHERE type = 'MGR_TYPE' AND use_yn = 'Y' AND item_cd = c.mgr_type)
              , mgr_sort   = (SELECT sort    FROM codemst WHERE type = 'MGR_TYPE' AND use_yn = 'Y' AND item_cd = c.mgr_type)
              , c.salesman
              , c.icube_no
              , c.open_close
              , credit_cnt = ( SELECT count(distinct cust_no) FROM customer_credit (nolock) WHERE c.cust_no = customer_credit.cust_no )
		   , c.top_level
             , c.imwon_user_id
           FROM customer C (nolock)
                LEFT OUTER JOIN opeom  D (nolock) ON c.cust_no  = d.cust_no AND ( datepart(year,d.eom_year) = year(getdate()) )
          WHERE ((:as_open      = '%' and c.open_close LIKE '%' ) OR
                 (:as_open     <> '%' and c.open_close    = 'O' )           
                )
            AND ((:as_salesman  = '%' and c.salesman   LIKE '%'          ) OR
                 (:as_salesman <> '%' and c.salesman      = :as_salesman ) OR
			 /*2018.10.05 JOWONSUK 임원담당 검색 추가 */
                 ( :as_salesman  = '%' and c.imwon_user_id LIKE '%'          ) OR
			 ( :as_salesman <> '%' and c.imwon_user_id    = :as_salesman )           
                )
         ) A
   WHERE ((:as_zero = 'Y' AND opeomamt <> 0) OR (:as_zero = '%'))
" arguments=(("as_open", string),("as_zero", string),("as_salesman", string))  sort="mgr_sort A cust_no A " )
