forward prototypes
public subroutine wf_codemst ()
end prototypes

public subroutine wf_codemst ();// 거래처마스터_변경 필드명 전체 가져오기
string ls_itemcd, ls_itemnm, ls_bigo
string ls_field
long   ll_row, ll_dw26cnt, ll_col, ll_cols, ll_width


Pointer oldpointer // Declares a pointer variable
oldpointer = SetPointer(HourGlass!)

tab_1.tabpage_7.dw_26.reset()
tab_1.tabpage_7.mle_1.visible = false

DECLARE codemst_item CURSOR FOR  
/*   SELECT item_cd, rtrim(item_nm), bigo, sort */
   SELECT item_cd, rtrim(item_nm), bigo
	  FROM codemst 
	 WHERE type = '거래처마스터_변경' AND use_yn = 'Y' ORDER BY sort;
	 
OPEN codemst_item;
FETCH codemst_item INTO :ls_itemcd, :ls_itemnm, :ls_bigo;
Do While sqlca.sqlcode = 0
	ll_dw26cnt = tab_1.tabpage_7.dw_26.insertrow(0)
	
	ll_width   = long(tab_1.tabpage_7.dw_27.Describe(ls_itemcd + ".width"))
	
	tab_1.tabpage_7.dw_26.object.chk[ll_dw26cnt]    = "N"   
	tab_1.tabpage_7.dw_26.object.cols[ll_dw26cnt]   = ls_itemnm
	tab_1.tabpage_7.dw_26.object.field[ll_dw26cnt]  = ls_itemcd
	tab_1.tabpage_7.dw_26.object.ftype[ll_dw26cnt]  = ls_bigo
	tab_1.tabpage_7.dw_26.object.lwidth[ll_dw26cnt] = ll_width		// 컬럼기본값 저장
	
   FETCH codemst_item INTO :ls_itemcd, :ls_itemnm, :ls_bigo;
Loop
CLOSE codemst_item;
if tab_1.tabpage_7.dw_26.rowcount() < 1 then RETURN
tab_1.tabpage_7.dw_26.ScrollToRow( 1 )

// 컬럼 기본값 지우기
tab_1.tabpage_7.dw_27.SetRedraw( false )
//ll_cols = tab_1.tabpage_7.dw_26.rowcount()
ll_cols = long(tab_1.tabpage_7.dw_27.object.datawindow.column.count) + 1
for ll_col = 1 to ll_cols							// dw_27: SEQ, 선택, 코드, 거래처명
	ls_field = tab_1.tabpage_7.dw_27.Describe("#" + string( ll_col ) + ".name")
	choose case lower(ls_field)
		case "seq", "chk", "cust_no", "cust_name"

		case else
			tab_1.tabpage_7.dw_27.Modify( ls_field + ".width=0" )
	end choose
next
tab_1.tabpage_7.dw_27.SetRedraw( true )


//case "rotate"   			// 회전월                          
//case "cap_birthday"   	// 대표자생년                          
//case "salesman"      		// 담당자                  
//case "collect_ymd"   		// 채권관리                
//case "credit_level"   	// 신용등급               
//case "level_grade"   		// 매출등급                
//case "price_level"   		// 단가등급                
//case "credit_day"   		// 여신일자                 
//case "terms"   				// 결재기간                      
//case "credit_limit"   	// 신용한도액             
//case "vat_user"   			// VAT담당자                  
//case "vat_phone"   		// VAT연락처                 
//case "vat_email"   		// VAT메일                   
//case "icube_no"   			// 더존                       
//case "dambo_ymde"   		// 담보만기                          
//case "captain_relation" 	// 대표자관계                          
//case "dambo_bigo"   		// 담보비고                          
//case "custmain"   			// 주거래건설사(CUSTINFO)
//case "licensenm"   		// 면허명(CUSTINFO)                          

// 사업장, 실채무자, 운송처 이전주소 관리(2013/11/11)로 기능삭제 함
//case "addr1"   			// 거래처우편                    
//case "addr2"   			// 거래처주소1                   
//case "addr3"   			// 거래처주소2                   
//case "bus_addr1"   	// 실채무자우편              
//case "bus_addr2"   	// 실채무자주소1             
//case "bus_addr3"   	// 실채무자주소2             
//case "shipto_addr1"   // 운송처우편             
//case "shipto_addr2"   // 운송처주소1            
//case "shipto_addr3"   // 운송처주소2            

end subroutine

