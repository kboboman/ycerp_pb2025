table(column=(type=char(14) update=yes updatewhereclause=yes key=yes name=intemp_no dbname="intemp.intemp_no" initial="NEW" )
 column=(type=long update=yes updatewhereclause=yes key=yes identity=yes name=seq dbname="intemp.seq" )
 column=(type=datetime update=yes updatewhereclause=yes name=intemp_date dbname="intemp.intemp_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=loc_no dbname="intemp.loc_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="intemp.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="intemp.qa" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=qty dbname="intemp.qty" initial="0" )
 column=(type=char(1) update=yes updatewhereclause=yes name=flag dbname="intemp.flag" )
 column=(type=char(10) update=yes updatewhereclause=yes name=user_id dbname="intemp.user_id" )
 column=(type=datetime update=yes updatewhereclause=yes name=user_date dbname="intemp.user_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=area_no dbname="intemp.area_no" )
 column=(type=char(50) update=yes updatewhereclause=yes name=rem dbname="intemp.rem" )
 column=(type=char(20) update=yes updatewhereclause=yes name=order_no dbname="intemp.order_no" )
 column=(type=long update=yes updatewhereclause=yes name=seq_no dbname="intemp.seq_no" )
 column=(type=char(3) update=yes updatewhereclause=yes name=type dbname="intemp.type" initial="NO" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="GroupItem.uom" )
 retrieve="  SELECT intemp.intemp_no     
       , intemp.seq           
       , intemp.intemp_date   
       , intemp.loc_no        
       , intemp.item_no       
       , intemp.qa            
       , intemp.qty           
       , intemp.flag          
       , intemp.user_id       
       , intemp.user_date     
       , intemp.area_no       
       , intemp.rem           
       , intemp.order_no      
       , intemp.seq_no        
       , intemp.type          
       , groupitem.uom  
    FROM intemp inner join groupitem  on intemp.item_no = groupitem.item_no
   WHERE ((intemp.intemp_no   = :as_intempno) AND (intemp.seq = :ai_seq))    
/*
    FROM intemp
       , groupitem  
   WHERE ( intemp.item_no    *= groupitem.item_no) 
     AND ((intemp.intemp_no   = :as_intempno) AND (intemp.seq = :ai_seq))    
*/" update="intemp" updatewhere=0 updatekeyinplace=no arguments=(("as_intempno", string),("ai_seq", number)) )
