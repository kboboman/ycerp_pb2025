release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="item.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=qa dbname="item.qa" )
 retrieve="  SELECT item.item_no
       , item.qa  
    FROM item  
   WHERE ( item.item_no     = :arg_item ) 
     AND ( item.qa       LIKE :arg_qa   )   
   ORDER BY item.item_no ASC, item.qa ASC   
" update="item" updatewhere=1 updatekeyinplace=no arguments=(("arg_item", string),("arg_qa", string)) )
