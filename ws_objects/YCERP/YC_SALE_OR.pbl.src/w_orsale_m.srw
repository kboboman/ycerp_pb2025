event open;//==GF_USEPROGRAM(프로그램 사용현황)===========================================================
GF_USEPROGRAM( gs_userid, THIS.ClassName(), "O", string(gf_today(),'yyyy/mm/dd'), THIS.Title )
//=============================================================================================
st_vertical.of_set_leftobject(dw_4)
st_vertical.of_set_rightobject(dw_2)
st_vertical.of_set_minsize(250, 250)
////////////////////////////////////////////////////////////////////////////////////////////

// 이미지
cbx_reattch.checked = false
cbx_reattch.enabled = false
cbx_attch.checked = false
cbx_attch.enabled = false
p_2.visible = false
p_1.visible = false
p_1.OriginalSize  = false
cb_3.enabled       = false		// 가져오기
pb_7.visible       = false		// 고객센터

this.x = 1
this.y = 1

dw_2.SetTransObject(SQLCA)
dw_export.SetTransObject(SQLCA)
dw_9.settransobject(sqlca)		// 수주품목발주조회
dw_9.visible = false
dw_10.settransobject(sqlca)	// 수주번호->출고번호 조회
dw_10.visible = false
dw_11.settransobject(sqlca)	// 이슈상품 수신자
dw_11.visible = false
dw_12.settransobject(sqlca)
dw_12.visible = false			// 출고의뢰(수주라벨)
dw_13.SetTransObject(SQLCA)
dw_13.visible = false
dw_14.SetTransObject(SQLCA)	// 출고예약
dw_14.visible = false
dw_15.SetTransObject(SQLCA)	// 수주공정표
dw_15.visible = false
dw_16.SetTransObject(SQLCA)	// 생산일정 조회
dw_16.visible = false
dw_6.settransobject(sqlca)
dw_4.settransobject(sqlca)
dw_6.insertrow(0)  
dw_6.object.area[1] = gs_area

if gs_userid = 'yoochang' then
	dw_3.dataobject = 'd_orsale_m1_yoochang'
	dw_3.settransobject(sqlca)	
end if

if GS_rank_no = '235' then
	pb_4.enabled = false
	pb_print_part.enabled = false	
end if

pb_12.visible  = false
dw_1.insertrow(0)  
dw_1.getchild("cust_no", idwc_cust_no)
idwc_cust_no.settransobject( sqlca)
idwc_cust_no.retrieve( )

// 판매관리_조회
if GF_PERMISSION("판매관리_조회", gs_userid) = "Y" then
	if GF_PERMISSION("판매관리_입력", gs_userid) = "Y" or GF_Permission("판매관리_입력(부분)", gs_userid) = "Y" then
	elseif GF_PERMISSION("판매관리_입력(영업담당)", gs_userid) = "Y" then
	else
		pb_insert.enabled = false
		pb_delete.enabled = false
		pb_save.enabled   = false

		cb_8.enabled = false		// 내보내기
		cb_3.enabled = false		// 가져오기
		pb_5.enabled = false		// 재고수주잔량
		pb_11.enabled = false	// 성형실사
		pb_8.enabled = false		// 몰딩실사
		pb_6.enabled = false		// 문자전송
		pb_9.enabled = false		// 규격=>송장규격
		pb_1.enabled = false		// 행추가
		pb_2.enabled = false		// 행삭제
	end if
end if

// 공무관리담당자는 해당하는 거래처만 권한 있음
if GF_PERMISSION("공무관리담당자", gs_userid) = 'Y' and ((GF_Permission("판매관리_입력", gs_userid) <> "Y" or GF_Permission("판매관리_입력(부분)", gs_userid) = "Y") and GF_Permission("판매관리_조회", gs_userid) <> "Y" ) then
	SELECT top 1 rtrim(bigo) INTO :is_custconst FROM codemst 
	 WHERE type = '공무관리담당자' AND use_yn = 'Y' AND item_cd = :gs_userid;	
	if isnull(is_custconst) OR is_custconst = "" OR LenA(is_custconst) <> 4 then
		MessageBox("확인","공무관리담당자의 기준정보(codemst) 거래처가 누락 되었습니다")
		RETURN
	end if
end if

dw_2.getchild("cust_no", idwc_cust)
GS_DS_WHCUSTRET.ShareData(idwc_cust)

dw_2.getchild("scene_code", idwc_scene)
idwc_scene.settransobject(sqlca)
idwc_scene.insertrow(0)  
is_scenesql = idwc_scene.describe("datawindow.table.select")

dw_3.getchild("item_no", idwc_item)
GS_DS_ITEMALL.ShareData(idwc_item)

dw_3.getchild("qa", idwc_qa)
GS_DS_QAALL.ShareData(idwc_qa)

dw_3.SetTransObject(sqlca)

string  ls_setting
ls_setting = ProfileString("YCERP.INI", "DATABASE", "ORSALE",  " ")	
if IsNumber(ls_setting) then
	dw_3.Object.DataWindow.Zoom = integer(ls_setting)
end if

em_1.text = string(RelativeDate(today(), - 10), "yyyy/mm/dd")
em_2.text = string(RelativeDate(today(), + 10), "yyyy/mm/dd")
if gs_area = "B0001" THEN  // YSP사업장
	rb_1.checked = true
	rb_1.triggerevent(clicked!)
else								//"S0001" //: 시화
	rb_2.checked = true
	rb_2.triggerevent(clicked!)
end if

//	시화사업장은 재료매출이므로 조회건이 별로 없어 강제로 H로 변환 이건 검토대상
if LeftA(gs_area,1) = "S" then
	em_3.text = "HD" + string(today(), "yyyymmdd")
else
	em_3.text = LeftA(gs_area, 1) + "D" + string(today(), "yyyymmdd")
end if

dw_5.visible = false
dw_export.visible = false

// 공정
pb_compute.visible = false

// 엑셀
cb_3.enabled = true

// 문자전송
pb_6.visible  = false
if gf_permission("SMSSEND", gs_userid) = 'Y' then
	pb_6.visible  = true
end if

dw_8.visible  = false
dw_7.settransobject(sqlca)		
dw_7.visible  = false			// 수주오류체크

ddlb_col.text = "현장명"
ddlb_2.text   = "LIKE"
em_3.SelectText(9, 2)
em_3.setfocus()

/* 2021.03.18 jowonsuk w_oiscene_r 현장별 자재투입에서 수주관리 바로 조회 하도록 내용 반영. 시작 */
string ls_orsale

ls_orsale = message.stringparm
if isnull(ls_orsale) or trim(ls_orsale) = '' then
else
	if LeftA(ls_orsale, 7) = 'oiscene' then
		em_3.text = MidA(ls_orsale,8,10)
		em_4.text = RightA(ls_orsale,3)	
		pb_cancel.postevent(clicked!)		
	end if
	
end if	
/* 2021.03.18 jowonsuk w_oiscene_r 현장별 자재투입에서 수주관리 바로 조회 하도록 내용 반영. 끝 */
end event

event resize;call super::resize;gb_2.width  = newwidth  - (gb_2.x * 2)

st_vertical.x      = dw_4.x + dw_4.width
st_vertical.height = dw_4.height

dw_2.x      = st_vertical.x + st_vertical.width
dw_2.width  = newwidth  - dw_2.x - gb_2.x

dw_3.width  = newwidth  - (gb_2.x * 2)
dw_3.height = newheight - dw_3.y - gb_2.x

dw_7.width  = dw_8.width  * 2
dw_7.height = dw_8.height * 2
dw_7.x      = (newwidth  - dw_7.width ) / 2
dw_7.y      = (newheight - dw_7.height) / 2

dw_10.x     = dw_7.x
dw_10.y     = dw_7.y
dw_10.width = dw_7.width
dw_10.height= dw_7.height

dw_12.x     = (newwidth  - dw_12.width ) / 2
dw_12.y     = (newheight - dw_12.height) / 2

dw_12.width = 3000
dw_12.height= 600

dw_13.width = 2889
dw_13.x     = ( newwidth  - dw_13.width ) / 2
dw_13.y     = ( newheight - dw_13.height) / 2 - 500

dw_16.x     = dw_7.x
dw_16.y     = dw_7.y
dw_16.width = 3442
dw_16.height= dw_7.height

dw_14.x     = gb_2.x + gb_2.width - 2277
dw_14.y     = dw_3.y
dw_14.width = 2277
dw_14.height= dw_3.height

p_1.x         = dw_3.x + (3255 / 2)
p_1.y         = dw_3.y
p_1.width     = 3255
p_1.height    = dw_3.height

il_maxWidth   = p_1.width
il_maxHeight  = p_1.height

st_filename.width = newwidth - st_filename.x - gb_2.x
end event

event key;call super::key;// 1 Shift, 2 Ctrl, 3 Shift + Ctrl keys
IF keyflags = 2 THEN
	IF key = KeyS! THEN
		if MessageBox("확인", "수주내용을 저장 하시겠습니까?", Exclamation!, OKCancel!, 2) = 1 then
			pb_save.triggerevent(clicked!)
		end if
	END IF
END IF
end event

event closequery;call super::closequery;if MessageBox("확인", "작업을 종료 하시겠습니까?", Question!, YesNo!) = 2 then
	RETURN 1
else
	RETURN 0
end if
end event

type pb_save from w_inheritance`pb_save within w_orsale_m
event ue_print pbm_custom01
integer x = 5074
integer y = 44
integer width = 178
integer taborder = 500
end type

event pb_save::clicked;dwitemstatus l_status
string  	ls_sale_no, ls_sale_no1, ls_sale_date,   ls_seq, ls_sale_flag, ls_tax_sign, ls_area, ls_item_name
string  	ls_confirm, ls_esti_no,  ls_new_chk = 'N'
string  	ls_shipto_addr, ls_msg,  ls_item_no, ls_qa, ls_uom, ls_itemno1, ls_qa1, ls_terms
string  	ls_qa_split[], ls_chk1, ls_chk2, ls_chk3, ls_chk4, ls_val1, ls_val2, ls_val3, ls_val4
string  	ls_mpsorder, ls_mps_sale, ls_remsale, ls_remmps,  ls_remcheck
int     	li_seq,     li_revision_no
long    	ll_row, ll_iY, ll_idx, ll_cnt
decimal 	lr_order_qty, lr_amt, lr_vat = 0
datetime ldt_trackdate, ldt_duedate

string  	ls_order_no, ls_sale_control, ls_scene_code, ls_confirm_flag, ls_open_close
string  	ls_cust_no, ls_shiptoaddr, ls_telno, ls_telnocap
DateTime ld_podate
string   ls_date,   ls_date60, ls_codemst_bigo
Int      li_today1, li_codemst_bigo
date		dt1, dt2
Decimal	ld_pricemin
string	ls_itemcost, ls_qacost, ls_uomcost

setnull( ldt_trackdate )

//01.	dw_2 validation 확인
if dw_2.accepttext() = -1 then return
if dw_2.rowcount() < 1 then RETURN

//수주 상태 확인
ls_order_no	=	dw_2.object.order_no[1]
if not gf_null_chk(ls_order_no) then
	select
		 confirm_flag
		,open_close
	into
		 :ls_confirm_flag
		,:ls_open_close
	from 
		sale
	where
		order_no = :ls_order_no
	using sqlca;
	
	if gf_null_chk(ls_confirm_flag) then ls_confirm_flag = 'N'
	if gf_null_chk(ls_open_close) then ls_open_close = 'O'	
	
	if ls_confirm_flag <> 'N' then
		MessageBox("확인","수주 상태가 등록이 아니면~r~n저장할수 없습니다.")
		return		
	end if
end if

if ls_open_close = 'Z' then
	MessageBox("확인","마감 구분이 여신한도 초과면~r~n저장할수 없습니다.")
	return		
end if


// 거래처 확인
ls_cust_no = dw_2.getitemstring(1, 'cust_no')
if gf_null_chk(ls_cust_no) then
	MessageBox("확인","거래처를 선택하세요.")
	return	
end if

// 선입금 업체 체크(선입금, 선입금해지)
SELECT rtrim(terms) INTO :ls_terms FROM customer WHERE cust_no = :ls_cust_no;
choose case ls_terms
	case "선입금해지"
		MessageBox("확인","선입금해지 된 업체 입니다. 영업지원팀에 문의 바랍니다.!",stopsign!)
		RETURN
end choose

// 매출통제
SELECT isnull(sale_control,'N')
INTO :ls_sale_control
FROM customer
WHERE cust_no = :ls_cust_no;
 
if ls_sale_control = "A" OR ls_sale_control = "Y" then
	MessageBox("저장오류","매출통제 대상 거래처입니다.",stopsign!)
	RETURN
end if

//현장 정보 확인하기
ls_scene_code = trim(dw_2.object.scene_code[1])
if isnull(ls_scene_code) or ls_scene_code = "" then // 수주현장
	MessageBox("저장오류","거래처 현장은 반드시 선택하시기 바랍니다.!",stopsign!)
	RETURN
end if

if isnull(dw_2.object.salesman[1]) or trim(dw_2.object.salesman[1]) = '' then
	MessageBox('경고','선택한 거래처의 담당영업사원이 지정되지 않았습니다.~n~n' + &
	                  '(거래처관리에서 담당영업사원 지정필요)',stopsign!)
	RETURN
end if

if isnull(dw_2.object.due_date[1]) then
	MessageBox("확인","납기일자를 입력하세요.")
	dw_2.setcolumn("due_date")
	dw_2.setfocus()
	RETURN
end if

// 운송처주소, 연락처, 보조연락처 마스터 정보 확인하기
ls_shiptoaddr = trim(dw_2.object.shipto_addr[1])		// 운송처주소
ls_telno      = trim(dw_2.object.tel_no[1])				// 연락처
ls_telnocap   = trim(dw_2.object.telno_cap[1])			// 보조연락처

if isnull(ls_shiptoaddr) or ls_shiptoaddr = "" or isnull(ls_telno) or ls_telno = "" then
	MessageBox("저장오류","운송처주소, 연락처은 반드시 입력하시기 바랍니다.!",stopsign!)
	dw_2.setcolumn('shipto_addr')
	dw_2.setfocus()
	RETURN
end if

if isnull(ls_telnocap) or ls_telnocap = "" then
	MessageBox("저장오류","보조연락처는 반드시 입력하시기 바랍니다.!",stopsign!)
	dw_2.setcolumn('telno_cap')
	dw_2.setfocus()
	RETURN
end if

// 요구납기 CHECK
ld_podate  	= dw_2.object.cust_po_date[dw_2.getrow()]
if date(ld_podate) = date("8282-08-28") OR date(ld_podate) = date("9999-09-29") then
	// 빨리빨리, 회신일자
else
	ls_date    = string(ld_podate, "yyyy/mm/dd")

	SELECT 
		top 1 Datediff( day, :ls_date, getdate() ), convert(char(10),dateadd( day, 60, :ls_date ),111)
	INTO 
		:li_today1, :ls_date60  
	FROM 
		login;
	
	if li_today1 < 0 then li_today1 = li_today1 * -1

	/* 여직원 가끔 요청함 - CODEMST로 변환 */
	ls_codemst_bigo = GF_Permission_BIGO_RETURN("판매수주관리_납기일범위", gs_userid)
	if ls_codemst_bigo <> "N" then
		li_codemst_bigo = Integer(ls_codemst_bigo)
	else
		li_codemst_bigo = 60
	end if
	
	if li_today1 > li_codemst_bigo then 
		ls_msg  = "요구납기일자는 " + ls_date + " 부터 +60일 까지(" + ls_date60 + ") 처리가능 합니다.~n~n"
		ls_msg += "현재 60일 경과된 수주내용을 변경하려고 합니다.(" + string(li_today1) + "일 경과)~n~n"
		ls_msg += "현 수주자료의 운송처만 수정됩니다.~n~n"
		ls_msg += "변경 하시겠습니까?"
	
		ls_shipto_addr = dw_2.object.shipto_addr[1]
		if MessageBox("경고", ls_msg, question!, yesno!, 1) = 1 then
			UPDATE sale SET shipto_addr = :ls_shipto_addr WHERE order_no = :ls_order_no;
			if sqlca.sqlcode <> 0 then
				ROLLBACK;
				MessageBox("확인","수주내용의 운송처 변경과정 중 ERROR가 발생하였습니다.")
				RETURN
			else
				COMMIT;
			end if
		end if
		
		dw_2.setcolumn('cust_po_date')
		dw_2.setfocus()
		RETURN
	else
		// 요구납기 정상 처리 : 금일부터 60일 이내 
	end if
end if

// 주문일자 CHECK
dt1 = date(dw_2.object.order_date[1])
dt2 = date(gdt_today)

ls_codemst_bigo = GF_Permission_BIGO_RETURN("판매수주관리_주문일범위", gs_userid)
if ls_codemst_bigo <> "N" then
	li_codemst_bigo = Integer(ls_codemst_bigo)
else
	li_codemst_bigo = 30
end if

// 주문일자 정상 처리 : 금일부터 7일 이내
if DaysAfter( dt1, dt2 ) > li_codemst_bigo then	
	ls_msg  = "주문일자는 "+string(li_codemst_bigo)+"일을 초과할 수 없습니다.~n~n"
	ls_msg += "확인 후 다시 진행해 주시기 바랍니다."
	MessageBox("경고",ls_msg, StopSign!)
	RETURN
end if

//02.	dw_3 validation
if dw_3.rowcount() < 1 then
	MessageBox("저장","등록된 물품이 없습니다!",exclamation!)
	RETURN
end if

if dw_3.accepttext() = -1 then 
	messagebox("오류","다시 저장 버튼을 클릭하세요.")
	return
end if


// 품목 + 규격 오류 검사 //  CHK1 = Y, QA1 = 080 : QA1 값이 080만 허용
ls_remcheck  = ""
for ll_iY = 1 to dw_3.rowcount()
	ls_item_no   = dw_3.object.item_no[ll_iY]			// 수주품목
	ls_qa        = dw_3.object.qa[ll_iY]				// 수주규격
	ls_uom       = dw_3.object.uom[ll_iY]				// 수주단위
	lr_order_qty = dw_3.object.order_qty[ll_iY]		// 수주수량
	ls_remsale   = dw_3.object.rem[ll_iY]				// 비고(색상)
	ls_item_name = dw_3.object.item_item_name[ll_iY]
	
	//규격확인
	if gf_null_chk(ls_qa) = true then
		MessageBox("확인",string(ll_iy) + " 행 규격을 입력하세요!",exclamation!)
	end if

	//수량확인
	if isnull(lr_order_qty) OR lr_order_qty = 0 then
		MessageBox("확인",string(ll_iy) + " 행 수량 확인바랍니다.", stopsign!)
		RETURN
	end if
	
	if dw_3.getitemdecimal(ll_iY, "stock_qty") > dw_3.getitemdecimal(ll_iY, "order_qty") then
		MessageBox("확인", "장기재고 수량은 주문수량보다 클수 없습니다.")
		dw_3.scrolltorow(ll_row)			
		dw_3.setfocus()
		RETURN
	end if	
	
	// 수주내용 변경시에 생산(작업지시) 확인
	if dw_2.object.sale_confirm_flag[1] <> "N" then
		ls_mps_sale = dw_2.object.order_no[1]			// 수주번호
		
		SELECT 
			mpsorder_order, rem INTO :ls_mpsorder, :ls_remmps
		FROM 
			mpsdet with (nolock)
		WHERE 
			sale_no = :ls_mps_sale AND seq_no = :ll_iY
		and 
			mpsorder_order is not null
		using sqlca;
		 
		if isnull(ls_mpsorder) OR ls_mpsorder = "" then
			// 작업지시 미발행 상태
		else
			if ls_remmps <> ls_remsale then
				ls_remcheck = ls_remcheck + "~n~r" + string(ll_iy,"000") + "행 [수주]" + ls_remsale + "~n~r" + &
				                                                      "        [생산]" + ls_remmps  + "~n~r"
			end if
		end if
	end if

	//2018.11.8 jowonsuk 규격패턴 점검 로직 수정, 기존 제품에 다양한 규격 패턴을 점검 못함. 시작
	LONG L_itemqa_pattern_COUNT
	L_itemqa_pattern_COUNT = 0

	SELECT COUNT(*)
	INTO :L_itemqa_pattern_COUNT
	from itemqa_pattern
	WHERE item_no = :ls_item_no AND uom = :ls_uom AND use_yn = 'Y' ;
	
	IF L_itemqa_pattern_COUNT <> 0  THEN		/* 2018.11.8 jowonsuk 점검 대상인겅우만 */
		L_itemqa_pattern_COUNT = 0
		SELECT COUNT(*)
		INTO :L_itemqa_pattern_COUNT
		from itemqa_pattern
		WHERE item_no = :ls_item_no AND uom = :ls_uom AND use_yn = 'Y'   AND QA1 = ( CASE WHEN CHK1 = 'Y' THEN  substring(:ls_qa,1,3) ELSE 'FRE' END);
		
		if L_itemqa_pattern_COUNT = 0 then		
			MessageBox("확인",string(ll_iy) + " 행 품목의 규격1 오류. " + MidA(ls_qa,1,3) + " 을 확인해 보세요.", stopsign!)
			RETURN
		end if
		
		L_itemqa_pattern_COUNT = 0
		SELECT COUNT(*)
		INTO :L_itemqa_pattern_COUNT
		from itemqa_pattern
		WHERE item_no = :ls_item_no AND uom = :ls_uom AND use_yn = 'Y'   
		AND QA2 = (CASE WHEN CHK2 = 'Y' THEN  substring(:ls_qa,5,4) ELSE 'FREE' END);	
		
		if L_itemqa_pattern_COUNT = 0 then		
			MessageBox("확인",string(ll_iy) + " 행 품목의 규격2 오류. " + MidA(ls_qa,5,4) + " 을 확인해 보세요.", stopsign!)
			RETURN
		end if	
		
		L_itemqa_pattern_COUNT = 0
		SELECT COUNT(*)
		INTO :L_itemqa_pattern_COUNT
		from itemqa_pattern
		WHERE item_no = :ls_item_no AND uom = :ls_uom AND use_yn = 'Y'   
		AND QA3 = (CASE WHEN CHK3 = 'Y' THEN  substring(:ls_qa,10,4) ELSE 'FREE' END);		
		
		if L_itemqa_pattern_COUNT = 0 then		
			MessageBox("확인",string(ll_iy) + " 행 품목의 규격3 오류. " + MidA(ls_qa,10,4) + " 을 확인해 보세요.", stopsign!)
			RETURN
		end if
		
		L_itemqa_pattern_COUNT = 0
		SELECT COUNT(*)
		INTO :L_itemqa_pattern_COUNT
		from itemqa_pattern
		WHERE item_no = :ls_item_no AND uom = :ls_uom AND use_yn = 'Y'   
		AND QA4 = (CASE WHEN CHK4 = 'Y' THEN  substring(:ls_qa,15, 5) ELSE 'FREE' END);	
		
		if L_itemqa_pattern_COUNT = 0 then		
		MessageBox("확인",string(ll_iy) + " 행 품목의 규격4 오류. " + MidA(ls_qa,15, 5) + " 을 확인해 보세요.", stopsign!)
		RETURN
		end if			
	
	END IF
	//2018.11.8 jowonsuk 규격패턴 점검 로직 수정, 기존 제품에 다양한 규격 패턴을 점검 못함. 끝*/		
next

if ls_remcheck <> "" then
	MessageBox("확인", ls_remcheck)
end if

//03.	dw_8 validation
// 가져오기 품목, 규격 오류 검사 
if dw_8.rowcount() > 0 then
	if MessageBox("저장확인","가져오기에서 품목,규격 오류 확인하시기 바랍니다.~n~n계속진행 합니까?",question!,okcancel!,2) = 2 then
		RETURN
	else
		dw_8.visible = true
		
		for ll_iY = dw_8.rowcount() to 1 step -1
			ll_idx = long(dw_8.object.no[ll_iY])		// 행번호
			if ll_idx > 0 and ll_idx <= dw_3.rowcount()  then
				ls_item_no = dw_3.object.item_no[ll_idx]		// 수주품목
				ls_qa      = dw_3.object.qa[ll_idx]				// 수주규격

				SELECT count(*) INTO :ll_row FROM item WHERE item_no = :ls_item_no AND qa = :ls_qa;
				if ll_row = 0 then
					if GF_ItemINSERT(ls_item_no, ls_qa) = true then
						dw_8.deleterow( ll_iY )
					end if
				end if
			end if
		next
		if dw_8.rowcount() < 1 then dw_8.visible = false
	end if
end if

// 최저단가
for ll_row = 1 to dw_3.rowcount()
   ls_itemcost = dw_3.object.item_no[ll_row]
	ls_qacost   = dw_3.object.qa[ll_row]
	ls_uomcost  = dw_3.object.uom[ll_row]
	
	if ls_uomcost = "M" then
		ls_qacost = LeftA(ls_qacost,13)
	else
		ls_qacost = ls_qacost
	end if

	// 최저단가
	SELECT price_min INTO :ld_pricemin 
	  FROM itemcost 
	 WHERE item_no = :ls_itemcost AND qa = :ls_qacost AND uom = :ls_uomcost;
	if isnull(ld_pricemin) then
	else
		if dw_3.Object.price[ll_row] < ld_pricemin then
			if MessageBox("단가확인","최저단가 이하금액으로 등록할 수 없습니다." + &
							  + "~n~n계속 등록하시겠습니까?",Exclamation!, YesNo!, 2) = 2 then
				dw_3.scrolltorow(ll_row)			
				dw_3.setfocus()
				RETURN
			end if
		end if
	end if
next
///////////////////////////////////////////////////////////////////////////////////////////

// 공급가액, V.A.T계산
ls_tax_sign = dw_2.getitemstring(1, "tax_sign")

if dw_3.rowcount() > 0 then
	for ll_row = 1 to dw_3.rowcount()
		lr_amt = lr_amt + dw_3.getitemdecimal(ll_row, "amount")
	next

	dw_2.object.sale_amount[1] = lr_amt
	if ls_tax_sign = "Y" then
		dw_2.object.sale_tax[1] = 0
		
		if dw_2.object.curr_code[1] = "WON" then
			dw_2.object.sale_tax[1] = TRUNCATE((lr_amt / 10) + 0.0000001, 0 )
		else
			dw_2.object.sale_tax[1] = TRUNCATE((lr_amt / 10) + 0.0000001, 2 )
		end if
	else
		dw_2.object.sale_tax[1] = 0
	end if
end if

if MessageBox("저장","저장하시겠습니까?",question!,okcancel!,1) = 2 then RETURN

l_status        = dw_2.getitemstatus(1, 0, primary!)
li_revision_no  = dw_2.getitemnumber(1, "revision_no")
dw_2.object.login_id[1] = gs_userid

dw_2.accepttext()
dw_3.accepttext()

setpointer(hourglass!)
if WF_nullchk(dw_2) = false then RETURN
if WF_nullchk(dw_3) = false then RETURN

// 신규등록시
if l_status = newmodified! OR l_status = new! then
	ls_new_chk = "Y"
	dw_2.object.input_date[1] = GF_Today()
	
	// 수주번호 부여
	dw_6.accepttext()

	ls_sale_flag = dw_2.getitemstring(1, "sale_flag")
	ls_area      = LeftA(dw_6.object.area[1],1)
	ls_sale_date = string(dw_2.object.order_date[1], "yyyymmdd")
	ls_sale_no1  = ls_area + ls_sale_flag + ls_sale_date + "-" + "%"
		
	// MASTER, DETAIL 상이한 번호 존재시
	string ls_ordertemp
	SELECT max(order_no) INTO :ls_ordertemp FROM saledet WHERE order_no LIKE :ls_sale_no1;	 
	SELECT max(order_no) INTO :ls_sale_no   FROM sale    WHERE order_no LIKE :ls_sale_no1;
	if ls_sale_no <> ls_ordertemp then
		MessageBox("확인","["+ls_ordertemp+"] SALEDET 채번 오류 입니다.")
		RETURN
	end if
	
	if isnull(ls_sale_no) OR ls_sale_no = "" then
		ls_sale_no1 = ls_area + ls_sale_flag + ls_sale_date + "-" + "001"
	else
		li_seq = integer(MidA(ls_sale_no, 12, 3))
		li_seq = li_seq + 1
		ls_seq = "00" + string(li_seq)
		ls_sale_no1 = LeftA(ls_sale_no1, 11) + RightA(ls_seq, 3)
	end if
	// 번호부여
	for ll_row = 1 to dw_3.rowcount() 
		dw_3.object.order_no[ll_row] = ls_sale_no1
	next
	
	dw_2.object.order_no[1] = ls_sale_no1
	ls_esti_no = dw_2.object.estimate_no[1]
	if isnull(ls_esti_no) OR trim(ls_esti_no) = "" then
	else
		UPDATE estimate_head SET sale_succ = 'Y' WHERE estimate_no = :ls_esti_no;
		if sqlca.sqlcode <> 0 then
			ROLLBACK;
			MessageBox("삭제","estimate_head UPDATE도중 오류가 발생하였습니다.")
			RETURN
		end if
	end if
// 수정작업시
else
	ls_new_chk = 'N'
	if WF_Confirm('N') = false then 		// 수주확정 체크
		ls_confirm = dw_2.object.sale_confirm_flag[1]
		if ls_confirm <> 'Y' then
			MessageBox("확인", "이미 확정되어있습니다. 재조회 하십시요")
			RETURN
		end if

		// 다공정 확인
		if dw_2.object.sale_tracking[1] = "Y" then
			if isnull(dw_2.object.tracking_date[1]) then
				dw_2.object.tracking_date[1] = gf_today()
			end if
		else
			dw_2.object.tracking_date[1] = ldt_trackdate
		end if
		// 거래처현장관리 마스터에 연락처, 보조연락처 UPDATE 
		WF_Images_SAVE()
		WF_Update1(dw_2, 'Y')		// sale master
		
		/* 2022-03-04 jowonsuk  생산확정일때 수정하면 수정 반영*/
		/* 2022-03-16 jowonsuk  보완내용 생산계획조정(RoutTempNew) -> 생산계획(mpsdet) 넘긴거는 제외 반영
										   		생산계획조정(RoutTempNew) -> 생산계획(mpsdet) 로 넘길때 RoutTempNew의 work_date를 today()반영
								      이 날짜를 기준으로 생산계획일을 조회하는데 이 날짜가 계속 바뀌니 문제가 됨.*/
		if  dw_2.object.sale_confirm_flag[1] = 'Y' then
			ldt_duedate = dw_2.object.due_date[1]
				
			update RoutTempNew
			set work_date = :ldt_duedate    
			where sale_no = :ls_order_no
			and  NOT EXISTS  (
									select *
									from mpsdet
									where mpsdet.sale_no = routtempnew.sale_no
									and mpsdet.seq_no = routtempnew.seq_no);
		end if		
		
		
		UPDATE scene  SET scene_tel = :ls_telno  WHERE scene_code = :ls_scene_code;
		
		if isnull(ls_telnocap) OR ls_telnocap = "" then
		else
			UPDATE scene  SET scene_telcap = :ls_telnocap  WHERE scene_code = :ls_scene_code;
		end if
		
		if sqlca.sqlcode <> 0 then
			ROLLBACK;
			MessageBox("확인","데이터업데이트시 ERROR가 발생하였습니다.")
			RETURN
		else
			COMMIT;
		end if		
		
		RETURN
	end if
	
	ls_sale_no1 = dw_2.getitemstring(1, "order_no")
	for ll_row = 1 to dw_3.rowcount() 
		l_status = dw_3.getitemstatus(ll_row, 0, primary!)
		if l_status = newmodified! OR l_status = new! then
			dw_3.object.order_no[ll_row] = ls_sale_no1
		end if
	next
	li_revision_no = li_revision_no + 1
	dw_2.object.revision_no[1] = li_revision_no
end if	

dw_2.object.revision_date[1] = GF_Today()

dw_2.accepttext()
dw_3.accepttext()

if ls_new_chk = "Y" then
	integer li_cnt 
	SELECT count(*) INTO :li_cnt FROM sale WHERE order_no LIKE :ls_sale_no1;
	if li_cnt <> 0 then
		// 수주번호 부여
		ls_sale_flag = dw_2.getitemstring(1, "sale_flag")
		
		ls_area      = LeftA(dw_6.object.area[1],1)
		ls_sale_date = string(dw_2.object.order_date[1], "yyyymmdd")
		ls_sale_no1  = ls_area + ls_sale_flag + ls_sale_date + '-' + '%'
			
		SELECT max(order_no) INTO :ls_sale_no FROM sale WHERE order_no LIKE :ls_sale_no1;
		 
		if isnull(ls_sale_no) OR ls_sale_no = '' then
			ls_sale_no1 = ls_area + ls_sale_flag + ls_sale_date + '-' + '001'
		else
			li_seq = integer(MidA(ls_sale_no, 12, 3))
			li_seq = li_seq + 1
			ls_seq = '00' + string(li_seq)
			ls_sale_no1 = LeftA(ls_sale_no1, 11) + RightA(ls_seq, 3)
		end if
					
		for ll_row = 1 to dw_3.rowcount() 
			dw_3.object.order_no[ll_row] = ls_sale_no1
		next
		
		dw_2.object.order_no[1] = ls_sale_no1
		dw_2.accepttext()
		dw_3.accepttext()
	end if
	
end if

// 다공정 확인
if dw_2.object.sale_tracking[1] = "Y" then
	if isnull(dw_2.object.tracking_date[1]) then
		dw_2.object.tracking_date[1] = gf_today()
	end if
else
	dw_2.object.tracking_date[1] = ldt_trackdate
end if

// 최초등록자
if isnull(dw_2.object.org_user[1]) OR dw_2.object.org_user[1] = "" then
	dw_2.object.org_user[1] = gs_userid
end if

// 저장(sale, saledet)
WF_Images_SAVE()
if WF_Update2(dw_2, dw_3, 'Y') = false then RETURN

// 이슈품목알림이_사용
if ls_new_chk = 'Y' then
	WF_IssueItem_SMS( ls_sale_no1 )
end if

// 결재유형 변경(선입금 -> 선입금해지)
if ls_terms = "선입금" then
	UPDATE customer SET terms = "선입금해지" WHERE cust_no = :ls_cust_no;
	if sqlca.sqlcode <> 0 then
		ROLLBACK;
		MessageBox("확인","거래처 선입금해지 저장시 ERROR가 발생하였습니다.")
		RETURN
	else
		COMMIT;
	end if

end if

// 현장전화 번호 수정
UPDATE scene SET scene_tel = :ls_telno, scene_telcap = :ls_telnocap
WHERE scene_code = :ls_scene_code;
if sqlca.sqlcode <> 0 then
	ROLLBACK;
	MessageBox("확인","현장전화번호 저장시   ERROR가 발생하였습니다.")
	RETURN
else
	COMMIT;
end if

 
 /* 2021-04-20 jowonsuk 합계금액 한번 더 계산 시작 */
ls_order_no =  dw_2.object.order_no[1]

select sum(acc_qty*price) amt
into :lr_amt
from saledet 
where order_no = :ls_order_no
group by  order_no;

if ls_tax_sign = "Y" then
	
	if dw_2.object.curr_code[1] = "WON" then
		lr_vat = TRUNCATE((lr_amt / 10) + 0.0000001, 0 )
	else
		lr_vat = TRUNCATE((lr_amt / 10) + 0.0000001, 2 )
	end if
else
	lr_vat = 0
end if

update sale
    set sale_amount = :lr_amt, 
	     sale_tax  = :lr_vat
where order_no = :ls_order_no;		  

if sqlca.sqlcode <> 0 then
	ROLLBACK;
	MessageBox("확인","수주 합계 금액 저장시 ERROR가 발생하였습니다.")
	RETURN
else
	COMMIT;
end if

 /* 2021-04-20 jowonsuk 합계금액 한번 더 계산 끝 */
//==GF_USEPROGRAM(프로그램 사용현황)==============================================================
GF_USEPROGRAM( gs_userid, Parent.ClassName(), "S", string(gf_today(),'yyyy/mm/dd'), Parent.Title )
//================================================================================================

string ls_sdate, ls_edate
 
em_1.text = string(dw_2.object.order_date[1], "yyyy/mm/dd")
em_2.text = string(dw_2.object.order_date[1], "yyyy/mm/dd")
dw_1.object.cust_no[1] = ls_cust_no
ls_sdate   = em_1.text
ls_edate   = em_2.text

dw_4.setredraw( false )
dw_4.retrieve( ls_cust_no, ls_sdate, ls_edate)
dw_4.setredraw( true )

ll_row = dw_4.Find( "order_no = '" + ls_sale_no1 + "'", 1, dw_4.rowcount() )
if ll_row > 0 then
	dw_4.scrolltorow( ll_row )
end if

// 출고시에 수주번호+순번으로 출고수량 재 계산함으로 수정불가
cb_5.enabled = false	// 순서(상)
cb_6.enabled = false	// 순서(하)

// 커서 이동하기
em_4.setfocus()
end event

type dw_1 from w_inheritance`dw_1 within w_orsale_m
integer x = 969
integer y = 260
integer width = 910
integer height = 96
integer taborder = 180
string dataobject = "d_orcustomer_s"
boolean hscrollbar = false
boolean vscrollbar = false
boolean border = false
boolean livescroll = false
end type

event dw_1::itemchanged;//// 공무관리담당자는 거래처변경 못함
string ls_custconst, ls_data

this.accepttext()
ls_data = data

/*2018.08.09 jowonsuk 권한 수정 작업 */
if GF_PERMISSION("공무관리담당자", gs_userid) = 'Y'  and ((GF_Permission("판매관리_입력", gs_userid) <> "Y" or GF_Permission("판매관리_입력(부분)", gs_userid) = "Y" ) and GF_Permission("판매관리_조회", gs_userid) <> "Y" )  then
		if this.object.cust_no[row] = is_custconst then
			// 공무관리담당자별 거래처선택
		else
			// 공무관리담당자는 등록된 복수거래처를 열람할 수 있음(2015/08/05)
			if GF_PERMISSION("공무관리담당자", gs_userid) = 'Y' then
				SELECT top 1 rtrim(bigo) INTO :ls_custconst FROM codemst 
				 WHERE type = '공무관리담당자' AND use_yn = 'Y' AND item_cd = :gs_userid AND rtrim(bigo) <> :is_custconst;	
				if isnull(ls_custconst) OR ls_custconst = "" OR LenA(ls_custconst) <> 4 then
					MessageBox("확인1","공무관리담당자는 해당하는 거래처만 선택할 수 있습니다!",exclamation!)
					this.object.cust_no[row] = is_custconst
					RETURN 2
				else
					if ls_data = ls_custconst then
						// 공무관리담당자별 거래처선택(복수거래처) 가능
						cb_filteroff.triggerevent(clicked!)
						pb_retrieve.postevent(clicked!)
					else
						MessageBox("확인1","공무관리담당자는 해당하는 거래처만 선택할 수 있습니다!",exclamation!)
						this.object.cust_no[row] = is_custconst
						RETURN 2
					end if
				end if
			end if
		end if
else
	cb_filteroff.triggerevent(clicked!)
	pb_retrieve.postevent(clicked!)
end if
end event

event dw_1::keydown;call super::keydown;// 판매관리_조회
if GF_PERMISSION("판매관리_조회", gs_userid) = "Y" then
	if GF_PERMISSION("판매관리_입력", gs_userid) = "Y" or GF_PERMISSION("판매관리_입력(부분)", gs_userid) = "Y" or GF_PERMISSION("판매관리_입력(영업담당)", gs_userid) = "Y" then
	else
		RETURN
	end if
end if

// 1 Shift, 2 Ctrl, 3 Shift + Ctrl keys
IF keyflags = 2 THEN
	IF key = KeyS! THEN
		if MessageBox("확인", "수주내용을 저장 하시겠습니까?", Exclamation!, OKCancel!, 2) = 1 then
			pb_save.triggerevent(clicked!)
		end if
	END IF
END IF

if key = KeyEnter! then
	//// 공무관리담당자는 거래처변경 못함
	if GF_PERMISSION("공무관리담당자", gs_userid) = 'Y'  and ((GF_Permission("판매관리_입력", gs_userid) <> "Y" or GF_Permission("판매관리_입력(부분)", gs_userid) <> "Y") and GF_Permission("판매관리_조회", gs_userid) <> "Y" ) then
		if this.object.cust_no[dw_1.getrow()] = is_custconst  then
			// 공무관리담당자는 거래처변경 못함
		else
			MessageBox("확인3","공무관리담당자는 거래처만 선택할 수 있습니다!",exclamation!)
			this.object.cust_no[dw_1.getrow()] = is_custconst
		end if
	end if
end if

end event

event dw_1::getfocus;call super::getfocus;// 한글 키보드 
long mode

mode = ImmGetContext( handle(parent) )
ImmSetConversionStatus( mode, 1, 0 )		// 2번째 인수값 1=KOR, 2=ENG

end event

