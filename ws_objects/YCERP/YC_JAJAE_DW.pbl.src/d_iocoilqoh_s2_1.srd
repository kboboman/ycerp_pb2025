$PBExportHeader$d_iocoilqoh_s2_1.srd
$PBExportComments$품목별 AL 코일재고 현황(2006/01/13,정갑용)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=164 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(255) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=c_qa dbname="c_qa" )
 column=(type=long updatewhereclause=yes name=q_cnt_1 dbname="q_cnt_1" )
 column=(type=long updatewhereclause=yes name=q_cnt_2 dbname="q_cnt_2" )
 column=(type=long updatewhereclause=yes name=t_cnt_1 dbname="t_cnt_1" )
 column=(type=long updatewhereclause=yes name=q_cnt_3 dbname="q_cnt_3" )
 column=(type=long updatewhereclause=yes name=q_cnt_4 dbname="q_cnt_4" )
 column=(type=long updatewhereclause=yes name=t_cnt_2 dbname="t_cnt_2" )
 column=(type=long updatewhereclause=yes name=t_cnt_3 dbname="t_cnt_3" )
 column=(type=char(2) updatewhereclause=yes name=sort1 dbname="sort1" )
 column=(type=char(1) updatewhereclause=yes name=gb dbname="gb" )
 retrieve="SELECT item_name = REPLACE(A.item_name,'스리팅 ',''), 
			c_qa = left(a.c_qa,10), /* 규격 */
			q_cnt_1 = sum(q_cnt_1), /*원코일,시화*/
			q_cnt_2 = sum(q_cnt_2), /*원코일,외주*/
			t_cnt_1 = sum(q_cnt_1) + sum(q_cnt_2),  /*원코일,계*/
			q_cnt_3 = sum(q_cnt_3), /*스리팅,시화*/
			q_cnt_4 = sum(q_cnt_4), /*스리팅,외주*/
			t_cnt_2 = sum(q_cnt_3) + sum(q_cnt_4), /*스리팅,계*/
			t_cnt_3 = sum(q_cnt_1) + sum(q_cnt_2) + sum(q_cnt_3) + sum(q_cnt_4), /*총계*/
			sort1,
			gb
from 			
(
	  SELECT sort1 = substring(coilmst.item_no, 3, 1),/*원코일,시화*/
				item_name = groupitem.item_name,
				c_qa = left(coilmst.qa,10), 
				q_cnt_1 = sum(coilmst.unit_qty * coilmst.qcnt),
				q_cnt_2 = 0,
				t_cnt_1 = 0,
				q_cnt_3 = 0,
				q_cnt_4 = 0,
				gb = dbo.uf_getcoilsort(coilmst.item_no)
		 FROM coilmst,   
				groupitem, location
		WHERE ( coilmst.item_no = groupitem.item_no) and  
				( coilmst.loc_no = location.loc_no) and  
				( ( coilmst.loc_no IN( 'WS00000000', 'WS00000003', 'WW01', 'WW02', 'WW03') or  
				  		( loc_type = 'W' ) ) AND  
				  ( coilmst.flag = 'W' ) AND  
				  ( coilmst.open_close <> 'C' ) AND
				  ( substring(coilmst.item_no, 3, 1) in ( 'A') ) ) and
				not exists ( select * from lossitem where loss_item = coilmst.item_no)
	group by substring(coilmst.item_no, 3, 1),dbo.uf_getcoilsort(coilmst.item_no), groupitem.item_name, left(coilmst.qa,10)
	
	union all
	
	  SELECT sort1 = substring(coilmst.item_no, 3, 1),/*원코일,외주*/
				item_name = groupitem.item_name,
				c_qa = left(coilmst.qa,10), 
				q_cnt_1 = 0,
				q_cnt_2 = sum(coilmst.unit_qty * coilmst.qcnt),
				t_cnt_1 = 0,
				q_cnt_3 = 0,
				q_cnt_4 = 0,
				gb = dbo.uf_getcoilsort(coilmst.item_no)
		 FROM coilmst,   
				groupitem, location
		WHERE ( coilmst.item_no = groupitem.item_no) and  
				( ( coilmst.loc_no = location.loc_no and loc_type = 'Y' ) and
				  ( coilmst.flag = 'W' ) AND  
				  ( coilmst.open_close <> 'C' ) AND
				  ( substring(coilmst.item_no, 3, 1) in ( 'A') ) ) and
				not exists ( select * from lossitem where loss_item = coilmst.item_no)
	group by substring(coilmst.item_no, 3, 1),dbo.uf_getcoilsort(coilmst.item_no), groupitem.item_name, left(coilmst.qa,10)
	  
	union all
	
	  SELECT sort1 = substring(coilmst.item_no, 3, 1),/*스리팅,시화*/
				item_name = groupitem.item_name,
				c_qa = left(coilmst.qa,10), 
				q_cnt_1 = 0,
				q_cnt_2 = 0,
				t_cnt_1 = 0,
				q_cnt_3 = sum(coilmst.unit_qty * coilmst.qcnt),
				q_cnt_4 = 0,
				gb = dbo.uf_getcoilsort(coilmst.item_no)
		 FROM coilmst,   
				groupitem, location
		WHERE ( coilmst.item_no = groupitem.item_no) and  
				( coilmst.loc_no = location.loc_no) and  
				( ( coilmst.loc_no IN ( 'WS00000000', 'WS00000003', 'WW01', 'WW02', 'WW03') or  
				  	 ( loc_type = 'W' ) ) AND  
				  ( coilmst.flag = 'S' ) AND  
				  ( coilmst.open_close <> 'C' ) AND
				  ( substring(coilmst.item_no, 3, 1) in ( 'A') ) ) and
				not exists ( select * from lossitem where loss_item = coilmst.item_no)
	group by substring(coilmst.item_no, 3, 1),dbo.uf_getcoilsort(coilmst.item_no), groupitem.item_name, left(coilmst.qa,10)
	
	union all
	
	  SELECT sort1 = substring(coilmst.item_no, 3, 1),/*스리팅,외주*/
				item_name = groupitem.item_name,
				c_qa = left(coilmst.qa,10), 
				q_cnt_1 = 0,
				q_cnt_2 = 0,
				t_cnt_1 = 0,
				q_cnt_3 = 0,
				q_cnt_4 = sum(coilmst.unit_qty * coilmst.qcnt),
				gb = dbo.uf_getcoilsort(coilmst.item_no)
		 FROM coilmst,   
				groupitem, location
		WHERE ( coilmst.item_no = groupitem.item_no) and  
				( ( coilmst.loc_no = location.loc_no and loc_type = 'Y' ) and
				  ( coilmst.flag = 'S' ) AND  
				  ( coilmst.open_close <> 'C' ) AND
				  ( substring(coilmst.item_no, 3, 1) in ( 'A') ) ) and
				not exists ( select * from lossitem where loss_item = coilmst.item_no)
	group by substring(coilmst.item_no, 3, 1),dbo.uf_getcoilsort(coilmst.item_no), groupitem.item_name, left(coilmst.qa,10)
) A

GROUP BY sort1, gb, REPLACE(A.item_name,'스리팅 ',''), c_qa
order by sort1 desc, gb, REPLACE(A.item_name,'스리팅 ',''), c_qa
"  sort="sort1 D gb A groupitem_item_name A c_qa A " )
group(level=1 header.height=0 trailer.height=80 by=("sort1" ) header.color="536870912" trailer.color="536870912" )
group(level=2 header.height=0 trailer.height=0 by=("gb" ) header.color="536870912" trailer.color="553648127" )
group(level=3 header.height=0 trailer.height=84 by=("groupitem_item_name" ) header.color="536870912" trailer.color="536870912" )
