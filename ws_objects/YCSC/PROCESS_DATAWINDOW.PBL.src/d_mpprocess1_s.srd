table(column=(type=datetime updatewhereclause=yes name=work_date dbname="routtempnew.work_date" )
 column=(type=char(10) updatewhereclause=yes name=wc_no dbname="routtempnew.wc_no" )
 column=(type=long updatewhereclause=yes name=work_per dbname="routtempnew.work_per" )
 column=(type=char(14) updatewhereclause=yes name=sale_no dbname="routtempnew.sale_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="routtempnew.seq_no" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="routtempnew.cust_no" )
 column=(type=char(11) updatewhereclause=yes name=scene_code dbname="routtempnew.scene_code" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="routtempnew.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="routtempnew.qa" )
 column=(type=char(10) updatewhereclause=yes name=assy_item dbname="routtempnew.assy_item" )
 column=(type=char(20) updatewhereclause=yes name=assy_qa dbname="routtempnew.assy_qa" )
 column=(type=decimal(4) updatewhereclause=yes name=plan_qty dbname="routtempnew.plan_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=make_qty dbname="routtempnew.make_qty" )
 column=(type=char(1) updatewhereclause=yes name=plan_flag dbname="routtempnew.plan_flag" )
 column=(type=char(17) updatewhereclause=yes name=mpsdet_plan_no dbname="mpsdet.plan_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name1 dbname="groupitem.item_name" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name2 dbname="groupitem.item_name" )
 column=(type=char(2) updatewhereclause=yes name=groupitem_uom dbname="groupitem.uom" )
 column=(type=char(2) updatewhereclause=yes name=auom dbname="groupitem.uom" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="routtempnew.uom" )
 column=(type=long updatewhereclause=yes name=routtempnew_division dbname="routtempnew.division" )
 column=(type=long updatewhereclause=yes name=routtempnew_operation dbname="routtempnew.operation" )
 column=(type=char(4) updatewhereclause=yes name=item_color dbname="routtempnew.item_color" )
 column=(type=char(10) updatewhereclause=yes name=area_no dbname="routtempnew.area_no" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene.scene_desc" )
 column=(type=char(16) updatewhereclause=yes name=mpsorder_order dbname="mpsdet.mpsorder_order" )
 column=(type=long updatewhereclause=yes name=order_seq dbname="mpsdet.order_seq" )
 column=(type=datetime updatewhereclause=yes name=mps_start_date dbname="mps.start_date" )
 retrieve="  SELECT routtempnew.work_date    
       , routtempnew.wc_no        
       , routtempnew.work_per     
       , routtempnew.sale_no      
       , routtempnew.seq_no       
       , routtempnew.cust_no      
       , routtempnew.scene_code   
       , routtempnew.item_no      
       , routtempnew.qa           
       , routtempnew.assy_item    
       , routtempnew.assy_qa      
       , routtempnew.plan_qty     
       , routtempnew.make_qty     
       , routtempnew.plan_flag    
       , mpsdet.plan_no           
       , groupitem_a.item_name    
       , groupitem_b.item_name    
       , groupitem_b.uom          
       , groupitem_a.uom          
       , routtempnew.uom          
       , routtempnew.division     
       , routtempnew.operation    
       , routtempnew.item_color   
       , routtempnew.area_no      
       , customer.cust_name       
       , scene.scene_desc         
       , mpsdet.mpsorder_order    
       , mpsdet.order_seq  
       , mps.start_date
		 FROM routtempnew LEFT OUTER JOIN customer ON routtempnew.cust_no  = customer.cust_no
								    LEFT OUTER JOIN SCENE ON  routtempnew.scene_code = scene.scene_code
								    LEFT OUTER JOIN groupitem groupitem_b on  routtempnew.item_no  = groupitem_b.item_no 
								    LEFT OUTER JOIN groupitem groupitem_a on  routtempnew.assy_item  = groupitem_a.item_no 
			 , mpsdet                  
			 , mps                     
   WHERE   ( routtempnew.division          = mpsdet.division     )  
     AND ( routtempnew.sale_no         = mpsdet.sale_no      )  
     AND ( routtempnew.seq_no          = mpsdet.seq_no       )  
     AND ( routtempnew.wc_no           = mpsdet.wc_no        )  
     AND ( routtempnew.operation       = mpsdet.operation        )  
     AND ( routtempnew.assy_item      = mpsdet.item_no      )  
     AND ( routtempnew.assy_qa         = mpsdet.qa           )  
     AND ( mpsdet.order_no             = mps.order_no        )  
     AND ( routtempnew.area_no         = mps.area_no         )  
     AND ( ( routtempnew.wc_no         = :arg_wc  ) AND  
			( routtempnew.plan_flag     = 'Y'      ) AND  
			( routtempnew.process_flag <> 'E'      ) AND  
			( mps.open_close            = 'P'      ) AND  
			( routtempnew.work_date    >= DATEadd(year, -1 ,getdate()) ) AND  
			( mps.order_date           >= DATEadd(year, -1 ,getdate()) ) AND  
			( routtempnew.area_no       = :as_area ) 
              )
" arguments=(("arg_wc", string),("as_area", string))  sort="mpsorder_order A order_seq A sale_no A seq_no A " )
