table(column=(type=char(1) updatewhereclause=yes name=chk dbname="CHK" values="	Y/	N" )
 column=(type=decimal(0) update=yes updatewhereclause=yes key=yes identity=yes name=id dbname="CODEMST.ID" )
 column=(type=char(20) update=yes updatewhereclause=yes name=item_cd dbname="CODEMST.ITEM_CD" )
 column=(type=char(50) update=yes updatewhereclause=yes name=item_nm dbname="CODEMST.ITEM_NM" )
 column=(type=char(10) update=yes updatewhereclause=yes name=category dbname="CATEGORY" values="데이터	DATA/메뉴	MENU/기준일	DATE/권한	AUTH/" )
 column=(type=long update=yes updatewhereclause=yes name=sort dbname="CODEMST.SORT" )
 column=(type=char(50) update=yes updatewhereclause=yes name=type dbname="CODEMST.TYPE" )
 column=(type=char(1) update=yes updatewhereclause=yes name=use_yn dbname="CODEMST.USE_YN" values="사용	Y/불가	N/" )
 column=(type=char(100) update=yes updatewhereclause=yes name=bigo dbname="CODEMST.BIGO" )
 column=(type=char(1) update=yes updatewhereclause=yes name=prt_yn dbname="CODEMST.PRT_YN" initial="N" values="	Y/	N" )
 retrieve="SELECT 
	 CHK = 'N'
	,ID
	,ITEM_CD
	,ITEM_NM
	,CATEGORY = isnull(CATEGORY,'')
	,SORT
	,TYPE
	,USE_YN
	,BIGO 
	,PRT_YN
FROM 
	CODEMST
WHERE 
	USE_YN   like :ag_use
AND 
	item_cd  like :ag_itemcd
AND 
	type     like :ag_type
" update="CODEMST" updatewhere=0 updatekeyinplace=no arguments=(("ag_use", string),("ag_itemcd", string),("ag_type", string))  sort="id D " )
