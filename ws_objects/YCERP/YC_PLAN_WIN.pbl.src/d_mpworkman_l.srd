 column=(type=char(2) updatewhereclause=yes name=team_cd dbname="V_INSABASE.team_cd" )
 column=(type=char(20) updatewhereclause=yes name=team_nm dbname="V_INSABASE.team_nm" )
 column=(type=char(3) updatewhereclause=yes name=jik_cd dbname="V_INSABASE.jik_cd" )
 column=(type=char(20) updatewhereclause=yes name=jik_nm dbname="V_INSABASE.jik_nm" )
 column=(type=char(4) updatewhereclause=yes name=foreign_gb dbname="V_INSABASE.foreign_gb" )
 column=(type=char(2) updatewhereclause=yes name=sex dbname="V_INSABASE.sex" )
 retrieve="  SELECT chk      = 'N'
       , acc_cd
       , acc_nm
       , user_id  = sabun
       , name_kor
       , dept_cd
       , dept_nm
       , team_cd
       , team_nm
       , jik_cd
       , jik_nm
       , foreign_gb
       , sex
    FROM V_INSABASE
   WHERE acc_cd = :as_area
   ORDER BY dept_cd, team_cd, jik_cd, sabun
" arguments=(("as_area", string))  sort="dept_nm A team_nm A jik_cd A jik_nm A name_kor A " )
