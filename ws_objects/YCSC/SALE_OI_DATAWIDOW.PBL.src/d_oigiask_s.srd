$PBExportHeader$d_oigiask_s.srd
$PBExportComments$물품요청번호조회(1998/10/20,성삼지)
release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=72 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=char(12) update=yes updatewhereclause=yes key=yes name=ask_no dbname="ask_head.ask_no" )
 column=(type=datetime update=yes updatewhereclause=yes name=ask_date dbname="ask_head.ask_date" )
 column=(type=char(1) updatewhereclause=yes name=proc_flag dbname="proc_flag" values="완료	Y/요청중	N/부분	P/" )
 column=(type=char(10) updatewhereclause=yes name=ask_user dbname="ask_user" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 retrieve="  SELECT ask_head.ask_no     
       , ask_head.ask_date   
       , ask_head.proc_flag  /* Y(완료), N(요청중), P(부문) */
       , ask_head.ask_user
       , login.user_name
    FROM ask_head  
         LEFT OUTER JOIN login  ON ask_head.ask_user = login.user_id
   WHERE ( convert(char(10),ask_head.ask_date,111)  between :as_sdate and :as_edate ) 
     AND ( ask_head.t_area         = :as_area )   
   ORDER BY ask_head.ask_date desc,   
            ask_head.ask_no   asc   
" update="ask_head" updatewhere=1 updatekeyinplace=no arguments=(("as_sdate", string),("as_edate", string),("as_area", string)) )
