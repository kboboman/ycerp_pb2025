release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=80 color="536870912" )
summary(height=100 color="15780518" )
footer(height=72 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=cwc dbname="cwc" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(10) updatewhereclause=yes name=coilsliting_item_no dbname="coilsliting.item_no" )
 column=(type=char(2) updatewhereclause=yes name=as_flag dbname="as_flag" )
 column=(type=decimal(4) updatewhereclause=yes name=sum_qty dbname="sum_qty" )
 column=(type=datetime updatewhereclause=yes name=start_date dbname="start_date" )
 column=(type=datetime updatewhereclause=yes name=end_date dbname="end_date" )
 retrieve="  SELECT cwc        = ( case when coilorder.wc_no = 'NO' then '외주' else '사내' end )
       , groupitem.item_name                                   
       , coilsliting.item_no                                
       , as_flag    = substring(coilsliting.item_no,3,1)       
       , sum_qty    = sum(coilsliting.unit_qty)             
       , start_date = convert(smalldatetime, :ad_start, 111)   
       , end_date   = convert(smalldatetime, :ad_end,   111)
    FROM coilorder      
       , coilorderdet   
       , coilsliting    
       , groupitem 
   WHERE ( coilorder.order_no           = coilorderdet.coilorder_order ) 
     AND ( coilorderdet.order_no        = coilsliting.order_no         )   
     AND ( coilsliting.item_no          = groupitem.item_no            )   
     AND ( coilsliting.sheet            = 'L'                          )   
     AND ( coilorder.order_date   BETWEEN :ad_start AND :ad_end        )
   GROUP BY ( case when coilorder.wc_no = 'NO' then '외주' else '사내' end )
          , groupitem.item_name   
          , coilsliting.item_no
          , substring(coilsliting.item_no,3,1)
" arguments=(("ad_start", date),("ad_end", date)) )
