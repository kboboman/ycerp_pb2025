$PBExportHeader$d_orsaledet_row.srd
$PBExportComments$출고집계(수주일)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=cat dbname="cat" )
 column=(type=char(50) updatewhereclause=yes name=category dbname="category" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(10) updatewhereclause=yes name=gtype dbname="gtype" )
 column=(type=char(10) updatewhereclause=yes name=order_date dbname="order_date" )
 column=(type=char(10) updatewhereclause=yes name=due_date dbname="due_date" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=decimal(2) updatewhereclause=yes name=cqty dbname="cqty" )
 column=(type=decimal(6) updatewhereclause=yes name=cprice dbname="cprice" )
 retrieve="  SELECT cat          = a.category
       , category     = cm.item_nm   
       , cust_name    = a.cust_name  
       , gtype        = a.gtype
       , order_date   = a.order_date
       , due_date     = a.due_date
       , item_no      = a.item_no    
       , item_name    = a.item_name  
       , cqty         = a.cqty       
       , cprice       = a.cprice
    FROM (
         SELECT category     = isnull(i.category, 'TOP1999')
              , gtype        = i.type
              , cust_name    = d.cust_name   
              , order_date   = (case when :as_yymm = 'Y' then convert(char(10),dateadd(day, - day(b.order_date)+1,b.order_date),111)
                                     else convert(char(10),b.order_date,111)
                                end)
              , due_date     = (case when :as_yymm = 'Y' then convert(char(10),dateadd(day, - day(b.due_date)+1,b.due_date),111)
                                     else convert(char(10),b.due_date,111)
                                end)
              , item_no      = a.item_no
              , item_name    = g.item_name
              , cqty         = a.acc_qty           /*dbo.uf_getqty(a.item_no, a.qa, a.uom, a.order_qty)*/
              , cprice       = a.price * a.acc_qty /*dbo.uf_getqty(a.item_no, a.qa, a.uom, a.order_qty) * a.price*/
           FROM saledet   A
                LEFT OUTER JOIN sale      B ON a.order_no  = b.order_no
                LEFT OUTER JOIN customer  D ON b.cust_no   = d.cust_no
                LEFT OUTER JOIN groupitem G ON a.item_no   = g.item_no
                LEFT OUTER JOIN itemtop10 I ON a.item_no   = i.item_no  
          WHERE ( b.order_date BETWEEN :as_sdate AND :as_edate )
            AND ((:as_area     = '%' and b.area_no  LIKE :as_area) OR
                 (:as_area    <> '%' and b.area_no     = :as_area)
                )
            AND ((:as_openclose  = 'Y'   AND b.open_close LIKE '%') OR
/*                 (:as_openclose <> 'Y'   AND b.open_close  NOT IN ('X','C')) 한도초과	*/
                   (:as_openclose <> 'Y'   AND b.open_close  = 'O')
                )           
            AND ((:as_inside   = '%' ) OR
                 (:as_inside  <> '%' and b.cust_no NOT IN (SELECT cust_no FROM V_CUST_INSIDE))
                )
         ) A
         LEFT OUTER JOIN (
              SELECT item_cd, item_nm FROM codemst with (nolock) WHERE type = 'ITEMTOP10' AND use_yn = 'Y'
         ) cm ON a.category = cm.item_cd
     WHERE ( (:as_itemtop10  = '%' AND a.category LIKE '%'           ) OR
             (:as_itemtop10 <> '%' AND a.category    = :as_itemtop10 )
           )" arguments=(("as_area", string),("as_sdate", string),("as_edate", string),("as_yymm", string),("as_itemtop10", string),("as_openclose", string),("as_inside", string))  sort="category A gtype A cust_name A " )
