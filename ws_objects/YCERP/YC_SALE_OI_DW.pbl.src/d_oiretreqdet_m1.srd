table(column=(type=char(14) update=yes updatewhereclause=yes key=yes name=ret_no dbname="retdet.ret_no" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=ret_seq dbname="retdet.ret_seq" )
 column=(type=char(14) update=yes updatewhereclause=yes name=sale_no dbname="retdet.sale_no" )
 column=(type=long update=yes updatewhereclause=yes name=seq_no dbname="retdet.seq_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="retdet.item_no" )
 column=(type=char(4) update=yes updatewhereclause=yes name=color dbname="retdet.color" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="retdet.qa" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="retdet.uom" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=ret_qty dbname="retdet.ret_qty" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=acc_qty dbname="retdet.acc_qty" )
 column=(type=char(1) update=yes updatewhereclause=yes name=acc_degree dbname="retdet.acc_degree" )
 column=(type=char(40) update=yes updatewhereclause=yes name=decision_desc dbname="retdet.decision_desc" )
 column=(type=char(40) update=yes updatewhereclause=yes name=rem dbname="retdet.rem" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_rlse_qty dbname="saledet.rlse_qty" )
 retrieve="  SELECT retdet.ret_no,   
         retdet.ret_seq,   
         retdet.sale_no,   
         retdet.seq_no,   
         retdet.item_no,   
         retdet.color,   
         retdet.qa,   
         retdet.uom,   
         retdet.ret_qty,   
         retdet.acc_qty,   
         retdet.acc_degree,   
         retdet.decision_desc,   
         retdet.rem,   
         groupitem.item_name,   
         saledet.rlse_qty  
    FROM retdet,   
         groupitem,   
         saledet  
   WHERE ( retdet.item_no = groupitem.item_no ) and  
         ( retdet.sale_no = saledet.order_no  ) and  
         ( retdet.seq_no  = saledet.seq_no    ) and  
         ( retdet.ret_no  = :as_order_no      )    
" update="retdet" updatewhere=0 updatekeyinplace=no arguments=(("as_order_no", string)) )
