$PBExportHeader$d_oidcgroup_check.srd
$PBExportComments$매출할인 금액과 출고금액 체크
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=88 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=cat dbname="cat" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(14) updatewhereclause=yes name=do_no dbname="do_no" )
 column=(type=decimal(4) updatewhereclause=yes name=do_total dbname="do_total" )
 column=(type=char(10) updatewhereclause=yes name=do_date dbname="do_date" )
 column=(type=char(14) updatewhereclause=yes name=dc_groupno dbname="dc_groupno" )
 retrieve="   SELECT a.cat
        , a.cust_no
        , a.cust_name
        , a.do_no
        , a.do_total
        , do_date = convert(char(10),a.do_date,111)
        , a.dc_groupno
     FROM (
          SELECT CAT='출고',do.cust_no, c.cust_name, do.do_no, do.do_total, do.do_date, dc_groupno = do.invoice_print
            FROM do 
                 LEFT OUTER JOIN customer    c ON do.cust_no    = c.cust_no
           WHERE do.do_date BETWEEN :as_sdate and :as_edate AND DO.rem LIKE '매출할인_결재%'
          
          UNION ALL
          
          SELECT CAT='할인',a.cust_no, c.cust_name, DC_DO_NO = b.do_no, price = round(b.price * 1.1, 0), a.dc_appdt5, a.dc_groupno
            FROM dc_group a 
                 LEFT OUTER JOIN dc_groupdet b ON a.dc_groupno = b.dc_groupno
                 LEFT OUTER JOIN customer    c ON a.cust_no    = c.cust_no
           WHERE a.dc_appdt5 is not null
             AND a.dc_date   BETWEEN :as_sdate and :as_edate
          ) A
    ORDER BY cust_name, do_no, cat
    " arguments=(("as_sdate", string),("as_edate", string)) )
