release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=836 color="536870912" )
summary(height=96 color="536870912" )
footer(height=0 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=groupitem_item_no dbname="GroupItem.item_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=decimal(2) updatewhereclause=yes name=inspdet_rcpt_qty dbname="inspdet.rcpt_qty" )
 column=(type=char(2) updatewhereclause=yes name=inspdet_uom dbname="inspdet.uom" )
 column=(type=decimal(4) updatewhereclause=yes name=inspdet_price dbname="inspdet.price" )
 column=(type=decimal(6) updatewhereclause=yes name=ship_amount dbname="ship_amount" )
 column=(type=decimal(4) updatewhereclause=yes name=insp_cash dbname="insp.insp_cash" )
 column=(type=long updatewhereclause=yes name=inspdet_seq_no dbname="inspdet.seq_no" )
 column=(type=char(10) updatewhereclause=yes name=pur_order_no dbname="pur.order_no" )
 column=(type=datetime updatewhereclause=yes name=pur_order_date dbname="pur.order_DATE" )
 column=(type=char(10) updatewhereclause=yes name=inspdet_loc_no dbname="inspdet.loc_no" )
 column=(type=char(20) updatewhereclause=yes name=inspdet_qa dbname="inspdet.qa" )
 column=(type=long updatewhereclause=yes name=inspdet_cnt dbname="inspdet.cnt" )
 column=(type=decimal(4) updatewhereclause=yes name=inspdet_comqty dbname="inspdet.comqty" )
 column=(type=long updatewhereclause=yes name=inspdet_oi_no dbname="inspdet.oi_no" )
 column=(type=char(14) updatewhereclause=yes name=inspdet_insp_no dbname="inspdet.insp_no" )
 column=(type=datetime updatewhereclause=yes name=insp_insp_date dbname="insp.insp_date" )
 column=(type=char(30) updatewhereclause=yes name=supp_supp_name dbname="supp.supp_name" )
 column=(type=char(10) updatewhereclause=yes name=purdet_order_no dbname="purdet.order_no" )
 column=(type=char(50) updatewhereclause=yes name=purdet_cust_name dbname="purdet.cust_name" )
 column=(type=datetime updatewhereclause=yes name=s dbname="s" )
 column=(type=datetime updatewhereclause=yes name=e dbname="e" )
 column=(type=datetime updatewhereclause=yes name=insp_log_date dbname="insp.log_date" )
 column=(type=char(2) updatewhereclause=yes name=purdet_com_uom dbname="com_uom" )
 column=(type=char(1) updatewhereclause=yes name=supp_round dbname="supp.round" )
 column=(type=char(2) updatewhereclause=yes name=coilmst_etc_no dbname="coilmst.etc_no" )
 column=(type=char(20) updatewhereclause=yes name=etc_name dbname="etc_name" )
 column=(type=char(14) updatewhereclause=yes name=purdet_sale_no dbname="purdet.sale_no" )
 column=(type=decimal(4) updatewhereclause=yes name=amount dbname="amount" )
 column=(type=decimal(8) updatewhereclause=yes name=camt dbname="camt" )
 retrieve="  SELECT groupitem.item_no     
       , groupitem.item_name   
       , inspdet.rcpt_qty      
       , inspdet.uom           
       , inspdet.price         
       , ship_amount = b.ship_amount
       , insp.insp_cash
       , inspdet.seq_no        
       , pur.order_no          
       , pur.order_DATE        
       , inspdet.loc_no        
       , inspdet.qa            
       , inspdet.cnt           
       , inspdet.comqty        
       , inspdet.oi_no         
       , inspdet.insp_no       
       , insp.insp_date        
       , supp.supp_name     
       , purdet.order_no       
       , purdet.cust_name      
       , s        = convert(smalldatetime, :ad_date1, 111)   
       , e        = convert(smalldatetime, :ad_date2, 111)   
       , insp.log_date               
       , com_uom  = inspdet.com_uom
       , supp.round               
       , coilmst.etc_no
       , etc_name = (case when insp.ship_flag = 'D' AND insp.ship_amount > 0 then inspdet.insp_no
                          else (SELECT coiletc.etc_name FROM coiletc WHERE etc_no = coilmst.etc_no)
                     end)
       , purdet.sale_no
       , isnull(supplier.amount,0) amount
       , camt  = isnull((case when supp.round = 'Y' then ROUND(inspdet.comqty * inspdet.price, 0, 0) 
                                 else ROUND(inspdet.comqty * inspdet.price, 0, 1) 
                            end), 0)
FROM  
         inspdet with(nolock) inner join insp with(nolock) on  inspdet.insp_no = insp.insp_no
                                             inner join groupitem  with(nolock) on inspdet.item_no = groupitem.item_no
                                             inner join purdet with(nolock) on inspdet.pur_no  = purdet.order_no  and  inspdet.seq_no = purdet.seq_no
                                             inner join pur with(nolock) on inspdet.pur_no = pur.order_no
                                             inner join supp with(nolock) on insp.supp_no  = supp.supp_no
                                             left outer join coilmst  with(nolock) on inspdet.coil_no = coilmst.coil_no AND inspdet.loc_no = coilmst.loc_no
                                             left outer join (
                                                                             SELECT insp_no     = a.insp_no
                                                                                  , oi_no       = min(a.oi_no)
                                                                                  , ship_amount = avg(a.ship_amount)
                                                                               FROM (
                                                                                                SELECT inspdet.insp_no
                                                                                                     , inspdet.oi_no
                                                                                                     , ship_amount = insp.ship_amount
                                                                                                  FROM inspdet with(nolock) inner join insp with(nolock) on insp.insp_no  = inspdet.insp_no                                                                                                 
                                                                                                  where ( insp.insp_date     BETWEEN :ad_date1 AND :ad_date2 )
                                                                                             ) A
                                                                               GROUP BY a.insp_no
                                                                        ) B on inspdet.insp_no = b.insp_no AND inspdet.oi_no = b.oi_no
                                            left outer join supplier with(nolock) on insp.supp_no = supplier.supp_no and inspdet.item_no = supplier.item_no and inspdet.qa = supplier.qa
     WHERE ( insp.insp_date     BETWEEN :ad_date1 AND :ad_date2  )
          AND ( ( :as_supp  = '%'      AND insp.supp_no   LIKE :as_supp ) or
                      ( :as_supp <> '%'      AND insp.supp_no      = :as_supp )
                    )
          AND ( ( :as_area  = 'S'      AND inspdet.pur_no LIKE 'PUR%'   ) or
                      ( :as_area  = '%'      AND insp.area_no   LIKE '%'      ) or
                      ( inspdet.pur_no      LIKE :as_area + '%'               ) 
                   ) 
          AND ( (:as_category  = '%'   AND insp.insp_flag  LIKE :as_category ) OR
                      (:as_category <> '%'   AND insp.insp_flag  LIKE :as_category )
                    )
   ORDER BY purdet.cust_name, inspdet.insp_no       
/*       
    FROM groupitem   
       , inspdet     
       , insp        
       , purdet   
       , pur      
       , supp     
       , coilmst       
       , (
               SELECT insp_no     = a.insp_no
                    , oi_no       = min(a.oi_no)
                    , ship_amount = avg(a.ship_amount)
                 FROM (
                      SELECT inspdet.insp_no
                           , inspdet.oi_no
                           , ship_amount = insp.ship_amount
                        FROM inspdet     
                           , insp        
                       WHERE ( insp.insp_no             = inspdet.insp_no )   
                         AND ( insp.insp_date     BETWEEN :ad_date1 AND :ad_date2 )
                     ) A
                 GROUP BY a.insp_no
          ) B 
   WHERE ( groupitem.item_no        = inspdet.item_no )   
     AND ( insp.insp_no             = inspdet.insp_no )   
     AND ( inspdet.pur_no           = purdet.order_no )   
     AND ( inspdet.seq_no           = purdet.seq_no   )   
     AND ( pur.order_no             = inspdet.pur_no  )   
     AND ( insp.supp_no             = supp.supp_no    )   
     AND ( inspdet.insp_no *= b.insp_no AND inspdet.oi_no *= b.oi_no)
     AND ((inspdet.coil_no *= coilmst.coil_no) AND (inspdet.loc_no *= coilmst.loc_no))
     AND ( insp.insp_date     BETWEEN :ad_date1 AND :ad_date2  )
     AND ( ( :as_supp  = '%'      AND insp.supp_no   LIKE :as_supp ) or
           ( :as_supp <> '%'      AND insp.supp_no      = :as_supp )
         )
     AND ( ( :as_area  = 'S'      AND inspdet.pur_no LIKE 'PUR%'   ) or
           ( :as_area  = '%'      AND insp.area_no   LIKE '%'      ) or
           ( inspdet.pur_no      LIKE :as_area + '%'               ) 
         ) 
     AND ( (:as_category  = '%'   AND insp.insp_flag  LIKE :as_category ) OR
           (:as_category <> '%'   AND insp.insp_flag  LIKE :as_category )
         )
   ORDER BY purdet.cust_name, inspdet.insp_no
*/" arguments=(("as_supp", string),("ad_date1", date),("ad_date2", date),("as_area", string),("as_category", string))  sort="supp_supp_name A groupitem_item_name A inspdet_qa A pur_order_no A inspdet_seq_no A " )
