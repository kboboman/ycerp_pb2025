event clicked;if row < 1 then return
this.SelectRow(0,  false)
this.SelectRow(row, true)

string ls_item, ls_qa, ls_value
long   ll_row
choose case dwo.name
	case "b_qoh"	// 이월수량
		
	case "in_qty"	// 입고
	case "out_qty"	// 출고		
end choose

ls_item = this.object.item_no[row]
