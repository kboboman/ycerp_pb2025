table(column=(type=char(10) updatewhereclause=yes name=user_name dbname="login.user_name" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="do.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=char(11) updatewhereclause=yes name=do_spot_code dbname="do.spot_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene.scene_desc" )
 column=(type=datetime updatewhereclause=yes name=do_do_date dbname="do.do_date" )
 column=(type=char(10) updatewhereclause=yes name=do_fob dbname="do.fob" )
 column=(type=char(30) updatewhereclause=yes name=do_ship_flag dbname="ship_flag" )
 column=(type=char(1) updatewhereclause=yes name=ship_flag2 dbname="ship_flag2" )
 column=(type=decimal(0) updatewhereclause=yes name=do_ship_amount dbname="do.ship_amount" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_rate dbname="do.do_rate" )
 column=(type=char(3) updatewhereclause=yes name=do_curr_code dbname="do.curr_code" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_cash dbname="do.do_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_total dbname="do.do_total" )
 column=(type=char(1) updatewhereclause=yes name=do_shipamt_case dbname="do.shipamt_case" )
 column=(type=char(14) updatewhereclause=yes name=do_do_no dbname="do.do_no" )
 column=(type=long updatewhereclause=yes name=dodet_oi_no dbname="dodet.oi_no" )
 column=(type=char(10) updatewhereclause=yes name=dodet_item_no dbname="dodet.item_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(20) updatewhereclause=yes name=dodet_qa dbname="dodet.qa" )
 column=(type=char(2) updatewhereclause=yes name=dodet_uom dbname="dodet.uom" )
 column=(type=decimal(2) updatewhereclause=yes name=dodet_ship_qty dbname="dodet.ship_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=dodet_price dbname="dodet.price" )
 column=(type=decimal(4) updatewhereclause=yes name=dodet_rate_cash dbname="dodet.rate_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=c_acc_qty dbname="c_acc_qty" )
 column=(type=char(15) updatewhereclause=yes name=customer_bus_tel dbname="customer.bus_tel" )
 column=(type=char(15) updatewhereclause=yes name=customer_tel_no dbname="customer.tel_no" )
 column=(type=char(1) updatewhereclause=yes name=round dbname="customer.round" )
 column=(type=char(14) updatewhereclause=yes name=dodet_sale_no dbname="dodet.sale_no" )
 column=(type=datetime updatewhereclause=yes name=do_prt_date dbname="do.prt_date" )
 retrieve="  SELECT login.user_name
       , do.cust_no        
       , customer.cust_name   
       , do.spot_code   
       , scene.scene_desc   
       , do.do_date     
       , do.fob         
       , ship_flag  = dbo.uf_getshipflag(do.ship_flag)
       , ship_flag2 = do.ship_flag
       , do.ship_amount
       , do.do_rate        
       , do.curr_code      
       , do.do_cash        
       , do.do_total       
       , do.shipamt_case   
       , do.do_no       
       , dodet.oi_no     
       , dodet.item_no   
       , groupitem.item_name
       , dodet.qa    
       , dodet.uom   
       , dodet.ship_qty   
       , dodet.price   
       , dodet.rate_cash
       , c_acc_qty = round(dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty),2,1)
       , customer.bus_tel   
       , customer.tel_no   
       , customer.round
       , dodet.sale_no
       , do.prt_date
    FROM dodet      
         LEFT OUTER JOIN do        ON dodet.do_no = do.do_no
         LEFT OUTER JOIN groupitem ON dodet.item_no = groupitem.item_no
         LEFT OUTER JOIN customer  ON do.cust_no  = customer.cust_no
         LEFT OUTER JOIN scene     ON do.spot_code = scene.scene_code
         LEFT OUTER JOIN login     ON customer.salesman = login.user_id
   WHERE ( do.do_date     between :ad_sdate and :ad_edate )
	  AND ( do.do_no          like :as_area          )
     AND ( customer.salesman like :as_salesman      )
" arguments=(("as_area", string),("ad_sdate", date),("ad_edate", date),("as_salesman", string))  sort="cust_name A do_do_no A do_spot_code A do_do_date A dodet_oi_no A " )
group(level=1 header.height=0 trailer.height=72 by=("cust_name" ) header.color="553648127" trailer.color="536870912" )
group(level=2 header.height=0 trailer.height=72 by=("do_do_no" ) header.color="536870912" trailer.color="536870912" )
