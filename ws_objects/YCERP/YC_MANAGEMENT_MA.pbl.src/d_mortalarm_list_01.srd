detail(height=92 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(10) updatewhereclause=yes name=salesman dbname="salesman" )
 column=(type=char(50) updatewhereclause=yes name=dambo_rem dbname="dambo_rem" )
 column=(type=decimal(0) updatewhereclause=yes name=dambo_amt dbname="dambo_amt" )
 column=(type=decimal(2) updatewhereclause=yes name=amount dbname="amount" )
 column=(type=datetime updatewhereclause=yes name=dambo_ymd dbname="dambo_ymd" )
 column=(type=char(50) updatewhereclause=yes name=dambo_value dbname="dambo_value" )
 column=(type=char(100) update=yes updatewhereclause=yes name=remark dbname="remark" )
 column=(type=char(1) update=yes updatewhereclause=yes name=use_yn dbname="use_yn" values="	Y/	N" )
 retrieve="select 
	 a.cust_no		cust_no
	,b.cust_name	cust_name
	,(select user_name from login where user_id = b.salesman) salesman
	,b.dambo_rem	dambo_rem
	,b.dambo_amt	dambo_amt
	,c.amount		amount
	,b.dambo_ymd	dambo_ymd
	,b.dambo_value	dambo_value
	,a.remark		remark
	,a.use_yn		use_yn
from
	mortalarm_list a	
		inner join customer b on a.cust_no = b.cust_no
		inner join (
					select
						 cust_no
						,balbf_amount + inv_01 + inv_02 + inv_03 + inv_04 + inv_05 + inv_06 + inv_07 + inv_08 + inv_09 + inv_10  + inv_11 + inv_12  - coll_01 - coll_02 - coll_03 - coll_04 - coll_05 - coll_06 - coll_07 - coll_08 - coll_09 - coll_10  - coll_11 - coll_12 as amount
					FROM 	
						opeom
					WHERE 
						datepart(year,opeom.eom_year)	= year(getdate())) c on a.cust_no = c.cust_no
order by
	b.dambo_value" update="mortalarm_list" updatewhere=0 updatekeyinplace=no )
