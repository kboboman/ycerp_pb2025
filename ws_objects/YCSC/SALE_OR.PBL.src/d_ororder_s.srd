$PBExportHeader$d_ororder_s.srd
$PBExportComments$판매수주관리 수주번호선택(1998/04/02, 정재수)
release 8;
datawindow(units=0 timer_interval=0 color=79219928 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=72 color="536870912" )
summary(height=0 color="536870912" )
footer(height=64 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=order_no dbname="sale.ORDER_NO" initial=" " )
 column=(type=char(10) updatewhereclause=yes name=due_date dbname="DUE_DATE" initial=" " )
 column=(type=char(10) updatewhereclause=yes name=order_date dbname="ORDER_DATE" initial=" " )
 column=(type=char(40) updatewhereclause=yes name=scene_name dbname="SCENE_NAME" )
 column=(type=decimal(2) updatewhereclause=yes name=order_qty dbname="ORDER_QTY" )
 column=(type=decimal(2) updatewhereclause=yes name=rlse_qty dbname="RLSE_QTY" )
 retrieve="  SELECT SALE.ORDER_NO   
       , DUE_DATE   = convert(char(10),SALE.DUE_DATE  ,111) 
       , ORDER_DATE = convert(char(10),SALE.ORDER_DATE,111)
       , SCENE_NAME = SCENE.SCENE_DESC
       , ORDER_QTY  = (SELECT SUM(order_qty) FROM saledet WHERE order_no = sale.order_no)
       , RLSE_QTY   = (SELECT SUM(rlse_qty)  FROM saledet WHERE order_no = sale.order_no)
    FROM SALE
       , SCENE         
   WHERE ( SALE.CUST_NO  = SCENE.CUST_NO AND SALE.SCENE_CODE = SCENE.SCENE_CODE )
     AND ( SALE.CUST_NO           = :as_custno ) 
     AND ( convert(char(10),SALE.ORDER_DATE,111) BETWEEN :as_sdate AND :as_edate )   
   ORDER BY SALE.ORDER_DATE DESC   
" arguments=(("as_custno", string),("as_sdate", string),("as_edate", string))  sort="order_no D " )
