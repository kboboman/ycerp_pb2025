$PBExportHeader$d_mpslitcon_r.srd
$PBExportComments$스리팅작업지시서(2000/7/28, 이인호)
release 8;
datawindow(units=0 timer_interval=60000 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=580 color="536870912" )
summary(height=120 color="553648127" )
footer(height=488 color="536870912" )
detail(height=120 color="553648127" )
table(column=(type=long updatewhereclause=yes name=coilsliting_seq dbname="coilsliting.seq" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(20) updatewhereclause=yes name=coilmst_qa dbname="coilmst.qa" )
 column=(type=char(2) updatewhereclause=yes name=groupitem_uom dbname="GroupItem.uom" )
 column=(type=long updatewhereclause=yes name=coilmst_unit_qty dbname="coilmst.unit_qty" )
 column=(type=long updatewhereclause=yes name=coilsliting_cnt dbname="coilsliting.cnt" )
 column=(type=decimal(4) updatewhereclause=yes name=coilsliting_unit_qty dbname="coilsliting.unit_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=coilsliting_length dbname="coilsliting.length" )
 column=(type=char(30) updatewhereclause=yes name=coilsliting_rem dbname="coilsliting.rem" )
 column=(type=char(20) updatewhereclause=yes name=coilsliting_coil_no dbname="coilsliting.coil_no" )
 column=(type=char(1) updatewhereclause=yes name=sheet dbname="coilsliting.sheet" )
 column=(type=char(30) updatewhereclause=yes name=supp_supp_name dbname="supp.supp_name" )
 column=(type=long updatewhereclause=yes name=coilorderdet_order_seq dbname="coilorderdet.order_seq" )
 column=(type=char(20) updatewhereclause=yes name=coilsliting_qa dbname="coilsliting.qa" )
 column=(type=long updatewhereclause=yes name=coilorderdet_div dbname="coilorderdet.div" initial="0" values="2등분	2/3등분	3/4등분	4/5등분	5/" )
 column=(type=char(10) updatewhereclause=yes name=wc_work_name dbname="wc.work_name" )
 column=(type=datetime updatewhereclause=yes name=coilorder_order_date dbname="coilorder.order_date" )
 column=(type=long updatewhereclause=yes name=coilorderdet_tot_qty dbname="coilorderdet.tot_qty" )
 column=(type=char(80) updatewhereclause=yes name=summary dbname="summary" )
 column=(type=char(1) updatewhereclause=yes name=coilorderdet_work_type dbname="coilorderdet.work_type" )
 retrieve="  SELECT distinct coilsliting.seq,   
         groupitem.item_name,   
         coilmst.qa,   
         groupitem.uom,   
         coilmst.unit_qty,   
         coilsliting.cnt,   
         coilsliting.unit_qty,   
         coilsliting.length,   
         coilsliting.rem,   
         coilsliting.coil_no,   
         coilsliting.sheet,   
         supp.supp_name,   
         coilorderdet.order_seq,   
         coilsliting.qa,   
         coilorderdet.div,   
         wc.work_name,   
         coilorder.order_date,
         coilorderdet.tot_qty, 
			summary = dbo.uf_getcoilunitqty(coilorderdet.order_no, coilorderdet.work_type),
			coilorderdet.work_type
   FROM coilorder inner join coilorderdet on coilorder.order_no = coilorderdet.coilorder_order
                              left outer join coilsliting on coilorderdet.order_no = coilsliting.order_no
                              inner join coilmst on coilorderdet.coil_no = coilmst.coil_no and coilorderdet.loc_no = coilmst.loc_no
                              inner join groupitem on coilmst.item_no = groupitem.item_no
                              left outer join supp on coilorder.supp_no = supp.supp_no
                              left outer join wc  on coilorder.wc_no = wc.work_no
   WHERE coilorder.order_no = :arg_orderno
/*
    FROM coilorder,   
         coilorderdet,   
         coilsliting,   
         coilmst,   
         groupitem,   
         supp,   
         wc  
   WHERE ( coilorder.wc_no *= wc.work_no) and  
         ( coilorder.supp_no *= supp.supp_no) and  
         ( coilorderdet.order_no = coilsliting.order_no ) and  
         ( coilorder.order_no = coilorderdet.coilorder_order ) and  
         ( ( coilorderdet.coil_no = coilmst.coil_no ) and  
         	( ( coilorder.supp_no = coilmst.loc_no ) OR  
         	  ( coilorderdet.loc_no = coilmst.loc_no ) ) ) and  
         ( coilmst.item_no = groupitem.item_no ) and  
         ( ( coilorder.order_no = :arg_orderno ) )    
*/
" arguments=(("arg_orderno", string))  sort="coilorderdet_order_seq A coilsliting_seq A " )
