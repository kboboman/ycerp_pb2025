$PBExportHeader$d_apbitemtot_t6.srd
$PBExportComments$조업자재 집계표(원본)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 grid.columnmove=no selected.mouse=no )
header(height=84 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=part_name dbname="part_name" )
 column=(type=char(30) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_1 dbname="in_month_1" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_2 dbname="in_month_2" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_3 dbname="in_month_3" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_4 dbname="in_month_4" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_5 dbname="in_month_5" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_6 dbname="in_month_6" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_7 dbname="in_month_7" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_8 dbname="in_month_8" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_9 dbname="in_month_9" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_10 dbname="in_month_10" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_11 dbname="in_month_11" )
 column=(type=decimal(4) updatewhereclause=yes name=in_month_12 dbname="in_month_12" )
 column=(type=char(10) updatewhereclause=yes name=cstart dbname="cstart" )
 column=(type=char(10) updatewhereclause=yes name=cend dbname="cend" )
 column=(type=long updatewhereclause=yes name=ship_qty dbname="ship_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=c_qty dbname="c_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=c_amt dbname="c_amt" )
 column=(type=long updatewhereclause=yes name=cnt dbname="cnt" )
 column=(type=long updatewhereclause=yes name=sort dbname="sort" )
 column=(type=long updatewhereclause=yes name=sort2 dbname="sort2" )
 retrieve="SELECT part_name                       
     , item_name                       
     , in_month_1  = max(in_month_1)   
     , in_month_2  = max(in_month_2)   
     , in_month_3  = max(in_month_3)   
     , in_month_4  = max(in_month_4)   
     , in_month_5  = max(in_month_5)   
     , in_month_6  = max(in_month_6)   
     , in_month_7  = max(in_month_7)   
     , in_month_8  = max(in_month_8)   
     , in_month_9  = max(in_month_9)   
     , in_month_10 = max(in_month_10)  
     , in_month_11 = max(in_month_11)  
     , in_month_12 = max(in_month_12)  
     , cstart      = max(cstart)       
     , cend        = max(cend)         
     , ship_qty    = sum(ship_qty)     
     , c_qty       = sum(c_qty)        
     , c_amt       = sum(c_amt)        
     , cnt         = sum(cnt)          
     , sort        = max(sort)         
     , sort2       = max(sort2)        
  FROM (                                 
       SELECT part_name                  
            , item_name                  
            , in_month_1  = (case when in_month = 1  then sum(c_amt) else 0 end)
            , in_month_2  = (case when in_month = 2  then sum(c_amt) else 0 end)
            , in_month_3  = (case when in_month = 3  then sum(c_amt) else 0 end)
            , in_month_4  = (case when in_month = 4  then sum(c_amt) else 0 end)
            , in_month_5  = (case when in_month = 5  then sum(c_amt) else 0 end)
            , in_month_6  = (case when in_month = 6  then sum(c_amt) else 0 end)
            , in_month_7  = (case when in_month = 7  then sum(c_amt) else 0 end)
            , in_month_8  = (case when in_month = 8  then sum(c_amt) else 0 end)
            , in_month_9  = (case when in_month = 9  then sum(c_amt) else 0 end)
            , in_month_10 = (case when in_month = 10 then sum(c_amt) else 0 end)
            , in_month_11 = (case when in_month = 11 then sum(c_amt) else 0 end)
            , in_month_12 = (case when in_month = 12 then sum(c_amt) else 0 end)
            , cstart      = max(cstart)                                  
            , cend        = max(cend)                                    
            , ship_qty    = sum(ship_qty)                                
            , c_qty       = sum(c_qty)                                   
            , c_amt       = sum(c_amt)                                   
            , cnt         = sum(cnt)                                     
            , sort        = max(sort)                                    
            , sort2       = max(sort2)                                   
         FROM (                                                          
              SELECT d.part_name                                         
                   , item_name = b.item_name                                                                                 
                   , item_no   = a.item_no
                   , in_year   = year(a.in_date)                                                                             
                   , in_month  = month(a.in_date)                                                                            
                   , cstart    = (case when :as_start = ''  then '          ' else :as_start   end)                          
                   , cend      = (case when :as_end   = ''  then '          ' else :as_end     end)                          
                   , ship_qty  = isNULL(count(a.qa),0)                                                                       
                   , c_qty     = sum(isNULL(a.qty,0))                                                                        
                   , c_amt     = sum(isNULL(a.amount,0))                                                                     
                   , cnt       = isNULL(count(a.qa),0)                                                                       
                   , sort      = max(isnull(d.sort,999))
                   , sort2     = max(isnull(e.sort,999))
                FROM binitem A                                                                                               
                     LEFT OUTER JOIN bitem B ON a.item_no   = b.item_no                                                      
                     LEFT OUTER JOIN bsupp C ON a.supp_no   = c.supp_no                                                      
                     LEFT OUTER JOIN bpart D ON a.part_code = d.part_no                                                      
                     LEFT OUTER JOIN (
                          SELECT item_cd, sort FROM codemst WHERE type = '조업자재_대중분류' AND use_yn = 'Y'
                     ) E  ON b.catgroup = e.item_cd
               WHERE ( convert(char(10),a.in_date,111)  BETWEEN :as_start AND :as_end )                                      
                 AND ( a.supp_no           LIKE :as_supp      )                                                              
                 AND ( a.part_code         LIKE :as_part_code )                                                              
               GROUP BY d.part_name    
                      , a.in_date      
                      , a.supp_no      
                      , b.item_name    
                      , a.item_no      
                      , a.uom          
              ) TMP_01                 
          GROUP BY part_name           
                 , item_name           
                 , in_month            
       ) TMP_MAIN                      
  GROUP BY part_name                   
         , item_name                   
  ORDER BY sort, sort2                 

/*
SELECT part_name                       
     , item_name                       
     , in_month_1  = max(in_month_1)   
     , in_month_2  = max(in_month_2)   
     , in_month_3  = max(in_month_3)   
     , in_month_4  = max(in_month_4)   
     , in_month_5  = max(in_month_5)   
     , in_month_6  = max(in_month_6)   
     , in_month_7  = max(in_month_7)   
     , in_month_8  = max(in_month_8)   
     , in_month_9  = max(in_month_9)   
     , in_month_10 = max(in_month_10)  
     , in_month_11 = max(in_month_11)  
     , in_month_12 = max(in_month_12)  
     , cstart      = max(cstart)       
     , cend        = max(cend)         
     , ship_qty    = sum(ship_qty)     
     , c_qty       = sum(c_qty)        
     , c_amt       = sum(c_amt)        
     , cnt         = sum(cnt)          
     , sort        = max(sort)         
     , sort2       = max(sort2)        
  FROM (                                 
       SELECT part_name                  
            , item_name                  
            , in_month_1  = (case when in_month = 1  then sum(c_amt) end)
            , in_month_2  = (case when in_month = 2  then sum(c_amt) end)
            , in_month_3  = (case when in_month = 3  then sum(c_amt) end)
            , in_month_4  = (case when in_month = 4  then sum(c_amt) end)
            , in_month_5  = (case when in_month = 5  then sum(c_amt) end)
            , in_month_6  = (case when in_month = 6  then sum(c_amt) end)
            , in_month_7  = (case when in_month = 7  then sum(c_amt) end)
            , in_month_8  = (case when in_month = 8  then sum(c_amt) end)
            , in_month_9  = (case when in_month = 9  then sum(c_amt) end)
            , in_month_10 = (case when in_month = 10 then sum(c_amt) end)
            , in_month_11 = (case when in_month = 11 then sum(c_amt) end)
            , in_month_12 = (case when in_month = 12 then sum(c_amt) end)
            , cstart      = max(cstart)                                  
            , cend        = max(cend)                                    
            , ship_qty    = sum(ship_qty)                                
            , c_qty       = sum(c_qty)                                   
            , c_amt       = sum(c_amt)                                   
            , cnt         = sum(cnt)                                     
            , sort        = max(sort)                                    
            , sort2       = max(sort2)                                   
         FROM (                                                          
              SELECT d.part_name                                         
                   , item_name = (case when b.item_name like '%스티로폼%'             then '스티로폼'                        
                                       when b.item_name like '%베어링%'               then '베어링'                          
                                       when b.item_name like '%작업복%'               then '작업복'                          
                                       when b.item_name like '%안전화%'               then '안전화'                          
                                       when b.item_name like '%면장갑%'               then '면장갑'                          
                                       when b.item_name like '%면보루%'               then '면보루'                          
                                       when b.item_name like '%마대%'                 then '마대'                            
                                       when b.item_name like '%필라멘트테이프%'       then '필라멘트테이프'                  
                                       when b.item_name like '%OPP테이프%'            then 'OPP테이프'                       
                                       when b.item_name like '%보호필름%'             then '보호필름'                        
                                       when b.item_name like '%비닐%'                 then '비닐'                            
                                       when b.item_name like '%노루지%'               then '노루지'                          
                                       when b.item_name like '%공업용랩%'             then '공업용랩'                        
                                       when b.item_name like '%유압유%'               then '유압유'                          
                                       when b.item_name like '%수성본드%'             then '수성본드'                        
                                       when b.item_name like '%우레탄본드%'           then '우레탄본드'                      
                                       when b.item_name like '%PP밴드%'               then 'PP밴드'                          
                                       when a.supp_no = '230'                         then '포장BOX'                         
                                       when b.item_name like '%받침목%'               then '받침목'                          
                                       when b.item_name like '%소포제%' or b.item_name like '%탈지제%' then '소포,탈지제'    
                                       when b.item_name like '%절삭유%'               then '절삭유'                          
                                       when b.item_name like '%펀칭유%'               then '펀칭유'                          
                                       when b.item_name like '%철밴드%'               then '철밴드'                          
                                       else '기타'                                                                           
                                  end)                                                                                       
                   , item_no   = (case when a.supp_no = '230' then '999999' else a.item_no end)                              
                   , in_year   = year(a.in_date)                                                                             
                   , in_month  = month(a.in_date)                                                                            
                   , cstart    = (case when :as_start = ''  then '          ' else :as_start   end)                          
                   , cend      = (case when :as_end   = ''  then '          ' else :as_end     end)                          
                   , ship_qty  = isNULL(count(a.qa),0)                                                                       
                   , c_qty     = sum(isNULL(a.qty,0))                                                                        
                   , c_amt     = sum(isNULL(a.amount,0))                                                                     
                   , cnt       = isNULL(count(a.qa),0)                                                                       
                   , sort      = (case when d.part_name = '성형'      then 1                                                 
                                       when d.part_name = '스리타'    then 2                                                 
                                       when d.part_name = 'YSP'       then 3                                                 
                                       when d.part_name = '절곡'      then 4                                                 
                                       when d.part_name = '유압'      then 5                                                 
                                       when d.part_name = '도장'      then 6                                                 
                                       when d.part_name = '공무'      then 7                                                 
                                       when d.part_name = '금형'      then 8                                                 
                                       when d.part_name = '출고'      then 9                                                 
                                       when d.part_name = '사무실'    then 10                                                
                                       when d.part_name = '공용'      then 11                                                
                                       when d.part_name = '모듈러'    then 12                                                
                                       when d.part_name = '화성공장'  then 13                                                
                                       when d.part_name = '프레스'    then 14                                                
                                  end)                                                                                       
                   , sort2     = (case when b.item_name like '%스티로폼%'                  then 1                            
                                       when b.item_name like '%베어링%'                    then 2                            
                                       when b.item_name like '%작업복%'                    then 3                            
                                       when b.item_name like '%안전화%'                    then 4                            
                                       when b.item_name like '%면장갑%'                    then 5                            
                                       when b.item_name like '%면보루%'                    then 6                            
                                       when b.item_name like '%마대%'                      then 7                            
                                       when b.item_name like '%필라멘트테이프%'            then 8                            
                                       when b.item_name like '%OPP테이프%'                 then 9                            
                                       when b.item_name like '%보호필름%'                  then 10                           
                                       when b.item_name like '%비닐%'                      then 11                           
                                       when b.item_name like '%노루지%'                    then 12                           
                                       when b.item_name like '%공업용랩%'                  then 13                           
                                       when b.item_name like '%유압유%'                    then 14                           
                                       when b.item_name like '%수성본드%'                  then 15                           
                                       when b.item_name like '%우레탄본드%'                then 16                           
                                       when b.item_name like '%PP밴드%'                    then 17                           
                                       when a.supp_no = '230'                              then 18                           
                                       when b.item_name like '%받침목%'                    then 19                           
                                       when b.item_name like '%소포제%' or b.item_name like '%탈지제%' then 20               
                                       when b.item_name like '%절삭유%'                    then 21                           
                                       when b.item_name like '%펀칭유%'                    then 22                           
                                       when b.item_name like '%철밴드%'                    then 23                           
                                       else 99                                                                               
                                  end)                                                                                       
                FROM binitem A                                                                                               
                     LEFT OUTER JOIN bitem B ON a.item_no   = b.item_no                                                      
                     LEFT OUTER JOIN bsupp C ON a.supp_no   = c.supp_no                                                      
                     LEFT OUTER JOIN bpart D ON a.part_code = d.part_no                                                      
               WHERE ( convert(char(10),a.in_date,111)  BETWEEN :as_start AND :as_end )                                      
                 AND ( a.supp_no           LIKE :as_supp      )                                                              
                 AND ( a.part_code         LIKE :as_part_code )                                                              
                 AND (( b.item_name like '%스티로폼%'   or b.item_name like '%베어링%'         or b.item_name like '%작업복%'    or 
                        b.item_name like '%안전화%'     or b.item_name like '%면장갑%'         or b.item_name like '%면보루%'    or 
                        b.item_name like '%마대%'       or b.item_name like '%필라멘트테이프%' or b.item_name like '%OPP테이프%' or 
                        b.item_name like '%보호필름%'   or b.item_name like '%비닐%'           or b.item_name like '%노루지%'    or 
                        b.item_name like '%공업용랩%'   or b.item_name like '%유압유%'         or b.item_name like '%수성본드%'  or 
                        b.item_name like '%우레탄본드%' or b.item_name like '%PP밴드%'         or b.item_name like '%받침목%'    or 
                        b.item_name like '%소포제%'     or b.item_name like '%탈지제%'         or b.item_name like '%절삭유%'    or
                        b.item_name like '%펀칭유%'     or b.item_name like '%철밴드%' 
                      ) OR  
                      ( convert(char(10),a.in_date,111)  BETWEEN :as_start AND :as_end ) AND
                      ( a.supp_no           LIKE :as_supp      ) AND
                      ( a.part_code         LIKE :as_part_code ) AND
                      ( a.supp_no              = '230'         ) 
                     )                 
               GROUP BY d.part_name    
                      , a.in_date      
                      , a.supp_no      
                      , b.item_name    
                      , a.item_no      
                      , a.uom          
              ) TMP_01                 
          GROUP BY part_name           
                 , item_name           
                 , in_month            
       ) TMP_MAIN                      
  GROUP BY part_name                   
         , item_name                   
  ORDER BY sort, sort2                 
*/
" arguments=(("as_start", string),("as_end", string),("as_supp", string),("as_part_code", string)) )
