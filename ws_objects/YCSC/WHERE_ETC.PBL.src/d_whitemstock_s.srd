$PBExportHeader$d_whitemstock_s.srd
$PBExportComments$장기재고조회(2003/08/26,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=67108864 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="itemloc.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="itemloc.qa" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=decimal(4) updatewhereclause=yes name=qoh dbname="itemloc.qoh" )
 retrieve="  SELECT itemloc.item_no    
       , itemloc.qa            
       , groupitem.item_name   
       , itemloc.qoh  
    FROM itemloc
       , groupitem  
   WHERE groupitem.item_no   < 'PZZZ' 
     AND groupitem.use_flag  = 'Y' 
     AND ( itemloc.item_no   = groupitem.item_no ) 
     AND ( itemloc.qoh       > 0                 ) 
     AND ( ( itemloc.loc_no           = :as_loc  ) AND 
           ( itemloc.last_rcpt_date   < :ad_date ) AND
           ( itemloc.item_no       LIKE :as_item ) 
         ) 
     AND itemloc.item_no + qa NOT IN (SELECT itemstock.item_no + qa FROM itemstock)
" arguments=(("as_loc", string),("ad_date", date),("as_item", string))  sort="groupitem_item_name A qa A " )
