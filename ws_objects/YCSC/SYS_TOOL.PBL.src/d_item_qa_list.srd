detail(height=64 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=item_no dbname="item.item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item.item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="item.qa" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"item~" ) COLUMN(NAME=~"item.item_no~") COLUMN(NAME=~"item.item_name~") COLUMN(NAME=~"item.qa~")WHERE(    EXP1 =~"item.use_flag~"   OP =~"=~"    EXP2 =~"'Y'~" ) ) "  sort="item_no A qa A " )
