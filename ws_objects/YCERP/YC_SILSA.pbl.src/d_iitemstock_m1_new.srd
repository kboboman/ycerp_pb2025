text(band=header alignment="2" text="기타입고" border="6" color="0" x="3776" y="8" height="60" width="325" html.valueishtml="0"  name=t_3 visible="1"  font.face="굴림체" font.height="-10" font.weight="700"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="15780518" )
text(band=header alignment="2" text="판매출고" border="6" color="33554432" x="4110" y="8" height="60" width="311" html.valueishtml="0"  name=real_out_qty_t visible="1"  font.face="굴림체" font.height="-10" font.weight="700"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="12639424" )
