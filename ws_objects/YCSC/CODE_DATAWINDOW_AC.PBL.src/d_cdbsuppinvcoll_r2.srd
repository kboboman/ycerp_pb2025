 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"bpeom~" )  TABLE(NAME=~"supp~" ) COLUMN(NAME=~"bpeom.supp_no~") COLUMN(NAME=~"bpeom.eom_year~") COLUMN(NAME=~"bpeom.balbf_amount~") COLUMN(NAME=~"bpeom.inv_01~") COLUMN(NAME=~"bpeom.inv_02~") COLUMN(NAME=~"bpeom.inv_03~") COLUMN(NAME=~"bpeom.inv_04~") COLUMN(NAME=~"bpeom.inv_05~") COLUMN(NAME=~"bpeom.inv_06~") COLUMN(NAME=~"bpeom.inv_07~") COLUMN(NAME=~"bpeom.inv_08~") COLUMN(NAME=~"bpeom.inv_09~") COLUMN(NAME=~"bpeom.inv_10~") COLUMN(NAME=~"bpeom.inv_11~") COLUMN(NAME=~"bpeom.inv_12~") COLUMN(NAME=~"bpeom.coll_01~") COLUMN(NAME=~"bpeom.coll_02~") COLUMN(NAME=~"bpeom.coll_03~") COLUMN(NAME=~"bpeom.coll_04~") COLUMN(NAME=~"bpeom.coll_05~") COLUMN(NAME=~"bpeom.coll_06~") COLUMN(NAME=~"bpeom.coll_07~") COLUMN(NAME=~"bpeom.coll_08~") COLUMN(NAME=~"bpeom.coll_09~") COLUMN(NAME=~"bpeom.coll_10~") COLUMN(NAME=~"bpeom.coll_11~") COLUMN(NAME=~"bpeom.coll_12~") COLUMN(NAME=~"bpeom.make_date~") COLUMN(NAME=~"bpeom.make_user~") COLUMN(NAME=~"supp.supp_name~")    JOIN (LEFT=~"bpeom.supp_no~"    OP =~"=~"RIGHT=~"supp.supp_no~" )WHERE(    EXP1 =~"bpeom.area_no~"   OP =~"=~"    EXP2 =~":arg_area~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"bpeom.supp_no~"   OP =~"=~"    EXP2 =~":aa~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"bpeom.eom_year~"   OP =~"=~"    EXP2 =~":bb ~" ) ) ARG(NAME = ~"arg_area~" TYPE = string)  ARG(NAME = ~"aa~" TYPE = string)  ARG(NAME = ~"bb~" TYPE = number) " arguments=(("arg_area", string),("aa", string),("bb", number)) )
