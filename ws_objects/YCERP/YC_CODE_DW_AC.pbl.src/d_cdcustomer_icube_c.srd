$PBExportComments$고객코드별 고객리스트(1998/3/12,성삼지)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=char(15) updatewhereclause=yes name=icube_no dbname="icube_no" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(1) updatewhereclause=yes name=open_close dbname="open_close" )
 column=(type=char(1) updatewhereclause=yes name=mgr_type dbname="mgr_type" )
 column=(type=char(10) updatewhereclause=yes name=salesman dbname="salesman" )
 column=(type=char(10) updatewhereclause=yes name=top_level dbname="top_level" )
 column=(type=char(10) updatewhereclause=yes name=imwon_user_id dbname="imwon_user_id" )
 retrieve="  SELECT customer.icube_no,
         customer.cust_no,   
         customer.cust_name,
         customer.open_close,
	    customer.mgr_type,
         customer.salesman,
         customer.top_level,
         customer.imwon_user_id
    FROM customer   
   WHERE customer.icube_no  IS NOT NULL
     AND ( ( :as_open = 'O' and customer.open_close    = 'O' ) OR
          		( :as_open = '%' and customer.open_close LIKE '%' )
         	   )
  UNION 
  SELECT '', '', '', '', '', '', '', ''
" arguments=(("as_open", string))  sort="cust_name A " )
