$PBExportHeader$d_osteamopeom_tm_old.srd
$PBExportComments$매출실적 집계현황(월간)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=180 color="536870912" )
summary(height=84 color="15780518" )
footer(height=0 color="16777215" )
detail(height=84 color="536870912" )
table(column=(type=long updatewhereclause=yes name=seq dbname="seq" )
 column=(type=char(20) updatewhereclause=yes name=area dbname="area" )
 column=(type=char(20) updatewhereclause=yes name=sector dbname="sector" )
 column=(type=char(20) updatewhereclause=yes name=team dbname="team" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="user_id" )
 column=(type=char(20) updatewhereclause=yes name=login_user_name dbname="user_name" )
 column=(type=char(10) updatewhereclause=yes name=login_rank dbname="rank" )
 column=(type=decimal(6) updatewhereclause=yes name=pre_yinv dbname="pre_yinv" )
 column=(type=decimal(6) updatewhereclause=yes name=cur_ayinv dbname="cur_ayinv" )
 column=(type=decimal(6) updatewhereclause=yes name=cur_amninv dbname="cur_amninv" )
 column=(type=decimal(6) updatewhereclause=yes name=cur_inv dbname="cur_inv" )
 column=(type=decimal(6) updatewhereclause=yes name=curinv_rate dbname="curinv_rate" )
 column=(type=decimal(6) updatewhereclause=yes name=bsale_amt dbname="bsale_amt" )
 column=(type=decimal(6) updatewhereclause=yes name=increm_rate dbname="increm_rate" )
 column=(type=decimal(6) updatewhereclause=yes name=cur_aminv dbname="cur_aminv" )
 column=(type=decimal(7) updatewhereclause=yes name=cur_minv dbname="cur_minv" )
 column=(type=decimal(6) updatewhereclause=yes name=inv_rate dbname="inv_rate" )
 column=(type=decimal(7) updatewhereclause=yes name=last_day dbname="last_day" )
 column=(type=decimal(7) updatewhereclause=yes name=bm_jan dbname="bm_jan" )
 column=(type=decimal(6) updatewhereclause=yes name=cur_amcoll dbname="cur_amcoll" )
 column=(type=decimal(6) updatewhereclause=yes name=cur_mcoll dbname="cur_mcoll" )
 column=(type=decimal(6) updatewhereclause=yes name=coll_rate dbname="coll_rate" )
 column=(type=decimal(7) updatewhereclause=yes name=m_jan dbname="m_jan" )
 column=(type=long updatewhereclause=yes name=cyear dbname="cyear" )
 column=(type=long updatewhereclause=yes name=cmon dbname="cmon" )
 retrieve="  SELECT seq         = o.seq                     /* 순서       */
       , area        = o.area                    /* 권역       */
       , sector      = o.sector                  /* 본부       */
       , team        = o.team                    /* 팀         */
       , user_id     = o.user_id                 /* 담당자     */
       , user_name   = o.user_name               /* 담당자명   */
       , rank        = o.rank                    /* 직책       */
       , pre_yinv    = z.pre_yinv                /* 전년 실적                                             */
       , cur_ayinv   = z.cur_ayinv               /* 매출목표   - 당년 목표                                */
       , cur_amninv  = z.cur_amninv              /* 매출목표   - 당년누계목표                             */
       , cur_inv     = z.cur_inv                 /* 매출실적   - 매출누계                                 */
       , curinv_rate = (case when z.cur_ayinv = 0 then 0 else (z.cur_inv / z.cur_ayinv)     end) /* 매출실적   - 진행율  = (매출누계 / 당년목표    )      */
       , bsale_amt   = z.bsale_amt               /* 전년       - 동월실적                                 */
       , increm_rate = (case when z.bsale_amt = 0 then 0 else (z.cur_minv / z.bsale_amt) -1 end) /* 실적       - 신장율  = (당월매출 / 전년동월실적) -1   */
       , cur_aminv   = z.cur_aminv               /* 매출       - 당월매출목표                             */
       , cur_minv    = z.cur_minv                /* 목표및진행 - 당월매출                                 */
  
       , inv_rate    = (case when z.cur_aminv = 0 then 0 else (z.cur_minv / z.cur_aminv)    end) /* 목표및진행 - 진행율  = (당월매출 / 당월매출목표)      */
       , last_day    = z.last_day                /* 당일매출                                              */
       , bm_jan      = z.bm_jan                  /* 전월미수금                                            */
       , cur_amcoll  = z.cur_amcoll              /* 수금       - 당월수금목표                             */
       , cur_mcoll   = z.cur_mcoll               /* 목표및진행 - 당월수금                                 */
       , coll_rate   = (case when z.cur_amcoll= 0 then 0 else (z.cur_mcoll / z.cur_amcoll)  end) /* 목표및진행 - 진행율                                   */
       , m_jan       = z.m_jan                   /* 당월미수금                                            */
       , cyear       = :ai_year
       , cmon        = :ai_month
    FROM (
          SELECT salesman    = (case when substring(a.insite,1,1) = 'O' then 'insite'   else a.salesman  end)
               , user_name   = (case when substring(a.insite,1,1) = 'O' then '내부업체' else a.user_name end)
               , pre_yinv    = sum(a.pre_yinv    )           /* 전년 실적                                             */
               , cur_ayinv   = sum(a.cur_ayinv   )           /* 매출목표   - 당년 목표                                */
               , cur_amninv  = sum(a.cur_amninv  )           /* 매출목표   - 당년누계목표                             */
               , cur_inv     = sum(a.cur_inv     )           /* 매출실적   - 매출누계                                 */
               , bsale_amt   = sum(a.bsale_amt   )           /* 전년       - 동월실적                                 */
               , cur_aminv   = sum(a.cur_aminv   )           /* 매출       - 당월매출목표                             */
               , cur_minv    = sum(a.cur_minv    )           /* 목표및진행 - 당월매출                                 */
               , last_day    = sum(a.last_day    )           /* 당일매출                                              */
               , bm_jan      = sum(a.bm_jan      )           /* 전월미수금                                            */
               , cur_amcoll  = sum(a.cur_amcoll  )           /* 수금       - 당월수금목표                             */
               , cur_mcoll   = sum(a.cur_mcoll   )           /* 목표및진행 - 당월수금                                 */
               , m_jan       = sum(a.m_jan       )           /* 당월미수금                                            */
            FROM (
                  SELECT salesman    = c.salesman
                       , user_name   = l.user_name
                       , insite      = (case when m.item_cd IS NOT NULL then 'O' else '' end)
                       , pre_yinv    = y.pre_yinv               /* 전년 실적                                             */
                       , cur_ayinv   = y.cur_ayinv              /* 매출목표   - 당년 목표                                */
                       , cur_amninv  = y.cur_amninv             /* 매출목표   - 당년누계목표                             */
                       , cur_inv     = y.cur_inv                /* 매출실적   - 매출누계                                 */
                       , bsale_amt   = y.bsale_amt              /* 전년       - 동월실적                                 */
                       , cur_aminv   = y.cur_aminv              /* 매출       - 당월매출목표                             */
                       , cur_minv    = y.cur_minv               /* 목표및진행 - 당월매출                                 */
                       , last_day    = y.last_day               /* 당일매출                                              */
                       , bm_jan      = y.bm_jan                 /* 전월미수금                                            */
                       , cur_amcoll  = y.cur_amcoll             /* 수금       - 당월수금목표                             */
                       , cur_mcoll   = y.cur_mcoll              /* 목표및진행 - 당월수금                                 */
                       , m_jan       = y.m_jan                  /* 당월미수금                                            */
                    FROM (
                          SELECT cust_no    = a.cust_no
                               , pre_yinv   = a.pre_yinv                                            /* 전년 실적                                             */
                               , cur_ayinv  = a.cur_ayinv                                           /* 매출목표   - 당년 목표                                */
                               , cur_amninv = a.cur_amninv                                          /* 매출목표   - 당년누계목표                             */
                               , cur_inv    = a.cur_inv                                             /* 매출실적   - 매출누계                                 */
                               , bsale_amt  = a.bsale_amt                                           /* 전년       - 동월실적                                 */
                               , cur_aminv  = a.cur_aminv                                           /* 매출       - 당월매출목표                             */
                               , cur_minv   = b.cur_minv                                            /* 목표및진행 - 당월매출                                 */
                               , last_day   = b.last_day                                            /* 당일매출                                              */
                               , bm_jan     = a.bm_jan                                              /* 전월미수금                                            */
                               , cur_amcoll = a.cur_amcoll                                          /* 수금       - 당월수금목표                             */
                               , cur_mcoll  = c.amount          /* a.cur_mcoll */                   /* 목표및진행 - 당월수금             */
                               , m_jan      = a.m_jan                                               /* 당월미수금                                            */
                            FROM (
                                  SELECT cust_no    = (case when aa.cust_no is not null then aa.cust_no else bb.cust_no end)
                                       , bm_jan     = bb.bm_jan        /* 전월미수금 */
                                       , m_jan      = bb.m_jan         /* 당월미수금 */
                                       , bsale_amt  = aa.bsale_amt     /* 전년 - 동월실적 */
                                       , pre_yinv   = aa.pre_yinv
                                       , cur_ayinv  = aa.cur_ayinv
                                       , cur_amninv = aa.cur_amninv
                                       , cur_inv    = aa.cur_inv
                                       , cur_aminv  = aa.cur_aminv
                                       , cur_minv   = aa.cur_minv
                                       , cur_amcoll = aa.cur_amcoll
                                       , cur_mcoll  = aa.cur_mcoll
                                    FROM (
                                          SELECT cust_no    = c.cust_no
                                               , bsale_amt  = sum((case :ai_month     /* 전년 - 동월실적 */
                                                                      when 01 then o_bf.inv_01
                                                                      when 02 then o_bf.inv_02
                                                                      when 03 then o_bf.inv_03
                                                                      when 04 then o_bf.inv_04
                                                                      when 05 then o_bf.inv_05
                                                                      when 06 then o_bf.inv_06
                                                                      when 07 then o_bf.inv_07
                                                                      when 08 then o_bf.inv_08
                                                                      when 09 then o_bf.inv_09
                                                                      when 10 then o_bf.inv_10
                                                                      when 11 then o_bf.inv_11
                                                                      when 12 then o_bf.inv_12 
                                                                   end) / 1.1) / 1000
                                                                                                                        
                                               , pre_yinv   = sum((o_bf.inv_01  + o_bf.inv_02  + o_bf.inv_03  + o_bf.inv_04  + o_bf.inv_05  + o_bf.inv_06   + 
                                                                   o_bf.inv_07  + o_bf.inv_08  + o_bf.inv_09  + o_bf.inv_10  + o_bf.inv_11  + o_bf.inv_12)  / 1.1) / 1000
                                               , cur_ayinv  = sum((t.inv_01 + t.inv_02 + t.inv_03 + t.inv_04 + t.inv_05 + t.inv_06  + 
                                                                   t.inv_07 + t.inv_08 + t.inv_09 + t.inv_10 + t.inv_11 + t.inv_12) / 1.1) / 1000
                                               , cur_amninv = sum((case :ai_month 
                                                                      when 01 then t.inv_01
                                                                      when 02 then t.inv_01 + t.inv_02
                                                                      when 03 then t.inv_01 + t.inv_02 + t.inv_03
                                                                      when 04 then t.inv_01 + t.inv_02 + t.inv_03 + t.inv_04
                                                                      when 05 then t.inv_01 + t.inv_02 + t.inv_03 + t.inv_04 + t.inv_05
                                                                      when 06 then t.inv_01 + t.inv_02 + t.inv_03 + t.inv_04 + t.inv_05 + t.inv_06
                                                                      when 07 then t.inv_01 + t.inv_02 + t.inv_03 + t.inv_04 + t.inv_05 + t.inv_06 + t.inv_07
                                                                      when 08 then t.inv_01 + t.inv_02 + t.inv_03 + t.inv_04 + t.inv_05 + t.inv_06 + t.inv_07 + t.inv_08
                                                                      when 09 then t.inv_01 + t.inv_02 + t.inv_03 + t.inv_04 + t.inv_05 + t.inv_06 + t.inv_07 + t.inv_08 + t.inv_09
                                                                      when 10 then t.inv_01 + t.inv_02 + t.inv_03 + t.inv_04 + t.inv_05 + t.inv_06 + t.inv_07 + t.inv_08 + t.inv_09 + t.inv_10
                                                                      when 11 then t.inv_01 + t.inv_02 + t.inv_03 + t.inv_04 + t.inv_05 + t.inv_06 + t.inv_07 + t.inv_08 + t.inv_09 + t.inv_10 + t.inv_11
                                                                      when 12 then t.inv_01 + t.inv_02 + t.inv_03 + t.inv_04 + t.inv_05 + t.inv_06 + t.inv_07 + t.inv_08 + t.inv_09 + t.inv_10 + t.inv_11 + t.inv_12 
                                                                   end) / 1.1) / 1000
                                               , cur_inv    = sum((case :ai_month  
                                                                      when 01 then o_af.inv_01
                                                                      when 02 then o_af.inv_01 + o_af.inv_02
                                                                      when 03 then o_af.inv_01 + o_af.inv_02 + o_af.inv_03
                                                                      when 04 then o_af.inv_01 + o_af.inv_02 + o_af.inv_03 + o_af.inv_04
                                                                      when 05 then o_af.inv_01 + o_af.inv_02 + o_af.inv_03 + o_af.inv_04 + o_af.inv_05
                                                                      when 06 then o_af.inv_01 + o_af.inv_02 + o_af.inv_03 + o_af.inv_04 + o_af.inv_05 + o_af.inv_06
                                                                      when 07 then o_af.inv_01 + o_af.inv_02 + o_af.inv_03 + o_af.inv_04 + o_af.inv_05 + o_af.inv_06 + o_af.inv_07
                                                                      when 08 then o_af.inv_01 + o_af.inv_02 + o_af.inv_03 + o_af.inv_04 + o_af.inv_05 + o_af.inv_06 + o_af.inv_07 + o_af.inv_08
                                                                      when 09 then o_af.inv_01 + o_af.inv_02 + o_af.inv_03 + o_af.inv_04 + o_af.inv_05 + o_af.inv_06 + o_af.inv_07 + o_af.inv_08 + o_af.inv_09
                                                                      when 10 then o_af.inv_01 + o_af.inv_02 + o_af.inv_03 + o_af.inv_04 + o_af.inv_05 + o_af.inv_06 + o_af.inv_07 + o_af.inv_08 + o_af.inv_09 + o_af.inv_10
                                                                      when 11 then o_af.inv_01 + o_af.inv_02 + o_af.inv_03 + o_af.inv_04 + o_af.inv_05 + o_af.inv_06 + o_af.inv_07 + o_af.inv_08 + o_af.inv_09 + o_af.inv_10 + o_af.inv_11
                                                                      when 12 then o_af.inv_01 + o_af.inv_02 + o_af.inv_03 + o_af.inv_04 + o_af.inv_05 + o_af.inv_06 + o_af.inv_07 + o_af.inv_08 + o_af.inv_09 + o_af.inv_10 + o_af.inv_11 + o_af.inv_12 
                                                                   end) / 1.1) / 1000
                                               , cur_aminv  = sum((case :ai_month  
                                                                      when 01 then t.mod_01
                                                                      when 02 then t.mod_02
                                                                      when 03 then t.mod_03
                                                                      when 04 then t.mod_04
                                                                      when 05 then t.mod_05
                                                                      when 06 then t.mod_06
                                                                      when 07 then t.mod_07
                                                                      when 08 then t.mod_08
                                                                      when 09 then t.mod_09
                                                                      when 10 then t.mod_10
                                                                      when 11 then t.mod_11
                                                                      when 12 then t.mod_12 
                                                                   end) / 1.1) / 1000
                                               , cur_minv   = sum((case :ai_month  
                                                                      when 01 then o_af.inv_01
                                                                      when 02 then o_af.inv_02
                                                                      when 03 then o_af.inv_03
                                                                      when 04 then o_af.inv_04
                                                                      when 05 then o_af.inv_05
                                                                      when 06 then o_af.inv_06
                                                                      when 07 then o_af.inv_07
                                                                      when 08 then o_af.inv_08
                                                                      when 09 then o_af.inv_09
                                                                      when 10 then o_af.inv_10
                                                                      when 11 then o_af.inv_11
                                                                      when 12 then o_af.inv_12 
                                                                   end) / 1.1) / 1000
                                               , cur_amcoll = sum((case :ai_month  
                                                                      when 01 then t.del_01
                                                                      when 02 then t.del_02
                                                                      when 03 then t.del_03
                                                                      when 04 then t.del_04
                                                                      when 05 then t.del_05
                                                                      when 06 then t.del_06
                                                                      when 07 then t.del_07
                                                                      when 08 then t.del_08
                                                                      when 09 then t.del_09
                                                                      when 10 then t.del_10
                                                                      when 11 then t.del_11
                                                                      when 12 then t.del_12 
                                                                   end)) / 1000
                                               , cur_mcoll  = sum((case :ai_month  
                                                                      when 01 then o_af.coll_01
                                                                      when 02 then o_af.coll_02
                                                                      when 03 then o_af.coll_03
                                                                      when 04 then o_af.coll_04
                                                                      when 05 then o_af.coll_05
                                                                      when 06 then o_af.coll_06
                                                                      when 07 then o_af.coll_07
                                                                      when 08 then o_af.coll_08
                                                                      when 09 then o_af.coll_09
                                                                      when 10 then o_af.coll_10
                                                                      when 11 then o_af.coll_11
                                                                      when 12 then o_af.coll_12 
                                                                   end)) / 1000
                                            FROM customer c
                                                 LEFT OUTER JOIN cust_aim    t ON c.cust_no = t.cust_code   AND datepart(year, t.tar_year)    = :ai_year
                                                 LEFT OUTER JOIN opeom    o_bf ON c.cust_no = o_bf.cust_no  AND datepart(year, o_bf.eom_year) = :ai_year - 1
                                                 LEFT OUTER JOIN opeom    o_af ON c.cust_no = o_af.cust_no  AND datepart(year, o_af.eom_year) = :ai_year
                                           WHERE ( c.cust_flag               = 'N' )
                                             AND ( c.cust_type              <> 'E' )
                                           /*AND ( c.credit_level           <> 'Z' )*/
                                           GROUP BY c.cust_no
                                         ) AA
                                              
                                         FULL OUTER JOIN (
                                              SELECT cust_no   = a.cust_no
                                                   , bm_jan    = (case :ai_month
                                                                     when 01 then a.bf_amount                        /* 전월잔액 */
                                                                     when 02 then a.bf_amount + a.sinv01 - a.scoll01
                                                                     when 03 then a.bf_amount + a.sinv02 - a.scoll02
                                                                     when 04 then a.bf_amount + a.sinv03 - a.scoll03
                                                                     when 05 then a.bf_amount + a.sinv04 - a.scoll04
                                                                     when 06 then a.bf_amount + a.sinv05 - a.scoll05
                                                                     when 07 then a.bf_amount + a.sinv06 - a.scoll06
                                                                     when 08 then a.bf_amount + a.sinv07 - a.scoll07
                                                                     when 09 then a.bf_amount + a.sinv08 - a.scoll08
                                                                     when 10 then a.bf_amount + a.sinv09 - a.scoll09
                                                                     when 11 then a.bf_amount + a.sinv10 - a.scoll10
                                                                     when 12 then a.bf_amount + a.sinv11 - a.scoll11
                                                                  end) / 1000
                                                   , m_jan     = (case :ai_month
                                                                     when 01 then a.bf_amount + a.sinv01 - a.scoll01 /* 당월잔액 */
                                                                     when 02 then a.bf_amount + a.sinv02 - a.scoll02 
                                                                     when 03 then a.bf_amount + a.sinv03 - a.scoll03 
                                                                     when 04 then a.bf_amount + a.sinv04 - a.scoll04 
                                                                     when 05 then a.bf_amount + a.sinv05 - a.scoll05 
                                                                     when 06 then a.bf_amount + a.sinv06 - a.scoll06 
                                                                     when 07 then a.bf_amount + a.sinv07 - a.scoll07 
                                                                     when 08 then a.bf_amount + a.sinv08 - a.scoll08 
                                                                     when 09 then a.bf_amount + a.sinv09 - a.scoll09 
                                                                     when 10 then a.bf_amount + a.sinv10 - a.scoll10 
                                                                     when 11 then a.bf_amount + a.sinv11 - a.scoll11 
                                                                     when 12 then a.bf_amount + a.sinv12 - a.scoll12 
                                                                  end) / 1000
                                                FROM (
                                                      SELECT v_opeom.cust_no, bf_amount = balbf_amount
                                                           , sinv01,  sinv02,  sinv03,  sinv04,  sinv05,  sinv06,  sinv07,  sinv08,  sinv09,  sinv10,  sinv11,  sinv12
                                                           , scoll01, scoll02, scoll03, scoll04, scoll05, scoll06, scoll07, scoll08, scoll09, scoll10, scoll11, scoll12
                                                        FROM v_opeom   
                                                             LEFT OUTER JOIN customer C on v_opeom.cust_no = c.cust_no
                                                       WHERE ( c.cust_flag               = 'N' )
                                                         AND ( c.cust_type              <> 'E' )
                                                       /*AND ( c.credit_level           <> 'Z' )*/
                                                         AND cyear = :ai_year
                                                     ) A      
                                         ) BB  ON AA.CUST_NO = BB.CUST_NO
                                 ) A
                                 
                                 FULL OUTER JOIN ( /* 출고내역 (당월, 당일) */
                                    SELECT cust_no   = a.cust_no
                                         , cur_minv  = sum(a.cur_minv / 1.1) / 1000   /* 당월매출 */
                                         , last_day  = sum(a.last_day / 1.1) / 1000   /* 당일매출 */
                                      FROM (
                                            SELECT cust_no   = do.cust_no
                                                 , cur_minv  = (do.do_total)
                                                 , last_day  = (case when convert(char(10),do.do_date,111) = :as_edate then do.do_total else 0 end)
                                              FROM do  
                                                   LEFT OUTER JOIN customer  C  ON c.cust_no  = do.cust_no
                                             WHERE ( c.cust_flag               = 'N' )
                                               AND ( c.cust_type              <> 'E' )
                                             /*AND ( c.credit_level           <> 'Z' )*/
                                               AND ( convert(char(10),do.do_date,111)   between :as_sdate and :as_edate ) 
                                           ) A
                                     GROUP BY cust_no
                                 ) B ON a.cust_no  = b.cust_no
  
                                 FULL OUTER JOIN ( /* 수금내역 (당월) */
                                    SELECT aroivc.cust_no  
                                         , amount = sum(aroivc.amount) / 1000
                                      FROM aroivc 
                                         , customer  
                                     WHERE ( aroivc.cust_no = customer.cust_no )    
                                       and (convert(char(10),oi_date,111)   between :as_sdate and :as_edate)
                                       and aroivc.delete_key = 'N'
                                     GROUP BY aroivc.cust_no
                                 ) C ON a.cust_no  = c.cust_no
                         ) Y
                         LEFT OUTER JOIN customer  C  ON y.cust_no  = c.cust_no
                         LEFT OUTER JOIN codemst   M  ON y.cust_no  = m.item_cd  AND m.type = '내부업체' AND m.use_yn ='Y'
                         LEFT OUTER JOIN login     L  ON c.salesman = l.user_id
                 ) A
           GROUP BY salesman, user_name, a.insite
         ) Z
         FULL JOIN opeom_org O  ON o.user_id = z.salesman
   WHERE o.seq  IS NOT NULL
   ORDER BY o.seq
" arguments=(("ai_year", number),("ai_month", number),("as_sdate", string),("as_edate", string))  sort="seq A " )
