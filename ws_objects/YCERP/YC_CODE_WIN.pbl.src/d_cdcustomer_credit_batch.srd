footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" values="	Y/	N" )
 column=(type=datetime updatewhereclause=yes name=last_tn_date dbname="customer.last_tn_date" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="customer_credit.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=char(255) updatewhereclause=yes name=cust_nm dbname="cust_nm" )
 retrieve="  SELECT DISTINCT chk = 'N'
       , c.last_tn_date
       , a.cust_no
       , c.cust_name
       , cust_nm = replace(replace(replace(c.cust_name,'(주)',''),'(유)',''),'(자)','')
    FROM customer_credit a
         LEFT OUTER JOIN customer c ON a.cust_no = c.cust_no
   ORDER BY cust_nm
"  sort="last_tn_date D " )
