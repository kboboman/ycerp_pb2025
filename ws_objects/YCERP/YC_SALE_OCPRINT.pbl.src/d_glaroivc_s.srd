table(column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" values="	Y/	N" )
 column=(type=char(255) updatewhereclause=yes name=register_no dbname="register_no" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(15) updatewhereclause=yes name=icube_no dbname="icube_no" )
 column=(type=datetime updatewhereclause=yes name=oi_date dbname="oi_date" )
 column=(type=char(12) updatewhereclause=yes name=vc_no dbname="vc_no" )
 column=(type=char(4) updatewhereclause=yes name=vc_type dbname="vc_type" )
 column=(type=char(11) updatewhereclause=yes name=rcpt_type dbname="rcpt_type" )
 column=(type=char(6) updatewhereclause=yes name=salesman dbname="salesman" )
 column=(type=char(6) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(5) updatewhereclause=yes name=team_name dbname="team_name" )
 column=(type=char(10) updatewhereclause=yes name=user_name1 dbname="user_name1" )
 column=(type=char(30) updatewhereclause=yes name=team_name1 dbname="team_name1" )
 column=(type=char(6) updatewhereclause=yes name=vc_inseq dbname="vc_inseq" )
 column=(type=decimal(4) updatewhereclause=yes name=cash dbname="cash" )
 column=(type=decimal(4) updatewhereclause=yes name=bill dbname="bill" )
 column=(type=decimal(4) updatewhereclause=yes name=amount dbname="amount" )
 column=(type=char(20) updatewhereclause=yes name=bank_name dbname="bank_name" )
 column=(type=char(20) updatewhereclause=yes name=branch dbname="branch" )
 column=(type=char(20) updatewhereclause=yes name=large dbname="large" )
 column=(type=char(2) updatewhereclause=yes name=vc_type2 dbname="vc_type2" )
 column=(type=char(50) updatewhereclause=yes name=rem dbname="rem" )
 column=(type=datetime updatewhereclause=yes name=cheque_start dbname="cheque_start" )
 column=(type=datetime updatewhereclause=yes name=cheque_end dbname="cheque_end" )
 column=(type=char(12) updatewhereclause=yes name=cheque_no dbname="cheque_no" )
 column=(type=long updatewhereclause=yes name=keysort dbname="keysort" )
 retrieve="  SELECT chk         = 'N'
       , register_no = replace(customer.register_no,'-','')
       , cust_no     = aroivc.cust_no  
       , cust_name   = customer.cust_name   
       , icube_no    = customer.icube_no
       , oi_date     = aroivc.oi_date   
       , vc_no       = aroivc.vc_no   
       , vc_type     = (case when aroivc.vc_type = 'R' then '수금' when aroivc.vc_type = 'P' then '지불' end)
       , rcpt_type   = (case aroivc.rcpt_type 
                             when 'A' then '01.예금'     when 'C' then '02.현금'     when 'B' then '03.어음'     
                             when 'D' then '04.잡손실'   when 'E' then '05.잡이익'
                             when 'F' then '06.하자보수' when 'S' then '07.상계'     
                             when 'G' then '08.대손상각' when 'P' then '09.처리어음' when 'Z' then '10.기타'                             
                             when 'R' then '11.대손이익' when 'M' then '12.대손예금' when 'N' then '13.대손어음'
                             else '99.기타' + aroivc.rcpt_type
                        end)
       , salesman    = login.duzon_sabun   
       , user_name   = isnull(login.duzon_sabun,login.user_name)
       , team_name   = isnull(login.duzon_dept, team.team_name) + ' '
       , user_name1  = rtrim(login.user_name)
       , team_name1  = rtrim(team.team_name)
       , vc_inseq    = aroivc.vc_inseq   
       , cash        = (case when aroivc.rcpt_type <> 'B' then
                                  (case when aroivc.vc_type = 'P' then 0 - aroivc.amount
                                        else aroivc.amount
                                   end)
                             else 0
                        end) 
       , bill        = (case when aroivc.rcpt_type  = 'B' then
                                  (case when aroivc.vc_type = 'P' then 0 - aroivc.amount
                                        else aroivc.amount
                                   end)
                             else 0
                        end)  
       , amount      = aroivc.amount   
       , bank_name   = bank.bank_name   
       , branch      = aroivc.branch   
       , large       = aroivc.large   
       , vc_type2    = aroivc.vc_type2
       , rem         = aroivc.rem
       , cheque_start= aroivc.cheque_start   
       , cheque_end  = aroivc.cheque_end   
       , cheque_no   = aroivc.cheque_no   
       , keysort     = 0
    FROM aroivc 
         LEFT OUTER JOIN bank     ON aroivc.bank_code  = bank.bank_code   
         LEFT OUTER JOIN money    ON aroivc.curr_code  = money.curr_type
         LEFT OUTER JOIN customer ON aroivc.cust_no    = customer.cust_no
         LEFT OUTER JOIN login    ON customer.salesman = login.user_id
         LEFT OUTER JOIN team     ON login.team_code   = team.team_code
   WHERE ( aroivc.delete_key    = 'N' )
   /*AND ( aroivc.open_close    = 'O' )*/
     AND ( aroivc.oi_date BETWEEN :ad_sdate AND :ad_edate )
     AND ((:as_custno    = '%' ) OR
          (:as_custno   <> '%' AND aroivc.cust_no = :as_custno)
         )
     AND ((:as_salesman  = '%' ) OR
          (:as_salesman <> '%' AND customer.salesman LIKE :as_salesman)
         )
" arguments=(("as_custno", string),("ad_sdate", date),("ad_edate", date),("as_salesman", string))  sort="oi_date D vc_no A cust_name A " )
