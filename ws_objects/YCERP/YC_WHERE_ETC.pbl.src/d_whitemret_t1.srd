release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=4 color="536870912" )
footer(height=88 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=saler_user dbname="saler_user" )
 column=(type=char(10) updatewhereclause=yes name=wc_no dbname="wc_no" )
 column=(type=char(10) updatewhereclause=yes name=work_name dbname="work_name" )
 column=(type=char(4) updatewhereclause=yes name=pri dbname="pri" )
 column=(type=datetime updatewhereclause=yes name=napgi_date dbname="napgi_date" )
 column=(type=char(14) updatewhereclause=yes name=sale_no dbname="sale_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="seq_no" )
 column=(type=char(1) updatewhereclause=yes name=overtime dbname="overtime" )
 column=(type=char(4) updatewhereclause=yes name=runcmd dbname="runcmd" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=char(10) updatewhereclause=yes name=assy_item dbname="assy_item" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=decimal(4) updatewhereclause=yes name=order_qty dbname="order_qty" )
 column=(type=char(20) updatewhereclause=yes name=assy_qa dbname="assy_qa" )
 column=(type=char(2) updatewhereclause=yes name=uom_order dbname="uom_order" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=decimal(4) updatewhereclause=yes name=plan_qty dbname="plan_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=make_qty dbname="make_qty" )
 column=(type=char(10) updatewhereclause=yes name=color_name dbname="color_name" )
 column=(type=char(17) updatewhereclause=yes name=planno dbname="planno" )
 column=(type=char(50) updatewhereclause=yes name=rem dbname="rem" )
 column=(type=datetime updatewhereclause=yes name=work_date dbname="work_date" )
 column=(type=char(1) updatewhereclause=yes name=flag dbname="flag" )
 column=(type=long updatewhereclause=yes name=op dbname="op" )
 column=(type=long updatewhereclause=yes name=div dbname="div" )
 column=(type=char(1) updatewhereclause=yes name=req_chk dbname="req_chk" )
 column=(type=char(1) updatewhereclause=yes name=utong_yn dbname="utong_yn" )
 column=(type=char(1) updatewhereclause=yes name=make_order_sort dbname="make_order_sort" )
 column=(type=char(16) updatewhereclause=yes name=mpsorder_order_no dbname="mpsorder.order_no" )
 retrieve="  SELECT saler_user = aroiinv_esero.saler_user
       , wc_no      = routtempnew.wc_no
       , work_name  = wc.work_name             
       , pri        = (case when mpsdet.priority is null then '미' 
                            else (case when mpsdet.mpsorder_order is null 
                                            then right(  '  ' + convert(char(2), mpsdet.priority), 2 ) 
                                       else right(  '  ' + convert(char(2), mpsdet.order_seq), 2 ) 
                                  end)
                       end)
       , napgi_date = routtempnew.napgi_date   
       , sale_no    = routtempnew.sale_no       
       , seq_no     = routtempnew.seq_no       
       , overtime   = (case when mpsorder.overtime = 'Y' then mpsorder.overtime else '' end)
       , runcmd     = substring(convert(char(10),mpsorder.order_date,111),9,2)
       , cust_name  = customer.cust_name       
       , scene_desc = scene.scene_desc         
       , assy_item  = routtempnew.assy_item     
       , item_name  = groupitem.item_name       
       , qa         = routtempnew.qa           
       , order_qty  = routtempnew.order_qty    
       , assy_qa    = routtempnew.assy_qa      
       , uom_order  = (case when groupitem.uom = 'M' OR  groupitem.uom = 'M2' then 'EA' else groupitem.uom end)         
       , uom        = groupitem.uom
       , plan_qty   = routtempnew.plan_qty     
       , make_qty   = routtempnew.make_qty     
       , color_name = color.color_name         
       , planno     = (case when mpsdet.order_no is null then 'ZZZZZZZZZZZZZZZZZ' 
                            else (case when mpsdet.mpsorder_order is null then mpsdet.order_no 
                                       else mpsdet.mpsorder_order 
                                  end)
                       end)
       , rem        = routtempnew.rem          
       , work_date  = routtempnew.work_date     
       , flag       = routtempnew.plan_flag         
       , op         = routtempnew.operation         
       , div        = routtempnew.division         
       , req_chk    = (case when b.sale_no is null then '' else 'Y' end)
	  , isnull( scene.utong_yn, 'N' ) utong_yn
       , ( case when mpsorder.order_no is null then '2' else '1' end ) make_order_sort
	 , mpsorder.order_no
    FROM routtempnew 
         LEFT OUTER JOIN customer    ON routtempnew.cust_no     = customer.cust_no 
         LEFT OUTER JOIN scene       ON routtempnew.scene_code  = scene.scene_code 
         LEFT OUTER JOIN color       ON routtempnew.item_color  = color.color_code 
         LEFT OUTER JOIN wc          ON routtempnew.wc_no       = wc.work_no   
         LEFT OUTER JOIN mpsdet      ON routtempnew.sale_no     = mpsdet.sale_no   
                                    AND routtempnew.seq_no      = mpsdet.seq_no  
                                    AND routtempnew.division    = mpsdet.division  
                                    AND routtempnew.operation   = mpsdet.operation 
                                    AND routtempnew.wc_no       = mpsdet.wc_no     
         LEFT OUTER JOIN mpsorder    ON mpsdet.mpsorder_order   = mpsorder.order_no
         LEFT OUTER JOIN groupitem   ON routtempnew.assy_item   = groupitem.item_no    
         LEFT OUTER JOIN aroiinv_esero  ON customer.salesman    = aroiinv_esero.id
         LEFT OUTER JOIN (
              SELECT DISTINCT sale_no 
                FROM issuereqdet B with (nolock) 
               WHERE b.req_date   = :ad_date
                 AND b.req_flag   = 'A' /* '출고의뢰' */
         ) B ON routtempnew.sale_no = b.sale_no  
   WHERE ( routtempnew.work_date      = :ad_date )  
     AND ( routtempnew.plan_flag   LIKE :as_flag ) 
     AND ( wc.work_name            LIKE :as_wcnm ) 
     AND ( routtempnew.area_no        = :as_area )     
" arguments=(("ad_date", date),("as_wcnm", string),("as_flag", string),("as_area", string))  sort="wc_no A make_order_sort A mpsorder_order_no A planno A right( '00' + trim( pri ), 3 ) A napgi_date A assy_qa A " )
