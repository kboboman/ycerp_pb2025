 column=(type=char(10) updatewhereclause=yes name=user_name3 dbname="user_name3" )
 column=(type=char(10) updatewhereclause=yes name=user_name4 dbname="user_name4" )
 column=(type=char(10) updatewhereclause=yes name=user_name5 dbname="user_name5" )
 column=(type=char(20) updatewhereclause=yes name=rank1 dbname="rank1" )
 column=(type=char(20) updatewhereclause=yes name=rank2 dbname="rank2" )
 column=(type=char(20) updatewhereclause=yes name=rank3 dbname="rank3" )
 column=(type=char(20) updatewhereclause=yes name=rank4 dbname="rank4" )
 column=(type=char(20) updatewhereclause=yes name=rank5 dbname="rank5" )
 retrieve="select approvalline.user_id, 
           approvalline.approval_name, 
           approvalline.approval1,
           approvalline.approval2,
           approvalline.approval3,
           approvalline.approval4,
           approvalline.approval5,
           lg1.user_name user_name1,
           lg2.user_name user_name2,
           lg3.user_name user_name3,
           lg4.user_name user_name4,
           lg5.user_name user_name5,           
           lg1.rank rank1,
           lg2.rank rank2,
           lg3.rank rank3,
           lg4.rank rank4,
           lg5.rank rank5
from approvalline left outer join login lg1 on approvalline.approval1 = lg1.user_id
                             left outer join login lg2 on approvalline.approval2 = lg2.user_id
                             left outer join login lg3 on approvalline.approval3 = lg3.user_id
                             left outer join login lg4 on approvalline.approval4 = lg4.user_id
                             left outer join login lg5 on approvalline.approval5 = lg5.user_id                             
where approvalline.user_id  = :as_user_id" update="approvalline" updatewhere=0 updatekeyinplace=no arguments=(("as_user_id", string)) )
