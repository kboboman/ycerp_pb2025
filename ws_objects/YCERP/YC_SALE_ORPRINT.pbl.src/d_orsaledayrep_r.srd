release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=72 color="79741120" )
summary(height=0 color="536870912" )
footer(height=68 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=cat dbname="cat" )
 column=(type=char(50) updatewhereclause=yes name=category dbname="category" )
 column=(type=char(10) updatewhereclause=yes name=gtype dbname="gtype" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" initial=" " )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(11) updatewhereclause=yes name=sale_scene_code dbname="scene_code" initial=" " )
 column=(type=char(14) updatewhereclause=yes name=sale_order_no dbname="order_no" initial=" " )
 column=(type=char(1) updatewhereclause=yes name=sale_sale_flag dbname="sale_flag" initial=" " values="내수	D/수출	E/L//C	L/" )
 column=(type=char(3) updatewhereclause=yes name=sale_curr_code dbname="curr_code" initial=" " )
 column=(type=datetime updatewhereclause=yes name=sale_order_date dbname="order_date" initial=" " )
 column=(type=datetime updatewhereclause=yes name=sale_cust_po_date dbname="cust_po_date" )
 column=(type=datetime updatewhereclause=yes name=sale_due_date dbname="due_date" initial=" " )
 column=(type=long updatewhereclause=yes name=saledet_seq_no dbname="seq_no" )
 column=(type=char(10) updatewhereclause=yes name=saledet_item_no dbname="item_no" )
 column=(type=char(20) updatewhereclause=yes name=saledet_qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=saledet_uom dbname="uom" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_order_qty dbname="order_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_acc_qty dbname="acc_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=saledet_price dbname="price" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene_desc" )
 column=(type=datetime updatewhereclause=yes name=c_start dbname="c_start" )
 column=(type=datetime updatewhereclause=yes name=c_end dbname="c_end" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_rlse_qty dbname="rlse_qty" )
 column=(type=char(30) updatewhereclause=yes name=sale_ship_flag dbname="ship_flag" )
 column=(type=char(10) updatewhereclause=yes name=color_color_name dbname="color_name" )
 column=(type=char(1) updatewhereclause=yes name=open_close dbname="open_close" )
 column=(type=char(10) updatewhereclause=yes name=org_user dbname="org_user" )
 retrieve="  SELECT cat          = a.category
       , category     = cm.item_nm   
       , gtype        = a.gtype
       , cust_no      = a.cust_no         
       , cust_name    = a.cust_name   
       , scene_code   = a.scene_code      
       , order_no     = a.order_no        
       , sale_flag    = a.sale_flag       
       , curr_code    = a.curr_code       
       , order_date   = a.order_date      
       , cust_po_date = a.cust_po_date    
       , due_date     = a.due_date        
       , seq_no       = a.seq_no       
       , item_no      = a.item_no      
       , qa           = a.qa           
       , uom          = a.uom          
       , order_qty    = a.order_qty    
       , acc_qty      = a.acc_qty      
       , price        = a.price        
       , scene_desc   = a.scene_desc     
       , c_start      = convert(smalldatetime, :ad_sdate, 111)   
       , c_end        = convert(smalldatetime, :ad_edate, 111)     
       , item_name    = a.item_name   
       , rlse_qty     = a.rlse_qty   
       , ship_flag    = a.ship_flag     
       , color_name   = a.color_name 
       , open_close   = a.open_close
       , org_user     = a.org_user
    FROM (
         SELECT category     = isnull(i.category, 'TOP1999')
              , gtype        = i.type
              , sale.cust_no         
              , customer.cust_name   
              , sale.scene_code      
              , sale.order_no        
              , sale.sale_flag       
              , sale.curr_code       
              , sale.order_date      
              , sale.cust_po_date    
              , sale.due_date        
              , saledet.seq_no       
              , saledet.item_no      
              , saledet.qa           
              , saledet.uom          
              , saledet.order_qty    
              , saledet.acc_qty      
              , saledet.price        
              , scene.scene_desc     
              , groupitem.item_name   
              , rlse_qty   = isnull(saledet.rlse_qty,0)        
              , ship_flag  = dbo.uf_getshipflag(sale.ship_flag)   
              , color_name = isnull(color.color_name,'')       
              , open_close = sale.open_close
              , org_user   = login.user_name
           FROM saledet 
                LEFT OUTER JOIN sale        ON saledet.order_no = sale.order_no
                LEFT OUTER JOIN customer    ON sale.cust_no     = customer.cust_no
                LEFT OUTER JOIN color       ON saledet.color    = color.color_code
                LEFT OUTER JOIN scene       ON sale.scene_code  = scene.scene_code
                LEFT OUTER JOIN groupitem   ON saledet.item_no  = groupitem.item_no
                LEFT OUTER JOIN login       ON sale.org_user    = login.user_id
                LEFT OUTER JOIN itemtop10 I ON saledet.item_no  = i.item_no                  
          WHERE ( sale.area_no        LIKE :as_area )    
            AND ( sale.order_date  BETWEEN :ad_sdate AND :ad_edate )
            AND ((:as_openclose  = 'Y') OR
/*                 (:as_openclose <> 'Y' AND sale.open_close  NOT IN ('X','C') ) 한도초과 */
                 (:as_openclose <> 'Y' AND sale.open_close  = 'O' )
                )           
            AND ((:as_custno     = '%' AND sale.cust_no LIKE :as_custno) OR
                 (:as_custno    <> '%' AND sale.cust_no    = :as_custno)
                )
         ) A
         LEFT OUTER JOIN (
              SELECT item_cd, item_nm FROM codemst WHERE type = 'ITEMTOP10' AND use_yn = 'Y'
         ) CM ON a.category = cm.item_cd
     WHERE ((:as_itemtop10  = '%' AND a.category LIKE :as_itemtop10) OR
            (:as_itemtop10 <> '%' AND a.category    = :as_itemtop10)
           )
       AND ((:as_inside   = '%' ) OR
            (:as_inside  <> '%' AND a.cust_no NOT IN (SELECT cust_no FROM V_CUST_INSIDE))
           )
" arguments=(("as_area", string),("ad_sdate", date),("ad_edate", date),("as_custno", string),("as_itemtop10", string),("as_openclose", string),("as_inside", string))  sort="cust_name A sale_scene_code A sale_order_date A sale_order_no A saledet_seq_no A " )
group(level=1 header.height=0 trailer.height=68 by=("cust_no" ) header.color="536870912" trailer.color="553648127" )
group(level=2 header.height=0 trailer.height=72 by=("sale_scene_code" ) header.color="536870912" trailer.color="553648127" )
