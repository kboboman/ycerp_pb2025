footer(height=72 color="12639424" )
detail(height=76 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=wc_no dbname="wc_no" )
 column=(type=char(10) updatewhereclause=yes name=work_name dbname="work_name" )
 column=(type=char(10) updatewhereclause=yes name=cdate dbname="cdate" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" initial=" " )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="uom" )
 column=(type=decimal(4) updatewhereclause=yes name=sum_qty dbname="sum_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=sum_ret dbname="sum_ret" )
 column=(type=decimal(4) updatewhereclause=yes name=sum_rem dbname="sum_rem" )
 retrieve="  SELECT wc_no     = aa.wc_no                 /* 일자별 사용자재 */
       , work_name = aa.work_name          
       , cdate     = aa.cdate              
       , item_no   = aa.item_no            
       , item_name = aa.item_name          
       , qa        = aa.qa                 
       , uom       = aa.uom                
       , sum_qty   = sum(aa.sum_qty)       
       , sum_ret   = sum(aa.sum_ret)       
       , sum_rem   = sum(aa.sum_rem)       
    FROM (
						SELECT wc_no      = a.wc_no
							  , work_name  = d.work_name
							  , cdate      = convert(char(10),a.use_date,111)
							  , item_no    = a.item_no
							  , item_name  = c.item_name   
							  , qa         = a.qa             
							  , uom        = a.uom
/*							  , sum_qty    = (case when a.uom = 'SH' then a.use_qty else isnull(a.unit_qty,1) * a.cnt end)*/ /*2018.05.24 jowonsuk 삭제  */
/*							  , sum_qty    = ( a.use_qty ) *//*사용수량으로 등록 되게 변경 jowonsuk 2018.05.24 */
								/*2018.08.03 jowonsuk 반영 */
							  , sum_qty =  (    case when c.p4 = '1' then isnull(a.mod_qty,0)
													      when c.p4 = '2' then isnull(a.use_qty,0) 
														   else  isnull(a.use_qty,0) 
														   end 
											  )
							  , sum_ret    = (case when b.unit_qty * b.cnt is not null then b.unit_qty * b.cnt   else 0 end)
											+ (case when a.rem_qty          is not null then a.rem_qty            else 0 end)
/*								2018.08.03 jowonsuk 주석처리 
							  , sum_rem    = (case when a.rem_qty is null then
																 (case when a.uom = 'SH' then a.use_qty else a.unit_qty * a.cnt end)   
														  else (case when a.uom = 'SH' then a.use_qty else a.unit_qty * a.cnt end) - a.rem_qty  
													end)
*/									/*2018.08.03 jowonsuk 반영 */
                                           , sum_rem =  (    case when c.p4 = '1' then isnull(a.mod_qty,0) - isnull(a.rem_qty,0)
													            when c.p4 = '2' then isnull(a.use_qty,0) - isnull(a.rem_cnt,0)
														    else  isnull(a.use_qty,0) - isnull(a.rem_qty,0)
														    end 
												   )
						  FROM sfcuse    A left outer join  sfcret    B on     a.use_date  = b.ret_date  
																	and	 a.coil_no     = b.wcoil_no 
																	and	 a.loc_no      = b.loc_no 
											left outer join  groupitem C on a.item_no = c.item_no
											inner join wc        D on a.wc_no = d.work_no
					where ( a.wc_no LIKE (CASE WHEN :AS_WC = '%' THEN '%' ELSE :AS_WC+'%' END ) )
					  AND ( ( convert( char(10),a.use_date,111) BETWEEN :ad_start AND :ad_end ) /*AND  
									( a.coil_no       is not null         )*/
								 )
							AND ( a.area_no       LIKE :as_area + '%' )
         ) AA
   GROUP BY aa.wc_no, aa.work_name, aa.cdate, aa.item_no, aa.item_name, aa.qa, aa.uom
/*
           FROM sfcuse    A,   
                sfcret    B,   
                groupitem C,   
                wc        D
          WHERE ( a.item_no         *= c.item_no           )   
            AND ( a.wc_no            = d.work_no           )          
/*            AND ( d.work_name     LIKE :AS_WC + '%'     )             */
			AND ( a.wc_no     LIKE :AS_WC + '%'     )		
            AND ( ( convert(char(10),a.use_date,111) BETWEEN :ad_start AND :ad_end ) AND  
                  ( a.coil_no       is not null         ) AND
                  ( a.use_date      *= b.ret_date       ) AND
                  ( a.coil_no       *= b.wcoil_no       ) AND
                  ( a.loc_no        *= b.loc_no         )
                )
            AND ( a.area_no       LIKE :as_area + '%' )
         ) AA
   GROUP BY aa.wc_no, aa.work_name, aa.cdate, aa.item_no, aa.item_name, aa.qa, aa.uom
*/" arguments=(("as_area", string),("as_wc", string),("ad_start", string),("ad_end", string))  sort="cdate A groupitem_item_name A qa A " )
