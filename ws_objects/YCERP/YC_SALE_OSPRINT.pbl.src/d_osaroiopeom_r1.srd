$PBExportHeader$d_osaroiopeom_r1.srd
$PBExportComments$매출거래처 이력
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no  crosstab.dynamic = yes grid.lines=0 grid.columnmove=no selected.mouse=no )
header[1](height=0 color="536870912" )
header[2](height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(20) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(20) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=number updatewhereclause=yes name=balance_amt dbname="balance_amt" )
 column=(type=number updatewhereclause=yes name=vatamt dbname="vatamt" )
 retrieve=" SELECT   user_name   = l.user_name                                          
			  , custno      = a.cust_no                                            
			  , cust_name   = c.cust_name                                          
			  , scene_desc  = scene.scene_desc                                               
			  , balance_amt = c.balance_amt                                        
			  , imonth      = convert(char(7),a.do_date,111)
			  , vatamt      = SUM(DO_TOTAL)
FROM do a  LEFT OUTER JOIN scene   ON a.spot_code = scene.scene_code      
							LEFT OUTER JOIN customer C ON a.cust_no  = c.cust_no        
							LEFT OUTER JOIN login    L ON c.salesman = l.user_id  
where  do_date between :ad_sdate AND :ad_edate
		AND ((:as_userid  = '%' ) OR
						 (:as_userid <> '%' AND c.salesman    = :as_userid)
						)
GROUP BY a.cust_no
						, l.user_name                                                                             
						, c.cust_name                                          
						, scene.scene_desc     
						, c.balance_amt         
						, convert(char(7),a.do_date,111)
/*
SELECT DISTINCT user_name   = l.user_name                                          
       , custno      = a.cust_no                                            
       , cust_name   = c.cust_name                                          
       , scene_desc  = scene.scene_desc                                               
       , balance_amt = c.balance_amt                                        
       , imonth      = convert(char(8),a.oi_date,111) + '01'                
       , vatamt      = do.do_total/*a.aroiinv_cash + a.aroiinv_rate + (a.ship_cost * 1.1)*/
    FROM aroiinv    A
         /*LEFT OUTER JOIN do         ON a.aroiinv_no = do.inv_no                                                       */
         left outer JOIN (SELECT INV_NO,  SPOT_CODE, SUM(DO_TOTAL) do_total FROM do GROUP BY INV_NO, SPOT_CODE)  DO ON a.aroiinv_no = do.inv_no      /*2019.02.14 현장별 매출을 보여주기 위해서 do에서 가져옴 */
         LEFT OUTER JOIN scene      ON do.spot_code = scene.scene_code                                                       
         LEFT OUTER JOIN customer C ON a.cust_no  = c.cust_no               
         LEFT OUTER JOIN login    L ON c.salesman = l.user_id               
   WHERE a.oi_date  between :ad_sdate AND :ad_edate
     AND (a.delete_flag  =  'N') /* 계산서 삭제유무 */                             
     AND ((:as_userid  = '%' ) OR
          (:as_userid <> '%' AND c.salesman    = :as_userid)
         )
*/
" arguments=(("as_userid", string),("ad_sdate", date),("ad_edate", date))  sort="user_name A cust_name A scene_desc A balance_amt A " )
group(level=1 header.height=0 trailer.height=80 by=("user_name" ) header.color="536870912" trailer.color="12639424" )
group(level=2 header.height=0 trailer.height=80 by=("cust_name" ) header.color="536870912" trailer.color="553648127" )
