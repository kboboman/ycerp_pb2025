 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"sale~" )  TABLE(NAME=~"saledet~" )  TABLE(NAME=~"groupitem~" )  TABLE(NAME=~"customer~" ) COLUMN(NAME=~"groupitem.item_name~") COLUMN(NAME=~"saledet.uom~") COLUMN(NAME=~"saledet.order_qty~") COLUMN(NAME=~"saledet.acc_qty~") COLUMN(NAME=~"saledet.price~") COLUMN(NAME=~"saledet.item_no~") COMPUTE(NAME=~"item1 = substring(saledet.item_no,1,1)~")    JOIN (LEFT=~"sale.order_no~"    OP =~"=~"RIGHT=~"saledet.order_no~" )    JOIN (LEFT=~"saledet.item_no~"    OP =~"=~"RIGHT=~"groupitem.item_no~" )    JOIN (LEFT=~"sale.cust_no~"    OP =~"=~"RIGHT=~"customer.cust_no~" )WHERE(    EXP1 =~"sale.open_close~"   OP =~"=~"    EXP2 =~"'O'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"sale.order_date~"   OP =~"between~"    EXP2 =~":arg_date1 and :arg_date2~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"customer.salesman~"   OP =~"like~"    EXP2 =~":as_ret~" ) ) ORDER(NAME=~"saledet.item_no~" ASC=yes )  ORDER(NAME=~"groupitem.item_name~" ASC=yes ) ARG(NAME = ~"arg_date1~" TYPE = date)  ARG(NAME = ~"arg_date2~" TYPE = date)  ARG(NAME = ~"as_ret~" TYPE = string) " arguments=(("arg_date1", date),("arg_date2", date),("as_ret", string))  sort="saledet_item_no A " )
