 column=(type=char(8) update=yes updatewhereclause=yes name=update_date dbname="yc_com_resource_user.update_date" )
 column=(type=char(12) update=yes updatewhereclause=yes name=update_user dbname="yc_com_resource_user.update_user" )
 retrieve="select
	 'N' 					chk
	,a.management_no	management_no
	,a.seq				seq                 
	,a.user_nm			user_nm          
	,a.dept_nm			dept_nm 
	,a.enter_date		enter_date         
	,a.delivery_date	delivery_date    
	,a.return_date		return_date      
	,a.bigo				bigo                
	,a.input_date		input_date       
	,a.input_user		input_user        
	,a.update_date		update_date     
	,a.update_user		update_user     
from
	yc_com_resource_user a
where
	a.management_no	= :as_management_no
order by
	a.seq
" update="yc_com_resource_user" updatewhere=0 updatekeyinplace=no arguments=(("as_management_no", string)) )
