 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="aroivc.cust_no" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"aroivc~" )  TABLE(NAME=~"bank~" )  TABLE(NAME=~"money~" )  TABLE(NAME=~"customer~" ) COLUMN(NAME=~"aroivc.oi_date~") COLUMN(NAME=~"aroivc.vc_no~") COLUMN(NAME=~"aroivc.vc_type~") COLUMN(NAME=~"aroivc.rcpt_type~") COLUMN(NAME=~"money.curr_name~") COLUMN(NAME=~"aroivc.amount~") COLUMN(NAME=~"aroivc.cheque_end~") COLUMN(NAME=~"bank.bank_name~") COLUMN(NAME=~"aroivc.branch~") COLUMN(NAME=~"aroivc.large~") COLUMN(NAME=~"aroivc.rem~") COLUMN(NAME=~"customer.cust_name~") COLUMN(NAME=~"aroivc.cheque_no~") COLUMN(NAME=~"customer.salesman~") COLUMN(NAME=~"aroivc.vc_inseq~") COLUMN(NAME=~"aroivc.cust_no~")    JOIN (LEFT=~"aroivc.bank_code~"    OP =~"=~"RIGHT=~"bank.bank_code~"    OUTER1 =~"aroivc.bank_code~" )    JOIN (LEFT=~"aroivc.curr_code~"    OP =~"=~"RIGHT=~"money.curr_type~" )    JOIN (LEFT=~"aroivc.cust_no~"    OP =~"=~"RIGHT=~"customer.cust_no~" )) "  sort="aroivc_oi_date D aroivc_vc_no A customer_cust_name A " )
