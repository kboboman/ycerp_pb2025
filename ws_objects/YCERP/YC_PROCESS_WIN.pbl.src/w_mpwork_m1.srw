type dw_4 from datawindow within tabpage_2
event keydown pbm_dwnkey
integer y = 200
integer width = 4526
integer height = 1680
integer taborder = 51
boolean bringtotop = true
string dataobject = "d_mpsfcwork_m1"
boolean hscrollbar = true
boolean vscrollbar = true
boolean hsplitscroll = true
boolean livescroll = true
borderstyle borderstyle = stylelowered!
end type

event keydown;// 
long   ll_row, i, ll_color
string ls_wc, ls_wc1, ls_flag, ls_color_draw

if keyflags = 1 then
   if keydown(KeyLeftButton!) then
		ll_row = il_row
      if ll_row < 1 then RETURN
		
      this.accepttext()
		for i = ll_row to 1 step -1
			 if i <> ll_row then
				 if this.IsSelected(i) = true then
					 exit
				 end if
			 end if
			 
          this.SelectRow( i, NOT this.IsSelected(i) )
		next
	end if
else
	// 작업색상명 복사하기
	choose case Key
		case KeyEnter!, KeyTab!, KeyUpArrow!, KeyDownArrow!, KeyLeftButton!
			this.accepttext()
			if this.getcolumnname() = "color_draw" then
				ll_row = this.getrow()
				ls_color_draw = trim(this.object.color_draw[ll_row])
				
				if isnumber(ls_color_draw) then
					ll_color = long(ls_color_draw)
					if ll_color > 0 and ll_color <= this.rowcount() then
						this.object.color_draw[ll_row] = this.object.color_draw[ll_color]
					end if
				else
					if LeftA(ls_color_draw,2) = ".." then		// 품목비고란 복사
						this.object.color_draw[ll_row] = this.object.saledet_rem[ll_row]
					end if
				end if
			end if
	end choose
end if

end event

event itemchanged;//
long   ll_row,  ll_cnt,  ll_rowcount, ll_rowcount1, ll_find, ll_count, ll_colordraw
string ls_plan, ls_loc,  ls_assy, ls_assyqa, ls_uom, ls_qa1, ls_colordraw
real   lr_qty,  lr_hebe, lr_len

this.accepttext()
ll_cnt = this.getrow()

DEBUGBREAK()
choose case dwo.name		
//	case 'color_draw'
//      KeyDown Event에 작업색상명 복사하기 

	case 'make_qty'
		ls_assy   = trim(this.object.assembly[ll_cnt])
		ls_assyqa = trim(this.object.assembly_qa[ll_cnt])
		ls_uom    = trim(this.object.uom[ll_cnt])
		lr_qty    = this.object.make_qty[ll_cnt]
		
		setnull(lr_hebe)
		SELECT price_c INTO :lr_hebe FROM item WHERE item_no = :ls_assy AND qa = :ls_assyqa;
		if isnull(lr_hebe) then	lr_hebe = 0
			
		choose case trim(ls_uom)
			case 'M'
		       lr_len = real(long(MidA(ls_assyqa,15,5)) / 1000.0)
				 this.object.hebe[row] = lr_len * lr_hebe * lr_qty
			case else
				 this.object.hebe[row] = lr_hebe * lr_qty
		end choose
end choose

end event

event clicked;//
if isnull(row) OR row < 1 then return
this.scrolltorow( row )

// 사용선택
if cbx_2.checked = false then return

this.selectrow( row, Not this.isselected(row) )
il_row = row

end event

type cb_3 from commandbutton within tabpage_2
integer x = 2912
integer y = 8
integer width = 677
integer height = 84
integer taborder = 180
boolean bringtotop = true
integer textsize = -10
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "사용자재등록으로=>"
end type

event clicked;// 사용자재등록으로-->
long    ll_rowcount, ll_row, ll_found, ll_rout_cnt, ll_cnt = 0, ll_cnt2, ll_row2, ll_firstrow
string  ls_plan, ls_item, ls_qa, ls_rout_item, ls_rout_qa, ls_name, ls_uom, ls_qa1, ls_date
string  ls_assy, ls_assyqa, ls_assyqa1, ls_null, ls_sale, ls_item_name
int     li_seq, i_exit = 1
integer li_oper

if isnull(id_date) then
	MessageBox("오류","작업일자를 입력하십시오.",exclamation!)
	return
end if

if is_wc = "" or isnull(is_wc) then
	MessageBox('오류','작업장을 입력하십시오.',exclamation!)
	return
end if

ls_date = string(dw_2.object.work_date[1]) 
ls_date = LeftA(ls_date,4) + MidA(ls_date,6,2) + MidA(ls_date, 9,2)

dw5.setredraw(false)
ll_firstrow = 100
ll_rowcount = dw4.rowcount()

for ll_row = 1 to ll_rowcount
	if dw4.isselected(ll_row) then
		ls_plan = trim(dw4.object.order_no[ll_row])

		if dw5.rowcount() < 1 then
			//dw5.retrieve(dw_area.object.area[1], id_date,is_wc)	// 사용자재등록
			dw5.retrieve(dw_area.object.area[1], ls_date,is_wc)	// 사용자재등록
		end if
		
		dw5.accepttext()
		if dw5.rowcount() > 0 then
			ll_found = dw5.find("order_no = '" + ls_plan + "'",1,dw5.rowcount())
			if ll_found > 0 then
				if MessageBox("확인",string(ll_found, "000") + " 번째 자료는 이미 이동되었습니다~r~n" + &
										"재이동 하시겠습니까", Exclamation!, OKCancel!, 2) = 1 then
					ll_found = 0
				end if
			end if
		else
			ll_found = 0
		end if
		
		if ll_found = 0 then
			
// 성형은 이전은 상품이나 자재이다. 제품별 공정관리가 없다. 여기서는 억지로 넣고 있는데 이건 아니다. 어떻게 등록할지 고민 jowonsuk */
/* jowonsuk 2018.05.23 주석처리함

			if left(is_wc,1) = "F" then		
			
				ls_rout_item = "M3S1S30K00"	// GI 스리팅 COIL 0.30
				ls_qa        = trim(dw4.object.qa[ll_row])
				ls_rout_qa   = left(ls_qa,8) + "X0000X00000"
				
			else
*/				
				ls_sale    = trim(dw4.object.sale_no[ll_row])
				li_seq     = dw4.object.seq_no[ll_row]
				ls_item    = trim(dw4.object.item_no[ll_row])
				ls_item_name = trim(dw4.object.groupitem_item_name[ll_row])						
				ls_qa      = trim(dw4.object.qa[ll_row])
				ls_assy    = trim(dw4.object.assembly[ll_row])
				ls_assyqa  = trim(dw4.object.assembly_qa[ll_row])
				ls_qa1     = LeftA(ls_qa,13) + "X00000"
				ls_assyqa1 = LeftA(ls_assyqa,13) + "X00000"
				
				// 제품별공정
				setnull(li_oper)
				SELECT operation INTO :li_oper 
				  FROM routtempnew
				 WHERE item_no   = :ls_item   AND qa      = :ls_qa
				   AND assy_item = :ls_assy   AND assy_qa = :ls_assyqa
				   AND sale_no   = :ls_sale   AND seq_no  = :li_seq ;
					
					
				/*2018-05-22 jowonsuk 자재 사용 자동 등록 보완 이전 공정의 가졍 와야한다. li_oper-1이 없으면 없음으로 */
				
				SELECT  distinct a.ASSY_ITEM, a.ASSY_QA, a.UOM, b.item_name
						into :ls_rout_item, :ls_rout_qa,  :ls_uom, :ls_name
				FROM routtempnew a with(nolock) inner join groupitem b with(nolock) on a.item_no = b.item_no
				 WHERE  a.sale_no   = :ls_sale 
					AND a.seq_no    = :li_seq 
					AND a.operation = (:li_oper - 1); /* 현재 공정 이전 공정을 자재 사용량으로 사용 한다. */			
					
					
				/* 이전공정이 있는것만 등록 */	
				if sqlca.sqlcode = 0 then	
	
						ll_row2 = dw5.insertrow(0)
						if ll_firstrow > ll_row2 then ll_firstrow = ll_row2
						
						dw5.object.use_date[ll_row2]       = id_date
						dw5.object.wc_no[ll_row2]          = trim(dw_2.object.wc_no[1])
						dw5.object.order_no[ll_row2]       = dw4.object.order_no[ll_row]
						dw5.object.item_no[ll_row2]        = ls_rout_item
						dw5.object.qa[ll_row2]            	 = ls_rout_qa
						dw5.object.color[ll_row2]        	  = dw4.object.color[ll_row]
						dw5.object.item_item_name[ll_row2] = ls_name
						dw5.object.uom[ll_row2]            = ls_uom
						dw5.object.use_qty[ll_row2]        = dw4.object.make_qty[ll_row]
						ll_cnt++
						
						setnull(ls_null)
						
						dw5.object.loc_no[ll_row2]  = trim(dw_2.object.loc_no[1])
						dw5.object.area_no[ll_row2] = dw_area.object.area[1]									
				else
						MessageBox("확인", ls_item_name + " 품목 " + ls_qa + " 규격의 이전 공정이 생산계획에 없습니다.  " )
						i_exit = 0
				end if					
//2018.05.23 jowonsuk 주석처리, 제품별공정관리에서 가져오는게 아니라, 생산계획조정된 내용을 가져 와야 한다. 					
//				if sqlca.sqlcode = 100 or isnull(li_oper) then	// Fetched row not found
//					SELECT operation INTO :li_oper 
//					  FROM rout
//					 WHERE item_no  = :ls_item  AND qa      = :ls_qa1
//					   AND assembly = :ls_assy  AND assy_qa = :ls_assyqa1;
//						
//					if li_oper > 1 then
//					   li_oper = li_oper - 1
//					else
//					   li_oper = 1
//					end if
//					 
//					SELECT assembly, assy_qa INTO :ls_rout_item, :ls_rout_qa 
//					  FROM rout
//					 WHERE rout.item_no   = :ls_item AND rout.qa = :ls_qa1
//					   AND rout.operation = :li_oper;
//						
//					ls_rout_qa = left(ls_rout_qa,13) + mid(ls_qa,14,6)
//					
//				else	// 분할?
//					if li_oper > 1 then
//						li_oper = li_oper - 1
//					else
//						li_oper = 1
//					end if
//							 
//					SELECT assy_item, assy_qa INTO :ls_rout_item, :ls_rout_qa 
//					  FROM routtempnew
//					 WHERE routtempnew.item_no   = :ls_item AND routtempnew.qa = :ls_qa
//					   AND routtempnew.operation = :li_oper AND sale_no = :ls_sale   AND seq_no = :li_seq;				
//						
//					if sqlca.sqlcode = 100 or isnull(li_oper) then
//						
//						SELECT operation INTO :li_oper 
//						  FROM rout
//						 WHERE item_no  = :ls_item  AND qa = :ls_qa1
//						   AND assembly = :ls_assy  AND assy_qa = :ls_assyqa1;
//							
//						if li_oper > 1 then
//							li_oper = li_oper - 1
//						else
//							li_oper = 1
//						end if
//						 
//						SELECT assembly, assy_qa INTO :ls_rout_item, :ls_rout_qa 
//						  FROM rout
//						 WHERE rout.item_no   = :ls_item AND rout.qa = :ls_qa1
//						   AND rout.operation = :li_oper;
//							
//						ls_rout_qa = left(ls_rout_qa,13) + mid(ls_qa,14,6)
//					end if
//				end if
//2018.05.23 jowonsuk 주석처리, 제품별공정관리에서 가져오는게 아니라, 생산계획조정된 내용을 가져 와야 한다. 
//			end if
/*
			if sqlca.sqlcode = 0 then	

			ll_row2 = dw5.insertrow(0)
			if ll_firstrow > ll_row2 then ll_firstrow = ll_row2
			
		     dw5.object.use_date[ll_row2]       = id_date
		     dw5.object.wc_no[ll_row2]          = trim(dw_2.object.wc_no[1])
			dw5.object.order_no[ll_row2]       = dw4.object.order_no[ll_row]
			dw5.object.item_no[ll_row2]        = ls_rout_item
			dw5.object.qa[ll_row2]             = ls_rout_qa
			dw5.object.color[ll_row2]          = dw4.object.color[ll_row]
/*			2018.05.23 jowonsuk 주석처리 			
			SELECT item_name, uom INTO :ls_name, :ls_uom 
			  FROM groupitem
			 WHERE item_no = :ls_rout_item;					
*/			 
			dw5.object.item_item_name[ll_row2] = ls_name
			dw5.object.uom[ll_row2]            = ls_uom
			dw5.object.use_qty[ll_row2]        = dw4.object.make_qty[ll_row]
			ll_cnt++
			
			setnull(ls_null)
		     dw5.object.loc_no[ll_row2]  = trim(dw_2.object.loc_no[1])
		     dw5.object.area_no[ll_row2] = dw_area.object.area[1]
*/		
		end if
		
	end if
	
next

if ll_cnt > 0  then
	dw5.scrolltorow(ll_firstrow)
//	dw5.triggerevent(rowfocuschanged!)
	dw5.setredraw(true)
	tab_1.selecttab(3)
else
	if i_exit = 1 then
		MessageBox("확인","이동할 자료를 선택하십시요")
	end if
end if
dw5.setredraw(true)

cbx_2.checked = false	// 작업일보등록->사용선택
dw4.selectrow(0,false)

end event

