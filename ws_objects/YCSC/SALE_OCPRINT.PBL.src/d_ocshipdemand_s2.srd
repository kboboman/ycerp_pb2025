$PBExportHeader$d_ocshipdemand_s2.srd
$PBExportComments$운반비청구내역서 (2002/08/28,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=68 color="10789024" )
detail(height=76 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=do_do_no dbname="do.do_no" )
 column=(type=char(1) updatewhereclause=yes name=do_ship_flag dbname="do.ship_flag" values="착불	C/부담	B/대여	D/시화방문	M/화곡방문	H/반월방문	Y/공사원가	A/재료원가	R/" )
 column=(type=decimal(0) updatewhereclause=yes name=ship_amount dbname="do.ship_amount" )
 column=(type=char(60) updatewhereclause=yes name=do_driver dbname="do.driver" )
 column=(type=char(1) updatewhereclause=yes name=do_shipamt_case dbname="do.shipamt_case" values="현금	C/외상	R/" )
 column=(type=char(10) updatewhereclause=yes name=docar_name dbname="docar.name" )
 column=(type=char(40) updatewhereclause=yes name=docar_cargo_name dbname="docar.cargo_name" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 column=(type=char(1) updatewhereclause=yes name=ship_close dbname="do.ship_close" values="	C/	O" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_cash dbname="do.do_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_rate dbname="do.do_rate" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_total dbname="do.do_total" )
 column=(type=datetime updatewhereclause=yes name=do_ship_date dbname="do.ship_date" )
 column=(type=datetime updatewhereclause=yes name=log_date dbname="log_date" )
 column=(type=char(10) updatewhereclause=yes name=close_user dbname="do.close_user" )
 column=(type=char(180) updatewhereclause=yes name=sale_no dbname="sale_no" )
 column=(type=datetime updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=datetime updatewhereclause=yes name=edate dbname="edate" )
 retrieve="  SELECT do.do_no,   
         do.ship_flag,   
         do.ship_amount,   
         do.driver,   
         do.shipamt_case,   
         docar.name,   
         docar.cargo_name,   
         customer.cust_name,   
         scene.scene_desc,   
         do.ship_close,   
         do.do_cash,   
         do.do_rate,   
         do.do_total,   
         do.ship_date,   
         log_date = do.log_date,
         do.close_user,
	    sale_no = DBO.uf_getdosaleno(do.do_no),
         sdate = convert(smalldatetime, :ad_start, 111),   
         edate = convert(smalldatetime, :ad_end, 111)

FROM do with(nolock) inner join customer with(nolock) on  do.cust_no = customer.cust_no 
			  left outer join scene with(nolock) on  do.spot_code = scene.scene_code
			  left outer join docar  with(nolock) on  do.driver = docar.driver
WHERE 
         ( ( do.do_no like :as_area + '%' ) AND  
           ( do.ship_date between :ad_start and :ad_end ) AND
           ( do.ship_flag in ('D' , 'B', 'A', 'R') ) AND  
           ( do.ship_close like :as_flag ) 
         )    
  UNION ALL
 SELECT ask_head.ask_no,   
			ship_flag = 'B',
         ask_head.ship_amount,   
         ask_head.driver,   
			shipamt_case = '',
         docar.name,   
         docar.cargo_name,   
			cust_name = '(주)송천건업',
			scene_desc = '화곡사업장',
         ask_head.ship_close,
			0,   
			0,   
			0,   
         ask_head.ship_date,   
         log_date = ask_head.ship_date,   
         ask_head.close_user,
			'',
         sdate = convert(smalldatetime, :ad_start, 111),   
         edate = convert(smalldatetime, :ad_end, 111)

   from ask_head with(nolock) left outer join docar with(nolock) on ask_head.driver = docar.driver
   where 
         ( ( :as_area = 'S' ) AND  
           ( ask_head.ship_date between :ad_start and :ad_end ) AND  
           ( ask_head.ship_close like :as_flag ) 
         )    
  UNION ALL
  SELECT case when do_no is not null then do_no else dbo.uf_getdatestring(doshipetc.etc_date) end,   
         doshipetc.ship_flag,   
         doshipetc.ship_amount,   
         doshipetc.driver,   
         doshipetc.shipamt_case,   
         doshipetc.drv_name,   
         doshipetc.cargo_name,   
         customer.cust_name,   
         scene.scene_desc,   
         doshipetc.ship_close,   
         0,   
         0,   
         0,   
         doshipetc.etc_date,   
         log_date = doshipetc.etc_date,   
         doshipetc.user_id,
			   doshipetc.sale_no,
         sdate = convert(smalldatetime, :ad_start, 111),   
         edate = convert(smalldatetime, :ad_end, 111)
 
FROM   doshipetc with(nolock)  left outer  join  scene  with(nolock) on  doshipetc.scene_code = scene.scene_code
                                                        inner  join  customer  with(nolock) on  doshipetc.cust_no = customer.cust_no
where          
         ( ( doshipetc.etc_area like :as_area + '%' ) AND 
           ( doshipetc.etc_date between :ad_start and :ad_end )  AND  
           ( doshipetc.ship_close like :as_flag ) and
			  ( doshipetc.doship_req = 'Y' )  
         )  
" arguments=(("as_area", string),("ad_start", date),("ad_end", date),("as_flag", string))  sort="do_ship_date A docar_name A do_do_no A " )
