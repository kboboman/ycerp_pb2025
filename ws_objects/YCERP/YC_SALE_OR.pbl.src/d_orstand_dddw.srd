$PBExportComments$New 일위대가 시스템 선택
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=68 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes key=yes name=item_no dbname="basis_head.item_no" )
 column=(type=char(30) updatewhereclause=yes name=item_name dbname="basis_head.item_name" )
 column=(type=char(81) updatewhereclause=yes name=rem dbname="rem" )
 column=(type=datetime updatewhereclause=yes name=make_date dbname="basis_head.make_date" )
 retrieve="  SELECT DISTINCT basis_head.item_no
       , basis_head.item_name
       , rem   = (basis_head.rem + ' ' + basis_head.rem2)
       , basis_head.make_date
    FROM basis_head  
	WHERE use_flag = 'Y'
     AND (:as_newitem  = 'Y' AND make_date   >= '2013/01/01'
          OR
          :as_newitem <> 'Y' AND make_date LIKE '%'
         )
" update="basis_head" updatewhere=0 updatekeyinplace=no arguments=(("as_newitem", string))  sort="item_name A " )
column(band=detail id=1 alignment="0" tabsequence=32766 border="0" color="0" x="5" y="4" height="60" width="251" format="[general]" html.valueishtml="0"  name=item_no  tag="시스템코드" visible="1" edit.limit=10 edit.case=any edit.autoselect=yes edit.autohscroll=yes edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
