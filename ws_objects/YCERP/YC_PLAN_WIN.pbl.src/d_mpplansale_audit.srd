$PBExportHeader$d_mpplansale_audit.srd
$PBExportComments$작업일보등록 조회
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=88 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=destination dbname="destination" )
 column=(type=char(10) updatewhereclause=yes name=work_name dbname="work_name" )
 column=(type=datetime updatewhereclause=yes name=inaudit_date dbname="inaudit_date" )
 column=(type=char(1) updatewhereclause=yes name=i_time dbname="i_time" )
 column=(type=char(1) updatewhereclause=yes name=itime dbname="itime" values="오전	1/오후	2/야간	3/" )
 column=(type=char(10) updatewhereclause=yes name=inaudit_item dbname="inaudit_item" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(10) updatewhereclause=yes name=loc_no dbname="loc_no" )
 column=(type=char(30) updatewhereclause=yes name=loc_name dbname="loc_name" )
 column=(type=decimal(2) updatewhereclause=yes name=rcpt_qty dbname="rcpt_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=issue_qty dbname="issue_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=cqty dbname="cqty" )
 retrieve="  SELECT destination  = b.destination 
       , work_name    = b.work_name   
       , inaudit_date = b.inaudit_date
       , i_time       = b.itime
       , itime        = b.itime
       , inaudit_item = b.inaudit_item
       , item_name    = b.item_name   
       , qa           = b.qa          
       , loc_no       = b.loc_no
       , loc_name     = b.loc_name    
       , rcpt_qty     = sum(b.rcpt_qty)
       , issue_qty    = sum(b.issue_qty)
       , cqty         = sum(b.cqty)
    FROM (
         SELECT destination  = a.destination 
              , work_name    = a.work_name   
              , inaudit_date = a.inaudit_date
              , itime        = (case when a.itime > '00:00' AND a.itime <= '12:00' then '1'
                                     when a.itime > '12:00' AND a.itime <= '17:30' then '2'
                                     when a.itime > '17:30' AND a.itime <= '23:59' then '3'
                                end)
              , inaudit_time = a.itime
              , inaudit_item = a.inaudit_item
              , item_name    = a.item_name   
              , qa           = a.qa          
              , loc_no       = a.loc_no
              , loc_name     = a.loc_name    
              , rcpt_qty     = a.rcpt_qty    
              , issue_qty    = a.issue_qty   
              , cqty         = a.rcpt_qty - a.issue_qty
           FROM (
                SELECT destination  = i.destination
                     , work_name    = w.work_name
                     , inaudit_date = i.inaudit_date
                     , itime        = convert(char(5),i.inaudit_time,14)
                     , inaudit_time = convert(char(19),i.inaudit_time,120)
                     , inaudit_item = i.inaudit_item
                     , item_name    = g.item_name
                     , qa           = i.qa
                     , order_no     = i.order_no
                     , loc_no       = i.loc_no
                     , loc_name     = l.loc_name
                     , rcpt_qty     = i.rcpt_qty   
                     , issue_qty    = i.issue_qty           
                  FROM inaudit  I WITH (NOLOCK)
                       LEFT OUTER JOIN groupitem G WITH (NOLOCK) ON i.inaudit_item = g.item_no
                       LEFT OUTER JOIN location  L WITH (NOLOCK) ON i.loc_no       = l.loc_no
                       LEFT OUTER JOIN wc        W WITH (NOLOCK) ON i.destination  = w.work_no
                 WHERE ( inaudit_date  between :as_sdate AND :as_edate )
                   AND ( i.loc_no      = :as_locno )
                   AND ( inaudit_type  = 'RP' )
                   AND ( i.rem      LIKE '작업일보%' )
                   AND ((:as_wcnm   = '%' AND w.work_name LIKE :as_wcnm) OR
                        (:as_wcnm  <> '%' AND w.work_name LIKE :as_wcnm + '%')
                       )
                ) A
         ) B
     GROUP BY b.destination    
            , b.work_name      
            , b.inaudit_date   
            , b.itime          
            , b.inaudit_item   
            , b.item_name      
            , b.qa             
            , b.loc_no         
            , b.loc_name       
" arguments=(("as_locno", string),("as_wcnm", string),("as_sdate", string),("as_edate", string))  sort="inaudit_date A work_name A i_time A item_name A qa A " )
group(level=1 header.height=0 trailer.height=80 by=("destination" , "inaudit_date" , "work_name" , "i_time" ) header.color="536870912" trailer.color="12639424" )
