global w_iocoilqoh_r w_iocoilqoh_r

type variables
//
DataWindow dw4, dw5, dw6, dw7, dw8, dw9, dw10

string  is_loc, is_item, is_flag, isa_lotno[]
integer i_xpos, i_ypos

boolean ib_down

end variables

event open;call super::open;//==GF_USEPROGRAM(프로그램 사용현황)===========================================================
GF_USEPROGRAM( gs_userid, THIS.ClassName(), "O", string(gf_today(),'yyyy/mm/dd'), THIS.Title )
//=============================================================================================
DataWindowChild ldwc_coil, ldwc_loc, ldwc_item
string ls_coilgrp, ls_loc

ddlb_dwtitles.reset()
ddlb_dwtitles.visible = false
GF_DWTitle2ddlb( dw_1, ddlb_fld, ddlb_dwtitles )

mle_1.visible = false
tab_1.visible = false

dw4 = tab_1.tabpage_1.dw_4
dw5 = tab_1.tabpage_2.dw_5
dw6 = tab_1.tabpage_3.dw_6
dw7 = tab_1.tabpage_4.dw_7
dw8 = tab_1.tabpage_5.dw_8
dw9 = tab_1.tabpage_6.dw_9
dw10= tab_1.tabpage_7.dw_10

dw4.settransobject(sqlca)
dw5.settransobject(sqlca)
dw6.settransobject(sqlca)
dw7.settransobject(sqlca)
dw8.settransobject(sqlca)
dw9.settransobject(sqlca)
dw10.settransobject(sqlca)

if gs_userid = "1999010s" then
	cbx_sql.visible = true
else
	cbx_sql.visible = false
end if

if gf_permission('코일재고현황관리open', gs_userid) = 'Y' then	
else
	messagebox("확인","이프로그램의 사용권한이 없습니다")
	pb_close.postevent(clicked!)
end if
	
if gf_permission('코일재고현황관리Print', gs_userid) = 'Y' then	
else
	pb_print.enabled = false
	pb_print_part.enabled = false
end if

if gf_permission('코일재고현황관리UPDATE', gs_userid) = 'Y' then	
else
	pb_2.enabled = false
	dw_1.object.t_long_stock_yn.visible = false
	dw_1.object.t_use_yn.visible = false
	dw_1.object.long_stock_yn.visible = false
	dw_1.object.use_yn.visible = false
	gb_6.visible = false
	cbx_long_stock.visible = false
	cbx_use.visible = false
end if



// 코일그룹
dw_coil.settransobject(sqlca)
dw_coil.insertrow(0)
dw_coil.getchild( "coilgroup", ldwc_coil )
ldwc_coil.settransobject(SQLCA)

ldwc_coil.insertrow(1)
ldwc_coil.setitem(1, "item_cd", "%")
ldwc_coil.setitem(1, "item_nm", "전체")
dw_coil.object.coilgroup[1] = "%"

//
dw_3.settransobject(sqlca)
dw_3.visible = false

dw_2.insertrow(0)
dw_2.getchild("loc_no", ldwc_loc)
ldwc_loc.settransobject(SQLCA)

ldwc_loc.insertrow(1)
ldwc_loc.setitem(1, "loc_no", "%")
ldwc_loc.setitem(1, "loc_name", "전체")
ldwc_loc.setfilter("loc_no <> 'WS00000006'")
is_loc = "%"
dw_2.object.loc_no[1] = "%"

ldwc_loc.filter()

dw_2.getchild("item_no", ldwc_item)
ldwc_item.settransobject(SQLCA)
ldwc_item.insertrow(1)
ldwc_item.setitem(1, "item_no", "%")
ldwc_item.setitem(1, "item_name", "전체")
is_item = "%"

is_flag = "W"
ldwc_item.SetFilter( "cat = 'W'" )			
ldwc_item.Filter()


end event

