table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=loc_no dbname="loc_no" )
 column=(type=char(30) updatewhereclause=yes name=loc_name dbname="loc_name" )
 column=(type=char(4) update=yes updatewhereclause=yes key=yes name=cyear dbname="cyear" )
 column=(type=char(2) update=yes updatewhereclause=yes key=yes name=cmon dbname="cmon" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=qa dbname="qa" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=rcpt_qty dbname="rcpt_qty" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=issue_qty dbname="issue_qty" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=qoh dbname="qoh" )
 column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" )
 column=(type=decimal(4) updatewhereclause=yes name=rcptqty dbname="rcptqty" )
 column=(type=decimal(4) updatewhereclause=yes name=issueqty dbname="issueqty" )
 column=(type=decimal(4) updatewhereclause=yes name=qohqty dbname="qohqty" )
 retrieve="  SELECT loc_no    = a.loc_no
       , loc_name  = l.loc_name
       , cyear     = a.cyear
       , cmon      = a.cmon
       , item_no   = a.item_no
       , item_name = g.item_name
       , qa        = a.qa
       , rcpt_qty  = a.rcpt_qty
       , issue_qty = a.issue_qty
       , qoh       = a.qoh
       , chk       = (case when a.rcpt_qty - a.issue_qty = a.qoh then '' else 'Y' end)
       , rcptqty   = a.rcpt_qty
       , issueqty  = a.issue_qty
       , qohqty    = a.qoh
    FROM ineoym   A
         LEFT OUTER JOIN groupitem G ON a.item_no = g.item_no
         LEFT OUTER JOIN location  L ON a.loc_no  = l.loc_no
   WHERE ( a.loc_no  = :as_locno )
     AND ( a.cyear   = :as_cyear )
     AND ( a.cmon    = :as_cmon  )
     AND ( a.qa      = :as_qa    )
     AND ( a.item_no = :as_itemno) 
" update="ineoym" updatewhere=0 updatekeyinplace=no arguments=(("as_locno", string),("as_cyear", string),("as_cmon", string),("as_itemno", string),("as_qa", string))  sort="loc_no A item_name A qa A cyear A cmon A " )
