footer(height=0 color="536870912" )
detail(height=560 color="536870912" )
table(column=(type=char(14) update=yes updatewhereclause=yes key=yes name=do_no dbname="do.do_no" )
 column=(type=char(4) update=yes updatewhereclause=yes name=cust_no dbname="do.cust_no" )
 column=(type=char(11) update=yes updatewhereclause=yes name=spot_code dbname="do.spot_code" )
 column=(type=datetime update=yes updatewhereclause=yes name=do_date dbname="do.do_date" )
 column=(type=char(1) update=yes updatewhereclause=yes name=sale_flag dbname="do.sale_flag" initial="D" )
 column=(type=char(1) update=yes updatewhereclause=yes name=do_flag dbname="do.do_flag" initial="1" values="정상	1/무상	2/교환	3/오류	4/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=invoice_print dbname="do.invoice_print" initial="N" )
 column=(type=char(3) update=yes updatewhereclause=yes name=curr_code dbname="do.curr_code" initial="WON" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=curr_rate dbname="do.curr_rate" initial="1" )
 column=(type=char(10) update=yes updatewhereclause=yes name=fob dbname="do.fob" initial="어음" )
 column=(type=char(1) update=yes updatewhereclause=yes name=ship_flag dbname="do.ship_flag" initial="C" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=ship_amount dbname="do.ship_amount" initial="0" )
 column=(type=char(80) update=yes updatewhereclause=yes name=shipto_addr dbname="do.shipto_addr" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=do_cash dbname="do.do_cash" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=do_rate dbname="do.do_rate" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=do_total dbname="do.do_total" initial="0" )
 column=(type=char(60) update=yes updatewhereclause=yes name=rem dbname="do.rem" )
 column=(type=char(20) update=yes updatewhereclause=yes name=tel_no dbname="do.tel_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=telno_cap dbname="do.telno_cap" )
 column=(type=char(12) update=yes updatewhereclause=yes name=do_inv_no dbname="do.inv_no" )
 column=(type=char(12) update=yes updatewhereclause=yes name=driver dbname="do.driver" )
 column=(type=char(12) update=yes updatewhereclause=yes name=do_car_no dbname="do.car_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=do_case dbname="do.do_case" initial="A" values="미수불	C/미수불	A" )
 column=(type=char(13) update=yes updatewhereclause=yes name=do_dr_hp dbname="do.dr_hp" )
 column=(type=char(10) update=yes updatewhereclause=yes name=do_user_id dbname="do.user_id" )
 column=(type=char(1) update=yes updatewhereclause=yes name=shipamt_case dbname="do.shipamt_case" values="현금	C/외상	R/" )
 column=(type=datetime update=yes updatewhereclause=yes name=do_ship_date dbname="do.ship_date" )
 column=(type=char(1) update=yes updatewhereclause=yes name=do_ship_close dbname="do.ship_close" initial="O" )
 column=(type=char(10) update=yes updatewhereclause=yes name=do_close_user dbname="do.close_user" )
 column=(type=char(10) update=yes updatewhereclause=yes name=do_area_no dbname="do.area_no" )
 column=(type=datetime update=yes updatewhereclause=yes name=do_issue_date dbname="do.issue_date" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 column=(type=char(1) updatewhereclause=yes name=do_chk dbname="do_chk" values="전체출고	Y/전체출고	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=sms_yn dbname="do.sms_yn" initial="Y" values="	Y/	N" )
 column=(type=char(1) updatewhereclause=yes name=calc_chk dbname="calc_chk" initial="N" values="	Y/	N" )
 column=(type=char(2) update=yes updatewhereclause=yes name=do_car_gbn dbname="do.car_gbn" )
 column=(type=char(5) update=yes updatewhereclause=yes name=budam_desc dbname="do.budam_desc" )
 column=(type=char(100) update=yes updatewhereclause=yes name=budam_desc2 dbname="do.budam_desc2" )
 column=(type=char(1) update=yes updatewhereclause=yes name=do_ewol dbname="do.ewol" initial="N" values="	Y/	N" )
 column=(type=datetime update=yes updatewhereclause=yes name=time_arrival dbname="do.time_arrival" )
 retrieve="  SELECT do.do_no,   
         do.cust_no,   
         do.spot_code,   
         do.do_date,   
         do.sale_flag,   
         do.do_flag,   
         do.invoice_print,   
         do.curr_code,   
         do.curr_rate,   
         do.fob,   
         do.ship_flag,   
         do.ship_amount,   
         do.shipto_addr,   
         do.do_cash,   
         do.do_rate,   
         do.do_total,   
         do.rem,   
         do.tel_no,   
         do.telno_cap,   
         do.inv_no,   
         do.driver,   
	    do.car_no,
         do.do_case,   
         do.dr_hp,   
         do.user_id,   
         do.shipamt_case,   
         do.ship_date,   
         do.ship_close,   
         do.close_user,   
         do.area_no,   
         do.issue_date,   
         customer.cust_name,   
         scene.scene_desc,   
         ' ' do_chk,   
         do.sms_yn,   
         ' ' calc_chk,   
         do.car_gbn ,
         do.budam_desc,
         do.budam_desc2,
         do.ewol,
         do.time_arrival
    FROM do left outer join customer on do.cust_no = customer.cust_no
                     left outer join scene  on do.spot_code = scene.scene_code
/*
  FROM do,   
         customer,   
         scene  
   WHERE ( do.cust_no *= customer.cust_no) and  
         ( do.spot_code *= scene.scene_code)    

*/
" update="do" updatewhere=0 updatekeyinplace=no )
