compute(band=detail alignment="1" expression="if( aroiinv_aroiinv_rate <> 0, if( aroiinv_curr_code = 'WON', truncate(aroiinv_discount * 1.1, 0), truncate(aroiinv_discount * 1.1, 2)), aroiinv_discount)"border="0" color="0" x="4201" y="4" height="60" width="393" format="#,##0" html.valueishtml="0"  name=tot_dis visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
compute(band=detail alignment="1" expression="aroiinv_aroiinv_cash  +  aroiinv_ship_cost  +  tot_ship +  aroiinv_aroiinv_rate - tot_dis"border="0" color="0" x="4608" y="4" height="60" width="480" format="#,##0.00" html.valueishtml="0"  name=c_amt visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
