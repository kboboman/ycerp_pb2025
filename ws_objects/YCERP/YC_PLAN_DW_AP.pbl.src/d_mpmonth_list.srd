compute(band=detail alignment="1" expression="if(left( item_no ,1) = 'P' and mid(item_no, 3,1) = 'Y' and (mid(item_no, 7,1) = 'A' or mid(item_no, 7,1) = 'B' or mid(item_no, 7,1) = 'C' or mid(item_no, 7,1) = 'D'), order_qty, if(uom = 'M2' or uom = ~"SS~" ,truncate( long(mid( qa ,5,4)) * long(mid(qa,10,4)) * order_qty / 1000000 + 0.000000001, 2), if(uom = 'M', if( order_qty < 0 , truncate(long(mid(  qa , 15,5)) *   order_qty / 1000 - 0.00001,2), truncate(long(mid(  qa , 15,5)) *  order_qty / 1000 + 0.00001,2)), order_qty )))"border="0" color="33554432" x="5568" y="8" height="72" width="320" format="#,##0" html.valueishtml="0"  name=com_qty visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="0" background.color="536870912~tif ( getrow() = currentrow(), rgb(254,252,175), rgb(255, 255, 255) )" )
