$PBExportHeader$d_oiscenerep_ra_new.srd
$PBExportComments$현장별 자재투입현황 DISPLAY(1998/05/16, 정재수)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="79741120" )
summary(height=0 color="16777215" )
footer(height=144 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(11) updatewhereclause=yes name=do_spot_code dbname="spot_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene_desc" )
 column=(type=char(14) updatewhereclause=yes name=do_do_no dbname="do_no" )
 column=(type=long updatewhereclause=yes name=dodet_oi_no dbname="oi_no" )
 column=(type=char(10) updatewhereclause=yes name=dodet_item_no dbname="item_no" )
 column=(type=char(20) updatewhereclause=yes name=dodet_qa dbname="qa" )
 column=(type=char(20) updatewhereclause=yes name=dodet_qa_cust dbname="qa_cust" )
 column=(type=long updatewhereclause=yes name=cost_qa dbname="cost_qa" )
 column=(type=char(2) updatewhereclause=yes name=dodet_uom dbname="uom" )
 column=(type=decimal(2) updatewhereclause=yes name=dodet_ship_qty dbname="ship_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=dodet_price dbname="price" )
 column=(type=decimal(8) updatewhereclause=yes name=calc_qty dbname="calc_qty" )
 column=(type=decimal(8) updatewhereclause=yes name=calc_amt dbname="calc_amt" )
 column=(type=decimal(4) updatewhereclause=yes name=dodet_rate_cash dbname="rate_cash" )
 column=(type=char(14) updatewhereclause=yes name=dodet_sale_no dbname="sale_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="seq_no" )
 column=(type=char(10) updatewhereclause=yes name=dodate1 dbname="dodate1" )
 column=(type=char(10) updatewhereclause=yes name=dodate2 dbname="dodate2" )
 column=(type=datetime updatewhereclause=yes name=do_do_date dbname="do_date" )
 column=(type=char(10) updatewhereclause=yes name=do_fob dbname="fob" )
 column=(type=char(1) updatewhereclause=yes name=do_ship_flag dbname="ship_flag" )
 column=(type=decimal(0) updatewhereclause=yes name=do_ship_amount dbname="ship_amount" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_rate dbname="do_rate" )
 column=(type=char(3) updatewhereclause=yes name=do_curr_code dbname="curr_code" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_cash dbname="do_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_total dbname="do_total" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=char(1) updatewhereclause=yes name=do_shipamt_case dbname="shipamt_case" )
 column=(type=char(1) updatewhereclause=yes name=round dbname="round" )
 retrieve="    SELECT spot_code    = a.spot_code    
       , scene_desc   = a.scene_desc    
       , do_no        = a.do_no        
       , oi_no        = a.oi_no        
       , item_no      = a.item_no      
       , qa           = a.qa           
       , qa_cust      = a.qa_cust      
       , cost_qa      = a.qa_cost      
       , uom          = a.uom          
       , ship_qty     = a.ship_qty     
       , price        = a.price           
       , calc_qty     = a.calc_qty
       , calc_amt     = (case when a.round = 'Y' then 
                                   (case when a.calc_qty < 0 then 
                                              round(a.price * a.calc_qty, 0)
                                         else round(a.price * a.calc_qty + 0.000001, 0) 
                                    end)
                              else (case when a.calc_qty < 0 then 
                                              round(a.price * a.calc_qty, 0, 1)
                                         else round(a.price * a.calc_qty + 0.000001, 0, 1) 
                                    end)                                   
                         end)
       , rate_cash    = a.rate_cash      
       , sale_no      = a.sale_no      
       , seq_no       = a.seq_no
       , dodate1      = (case when a.price = 0 then null else b.dodate end)
       , dodate2      = (case when a.price = 0 then null else c.dodate end)
       , do_date      = a.do_date       
       , fob          = a.fob           
       , ship_flag    = a.ship_flag     
       , ship_amount  = a.ship_amount   
       , do_rate      = a.do_rate       
       , curr_code    = a.curr_code     
       , do_cash      = a.do_cash       
       , do_total     = a.do_total      
       , item_name    = a.item_name     
       , shipamt_case = a.shipamt_case       
       , round        = a.round         
    FROM (
						SELECT do.cust_no
							  , do.spot_code   
							  , scene.scene_desc   
							  , do.do_no   
							  , dodet.oi_no   
							  , dodet.item_no   
							  , dodet.qa   
							  , dodet.qa_cust   
							  , qa_cost     = (case when groupitem.uom = 'M' then substring(dodet.qa,1,13) else dodet.qa end)
							  , dodet.uom   
							  , dodet.ship_qty   
							  , calc_qty    = dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty)             
							  , price       = (case when :as_price = 'Y' then 0 else dodet.price     end)   
							  , rate_cash   = (case when :as_price = 'Y' then 0 else dodet.rate_cash end)   
							  , sale_no     = dodet.sale_no
							  , seq_no      = dodet.seq_no   
							  , do.do_date   
							  , do.fob   
							  , do.ship_flag   
							  , ship_amount = (case when :as_price = 'Y' then 0 else do.ship_amount  end)   
							  , do_rate     = (case when :as_price = 'Y' then 0 else do.do_rate      end)   
							  , do.curr_code   
							  , do_cash     = (case when :as_price = 'Y' then 0 else do.do_cash      end)   
							  , do_total    = (case when :as_price = 'Y' then 0 else do.do_total     end)   
							  , groupitem.item_name   
							  , do.shipamt_case       
							  , customer.round  
						  FROM do   with(nolock)   
							  , dodet   with(nolock)
							  , scene   with(nolock)
							  , groupitem   with(nolock)
							  , customer  with(nolock)
						 WHERE ( do.do_no      = dodet.do_no       )   
							AND ( do.cust_no    = scene.cust_no     )   
							AND ( do.spot_code  = scene.scene_code  )   
							AND ( dodet.item_no = groupitem.item_no )   
							AND ( do.cust_no    = customer.cust_no  )   
							AND ( do.spot_code IN (:as_scene)       )    
							AND (
										  (:as_custno    = '%'   AND do.cust_no LIKE '%'  ) OR
										  (:as_custno    = 'ALL' AND do.cust_no LIKE '%'  ) OR
										  (:as_custno   <> '%'   AND do.cust_no    = :as_custno)
								    )
							AND  ( do.do_date BETWEEN convert(datetime,  :as_sdate +' 00:00:00' ) and convert(datetime,  :as_edate + ' 23:59:59' ) )
							AND ( do.do_no          LIKE :as_area                )
							AND ( customer.salesman LIKE :as_salesman            )
        ) A

        LEFT OUTER JOIN (
											SELECT d.cust_no
												  , d.spot_code
												  , d.item_no
												  , d.qa_cost
												  , d.uom
												  , dodate = substring(convert(char(10),max(d.dodate),111),3,8)
											  FROM (
																 SELECT DISTINCT a1.cust_no
																		, a1.spot_code
																		, b1.item_no
																		, qa_cost = (case when g1.uom = 'M' then substring(b1.qa,1,13) else b1.qa end)
																		, b1.uom
																		, dodate  = a1.do_date
																	FROM do A1 with(nolock)
																		  LEFT OUTER JOIN dodet B1  with(nolock)   ON a1.do_no   = b1.do_no
																		  LEFT OUTER JOIN customer  C1 with(nolock) ON a1.cust_no = c1.cust_no
																		  LEFT OUTER JOIN groupitem G1 with(nolock) ON b1.item_no = g1.item_no
																  WHERE a1.do_date BETWEEN DATEAdd(year, -1, :as_sdate) AND DATEAdd(Day, -1, :as_sdate)
																	 AND ((:as_custno    = '%'   AND a1.cust_no LIKE '%'  ) OR
																			(:as_custno    = 'ALL' AND a1.cust_no LIKE '%'  ) OR
																			(:as_custno   <> '%'   AND a1.cust_no    = :as_custno)
																		  )
																	 AND ( a1.spot_code IN (:as_scene) )    
													 ) d
											 GROUP BY d.cust_no, d.spot_code, d.item_no, d.qa_cost, d.uom
       							 ) B ON a.cust_no = b.cust_no AND a.spot_code = b.spot_code AND a.item_no = b.item_no AND a.qa_cost = b.qa_cost AND a.uom = b.uom

        LEFT OUTER JOIN (
												SELECT d.cust_no
													  , d.item_no
													  , d.qa_cost
													  , d.uom
													  , dodate = substring(convert(char(10),max(d.dodate),111),3,8)
												  FROM (
																 SELECT DISTINCT a1.cust_no
																		, b1.item_no
																		, qa_cost = (case when g1.uom = 'M' then substring(b1.qa,1,13) else b1.qa end)
																		, b1.uom
																		, dodate  = a1.do_date
																	FROM do A1 with(nolock)
																		  LEFT OUTER JOIN dodet B1    with(nolock)  ON a1.do_no   = b1.do_no
																		  LEFT OUTER JOIN customer  C1 with(nolock) ON a1.cust_no = c1.cust_no
																		  LEFT OUTER JOIN groupitem G1 with(nolock) ON b1.item_no = g1.item_no
																  WHERE a1.do_date BETWEEN DATEAdd(year, -1, :as_sdate) AND DATEAdd(Day, -1, :as_sdate)
																	 AND (
																				(:as_custno    = '%'   AND a1.cust_no LIKE '%'  ) OR
																				(:as_custno    = 'ALL' AND a1.cust_no LIKE '%'  ) OR
																				(:as_custno   <> '%'   AND a1.cust_no    = :as_custno)
																			 )
																	 AND ( a1.spot_code IN (:as_scene) )    
														 ) d
															GROUP BY d.cust_no, d.item_no, d.qa_cost, d.uom
       								) C ON a.cust_no = c.cust_no AND a.item_no = c.item_no AND a.qa_cost = c.qa_cost AND a.uom = c.uom

      UNION ALL   
       SELECT    a.spot_code   
					                    , a.scene_desc   
                              , a.do_no
                  					  , a.oi_no   
                  					  , a.item_no   
                  					  , a.qa   
                  					  , a.qa_cust   
                  					  , a.qa_cost    
                  					  , a.uom   
                  					  , a.ship_qty   
                  					  , a.calc_qty
                              , a.calc_amt
                  					  , a.price
                  					  , a.rate_cash
                  					  , a.sale_no 
                  					  , a.seq_no
                               , dodate1      = (case when a.price = 0 then null else b.dodate end)
                               , dodate2      = (case when a.price = 0 then null else c.dodate end)
                  					  , a.do_date   
                  					  , a.fob   
                  					  , a.ship_flag   
                  					  , a.ship_amount
                  					  , a.do_rate 
                  					  , a.curr_code   
                  					  , a.do_cash
                  					  , a.do_total
                  					  , a.item_name   
                  					  , a.shipamt_case       
                  					  , a.round  
from 
(
					 SELECT   b.cust_no
					                    , b.spot_code   
					                    , d.scene_desc   
                              ,  a.do_no
                  					  , '' oi_no   
                  					  , '' item_no   
                  					  , '' qa   
                  					  , '' qa_cust   
                  					  , 0  qa_cost    
                  					  , '' uom   
                  					  , 0 ship_qty  
                              , calc_amt     = sum(
                                                                            case when c.round = 'Y' then 
                                                                                             (case when dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty) < 0 then 
                                                                                                        round(a.price * dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty), 0)
                                                                                                   else round(a.price * dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty) + 0.000001, 0) 
                                                                                              end)
                                                                            else 
                                                                                              (case when dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty) < 0 then 
                                                                                                         round(a.price * dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty), 0, 1)
                                                                                                      else round(a.price * dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty) + 0.000001, 0, 1) 
                                                                                                  end)                                   
                                                                           end
                                                                        ) 
                  					  , 0 calc_qty
                  					  , 0 price
                  					  , 0 rate_cash
                  					  , a.sale_no 
                  					  , null seq_no
                  					  , b.do_date   
                  					  , b.fob   
                  					  , b.ship_flag   
                  					  , ship_amount = (case when :as_price = 'Y' then 0 else b.ship_amount  end)   
                  					  , do_rate     = (case when :as_price = 'Y' then 0 else b.do_rate      end)   
                  					  , b.curr_code   
                  					  , do_cash     =(case when :as_price = 'Y' then 0 else b.do_cash      end)   
                  					  , do_total    = (case when :as_price = 'Y' then 0 else b.do_total     end)   
                  					  , '기타비용(운전비용등)' item_name   
                  					  , b.shipamt_case       
                  					  , c.round  
						  FROM dodet  A with(nolock)
								 inner JOIN do  B WITH (NOLOCK) ON a.do_no   = b.do_no
                 inner join customer c with(nolock) on b.cust_no = c.cust_no
					       inner join  scene  D with(nolock) ON 	( B.cust_no    = D.cust_no )  AND ( B.spot_code  = D.scene_code  )  		  
						  where ( b.do_date BETWEEN convert(datetime,  :as_sdate +' 00:00:00' ) and convert(datetime,  :as_edate + ' 23:59:59' ) )
        				AND ( b.spot_code IS NOT NULL          )    
        					AND ((:as_custno    = '%'   AND b.cust_no LIKE '%'  ) OR
        						  (:as_custno    = 'ALL' AND b.cust_no LIKE '%'  ) OR
        						  (:as_custno   <> '%'   AND b.cust_no    = :as_custno)
        						 )
        					AND ( convert(char(10),b.do_date,111)     BETWEEN :as_sdate AND :as_edate )
        					AND ( b.do_no          LIKE :as_area     )
        					AND ( c.salesman LIKE :as_salesman )
							   AND a.ship_qty > 0
						 group by b.cust_no
					                    , b.spot_code   
					                    , d.scene_desc   
                              ,  a.do_no  
                  					  , a.sale_no
                  					  , b.do_date   
                  					  , b.fob   
                  					  , b.ship_flag   
                  					  , (case when :as_price = 'Y' then 0 else b.ship_amount  end)   
                  					  , (case when :as_price = 'Y' then 0 else b.do_rate      end)   
                  					  , b.curr_code   
                  					  , (case when :as_price = 'Y' then 0 else b.do_cash      end)   
                  					  , (case when :as_price = 'Y' then 0 else b.do_total     end)   
                  					  , b.shipamt_case       
                  					  , c.round  
) a 
     LEFT OUTER JOIN (
											SELECT d.cust_no
												  , d.spot_code
												  , d.item_no
												  , d.qa_cost
												  , d.uom
												  , dodate = substring(convert(char(10),max(d.dodate),111),3,8)
											  FROM (
																 SELECT DISTINCT a1.cust_no
																		, a1.spot_code
																		, b1.item_no
																		, qa_cost = (case when g1.uom = 'M' then substring(b1.qa,1,13) else b1.qa end)
																		, b1.uom
																		, dodate  = a1.do_date
																	FROM do A1 with(nolock)
																		  LEFT OUTER JOIN dodet B1  with(nolock)   ON a1.do_no   = b1.do_no
																		  LEFT OUTER JOIN customer  C1 with(nolock) ON a1.cust_no = c1.cust_no
																		  LEFT OUTER JOIN groupitem G1 with(nolock) ON b1.item_no = g1.item_no
																  WHERE a1.do_date BETWEEN DATEAdd(year, -1, :as_sdate) AND DATEAdd(Day, -1, :as_sdate)
																	 AND ((:as_custno    = '%'   AND a1.cust_no LIKE '%'  ) OR
																			(:as_custno    = 'ALL' AND a1.cust_no LIKE '%'  ) OR
																			(:as_custno   <> '%'   AND a1.cust_no    = :as_custno)
																		  )
																	 AND ( a1.spot_code IN (:as_scene) )    
													 ) d
											 GROUP BY d.cust_no, d.spot_code, d.item_no, d.qa_cost, d.uom
       							 ) B ON a.cust_no = b.cust_no AND a.spot_code = b.spot_code AND a.item_no = b.item_no AND a.qa_cost = b.qa_cost AND a.uom = b.uom

        LEFT OUTER JOIN (
												SELECT d.cust_no
													  , d.item_no
													  , d.qa_cost
													  , d.uom
													  , dodate = substring(convert(char(10),max(d.dodate),111),3,8)
												  FROM (
																 SELECT DISTINCT a1.cust_no
																		, b1.item_no
																		, qa_cost = (case when g1.uom = 'M' then substring(b1.qa,1,13) else b1.qa end)
																		, b1.uom
																		, dodate  = a1.do_date
																	FROM do A1 with(nolock)
																		  LEFT OUTER JOIN dodet B1    with(nolock)  ON a1.do_no   = b1.do_no
																		  LEFT OUTER JOIN customer  C1 with(nolock) ON a1.cust_no = c1.cust_no
																		  LEFT OUTER JOIN groupitem G1 with(nolock) ON b1.item_no = g1.item_no
																  WHERE a1.do_date BETWEEN DATEAdd(year, -1, :as_sdate) AND DATEAdd(Day, -1, :as_sdate)
																	 AND (
																				(:as_custno    = '%'   AND a1.cust_no LIKE '%'  ) OR
																				(:as_custno    = 'ALL' AND a1.cust_no LIKE '%'  ) OR
																				(:as_custno   <> '%'   AND a1.cust_no    = :as_custno)
																			 )
																	 AND ( a1.spot_code IN (:as_scene) )    
														 ) d
															GROUP BY d.cust_no, d.item_no, d.qa_cost, d.uom
       								) C ON a.cust_no = c.cust_no AND a.item_no = c.item_no AND a.qa_cost = c.qa_cost AND a.uom = c.uom

 where  a.do_cash  - a.calc_amt <> 0" arguments=(("as_price", string),("as_sdate", string),("as_edate", string),("as_custno", string),("as_scene", stringlist),("as_area", string),("as_salesman", string))  sort="scene_scene_desc A do_do_date A do_do_no A dodet_oi_no A " )
group(level=1 header.height=0 trailer.height=140 by=("do_spot_code" ) header.color="536870912" trailer.color="536870912" )
group(level=2 header.height=0 trailer.height=136 by=("do_spot_code" , "do_do_date" , "do_do_no" ) header.color="536870912" trailer.color="536870912" )
