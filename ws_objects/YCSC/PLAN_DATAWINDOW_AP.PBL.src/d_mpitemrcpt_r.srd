 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"inaudit~" )  TABLE(NAME=~"item~" )  TABLE(NAME=~"iotype~" )  TABLE(NAME=~"location~" ) COLUMN(NAME=~"inaudit.inaudit_time~") COLUMN(NAME=~"inaudit.inaudit_type~") COLUMN(NAME=~"inaudit.inaudit_item~") COLUMN(NAME=~"inaudit.qa~") COLUMN(NAME=~"inaudit.loc_no~") COLUMN(NAME=~"inaudit.rcpt_qty~") COLUMN(NAME=~"inaudit.destination~") COLUMN(NAME=~"inaudit.issue_qty~") COLUMN(NAME=~"inaudit.cost~") COLUMN(NAME=~"inaudit.inaudit_date~") COLUMN(NAME=~"inaudit.order_no~") COLUMN(NAME=~"inaudit.serial_id~") COLUMN(NAME=~"inaudit.rem~") COLUMN(NAME=~"inaudit.unit_qty~") COLUMN(NAME=~"inaudit.cnt~") COLUMN(NAME=~"iotype.remarks~") COLUMN(NAME=~"item.item_name~") COLUMN(NAME=~"location.loc_name~") COLUMN(NAME=~"item.uom~") COLUMN(NAME=~"item.source~") COLUMN(NAME=~"item.qoh~") COMPUTE(NAME=~"'' as_from~") COMPUTE(NAME=~"'' as_to~")    JOIN (LEFT=~"inaudit.inaudit_item~"    OP =~"=~"RIGHT=~"item.item_no~" )    JOIN (LEFT=~"inaudit.qa~"    OP =~"=~"RIGHT=~"item.qa~" )    JOIN (LEFT=~"inaudit.inaudit_type~"    OP =~"=~"RIGHT=~"iotype.inaudit_type~" )    JOIN (LEFT=~"inaudit.loc_no~"    OP =~"=~"RIGHT=~"location.loc_no~" )) " )
