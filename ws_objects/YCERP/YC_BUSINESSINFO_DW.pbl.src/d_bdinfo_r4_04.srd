release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=136 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=88 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=bdinfodet_project dbname="bdinfodet.project" )
 column=(type=long updatewhereclause=yes name=bdinfodet_square dbname="bdinfodet.square" )
 column=(type=char(7) updatewhereclause=yes name=bdinfodet_floors dbname="bdinfodet.floors" )
 column=(type=datetime updatewhereclause=yes name=bdinfodet_constructiondate dbname="bdinfodet.constructiondate" )
 column=(type=datetime updatewhereclause=yes name=bdinfodet_completiondate dbname="bdinfodet.completiondate" )
 column=(type=char(3) updatewhereclause=yes name=spec_code dbname="bdinfodet2.spec_code" )
 column=(type=decimal(0) updatewhereclause=yes name=quantity dbname="bdinfodet2.quantity" )
 column=(type=decimal(0) updatewhereclause=yes name=prc dbname="bdinfodet2.prc" )
 column=(type=char(34) updatewhereclause=yes name=bd_positon dbname="bd_positon" )
 column=(type=char(4) updatewhereclause=yes name=bdinfodet_buildingcom dbname="bdinfodet.buildingcom" )
 column=(type=char(50) updatewhereclause=yes name=bdinfodet_buildingcomphone dbname="bdinfodet.buildingcomphone" )
 column=(type=char(15) updatewhereclause=yes name=bdinfodet_bulidingphone dbname="bdinfodet.bulidingphone" )
 column=(type=char(4) updatewhereclause=yes name=bdinfodet_builder dbname="bdinfodet.builder" )
 column=(type=char(15) updatewhereclause=yes name=bdinfodet_builderphone dbname="bdinfodet.builderphone" )
 column=(type=char(4) updatewhereclause=yes name=bdinfodet_master dbname="bdinfodet.master" )
 column=(type=char(3) updatewhereclause=yes name=bdinfodet_design_prog dbname="bdinfodet.design_prog" )
 column=(type=char(3) updatewhereclause=yes name=bdinfodet_com_prog dbname="bdinfodet.com_prog" )
 column=(type=char(3) updatewhereclause=yes name=bdinfodet_build_prog dbname="bdinfodet.build_prog" )
 retrieve="  SELECT bdinfodet.project,   
			bdinfodet.square,
			bdinfodet.floors,
			bdinfodet.constructiondate,
			bdinfodet.completiondate,
         bdinfodet2.spec_code,   
         bdinfodet2.quantity,
         bdinfodet2.prc,      
         bd_positon = (  SELECT city_name FROM bdcity where city_code = bdinfodet.city ) + bdinfodet.dong,   
         bdinfodet.buildingcom,
         bdinfodet.buildingcomphone,   
         bdinfodet.bulidingphone,   
			bdinfodet.builder,
			bdinfodet.builderphone,
			bdinfodet.master,
			bdinfodet.design_prog,
			bdinfodet.com_prog,
			bdinfodet.build_prog
     FROM   bdinfodet with(nolock) inner join bdinfo with(nolock) on bdinfodet.build_no = bdinfo.build_no
                                                        left outer join bdinfodet2 with(nolock) on bdinfodet.build_no = bdinfodet2.build_no and bdinfodet.seq = bdinfodet2.seq
   WHERE ( ( bdinfo.build_no = :arg_build_no ) AND  
         ( bdinfodet.std_chk = '1' ) AND  
         ( bdinfodet.project like :as_project ) AND  
         ( bdinfodet.sale_prog like :as_flag ) AND  
/*         ( bdinfodet.fixeddate between :ad_date1 and :ad_date2 ) AND  */
         ( bdinfodet.design_prog like :as_dprog ) AND  
         ( bdinfodet.com_prog like :as_cprog ) AND  
         ( bdinfodet.city like :as_city ) AND  
         ( ( bdinfodet.person like :as_person ) OR  
         ( bdinfodet.dperson like :as_dperson ) OR  
         ( bdinfodet.cperson like :as_cperson ) OR  
         ( bdinfodet.bperson like :as_bperson ) OR  
         ( bdinfodet.sperson like :as_sperson ) ) AND  
         ( ( bdinfodet.div like :as_div ) OR  
         ( bdinfodet.ddiv like :as_ddiv ) OR  
         ( bdinfodet.cdiv like :as_cdiv ) OR  
         ( bdinfodet.bdiv like :as_bdiv ) OR  
         ( bdinfodet.sdiv like :as_sdiv ) ) ) AND    
         ( bdinfodet.organcd like :as_organcd ) AND
         ( bdinfodet.designoffice like :as_dcode ) AND
         ( bdinfodet.buildingcom like :as_buildingcd ) and
			( bdinfodet.builder like :as_scust)
  order by  bdinfodet.project, bd_positon
" arguments=(("arg_build_no", string),("as_div", string),("as_spec", string),("as_project", string),("as_flag", string),("ad_date1", string),("ad_date2", string),("as_dprog", string),("as_cprog", string),("as_city", string),("as_person", string),("as_dperson", string),("as_ddiv", string),("as_cperson", string),("as_cdiv", string),("as_bperson", string),("as_bdiv", string),("as_sperson", string),("as_sdiv", string),("as_organcd", string),("as_dcode", string),("as_buildingcd", string),("as_scust", string)) )
