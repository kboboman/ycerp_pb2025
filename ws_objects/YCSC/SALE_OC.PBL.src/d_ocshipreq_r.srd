 column=(type=char(10) updatewhereclause=yes name=doship_area_no dbname="doship.area_no" )
 column=(type=char(60) updatewhereclause=yes name=doship_rem dbname="doship.rem" )
 column=(type=char(1) updatewhereclause=yes name=doship_process_flag dbname="doship.process_flag" )
