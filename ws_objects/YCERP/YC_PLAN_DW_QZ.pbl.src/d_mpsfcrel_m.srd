 column=(type=char(4) updatewhereclause=yes name=item_color dbname="mpsdet.item_color" )
 column=(type=char(16) update=yes updatewhereclause=yes name=mpsorder_order dbname="mpsdet.mpsorder_order" )
 column=(type=long update=yes updatewhereclause=yes name=order_seq dbname="mpsdet.order_seq" )
 column=(type=char(50) update=yes updatewhereclause=yes name=mpsdet_rem dbname="mpsdet.rem" )
