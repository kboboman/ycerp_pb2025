$PBExportHeader$d_oiitem_r.srd
$PBExportComments$제품별 제품출고현황(1998/5/13,성삼지)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="cust_name" )
 column=(type=char(20) updatewhereclause=yes name=customer_bus_cord dbname="bus_cord" )
 column=(type=char(20) updatewhereclause=yes name=customer_bus_rep dbname="bus_rep" )
 column=(type=char(30) updatewhereclause=yes name=customer_industry_code dbname="industry_code" )
 column=(type=char(11) updatewhereclause=yes name=do_spot_code dbname="spot_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene_desc" )
 column=(type=char(14) updatewhereclause=yes name=do_do_no dbname="do_no" )
 column=(type=datetime updatewhereclause=yes name=do_do_date dbname="do_date" )
 column=(type=datetime updatewhereclause=yes name=do_issue_date dbname="issue_date" )
 column=(type=datetime updatewhereclause=yes name=do_ship_date dbname="ship_date" )
 column=(type=long updatewhereclause=yes name=datecalc dbname="datecalc" )
 column=(type=char(3) updatewhereclause=yes name=do_curr_code dbname="curr_code" )
 column=(type=char(10) updatewhereclause=yes name=dodet_item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=dodet_qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=dodet_uom dbname="uom" )
 column=(type=char(14) updatewhereclause=yes name=dodet_sale_no dbname="sale_no" )
 column=(type=long updatewhereclause=yes name=dodet_oi_no dbname="oi_no" )
 column=(type=decimal(2) updatewhereclause=yes name=dodet_ship_qty dbname="ship_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=com_qty2 dbname="com_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=dodet_price dbname="price" )
 column=(type=decimal(8) updatewhereclause=yes name=amount dbname="amount" )
 column=(type=char(30) updatewhereclause=yes name=loc_name dbname="loc_name" )
 column=(type=char(50) updatewhereclause=yes name=rem dbname="rem" )
 retrieve="  SELECT customer.cust_name       
       , customer.bus_cord        
       , customer.bus_rep         
       , customer.industry_code   
       , do.spot_code     
       , scene.scene_desc  
       , do.do_no         
       , do.do_date       
       , do.issue_date
       , do.ship_date
       , datecalc    = DATEDIFF(month, do.issue_date, do.do_date) 
       , do.curr_code     
       , dodet.item_no    
       , groupitem.item_name      
       , qa          = (case when dodet.qa_cust is not null then dodet.qa_cust else dodet.qa end)
       , dodet.uom        
       , dodet.sale_no    
       , dodet.oi_no      
       , dodet.ship_qty
       , com_qty = dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty)
       , price   = (case when :as_price = 'Y' then 0  else dodet.price end)
       , amount  = (case when :as_price = 'Y' then 0
                         else (case when customer.round = 'Y' then
                                         round(dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty) * dodet.price, 0, 0)
                                    else round(dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty) * dodet.price, 0, 1) 
                               end)
                    end)
       , loc_name= location.loc_name
	  , saledet.rem
    FROM dodet    
         LEFT OUTER JOIN do        ON dodet.do_no = do.do_no
         LEFT OUTER JOIN customer  ON do.cust_no = customer.cust_no
         LEFT OUTER JOIN groupitem ON dodet.item_no = groupitem.item_no
         LEFT OUTER JOIN scene     ON do.spot_code = scene.scene_code
         LEFT OUTER JOIN location  ON dodet.loc_no  = location.loc_no
         LEFT OUTER JOIN saledet  ON dodet.sale_no  = saledet.order_no and dodet.seq_no  = saledet.seq_no
   WHERE ( do.do_date  between :ad_sdate and :ad_edate )
     AND ((:as_custno   = '%' ) OR
          (:as_custno  <> '%' AND do.cust_no = :as_custno)
         )
     AND ((:as_salesman = '%' ) OR
          (customer.salesman  LIKE :as_salesman )
         )
     AND ((:as_gubun   = '%' AND dodet.item_no LIKE '%') OR
          (:as_gubun  <> '%' AND dodet.item_no IN (:as_itemno))
	      )
" arguments=(("as_custno", string),("ad_sdate", date),("ad_edate", date),("as_salesman", string),("as_itemno", stringlist),("as_price", string),("as_gubun", string))  sort="groupitem_item_name A dodet_qa A do_do_date A customer_cust_name A do_spot_code A do_do_no A dodet_oi_no A " )
group(level=1 header.height=0 trailer.height=72 by=("dodet_item_no" ) header.color="536870912" trailer.color="12639424" )
