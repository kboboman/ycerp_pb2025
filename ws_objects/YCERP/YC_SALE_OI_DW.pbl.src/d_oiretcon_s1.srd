release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=880 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes key=yes name=ret_no dbname="ret.ret_no" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="ret.cust_no" )
 column=(type=char(11) updatewhereclause=yes name=spot_code dbname="ret.spot_code" )
 column=(type=char(40) updatewhereclause=yes name=ship_flag dbname="ret.ship_flag" )
 column=(type=char(40) updatewhereclause=yes name=ship_case dbname="ret.ship_case" )
 column=(type=datetime updatewhereclause=yes name=preret_date dbname="ret.preret_date" )
 column=(type=datetime update=yes updatewhereclause=yes name=ret_date dbname="ret.ret_date" )
 column=(type=char(14) updatewhereclause=yes name=sale_no dbname="ret.sale_no" )
 column=(type=char(14) updatewhereclause=yes name=do_no dbname="ret.do_no" )
 column=(type=char(1) updatewhereclause=yes name=ret_agree dbname="ret.ret_agree" initial="1" values="보관	1/타 전용판매	2/폐기	3/기타	4/" )
 column=(type=char(60) updatewhereclause=yes name=agree_desc dbname="ret.agree_desc" )
 column=(type=char(10) updatewhereclause=yes name=approve_team dbname="ret.approve_team" )
 column=(type=char(10) updatewhereclause=yes name=approve_center dbname="ret.approve_center" )
 column=(type=char(10) updatewhereclause=yes name=approve_top dbname="ret.approve_top" )
 column=(type=char(10) updatewhereclause=yes name=create_login dbname="ret.create_login" )
 column=(type=char(1) update=yes updatewhereclause=yes name=process_flag dbname="ret.process_flag" )
 column=(type=char(60) updatewhereclause=yes name=ret_reason1 dbname="ret.ret_reason1" )
 column=(type=char(60) updatewhereclause=yes name=ret_reason2 dbname="ret.ret_reason2" )
 column=(type=char(60) updatewhereclause=yes name=ret_reason3 dbname="ret.ret_reason3" )
 column=(type=char(1) updatewhereclause=yes name=sale_flag dbname="ret.sale_flag" values="내수	D/수출	E/L//C	L/" )
 column=(type=char(10) updatewhereclause=yes name=rcpt_area dbname="ret.rcpt_area" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 retrieve="  SELECT ret.ret_no,   
         ret.cust_no,   
         ret.spot_code,   
         ret.ship_flag,   
         ret.ship_case,   
         ret.preret_date,   
         ret.ret_date,   
         ret.sale_no,   
         ret.do_no,   
         ret.ret_agree,   
         ret.agree_desc,   
         ret.approve_team,   
         ret.approve_center,   
         ret.approve_top,   
         ret.create_login,   
         ret.process_flag,   
         ret.ret_reason1,   
         ret.ret_reason2,   
         ret.ret_reason3,   
         ret.sale_flag,   
         ret.rcpt_area,   
         customer.cust_name,   
         scene.scene_desc  
FROM ret left outer join customer on  ret.cust_no = customer.cust_no
                 left outer join scene on ret.spot_code = scene.cust_no
WHERE ( 
                 ( ret.process_flag like :as_flag ) AND  
	            ( ret.ret_no like :as_order )
               )    
/*
    FROM ret,   
         customer,   
         scene  
   WHERE ( ret.cust_no *= customer.cust_no) and  
         ( ret.spot_code *= scene.cust_no) and  
         ( ( ret.process_flag like :as_flag ) AND  
         ( ret.ret_no like :as_order ) )    


*/" update="ret" updatewhere=0 updatekeyinplace=no arguments=(("as_flag", string),("as_order", string)) )
