 column=(type=char(4099) updatewhereclause=no name=req_desc dbname="pgmreq.req_desc" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"pgmreq~" ) COLUMN(NAME=~"pgmreq.req_date~") COLUMN(NAME=~"pgmreq.req_desc~")WHERE(    EXP1 =~"pgmreq.acc_user~"   OP =~"=~"    EXP2 =~":as_user~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"pgmreq.req_date~"   OP =~"between~"    EXP2 =~":as_start and :as_end~" ) ) ARG(NAME = ~"as_user~" TYPE = string)  ARG(NAME = ~"as_start~" TYPE = date)  ARG(NAME = ~"as_end~" TYPE = date) " arguments=(("as_user", string),("as_start", date),("as_end", date)) )
