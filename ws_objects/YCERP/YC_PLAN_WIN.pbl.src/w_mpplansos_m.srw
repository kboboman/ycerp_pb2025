	RETURN
end if

if MessageBox("확인","A4용지 바코드(대량) 를 출력 하시겠습니까?", Exclamation!, OKCancel!, 2) = 2 then RETURN

// dw_6의 체크한 나머지 행삭제하기
dw6.accepttext()
dw6.setredraw( false )
for ll_row = dw6.rowcount() to 1 step -1
	ls_chk = dw6.object.chk[ll_row]
	if ls_chk = "Y" then
		//
	else
		dw6.deleterow( ll_row )
	end if
next
dw6.groupcalc()
dw6.setredraw( true )

// dw_6에서 dw_10 공유하기
dw6.sharedata( dw_10 )
if dw6.rowcount() < 1 then
	MessageBox("확인","출력대상이 존재하지 않습니다.")
	RETURN
end if

ls_oldprinter = PrintGetPrinter()

//long   ll_place
//string ls_setprn
//string ls_prntrs = PrintGetPrinters()
//
//ll_place   = pos(ls_prntrs, "~n") 
////mle_1.text = PrintGetPrinters()
//ls_setprn  = Left(ls_prntrs, ll_place - 1)
//PrintSetPrinter( ls_setprn )

// 프린트 선택
PrintSetPrinter( ls_setprn )

string ls_left, ls_top

ls_left = em_left.text
ls_top  = em_top.text

dw_10.modify("DataWindow.print.margin.left = 0 ")
dw_10.modify("DataWindow.print.margin.top  = 0 ")
dw_10.modify("DataWindow.print.margin.left = 0 ")
dw_10.modify("DataWindow.print.margin.top  = 0 ")
dw_10.Modify("DataWindow.Print.Orientation=1 DataWindow.Print.Paper.Size=9 Datawindow.Zoom=100")
dw_10.Print()

for ll_row = 1 to dw_10.RowCount()
	ldt_getdate = GF_TODAY()
	ls_saleno =	dw_10.object.sale_no[ll_row]
	ll_seqno  =	dw_10.object.seq_no[ll_row]
	
	// 출력시간
	dw6.object.prt_date[ll_row]	 = ldt_getdate
	UPDATE itemsosdet SET prt_date = getdate() WHERE sale_no = :ls_saleno AND seq_no = :ll_seqno;
next
/////////////////////////////////////////////////////////////////////
PrintSetPrinter( ls_oldprinter )

dw6.reset() ; dw_10.reset()

pb_retrieve.triggerevent( clicked! )
dw6.sharedata( dw_10 )
MessageBox("확인", "출력완료")

end event

type tabpage_3 from userobject within tab_1
