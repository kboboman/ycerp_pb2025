release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=144 color="10789024" )
detail(height=76 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=do_do_no dbname="do_do_no" )
 column=(type=char(1) updatewhereclause=yes name=a_ship_falg dbname="a_ship_falg" )
 column=(type=char(1) updatewhereclause=yes name=b_ship_falg dbname="b_ship_falg" )
 column=(type=datetime updatewhereclause=yes name=log_date dbname="log_date" )
 column=(type=char(60) updatewhereclause=yes name=do_driver dbname="driver" )
 column=(type=char(50) updatewhereclause=yes name=a_budam_desc_name dbname="a_budam_desc_name" )
 column=(type=char(50) updatewhereclause=yes name=b_budam_desc_name dbname="b_budam_desc_name" )
 column=(type=decimal(0) updatewhereclause=yes name=a_ship_amount dbname="a_ship_amount" )
 column=(type=decimal(0) updatewhereclause=yes name=b_ship_amount dbname="b_ship_amount" )
 column=(type=decimal(0) updatewhereclause=yes name=gab dbname="gab" )
 column=(type=char(8) updatewhereclause=yes name=a_ship_flag_name dbname="a_ship_flag_name" )
 column=(type=char(8) updatewhereclause=yes name=b_ship_flag_name dbname="b_ship_flag_name" )
 column=(type=char(4) updatewhereclause=yes name=sip_flag_gab dbname="sip_flag_gab" )
 column=(type=char(1) updatewhereclause=yes name=do_shipamt_case dbname="shipamt_case" values="현금	C/외상	R/" )
 column=(type=char(10) updatewhereclause=yes name=docar_name dbname="docar_name" )
 column=(type=char(40) updatewhereclause=yes name=docar_cargo_name dbname="cargo_name" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene_desc" )
 column=(type=char(1) updatewhereclause=yes name=ship_close dbname="ship_close" values="	C/	O" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_cash dbname="do_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_rate dbname="do_rate" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_total dbname="do_total" )
 column=(type=datetime updatewhereclause=yes name=do_ship_date dbname="ship_date" )
 column=(type=char(10) updatewhereclause=yes name=close_user dbname="close_user" )
 column=(type=char(180) updatewhereclause=yes name=sale_no dbname="sale_no" )
 column=(type=char(20) updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=char(20) updatewhereclause=yes name=edate dbname="edate" )
 column=(type=char(50) updatewhereclause=yes name=car_gbn dbname="car_gbn" )
 column=(type=char(10) updatewhereclause=yes name=salesman dbname="salesman" )
 column=(type=char(10) updatewhereclause=yes name=area dbname="area" )
 column=(type=char(12) updatewhereclause=yes name=customer_register_no dbname="register_no" )
 column=(type=char(10) updatewhereclause=yes name=docar_icube_no dbname="icube_no" )
 retrieve="  select  a.do_no do_do_no, 
              a.ship_flag a_ship_falg,  
              b.ship_flag b_ship_falg,  
              a.log_date log_date,     
              a.driver driver,                    
/*              a.budam_desc a_budam_desc,*/
              c.item_nm a_budam_desc_name,
 /*             b.budam_desc b_budam_desc,*/
              d.item_nm b_budam_desc_name,              
              isnull(a.ship_amount,0) a_ship_amount,
              isnull(b.ship_amount,0) b_ship_amount,
              isnull(a.ship_amount,0) - isnull(b.ship_amount,0) gab,
              (case when a.ship_flag = 'C' THEN '착불'
               when a.ship_flag = 'B' THEN '부담'
               when a.ship_flag = 'D' THEN '대여'
               when a.ship_flag = 'M' THEN '시화방문'
               when a.ship_flag = 'H' THEN '화곡방문'
               when a.ship_flag = 'Y' THEN '반월방문'
               when a.ship_flag = 'A' THEN '공사원가'
               when a.ship_flag = 'R' THEN '재료원가'   
               END) a_ship_flag_name,
              (case when b.ship_flag = 'C' THEN '착불'
               when b.ship_flag = 'B' THEN '부담'
               when b.ship_flag = 'D' THEN '대여'
               when b.ship_flag = 'M' THEN '시화방문'
               when b.ship_flag = 'H' THEN '화곡방문'
               when b.ship_flag = 'Y' THEN '반월방문'
               when b.ship_flag = 'A' THEN '공사원가'
               when b.ship_flag = 'R' THEN '재료원가'   
               END) b_ship_flag_name,              
              (case when a.ship_flag = b.ship_flag and isnull(a.ship_amount,0) - isnull(b.ship_amount,0) = 0 then '동일' else '수정' end) sip_flag_gab,
              a.shipamt_case,
              a.name  docar_name,
              a.cargo_name,
              a.cust_name,
              a.scene_desc,
              a.ship_close,
              a.do_cash,
              a.do_rate,
              a.do_total,
              a.ship_date,
              a.close_user,
              a.sale_no,
              a.sdate,
              a.edate,
              a.car_gbn,
              a.salesman,
              a.area,
              a.register_no,
              a.icube_no                  
from (select * from do_carry  with(nolock)
          where area_no = :as_area + '0001'                                                                                
              and yyyymm = :as_yyyymm
              and seq = :as_seq
          ) a   left outer join    (
                                                                                          SELECT do.do_no                                         
                                                                                               , do.ship_flag                                     
                                                                                               , do.ship_amount                                   
                                                                                               , isnull(do.driver,'') driver
                                                                                               , do.shipamt_case                                  
                                                                                               , docar.name docar_name
                                                                                               , docar.cargo_name                                 
                                                                                               , customer.cust_name                               
                                                                                               , scene.scene_desc                                 
                                                                                               , do.ship_close                                    
                                                                                               , do.do_cash                                       
                                                                                               , do.do_rate                                       
                                                                                               , do.do_total                                      
                                                                                               , do.ship_date                                     
                                                                                               , log_date   = do.log_date                        
                                                                                               , do.close_user                                 
                                                                                               , sale_no    = dbo.uf_getdosaleno(do.do_no)        
                                                                                               , sdate      = (case when :as_sdate = '' then '          ' else :as_sdate end)
                                                                                               , edate      = (case when :as_edate = '' then '          ' else :as_edate end)
                                                                                               , budam_desc = do.budam_desc                    
                                                                                               , car_gbn    = (select item_nm from codemst where type = 'car_gbn' and item_cd = do.car_gbn)
                                                                                               , salesman   = login.user_name
                                                                                               , area       = do.area_no
                                                                                               , customer.register_no                               
                                                                                               , docar.icube_no                  
                                                                                             FROM  do with(nolock) inner join customer with(nolock) on do.cust_no = customer.cust_no
                                                                                                                                      left outer  join scene with(nolock) on do.spot_code  = scene.scene_code
                                                                                                                                      left outer  join docar with(nolock) on do.driver  = docar.driver 
                                                                                                                                      left outer  join login with(nolock) on customer.salesman   = login.user_id
                                                                                             
                                                                                             WHERE  ( ( do.do_no           LIKE :as_area + '%'        ) AND  
                                                                                                   ( convert(char(10),do.ship_date,111)    BETWEEN :as_sdate and :as_edate ) AND  
                                                                                                   ( do.ship_flag         IN ('D' , 'B', 'A', 'R') ) AND  
                                                                                                   ( do.ship_close      LIKE :as_flag ) 
                                                                                                 )    
                                                                                          UNION ALL
                                                                                          SELECT ask_head.ask_no                                  
                                                                                               , ship_flag     = 'B'                               
                                                                                               , ask_head.ship_amount                             
                                                                                               , isnull(ask_head.driver,'') driver
                                                                                               , shipamt_case  = ''                             
                                                                                               , docar.name                                       
                                                                                               , docar.cargo_name                                 
                                                                                               , cust_name     = '(주)유창'                        
                                                                                               , scene_desc    = '시화사업장'                     
                                                                                               , ask_head.ship_close                           
                                                                                               , 0                                                
                                                                                               , 0                                                
                                                                                               , 0                                                
                                                                                               , ask_head.ship_date                               
                                                                                               , log_date      = ask_head.ship_date                    
                                                                                               , ask_head.close_user                           
                                                                                               , ''                                            
                                                                                               , sdate      = :as_sdate
                                                                                               , edate      = :as_edate
                                                                                               , budam_desc = ''                               
                                                                                               , car_gbn    = ''  
                                                                                               , salesman   = ''
                                                                                               , area       = ''
                                                                                               , register_no= ''
                                                                                               , docar.icube_no                                 

                                                                                             FROM ask_head with(nolock) left outer join docar with(nolock) on ask_head.driver  = docar.driver     
                                                                                             WHERE  ( 
                                                                                                               ( :as_area                  = 'S'                   ) and  
                                                                                                               ( convert(char(10),ask_head.ship_date,111)  BETWEEN :as_sdate and :as_edate ) and  
                                                                                                               (  ask_head.ship_close    LIKE :as_flag              ) 
                                                                                                            )    
                                                                                          UNION ALL
                                                                                          SELECT case when do_no is not null then do_no else dbo.uf_getdatestring(doshipetc.etc_date) end   
                                                                                               , doshipetc.ship_flag                              
                                                                                               , doshipetc.ship_amount                            
                                                                                               , isnull(doshipetc.driver,'') driver
                                                                                               , doshipetc.shipamt_case                           
                                                                                               , doshipetc.drv_name                               
                                                                                               , doshipetc.cargo_name                             
                                                                                               , customer.cust_name                               
                                                                                               , scene.scene_desc                                 
                                                                                               , doshipetc.ship_close                             
                                                                                               , 0                                                
                                                                                               , 0                                                
                                                                                               , 0                                                
                                                                                               , doshipetc.etc_date                               
                                                                                               , log_date   = doshipetc.etc_date                    
                                                                                               , doshipetc.user_id                             
                                                                                               , doshipetc.sale_no                             
                                                                                               , sdate      = :as_sdate
                                                                                               , edate      = :as_edate
                                                                                               , budam_desc = ''                               
                                                                                               , car_gbn    = ''
                                                                                               , salesman   = login.user_name
                                                                                               , area       = doshipetc.etc_area
                                                                                               , customer.register_no                               
                                                                                               , docar.icube_no        
                                                                                        from doshipetc with(nolock) inner join customer with(nolock) on doshipetc.cust_no          = customer.cust_no
                                                                                                                        left outer join scene with(nolock) on doshipetc.scene_code   = scene.scene_code
                                                                                                                        left outer join docar with(nolock) on doshipetc.driver            = docar.driver
                                                                                                                        left outer join login with(nolock) on customer.salesman       = login.user_id
                                                                                        WHERE 
                                                                                              ( ( doshipetc.etc_area      LIKE :as_area + '%'        ) and  
                                                                                                   ( convert(char(10),doshipetc.etc_date,111)   BETWEEN :as_sdate and :as_edate ) and  
                                                                                                   ( doshipetc.ship_close    LIKE :as_flag              ) and
                                                                                                   ( doshipetc.doship_req       = 'Y'                   )
                                                                                                 )  
                                         ) b on a.do_no = b.do_no and  a.log_date = b.log_date
/*                                         on a.do_no = b.do_no and  a.log_date = b.log_date and a.ship_flag = b.ship_flag and a.driver = b.driver */
             left outer join   (
                                              SELECT codemst.item_cd, codemst.item_nm
                                                FROM codemst with(nolock)
                                            	where type = 'budam_desc'
                                            	and use_yn = 'Y'
                                       ) c on a.budam_desc = c.item_cd
             left outer join   (
                                              SELECT codemst.item_cd, codemst.item_nm
                                                FROM codemst with(nolock)
                                            	where type = 'budam_desc'
                                            	and use_yn = 'Y'
                                       ) d on b.budam_desc = d.item_cd       
where (case when a.ship_flag = b.ship_flag and isnull(a.ship_amount,0) - isnull(b.ship_amount,0) = 0 then '동일' else '수정' end)  like :as_change
    and  abs(isnull(a.ship_amount,0)) + abs(isnull(b.ship_amount,0)) <> 0 

" arguments=(("as_area", string),("as_yyyymm", string),("as_seq", string),("as_sdate", string),("as_edate", string),("as_flag", string),("as_change", string))  sort="do_ship_date A docar_name A do_do_no A " )
