table(column=(type=datetime update=yes updatewhereclause=yes key=yes name=inaudit_time dbname="inaudit.inaudit_time" )
 column=(type=datetime update=yes updatewhereclause=yes key=yes name=inaudit_date dbname="inaudit.inaudit_date" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=inaudit_item dbname="inaudit.inaudit_item" )
