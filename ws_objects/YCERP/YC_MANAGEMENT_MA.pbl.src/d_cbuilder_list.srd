table(column=(type=char(60) updatewhereclause=yes name=company_name dbname="make_manager.company_name" )
 column=(type=char(100) updatewhereclause=yes name=site_name dbname="make_manager.site_name" )
 column=(type=char(8) updatewhereclause=yes name=order_date dbname="make_manager.order_date" )
 column=(type=char(8) updatewhereclause=yes name=tender_date dbname="make_manager.tender_date" )
 column=(type=long updatewhereclause=yes identity=yes name=id dbname="make_manager.id" )
 retrieve="select company_name, site_name, order_date, tender_date, id
from make_manager
where write_date between :arg_fr_date and :arg_to_date" arguments=(("arg_fr_date", string),("arg_to_date", string))  sort="company_name A site_name A " )
