table(column=(type=char(10) updatewhereclause=yes name=user_name dbname="login.user_name" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="login.user_id" )
 retrieve="  SELECT login.user_name,   
         login.user_id  
    FROM login  
   WHERE ( login.team_code = '93200' or  login.team_code = '93300'  ) AND  
         ( login.user_id not in ( select user_id from sfcdayuser
											  where area_no = :as_area
												 and wc_no = :as_wc
												 and sfc_date = :ad_date ) )    
" arguments=(("as_area", string),("as_wc", string),("ad_date", date))  sort="user_name A " )
text(band=header alignment="2" text="성명" border="6" color="33554432" x="9" y="12" height="60" width="320" html.valueishtml="0"  name=user_name_t visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="67108864" )
column(band=detail id=1 alignment="2" tabsequence=32766 border="0" color="33554432~tif ( getrow() = currentRow(), rgb(255,255,128), rgb(0,0,0))" x="9" y="4" height="60" width="320" format="[general]" html.valueishtml="0"  name=user_name visible="1" edit.limit=0 edit.case=any edit.autoselect=yes edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="2" font.pitch="2" font.charset="129" background.mode="0" background.color="1073741824~tif ( getrow() = currentRow(), rgb(0,0,255), rgb(255,255,255))" )
