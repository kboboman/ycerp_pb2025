table(column=(type=char(14) update=yes updatewhereclause=yes key=yes name=etcout_no dbname="etcout.etcout_no" )
 column=(type=long update=yes updatewhereclause=yes key=yes identity=yes name=seq dbname="etcout.seq" )
 column=(type=datetime update=yes updatewhereclause=yes name=etcout_date dbname="etcout.etcout_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=loc_no dbname="etcout.loc_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="etcout.item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="GroupItem.item_name" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="etcout.qa" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=qty dbname="etcout.qty" initial="0" )
 column=(type=char(2) update=yes updatewhereclause=yes name=etc_kind dbname="etcout.etc_kind" )
 column=(type=char(10) update=yes updatewhereclause=yes name=user_id dbname="etcout.user_id" )
 column=(type=datetime update=yes updatewhereclause=yes name=user_date dbname="etcout.user_date" )
 column=(type=char(50) update=yes updatewhereclause=yes name=rem dbname="etcout.rem" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="GroupItem.uom" )
 retrieve="  SELECT  etcout.etcout_no     
			 , etcout.seq           
			 , etcout.etcout_date   
			 , etcout.loc_no        
			 , etcout.item_no
			 , groupitem.item_name       
			 , etcout.qa            
			 , etcout.qty           
			 , etcout.etc_kind          
			 , etcout.user_id       
			 , etcout.user_date     
			 , etcout.rem           
			 , groupitem.uom  
    FROM etcout left outer join  groupitem  on etcout.item_no = groupitem.item_no 
     WHERE  ((etcout.etcout_no   = :as_etcoutno) AND (etcout.seq = :ai_seq))    
" update="etcout" updatewhere=0 updatekeyinplace=no arguments=(("as_etcoutno", string),("ai_seq", number)) )
