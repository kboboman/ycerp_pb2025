 column=(type=datetime updatewhereclause=yes name=input_date dbname="input_date" )
 column=(type=char(12) updatewhereclause=yes name=input_user dbname="input_user" )
 column=(type=datetime updatewhereclause=yes name=update_date dbname="update_date" )
 column=(type=char(12) updatewhereclause=yes name=update_user dbname="update_user" )
 retrieve="select 
	 a.work_day			work_day		 
	,a.area_no			area_no		
	,a.area_name		area_name	 
	,a.work_no			work_no                    
	,a.work_nm			work_nm                   
	,a.work_no_insa	work_no_insa            
	,a.user_id			user_id                     
	,a.user_nm			user_nm                  
	,a.timewage			timewage                 
	,a.day_timewage	day_timewage           
	,a.day_worktime	day_worktime
	,a.night_timewage	night_timewage     
	,a.night_worktime	night_worktime   
	,a.input_date		input_date                
	,a.input_user		input_user                
	,a.update_date		update_date             
	,a.update_user		update_user             
from 
	sfcworkman_timewage a
where
	a.work_day	= :as_day
and
	a.area_no	like :as_area
and
	a.work_no	like :as_work
order by 
	a.work_nm, a.user_nm" arguments=(("as_day", string),("as_area", string),("as_work", string)) )
