$PBExportHeader$d_ipcustpur1_t2.srd
$PBExportComments$물품별구매내역조회(집계)(2002/02/08,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=long updatewhereclause=yes name=cyear dbname="cyear" )
 column=(type=long updatewhereclause=yes name=cmonth dbname="cmonth" )
 column=(type=datetime updatewhereclause=yes name=s dbname="s" )
 column=(type=datetime updatewhereclause=yes name=e dbname="e" )
 column=(type=char(10) updatewhereclause=yes name=insp_supp_no dbname="insp.supp_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(10) updatewhereclause=yes name=groupitem_item_no dbname="groupitem.item_no" )
 column=(type=char(20) updatewhereclause=yes name=inspdet_qa dbname="inspdet.qa" )
 column=(type=char(2) updatewhereclause=yes name=inspdet_uom dbname="inspdet.uom" )
 column=(type=decimal(2) updatewhereclause=yes name=crcpt_qty dbname="crcpt_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=com_qty dbname="com_qty" )
 column=(type=decimal(8) updatewhereclause=yes name=camt dbname="camt" )
 retrieve="  SELECT cyear     = datepart(year,  insp_date)             
       , cmonth    = datepart(month, insp_date)             
       , s         = convert(smalldatetime, :ad_date1, 111)
       , e         = convert(smalldatetime, :ad_date2, 111)
       , insp.supp_no
       , groupitem.item_name                                
       , groupitem.item_no                                  
       , inspdet.qa                                         
       , inspdet.uom                                        
       , crcpt_qty = sum(inspdet.rcpt_qty)               
       , com_qty   = sum(inspdet.comqty)                 
       , camt      = sum(inspdet.comqty * inspdet.price)  
    FROM groupitem   
       , inspdet     
       , insp        
       , supp  
   WHERE ( groupitem.item_no      = inspdet.item_no )  
     AND ( insp.insp_no           = inspdet.insp_no )  
     AND ( insp.supp_no           = supp.supp_no    )  
     AND ( ( inspdet.item_no      LIKE :as_item                 ) AND  
           ( insp.insp_date    BETWEEN :ad_date1 and :ad_date2  ) AND
           ( ( inspdet.pur_no     LIKE :as_area + ~"%~"             ) or
             ( :as_area   = 'S'    and inspdet.pur_no LIKE 'PUR%' )
           )
         )       
   GROUP BY datepart(year, insp_date) 
          , datepart(month,insp_date) 
          , insp.supp_no
          , groupitem.item_name          
          , groupitem.item_no            
          , inspdet.qa
          , inspdet.uom
" arguments=(("as_item", string),("ad_date1", date),("ad_date2", date),("as_area", string))  sort="cyear A cmonth A groupitem_item_name A inspdet_qa A " )
