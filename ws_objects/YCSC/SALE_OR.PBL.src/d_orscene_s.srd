compute(band=footer alignment="2" expression="count(  cust_no  for all )"border="0" color="0" x="9" y="8" height="68" width="1349" format="#,##0" html.valueishtml="0"  name=compute_1 visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="553648127" )
