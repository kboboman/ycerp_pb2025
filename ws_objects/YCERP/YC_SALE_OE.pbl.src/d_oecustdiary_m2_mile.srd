release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=92 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=diary_date dbname="cust_diary.diary_date" )
 column=(type=char(10) updatewhereclause=yes name=cust_diary_salesman dbname="cust_diary.salesman" )
 column=(type=long updatewhereclause=yes name=mileage dbname="cust_diary.mileage" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="login.user_name" )
 retrieve="SELECT distinct a.diary_date
     , a.salesman
     , a.mileage
     , login.user_name
  FROM cust_diary a
       LEFT OUTER JOIN login ON a.user_id = login.user_id
 WHERE ( a.diary_date  BETWEEN :as_sdate AND :as_edate )
   AND ( a.mileage     > 0                             )
   AND ( :as_custno   <> '%' AND a.cust_no     = :as_custno
         OR           
         :as_custno    = '%' AND a.cust_no  LIKE :as_custno
       )
   AND ( :as_salesman <> '%' AND a.salesman    = :as_salesman
         OR
         :as_salesman  = '%' AND a.salesman LIKE :as_salesman
       )
" arguments=(("as_custno", string),("as_sdate", string),("as_edate", string),("as_salesman", string))  sort="diary_date D user_name A " )
