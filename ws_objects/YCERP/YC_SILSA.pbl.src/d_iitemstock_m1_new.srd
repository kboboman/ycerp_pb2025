text(band=header alignment="2" text="요청출고" border="6" color="0" x="4859" y="8" height="60" width="288" html.valueishtml="0"  name=ask_out_qty_t visible="1"  font.face="굴림체" font.height="-10" font.weight="700"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="12639424" )
text(band=header alignment="2" text="대체출고" border="6" color="0" x="5157" y="8" height="60" width="288" html.valueishtml="0"  name=change_out_qty_t visible="1"  font.face="굴림체" font.height="-10" font.weight="700"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="12639424" )
text(band=header alignment="2" text="이동출고" border="6" color="0" x="5454" y="8" height="60" width="288" html.valueishtml="0"  name=move_out_qty_t visible="1"  font.face="굴림체" font.height="-10" font.weight="700"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="12639424" )
