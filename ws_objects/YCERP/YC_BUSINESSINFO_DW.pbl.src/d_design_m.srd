table(column=(type=char(2) update=yes updatewhereclause=yes key=yes name=gubun dbname="sale_bogo_code.gubun" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=code dbname="sale_bogo_code.code" )
 column=(type=char(50) update=yes updatewhereclause=yes name=code_name dbname="sale_bogo_code.code_name" )
 column=(type=char(10) update=yes updatewhereclause=yes name=salesman1 dbname="sale_bogo_code.salesman1" )
 column=(type=char(10) update=yes updatewhereclause=yes name=salesman2 dbname="sale_bogo_code.salesman2" )
 column=(type=char(8) update=yes updatewhereclause=yes name=write_date dbname="sale_bogo_code.write_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=write_user_id dbname="sale_bogo_code.write_user_id" )
 column=(type=char(10) updatewhereclause=yes name=write_user_name dbname="V_PRESALE_ALL_USER.write_user_name" )
 column=(type=char(1) update=yes updatewhereclause=yes name=end_yn dbname="sale_bogo_code.end_yn" values="사용	Y/종료	N/" )
 column=(type=char(255) update=yes updatewhereclause=yes name=special dbname="sale_bogo_code.special" )
 column=(type=char(100) update=yes updatewhereclause=yes name=address dbname="sale_bogo_code.address" )
 column=(type=char(20) update=yes updatewhereclause=yes name=ceo dbname="sale_bogo_code.ceo" )
 retrieve="select  a.gubun,
            a.code,
            a.code_name, 
            a.salesman1, 
            a.salesman2, 
            a.write_date, 
            a.write_user_id,
            b.user_name write_user_name,
            a.end_yn,
            a.special,
            a.address,
            a.ceo
from sale_bogo_code a LEFT OUTER JOIN V_PRESALE_ALL_USER b on a.write_user_Id = b.user_id
where a.code = :as_code
and a.gubun = :as_gubun" update="sale_bogo_code" updatewhere=0 updatekeyinplace=no arguments=(("as_code", string),("as_gubun", string)) )
