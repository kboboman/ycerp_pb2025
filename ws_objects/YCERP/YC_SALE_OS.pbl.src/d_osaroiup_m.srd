compute(band=detail alignment="1" expression="if ( mod( ship_cost, 10) >= 0.5, ( ship_cost / 10 + 0.5 ) + ship_cost , truncate(ship_cost / 10, 1) + ship_cost )"border="5" color="0" x="2021" y="88" height="60" width="512" format="#,##0" html.valueishtml="0"  name=tot_ship visible="1"  font.face="굴림체" font.height="-10" font.weight="700"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="79416533" )
