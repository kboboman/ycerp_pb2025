$PBExportHeader$d_cditemcustitem_m.srd
$PBExportComments$물품별 거래처 표준단가 관리(2002/01/10,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" values="	Y/	N" )
 column=(type=char(4) updatewhereclause=yes key=yes name=custitem_cust_no dbname="custitem.cust_no" )
 column=(type=char(10) updatewhereclause=yes key=yes name=custitem_item_no dbname="custitem.item_no" )
 column=(type=char(20) updatewhereclause=yes key=yes name=custitem_qa dbname="custitem.qa" )
 column=(type=char(2) updatewhereclause=yes name=custitem_uom dbname="custitem.uom" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=price dbname="custitem.price" )
 column=(type=char(30) update=yes updatewhereclause=yes name=custitem_rem dbname="custitem.rem" )
 column=(type=decimal(4) updatewhereclause=yes name=itemcost_price dbname="itemcost.price" )
 column=(type=decimal(0) updatewhereclause=yes name=pre_cost dbname="custitem.pre_cost" )
 column=(type=decimal(0) updatewhereclause=yes name=custitem_std_cost dbname="custitem.std_cost" )
 column=(type=datetime updatewhereclause=yes name=sys_date dbname="custitem.sys_date" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="custitem.user_id" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=decimal(0) updatewhereclause=yes name=cprice dbname="cprice" )
 retrieve="  SELECT chk   = 'N'
       , custitem.cust_no     
       , custitem.item_no     
       , custitem.qa          
       , custitem.uom         
       , custitem.price       
       , custitem.rem         
       , itemcost.price       
       , custitem.pre_cost    
       , custitem.std_cost    
       , custitem.sys_date    
       , custitem.user_id     
       , customer.cust_name   
       , cprice = custitem.price  
    FROM custitem left outer join customer on custitem.cust_no = customer.cust_no
                               inner join itemcost   on custitem.item_no  = itemcost.item_no  AND custitem.qa       = itemcost.qa
   WHERE ( custitem.item_no  = :as_item         )   

/*
    FROM custitem   
       , itemcost   
       , customer   
   WHERE ( custitem.cust_no *= customer.cust_no )   
     AND ( custitem.item_no  = itemcost.item_no )   
     AND ( custitem.qa       = itemcost.qa      )   
     AND ( custitem.item_no  = :as_item         )   
*/
" update="custitem" updatewhere=0 updatekeyinplace=no arguments=(("as_item", string))  sort="custitem_cust_no A custitem_qa A " )
