detail(height=76 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=sale_cust_no dbname="cust_no" initial=" " )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="cust_name" )
 column=(type=char(11) updatewhereclause=yes name=sale_scene_code dbname="scene_code" initial=" " )
 column=(type=char(14) updatewhereclause=yes name=sale_order_no dbname="order_no" initial=" " )
 column=(type=char(1) updatewhereclause=yes name=sale_sale_flag dbname="sale_flag" initial=" " values="내수	D/수출	E/L//C	L/" )
 column=(type=char(3) updatewhereclause=yes name=sale_curr_code dbname="curr_code" initial=" " )
 column=(type=datetime updatewhereclause=yes name=sale_order_date dbname="order_date" initial=" " )
 column=(type=datetime updatewhereclause=yes name=sale_due_date dbname="due_date" initial=" " )
 column=(type=long updatewhereclause=yes name=saledet_seq_no dbname="seq_no" )
 column=(type=char(10) updatewhereclause=yes name=saledet_item_no dbname="item_no" )
 column=(type=char(20) updatewhereclause=yes name=saledet_qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=saledet_uom dbname="uom" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_order_qty dbname="order_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_acc_qty dbname="acc_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=saledet_price dbname="saledet_price" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene_desc" )
 column=(type=char(10) updatewhereclause=yes name=c_start dbname="c_start" )
 column=(type=char(10) updatewhereclause=yes name=c_end dbname="c_end" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=char(8) updatewhereclause=yes name=c_text dbname="c_text" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_rlse_qty dbname="rlse_qty" )
 column=(type=char(30) updatewhereclause=yes name=sale_ship_flag dbname="ship_flag" )
 column=(type=char(10) updatewhereclause=yes name=color_color_name dbname="color_name" )
 column=(type=char(14) updatewhereclause=yes name=sale_order_no dbname="order_no" )
 retrieve="  SELECT distinct cust_no     = sale.cust_no   
       , cust_name   = c.cust_name   
       , scene_code  = sale.scene_code   
       , order_no    = sale.order_no   
       , sale_flag   = sale.sale_flag   
       , curr_code   = sale.curr_code   
       , order_date  = sale.order_date   
       , due_date    = sale.due_date   
       , seq_no      = saledet.seq_no   
       , item_no     = saledet.item_no   
       , qa          = saledet.qa   
       , uom         = saledet.uom   
       , order_qty   = saledet.order_qty   
       , acc_qty     = saledet.acc_qty   
       , saledet_price = saledet.price
       , scene_desc  = s.scene_desc   
       , c_start     = (case when :as_sdate = '' then space(10) else :as_sdate end)
       , c_end       = (case when :as_edate = '' then space(10) else :as_edate end)
       , item_name   = g.item_name
       , c_text      = '        '   
       , rlse_qty    = saledet.rlse_qty   
       , ship_flag   = dbo.uf_getshipflag(sale.ship_flag)
       , color_name  = color.color_name
			 , order_no    = sale.order_no
    FROM UF_MyCustomers( :as_salesman ) M
         LEFT OUTER JOIN customer   C ON m.cust_no     = c.cust_no
/*         LEFT OUTER JOIN sale         ON sale.cust_no  = c.cust_no  AND sale.open_close <> 'C' 한도초과 */
         LEFT OUTER JOIN sale         ON sale.cust_no  = c.cust_no  AND sale.open_close = 'O'
         LEFT OUTER JOIN saledet      ON sale.order_no = saledet.order_no
         LEFT OUTER JOIN groupitem  G ON saledet.item_no = g.item_no    
         LEFT OUTER JOIN scene      S ON sale.scene_code = s.scene_code
         LEFT OUTER JOIN color        ON saledet.color   = color.color_code 
   WHERE ( sale.order_no      LIKE :as_area         )   
     AND ( sale.order_date BETWEEN :as_sdate AND :as_edate )
     AND ((:as_team  = '%' AND m.cust_no   LIKE '%' ) OR 
          (:as_team <> '%' AND m.salesman     = :as_salesman )
         )
     AND ((:as_custno  = '%'   AND m.cust_no   LIKE '%'  ) OR 
          (:as_custno  = 'ALL' AND m.cust_no   LIKE '%'  ) OR 
          (:as_custno <> 'ALL' AND m.cust_no      = :as_custno )
         )
" arguments=(("as_area", string),("as_custno", string),("as_sdate", string),("as_edate", string),("as_salesman", string),("as_team", string))  sort="customer_cust_name A sale_scene_code A sale_order_no A saledet_seq_no A sale_order_date A " )
group(level=1 header.height=0 trailer.height=76 by=("customer_cust_name" , "sale_scene_code" , "sale_order_no" ) header.color="536870912" trailer.color="12639424" )
