$PBExportComments$담당자별item실사재고추가(2001/10/08,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=decimal(4) updatewhereclause=yes name=eom_qoh dbname="eom_qoh" )
 column=(type=char(2) updatewhereclause=yes name=groupitem_uom dbname="groupitem.uom" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 retrieve="  SELECT item_no = itemloc.item_no,   
         qa = itemloc.qa,   
        	eom_qoh = itemloc.qoh,  
         groupitem.uom,   
         groupitem.item_name  
    FROM groupitem ,   
         itemloc,
			item  
   WHERE ( itemloc.item_no = groupitem.item_no ) and  
			( itemloc.qoh <> 0 ) and
			( itemloc.item_no = item.item_no ) and
			( itemloc.qa = item.qa ) and
         ( item.use_flag <> 'C' ) and
         ( ( itemloc.loc_no = :as_loc ) )    
" arguments=(("as_loc", string))  sort="groupitem_item_name A qa A " )
