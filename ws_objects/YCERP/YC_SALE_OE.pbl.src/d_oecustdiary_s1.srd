table(column=(type=datetime updatewhereclause=yes name=diary_date dbname="custdiary.diary_date" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=emp_no dbname="custdiary.emp_no" )
 column=(type=long updatewhereclause=yes key=yes name=seq_no dbname="custdiary.seq_no" )
 column=(type=char(1) updatewhereclause=yes key=yes name=urgent dbname="custdiary.urgent" values="	Y/	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=process_flag dbname="custdiary.process_flag" values="	Y/	N" )
 column=(type=char(100) updatewhereclause=yes name=desc1 dbname="custdiary.desc1" )
 column=(type=char(10) updatewhereclause=yes name=cust_no dbname="custdiary.cust_no" )
 column=(type=char(60) updatewhereclause=yes name=cust_name dbname="custdiary.cust_name" )
 column=(type=char(60) updatewhereclause=yes name=bdcust_name dbname="custdiary.bdcust_name" )
 column=(type=char(30) updatewhereclause=yes name=team_team_name dbname="team.team_name" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name dbname="login.user_name" )
 column=(type=char(1) updatewhereclause=yes name=chk_team dbname="chk_team" values="	Y/	N" )
 column=(type=char(10) update=yes updatewhereclause=yes name=approve_team dbname="custdiary.approve_team" )
 column=(type=char(10) update=yes updatewhereclause=yes name=approve_top dbname="custdiary.approve_top" )
 column=(type=char(1) updatewhereclause=yes name=prt_chk dbname="prt_chk" initial="N" values="	Y/	N" )
 retrieve="  SELECT custdiary.diary_date,   
         custdiary.emp_no,   
         custdiary.seq_no,   
         custdiary.urgent,   
         custdiary.process_flag,   
         custdiary.desc1 ,   
         custdiary.cust_no,   
         custdiary.cust_name,   
         custdiary.bdcust_name,   
         team.team_name,   
         login.user_name,   
         chk_team = ( case when ( custdiary.approve_team is null ) or (  custdiary.approve_team = '') then 'N' else 'Y' end ),   
         custdiary.approve_team,   
         custdiary.approve_top,
			' ' as prt_chk  
   from custdiary left outer join team on custdiary.team_code = team.team_code
		 		   left outer join login on custdiary.emp_no = login.user_id 
   WHERE       ( ( custdiary.emp_no like :as_user ) AND  
         (('%' = :as_chk) OR ( custdiary.process_flag = :as_chk ) ) AND
			( ( ( custdiary.cust_name like :as_cust ) or ( :as_cust = '%' and custdiary.cust_name is null ) ) 
				and ( ( custdiary.bdcust_name like :as_com ) or ( :as_com = '%' and custdiary.bdcust_name is null ) )
				and ( ( custdiary.desc1 like :as_title ) or ( :as_title = '%' and custdiary.desc1 is null ) ) ) AND
			( ( (:as_all = 'Y') OR ( :as_all = 'N' AND custdiary.diary_date BETWEEN :ad_start and :ad_end) ) ) )
/*
    FROM custdiary,   
         login,
			team
   WHERE ( custdiary.emp_no *= login.user_id) and  
         ( custdiary.team_code *= team.team_code) and  
         ( ( custdiary.emp_no like :as_user ) AND  
         (('%' = :as_chk) OR ( custdiary.process_flag = :as_chk ) ) AND
			( ( ( custdiary.cust_name like :as_cust ) or ( :as_cust = '%' and custdiary.cust_name is null ) ) 
				and ( ( custdiary.bdcust_name like :as_com ) or ( :as_com = '%' and custdiary.bdcust_name is null ) )
				and ( ( custdiary.desc1 like :as_title ) or ( :as_title = '%' and custdiary.desc1 is null ) ) ) AND
			( ( (:as_all = 'Y') OR ( :as_all = 'N' AND custdiary.diary_date BETWEEN :ad_start and :ad_end) ) ) )

*/" update="custdiary" updatewhere=0 updatekeyinplace=yes arguments=(("as_user", string),("as_chk", string),("as_cust", string),("as_com", string),("ad_start", date),("ad_end", date),("as_all", string),("as_title", string))  sort="team_team_name A login_user_name A diary_date D " )
