$PBExportHeader$d_bdinfodet2_m_design.srd
release 8;
datawindow(units=0 timer_interval=0 color=67108864 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=88 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=build_no dbname="bdinfodet2.build_no" )
 column=(type=decimal(0) update=yes updatewhereclause=yes key=yes name=seq dbname="bdinfodet2.seq" )
 column=(type=char(3) update=yes updatewhereclause=yes key=yes name=spec_code dbname="bdinfodet2.spec_code" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=seq_no dbname="bdinfodet2.seq_no" )
 column=(type=char(3) update=yes updatewhereclause=yes name=uom dbname="bdinfodet2.uom" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=quantity dbname="bdinfodet2.quantity" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=prc dbname="bdinfodet2.prc" )
 retrieve="  SELECT b.build_no,   
         b.seq,   
         b.spec_code,
			b.seq_no,
         b.uom,   
         b.quantity,   
         b.prc  
    FROM bdinfodet2 b,
			bdspec c
where b.spec_code = c.spec_code
and	c.spec_gubun = 'D'   
and	b.build_no = :as_build_no
and 	b.seq = :adc_seq 
" update="bdinfodet2" updatewhere=1 updatekeyinplace=yes arguments=(("as_build_no", string),("adc_seq", number))  sort="build_no A seq A seq_no A " )
