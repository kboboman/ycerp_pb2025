$PBExportComments$반품요청서확인관리반품번호선택(2000/04/27,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=67108864 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=72 color="536870912" )
summary(height=0 color="536870912" )
footer(height=68 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=order_no dbname="ret.ret_no" )
 column=(type=datetime updatewhereclause=yes name=preret_date dbname="ret.preret_date" )
 column=(type=char(14) updatewhereclause=yes name=sale_no dbname="ret.sale_no" )
 column=(type=char(1) updatewhereclause=yes name=process_flag dbname="ret.process_flag" values="	I/	Y" )
 column=(type=char(10) updatewhereclause=yes name=approve_top dbname="ret.approve_top" )
 column=(type=char(10) updatewhereclause=yes name=approve_team dbname="ret.approve_team" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene.scene_desc" )
 retrieve="  SELECT ret.ret_no,   
         ret.preret_date,   
         ret.sale_no,   
         ret.process_flag,   
         ret.approve_top,   
         ret.approve_team  ,
         customer.cust_name,
         scene.scene_desc
    FROM ret  
         left outer join sale     on ret.sale_no = sale.order_no
         left outer join customer on sale.cust_no = customer.cust_no
         left outer join scene    on sale.cust_no = scene.cust_no and sale.scene_code = scene.scene_code  
   WHERE ret.process_flag like :as_flag    
" arguments=(("as_flag", string))  sort="order_no A " )
