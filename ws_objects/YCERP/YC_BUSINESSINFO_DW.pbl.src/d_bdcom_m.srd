 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"bdcom~" ) COLUMN(NAME=~"bdcom.comcode~") COLUMN(NAME=~"bdcom.address~") COLUMN(NAME=~"bdcom.damdang~") COLUMN(NAME=~"bdcom.phone~") COLUMN(NAME=~"bdcom.comname~") COLUMN(NAME=~"bdcom.fax_no~") COLUMN(NAME=~"bdcom.rem1~") COLUMN(NAME=~"bdcom.rem2~") COLUMN(NAME=~"bdcom.rem3~") COLUMN(NAME=~"bdcom.per_cnt~")WHERE(    EXP1 =~"bdcom.comcode~"   OP =~"like~"    EXP2 =~":as_cd~" ) ) ARG(NAME = ~"as_cd~" TYPE = string) " update="bdcom" updatewhere=0 updatekeyinplace=no arguments=(("as_cd", string)) )
