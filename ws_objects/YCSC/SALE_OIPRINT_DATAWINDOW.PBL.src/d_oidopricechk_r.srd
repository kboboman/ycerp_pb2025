table(column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=datetime updatewhereclause=yes name=do_date dbname="do_date" )
 column=(type=decimal(0) updatewhereclause=yes name=min_price dbname="min_price" )
 column=(type=decimal(4) updatewhereclause=yes name=do_cost dbname="do_cost" )
 column=(type=char(2) updatewhereclause=yes name=catcost dbname="catcost" )
 column=(type=decimal(0) updatewhereclause=yes name=scost dbname="scost" )
 column=(type=decimal(0) updatewhereclause=yes name=ccost dbname="ccost" )
 column=(type=decimal(4) updatewhereclause=yes name=std_cost dbname="std_cost" )
 column=(type=char(2) updatewhereclause=yes name=price_level dbname="price_level" )
 column=(type=char(14) updatewhereclause=yes name=do_no dbname="do_no" )
 column=(type=long updatewhereclause=yes name=oi_no dbname="oi_no" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(10) updatewhereclause=yes name=saler_user dbname="saler_user" )
 retrieve="  SELECT item_no      = a.item_no
       , item_name    = a.item_name
       , qa           = a.do_qa
       , uom          = a.uom
       , do_date      = ab.dodate	
       , min_price    = dbo.UF_GetCustPRICE(a.cust_no, a.item_no, a.do_qa)
       , do_cost      = a.price
       , catcost      = (case when a.price > dbo.UF_GetCustPRICE(a.cust_no, a.item_no, a.do_qa) then '▲'
                              when a.price < dbo.UF_GetCustPRICE(a.cust_no, a.item_no, a.do_qa) then '▼'
                              when a.price = dbo.UF_GetCustPRICE(a.cust_no, a.item_no, a.do_qa) then '〓'
                              when dbo.UF_GetCustPRICE(a.cust_no, a.item_no, a.do_qa) = 0       then '●'
                         end)
       , scost        = isnull(b.price,0)
       , ccost        = isnull(f.price,0)
       , std_cost     = isnull(h.price,0)
       , price_level  = isnull(a.price_level,'')
       , do_no        = a.do_no
       , oi_no        = a.oi_no
       , cust_no      = a.cust_no
       , cust_name    = a.cust_name
       , user_name    = a.user_name
       , saler_user   = a.saler_user
    FROM (
         SELECT item_no      = dodet.item_no
              , item_name    = g.item_name
              , do_qa        = dodet.qa
              , uom          = g.uom
              , price        = dodet.price
              , do_no        = do.do_no
              , oi_no        = dodet.oi_no
              , qa           = (case when dodet.uom = 'M' then substring(dodet.qa,1,13) 
                                     when dodet.uom = 'SH' AND substring(g.item_name,1,11) = 'AL 절곡판넬' then substring(dodet.qa,1,13) 
                                     else dodet.qa 
                                end)
              , price_level  = c.price_level
              , credit_level = c.credit_level
              , level_grade  = c.level_grade
              , cust_no      = do.cust_no
              , cust_name    = c.cust_name
              , spot_code    = do.spot_code
              , salesman     = c.salesman
              , user_name    = l.user_name
              , saler_user   = e.saler_user
           FROM do
                LEFT OUTER JOIN dodet        ON do.do_no      = dodet.do_no
                LEFT OUTER JOIN customer  C  ON do.cust_no    = c.cust_no
                LEFT OUTER JOIN groupitem G  ON dodet.item_no = g.item_no
                LEFT OUTER JOIN login     L  ON c.salesman    = l.user_id
                LEFT OUTER JOIN aroiinv_esero E ON c.salesman = e.id
          WHERE ( do.do_date BETWEEN :ad_sdate AND :ad_edate )
            AND ((:as_salesman  = '%' AND c.salesman LIKE :as_salesman) OR
                 (:as_salesman <> '%' AND c.salesman    = :as_salesman) 
                )
            AND ((:as_custno    = '%' ) OR
                 (:as_custno   <> '%' AND do.cust_no    = :as_custno) 
                )
         ) A
         LEFT OUTER JOIN custscene B  ON a.cust_no = b.cust_no AND a.spot_code = b.scene_code 
                                     AND a.item_no = b.item_no AND a.qa = b.qa AND a.uom = b.uom
         LEFT OUTER JOIN custitem  F  ON a.cust_no = f.cust_no 
                                     AND a.item_no = f.item_no AND a.qa = f.qa AND a.uom = f.uom
         LEFT OUTER JOIN itemcost  H  ON a.item_no = h.item_no AND a.qa = h.qa AND a.uom = h.uom
         LEFT OUTER JOIN (
              SELECT cust_no  = d.cust_no
                   , item_no  = d.item_no
                   , qa       = d.qa
                   , dodate   = max(d.dodate)
               FROM (
                    SELECT DISTINCT a1.cust_no
                         , b1.item_no
                         , qa = (case when b1.uom = 'M' then substring(b1.qa,1,13) else b1.qa end)
                         , dodate = a1.do_date
                      FROM do A1
                           LEFT OUTER JOIN dodet     B1 ON a1.do_no   = b1.do_no
                           LEFT OUTER JOIN customer  C  ON a1.cust_no = c.cust_no
                     WHERE ( a1.do_date BETWEEN :ad_sdate AND :ad_edate )
                       AND ((:as_custno    = '%' ) OR
                            (:as_custno   <> '%' AND a1.cust_no     = :as_custno)
                           )
                       AND ((:as_salesman  = '%' AND c.salesman LIKE :as_salesman) OR
                            (:as_salesman <> '%' AND c.salesman    = :as_salesman) 
                           )
                    ) D
              GROUP BY d.cust_no, d.item_no, d.qa
        ) AB ON a.cust_no = ab.cust_no AND a.item_no = ab.item_no AND a.qa = ab.qa
  WHERE ( a.item_name NOT IN ('매출 에누리', '공사비', '운반비') )
" arguments=(("as_salesman", string),("as_custno", string),("ad_sdate", datetime),("ad_edate", datetime))  sort="item_name A qa A do_cost A price_level A " )
