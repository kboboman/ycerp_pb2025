table(column=(type=char(12) update=yes updatewhereclause=yes key=yes name=apoiinv_no dbname="apoiinv.apoiinv_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=supp_no dbname="apoiinv.supp_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=pur_flag dbname="apoiinv.pur_flag" )
 column=(type=char(12) update=yes updatewhereclause=yes name=register_no dbname="apoiinv.register_no" )
