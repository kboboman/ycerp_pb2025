$PBExportHeader$d_oisalemanbaldo_r.srd
$PBExportComments$판매거래처별 제품출고및 미출고조회(1998/5/14,성삼지)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="553648127" )
footer(height=92 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=sale_order_no dbname="order_no" initial=" " )
 column=(type=datetime updatewhereclause=yes name=sale_due_date dbname="due_date" initial=" " )
 column=(type=char(4) updatewhereclause=yes name=sale_cust_no dbname="cust_no" initial=" " )
 column=(type=char(10) updatewhereclause=yes name=saledet_item_no dbname="item_no" )
 column=(type=char(20) updatewhereclause=yes name=saledet_qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=saledet_uom dbname="uom" )
 column=(type=long updatewhereclause=yes name=saledet_seq_no dbname="seq_no" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_order_qty dbname="order_qty" )
 column=(type=datetime updatewhereclause=yes name=saledet_rlse_date dbname="rlse_date" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_rlse_qty dbname="rlse_qty" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="cust_name" )
 column=(type=char(20) updatewhereclause=yes name=customer_bus_cord dbname="bus_cord" )
 column=(type=char(20) updatewhereclause=yes name=customer_bus_rep dbname="bus_rep" )
 column=(type=char(30) updatewhereclause=yes name=customer_industry_code dbname="industry_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene_desc" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=decimal(4) updatewhereclause=yes name=price dbname="price" )
 column=(type=char(10) updatewhereclause=yes name=customer_salesman dbname="salesman" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name dbname="user_name" )
 column=(type=char(1) updatewhereclause=yes name=open_close dbname="open_close" values="	C/	O" )
 column=(type=char(1) updatewhereclause=yes name=origin_open_close dbname="origin_open_close" )
 column=(type=decimal(4) updatewhereclause=yes name=rang_qty dbname="rang_qty" )
 column=(type=char(10) updatewhereclause=yes name=makeplan_yn dbname="makeplan_yn" )
 retrieve="  SELECT s.order_no   
       , s.due_date   
       , s.cust_no   
       , sd.item_no   
       , sd.qa   
       , sd.uom   
       , sd.seq_no   
       , sd.order_qty   
       , sd.rlse_date   
       , sd.rlse_qty   
       , c.cust_name   
       , c.bus_cord   
       , c.bus_rep   
       , c.industry_code 
       , sc.scene_desc   
       , g.item_name
       , sd.price
       , c.salesman
       , m.user_name
	  , s.open_close open_close
       , s.open_close origin_open_close
       , dbo.uf_getqty(sd.item_no, sd.qa, sd.uom, sd.order_qty - sd.rlse_qty) rang_qty
	 , makeplan_yn = ( select (CASE WHEN mpsdet.mpsorder_order IS NULL THEN ''
																 WHEN mpsdet.mpsorder_order IS NOT NULL THEN '생산계획중'
																										  END) 
							 from mpsdet where plan_no = dbo.uf_mpsdet(SD.order_no, SD.seq_no) )
    FROM UF_MyCustomers( :as_salesman ) M
         INNER JOIN customer   C with(nolock) ON m.cust_no     = c.cust_no
         INNER JOIN sale       S with(nolock) ON c.cust_no     = s.cust_no AND s.open_close = 'O'
         INNER JOIN saledet   SD with(nolock) ON s.order_no    = sd.order_no
         INNER JOIN groupitem  G with(nolock) ON sd.item_no    = g.item_no
         INNER JOIN scene     SC with(nolock) ON s.scene_code  = sc.scene_code
   WHERE ( s.area_no        LIKE :as_area ) 
     AND ( s.due_date    BETWEEN :as_sdate AND :as_edate ) 
     AND ((:as_team  = '%' AND c.cust_no   LIKE '%'  ) OR 
          (:as_team <> '%' AND c.salesman     = :as_salesman )
         )
     AND ((:as_custno  = '%'   AND c.cust_no   LIKE '%'  ) OR 
          (:as_custno  = 'ALL' AND c.cust_no   LIKE '%'  ) OR 
          (:as_custno <> 'ALL' AND c.cust_no      = :as_custno )
         )
     AND ( sd.order_qty      > sd.rlse_qty )
" arguments=(("as_area", string),("as_custno", string),("as_sdate", string),("as_edate", string),("as_salesman", string),("as_team", string))  sort="customer_salesman A sale_cust_no A scene_scene_desc A sale_order_no A saledet_seq_no A saledet_item_no A " )
group(level=1 header.height=0 trailer.height=84 by=("login_user_name" ) header.color="536870912" trailer.color="12639424" )
group(level=2 header.height=0 trailer.height=84 by=("sale_cust_no" ) header.color="536870912" trailer.color="15793151" )
