table(column=(type=char(4) update=yes updatewhereclause=yes key=yes name=car_custno dbname="car_intervals.car_custno" )
 column=(type=char(11) update=yes updatewhereclause=yes key=yes name=car_scene dbname="car_intervals.car_scene" )
 column=(type=datetime update=yes updatewhereclause=yes key=yes name=cardate dbname="car_intervals.cardate" )
 column=(type=char(10) update=yes updatewhereclause=yes name=area_no dbname="car_intervals.area_no" )
 retrieve="  SELECT car_intervals.car_custno   
       , car_intervals.car_scene   
       , car_intervals.cardate   
       , car_intervals.area_no   
    FROM car_intervals   
   WHERE car_intervals.car_custno   = :as_custno
     AND car_intervals.car_scene    = :as_scene
     AND car_intervals.cardate      = :ad_date
  " update="car_intervals" updatewhere=1 updatekeyinplace=no arguments=(("as_custno", string),("as_scene", string),("ad_date", date)) )
