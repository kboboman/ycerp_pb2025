$PBExportHeader$d_osaroirep_r3.srd
$PBExportComments$계산서 운반비 체크
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no  crosstab.dynamic = yes grid.lines=0 grid.columnmove=no selected.mouse=no )
header[1](height=68 color="536870912" )
header[2](height=68 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=do_no dbname="do_no" )
 column=(type=char(20) updatewhereclause=yes name=aroiinv_no dbname="aroiinv_no" )
 column=(type=number updatewhereclause=yes name=ship_amount dbname="ship_amount" )
 retrieve="  SELECT do_no       = a.do_no
       , cat         = a.cat
       , ship_amount = a.ship_amount
       , aroiinv_no  = a.aroiinv_no
    FROM (
         SELECT DISTINCT cat  = '1.VAT'
              , aroi.do_no                                                     
              , ship_amount = aroiinv.ship_cost        /* 운반비(공급가액) */
              , aroiinv.aroiinv_no       /* 계산서번호 */                      
           FROM  aroiinv left outer join aroi on aroiinv.aroiinv_no = aroi.aroiinv_no
          WHERE ( aroiinv.inv_area         LIKE :as_area + '%'   )
                 AND ( aroiinv.sale_flag          IN ( 'D','L','E' )  ) 
                 AND ( convert(char(10),aroiinv.oi_date,111)       BETWEEN :as_sdate and :as_edate ) 
                 AND ( aroiinv.delete_flag         = 'N'              )
         UNION ALL
         SELECT cat = '2.DO'
              , do.do_no                                         
              , do.ship_amount                                   
              , ''
           FROM do         
          WHERE ( do.do_no           LIKE :as_area + '%'        ) 
            AND ( convert(char(10),do.ship_date,111)    BETWEEN :as_sdate and :as_edate ) 
            AND ( do.ship_flag         IN ('D' , 'B', 'A', 'R') ) 
         
         UNION ALL
         SELECT cat = '3.ASK'
              , ask_head.ask_no                                  
              , ask_head.ship_amount                             
              , ''
           FROM ask_head
          WHERE ( :as_area                  = 'S'                   ) 
            AND ( convert(char(10),ask_head.ship_date,111)  BETWEEN :as_sdate and :as_edate )
         
         UNION ALL
         SELECT cat = '4.ETC'
              , do_no  = (case when do_no is not null then do_no else dbo.uf_getdatestring(doshipetc.etc_date) end)
              , doshipetc.ship_amount                            
              , ''
           FROM doshipetc   
          WHERE ( doshipetc.etc_area      LIKE :as_area + '%'        ) 
            AND ( convert(char(10),doshipetc.etc_date,111)   BETWEEN :as_sdate and :as_edate )
            AND ( doshipetc.doship_req       = 'Y'                   )
                 
         ) A
     ORDER BY do_no, cat

" arguments=(("as_area", string),("as_sdate", string),("as_edate", string))  sort="do_no A aroiinv_no A " )
group(level=1 header.height=0 trailer.height=0 by=("do_no" ) header.color="536870912" trailer.color="536870912" )
