 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"itemmovedet~" )  TABLE(NAME=~"groupitem~" ) COLUMN(NAME=~"itemmovedet.move_no~") COLUMN(NAME=~"itemmovedet.seq~") COLUMN(NAME=~"itemmovedet.item_no~") COLUMN(NAME=~"itemmovedet.qa~") COLUMN(NAME=~"itemmovedet.move_qty~") COLUMN(NAME=~"itemmovedet.lot_no~") COLUMN(NAME=~"itemmovedet.cnt~") COLUMN(NAME=~"itemmovedet.rem~") COLUMN(NAME=~"itemmovedet.pre_seq~") COLUMN(NAME=~"groupitem.uom~") COLUMN(NAME=~"itemmovedet.qcnt~") COLUMN(NAME=~"groupitem.item_name~")    JOIN (LEFT=~"itemmovedet.item_no~"    OP =~"=~"RIGHT=~"groupitem.item_no~"    OUTER1 =~"itemmovedet.item_no~" )WHERE(    EXP1 =~"itemmovedet.move_no~"   OP =~"=~"    EXP2 =~":as_no~" ) ) ARG(NAME = ~"as_no~" TYPE = string) " update="itemmovedet" updatewhere=0 updatekeyinplace=no arguments=(("as_no", string))  sort="seq A " )
