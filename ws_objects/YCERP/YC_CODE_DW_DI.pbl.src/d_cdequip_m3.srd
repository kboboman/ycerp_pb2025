table(column=(type=char(6) update=yes updatewhereclause=yes key=yes name=equip_code dbname="EQUIP_REPAIR.EQUIP_CODE" )
 column=(type=char(8) update=yes updatewhereclause=yes key=yes name=repair_date dbname="EQUIP_REPAIR.REPAIR_DATE" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=seq dbname="EQUIP_REPAIR.SEQ" )
 column=(type=char(40) update=yes updatewhereclause=yes name=repair_com dbname="EQUIP_REPAIR.REPAIR_COM" )
 column=(type=char(10) update=yes updatewhereclause=yes name=repair_name dbname="EQUIP_REPAIR.REPAIR_NAME" )
 column=(type=char(20) update=yes updatewhereclause=yes name=repair_tel dbname="EQUIP_REPAIR.REPAIR_TEL" )
 column=(type=char(200) update=yes updatewhereclause=yes name=repair_reason dbname="EQUIP_REPAIR.REPAIR_REASON" )
 column=(type=char(200) update=yes updatewhereclause=yes name=repair_text dbname="EQUIP_REPAIR.REPAIR_TEXT" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=repair_price dbname="EQUIP_REPAIR.REPAIR_PRICE" )
 column=(type=char(10) update=yes updatewhereclause=yes name=manage_name dbname="EQUIP_REPAIR.MANAGE_NAME" )
 column=(type=char(40) update=yes updatewhereclause=yes name=etc dbname="EQUIP_REPAIR.ETC" )
 retrieve="SELECT EQUIP_CODE,
       REPAIR_DATE,
       SEQ,
       REPAIR_COM,
       REPAIR_NAME,
       REPAIR_TEL,
       REPAIR_REASON,
       REPAIR_TEXT,
       REPAIR_PRICE,
       MANAGE_NAME,
       ETC 
  FROM EQUIP_REPAIR
WHERE  EQUIP_CODE = :arg_equip_code
" update="EQUIP_REPAIR" updatewhere=1 updatekeyinplace=no arguments=(("arg_equip_code", string))  sort="repair_date A seq A " )
