table(column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(11) updatewhereclause=yes name=scene_code dbname="scene_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=char(1) updatewhereclause=yes name=open_close dbname="open_close" )
 column=(type=char(14) updatewhereclause=yes name=order_no dbname="order_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="seq_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=decimal(2) updatewhereclause=yes name=order_qty dbname="order_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=rlse_qty dbname="rlse_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=ship_qty dbname="ship_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=ret_qty dbname="ret_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=make_qty dbname="make_qty" )
 column=(type=datetime updatewhereclause=yes name=order_date dbname="order_date" )
 column=(type=datetime updatewhereclause=yes name=sfc_date dbname="sfc_date" )
 column=(type=datetime updatewhereclause=yes name=do_date dbname="do_date" )
 column=(type=datetime updatewhereclause=yes name=ret_date dbname="ret_date" )
 column=(type=long updatewhereclause=yes name=sfc_day dbname="sfc_day" )
 column=(type=long updatewhereclause=yes name=do_day dbname="do_day" )
 column=(type=long updatewhereclause=yes name=ret_day dbname="ret_day" )
 column=(type=char(4) updatewhereclause=yes name=ret_chk dbname="ret_chk" )
 retrieve="SELECT distinct cust_no     = a.cust_no   
     , cust_name   = c.cust_name
     , scene_code  = a.scene_code
     , scene_desc  = s.scene_desc
     , open_close  = a.open_close
     , order_no    = a.order_no
     , seq_no      = a.seq_no
     , item_no     = a.item_no
     , item_name   = g.item_name
     , qa          = a.qa
     , order_qty   = a.order_qty
     , rlse_qty    = a.rlse_qty
     , ship_qty    = a.ship_qty
     , ret_qty     = a.ret_qty
     , make_qty    = a.make_qty
     , order_date  = a.order_date
     , sfc_date    = a.sfc_date
     , do_date     = a.do_date
     , ret_date    = a.ret_date
     , sfc_day     = datediff(day, a.order_date, a.sfc_date)
     , do_day      = datediff(day, a.order_date, a.do_date)
     , ret_day     = datediff(day, a.do_date,    a.ret_date)
     , ret_chk     = (case when a.ret_qty > 0 AND a.ret_date is null then '이월' else '' end)
  FROM (
       SELECT cust_no     = a.cust_no     
            , scene_code  = a.scene_code  
            , open_close  = a.open_close
            , order_no    = a.order_no
            , seq_no      = a.seq_no
            , item_no     = a.item_no
            , qa          = a.qa
            , order_date  = a.order_date
            , order_qty   = a.order_qty
            , rlse_qty    = a.rlse_qty

            , make_qty    = c.make_qty
            , ship_qty    = dr.ship_qty
            , ret_qty     = dr.ret_qty

            , sfc_date    = c.sfc_date         
            , do_date     = dr.do_date
            , ret_date    = dr.ret_date
         FROM ( /* 수주기간 */
              SELECT s.cust_no
                   , s.scene_code 
                   , s.open_close
                   , s.close_type
                   , s.order_date
                   , sd.order_no
                   , sd.seq_no
                   , sd.item_no
                   , sd.qa
                   , qa13   = left(sd.qa,13) + 'X00000'
                   , sd.order_qty
                   , sd.rlse_qty
                FROM UF_MyCustomers( :as_salesman ) M
                     LEFT OUTER JOIN sale     S ON m.cust_no  = s.cust_no
                     LEFT OUTER JOIN saledet SD ON s.order_no = sd.order_no
               WHERE ( s.area_no        LIKE :as_area ) 
                 AND ( s.order_date  BETWEEN :as_sdate AND :as_edate ) 
                 AND ( sd.order_qty <> sd.rlse_qty    )
                 AND ((:as_team  = '%' AND m.cust_no   LIKE '%'  ) OR 
                      (:as_team <> '%' AND m.salesman     = :as_salesman )
                     )
                 AND ((:as_custno  = '%'   AND m.cust_no   LIKE '%'  ) OR 
                      (:as_custno  = 'ALL' AND m.cust_no   LIKE '%'  ) OR 
                      (:as_custno <> 'ALL' AND m.cust_no      = :as_custno )
                     )
/*
                 AND ((:as_itemno  = '%' ) OR
                      (:as_itemno <> '%' AND sd.item_no = :as_itemno )
                     )
*/
			  AND ((:as_gubun   = '%' AND sd.item_no LIKE '%') OR
					 (:as_gubun  <> '%' AND sd.item_no IN (:as_itemno))
					)
              ) A
              LEFT OUTER JOIN ( /* 마지막공정 */
                          SELECT item_no, qa
                               , op   = max(op)
                               , wc1  = max(wc1)
                               , wc2  = max(wc2)
                               , wc3  = max(wc3)
                            FROM (
                                 SELECT item_no, qa
                                      , op   = operation
                                      , wc1  = (case when operation = 1 then wc_no else '' end)
                                      , wc2  = (case when operation = 2 then wc_no else '' end)
                                      , wc3  = (case when operation = 3 then wc_no else '' end)
                                   FROM ROUT
                                 ) A
                           GROUP BY item_no, qa
              ) B ON a.item_no = b.item_no AND a.qa13 = b.qa
       
              LEFT OUTER JOIN ( /* 생산실적 */
                   SELECT sale_no, seq_no
                        , item_no, qa
                        , make_qty  = sum(a.make_qty)
                        , sfc_date  = max(a.sfc_date)
                     FROM (
                          SELECT sale_no, seq_no
                               , item_no, qa
                               , area_no
                               , make_qty
                               , sfc_date
                            FROM sfcday 
                           WHERE sfc_date >= :as_sdate
                          ) A
                    GROUP BY sale_no, seq_no, item_no, qa
              ) C ON a.order_no = c.sale_no AND a.seq_no = c.seq_no

              LEFT OUTER JOIN ( /* 출고,반품 내역 */
                   SELECT sale_no, seq_no, item_no, qa
                        , ship_qty = max(ship_qty), do_date  = max(do_date)
                        , ret_qty  = max(ret_qty),  ret_date = max(ret_date)
                     FROM (
                          SELECT sale_no, seq_no, item_no, qa
                               , ship_qty = sum(ship_qty), do_date = max(do_date)
                               , ret_qty  = 0, ret_date = null
                            FROM do
                                 LEFT OUTER JOIN dodet ON do.do_no = dodet.do_no
                           WHERE do.do_date > :as_sdate
/*
                             AND ((:as_itemno  = '%' ) OR
                                  (:as_itemno <> '%' AND dodet.item_no = :as_itemno )
                                 )
*/
							  AND ((:as_gubun   = '%' AND dodet.item_no LIKE '%') OR
									 (:as_gubun  <> '%' AND dodet.item_no IN (:as_itemno))
									)
                           GROUP BY sale_no, seq_no, item_no, qa
                          
                          UNION ALL
                          
                          SELECT sale_no, seq_no, item_no, qa
                               , ship_qty = 0, do_date = null
                               , ret_qty  = sum(ret_qty), ret_date = max(ret_date)
                            FROM (
                                 SELECT ret.ret_no, ret_date = (SELECT do_date FROM do WHERE do_no  = ret.do_no)
                                      , retdet.sale_no, retdet.seq_no, item_no, qa, ret_qty
                                   FROM ret
                                        LEFT OUTER JOIN retdet ON ret.ret_no = retdet.ret_no
                                  WHERE ret.ret_date > :as_sdate
/*
                                    AND ((:as_itemno  = '%' ) OR
                                         (:as_itemno <> '%' AND retdet.item_no = :as_itemno )
                                        )
*/
							  AND ((:as_gubun   = '%' AND retdet.item_no LIKE '%') OR
									 (:as_gubun  <> '%' AND retdet.item_no IN (:as_itemno))
									)

                                 ) A
                           GROUP BY sale_no, seq_no, item_no, qa
                          ) A
                    GROUP BY sale_no, seq_no, item_no, qa
                           
              ) DR ON a.order_no = dr.sale_no AND a.seq_no = dr.seq_no
       ) A
       LEFT OUTER JOIN groupitem G  ON a.item_no = g.item_no
       LEFT OUTER JOIN customer  C  ON a.cust_no = c.cust_no
       LEFT OUTER JOIN scene     S  ON a.scene_code = s.scene_code

" arguments=(("as_area", string),("as_custno", string),("as_itemno", stringlist),("as_sdate", string),("as_edate", string),("as_salesman", string),("as_team", string),("as_gubun", string))  sort="cust_name A scene_desc A order_no A seq_no A do_date A " )
