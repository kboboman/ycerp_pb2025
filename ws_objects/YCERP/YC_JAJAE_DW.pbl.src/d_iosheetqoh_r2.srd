$PBExportHeader$d_iosheetqoh_r2.srd
$PBExportComments$품목별 sheet 재고 현황(2006/01/21,정갑용)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=560 color="536870912" )
summary(height=100 color="536870912" )
footer(height=0 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(255) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=decimal(4) updatewhereclause=yes name=q_cnt_1 dbname="q_cnt_1" )
 column=(type=decimal(4) updatewhereclause=yes name=q_cnt_2 dbname="q_cnt_2" )
 column=(type=decimal(4) updatewhereclause=yes name=t_cnt_1 dbname="t_cnt_1" )
 column=(type=decimal(4) updatewhereclause=yes name=q_cnt_3 dbname="q_cnt_3" )
 column=(type=decimal(4) updatewhereclause=yes name=q_cnt_4 dbname="q_cnt_4" )
 column=(type=decimal(4) updatewhereclause=yes name=t_cnt_2 dbname="t_cnt_2" )
 column=(type=decimal(4) updatewhereclause=yes name=t_cnt_3 dbname="t_cnt_3" )
 column=(type=char(2) updatewhereclause=yes name=sort1 dbname="sort1" )
 column=(type=char(1) updatewhereclause=yes name=gb dbname="gb" )
 retrieve="SELECT item_name = REPLACE(A.item_name,' 반제품',''), 
			q_cnt_1 = sum(q_cnt_1), /*원코일,시화*/
			q_cnt_2 = sum(q_cnt_2), /*원코일,외주*/
			t_cnt_1 = sum(q_cnt_1) + sum(q_cnt_2),  /*원코일,계*/
			q_cnt_3 = sum(q_cnt_3), /*스리팅,시화*/
			q_cnt_4 = sum(q_cnt_4), /*스리팅,외주*/
			t_cnt_2 = sum(q_cnt_3) + sum(q_cnt_4), /*스리팅,계*/
			t_cnt_3 = sum(q_cnt_1) + sum(q_cnt_2) + sum(q_cnt_3) + sum(q_cnt_4), /*총계*/
			sort1,
			gb
from 			
(
	  SELECT sort1 = substring(sheetmst.item_no, 3, 1),/*원코일,시화*/
				item_name = groupitem.item_name,
				q_cnt_1 = sum(sheetmst.unit_qty * sheetmst.qcnt),
				q_cnt_2 = 0,
				t_cnt_1 = 0,
				q_cnt_3 = 0,
				q_cnt_4 = 0,
				gb = dbo.uf_getcoilsort(sheetmst.item_no)
		 FROM sheetmst,   
				groupitem, location
		WHERE ( sheetmst.item_no = groupitem.item_no) and  
				( sheetmst.loc_no = location.loc_no) and  
				( ( sheetmst.loc_no IN( 'WS00000000', 'WS00000003', 'WW01', 'WW02', 'WW03') or  
				  		( loc_type = 'W' ) ) AND  
				  ( sheetmst.flag = 'W' ) AND  
				  ( sheetmst.open_close <> 'C' ) AND
				  ( substring(sheetmst.item_no, 3, 1) in ('S', 'A') ) ) and
				not exists ( select * from lossitem where loss_item = sheetmst.item_no)
	group by substring(sheetmst.item_no, 3, 1),dbo.uf_getcoilsort(sheetmst.item_no), groupitem.item_name
union all
	  SELECT sort1 = substring(sheetmst.item_no, 3, 1),/*원코일,외주*/
				item_name = groupitem.item_name,
				q_cnt_1 = 0,
				q_cnt_2 = sum(sheetmst.unit_qty * sheetmst.qcnt),
				t_cnt_1 = 0,
				q_cnt_3 = 0,
				q_cnt_4 = 0,
				gb = dbo.uf_getcoilsort(sheetmst.item_no)
		 FROM sheetmst,   
				groupitem, location
		WHERE ( sheetmst.item_no = groupitem.item_no) and  
				( ( sheetmst.loc_no = location.loc_no and loc_type = 'Y' ) and
				  ( sheetmst.flag = 'W' ) AND  
				  ( sheetmst.open_close <> 'C' ) AND
				  ( substring(sheetmst.item_no, 3, 1) in ('S', 'A') ) ) and
				not exists ( select * from lossitem where loss_item = sheetmst.item_no)
	group by substring(sheetmst.item_no, 3, 1),dbo.uf_getcoilsort(sheetmst.item_no), groupitem.item_name
union all
	  SELECT sort1 = substring(sheetmst.item_no, 3, 1),/*스리팅,시화*/
				item_name = groupitem.item_name,
				q_cnt_1 = 0,
				q_cnt_2 = 0,
				t_cnt_1 = 0,
				q_cnt_3 = sum(sheetmst.unit_qty * sheetmst.qcnt),
				q_cnt_4 = 0,
				gb = dbo.uf_getcoilsort(sheetmst.item_no)
		 FROM sheetmst,   
				groupitem, location
		WHERE ( sheetmst.item_no = groupitem.item_no) and  
				( sheetmst.loc_no = location.loc_no) and  
				( ( sheetmst.loc_no IN ( 'WS00000000', 'WS00000003', 'WW01', 'WW02', 'WW03') or  
				  	 ( loc_type = 'W' ) ) AND  
				  ( sheetmst.flag = 'S' ) AND  
				  ( sheetmst.open_close <> 'C' ) AND
				  ( substring(sheetmst.item_no, 3, 1) in ('S', 'A') ) ) and
				not exists ( select * from lossitem where loss_item = sheetmst.item_no)
	group by substring(sheetmst.item_no, 3, 1),dbo.uf_getcoilsort(sheetmst.item_no), groupitem.item_name
union all
	SELECT sort1 = substring(sheetmst.item_no, 3, 1),/*스리팅,외주*/
				item_name = groupitem.item_name,
				q_cnt_1 = 0,
				q_cnt_2 = 0,
				t_cnt_1 = 0,
				q_cnt_3 = 0,
				q_cnt_4 = sum(sheetmst.unit_qty * sheetmst.qcnt),
				gb = dbo.uf_getcoilsort(sheetmst.item_no)
		 FROM sheetmst,   
				groupitem, location
		WHERE ( sheetmst.item_no = groupitem.item_no) and  
				( ( sheetmst.loc_no = location.loc_no and loc_type = 'Y' ) and
				  ( sheetmst.flag = 'S' ) AND  
				  ( sheetmst.open_close <> 'C' ) AND
				  ( substring(sheetmst.item_no, 3, 1) in ('S', 'A') ) ) and
				not exists ( select * from lossitem where loss_item = sheetmst.item_no)
	group by substring(sheetmst.item_no, 3, 1),dbo.uf_getcoilsort(sheetmst.item_no), groupitem.item_name

) A

GROUP BY sort1,
				gb , REPLACE(A.item_name,' 반제품','')
"  sort="sort1 D gb A groupitem_item_name A " )
group(level=1 header.height=0 trailer.height=100 by=("sort1" ) header.color="536870912" trailer.color="536870912"  sort="count(gb for group 1) D count(groupitem_item_name for group 1) A " )
group(level=2 header.height=0 trailer.height=88 by=("gb" ) header.color="536870912" trailer.color="536870912" )
