table(column=(type=char(12) updatewhereclause=yes name=register_no dbname="register_no" )
 column=(type=char(20) updatewhereclause=yes name=captain_name dbname="captain_name" )
 column=(type=char(50) updatewhereclause=yes name=supp_name dbname="supp_name" )
 column=(type=char(20) updatewhereclause=yes name=contact dbname="contact" )
 column=(type=char(80) updatewhereclause=yes name=addr dbname="addr" )
 column=(type=char(15) updatewhereclause=yes name=tel_no dbname="tel_no" )
 column=(type=char(30) updatewhereclause=yes name=industry_type dbname="industry_type" )
 column=(type=char(30) updatewhereclause=yes name=industry_code dbname="industry_code" )
 column=(type=char(15) updatewhereclause=yes name=fax_no dbname="fax_no" )
 column=(type=char(4) updatewhereclause=yes name=supp_no dbname="supp_no" )
 retrieve="  SELECT register_no = customer.register_no,   
         captain_name = customer.captain_name,   
         supp_name = customer.cust_name,   
         contact = customer.buyer1,   
         addr = customer.addr,   
         tel_no = customer.tel_no,   
         industry_type = customer.industry_type,   
         industry_code = customer.industry_code,   
         fax_no = customer.fax_no,   
         supp_no = customer.cust_no  
    FROM customer  
   WHERE customer.cust_type <> 'L'    
"  sort="supp_name A " )
