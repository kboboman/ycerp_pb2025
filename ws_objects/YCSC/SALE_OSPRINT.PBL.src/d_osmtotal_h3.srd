table(column=(type=char(10) updatewhereclause=yes name=salesman dbname="SALESMAN" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=balbf_amount dbname="BALBF_AMOUNT" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=inv_01 dbname="INV_01" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=inv_02 dbname="INV_02" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=inv_03 dbname="INV_03" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=inv_04 dbname="INV_04" )
