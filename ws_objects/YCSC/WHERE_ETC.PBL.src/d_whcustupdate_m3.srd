 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"pur~" )  TABLE(NAME=~"purdet~" )  TABLE(NAME=~"groupitem~" ) COLUMN(NAME=~"purdet.order_no~") COLUMN(NAME=~"purdet.seq_no~") COLUMN(NAME=~"pur.order_date~") COLUMN(NAME=~"purdet.cust_name~") COLUMN(NAME=~"groupitem.item_name~") COLUMN(NAME=~"purdet.qa~") COLUMN(NAME=~"purdet.order_qty~") COLUMN(NAME=~"purdet.rlse_qty~")    JOIN (LEFT=~"pur.order_no~"    OP =~"=~"RIGHT=~"purdet.order_no~" )    JOIN (LEFT=~"purdet.item_no~"    OP =~"=~"RIGHT=~"groupitem.item_no~" )WHERE(    EXP1 =~"purdet.sale_no~"   OP =~"in~"    EXP2 =~"(select distinct sale_no from dodet where do_no = :as_dono)~" ) ) ARG(NAME = ~"as_dono~" TYPE = string) " update="purdet" updatewhere=0 updatekeyinplace=no arguments=(("as_dono", string)) )
