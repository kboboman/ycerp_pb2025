$PBExportHeader$d_apoiup_h1.srd
$PBExportComments$자재매입수정 및 취소 insp TABLE UPDATE용 DATAWINDOW(1999/05/31, 이인호)
release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes key=yes name=insp_no dbname="insp.insp_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=invoice_print dbname="insp.invoice_print" )
 column=(type=char(12) updatewhereclause=yes name=apoiinv_no dbname="apoiinv.apoiinv_no" )
 retrieve="  SELECT DISTINCT insp.insp_no,   
         insp.invoice_print,   
         apoiinv.apoiinv_no  
    FROM apoi,   
         apoiinv,   
         inspdet,   
         insp  
   WHERE ( inspdet.insp_no = insp.insp_no ) and  
         ( apoiinv.apoiinv_no = apoi.apoiinv_no ) and  
         ( apoi.insp_no = inspdet.insp_no ) and  
         ( apoi.oi_no = inspdet.oi_no ) and  
         ( ( apoiinv.supp_no = :as_supp_no ) AND  
         ( apoiinv.inv_area = :as_area ) AND  
         ( apoiinv.open_close = 'O' ) AND  
         ( apoiinv.delete_flag = 'N' ) )    
" update="insp" updatewhere=1 updatekeyinplace=yes arguments=(("as_supp_no", string),("as_area", string)) )
column(band=detail id=1 alignment="0" tabsequence=32766 border="0" color="0" x="0" y="4" height="64" width="384" format="[general]"  name=insp_no edit.limit=0 edit.case=any edit.autoselect=yes  font.face="굴림체" font.height="-10" font.weight="400"  font.family="2" font.pitch="2" font.charset="129" background.mode="2" background.color="16777215" )
column(band=detail id=2 alignment="0" tabsequence=32766 border="0" color="0" x="443" y="4" height="64" width="384" format="[general]"  name=invoice_print edit.limit=0 edit.case=any edit.autoselect=yes  font.face="굴림체" font.height="-10" font.weight="400"  font.family="2" font.pitch="2" font.charset="129" background.mode="2" background.color="16777215" )
column(band=detail id=3 alignment="0" tabsequence=32766 border="0" color="0" x="882" y="4" height="64" width="384" format="[general]"  name=apoiinv_no edit.limit=0 edit.case=any edit.autoselect=yes  font.face="굴림체" font.height="-10" font.weight="400"  font.family="2" font.pitch="2" font.charset="129" background.mode="2" background.color="16777215" )
htmltable(border="1" cellpadding="0" cellspacing="0" generatecss="no" nowrap="yes")