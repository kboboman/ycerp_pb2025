GF_DWTitle2ddlb( this, ddlb_fld, ddlb_dwtitles )
GF_DWClick2Info(this, ddlb_fld, ddlb_op, sle_value, row, dwo.name, ddlb_dwtitles)

//
dwitemstatus l_status
long   ll_row, ll_count, ll_cnt, ll_max
string ls_sosno
		
if dw5.rowcount() < 1 then RETURN

dw5.accepttext()
l_status = dw5.getitemstatus(1, 0, primary!)
if l_status = notmodified! then
else
	if MessageBox("확인","수정한 내용을 무시하고 다시 조회 하시겠습니까?", Exclamation!, yesno!, 2) = 2 then
		RETURN -1
	end if
end if

dw6.accepttext()
l_status = dw6.getitemstatus(1, 0, primary!)
if l_status = notmodified! then
else
	if MessageBox("확인","수정한 품목을 저장 하시겠습니까?", Exclamation!, yesno!, 2) = 2 then
		RETURN
	end if
end if

