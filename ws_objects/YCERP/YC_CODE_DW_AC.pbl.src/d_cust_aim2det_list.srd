 column=(type=decimal(0) updatewhereclause=yes name=상계2 dbname="상계2" )
 column=(type=decimal(0) updatewhereclause=yes name=상계3 dbname="상계3" )
 column=(type=decimal(0) updatewhereclause=yes name=상계4 dbname="상계4" )
 column=(type=decimal(0) updatewhereclause=yes name=상계5 dbname="상계5" )
 column=(type=char(50) updatewhereclause=yes name=비고 dbname="비고" )
 retrieve="  SELECT '팀명'     = d.team_name
       , '담당자'   = c.user_name
       , '거래처'   = a.cust_no    
       , '거래처명' = b.cust_name  
       , '년월'     = convert(char(10),a.tar_year,111)
       , '주차'     = a.weeks      
       , '현금1'    = (case when a.weeks = 1 then a.cash   else 0 end)
       , '현금2'    = (case when a.weeks = 2 then a.cash   else 0 end)
       , '현금3'    = (case when a.weeks = 3 then a.cash   else 0 end)
       , '현금4'    = (case when a.weeks = 4 then a.cash   else 0 end)
       , '현금5'    = (case when a.weeks = 5 then a.cash   else 0 end)
       , '어음1'    = (case when a.weeks = 1 then a.bill   else 0 end)
       , '어음2'    = (case when a.weeks = 2 then a.bill   else 0 end)
       , '어음3'    = (case when a.weeks = 3 then a.bill   else 0 end)
       , '어음4'    = (case when a.weeks = 4 then a.bill   else 0 end)
       , '어음5'    = (case when a.weeks = 5 then a.bill   else 0 end)
       , '상계1'    = (case when a.weeks = 1 then a.setoff else 0 end)
       , '상계2'    = (case when a.weeks = 2 then a.setoff else 0 end)
       , '상계3'    = (case when a.weeks = 3 then a.setoff else 0 end)
       , '상계4'    = (case when a.weeks = 4 then a.setoff else 0 end)
       , '상계5'    = (case when a.weeks = 5 then a.setoff else 0 end)
       , '비고'     = a.bigo      
    FROM cust_aimdet A  
         LEFT OUTER JOIN customer B ON a.cust_no   = b.cust_no
         LEFT OUTER JOIN login    C ON b.salesman  = c.user_id
         LEFT OUTER JOIN team     D ON c.team_code = d.team_code
   WHERE SUBSTRING(CONVERT(CHAR(10),a.tar_year,111),1,7) = :as_yyyymm
   ORDER BY d.team_name, c.user_name, b.cust_name, a.weeks
" arguments=(("as_yyyymm", string)) )
