table(column=(type=datetime update=yes updatewhereclause=yes name=req_date dbname="req_date" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=salesman dbname="salesman" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=req_seq dbname="req_seq" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=accept_user dbname="accept_user" )
 column=(type=char(10) update=yes updatewhereclause=yes name=accept1 dbname="accept1" )
 column=(type=char(10) update=yes updatewhereclause=yes name=accept2 dbname="accept2" )
 column=(type=char(10) update=yes updatewhereclause=yes name=accept3 dbname="accept3" )
 column=(type=char(10) update=yes updatewhereclause=yes name=accept4 dbname="accept4" )
 column=(type=char(10) update=yes updatewhereclause=yes name=accept5 dbname="accept5" )
 column=(type=char(1) updatewhereclause=yes name=chk0 dbname="chk0" values="	Y/	N" )
 column=(type=char(1) updatewhereclause=yes name=chk1 dbname="chk1" values="	Y/	N" )
 column=(type=char(1) updatewhereclause=yes name=chk2 dbname="chk2" values="	Y/	N" )
 column=(type=char(1) updatewhereclause=yes name=chk3 dbname="chk3" values="	Y/	N" )
 column=(type=char(1) updatewhereclause=yes name=chk4 dbname="chk4" values="	Y/	N" )
 column=(type=char(1) updatewhereclause=yes name=chk5 dbname="chk5" values="	Y/	N" )
 column=(type=char(60) update=yes updatewhereclause=yes name=rem dbname="rem" )
 column=(type=char(255) update=yes updatewhereclause=yes name=req_text dbname="req_text" )
 column=(type=char(10) update=yes updatewhereclause=yes name=accept_area dbname="accept_area" )
 column=(type=char(1) update=yes updatewhereclause=yes name=confirm_flag dbname="confirm_flag" initial="N" values="확정	Y/미확정	N/" )
 column=(type=datetime update=yes updatewhereclause=yes name=sys_date dbname="sys_date" )
 column=(type=char(10) updatewhereclause=yes name=loc_no dbname="loc_no" )
 column=(type=char(10) updatewhereclause=yes name=location_area_no dbname="location.area_no" )
 column=(type=char(1) updatewhereclause=yes name=issue_schedule dbname="ISSUE_SCHEDULE" values="직출	A/생산후직출	B/저녁상차	J/택배//정기	K/방문	D/야간도착	I/외주(시화)	E/외주(본사)	F/유창강건	G/지점이송	H/자동작성	C/" )
 column=(type=char(1) updatewhereclause=yes name=ship_case dbname="SHIP_CASE" values="정기화물	J/택배	T/오토바이	A/선박	S/항공	P/기타	E/" )
 retrieve="  SELECT req_date     = i.req_date      
       , salesman     = i.salesman      
       , req_seq      = i.req_seq       
       , accept_user  = i.accept_user   
       , accept1      = i.accept1   
       , accept2      = i.accept2   
       , accept3      = i.accept3
       , accept4      = i.accept4
       , accept5      = i.accept5
       , chk0         = (case when i.confirm_flag = 'Y' then 'Y' else 'N' end)
       , chk1         = (case when i.confirm_flag = 'Y' then (case when i.accept1 is null OR i.accept1 = '' then 'N' else 'Y' end) else 'N' end)
       , chk2         = (case when i.confirm_flag = 'Y' then (case when i.accept2 is null OR i.accept2 = '' then 'N' else 'Y' end) else 'N' end)
       , chk3         = (case when i.confirm_flag = 'Y' then (case when i.accept3 is null OR i.accept3 = '' then 'N' else 'Y' end) else 'N' end)
       , chk4         = (case when i.confirm_flag = 'Y' then (case when i.accept4 is null OR i.accept4 = '' then 'N' else 'Y' end) else 'N' end)
       , chk5         = (case when i.confirm_flag = 'Y' then (case when i.accept5 is null OR i.accept5 = '' then 'N' else 'Y' end) else 'N' end)
       , rem          = i.rem           
       , req_text     = i.req_text      
       , accept_area  = i.accept_area   
       , confirm_flag = i.confirm_flag  
       , sys_date     = i.sys_date      
       , loc_no       = l.loc_no
       , L.area_no
       , '' ISSUE_SCHEDULE
       , '' SHIP_CASE
    FROM issuereq I              
         LEFT OUTER JOIN location L ON i.accept_user = l.loc_manager
   WHERE ( i.req_date = :ad_date ) 
     AND ( i.salesman = :as_user ) 
     AND ( i.req_seq  = :ai_seq  ) 
" update="issuereq" updatewhere=0 updatekeyinplace=no arguments=(("ad_date", date),("as_user", string),("ai_seq", number)) )
