table(column=(type=char(60) updatewhereclause=yes name=item_item_name dbname="GroupItem.item_name" )
 column=(type=char(17) update=yes updatewhereclause=yes key=yes name=order_no dbname="sfcuse.order_no" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=wc_no dbname="sfcuse.wc_no" )
 column=(type=datetime update=yes updatewhereclause=yes key=yes name=use_date dbname="sfcuse.use_date" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="sfcuse.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=qa dbname="sfcuse.qa" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="sfcuse.uom" )
 column=(type=decimal(4) update=yes updatewhereclause=yes key=yes name=use_qty dbname="sfcuse.use_qty" initial="0" )
