$PBExportComments$코일발주시코일선택1(2018/11/30,조원석)
release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(30) updatewhereclause=yes name=loc_name dbname="coilmst.loc_name" )
 column=(type=char(10) updatewhereclause=yes name=a_loc_no dbname="coilmst.LOC_NO" )
 column=(type=char(20) updatewhereclause=yes name=coil_no dbname="coilmst.COIL_NO" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="coilmst.ITEM_NO" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="coilmst.QA" )
 column=(type=decimal(1) updatewhereclause=yes name=wid dbname="coilmst.WID" )
 column=(type=char(7) updatewhereclause=yes name=thick dbname="thick" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="coilmst.item_name" )
 column=(type=char(1) updatewhereclause=yes name=flag dbname="coilmst.flag" )
 retrieve="SELECT c.loc_name,
              a.LOC_NO,
              a.COIL_NO,       
              a.ITEM_NO, 
              a.QA,             
              a.WID, 
              substring( a.qa ,1,1) + '.' + substring(  a.qa ,2,2 ) thick,
              b.item_name,
              a.flag
FROM COILMST a WITH(NOLOCK) inner join groupitem b with(nolock) on a.item_no = b.item_no
                                                              inner join location c  with(nolock) on a.loc_no  = c.loc_no and c.loc_type = 'Y' and c.use_yn = 'Y'
WHERE a.OPEN_CLOSE in ( 'O' )
    AND a.item_no = :as_item_no
    AND a.qa          = :as_qa
" arguments=(("as_item_no", string),("as_qa", string))  sort="wid A thick A loc_name A coil_no A " )
