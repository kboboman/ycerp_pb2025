 column=(type=char(2) updatewhereclause=yes name=uom dbname="appeom.uom" )
 column=(type=decimal(2) updatewhereclause=yes name=insp_qty dbname="appeom.insp_qty" )
 column=(type=decimal(3) updatewhereclause=yes name=price dbname="appeom.price" )
 column=(type=decimal(2) updatewhereclause=yes name=amount dbname="appeom.amount" )
 column=(type=decimal(0) updatewhereclause=yes name=vat dbname="appeom.vat" )
 column=(type=decimal(2) updatewhereclause=yes name=tot_amount dbname="appeom.tot_amount" )
 column=(type=decimal(2) updatewhereclause=yes name=vc_amount dbname="appeom.vc_amount" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="appeom.seq_no" )
 column=(type=char(10) updatewhereclause=yes name=supp_no dbname="appeom.supp_no" )
 column=(type=decimal(2) updatewhereclause=yes name=bal_amount dbname="appeom.bal_amount" )
 column=(type=char(50) updatewhereclause=yes name=inspdet_rem dbname="inspdet.rem" )
