footer(height=0 color="536870912" )
detail(height=104 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=customer_cust_no dbname="customer.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=char(11) update=yes updatewhereclause=yes key=yes name=scene_code dbname="item_paint.scene_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="item_paint.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=qa dbname="item_paint.qa" )
 column=(type=char(40) update=yes updatewhereclause=yes key=yes name=item_gubun dbname="item_paint.item_gubun" )
 column=(type=char(50) updatewhereclause=yes name=paint_name dbname="item_paint.paint_name" )
 column=(type=char(50) update=yes updatewhereclause=yes name=paint_company dbname="item_paint.paint_company" )
 column=(type=char(50) update=yes updatewhereclause=yes key=yes name=order_paint_name dbname="item_paint.order_paint_name" )
 column=(type=char(50) update=yes updatewhereclause=yes name=order_paint_company dbname="item_paint.order_paint_company" )
 column=(type=char(1) updatewhereclause=yes name=glossy_yn dbname="item_paint.glossy_yn" values="유광	1/무광	2/반광	3/" )
 column=(type=char(50) update=yes updatewhereclause=yes name=rem dbname="item_paint.rem" )
 retrieve="select  customer.cust_no, 
		 customer.cust_name,
		 item_paint.scene_code,
	      scene.scene_desc,
		 item_paint.item_no,
     		 item_paint.qa,
		 item_paint.item_gubun,
		 item_paint.paint_name,
		 item_paint.paint_company,
		 item_paint.order_paint_name,
		 item_paint.order_paint_company,
		 item_paint.glossy_yn,
		 item_paint.rem
from item_paint inner join scene on item_paint.scene_code = scene.scene_code
                             inner join customer on scene.cust_no = customer.cust_no
where item_paint.item_no = :as_item_no
   and  item_paint.qa = :as_qa
" update="item_paint" updatewhere=1 updatekeyinplace=no arguments=(("as_item_no", string),("as_qa", string))  sort="qa A paint_name A " )
