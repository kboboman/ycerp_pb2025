table(column=(type=char(1) updatewhereclause=yes name=chk dbname="CHK" values="	1/	0" )
 column=(type=char(10) updatewhereclause=yes name=area_no dbname="AREA_NO" )
 column=(type=char(20) updatewhereclause=yes name=area_name dbname="AREA_NAME" )
 column=(type=char(5) updatewhereclause=yes name=team_code dbname="TEAM_CODE" )
 column=(type=char(30) updatewhereclause=yes name=team_name dbname="TEAM_NAME" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="USER_ID" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="USER_NAME" )
 column=(type=char(10) updatewhereclause=yes name=rank_no dbname="RANK_NO" )
 column=(type=char(20) updatewhereclause=yes name=rank dbname="RANK" )
 column=(type=char(1) updatewhereclause=yes name=user_level dbname="USER_LEVEL" )
 column=(type=char(10) updatewhereclause=yes name=gw_id dbname="GW_ID" )
 column=(type=char(30) updatewhereclause=yes name=rem dbname="REM" )
 retrieve="SELECT CHK        = '0'
     , AREA_NO    = A.AREA_NO
     , AREA_NAME  = C.AREA_NAME
     , TEAM_CODE  = A.TEAM_CODE
     , TEAM_NAME  = B.TEAM_NAME
     , USER_ID    = A.USER_ID
     , USER_NAME  = A.USER_NAME
     , RANK_NO    = A.RANK_NO
     , RANK       = A.RANK
     , USER_LEVEL = A.USER_LEVEL
     , GW_ID      = ISNULL(A.GW_ID,'')
     , REM        = ISNULL(A.REM,'')
  FROM LOGIN A
       LEFT OUTER JOIN TEAM B  ON A.TEAM_CODE = B.TEAM_CODE
       LEFT OUTER JOIN AREA C  ON A.AREA_NO   = C.AREA_NO
 WHERE A.TEAM_CODE   LIKE '9%'
   AND A.AREA_NO     LIKE '%'
   AND A.USE_FLAG       = 'Y'
   AND A.GW_ID         IS NULL   /* 생산직과 사무직 구분*/
 ORDER BY A.TEAM_CODE, A.RANK_NO
" )
