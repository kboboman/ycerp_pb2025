type dw_9 from datawindow within tabpage_5
event keydown pbm_dwnkey
integer x = 1993
integer y = 208
integer width = 2533
integer height = 1664
integer taborder = 30
string title = "none"
string dataobject = "d_mpsfcdayman_m"
boolean hscrollbar = true
boolean vscrollbar = true
boolean livescroll = true
borderstyle borderstyle = stylelowered!
end type

event keydown;// 1 Shift, 2 Ctrl, 3 Shift + Ctrl keys : keyflags
// Tab -> Enter키로 변경
//if Key = KeyTab! then key = KeyEnter! 

end event

event clicked;string ls_col, ls_text

if row < 1 or row > this.rowcount() then return

This.SelectRow(0, FALSE)
This.SelectRow(row, TRUE)

choose case dwo.name
	case "chk"
		ls_col  = "선택 "
		ls_text = string(this.object.chk[row])
	case "wc_no"
		ls_col  = "작업장 "
		ls_text = string(this.object.wc_no[row])
	case "user_id"
		ls_col  = "작업자 "
		ls_text = string(this.object.user_id[row])
	case "work1"
		ls_col  = "오전 "
		ls_text = string(this.object.work1[row])
	case "work2"
		ls_col  = "오후 "
		ls_text = string(this.object.work2[row])
	case "work3"
		ls_col  = "야간 "
		ls_text = string(this.object.work3[row])
end choose		

choose case ls_col
	case "선택"
		ddlb_4.text = "="
	case else
		ddlb_4.text = "LIKE"
end choose

ddlb_col2.text  = ls_col
sle_value2.text = ls_text

end event

event editchanged;real   lr_time
string ls_chk = "N", ls_temp

choose case dwo.name
	case "time1", "time2", "time3"
		if RightA(data,1) = "0" or RightA(data,1) = "5" then
			lr_time = real(data)
			if lr_time > 0 and  lr_time < 5 then
				ls_chk = "Y"
			else
				MessageBox("확인","0 에서 부터 5 까지(0.5는 30분 단위)")
				ls_chk = "N"
			end if
		else
			MessageBox("확인","작업시간은 30분 단위로만 계산합니다.(0.5는 30분)")
			ls_chk = "N"
		end if
end choose

if ls_chk = "N" then
	choose case dwo.name
		case "time1"
				this.object.time1[row] = 0
		case "time2"
				this.object.time2[row] = 0
		case "time3"
				this.object.time3[row] = 0			
	end choose
end if

end event

