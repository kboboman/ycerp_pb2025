on tab_1.create
this.tabpage_1=create tabpage_1
this.tabpage_2=create tabpage_2
this.tabpage_3=create tabpage_3
this.tabpage_4=create tabpage_4
this.tabpage_5=create tabpage_5
this.tabpage_6=create tabpage_6
this.Control[]={this.tabpage_1,&
this.tabpage_2,&
this.tabpage_3,&
this.tabpage_4,&
this.tabpage_5,&
this.tabpage_6}
end on

event selectionchanged;//
//dw_area.enabled    = true
dw_3.enabled       = true
pb_compute.enabled = true
pb_insert.enabled  = true
pb_2.enabled       = false

CHOOSE CASE newindex
	case 1	// 재고현황
		pb_2.enabled = true

	CASE 2	// 생산계획
		pb_2.enabled = true

	CASE 3	// 재고이력검색
		pb_2.enabled = true
		
		dw8.setredraw(false)
		if dw4.rowcount() > 0 then
			dw8.dataobject = dw4.dataobject
			dw4.sharedata(dw8)
			//dw8.scrolltorow( dw4.getrow() )
		end if
		dw8.setredraw(true)

	CASE 4	// 수불부
//		dw_area.enabled    = false
		dw_3.enabled       = false
		pb_compute.enabled = false
		pb_insert.enabled  = false
		
		pb_2.enabled = true

	CASE 5	// 장기재고
		pb_2.enabled = true

	CASE 6	// 발주현황
		pb_2.enabled = true
END CHOOSE

end event

