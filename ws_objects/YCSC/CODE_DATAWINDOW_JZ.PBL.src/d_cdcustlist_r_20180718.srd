table(column=(type=char(3) updatewhereclause=yes name=idx dbname="idx" )
 column=(type=char(50) updatewhereclause=yes name=fname dbname="fname" )
 column=(type=char(50) updatewhereclause=yes name=aname dbname="aname" )
 column=(type=char(4) updatewhereclause=yes name=cid dbname="cid" )
 column=(type=char(10) updatewhereclause=yes name=cuser dbname="cuser" )
 column=(type=char(10) updatewhereclause=yes name=puser dbname="puser" )
 column=(type=decimal(2) updatewhereclause=yes name=opeomamt dbname="opeomamt" )
 column=(type=char(4) updatewhereclause=yes name=del dbname="del" )
 column=(type=char(1) updatewhereclause=yes name=sp dbname="sp" )
 retrieve="SELECT idx  
     , fname
     , aname
     , cid  
     , cuser
     , puser
     , opeomamt
     , del  
     , sp    = '' 
  FROM V_CUSTOMER
 WHERE idx LIKE :ag_idx
   AND (( :as_open = 'O' AND del    = '가능' ) OR
        ( :as_open = '%' AND DEL LIKE '%'    )
       )
   AND (( :as_zero = 'Y' AND opeomamt <> 0   ) OR ( :as_zero = '%' ))
   AND (( :as_salesman  = '%' AND salesman  LIKE '%'          ) OR
        ( :as_salesman <> '%' AND salesman     = :as_salesman )           
       )
" arguments=(("ag_idx", string),("as_open", string),("as_zero", string),("as_salesman", string))  sort="aname A del A " )
