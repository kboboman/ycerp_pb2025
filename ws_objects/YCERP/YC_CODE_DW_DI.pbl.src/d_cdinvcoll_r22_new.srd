 column=(type=char(10) update=yes updatewhereclause=yes name=make_user dbname="opeom.make_user" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 retrieve="  SELECT opeom.cust_no,   
         isnull(opeom.eom_year, convert(char(4),:bb) ) eom_year,   
         isnull(opeom.balbf_amount,0) balbf_amount,   
         isnull(opeom.inv_01,0) inv_01,   
         isnull(opeom.inv_02,0) inv_02,   
         isnull(opeom.inv_03,0) inv_03,   
         isnull(opeom.inv_04,0) inv_04,   
         isnull(opeom.inv_05,0) inv_05,   
         isnull(opeom.inv_06,0) inv_06,   
         isnull(opeom.inv_07,0) inv_07,   
         isnull(opeom.inv_08,0) inv_08,   
         isnull(opeom.inv_09,0) inv_09,   
         isnull(opeom.inv_10,0) inv_10,   
         isnull(opeom.inv_11,0) inv_11,   
         isnull(opeom.inv_12,0) inv_12,   
         isnull(opeom.coll_01,0) coll_01,   
         isnull(opeom.coll_02,0) coll_02,   
         isnull(opeom.coll_03,0) coll_03,   
         isnull(opeom.coll_04,0) coll_04,   
         isnull(opeom.coll_05,0) coll_05,   
         isnull(opeom.coll_06,0) coll_06,   
         isnull(opeom.coll_07,0) coll_07,   
         isnull(opeom.coll_08,0) coll_08,   
         isnull(opeom.coll_09,0) coll_09,   
         isnull(opeom.coll_10,0) coll_10,   
         isnull(opeom.coll_11,0) coll_11,   
         isnull(opeom.coll_12,0) coll_12,   
         opeom.make_date,   
         opeom.make_user,   
         customer.cust_name,
         user_name = b.user_name  
    FROM customer    
         LEFT OUTER JOIN opeom ON customer.cust_no = opeom.cust_no 
					AND        ( datepart(year,opeom.eom_year) = :bb  ) 
         LEFT OUTER JOIN login B  ON customer.pre_salesman = b.user_id  
   WHERE ( ( customer.cust_no = :aa ))    
" arguments=(("aa", string),("bb", number)) )
