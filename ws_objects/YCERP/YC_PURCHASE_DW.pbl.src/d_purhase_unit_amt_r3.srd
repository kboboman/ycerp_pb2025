$PBExportHeader$d_purhase_unit_amt_r3.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=68 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(12) updatewhereclause=yes name=yyyymm dbname="yyyymm" )
 column=(type=decimal(6) updatewhereclause=yes name=unit_amt00001 dbname="unit_amt00001" )
 column=(type=decimal(6) updatewhereclause=yes name=unit_amt00002 dbname="unit_amt00002" )
 retrieve="select a.yyyymm,
          avg( case when a.unit_amt00001 = 0 then null else a.unit_amt00001 end ) unit_amt00001, 
          avg( case when a.unit_amt00002 = 0 then null else a.unit_amt00002 end ) unit_amt00002

from 
(
		select substring(yyyymm,3,2)+'년'+substring(yyyymm,5,2)+'월' yyyymm,
				sum(case when purchase_code = '00004' then kor_amt else 0 end) unit_amt00001,
				sum(case when purchase_code = '00005' then kor_amt else 0 end) unit_amt00002
		from purchase_unit_amt
		 where use_yn = 'Y'
		 and  purchase_code in ('00004', '00005')
		 and substring(yyyymm,1,6) between :as_fr_date  and :as_to_date
		group by substring(yyyymm,3,2)+'년'+substring(yyyymm,5,2)+'월'
) a
group by a.yyyymm" arguments=(("as_fr_date", string),("as_to_date", string)) )
