table(column=(type=char(10) updatewhereclause=yes name=basis_head_item_no dbname="basis_head.item_no" )
 column=(type=char(20) updatewhereclause=yes name=basis_head_qa dbname="basis_head.qa" )
 column=(type=char(2) updatewhereclause=yes name=basis_head_uom dbname="basis_head.uom" )
 column=(type=char(40) updatewhereclause=yes name=rem dbname="basis_head.rem" )
 column=(type=decimal(2) updatewhereclause=yes name=basis_head_amount dbname="basis_head.amount" )
 column=(type=char(30) updatewhereclause=yes name=basis_head_item_name dbname="basis_head.item_name" )
 column=(type=char(10) updatewhereclause=yes name=basis_det_asc_item dbname="basis_det.asc_item" )
 column=(type=char(20) updatewhereclause=yes name=basis_det_asc_qa dbname="basis_det.asc_qa" )
 column=(type=char(2) updatewhereclause=yes name=basis_det_uom dbname="basis_det.uom" )
 column=(type=decimal(3) updatewhereclause=yes name=basis_det_asc_qty dbname="basis_det.asc_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=basis_det_std_cost dbname="basis_det.std_cost" )
 column=(type=decimal(2) updatewhereclause=yes name=basis_det_std_amount dbname="basis_det.std_amount" )
 column=(type=char(30) updatewhereclause=yes name=basis_det_rem dbname="basis_det.rem" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 retrieve="  SELECT basis_head.item_no,   
         basis_head.qa,   
         basis_head.uom,   
         basis_head.rem,   
         basis_head.amount,   
         basis_head.item_name,   
         basis_det.asc_item,   
         basis_det.asc_qa,   
         basis_det.uom,   
         basis_det.asc_qty,   
         basis_det.std_cost,   
         basis_det.std_amount,   
         basis_det.rem,   
         groupitem.item_name  
from basis_det inner join basis_head on basis_det.item_no = basis_head.item_no
				 	left outer  join groupitem on basis_det.asc_item = groupitem.item_no
where  ( basis_head.item_no = :as_item )    " arguments=(("as_item", string))  sort="basis_head_item_no A basis_det_asc_item A basis_det_asc_qa A " )
group(level=1 header.height=532 trailer.height=0 by=("basis_head_item_no" ) newpage=yes resetpagecount=yes header.color="536870912" trailer.color="536870912" )
group(level=2 header.height=68 trailer.height=92 by=("basis_head_qa" ) header.color="536870912" trailer.color="536870912" )
