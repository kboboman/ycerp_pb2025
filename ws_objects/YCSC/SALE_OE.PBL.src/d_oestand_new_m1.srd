 retrieve="  SELECT sid        = a.sid       
       , sdate      = a.sdate     
       , cat        = a.cat       
       , seq        = a.seq       
       , item_no    = a.item_no   
       , itemnm_y   = a.itemnm_y  
       , qa_y       = a.qa_y      
       , uom        = a.uom       
       , itemnm_s   = a.itemnm_s  
       , qa_s       = a.qa_s      
       , itemnm_p   = a.itemnm_p  
       , qa_p       = a.qa_p      
       , qty        = a.qty       
       , amt_y      = a.amt_y     
       , amt_s      = a.amt_s     
       , amt_p      = a.amt_p     
       , bigo       = a.bigo      
    FROM NBASIS_DET a
   WHERE a.sid      = :as_sid
" update="NBASIS_DET" updatewhere=0 updatekeyinplace=no arguments=(("as_sid", string))  sort="sid A cat A seq A " )
