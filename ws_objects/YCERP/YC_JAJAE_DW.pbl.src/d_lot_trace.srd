table(column=(type=char(20) updatewhereclause=yes name=coil_no dbname="coil_no" )
 column=(type=char(60) updatewhereclause=yes name=coil_name dbname="coil_name" )
 column=(type=decimal(1) updatewhereclause=yes name=wid dbname="wid" )
 column=(type=long updatewhereclause=yes name=unitqty dbname="unitqty" )
