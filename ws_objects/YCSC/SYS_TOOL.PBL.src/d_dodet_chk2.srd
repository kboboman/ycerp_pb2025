$PBExportHeader$d_dodet_chk2.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=136 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=88 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=dodet_do_no dbname="dodet.do_no" )
 column=(type=long updatewhereclause=yes name=dodet_oi_no dbname="dodet.oi_no" )
 column=(type=decimal(8) updatewhereclause=yes name=qty dbname="qty" )
 column=(type=decimal(4) updatewhereclause=yes name=vat dbname="vat" )
 retrieve=" select dodet.do_no, oi_no,
		 			qty =sum( round(dbo.uf_getqty (dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty) * dodet.price, 0,0)) ,
 vat = sum( round(dodet.rate_cash, 0,1))		 from dodet, do
		where dodet.do_no = do.do_no
			and datepart(year, do_date) = :ai_year
			   and datepart(month, do_date) = :ai_mon
		group by dodet.do_no, oi_no" filter=" aa >1"arguments=(("ai_year", number),("ai_mon", number)) )
