type variables
//
DataWindowChild  idwc_supp, idwc_draw, idwc_area
DataWindow dw3, dw4, dw5, dw6, dw7, dw8, dw10, dw12, dw17


st_print i_print
boolean ib_first, ib_move, ib_auto
string  is_flag = '0', is_select, is_loc, is_round = "Y", is_orderno, is_tabcheck = '4'
dec {6} ia_rate, is_rate, is_tabpage
end variables

forward prototypes
public function boolean wf_move2 ()
public function boolean wf_move3 ()
public function boolean wf_move4 ()
public function boolean wf_move5 ()
public function boolean wf_move7 ()
public function boolean wf_move6 ()
public function boolean wf_outproc (string arg_subcon, long arg_row)
public function boolean wf_deleteproc (string arg_subcon, long arg_row)
public subroutine wf_calc (long arg_row)
public subroutine wf_calc_yrate (long arg_row)
public function decimal wf_price (string as_supp, string as_item, string as_qa, string as_uom)
public function boolean wf_sel (long arg_row)
public subroutine wf_calc2 (integer arg_row)
public function boolean wf_dw3chk ()
public function boolean wf_itemselect (datawindow arg_dw, string arg_ms, integer ai_row, integer ai_flag)
public function boolean wf_move4_new ()
public function decimal wf_price1 (string as_supp, string as_item, string as_qa, string as_uom)
end prototypes

event ue_1;//
string ls_colx

em_s.text = string(today(), "yyyy/mm/dd")
em_e.text = string(today(), "yyyy/mm/dd")
dw_9.settransobject(sqlca)
dw_9.visible = false

dw4.settransobject(sqlca)
dw5.settransobject(sqlca)
dw6.settransobject(sqlca)
dw7.settransobject(sqlca)
dw8.settransobject(sqlca)
dw_14.settransobject(sqlca)
dw_15.settransobject(sqlca)
dw_16.settransobject(sqlca)
dw17.settransobject(sqlca)

dw3.dataobject = 'd_ippurdet'
dw3.settransobject(sqlca)
dw3.getchild('draw_no',idwc_draw)
idwc_draw.settransobject(sqlca)
is_select = idwc_draw.Describe("DataWindow.Table.Select")

dw_1.getchild('supp_no',idwc_supp)
idwc_supp.settransobject(sqlca)
tab_1.tabpage_2.dw_loc.settransobject(sqlca)
tab_1.tabpage_2.dw_loc.insertrow(0)

dw_area.settransobject(sqlca)
dw_area.insertrow(0)  
dw_area.object.area[1] = gs_area

SELECT def_loc INTO :is_loc FROM area WHERE area_no = :gs_area;
tab_1.tabpage_2.dw_loc.object.loc_no[1] = is_loc


tab_1.tabpage_8.em_4.text  = "HD" + string(today(), "yyyy")		// 수주기본 사업장 
tab_1.tabpage_8.cb_30.text = "수주물품별 재고현황(NEW) " + string(dw_jaego.rowcount()) + " 건 가져오기"

tab_1.tabpage_4.em_3.text  = "HD" + string(today(), "yyyy")		// 수주기본 사업장 
tab_1.tabpage_4.cb_18.text = "수주물품별 재고현황(NEW) " + string(dw_jaego.rowcount()) + " 건 가져오기"


if dw_jaego.rowcount() > 0 then
	
	if is_tabcheck = '4' then
		tab_1.selecttab(4)	// 수주내역			
	else
		tab_1.selecttab(8)	// 수주내역				
	end if
	
	pb_insert.triggerevent(clicked!)
		
	dw_1.setcolumn("supp_no")
	dw_1.setfocus()
	MessageBox("확인","수주물품별 재고현황(NEW) 자동처리 작업입니다.~r~r거래처를 먼저 선택하십시오.")
	
end if


// 알루미늄, 스틸 비중 읽어오기
SELECT al_rate, st_rate INTO :ia_rate, :is_rate FROM globals;

// 담당자별 거래처유형 필터링
dw_11.settransobject(sqlca)
dw_11.insertrow(0)
if gs_userid = 'bestvic' then	// 최성욱
	DataWindowChild state_child
	dw_11.GetChild('supp_no', state_child)
	state_child.SetTransObject(SQLCA)	
end if

end event

public function boolean wf_move2 ();long ll_rowcount,ll_rowcount1,ll_cnt,ll_find,ll_row,ll_count
string ls_plan,ls_order,ls_uom,ls_supp,ls_qa,ls_item,ls_subcon
string ls_qa1, ls_loc, ls_comp, ls_sale, ls_scene
decimal {4} lr_cost

dw_1.accepttext()
dw4.accepttext()

if dw_1.rowcount() < 1 then 
	MessageBox("오류","발주를 입력하십시오.", Exclamation!)
	dw4.selectrow(0,false)
	return false
end if	

ls_supp = trim(dw_1.object.supp_no[1])

if isnull(ls_supp) or ls_supp=""  then
	MessageBox("오류","발주헤더에 거래처를 입력하십시오.", Exclamation!)
	dw4.selectrow(0,false)
	return false
end if	
dw_1.object.subcon[1] = 'P'
ll_rowcount1 = dw3.rowcount()
ll_rowcount  = dw4.rowcount()

ll_count = 0
for ll_cnt = 1 to ll_rowcount
	if dw4.isselected(ll_cnt) then
      ll_count ++
	end if
next
if ll_count = 0 then
	messagebox('오류','외주가공대상물품을 선택하십시요.',exclamation!)
	return false
end if

for ll_cnt = 1 to ll_rowcount
	if dw4.isselected(ll_cnt) then
		ls_plan = trim(dw4.object.order_no[ll_cnt])
		if ll_rowcount1 < 1 then
			ll_find = 0
		else
		   ll_find = dw3.find("product_no = '" + ls_plan + "'",1,dw3.rowcount())
		end if
		if ll_find = 0 then
			ls_item = trim(dw4.object.item_no[ll_cnt])
			ls_qa   = trim(dw4.object.qa[ll_cnt])
			ls_uom  = trim(dw4.object.groupitem_uom[ll_cnt])
			/*2019.08.14 jowonsuk  최근단가가 기본이다. */
			if cbx_danga.checked then			
			 	lr_cost = wf_price1(ls_supp, ls_item, ls_qa, ls_uom)
			else
				lr_cost = wf_price (ls_supp, ls_item, ls_qa, ls_uom)
			end if

			ll_row = dw3.insertrow(0)
			dw3.object.seq_no[ll_row] = ll_row
			dw3.object.price[ll_row] = lr_cost
			dw3.object.cprice[ll_row] = lr_cost
			dw3.object.com_uom[ll_row] = ls_uom
			dw3.object.uom[ll_row] = gf_uom(ls_uom)
			dw3.object.com_qty[ll_row] = gf_getqty(ls_item, ls_qa, ls_uom, dw4.object.plan_qty[ll_cnt])
			if is_round = 'Y' then
				dw3.object.amt[ll_row] = round(dw3.object.com_qty[ll_row] + dw3.object.price[ll_row],0 )
			else
				dw3.object.amt[ll_row] = truncate(dw3.object.com_qty[ll_row] + dw3.object.price[ll_row],0 )
			end if
			dw3.object.order_no[ll_row]   = ls_order
			dw3.object.product_no[ll_row] = ls_plan
			dw3.object.item_no[ll_row]    = ls_item
			
			dw3.object.qa[ll_row]         = ls_qa
         		dw3.object.item_item_name[ll_row]  =  dw4.object.itemname1[ll_cnt]
			dw3.object.order_qty[ll_row]  = dw4.object.plan_qty[ll_cnt]
			dw3.object.unit_qty[ll_row] = dw3.object.order_qty[ll_row]
			dw3.object.rlse_date[ll_row]  =  wf_today()
			dw3.object.due_date[ll_row]   =  dw4.object.due_date[ll_cnt]
			dw3.object.sale_no[ll_row]    =  dw4.object.sudodet_sale_no[ll_cnt]
			dw3.object.sale_seq[ll_row]   =  dw4.object.sudodet_seq_no[ll_cnt]
			ls_sale = dw3.object.sale_no[ll_row]
			select scene.scene_desc into :ls_scene from sale, scene
			 where order_no = :ls_sale
			   and scene.scene_code = sale.scene_code;
			if isnull(ls_scene) or trim(ls_scene) = '' then
				ls_scene = ''
			else
				ls_scene = '/' + ls_scene
			end if
			dw3.object.cust_name[ll_row]  =  dw4.object.customer_cust_name[ll_cnt] + ls_scene
			dw3.object.color[ll_row]      =  dw4.object.sudodet_color[ll_cnt]
			dw3.object.sale_rem[ll_row]      =  dw4.object.rem[ll_cnt]
			dw3.object.pur_type[ll_row]   =  'P'
//			dw3.object.coil_no[ll_row]      =  dw4.object.issue_lot[ll_cnt] //원코일번호
//			dw4.RowsMove ( ll_cnt, ll_cnt, Primary!, dw4, 1, Filter! )
//			ll_cnt = ll_cnt - 1
		end if
	end if
next
if wf_update1(dw4,'N') = false then
	return false
end if
messagebox('확인','외주가공대상물품이 이동되었습니다.',information!)
return true

end function

public function boolean wf_move3 ();long ll_rowcount,ll_rowcount1,ll_cnt,ll_find,ll_row,ll_count
string ls_plan,ls_order,ls_uom,ls_supp,ls_qa,ls_item,ls_subcon,ls_qa1, ls_sale, ls_scene
decimal {4} lr_cost

dw_1.accepttext()
dw5.accepttext()

if dw_1.rowcount() < 1 then 
	MessageBox("오류","발주헤더를 입력하십시오.", Exclamation!)
	dw5.selectrow(0,false)
	return false
end if	
ls_supp = trim(dw_1.object.supp_no[1])

if isnull(ls_supp) or ls_supp=""  then
	MessageBox("오류","발주헤더에 거래처를 입력하십시오.", Exclamation!)
	dw5.selectrow(0,false)
	return false
end if	

dw_1.object.subcon[1] = 'Y'
ll_rowcount1 = dw3.rowcount()
ll_rowcount  = dw5.rowcount()

ll_count = 0
for ll_cnt = 1 to ll_rowcount
	if dw5.isselected(ll_cnt) then
      ll_count ++
	end if
next
if ll_count = 0 then
	messagebox('오류','외주구매대상물품을 선택하십시요.',exclamation!)
	return false
end if

for ll_cnt = 1 to ll_rowcount
	if dw5.isselected(ll_cnt) then
		ls_plan = trim(dw5.object.order_no[ll_cnt])
		if ll_rowcount1 < 1 then
			ll_find = 0
		else
		   ll_find = dw3.find("product_no = '" + ls_plan + "'", 1, dw3.rowcount())
		end if
		if ll_find = 0 then
			ls_item = trim(dw5.object.item_no[ll_cnt])
			ls_qa   = trim(dw5.object.qa[ll_cnt])
			ls_uom  = trim(dw5.object.groupitem_uom[ll_cnt])		 	
			/*2019.08.14 jowonsuk  최근단가가 기본이다. */
			if cbx_danga.checked then			
			 	lr_cost = wf_price1(ls_supp, ls_item, ls_qa, ls_uom)
			else
				lr_cost = wf_price (ls_supp, ls_item, ls_qa, ls_uom)
			end if			 
			
         ll_row = dw3.insertrow(0)
			dw3.object.seq_no[ll_row] = ll_row
			dw3.object.price[ll_row] = lr_cost
			dw3.object.cprice[ll_row] = lr_cost
			dw3.object.com_uom[ll_row] = ls_uom
			dw3.object.uom[ll_row] = gf_uom(ls_uom)
			dw3.object.com_qty[ll_row] = gf_getqty(ls_item, ls_qa, ls_uom, dw5.object.plan_qty[ll_cnt])
			if is_round = 'Y' then
				dw3.object.amt[ll_row] = round(dw3.object.com_qty[ll_row] + dw3.object.price[ll_row],0 )
			else
				dw3.object.amt[ll_row] = truncate(dw3.object.com_qty[ll_row] + dw3.object.price[ll_row],0 )
			end if

			dw3.object.order_no[ll_row]   = ls_order
			dw3.object.product_no[ll_row] = ls_plan
			dw3.object.item_no[ll_row]    = ls_item
			dw3.object.qa[ll_row]         = ls_qa
         		dw3.object.item_item_name[ll_row]  =  dw5.object.groupitem_item_name[ll_cnt]
			dw3.object.order_qty[ll_row]  = dw5.object.plan_qty[ll_cnt]
			dw3.object.unit_qty[ll_row] = dw3.object.order_qty[ll_row]
			dw3.object.rlse_date[ll_row]   =  wf_today()
			dw3.object.due_date[ll_row]   =  dw5.object.due_date[ll_cnt]
			dw3.object.sale_no[ll_row]    =  dw5.object.sudodet1_sale_no[ll_cnt]
			dw3.object.sale_seq[ll_row]   =  dw5.object.sudodet1_seq_no[ll_cnt]
			ls_sale = dw3.object.sale_no[ll_row]
			select scene.scene_desc into :ls_scene from sale, scene
			 where order_no = :ls_sale
			   and scene.scene_code = sale.scene_code;
			if isnull(ls_scene) or trim(ls_scene) = '' then
				ls_scene = ''
			else
				ls_scene = '/' + ls_scene
			end if
			dw3.object.cust_name[ll_row]  =  dw5.object.customer_cust_name[ll_cnt] + ls_scene
			dw3.object.color[ll_row]      =  dw5.object.sudodet1_color[ll_cnt]	
			dw3.object.sale_rem[ll_row]   =  dw5.object.rem[ll_cnt]
			dw3.object.pur_type[ll_row]   =  'Y'
			dw5.RowsMove ( ll_cnt, ll_cnt, Primary!, dw5, 1, Filter! )
			ll_cnt = ll_cnt - 1
		end if
	end if
next
messagebox('확인','외주구매대상물품이 이동되었습니다.',information!)
return true

end function

public function boolean wf_move4 ();//
long    ll_rowcount, ll_rowcount1, ll_cnt,  ll_find, ll_row, ll_count
string  ls_plan, ls_order, ls_uom, ls_supp, ls_qa, ls_item, ls_subcon, ls_qa1, ls_scene, ls_saleno
decimal {4} lr_cost, lr_qty
datetime ldt_due_date

dw_1.accepttext()
dw6.accepttext()

if dw_1.rowcount() < 1 then 
	MessageBox("오류","발주헤더를 입력하십시오.", Exclamation!)
	dw6.selectrow(0,false)
	RETURN false
end if	

ls_order  = trim(dw_1.object.order_no[1])
ls_subcon = trim(dw_1.object.subcon[1])


if ls_subcon = "Y" OR ls_subcon = "J" or ls_subcon = "P"  then
	MessageBox("오류","구매발주가 아닙니다.", Exclamation!)
	dw6.selectrow(0,false)
	RETURN false
end if	

ls_supp = trim(dw_1.object.supp_no[1])
if isnull(ls_supp) or ls_supp = "" then
	MessageBox("오류","발주헤더에 거래처를 입력하십시오.", Exclamation!)
	dw6.selectrow(0,false)
	RETURN false
end if	

ll_rowcount1 = dw3.rowcount()
ll_rowcount  = dw6.rowcount()

ll_count = 0
for ll_cnt = 1 to ll_rowcount
	if dw6.isselected(ll_cnt) then
      ll_count ++
	end if
next
if ll_count = 0 then
	MessageBox('오류','수주대상물품을 선택하십시요.',exclamation!)
	RETURN false
end if

for ll_cnt = 1 to ll_rowcount
	if dw6.isselected(ll_cnt) then
		
		if ll_rowcount1 < 1 then
			ll_find = 0
		else
		   ll_find = dw3.find("item_no = '" + ls_item + "' and qa = '" + ls_qa + "'",1,dw3.rowcount())
		end if
		
		if ll_find = 0 then
			ls_item = trim(dw6.object.item_no[ll_cnt])
			ls_qa   = trim(dw6.object.qa[ll_cnt])
			ls_uom  = trim(dw6.object.uom[ll_cnt])

			/*2019.08.14 jowonsuk  최근단가가 기본이다. */
			if cbx_danga.checked then			
			 	lr_cost = wf_price1(ls_supp, ls_item, ls_qa, ls_uom)
			else
				lr_cost = wf_price (ls_supp, ls_item, ls_qa, ls_uom)
			end if			 

			ll_row = dw3.insertrow(0)
			dw3.object.seq_no[ll_row]   = ll_row
			dw3.object.price[ll_row]    = lr_cost
			dw3.object.cprice[ll_row]   = lr_cost
			dw3.object.com_uom[ll_row]  = dw6.object.uom[ll_cnt]
			dw3.object.uom[ll_row]      = gf_uom(ls_uom)
			dw3.object.order_no[ll_row] = ls_order
			dw3.object.item_no[ll_row]  = ls_item
			dw3.object.qa[ll_row]       = ls_qa
			dw3.object.due_date[ll_row] = wf_today()
        		dw3.object.item_item_name[ll_row]  =  dw6.object.item_name[ll_cnt]
				  
			if dw6.object.req_qty[ll_cnt] < 0 then
				lr_qty = dw6.object.req_qty[ll_cnt] * -1
			else
				lr_qty = dw6.object.saledetqty[ll_cnt]
			end if
			
			dw3.object.com_qty[ll_row] = gf_getqty(ls_item, ls_qa, ls_uom, lr_qty)
			if is_round = 'Y' then
				dw3.object.amt[ll_row] = round(dw3.object.com_qty[ll_row] + dw3.object.price[ll_row],0 )
			else
				dw3.object.amt[ll_row] = truncate(dw3.object.com_qty[ll_row] + dw3.object.price[ll_row],0 )
			end if

			setnull(ls_scene)
			ls_saleno  = dw6.object.order_no[ll_cnt]
			dw3.object.sale_no[ll_row]    =  ls_saleno
			dw3.object.sale_seq[ll_row]   =  dw6.object.seq_no[ll_cnt]
			dw3.object.sale_rem[ll_row]   =  dw6.object.saledet_rem[ll_cnt]
			
			SELECT due_date, scene.scene_desc
			  INTO :ldt_due_date, :ls_scene 
			  FROM sale
			       LEFT OUTER JOIN scene ON sale.scene_code = scene.scene_code
			 WHERE order_no = :ls_saleno;
			if isnull(ls_scene) OR trim(ls_scene) = "" then
				ls_scene = ""
			else
				ls_scene = "/" + ls_scene
			end if
			
			dw3.object.cust_name[ll_row] = dw6.object.cust_name[ll_cnt] + ls_scene
			dw3.object.order_qty[ll_row] = lr_qty
//			dw3.object.com_qty[ll_row]   = lr_qty
			dw3.object.unit_qty[ll_row]  = lr_qty
			dw3.object.cnt[ll_row]       = 1
			dw3.object.rlse_date[ll_row] = ldt_due_date		// 확정일자
        		dw3.object.pur_type[ll_row]  = "N"
        		dw3.object.color[ll_row]     = dw6.object.color[ll_cnt]
			
			dw6.RowsMove ( ll_cnt, ll_cnt, Primary!, dw6, 1, Filter! )
			
			ll_cnt = ll_cnt - 1
		end if
	end if
next

if ib_auto = true then
else
	MessageBox('확인','수주대상물품이 이동 되었습니다.',information!)
end if
//dw6.selectrow(0,false)
RETURN true

end function

