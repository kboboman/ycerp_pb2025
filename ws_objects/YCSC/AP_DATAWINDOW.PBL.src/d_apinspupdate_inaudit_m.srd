 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"inaudit~" ) COLUMN(NAME=~"inaudit.inaudit_time~") COLUMN(NAME=~"inaudit.inaudit_date~") COLUMN(NAME=~"inaudit.inaudit_item~") COLUMN(NAME=~"inaudit.qa~") COLUMN(NAME=~"inaudit.loc_no~") COLUMN(NAME=~"inaudit.inaudit_type~") COLUMN(NAME=~"inaudit.order_no~") COLUMN(NAME=~"inaudit.rcpt_qty~") COLUMN(NAME=~"inaudit.issue_qty~") COLUMN(NAME=~"inaudit.cost~") COLUMN(NAME=~"inaudit.destination~") COLUMN(NAME=~"inaudit.serial_id~") COLUMN(NAME=~"inaudit.rem~") COLUMN(NAME=~"inaudit.unit_qty~") COLUMN(NAME=~"inaudit.cnt~") COLUMN(NAME=~"inaudit.com_qty~") COLUMN(NAME=~"inaudit.user_id~")WHERE(    EXP1 =~"inaudit.order_no~"   OP =~"=~"    EXP2 =~":aa~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"inaudit.cnt~"   OP =~"=~"    EXP2 =~":bb~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"inaudit.rcpt_qty~"   OP =~">=~"    EXP2 =~"0~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"inaudit.issue_qty~"   OP =~">=~"    EXP2 =~"0~" ) ) ARG(NAME = ~"aa~" TYPE = string)  ARG(NAME = ~"bb~" TYPE = number) " update="inaudit" updatewhere=1 updatekeyinplace=no arguments=(("aa", string),("bb", number)) )
