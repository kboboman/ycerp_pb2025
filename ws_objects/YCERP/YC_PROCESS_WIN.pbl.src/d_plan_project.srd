table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=cust_no dbname="plan_project.cust_no" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="plan_project.item_no" )
 column=(type=datetime update=yes updatewhereclause=yes key=yes name=plan_date dbname="plan_project.plan_date" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=plan_qty dbname="plan_project.plan_qty" )
 retrieve="  SELECT plan_project.cust_no
       , plan_project.item_no
       , plan_project.plan_date
       , plan_project.plan_qty  
    FROM plan_project   
   WHERE plan_project.plan_date between :ad_sdate AND :ad_edate
" update="plan_project" updatewhere=0 updatekeyinplace=no arguments=(("ad_sdate", datetime),("ad_edate", datetime))  sort="cust_no A item_no A plan_date A " )
