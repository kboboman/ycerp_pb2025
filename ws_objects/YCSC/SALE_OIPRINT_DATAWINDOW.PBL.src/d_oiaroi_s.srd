detail(height=100 color="536870912" )
table(column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=datetime updatewhereclause=yes name=oi_date dbname="aroiinv.oi_date" )
 column=(type=char(12) updatewhereclause=yes name=aroiinv_no dbname="aroi.aroiinv_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="aroi.qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="aroi.uom" )
 column=(type=decimal(2) updatewhereclause=yes name=ship_qty dbname="aroi.ship_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=price dbname="aroi.price" )
 column=(type=decimal(4) updatewhereclause=yes name=ori_amount dbname="aroi.ori_amount" )
 column=(type=decimal(4) updatewhereclause=yes name=rate_cash dbname="aroi.rate_cash" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="aroi.seq_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="aroi.item_no" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="aroiinv.cust_no" )
 column=(type=char(14) updatewhereclause=yes name=aroi_do_no dbname="aroi.do_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="groupitem.item_name" )
 column=(type=long updatewhereclause=yes name=aroi_oi_no dbname="aroi.oi_no" )
 retrieve="  SELECT customer.cust_name,   
         aroiinv.oi_date,   
         aroi.aroiinv_no,   
         aroi.qa,   
         aroi.uom,   
         aroi.ship_qty,   
         aroi.price,   
         aroi.ori_amount,   
         aroi.rate_cash,   
         aroi.seq_no,   
         aroi.item_no,   
         aroiinv.cust_no,   
         aroi.do_no,   
         groupitem.item_name,   
         aroi.oi_no  
    FROM aroi,   
         aroiinv,   
         customer,   
         groupitem  
   WHERE ( aroi.aroiinv_no = aroiinv.aroiinv_no ) and  
         ( aroiinv.cust_no = customer.cust_no ) and  
         ( aroi.item_no = groupitem.item_no )    
" )
