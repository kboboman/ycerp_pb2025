$PBExportComments$생산계획
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=saler_user dbname="saler_user" )
 column=(type=char(10) updatewhereclause=yes name=salesman dbname="salesman" )
 column=(type=char(10) updatewhereclause=yes name=wc_no dbname="wc_no" )
 column=(type=char(10) updatewhereclause=yes name=work_name dbname="work_name" )
 column=(type=long updatewhereclause=yes name=priority dbname="priority" )
 column=(type=datetime updatewhereclause=yes name=napgi_date dbname="napgi_date" )
 column=(type=char(14) updatewhereclause=yes name=sale_no dbname="sale_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="seq_no" )
 column=(type=datetime updatewhereclause=yes name=start_date dbname="start_date" )
 column=(type=char(1) updatewhereclause=yes name=mpsorder_overtime dbname="mpsorder_overtime" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(11) updatewhereclause=yes name=scene_code dbname="scene_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=char(4) updatewhereclause=yes name=item_color dbname="item_color" )
 column=(type=char(10) updatewhereclause=yes name=color_name dbname="color_name" )
 column=(type=char(50) updatewhereclause=yes name=mpsdet_rem dbname="mpsdet_rem" )
 column=(type=decimal(4) updatewhereclause=yes name=order_qty dbname="order_qty" )
 column=(type=char(17) updatewhereclause=yes name=plan_no dbname="plan_no" )
 column=(type=char(17) updatewhereclause=yes name=order_no dbname="order_no" )
 column=(type=datetime updatewhereclause=yes name=due_date dbname="due_date" )
 column=(type=char(1) updatewhereclause=yes name=suju_type dbname="suju_type" )
 column=(type=char(1) updatewhereclause=yes name=rcpt_type dbname="rcpt_type" )
 column=(type=decimal(4) updatewhereclause=yes name=rcpt_qty dbname="rcpt_qty" )
 column=(type=char(16) updatewhereclause=yes name=mpsorder_order dbname="mpsorder_order" )
 column=(type=long updatewhereclause=yes name=order_seq dbname="order_seq" )
 column=(type=datetime updatewhereclause=yes name=order_date dbname="order_date" )
 column=(type=char(10) updatewhereclause=yes name=work_manager dbname="work_manager" )
 column=(type=char(1) updatewhereclause=yes name=utong_yn dbname="utong_yn" )
 retrieve="  SELECT saler_user = (SELECT saler_user FROM aroiinv_esero WHERE id      = customer.salesman ) /* 담당자   */
       , salesman   = (SELECT user_name  FROM login         WHERE user_id = customer.salesman ) /* 영업담당 */
       , mpsdet.wc_no                                     /* 작업장   */
       , wc.work_name                                     /* 작업장명 */
       , mpsdet.priority                                  /* 순위     */
       , mpsdet.napgi_date                                /* 납기일자 */
       , mpsdet.sale_no                                   /* 수주번호 */
       , mpsdet.seq_no                                    /* 수주순번 */
       , mps.start_date                                   /* 생산시작 */
       , mpsorder_overtime = isnull(mpsorder.overtime,'') /* 야간     */
       , mpsdet.cust_no                                   /* 거래처   */
       , customer.cust_name                               /* 거래처명 */
       , mpsdet.scene_code                                /* 현장     */
       , scene.scene_desc                                 /* 현장명   */
       , mpsdet.item_no                                   /* 품목     */
       , groupitem.item_name                              /* 품목명   */
       , mpsdet.qa                                        /* 규격     */
       , mpsdet.uom                                       /* 단위     */
       , mpsdet.item_color                                /* 색상     */
       , color.color_name                                 /* 색상명   */
       , mpsdet_rem        = isnull(mpsdet.rem,'')        /* 품목비고 */
       , mpsdet.order_qty                                 /* 계획수량 */
       , mpsdet.plan_no                                   /* 계획번호 */
       
       , mpsdet.order_no                                  /* 계획헤더 */
       , mpsdet.due_date                                  /* 납기일자 */
       , mpsdet.suju_type                                 /* 수주유형 */
       , mpsdet.rcpt_type                                 /* 입고유형 */
       , mpsdet.rcpt_qty                                  /* 입고수량 */
       , mpsdet.mpsorder_order                            /* 작지번호 */
       , mpsdet.order_seq                                 /* 작지순번 */
       , mpsorder.order_date                              /* 작지일자 */
       , wc.work_manager                                  /* 작업반장 */
	  , isnull(scene.utong_yn,'N') utong_yn
    FROM  mpsdet inner join  mps  on  mpsdet.order_no      = mps.order_no   
					    inner join  mpsorder on  mpsdet.mpsorder_order    = mpsorder.order_no
					    inner join  wc on mpsdet.wc_no         = wc.work_no
       				    inner join  groupitem  on mpsdet.item_no       = groupitem.item_no   
				         left outer join customer on  mpsdet.cust_no = customer.cust_no 
       				    left outer join color  on mpsdet.item_color = color.color_code 
					    left outer join scene on mpsdet.scene_code = scene.scene_code 
    where ( mps.start_date      >= :ad_date              )
     AND  ( wc.work_name      LIKE :as_worknm    )
     AND ( mps.area_no          = :as_areano            )
/*
    FROM mpsdet        /* 생산계획상세 */
       , mps           /* 생산계획헤더 */
       , wc            /* 작업장       */
       , customer      /* 거래처       */
       , scene         /* 현장         */
       , color         /* 색상         */
       , groupitem     /* 그룹품목     */
       , mpsorder      /* 작업지시서   */
   WHERE ( mpsdet.scene_code   *= scene.scene_code      )
     AND ( mpsdet.cust_no      *= customer.cust_no      )
     AND ( mpsdet.item_color   *= color.color_code      )
     AND ( mpsdet.wc_no         = wc.work_no            )
     AND ( mpsdet.item_no       = groupitem.item_no     )
     AND ( mpsdet.order_no      = mps.order_no          )
     AND ( mpsorder.order_no    = mpsdet.mpsorder_order )
     AND ( mps.start_date      >= :ad_date              )
     AND ( wc.work_name      LIKE :as_worknm            )
     AND ( mps.area_no          = :as_areano            )
*/" arguments=(("ad_date", date),("as_worknm", string),("as_areano", string))  sort="wc_no A plan_no A right( '00' + trim( string(priority) ) , 3 ) A napgi_date A qa A " )
group(level=1 header.height=0 trailer.height=80 by=("wc_no" ) header.color="536870912" trailer.color="12639424" )
