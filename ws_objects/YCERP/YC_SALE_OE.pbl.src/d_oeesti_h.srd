$PBExportComments$견적서 시스템코드추가(2001/02/19,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=88 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=item_no dbname="basis_det.item_no" )
 column=(type=char(10) updatewhereclause=yes name=asc_item dbname="basis_det.asc_item" )
 column=(type=char(20) updatewhereclause=yes name=asc_qa dbname="basis_det.asc_qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="basis_det.uom" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="seq_no" )
 column=(type=decimal(3) updatewhereclause=yes name=asc_qty dbname="basis_det.asc_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=std_cost dbname="basis_det.std_cost" )
 column=(type=decimal(2) updatewhereclause=yes name=std_amount dbname="basis_det.std_amount" )
 column=(type=char(30) updatewhereclause=yes name=rem dbname="basis_det.rem" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 retrieve="  SELECT basis_det.item_no
       , basis_det.asc_item   
       , basis_det.asc_qa   
       , basis_det.uom   
       , seq_no   = 0
       , basis_det.asc_qty   
       , basis_det.std_cost   
       , basis_det.std_amount   
       , basis_det.rem   
       , groupitem.item_name  
    FROM basis_det 
         LEFT OUTER JOIN groupitem ON basis_det.asc_item = groupitem.item_no  
   WHERE basis_det.item_no    LIKE :as_item    
     AND (:as_basis    = 'Y' )

  UNION ALL
  
  SELECT yspgrp_det.item_no
       , yspgrp_det.asc_item   
       , yspgrp_det.asc_qa   
       , yspgrp_det.uom   
       , yspgrp_det.seq_no
       , yspgrp_det.asc_qty   
       , yspgrp_det.std_cost   
       , yspgrp_det.std_amount   
       , yspgrp_det.rem   
       , groupitem.item_name  
    FROM yspgrp_det 
         LEFT OUTER JOIN groupitem ON yspgrp_det.asc_item = groupitem.item_no  
   WHERE yspgrp_det.item_no    LIKE :as_item    
     AND (:as_basis    = 'N' )

" arguments=(("as_item", string),("as_basis", string))  sort="item_no A seq_no A " )
