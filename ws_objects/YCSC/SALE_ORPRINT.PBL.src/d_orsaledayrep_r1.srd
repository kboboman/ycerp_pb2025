$PBExportComments$수주일보REPORT(1998/05/12, 정재수)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=580 color="536870912" )
summary(height=80 color="536870912" )
footer(height=0 color="536870912" )
detail(height=148 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=cust_no dbname="sale.cust_no" initial=" " )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=char(11) updatewhereclause=yes name=sale_scene_code dbname="sale.scene_code" initial=" " )
 column=(type=char(14) updatewhereclause=yes name=sale_order_no dbname="sale.order_no" initial=" " )
 column=(type=char(1) updatewhereclause=yes name=sale_sale_flag dbname="sale.sale_flag" initial=" " values="내수	D/수출	E/L//C	L/" )
 column=(type=char(3) updatewhereclause=yes name=sale_curr_code dbname="sale.curr_code" initial=" " )
 column=(type=datetime updatewhereclause=yes name=sale_order_date dbname="sale.order_date" initial=" " )
 column=(type=datetime updatewhereclause=yes name=sale_cust_po_date dbname="sale.cust_po_date" )
 column=(type=datetime updatewhereclause=yes name=sale_due_date dbname="sale.due_date" initial=" " )
 column=(type=long updatewhereclause=yes name=saledet_seq_no dbname="saledet.seq_no" )
 column=(type=char(10) updatewhereclause=yes name=saledet_item_no dbname="saledet.item_no" )
 column=(type=char(20) updatewhereclause=yes name=saledet_qa dbname="saledet.qa" )
 column=(type=char(2) updatewhereclause=yes name=saledet_uom dbname="saledet.uom" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_order_qty dbname="saledet.order_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_acc_qty dbname="saledet.acc_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=saledet_price dbname="saledet.price" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 column=(type=datetime updatewhereclause=yes name=c_start dbname="c_start" )
 column=(type=datetime updatewhereclause=yes name=c_end dbname="c_end" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(8) updatewhereclause=yes name=c_text dbname="c_text" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_rlse_qty dbname="saledet.rlse_qty" )
 column=(type=char(30) updatewhereclause=yes name=sale_ship_flag dbname="ship_flag" )
 column=(type=char(10) updatewhereclause=yes name=color_color_name dbname="color.color_name" )
 column=(type=char(10) updatewhereclause=yes name=wc_work_name dbname="wc.work_name" )
 retrieve="  SELECT sale.cust_no,   
         customer.cust_name,   
         sale.scene_code,   
         sale.order_no,   
         sale.sale_flag,   
         sale.curr_code,   
         sale.order_date,   
         sale.cust_po_date,   
         sale.due_date,   
         saledet.seq_no,   
         saledet.item_no,   
         saledet.qa,   
         saledet.uom,   
         saledet.order_qty,   
         saledet.acc_qty,   
         saledet.price,   
         scene.scene_desc,   
         c_start = convert(smalldatetime, :ad_start, 111),   
         c_end = convert(smalldatetime, :ad_end, 111),   
         groupitem.item_name,   
         '        ' c_text,   
         saledet.rlse_qty,   
         ship_flag = dbo.uf_getshipflag(sale.ship_flag),   
         color.color_name , 
         wc.work_name
    FROM sale  with(nolock) inner join saledet   with(nolock) on  sale.order_no         = saledet.order_no
                                               inner join customer  with(nolock) on sale.cust_no          = customer.cust_no
                                               inner join groupitem  with(nolock) on saledet.item_no       = groupitem.item_no
                                               left outer  join scene with(nolock) on sale.cust_no    = scene.cust_no and sale.scene_code     = scene.scene_code
                                               left outer join color  with(nolock) on  saledet.color   = color.color_code 
                                               inner join routtempnew  with(nolock) on saledet.order_no      = routtempnew.sale_no and  saledet.seq_no = routtempnew.seq_no
                                               inner join wc  with(nolock) on routtempnew.wc_no     = wc.work_no                                                                
WHERE ( sale.open_close      <> 'X'                 ) 
     AND ( sale.cust_no       LIKE :as_cust            ) 
     AND ( customer.salesman  LIKE :as_ret             ) 
     AND ( sale.sale_flag       IN (:asa_sale_flag)    ) 
     AND ( sale.order_date BETWEEN :ad_start AND :ad_end ) 
     AND ( sale.confirm_flag    IN (:asa_confirm_flag) ) 
     AND ( sale.order_no      LIKE :as_area            ) 
     AND ( sale.ship_flag     LIKE :as_f               ) 
     AND ( sale.salesman      LIKE :as_userid          ) 
     AND ((:as_class = 'A') OR 
          (:as_class = 'P' AND customer.credit_level in ('D', 'E', 'F') )
         )
/*
    FROM customer,   
         groupitem,   
         sale,   
         saledet,   
         routtempnew ,
         wc , 
         scene,   
         color  
   WHERE ( sale.open_close <> 'X') and  
         ( sale.cust_no *= scene.cust_no) and  
         ( sale.scene_code *= scene.scene_code) and  
         ( saledet.color *= color.color_code) and  
         ( saledet.order_no  = routtempnew.sale_no ) and
         ( saledet.seq_no    = routtempnew.seq_no  ) and
         ( routtempnew.wc_no = wc.work_no          ) and 
         ( sale.order_no = saledet.order_no ) and  
         ( sale.cust_no like :as_cust ) and  
         ( sale.cust_no = customer.cust_no ) and  
         ( customer.salesman like:as_ret ) and  
         ( saledet.item_no = groupitem.item_no ) and  
         ( sale.sale_flag in (:asa_sale_flag) ) AND  
         ( sale.order_date between :ad_start and :ad_end ) AND  
         ( sale.confirm_flag in (:asa_confirm_flag) ) AND  
         ( sale.order_no like :as_area ) AND  
         ( sale.ship_flag like :as_f ) AND  
			( sale.salesman like :as_userid ) AND 
         ( :as_class = 'A' or ( :as_class = 'P' and  customer.credit_level in ('D', 'E', 'F') ))

*/" arguments=(("asa_sale_flag", string),("ad_start", date),("ad_end", date),("asa_confirm_flag", string),("as_area", string),("as_f", string),("as_cust", string),("as_ret", string),("as_class", string),("as_userid", string))  sort="cust_name A sale_scene_code A sale_order_date A sale_order_no A saledet_seq_no A " )
