$PBExportHeader$d_apglbill_r1.srd
$PBExportComments$어음처리내역 REPORT(1999/05/25, 이인호)
release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=372 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=68 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=apbill_close_date dbname="apbill.close_date" )
 column=(type=char(1) updatewhereclause=yes name=apbill_bill_class dbname="apbill.bill_class" values="받을어음	R/지급어음	P/교환어음	C/만기어음	E/부도어음	D/" )
 column=(type=decimal(0) updatewhereclause=yes name=apbill_bill_amount dbname="apbill.bill_amount" )
 column=(type=char(30) updatewhereclause=yes name=supp_supp_name dbname="supp.supp_name" )
 column=(type=char(20) updatewhereclause=yes name=apbill_draft dbname="apbill.draft" )
 column=(type=char(12) updatewhereclause=yes name=apbilldet_billdet_vcno dbname="apbilldet.billdet_vcno" )
 column=(type=char(1) updatewhereclause=yes name=apbilldet_det_class dbname="apbilldet.det_class" )
 column=(type=decimal(0) updatewhereclause=yes name=apbilldet_amount dbname="apbilldet.amount" )
 column=(type=datetime updatewhereclause=yes name=apbilldet_close_date dbname="apbilldet.close_date" )
 column=(type=char(6) updatewhereclause=yes name=apbilldet_bank_code dbname="apbilldet.bank_code" )
 column=(type=char(20) updatewhereclause=yes name=apbilldet_bill_area dbname="apbilldet.bill_area" )
 column=(type=char(20) updatewhereclause=yes name=apbilldet_draft dbname="apbilldet.draft" )
 column=(type=char(10) updatewhereclause=yes name=c_end dbname="c_end" )
 column=(type=datetime updatewhereclause=yes name=apbilldet_start_date dbname="apbilldet.start_date" )
 column=(type=datetime updatewhereclause=yes name=apbill_set_date dbname="apbill.set_date" )
 column=(type=char(12) updatewhereclause=yes name=apbill_bill_no dbname="apbill.bill_no" )
 column=(type=char(12) updatewhereclause=yes name=apbilldet_billdet_no dbname="apbilldet.billdet_no" )
 column=(type=char(10) updatewhereclause=yes name=c_start dbname="c_start" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"supp~" )  TABLE(NAME=~"apbill~" )  TABLE(NAME=~"apbilldet~" ) COLUMN(NAME=~"apbill.close_date~") COLUMN(NAME=~"apbill.bill_class~") COLUMN(NAME=~"apbill.bill_amount~") COLUMN(NAME=~"supp.supp_name~") COLUMN(NAME=~"apbill.draft~") COLUMN(NAME=~"apbilldet.billdet_vcno~") COLUMN(NAME=~"apbilldet.det_class~") COLUMN(NAME=~"apbilldet.amount~") COLUMN(NAME=~"apbilldet.close_date~") COLUMN(NAME=~"apbilldet.bank_code~") COLUMN(NAME=~"apbilldet.bill_area~") COLUMN(NAME=~"apbilldet.draft~") COMPUTE(NAME=~"'          ' c_end~") COLUMN(NAME=~"apbilldet.start_date~") COLUMN(NAME=~"apbill.set_date~") COLUMN(NAME=~"apbill.bill_no~") COLUMN(NAME=~"apbilldet.billdet_no~") COMPUTE(NAME=~"'          ' c_start~")    JOIN (LEFT=~"apbill.vc_no~"    OP =~"=~"RIGHT=~"apbilldet.vc_no~"    OUTER1 =~"apbill.vc_no~" )    JOIN (LEFT=~"apbill.supp_no~"    OP =~"=~"RIGHT=~"supp.supp_no~" )WHERE(    EXP1 =~"( ( apbill.bill_class~"   OP =~"in~"    EXP2 =~"( :asa_class ) )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( apbill.set_flag~"   OP =~"in~"    EXP2 =~"( :asa_flag ) )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( apbill.close_date~"   OP =~"between~"    EXP2 =~":ad_start and :ad_end ) )~" ) ) ARG(NAME = ~"asa_class~" TYPE = stringlist)  ARG(NAME = ~"asa_flag~" TYPE = stringlist)  ARG(NAME = ~"ad_start~" TYPE = date)  ARG(NAME = ~"ad_end~" TYPE = date) " arguments=(("asa_class", stringlist),("asa_flag", stringlist),("ad_start", date),("ad_end", date)) )
