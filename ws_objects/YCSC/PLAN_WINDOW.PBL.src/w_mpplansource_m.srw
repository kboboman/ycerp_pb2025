			case "레퍼런스2"
				dw6.object.b1_qa8[ll_row]  = long(em_value.text)
			case "절곡(비고)"
				dw6.object.b1_rem[ll_row]  = sle_value1.text
			case "프로그램NO"
				dw6.object.b1_pgmno[ll_row]= sle_value1.text
			case "TYPE"
				dw6.object.b1_type[ll_row] = sle_value1.text
				
			case "도장(폭)"
				dw6.object.p1_qa1[ll_row]  = long(em_value.text)
			case "도장(길이)"
				dw6.object.p1_qa2[ll_row]  = long(em_value.text)
			case "도장(면)"
				dw6.object.p1_face[ll_row] = long(em_value.text)
			case "도장(비고)"
				dw6.object.p1_rem[ll_row]  = sle_value1.text
			case "도장(번호)"
				dw6.object.p1_keyno[ll_row]= sle_value1.text
		end choose
	end if
next

