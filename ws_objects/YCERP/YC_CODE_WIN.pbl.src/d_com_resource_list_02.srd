$PBExportHeader$d_com_resource_list_02.srd
$PBExportComments$전산자원 조회_통계
release 8;
datawindow(units=0 timer_interval=0 color=134217750 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=92 color="536870912" )
summary(height=92 color="536870912" )
footer(height=0 color="536870912" )
detail(height=92 color="536870912" )
table(column=(type=char(12) updatewhereclause=yes name=detl_cd dbname="detl_cd" )
 column=(type=char(100) updatewhereclause=yes name=detl_nm dbname="detl_nm" )
 column=(type=decimal(0) updatewhereclause=yes name=sort_order dbname="sort_order" )
 column=(type=char(4) updatewhereclause=yes name=pre_mm dbname="pre_mm" )
 column=(type=long updatewhereclause=yes name=pre_cnt dbname="pre_cnt" )
 column=(type=char(1) updatewhereclause=yes name=mm dbname="mm" )
 column=(type=long updatewhereclause=yes name=cnt dbname="cnt" )
 column=(type=long updatewhereclause=yes name=new_cnt1 dbname="new_cnt1" )
 column=(type=long updatewhereclause=yes name=discard_cnt1 dbname="discard_cnt1" )
 column=(type=long updatewhereclause=yes name=new_cnt2 dbname="new_cnt2" )
 column=(type=long updatewhereclause=yes name=return_cnt dbname="return_cnt" )
 column=(type=long updatewhereclause=yes name=discard_cnt2 dbname="discard_cnt2" )
 column=(type=long updatewhereclause=yes name=change_cnt dbname="change_cnt" )
 retrieve="select 
	 aa.detl_cd						detl_cd 
	,aa.detl_nm						detl_nm
	,aa.sort_order					sort_order
	,right(convert(varchar(6), dateadd(M, -1, :as_yyyymm + '01'), 112),2) pre_mm
	,isnull(cc.pre_cnt, 0)		pre_cnt
	,right(:as_yyyymm,2) 		mm
	,isnull(bb.cnt, 0)			cnt
	,isnull(dd.new_cnt, 0)		new_cnt1
	,isnull(ee.discard_cnt, 0)	discard_cnt1
	,isnull(dd.new_cnt, 0)		new_cnt2
	,isnull(ff.return_cnt, 0)	return_cnt
	,isnull(ee.discard_cnt, 0)	discard_cnt2
	,isnull(gg.change_cnt, 0)	change_cnt
from 
	(
	select 
	 	 detl_cd 
		,detl_nm
		,sort_order 
	from 
		yc_codemst
	where
		mast_cd = 'A001'
	and 
		detl_cd <> 'ROOT'
	and 
		ext_attr1 = 'Y') aa
	left outer join		
		(
		select
			 a.device_nm
			,count(*) cnt
		from
			yc_com_resource a
		where
			left(a.delivery_date,6) = :as_yyyymm or left(a.return_date,6) = :as_yyyymm
		group by 
			a.device_nm) bb on aa.detl_cd = bb.device_nm
	left outer join 
		(
		select
			 a.device_nm
			,count(*) pre_cnt
		from
			yc_com_resource a
		where
			left(a.delivery_date,6) = (select convert(varchar(6), dateadd(M, -1, :as_yyyymm + '01'), 112)) or left(a.return_date,6) = (select convert(varchar(6), dateadd(M, -1, :as_yyyymm + '01'), 112))
		group by 
			a.device_nm) cc on aa.detl_cd = cc.device_nm
	left outer join 	
		(
		select
			 a.device_nm
			,count(*) new_cnt
		from
			yc_com_resource a
		where
			state_m	= '001'
		and	
			left(a.delivery_date,6) = :as_yyyymm or left(a.return_date,6) = :as_yyyymm
		group by 
			a.device_nm) dd on aa.detl_cd = dd.device_nm
	left outer join 	
		(
		select
			 a.device_nm
			,count(*) discard_cnt
		from
			yc_com_resource a
		where
			state_d	= '004'
		and	
			left(a.delivery_date,6) = :as_yyyymm or left(a.return_date,6) = :as_yyyymm
		group by 
			a.device_nm) ee on aa.detl_cd = ee.device_nm		
	left outer join 	
		(
		select
			 a.device_nm
			,count(*) return_cnt
		from
			yc_com_resource a
		where
			state_m	= '003'
		and	
			left(a.delivery_date,6) = :as_yyyymm or left(a.return_date,6) = :as_yyyymm
		group by 
			a.device_nm) ff on aa.detl_cd = ff.device_nm			
	left outer join 	
		(
		select
			 a.device_nm
			,count(*) change_cnt
		from
			yc_com_resource a
		where
			state_m	= '002'
		and	
			left(a.delivery_date,6) = :as_yyyymm or left(a.return_date,6) = :as_yyyymm
		group by 
			a.device_nm) gg on aa.detl_cd = gg.device_nm
order by
	aa.sort_order			" arguments=(("as_yyyymm", string)) )
