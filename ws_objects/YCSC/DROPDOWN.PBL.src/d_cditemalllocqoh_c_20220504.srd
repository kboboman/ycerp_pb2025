table(column=(type=decimal(4) updatewhereclause=yes name=qoh dbname="qoh" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="item.qa" )
 retrieve="  SELECT qoh = isnull(itemloc.qoh, 0),   
         		  item.qa  
    FROM item LEFT OUTER JOIN itemloc ON item.item_no = itemloc.item_no AND item.qa = itemloc.qa and itemloc.loc_no = :as_loc
   WHERE item.item_no = :as_item
			and item.use_flag = 'Y'" arguments=(("as_loc", string),("as_item", string))  sort="qa A " )
