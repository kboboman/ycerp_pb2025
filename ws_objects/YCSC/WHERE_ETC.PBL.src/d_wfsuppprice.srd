table(column=(type=char(1) updatewhereclause=yes name=seq dbname="seq" )
 column=(type=decimal(4) updatewhereclause=yes name=amount dbname="supplier.amount" )
 retrieve=" SELECT CONVERT(CHAR(1), '1') seq, amount 
   FROM supplier
  WHERE supp_no = :as_supp_no 
    AND item_no = :as_item_no
	 AND qa = :as_com_qa
					
  UNION
	
 SELECT CONVERT(CHAR(1), '2') seq, price_a 
	FROM item
  WHERE item_no = :as_item_no 
    AND qa = :as_com_qa1" arguments=(("as_supp_no", string),("as_item_no", string),("as_com_qa", string),("as_com_qa1", string))  sort="seq A " )
