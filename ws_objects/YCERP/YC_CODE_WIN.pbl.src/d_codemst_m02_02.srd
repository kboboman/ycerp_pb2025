 retrieve="select
	 a.mast_cd		mast_cd      
	,a.mast_nm		mast_nm      
	,a.detl_cd		detl_cd        
	,a.detl_nm		detl_nm       
	,a.ext_attr1	ext_attr1     
	,a.ext_attr2	ext_attr2     
	,a.ext_attr3	ext_attr3     
	,a.ext_attr4	ext_attr4     
	,a.ext_attr5	ext_attr5     
	,a.ext_attr6	ext_attr6     
	,a.ext_attr7	ext_attr7     
	,a.ext_attr8	ext_attr8      
	,a.ext_attr9	ext_attr9     
	,a.ext_attr10	ext_attr10   
	,a.sort_order	sort_order    
	,a.use_yn		use_yn        
	,a.code_desc	code_desc   
	,a.input_date	input_date   
	,a.input_user	input_user    
	,a.update_date	update_date 
	,a.update_user	update_user 
from
	yc_codemst a
where
	a.mast_cd = :as_mast_cd
and 
	a.detl_cd <> 'ROOT'
order by 	
	a.sort_order, a.detl_cd" update="yc_codemst" updatewhere=0 updatekeyinplace=no arguments=(("as_mast_cd", string)) )
