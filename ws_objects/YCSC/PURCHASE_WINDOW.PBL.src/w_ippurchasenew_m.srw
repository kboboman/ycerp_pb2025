event pb_retrieve::clicked;//==GF_USEPROGRAM(프로그램 사용현황)==============================================================
GF_USEPROGRAM( gs_userid, Parent.ClassName(), "R", string(gf_today(),'yyyy/mm/dd'), Parent.Title )
//================================================================================================

string ls_suppno
long   ll_row
date   ld_sdate, ld_edate

pb_delete.enabled = true
pb_save.enabled   = true

ls_suppno = trim(dw_11.object.supp_no[dw_11.getrow()])
if ls_suppno = '' or isnull(ls_suppno) then
	ls_suppno = "%"
end if 

ld_sdate = date(em_s.text)
ld_edate = date(em_e.text)
if not isdate(em_s.text) then
	em_s.setfocus()
	return
end if

if not isdate(em_e.text) then
	em_e.setfocus()
	return
end if

dw_2.setredraw(false)
dw_2.reset()
ll_row = dw_2.retrieve( ls_suppno, '%', '%', ld_sdate, ld_edate, LeftA(dw_area.object.area[1],1) ) 
if ll_row < 1 then
	dw_1.reset()
	dw3.reset()
end if
dw_2.setredraw(true)
tab_1.selecttab(1)

/*
	2006.02.01
	시화와 모듈라의 구분을 위해
*/					
//If gs_userid = 'yonga252' Or gs_userid = 'pjgyo' Then
