$PBExportComments$물품요청선정취소번호조회(2001/03/02,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=72 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=ask_date dbname="ask_head.ask_date" )
 column=(type=char(1) updatewhereclause=yes name=ask_head_proc_flag dbname="ask_head.proc_flag" values="요청	N/완료	Y/부분	P/" )
 column=(type=char(12) updatewhereclause=yes name=ask_no dbname="ask_head.ask_no" )
 retrieve="PBSELECT( VERSION(400) DISTINCT ()TABLE(NAME=~"ask_head~" ) COLUMN(NAME=~"ask_head.ask_date~") COLUMN(NAME=~"ask_head.proc_flag~") COLUMN(NAME=~"ask_head.ask_no~")WHERE(    EXP1 =~"ask_head.ask_date~"   OP =~"between~"    EXP2 =~":ad_start and :ad_end~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"ask_head.f_area~"   OP =~"=~"    EXP2 =~":as_area~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"ask_head.proc_flag~"   OP =~"<>~"    EXP2 =~"'N'~" ) ) ORDER(NAME=~"ask_head.ask_date~" ASC=no) ARG(NAME = ~"ad_start~" TYPE = date)  ARG(NAME = ~"ad_end~" TYPE = date)  ARG(NAME = ~"as_area~" TYPE = string) " arguments=(("ad_start", date),("ad_end", date),("as_area", string)) )
