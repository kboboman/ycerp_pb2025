detail(height=72 color="536870912" )
table(column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=char(4) updatewhereclause=yes name=customer_cust_no dbname="customer.cust_no" )
 column=(type=char(1) updatewhereclause=yes name=open_close dbname="customer.open_close" )
 retrieve="  SELECT DISTINCT customer.cust_name
       , customer.cust_no  
       , customer.open_close
    FROM do,   
         customer  
   WHERE ( do.cust_no = customer.cust_no ) 
     AND ( ( do.ship_flag = 'D' ) AND ( do.ship_amount <> 0 ) )   
   ORDER BY customer.cust_name ASC   
" )
