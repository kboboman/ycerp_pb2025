detail(height=80 color="536870912" )
table(column=(type=char(14) update=yes updatewhereclause=yes key=yes name=order_no dbname="coilorderdet.order_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=coil_no dbname="coilorderdet.coil_no" )
 column=(type=decimal(1) update=yes updatewhereclause=yes name=wid dbname="coilorderdet.wid" )
 column=(type=long updatewhereclause=yes name=coilmst_unit_qty dbname="coilmst.unit_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=rt dbname="rt" )
 column=(type=long update=yes updatewhereclause=yes name=cnt dbname="coilorderdet.cnt" )
 column=(type=char(1) update=yes updatewhereclause=yes name=proc_flag dbname="coilorderdet.proc_flag" initial="O" values="생산계획	O/작업지시	P/입고완료	C/" )
 column=(type=char(40) update=yes updatewhereclause=yes name=rem dbname="coilorderdet.rem" )
 column=(type=char(14) update=yes updatewhereclause=yes name=coilorder_order dbname="coilorderdet.coilorder_order" )
 column=(type=long update=yes updatewhereclause=yes name=order_seq dbname="coilorderdet.order_seq" )
 column=(type=datetime update=yes updatewhereclause=yes name=coilorderdet_order_date dbname="coilorderdet.order_date" )
 column=(type=char(1) update=yes updatewhereclause=yes name=coilorderdet_work_type dbname="coilorderdet.work_type" )
 column=(type=long update=yes updatewhereclause=yes name=coilorderdet_los_qty dbname="coilorderdet.los_qty" )
 column=(type=decimal(1) update=yes updatewhereclause=yes name=coilorderdet_los_width dbname="coilorderdet.los_width" )
 column=(type=long update=yes updatewhereclause=yes name=coilorderdet_div dbname="coilorderdet.div" initial="0" )
 column=(type=long update=yes updatewhereclause=yes name=coilorderdet_tot_qty dbname="coilorderdet.tot_qty" )
 column=(type=char(10) update=yes updatewhereclause=yes name=loc_no dbname="coilorderdet.loc_no" )
 column=(type=char(2) updatewhereclause=yes name=coilmst_etc_no dbname="coilmst.etc_no" )
 retrieve="  SELECT coilorderdet.order_no,   
         coilorderdet.coil_no,   
         coilorderdet.wid,   
         coilmst.unit_qty,   
         rt = convert (decimal (3,2) , substring(qa,1,1) + ~".~" + substring(qa, 2,2)),   
         coilorderdet.cnt,   
         coilorderdet.proc_flag,   
         coilorderdet.rem,   
         coilorderdet.coilorder_order,   
         coilorderdet.order_seq,   
         coilorderdet.order_date,   
         coilorderdet.work_type,   
         coilorderdet.los_qty,   
         coilorderdet.los_width,   
         coilorderdet.div,   
         coilorderdet.tot_qty,   
         coilorderdet.loc_no,   
         coilmst.etc_no  
    FROM coilorderdet,   
         coilmst  
   WHERE ( coilorderdet.coil_no = coilmst.coil_no ) and  
         ( coilorderdet.loc_no = coilmst.loc_no ) and  
         ( ( coilorderdet.order_date between :ad_start and :ad_end ) AND  
         ( coilorderdet.proc_flag = :as_flag ) )    
" update="coilorderdet" updatewhere=0 updatekeyinplace=no arguments=(("ad_start", date),("ad_end", date),("as_flag", string))  sort="order_seq A " )
