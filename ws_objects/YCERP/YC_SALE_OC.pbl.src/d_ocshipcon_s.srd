detail(height=256 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=doship_no dbname="doship.doship_no" )
 column=(type=datetime updatewhereclause=yes name=doship_date dbname="doship.doship_date" )
 column=(type=char(10) updatewhereclause=yes name=approve_team dbname="doship.approve_team" )
 column=(type=char(10) updatewhereclause=yes name=approve_top dbname="doship.approve_top" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="doship.user_id" )
 column=(type=datetime updatewhereclause=yes name=user_date dbname="doship.user_date" )
 column=(type=char(10) updatewhereclause=yes name=area_no dbname="doship.area_no" )
 column=(type=char(60) updatewhereclause=yes name=rem dbname="doship.rem" )
 column=(type=char(1) updatewhereclause=yes name=process_flag dbname="doship.process_flag" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"doship~" ) COLUMN(NAME=~"doship.doship_no~") COLUMN(NAME=~"doship.doship_date~") COLUMN(NAME=~"doship.approve_team~") COLUMN(NAME=~"doship.approve_top~") COLUMN(NAME=~"doship.user_id~") COLUMN(NAME=~"doship.user_date~") COLUMN(NAME=~"doship.area_no~") COLUMN(NAME=~"doship.rem~") COLUMN(NAME=~"doship.process_flag~")WHERE(    EXP1 =~"doship.process_flag~"   OP =~"=~"    EXP2 =~":as_flag~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"doship.doship_no~"   OP =~"like~"    EXP2 =~":as_doship_no~" ) ) ARG(NAME = ~"as_flag~" TYPE = string)  ARG(NAME = ~"as_doship_no~" TYPE = string) " arguments=(("as_flag", string),("as_doship_no", string)) )
