	case 'draw_no'
		this.getchild('draw_no',idwc_draw)
		ll_found = idwc_draw.find("draw_no = '" + data + "'" ,1, idwc_draw.rowcount())
		if ll_found < 1 then
			lst_code.str1 = ls_supp
			lst_code.str2 = data
         openwithparm(w_whdraw_w, lst_code)
			lst_code = message.powerobjectparm
			if lst_code.chk = "N" then return 1

			st_bug.text = '도면조회 ' + string(lst_code.chk)

			ll_found = idwc_draw.insertrow(0)
			this.object.draw_no[row] = lst_code.str2
			ld_m_kg = dec(lst_code.str3)
			idwc_draw.setitem(ll_found,'draw_no',lst_code.str2)
			idwc_draw.setitem(ll_found,'mk',ld_m_kg)
		else
			st_bug.text = '도면조회(getitemdecimal) '
			ld_m_kg = idwc_draw.getitemdecimal(idwc_draw.getrow(),'mk')
		end if
		this.object.price[row] = truncate(this.object.cprice[row] * ld_m_kg, 0 )
		
	case 'order_qty'
		if this.object.com_uom[row] = 'SH' then
			this.object.cnt[row] = this.object.order_qty[row]
		else
			this.object.unit_qty[row] = this.object.order_qty[row] 
		end if
		wf_calc(row)
		
	case 'uom' , 'price', 'com_uom' 
/*		
		if dwo.name = 'price' then
		
				string ls_item_no, ls_supp_no, ls_yyyymm
				decimal l_amount
				
				l_amount = dec(data)				
				ls_item_no = this.object.item_no[row]
				ls_qa = this.object.item_no[row]
				ls_supp_no = dw_1.object.supp_no[1]
				ls_yyyymm  = left(string(dw_1.object.order_date[1]),4)+mid(string(dw_1.object.order_date[1]),6,2)
		
				update supplier_unit_det 
					set amount = :l_amount
				from supplier_unit_det A INNER JOIN (
																		select supp_no, max(ver) ver
																		  from supplier_unit
																		where  yyyymm <= :ls_yyyymm
																			 and use_yn = 'Y'
																		 group by supp_no
																) B  on a.supp_no = b.supp_no and a.ver = b.ver
				where a.supp_no = :ls_supp_no
					and  a.item_no = :ls_item_no
					and  a.qa = :ls_qa
					and  a.amount <> :l_amount;
					
		end if				
*/		
		wf_calc(row)		
		
	case 'com_qty' /*'price', 'com_qty'  2019.02.01 jowosnuk price 안탐 */
		  
		wf_calc2(row)
		
	case 'yrate'
		wf_calc_yrate(row)
		
	case 'unit_qty'
		this.object.order_qty[row] = this.object.unit_qty[row] * this.object.cnt[row]
		this.object.com_qty[row]   = this.object.order_qty[row] 
		
	case 'cnt'
		this.object.order_qty[row] = this.object.unit_qty[row] * this.object.cnt[row]
		this.object.com_qty[row]   = this.object.order_qty[row] 
		
	case 'sale_no'
		ls_item    = trim(this.object.item_no[row])
		ls_qa      = trim(this.object.qa[row])
		ls_sale_no = trim(this.object.sale_no[row])

		setnull(li_seq) ;	setnull(ls_cust_name)
		SELECT saledet.seq_no, cust_name, scene_desc
		  INTO :li_seq, :ls_cust_name, :ls_scene
		  FROM saledet
		       LEFT OUTER JOIN sale     ON saledet.order_no = sale.order_no
			    LEFT OUTER JOIN customer ON sale.cust_no     = customer.cust_no
			    LEFT OUTER JOIN scene    ON sale.scene_code  = scene.scene_code
		 WHERE sale.order_no    = :ls_sale_no
		   AND saledet.item_no  = :ls_item
			AND saledet.qa       = :ls_qa;
		if sqlca.sqlcode = 100 then
			messagebox("확인","입력하신 수주번호가 등록되어있지 않습니다.")
		else
			this.setredraw(false)
			if gs_area = 'B0001' or gs_area = 'C0001' then
				if isnull(ls_scene) then 
					ls_scene = ''
				else
					ls_scene = '/' + trim(ls_scene)
				end if
				this.object.cust_name[row] = trim(ls_cust_name) + ls_scene
			else
				this.object.cust_name[row] = trim(ls_cust_name)
			end if
			
			this.object.sale_seq[row] = li_seq
			this.setredraw(true)
		end if
end choose

end event

event itemerror;string ls_data,ls_item

setnull(ls_data)
choose case dwo.name
	case 'qa'
        this.object.qa[row] = ls_data
	case 'draw_no'
        this.object.draw_no[row] = ls_data
end choose

return 2
end event

event doubleclicked;	
CHOOSE CASE dwo.name
	CASE 'item_no','qa',"item_item_name"
			if wf_dw3chk() = false then return
			if this.object.po_print[row] = 'N' or isnull(this.object.po_print[row]) then
				wf_itemselect(dw3,'S', row, 0)
			end if
			
//20070110 수주장 출력
	CASE 'sale_no'		
//		ws_process st_process
//		string ls_sale
//		
//		st_process.sale_no     = this.object.sale_no[row]
//		OpenWithParm(w_whsaledodet_w, st_process)	
		w_repsuper w_print
		st_print l_print
		string ls_where, ls_sql, ls_dw5sql, ls_sale_orderno
		
		ls_sale_orderno = this.object.sale_no[row]

		If ls_sale_orderno = '' Or isnull(ls_sale_orderno) Then
			return
		End If
		
		string ls_scenehp
		if MessageBox("확인", "수주상황접수부의 연락처 번호를 해당 거래처 현장관리 번호로 출력 합니까?", Exclamation!, YesNo!, 1) = 1 then
			ls_scenehp = "Y"
		else
			ls_scenehp = ""
		end if		
		
		dw_13.dataobject = 'd_orsale_print2'
		dw_13.settransobject(sqlca)
//		ls_dw5sql = dw_13.describe("datawindow.table.select")
//		
//		ls_where = " and sale.order_no = ~~'" + ls_sale_orderno + "~~'"
//		ls_sql = "datawindow.table.select = '" + ls_dw5sql + ls_where + "'"
//			
//		dw_13.modify(ls_sql)
//		dw_13.retrieve( ls_scenehp )

		dw_13.retrieve( ls_scenehp, ls_sale_orderno,  ls_sale_orderno, '%')

		
		l_print.st_datawindow = dw_13
		l_print.st_print_sheet = " 프린트용지 : A5"
		gs_print_control = 'DataWindow.Print.Orientation=1 DataWindow.Print.Paper.Size=9 ' + &
									 'Datawindow.Zoom=100'
		
		// LANDSCAPE:1, PORTRAIT:2
		// SIZE 9-A4, 12-B4, 13-B5 182 x 257 mm
		
		opensheetwithparm(w_print, l_print, parentwindow(), 1, Original!)
END CHOOSE

end event

event losefocus;//
this.AcceptText()

end event

event editchanged;//
choose case dwo.name
	case 'uom'
		this.object.uom[row] = UPPER(DATA)
		wf_calc(row)
		
	case 'com_uom'
		this.object.com_uom[row] = UPPER(DATA)
		wf_calc(row)
end choose

return 0

end event

event clicked;//
if row < 1 then return

this.scrolltorow(row)

end event

