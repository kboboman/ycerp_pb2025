 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"routtempnew~" )  TABLE(NAME=~"groupitem~" ALIAS=~"groupitem_a~" )  TABLE(NAME=~"groupitem~" ALIAS=~"groupitem_b~" )  TABLE(NAME=~"customer~" )  TABLE(NAME=~"scene~" )  TABLE(NAME=~"sale~" ) COLUMN(NAME=~"routtempnew.work_date~") COLUMN(NAME=~"routtempnew.division~") COLUMN(NAME=~"routtempnew.wc_no~") COLUMN(NAME=~"routtempnew.operation~") COLUMN(NAME=~"routtempnew.process_flag~") COLUMN(NAME=~"routtempnew.work_per~") COLUMN(NAME=~"routtempnew.sale_no~") COLUMN(NAME=~"routtempnew.seq_no~") COLUMN(NAME=~"routtempnew.cust_no~") COLUMN(NAME=~"routtempnew.scene_code~") COLUMN(NAME=~"routtempnew.napgi_date~") COLUMN(NAME=~"routtempnew.suju_type~") COLUMN(NAME=~"routtempnew.item_no~") COLUMN(NAME=~"routtempnew.qa~") COLUMN(NAME=~"routtempnew.item_color~") COLUMN(NAME=~"routtempnew.order_qty~") COLUMN(NAME=~"routtempnew.assy_item~") COLUMN(NAME=~"routtempnew.assy_qa~") COLUMN(NAME=~"routtempnew.bom_no~") COLUMN(NAME=~"routtempnew.uom~") COLUMN(NAME=~"routtempnew.plan_qty~") COLUMN(NAME=~"routtempnew.setup_time~") COLUMN(NAME=~"routtempnew.work_time~") COLUMN(NAME=~"routtempnew.make_qty~") COLUMN(NAME=~"routtempnew.plan_flag~") COLUMN(NAME=~"routtempnew.qpa~") COLUMN(NAME=~"groupitem_a.item_name~") COLUMN(NAME=~"groupitem_b.item_name~") COLUMN(NAME=~"customer.cust_name~") COLUMN(NAME=~"scene.scene_desc~") COLUMN(NAME=~"routtempnew.reserved_qty~") COLUMN(NAME=~"routtempnew.rem~") COLUMN(NAME=~"routtempnew.area_no~")    JOIN (LEFT=~"routtempnew.sale_no~"    OP =~"=~"RIGHT=~"sale.order_no~"    OUTER1 =~"routtempnew.sale_no~" )    JOIN (LEFT=~"routtempnew.item_no~"    OP =~"=~"RIGHT=~"groupitem_a.item_no~"    OUTER1 =~"routtempnew.item_no~" )    JOIN (LEFT=~"routtempnew.assy_item~"    OP =~"=~"RIGHT=~"groupitem_b.item_no~"    OUTER1 =~"routtempnew.assy_item~" )    JOIN (LEFT=~"routtempnew.cust_no~"    OP =~"=~"RIGHT=~"customer.cust_no~"    OUTER1 =~"routtempnew.cust_no~" )    JOIN (LEFT=~"routtempnew.scene_code~"    OP =~"=~"RIGHT=~"scene.scene_code~"    OUTER1 =~"routtempnew.scene_code~" )WHERE(    EXP1 =~"( ( sale.open_close~"   OP =~"=~"    EXP2 =~"~~~"O~~~" )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( routtempnew.process_flag~"   OP =~"<>~"    EXP2 =~"~~~"C~~~" )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( routtempnew.plan_flag~"   OP =~"=~"    EXP2 =~"'N')~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( routtempnew.sale_no~"   OP =~"=~"    EXP2 =~":arg_sale ) )~" ) ) ARG(NAME = ~"arg_sale~" TYPE = string) " update="routtempnew" updatewhere=0 updatekeyinplace=yes arguments=(("arg_sale", string))  sort="seq_no A operation A division A " )
