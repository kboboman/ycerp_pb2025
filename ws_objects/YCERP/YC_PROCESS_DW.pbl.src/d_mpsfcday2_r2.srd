$PBExportComments$생산일보조회_보고서자재사용내역(일자)(1998/05/11,이인호)
release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=68 color="536870912" )
table(column=(type=char(31) updatewhereclause=yes name=wc_name dbname="wc_name" )
 column=(type=datetime updatewhereclause=yes name=cdata dbname="cdata" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" initial=" " )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="uom" )
 column=(type=decimal(4) updatewhereclause=yes name=sum_qty dbname="sum_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=sum_ret dbname="sum_ret" )
 column=(type=decimal(4) updatewhereclause=yes name=sum_rem dbname="sum_rem" )
 column=(type=datetime updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=datetime updatewhereclause=yes name=edate dbname="edate" )
 retrieve="  SELECT wc_name,   
         cdata,   
         item_name,   
         qa,   
         uom,
         sum_qty = sum(sum_qty),   
         sum_ret = sum(sum_ret),   
			sum_rem = sum(sum_rem),
         sdate,   
         edate  
from (
  SELECT wc_name  = rtrim(:as_wc + space(30)),   
         sfcuse.use_date cdata,   
         groupitem.item_name,   
         sfcuse.qa,   
         sfcuse.uom,
         sum_qty = sum(use_qty),   
         sum_ret = 0,   
			sum_rem = sum(use_qty),
         sdate = convert(smalldatetime, :ad_start, 111),   
         edate = convert(smalldatetime, :ad_end, 111)  
    FROM sfcuse,  
         groupitem,   
         wc  
   WHERE ( sfcuse.item_no = groupitem.item_no ) and  
         ( sfcuse.wc_no = wc.work_no ) and 
         ( ( wc.work_name like :as_wc + ~"%~"  ) AND  
         ( sfcuse.use_date between :ad_start and :ad_end ) )   
GROUP BY sfcuse.use_date,   
         groupitem.item_name,   
         sfcuse.qa,   
         sfcuse.uom
union
  SELECT wc_name  = rtrim(:as_wc + space(30)),   
         sfcret.ret_date cdata,   
         groupitem.item_name,   
         sfcret.qa,   
         sfcret.uom,
         sum_qty = 0,   
         sum_ret = sum(sfcret.ret_qty),   
			sum_rem = 0 - sum(sfcret.ret_qty),
         sdate = convert(smalldatetime, :ad_start, 111),   
         edate = convert(smalldatetime, :ad_end, 111)  
    FROM sfcret,  
         groupitem,   
         wc  
   WHERE ( sfcret.item_no = groupitem.item_no ) and  
         ( sfcret.wc_no = wc.work_no ) and 
         ( ( wc.work_name like :as_wc + ~"%~"  ) AND  
         ( sfcret.ret_date between :ad_start and :ad_end ) )  
GROUP BY sfcret.ret_date,   
         groupitem.item_name,   
         sfcret.qa,   
         sfcret.uom) sumsfc
GROUP BY wc_name,   
         cdata,   
         item_name,   
         qa,   
         uom,
         sdate,   
         edate  

" arguments=(("as_wc", string),("ad_start", date),("ad_end", date))  sort="groupitem_item_name A qa A " )
