/*  물품요청 헤드
  SELECT ask_head.ask_no     
       , ask_head.ask_date   
       , ask_head.proc_flag  /* Y(완료), N(요청중), P(부문) */
       , ask_head.ask_user
       , login.user_name
    FROM ask_head  
         LEFT OUTER JOIN login  ON ask_head.ask_user = login.user_id
   WHERE ( convert(char(10),ask_head.ask_date,111)  between :as_sdate and :as_edate ) 
     AND ( ask_head.t_area         = :as_area )   
   ORDER BY ask_head.ask_date desc,   
            ask_head.ask_no   asc   
*/
end event

