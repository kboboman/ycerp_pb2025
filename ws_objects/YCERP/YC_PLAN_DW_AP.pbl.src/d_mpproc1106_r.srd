table(column=(type=long updatewhereclause=yes name=routtempnew_operation dbname="operation" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="seq_no" )
 column=(type=char(20) updatewhereclause=yes name=routtempnew_assy_qa dbname="assy_qa" )
 column=(type=char(1) updatewhereclause=yes name=type1 dbname="type1" )
 column=(type=decimal(4) updatewhereclause=yes name=plan_qty dbname="plan_qty" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" initial=" " )
 column=(type=char(17) updatewhereclause=yes name=mpsdet_plan_no dbname="plan_no" )
 column=(type=char(17) updatewhereclause=yes name=mpsdet_order_no dbname="order_no" initial=" " )
 column=(type=char(10) updatewhereclause=yes name=routtempnew_assy_item dbname="assy_item" )
 retrieve="  SELECT operation = r.operation   
       , seq_no    = r.seq_no   
       , assy_qa   = r.assy_qa   
       , type1     = dbo.uf_getmpsproc(m.plan_no, m.order_no)
       , plan_qty  = r.plan_qty   
       , item_name = g.item_name   
       , plan_no   = m.plan_no   
       , order_no  = m.order_no   
       , assy_item = r.assy_item  
    FROM routtempnew R (nolock)  
         LEFT OUTER JOIN mpsdet    M (nolock) ON r.assy_item = m.item_no 
                       AND r.assy_qa   = m.qa  AND r.sale_no = m.sale_no AND r.seq_no = m.seq_no AND r.division = m.division
         LEFT OUTER JOIN groupitem G (nolock) ON r.assy_item = g.item_no
         LEFT OUTER JOIN mpsorder MO (nolock) ON M.mpsorder_order = mo.order_no
   WHERE ( r.sale_no    = :arg_str )    
   ORDER BY r.seq_no ASC
          , r.operation ASC   
" arguments=(("arg_str", string)) )
