table(column=(type=char(4) updatewhereclause=yes name=cat dbname="cat" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=datetime updatewhereclause=yes name=do_date dbname="do_date" )
 column=(type=char(10) updatewhereclause=yes name=salesman dbname="salesman" )
 column=(type=char(14) updatewhereclause=yes name=do_no dbname="do_no" )
 column=(type=char(80) updatewhereclause=yes name=shipto_addr dbname="shipto_addr" )
 column=(type=char(13) updatewhereclause=yes name=dr_hp dbname="dr_hp" )
 column=(type=char(12) updatewhereclause=yes name=driver dbname="driver" )
 column=(type=long updatewhereclause=yes name=oi_no dbname="oi_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=decimal(2) updatewhereclause=yes name=ship_qty dbname="ship_qty" )
 column=(type=char(50) updatewhereclause=yes name=rem dbname="rem" )
 column=(type=char(14) updatewhereclause=yes name=order_no dbname="order_no" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(11) updatewhereclause=yes name=scene_code dbname="scene_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=char(20) updatewhereclause=yes name=area_no dbname="area_no" )
 retrieve=" SELECT DISTINCT cat = '송장'
      , user_name  = aroiinv_esero.saler_user
      , do_date    = do.do_date
      , salesman   = customer.salesman
      , do_no      = do.do_no
      , shipto_addr= do.shipto_addr
      , dr_hp      = do.dr_hp
      , driver     = do.driver
      , oi_no      = dodet.oi_no
      , item_no    = dodet.item_no
      , item_name  = groupitem.item_name
      , ship_qty   = dodet.ship_qty
      , rem        = dodet.rem
      , order_no   = dodet.sale_no
      , cust_no    = do.cust_no 
      , cust_name  = customer.cust_name 
      , scene_code = do.spot_code
      , scene_desc = scene.scene_desc
      , area_no    = area.area_name
   FROM do        ( nolock )
        LEFT OUTER JOIN dodet     ( nolock ) ON do.do_no      = dodet.do_no
        LEFT OUTER JOIN customer  ( nolock ) ON do.cust_no    = customer.cust_no
        LEFT OUTER JOIN scene     ( nolock ) ON do.spot_code  = scene.scene_code
        LEFT OUTER JOIN groupitem ( nolock ) ON dodet.item_no = groupitem.item_no
        LEFT OUTER JOIN area      ( nolock ) ON do.area_no    = area.area_no
        LEFT OUTER JOIN aroiinv_esero ( nolock ) ON customer.salesman = aroiinv_esero.id
  WHERE ( do.do_date  = :as_sdate )
" arguments=(("as_sdate", string))  sort="cat A cust_name A scene_desc A do_no A oi_no A " )
