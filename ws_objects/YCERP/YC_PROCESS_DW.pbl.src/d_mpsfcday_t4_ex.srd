$PBExportComments$생산일보조회_보고서(리스트)(1998/05/08,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=72 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=72 color="553648127" )
table(column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 column=(type=char(10) updatewhereclause=yes name=color_color_name dbname="color.color_name" )
 column=(type=char(10) updatewhereclause=yes name=wc_work_name dbname="wc.work_name" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=datetime updatewhereclause=yes name=sfcday_sfc_date dbname="sfcday.sfc_date" )
 column=(type=char(14) updatewhereclause=yes name=sfcday_sale_no dbname="sfcday.sale_no" )
 column=(type=decimal(4) updatewhereclause=yes name=sfcday_make_qty dbname="sfcday.make_qty" )
 column=(type=datetime updatewhereclause=yes name=sale_order_date dbname="sale.order_date" )
 column=(type=decimal(4) updatewhereclause=yes name=sfcday_plan_qty dbname="sfcday.plan_qty" )
 column=(type=char(50) updatewhereclause=yes name=saledet_rem dbname="saledet.rem" )
 column=(type=long updatewhereclause=yes name=sfcday_seq_no dbname="sfcday.seq_no" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_order_qty dbname="saledet.order_qty" )
 column=(type=char(10) updatewhereclause=yes name=sfcday_assembly dbname="sfcday.assembly" )
 column=(type=char(20) updatewhereclause=yes name=sfcday_assembly_qa dbname="sfcday.assembly_qa" )
 column=(type=char(2) updatewhereclause=yes name=sfcday_uom dbname="sfcday.uom" )
 column=(type=datetime updatewhereclause=yes name=start_date dbname="start_date" )
 column=(type=datetime updatewhereclause=yes name=end_date dbname="end_date" )
 retrieve="  SELECT customer.cust_name,   
         scene.scene_desc,   
         color.color_name,   
         wc.work_name,   
         groupitem.item_name,   
         sfcday.sfc_date,   
         sfcday.sale_no,   
         sfcday.make_qty,   
         sale.order_date,   
         sfcday.plan_qty,   
         saledet.rem,   
         sfcday.seq_no,   
         saledet.order_qty,   
         sfcday.assembly,   
         sfcday.assembly_qa,   
         sfcday.uom,   
         start_date = convert(smalldatetime, :as_start, 111),   
         end_date =  convert(smalldatetime, :as_end, 111)  
    FROM sfcday with(nolock) left outer join color with(nolock) on sfcday.color = color.color_code      
                            left outer join customer with(nolock) on sfcday.cust_no = customer.cust_no
                            left outer join  scene  with(nolock) on sfcday.scene_code = scene.scene_code
                            left outer join groupitem with(nolock) on sfcday.assembly = groupitem.item_no              
                            left outer join  sale with(nolock) on sfcday.sale_no = sale.order_no
                            left outer join  saledet  with(nolock) on sfcday.sale_no = saledet.order_no and  sfcday.seq_no = saledet.seq_no
                            inner join wc with(nolock) on sfcday.wc_no       = wc.work_no       
where ( ( wc.work_name like ltrim(:as_wc + '%') ) AND  
             ( sfcday.sfc_date between :as_start and :as_end + ' 23:59:59:999' ) and
		   ( sfcday.area_no = :as_area ) )   
/*
    FROM sfcday,   
         customer,   
         scene,   
         color,   
         wc,   
         groupitem,   
         sale,   
         saledet  
   WHERE ( sfcday.color *= color.color_code) and  
         ( sfcday.cust_no *= customer.cust_no) and  
         ( sfcday.scene_code *= scene.scene_code) and  
         ( sfcday.sale_no *= sale.order_no) and  
         ( sfcday.assembly *= groupitem.item_no) and  
         ( sfcday.sale_no *= saledet.order_no) and  
         ( sfcday.seq_no *= saledet.seq_no) and  
         ( sfcday.wc_no = wc.work_no ) and  
         ( ( wc.work_name like ltrim(:as_wc + ~"%~") ) AND  
         ( sfcday.sfc_date between :as_start and :as_end + ~" 23:59:59:999~" ) and
			( sfcday.area_no = :as_area ) )       
*/" arguments=(("as_wc", string),("as_start", date),("as_end", date),("as_area", string))  sort="sfcday_sfc_date A wc_work_name A groupitem_item_name A sfcday_assembly_qa A " )
group(level=1 header.height=0 trailer.height=0 by=("sfcday_sfc_date" ) header.color="536870912" trailer.color="536870912" )
