event open;call super::open;//==GF_USEPROGRAM(프로그램 사용현황)===========================================================
GF_USEPROGRAM( gs_userid, THIS.ClassName(), "O", string(gf_today(),'yyyy/mm/dd'), THIS.Title )
//=============================================================================================

string ls_clause, ls_where, ls_left, ls_top, ls_prt1, ls_prt2

dw3  = tab_1.tabpage_1.dw_3
dw4  = tab_1.tabpage_2.dw_4
dw5  = tab_1.tabpage_2.dw_5
dw6  = tab_1.tabpage_2.dw_6
dw7  = tab_1.tabpage_3.dw_7
dw9  = tab_1.tabpage_2.dw_9

ddlb_fld.reset()
ddlb_dwtitles.reset()
ddlb_dwtitles.visible = false

GF_DWTitle2ddlb( dw3, ddlb_fld, ddlb_dwtitles )

tab_1.tabpage_2.cb_paste.enabled  = false
tab_1.tabpage_2.cb_export.enabled = false
tab_1.tabpage_2.pb_ins.enabled    = false

//////////////////////////////////////////////////////////////////////////////
ls_left  = ProfileString("YCERP.INI","Database","LEFT", " ")
ls_top   = ProfileString("YCERP.INI","Database","TOP",  " ")

if isnull(ls_left) OR ls_left = "" then ls_left = "0"
if isnull(ls_top)  OR ls_top  = "" then ls_top  = "0"

tab_1.tabpage_2.em_left.text = ls_left
tab_1.tabpage_2.em_top.text  = ls_top 
//////////////////////////////////////////////////////////////////////////////
ls_prt1  = ProfileString("YCERP.INI","Database","BARCODE1", " ")
ls_prt2  = ProfileString("YCERP.INI","Database","BARCODE2", " ")

if isnull(ls_prt1) OR ls_prt1 = "" then ls_prt1 = PrintGetPrinter()
if isnull(ls_prt2) OR ls_prt2 = "" then ls_prt2 = PrintGetPrinter()

tab_1.tabpage_2.sle_prt1.text = ls_prt1
tab_1.tabpage_2.sle_prt2.text = ls_prt2 
//////////////////////////////////////////////////////////////////////////////

pb_cancel.visible = false
dw_1.visible  = false
dw_8.visible  = false
dw9.visible   = false
dw_10.visible = false

// 사업장
dw_area.SetTransObject(SQLCA)
dw_area.insertrow(0)  
dw_area.object.area[1] = "S0001" //gs_area
//dw_area.accepttext()

// 작업장
dw_2.insertrow(0)
dw_2.getchild('wc_no', idwc_wc)
idwc_wc.insertrow(1)
idwc_wc.setitem(1,"work_no"," ")
idwc_wc.setitem(1,"work_name","전체")
idwc_wc.accepttext()
dw_2.object.wc_no[1] = "B01"

dw3.object.pri.width = 0	// 순위
dw3.SetTransObject(SQLCA)
dw4.SetTransObject(SQLCA)
dw5.SetTransObject(SQLCA)
dw6.SetTransObject(SQLCA)
dw7.SetTransObject(SQLCA)
dw9.SetTransObject(SQLCA)
dw_10.SetTransObject(SQLCA)

dw5.getchild("scene_code", idwc_scene)
idwc_scene.settransobject(sqlca)
idwc_scene.insertrow(0)  
is_scenesql = idwc_scene.describe("datawindow.table.select")

em_1.text = string(today(),'yyyy/mm/dd')
em_2.text = string(today(),'yyyy/mm/dd')

tab_1.tabpage_3.visible = false
tab_1.SelectedTab = 2

pb_save.enabled = false
if GF_Permission("소요자재_신청자", gs_userid) = "Y" then
	pb_save.enabled = true
end if

end event

event resize;call super::resize;//
gb_3.width   = newwidth  - (gb_3.x * 2)

tab_1.width  = newwidth  - 63
tab_1.height = newheight - 460

tab_1.tabpage_1.dw_3.width  = tab_1.width  - 59
tab_1.tabpage_1.dw_3.height = tab_1.height - 232

//tab_1.tabpage_2.dw_4.width  = tab_1.width  - tab_1.tabpage_2.dw_4.width - 59
//tab_1.tabpage_2.dw_5.width  = 3246

tab_1.tabpage_2.dw_6.width  = tab_1.width  - 59
tab_1.tabpage_2.dw_6.height = tab_1.height - 800

tab_1.tabpage_3.dw_7.width  = tab_1.width  - 59
tab_1.tabpage_3.dw_7.height = tab_1.height - 232

end event

type pb_save from w_inheritance`pb_save within w_mpplansos_m
integer x = 3685
integer y = 64
end type

event pb_save::clicked;call super::clicked;// 저장
long    ll_row, ll_y, ll_chk
integer li_seq
string  ls_sosno, ls_seq, ls_area, ls_sosdate, ls_maxno, ls_saleno, ls_saleseq, ls_key1, ls_key2
string  ls_sdate, ls_edate, ls_subject

if dw6.rowcount() < 1 then return

ls_sdate = em_1.text
ls_edate = em_2.text

ls_subject = dw5.object.subject[1]
if isnull(ls_subject) OR ls_subject = "" then
	MessageBox("확인", "제목을 입력하시기 바랍니다.")	
	RETURN
end if

// 수주번호, 순번 공난 삭제하기
for ll_row = dw6.rowcount() to 1 step -1
	ls_saleno  = dw6.object.sale_no[ll_row]
	ls_saleseq = string(dw6.object.seq_no[ll_row])		// 수주순번
   if ls_saleno = "" OR ls_saleseq = "" then
		dw6.deleterow( ll_row )	// 수주번호, 순번 공난 삭제하기
	end if
next

// 수주번호, 순번 공난 삭제하기
for ll_row = 1 to dw6.rowcount()
	ll_chk  = 0
	ls_saleno  = dw6.object.sale_no[ll_row]
	ls_saleseq = string(dw6.object.seq_no[ll_row])
	ls_key1    = ls_saleno + ls_saleseq
	
	for ll_y = 1 to dw6.rowcount()
		if ll_row = ll_y then	// 같은행 중복검사 제외
		else
			ls_key2  = dw6.object.sale_no[ll_y] + string(dw6.object.seq_no[ll_y])
			if ls_key1 = ls_key2 then	// 수주번호 + 순번 중복 시 오류
				dw6.scrolltorow( ll_y )
				ll_chk = ll_y
				exit
			end if
		end if
	next
	
	if ll_chk = ll_y then exit
next
if ll_chk = ll_y then
	MessageBox("확인", string(ll_chk) + "행 수주번호+순번 중복 체크 오류입니다.")	
	RETURN
end if

if MessageBox("확인","저장 하시겠습니까?", Exclamation!, OKCancel!, 1) = 2 THEN
	RETURN
end if

//==GF_USEPROGRAM(프로그램 사용현황)==============================================================
GF_USEPROGRAM( gs_userid, Parent.ClassName(), "S", string(gf_today(),'yyyy/mm/dd'), Parent.Title )
//================================================================================================

////////////////////////////////////////
// 소재신청 저장
////////////////////////////////////////
// 신청번호 부여(IS20120106-001)
////////////////////////////////////////
ls_sosno = dw5.getitemstring(1, "sos_no")
if isnull(ls_sosno) OR ls_sosno = "" then
	ls_area    = "I" + LeftA(dw_area.object.area[1],1)
	ls_sosdate = string(gf_today(), "yyyymmdd")
	ls_sosdate = GF_ReplaceAll(ls_edate, "/", "")
	ls_maxno   = ls_area + ls_sosdate + "-" + "%"
		
	SELECT max(sos_no) INTO :ls_sosno FROM itemsos WHERE sos_no LIKE :ls_maxno;
	if isnull(ls_sosno) or ls_sosno = "" then
		ls_sosno = ls_area + ls_sosdate + "-" + "001"
	else
		li_seq   = integer(MidA(ls_sosno, 12, 3))
		li_seq   = li_seq + 1
		ls_seq   = "00" + string(li_seq)
		ls_sosno = LeftA(ls_sosno, 11) + RightA(ls_seq, 3)
	end if

	dw5.object.sos_no[1]   = ls_sosno
	dw5.object.sos_date[1] = date(ls_edate)
	dw5.object.user_id[1]  = gs_userid
end if
			
// 행번호만들기
for ll_row = 1 to dw6.rowcount() 
	dw6.object.sos_no[ll_row] = ls_sosno
	dw6.object.seq[ll_row]    = ll_row
next

// 저장
if wf_update2(dw5, dw6,"Y") = false then
	MessageBox('오류dw6','소재신청 저장중 오류가 발생했습니다.',exclamation!)
	RETURN
end if

dw4.retrieve( ls_sdate, ls_edate )		// 신청리스트

end event

