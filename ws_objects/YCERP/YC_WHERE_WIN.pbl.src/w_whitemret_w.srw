if row > 0 and row < this.rowcount() then
	this.scrolltorow(row)

	ls_item = this.object.item_no[row]
	ls_qa   = this.object.qa[row]
	for ll_row = 1 to dw7.rowcount()
		if ls_item = dw7.object.item_no[ll_row] and ls_qa = dw7.object.qa[ll_row] then
			dw7.scrolltorow(ll_row)
		end if
	next
end if

