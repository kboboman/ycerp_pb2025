$PBExportHeader$d_itemstock_planout_r.srd
$PBExportComments$수주조회(2002/01/14)
release 8;
datawindow(units=0 timer_interval=0 color=67108864 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=108 color="536870912" )
summary(height=120 color="536870912" )
footer(height=0 color="12639424" )
detail(height=92 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=sale_order_no dbname="issuereq.order_no" )
 column=(type=long updatewhereclause=yes name=issuereq_seq_no dbname="issuereq.seq_no" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene_desc" )
 column=(type=char(10) updatewhereclause=yes name=c_item_no dbname="issuereq.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=decimal(0) updatewhereclause=yes name=plan_out_qty dbname="PLAN_OUT_qty" )
 retrieve="		 SELECT   c.order_no
				     ,  seq_no       
				     , cust_name = customer.cust_name
				     , scene_desc= scene.scene_desc         
				     , c.item_no
				     , qa   = c.qa
			      	, PLAN_OUT_qty      = sum(ISNULL(c.issue_qty,0))
			  FROM issuereq   A WITH (NOLOCK)
			  LEFT OUTER JOIN issuereqdet   B WITH (NOLOCK) ON a.req_date  = b.req_date AND a.salesman = b.salesman AND a.req_seq = b.req_seq
			  LEFT OUTER JOIN issuereqdet_sale c with(nolock) on b.req_date = c.req_date and b.salesman = c.salesman and b.req_seq = c.req_seq and  b.seq = c.seq
			  inner join customer with(nolock) on b.cust_no = customer.cust_no
			  left outer join scene with(nolock) on b.scene_code = scene.scene_code
			  LEFT OUTER JOIN location L WITH (NOLOCK) ON a.accept_user = l.loc_manager
	WHERE ( a.req_date BETWEEN convert(datetime,  :as_date +' 00:00:00' ) and convert(datetime,  :as_date + ' 23:59:59' )  )
		 AND ( b.req_flag    =       'A'  ) /* 출고의뢰 */
		 AND ( a.confirm_flag=    'Y'  ) /* 확정     */				
		 AND ( c.item_no   = :as_item )
		 AND ( c.qa   = :as_qa     		 )		
		 AND isnull( l.loc_no, (  case when a.accept_area = 'B0001'    then 'WS00000006'
																								  when a.accept_area = 'H0001'    then 'WS00000007'
																								  when a.accept_area = 'S0001'    then 'WS00000000'
																								  when a.accept_area = 'T0001'    then 'WS00000008'
																								  when a.accept_area = 'Z0001'    then 'WS00000011'
																								  else 'WS99999999'
																						  end
																						)
									)	like :as_locno			
	  group by c.order_no
				, seq_no       
				, customer.cust_name
				, scene.scene_desc         
				, c.item_no
				, c.qa
" arguments=(("as_locno", string),("as_date", string),("as_item", string),("as_qa", string))  sort="sale_order_no A customer_cust_name A scene_scene_desc A " )
