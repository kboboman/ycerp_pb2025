table(column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=char(14) updatewhereclause=yes name=order_no dbname="order_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="seq_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=decimal(2) updatewhereclause=yes name=order_qty dbname="order_qty" )
 column=(type=long updatewhereclause=yes name=op1 dbname="op1" )
 column=(type=char(10) updatewhereclause=yes name=wc1 dbname="wc1" )
 column=(type=char(10) updatewhereclause=yes name=wc1_nm dbname="wc1_nm" )
 column=(type=char(1) updatewhereclause=yes name=wc1_date dbname="wc1_date" )
 column=(type=long updatewhereclause=yes name=op2 dbname="op2" )
 column=(type=char(10) updatewhereclause=yes name=wc2 dbname="wc2" )
 column=(type=char(10) updatewhereclause=yes name=wc2_nm dbname="wc2_nm" )
 column=(type=char(1) updatewhereclause=yes name=wc2_date dbname="wc2_date" )
 column=(type=long updatewhereclause=yes name=op3 dbname="op3" )
 column=(type=char(10) updatewhereclause=yes name=wc3 dbname="wc3" )
 column=(type=char(10) updatewhereclause=yes name=wc3_nm dbname="wc3_nm" )
 column=(type=char(1) updatewhereclause=yes name=wc3_date dbname="wc3_date" )
 retrieve="  SELECT cust_name  = c.cust_name
       , scene_desc = s.scene_desc
       , order_no   = a.order_no
       , seq_no     = a.seq_no
       , item_no    = a.item_no
       , item_name  = g.item_name
       , qa         = saledet.qa
       , order_qty  = saledet.order_qty
       , op1        = a.op1
       , wc1        = a.wc1
       , wc1_nm     = wc1.work_name
       , wc1_date   = ''
       , op2        = a.op2
       , wc2        = a.wc2
       , wc2_nm     = wc2.work_name
       , wc2_date   = ''
       , op3        = a.op3
       , wc3        = a.wc3
       , wc3_nm     = wc3.work_name
       , wc3_date   = ''
    FROM (
         SELECT cust_no    = a.cust_no
              , scene_code = a.scene_code
              , order_no   = a.order_no
              , seq_no     = a.seq_no
              , item_no    = a.item_no
              , qa         = a.qa
              , op1        = max(a.op1)
              , wc1        = max(a.wc1)
              , op2        = max(a.op2)
              , wc2        = max(a.wc2)
              , op3        = max(a.op3)
              , wc3        = max(a.wc3)
           FROM (
                SELECT cust_no    = a.cust_no
                     , scene_code = a.scene_code
                     , order_no   = a.order_no
                     , seq_no     = a.seq_no
                     , item_no    = a.item_no
                     , qa         = a.qa
                     , op1        = (case when a.operation = 1 then a.operation end)
                     , wc1        = (case when a.operation = 1 then a.wc_no     end)
                     , op2        = (case when a.operation = 2 then a.operation end)
                     , wc2        = (case when a.operation = 2 then a.wc_no     end)
                     , op3        = (case when a.operation = 3 then a.operation end)
                     , wc3        = (case when a.operation = 3 then a.wc_no     end)
                  FROM (
                       SELECT cust_no    = saledet.cust_no
                            , scene_code = saledet.scene_code
                            , order_no   = saledet.order_no
                            , seq_no     = saledet.seq_no
                            , item_no    = saledet.item_no
                            , qa         = saledet.qa
                            , operation  = rout.operation
                            , wc_no      = rout.wc_no
                         FROM (SELECT cust_no, scene_code, order_no = saledet.order_no, seq_no, item_no, qa = left(saledet.qa,13) + 'X00000'
                                 FROM saledet 
                                      LEFT OUTER JOIN sale ON saledet.order_no = sale.order_no
                                WHERE ( saledet.order_no = :as_orderno )
                              ) saledet
                              LEFT OUTER JOIN rout ON saledet.item_no = rout.item_no AND saledet.qa = rout.qa
                       ) A
                ) A
          GROUP BY a.cust_no, a.scene_code, a.order_no, a.seq_no, a.item_no, a.qa
         ) A
         LEFT OUTER JOIN saledet     ON a.order_no = saledet.order_no AND a.seq_no = saledet.seq_no
         LEFT OUTER JOIN wc      wc1 ON a.wc1 = wc1.work_no
         LEFT OUTER JOIN wc      wc2 ON a.wc2 = wc2.work_no
         LEFT OUTER JOIN wc      wc3 ON a.wc3 = wc3.work_no
         LEFT OUTER JOIN groupitem G ON a.item_no    = g.item_no
         LEFT OUTER JOIN sale        ON a.order_no   = sale.order_no
         LEFT OUTER JOIN customer  C ON a.cust_no    = c.cust_no
         LEFT OUTER JOIN scene     S ON a.scene_code = s.scene_code
" arguments=(("as_orderno", string)) )
