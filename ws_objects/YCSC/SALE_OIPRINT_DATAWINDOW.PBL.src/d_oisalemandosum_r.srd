table(column=(type=char(10) updatewhereclause=yes name=user_name dbname="USER_NAME" )
 column=(type=char(4) updatewhereclause=yes name=do_cust_no dbname="CUST_NO" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="CUST_NAME" )
 column=(type=char(11) updatewhereclause=yes name=do_spot_code dbname="SPOT_CODE" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="SCENE_DESC" )
 column=(type=decimal(1) updatewhereclause=yes name=ship_amount dbname="SHIP_AMOUNT" )
 column=(type=decimal(4) updatewhereclause=yes name=do_rate dbname="DO_RATE" )
 column=(type=decimal(4) updatewhereclause=yes name=do_cash dbname="DO_CASH" )
 column=(type=decimal(4) updatewhereclause=yes name=do_total dbname="DO_TOTAL" )
 retrieve="  SELECT USER_NAME   = A.USER_NAME          
       , CUST_NO     = A.CUST_NO            
       , CUST_NAME   = A.CUST_NAME
       , SPOT_CODE   = A.SPOT_CODE     
       , SCENE_DESC  = A.SCENE_DESC  
       , SHIP_AMOUNT = SUM(A.SHIP_AMOUNT)
       , DO_RATE     = SUM(A.DO_RATE )
       , DO_CASH     = SUM(A.DO_CASH )
       , DO_TOTAL    = SUM(A.DO_TOTAL)
    FROM (
         SELECT USER_NAME   = E.USER_NAME          
              , CUST_NO     = A.CUST_NO            
              , CUST_NAME   = D.CUST_NAME
              , SPOT_CODE   = A.SPOT_CODE     
              , SCENE_DESC  = F.SCENE_DESC  
              , DO_NO       = A.DO_NO
              , DO_DATE     = CONVERT(CHAR(10), A.DO_DATE, 111)
              , SHIP_AMOUNT = (CASE WHEN A.DO_RATE <> 0 THEN A.SHIP_AMOUNT * 1.1 ELSE A.SHIP_AMOUNT END)
              , DO_RATE     = A.DO_RATE            
              , DO_CASH     = A.DO_CASH            
              , DO_TOTAL    = A.DO_TOTAL                                
           FROM DO        A  
                LEFT OUTER JOIN CUSTOMER D  ON A.CUST_NO  = D.CUST_NO
                LEFT OUTER JOIN SCENE    F  ON A.CUST_NO  = F.CUST_NO  AND A.SPOT_CODE = F.SCENE_CODE
                LEFT OUTER JOIN LOGIN    E  ON D.SALESMAN = E.USER_ID
          WHERE (( CONVERT(CHAR(10), A.DO_DATE, 111)     BETWEEN :as_start AND :as_end ) AND  
                 ( A.SALE_FLAG        IN ( :as_saleflag )               ) AND  
                 ((D.SALESMAN       LIKE :as_salesman ) OR 
                  (:as_team = 'T' AND D.SALESMAN  IN ( SELECT E.USER_ID  FROM LOGIN, TEAM 
                                                   WHERE E.TEAM_CODE   = TEAM.TEAM_CODE  AND TEAM_MANAGER = :as_salesman) )
                 ) AND
                 ( A.AREA_NO        LIKE :as_area ) 
                )
         ) A
   GROUP BY A.USER_NAME          
          , A.CUST_NO            
          , A.CUST_NAME
          , A.SPOT_CODE     
          , A.SCENE_DESC  
   ORDER BY A.USER_NAME, A.CUST_NAME, A.SPOT_CODE DESC
   " arguments=(("as_saleflag", stringlist),("as_start", string),("as_end", string),("as_salesman", string),("as_area", string),("as_team", string)) )
group(level=1 header.height=0 trailer.height=80 by=("user_name" ) header.color="553648127" trailer.color="15780518" )
