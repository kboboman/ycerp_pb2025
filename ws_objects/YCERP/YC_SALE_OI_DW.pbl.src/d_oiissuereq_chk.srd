table(column=(type=datetime updatewhereclause=yes name=req_date dbname="req_date" )
 column=(type=char(10) updatewhereclause=yes name=salesman dbname="salesman" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=long updatewhereclause=yes name=req_seq dbname="req_seq" )
 column=(type=char(10) updatewhereclause=yes name=accept_user dbname="accept_user" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name dbname="user_name" )
 column=(type=char(13) updatewhereclause=yes name=req_flag dbname="req_flag" )
 column=(type=char(8) updatewhereclause=yes name=confirm_flag dbname="confirm_flag" )
 column=(type=char(10) updatewhereclause=yes name=accept_area dbname="accept_area" )
 column=(type=datetime updatewhereclause=yes name=sys_date dbname="sys_date" )
 column=(type=char(60) updatewhereclause=yes name=req_rem dbname="req_rem" )
 column=(type=char(10) updatewhereclause=yes name=issue_schedule dbname="issue_schedule" )
 column=(type=long updatewhereclause=yes name=seq dbname="seq" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(11) updatewhereclause=yes name=scene_code dbname="scene_code" )
 column=(type=char(50) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=char(20) updatewhereclause=yes name=add_scene dbname="add_scene" )
 column=(type=char(14) updatewhereclause=yes name=sale_no dbname="sale_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="seq_no" )
 column=(type=datetime updatewhereclause=yes name=do_date dbname="do_date" )
 column=(type=char(14) updatewhereclause=yes name=do_no dbname="do_no" )
 column=(type=long updatewhereclause=yes name=oi_no dbname="oi_no" )
 column=(type=char(10) updatewhereclause=yes name=area_no dbname="area_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(3) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=char(6) updatewhereclause=yes name=issue_flag dbname="issue_flag" )
 column=(type=char(30) updatewhereclause=yes name=ship_flag dbname="ship_flag" )
 column=(type=char(8) updatewhereclause=yes name=ship_case dbname="ship_case" )
 column=(type=char(60) updatewhereclause=yes name=issuereqdet_tel dbname="tel" )
 column=(type=char(60) updatewhereclause=yes name=reqdet_rem dbname="reqdet_rem" )
 column=(type=datetime updatewhereclause=yes name=reqdet_sysdate dbname="reqdet_sysdate" )
 retrieve="  SELECT req_date  = issuereq.req_date                                                                                                                        
       , salesman  = issuereq.salesman                                                                                                                        
       , user_name = login_a.user_name                                                                                                                        
       , req_seq   = issuereq.req_seq                                                                                                                         
       , accept_user = issuereq.accept_user                                                                                                                     
       , user_name = login_b.user_name                                                                                                                        
       , req_flag        = (case when issuereqdet.req_flag = 'A' then '출고의뢰'
                                 when issuereqdet.req_flag = 'B' then '생산확인'
                                 when issuereqdet.req_flag = 'P' then '출고/생산확인'
                                 else ''
                            end)
       , confirm_flag    = (case issuereq.confirm_flag                                        
                                 when 'Y' then '확정완료'                                   
                                 when 'N' then '미확정'                                 
                                 else          ''                                       
                            end)                                                        
       , accept_area = issuereq.accept_area                                                                                                                     
       , sys_date    = issuereq.sys_date                                                                                                           
       , req_rem     = issuereq.rem                                                                                                                             

       , issue_schedule  = (case issuereqdet.issue_schedule                                      
                                 when 'A' then '직출'                                   
                                 when 'B' then '생산후직출'                             
                                 when 'C' then '자동작성'                               
                                 when 'D' then '방문'                                   
                                 when 'E' then '외주(시화)'                             
                                 when 'F' then '외주(본사)'                             
                                 when 'G' then '유창강건'                               
                                 when 'H' then '지점이송'                               
                                 when 'I' then '야간도착'                               
                                 when 'J' then '저녁상차'                               
                                 when 'K' then '택배/정기'                              
                                 else           ''                                      
                            end)                                                        
                                                                                                                                                  
       , seq        = issuereqdet.seq                /* Key1 */                                                                                                
       , cust_no    = issuereqdet.cust_no            /* Key1 */                                                                                                
       , cust_name  = dbo.uf_getcustname(issuereqdet.sale_no)                                                                                     
       , scene_code = issuereqdet.scene_code         /* Key1 */                                                                                                
       , scene_desc = dbo.uf_getscenename(issuereqdet.sale_no)                                                                                    
       , add_scene  = issuereqdet.add_scene          /* Key1 */                                                                                                
       , sale_no    = issuereqdet.sale_no                                                                                                                      
       , seq_no     = a.seq_no
       , do_date    = isnull(issuereqdet.do_date, a.prt_date) /* 출력송장 미발행인 경우도 있음 */
       , do_no      = a.do_no
       , oi_no      = a.oi_no
       , area_no    = a.area_no
       , item_name  = issuereqdet.item_name                                                                                                                    
       , uom        = issuereqdet.uom                                                                                                                          
       , issue_flag      = (case issuereqdet.issue_flag                                          
                                 when 'A' then '전량'                                   
                                 when 'P' then '부분'                                   
                                 when 'R' then '잔여분'                                 
                                 else          ''                                       
                            end)                                                        
       , ship_flag       = dbo.uf_getshipflag(issuereqdet.ship_flag)                                                                                   
       , ship_case       = (case issuereqdet.ship_case                                           
                                 when 'J' then '정기화물'                               
                                 when 'T' then '택배'                                   
                                 when 'A' then '오토바이'                               
                                 when 'S' then '선박'                                   
                                 when 'P' then '항공'                                   
                                 when 'E' then '기타'                                   
                                 else          ''                                       
                            end)                                                        
       , tel        = issuereqdet.tel                                                                                                                          
       , reqdet_rem = issuereqdet.rem                                                                                                                          
       , reqdet_sysdate = issuereqdet.sys_date                                                                                                                     
    FROM issuereq                                                                                                                                 
         LEFT OUTER JOIN issuereqdet                                                                                                              
           ON issuereq.req_date = issuereqdet.req_date AND issuereq.salesman = issuereqdet.salesman AND issuereq.req_seq = issuereqdet.req_seq    
         LEFT OUTER JOIN login login_a ON issuereq.salesman    = login_a.user_id                                                                  
         LEFT OUTER JOIN login login_b ON issuereq.accept_user = login_b.user_id                                                                  
         LEFT OUTER JOIN (                                                                                                                        
              SELECT do.do_no, dodet.oi_no, dodet.sale_no, dodet.seq_no, prt_date, do.area_no                                                                                        
                FROM do                                                                                                                           
                     LEFT OUTER JOIN dodet ON do.do_no = dodet.do_no                                                                              
               WHERE DO_DATE between :as_sdate + ' 00:00:00.000' AND :as_edate + ' 23:59:59.999' 
         ) A ON issuereqdet.sale_no = a.sale_no                                                                                                   
   WHERE ( issuereq.req_date between :as_sdate + ' 00:00:00.000' AND :as_edate + ' 23:59:59.999' )                                                                                                       
" arguments=(("as_sdate", string),("as_edate", string))  sort="req_date D salesman A req_seq A " )
