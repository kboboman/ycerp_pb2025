 column=(type=char(11) updatewhereclause=yes name=user4 dbname="user4" )
 column=(type=char(11) updatewhereclause=yes name=user5 dbname="user5" )
 column=(type=char(10) updatewhereclause=yes name=userh dbname="userh" )
