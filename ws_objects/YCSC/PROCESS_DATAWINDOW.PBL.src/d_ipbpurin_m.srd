$PBExportComments$조업자재 구매일보((1999/06/7,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=84 color="536870912" )
summary(height=0 color="553648127" )
footer(height=68 color="12639424" )
detail(height=80 color="536870912" )
table(column=(type=datetime update=yes updatewhereclause=yes key=yes name=in_date dbname="binitem.in_date" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=area_no dbname="binitem.area_no" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=seq dbname="binitem.seq" initial="1" )
 column=(type=char(3) update=yes updatewhereclause=yes name=supp_no dbname="binitem.supp_no" )
 column=(type=long update=yes updatewhereclause=yes name=item_no dbname="binitem.item_no" )
 column=(type=char(30) update=yes updatewhereclause=yes name=qa dbname="binitem.qa" )
 column=(type=char(4) update=yes updatewhereclause=yes name=uom dbname="binitem.uom" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=qty dbname="binitem.qty" initial="0" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=cost dbname="binitem.cost" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=amount dbname="binitem.amount" initial="0" )
 column=(type=char(1) update=yes updatewhereclause=yes name=part_code dbname="binitem.part_code" )
 column=(type=datetime update=yes updatewhereclause=yes name=sys_date dbname="binitem.sys_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=user_id dbname="binitem.user_id" )
 column=(type=char(30) updatewhereclause=yes name=bsupp_supp_name dbname="bsupp.supp_name" )
 column=(type=char(30) updatewhereclause=yes name=bitem_item_name dbname="bitem.item_name" )
 column=(type=char(60) update=yes updatewhereclause=yes name=rem dbname="binitem.rem" )
 column=(type=char(11) updatewhereclause=yes name=item_class dbname="item_class" )
 retrieve="  SELECT binitem.in_date,   
         binitem.area_no,   
         binitem.seq,   
         binitem.supp_no,   
         binitem.item_no,   
         binitem.qa,   
         binitem.uom,   
         binitem.qty,   
         binitem.cost,   
         binitem.amount,   
         binitem.part_code,   
         binitem.sys_date,   
         binitem.user_id,   
         bsupp.supp_name,   
         bitem.item_name,   
         binitem.rem,
		   item_class = '조 업 자 재'
    FROM binitem LEFT OUTER JOIN bitem ON binitem.item_no = bitem.item_no LEFT OUTER JOIN bsupp ON binitem.supp_no = bsupp.supp_no  
   WHERE ( binitem.in_date between :arg_sdate and :arg_edate ) AND  
         ( binitem.area_no = :arg_area )    
" update="binitem" updatewhere=0 updatekeyinplace=no arguments=(("arg_sdate", date),("arg_edate", date),("arg_area", string))  sort="in_date A seq A " )
