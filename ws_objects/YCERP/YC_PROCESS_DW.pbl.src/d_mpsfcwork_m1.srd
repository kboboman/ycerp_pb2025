table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="sfcday.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=qa dbname="sfcday.qa" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=assembly dbname="sfcday.assembly" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=assembly_qa dbname="sfcday.assembly_qa" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=make_qty dbname="sfcday.make_qty" initial="0" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="sfcday.uom" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=per_qty dbname="sfcday.per_qty" initial="0" )
 column=(type=char(10) update=yes updatewhereclause=yes name=wc_no dbname="sfcday.wc_no" )
 column=(type=char(30) update=yes updatewhereclause=yes name=wc_desc dbname="sfcday.wc_desc" )
 column=(type=char(4) update=yes updatewhereclause=yes name=scrap_code dbname="sfcday.scrap_code" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=scrap_qty dbname="sfcday.scrap_qty" )
 column=(type=char(30) update=yes updatewhereclause=yes name=scrap_desc dbname="sfcday.scrap_desc" )
 column=(type=char(17) update=yes updatewhereclause=yes key=yes name=order_no dbname="sfcday.order_no" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=work_time dbname="sfcday.work_time" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=plan_qty dbname="sfcday.plan_qty" )
 column=(type=char(1) update=yes updatewhereclause=yes name=type dbname="sfcday.type" initial="C" values="진행	P/완료	C/취소	N/" )
 column=(type=char(10) update=yes updatewhereclause=yes name=loc_no dbname="sfcday.loc_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=hebe dbname="sfcday.hebe" )
 column=(type=char(14) update=yes updatewhereclause=yes name=sale_no dbname="sfcday.sale_no" )
 column=(type=long update=yes updatewhereclause=yes name=seq_no dbname="sfcday.seq_no" )
 column=(type=char(50) update=yes updatewhereclause=yes name=cust_name dbname="sfcday.cust_name" )
 column=(type=datetime update=yes updatewhereclause=yes key=yes name=sfc_date dbname="sfcday.sfc_date" )
 column=(type=char(4) update=yes updatewhereclause=yes name=color dbname="sfcday.color" )
 column=(type=char(4) update=yes updatewhereclause=yes name=cust_no dbname="sfcday.cust_no" )
 column=(type=char(11) update=yes updatewhereclause=yes name=scene_code dbname="sfcday.scene_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 column=(type=char(20) update=yes updatewhereclause=yes name=lot_no dbname="sfcday.lot_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=lot_loc dbname="sfcday.lot_loc" )
 column=(type=char(10) update=yes updatewhereclause=yes name=area_no dbname="sfcday.area_no" )
 column=(type=long update=yes updatewhereclause=yes name=sfcday_operation dbname="sfcday.operation" )
 column=(type=char(10) update=yes updatewhereclause=yes name=user_id dbname="sfcday.user_id" )
 column=(type=char(17) updatewhereclause=yes name=sfcuse_order_no dbname="sfcuse.order_no" )
 column=(type=char(16) update=yes updatewhereclause=yes name=mpsorder_order dbname="sfcday.mpsorder_order" )
 column=(type=long update=yes updatewhereclause=yes name=order_seq dbname="sfcday.order_seq" )
 column=(type=datetime updatewhereclause=yes name=use_date dbname="sfcuse.use_date" )
 column=(type=char(1) updatewhereclause=yes name=saledet_rem dbname="saledet_rem" )
 column=(type=char(50) update=yes updatewhereclause=yes name=color_draw dbname="sfcday.color_draw" )
 column=(type=char(12) updatewhereclause=yes name=pack_no dbname="pack_no" )
 column=(type=long updatewhereclause=yes name=sfcuse_count dbname="sfcuse_count" values="사용	1/미사용	0/" )
 column=(type=char(21) updatewhereclause=yes name=sfcday_key dbname="sfcday_key" )
 retrieve="SELECT sfcday.item_no 
     , sfcday.qa 
     , sfcday.assembly 
     , sfcday.assembly_qa 
     , sfcday.make_qty 
     , sfcday.uom 
     , sfcday.per_qty 
     , sfcday.wc_no 
     , sfcday.wc_desc 
     , sfcday.scrap_code 
     , sfcday.scrap_qty 
     , sfcday.scrap_desc 
     , sfcday.order_no 
     , sfcday.work_time 
     , sfcday.plan_qty 
     , sfcday.type 
     , sfcday.loc_no 
     , groupitem.item_name 
     , sfcday.hebe 
     , sfcday.sale_no 
     , sfcday.seq_no 
     , sfcday.cust_name 
     , sfcday.sfc_date 
     , sfcday.color 
     , sfcday.cust_no 
     , sfcday.scene_code 
     , scene.scene_desc 
     , sfcday.lot_no 
     , sfcday.lot_loc 
     , sfcday.area_no 
     , sfcday.operation 
     , sfcday.user_id
     , sfcuse.order_no
     , sfcday.mpsorder_order
     , sfcday.order_seq 
     , sfcuse.use_date
     , saledet_rem   = ''
     , sfcday.color_draw 
     , pack_no        = isnull((SELECT top 1 packdet.pack_no 
                                  FROM packdet, pack
                                 WHERE packdet.mpsorder_order = sfcday.mpsorder_order AND packdet.order_seq =  sfcday.order_seq 
                                   AND packdet.pack_no = pack.pack_no 
                                 ORDER BY pack.sys_date DESC),'')
	, ( SELECT COUNT(*) FROM sfcuse where sfcuse.order_no = sfcday.order_no and sfcuse.use_date = sfcday.sfc_date) sfcuse_count
	,  sfcday.mpsorder_order+( case when len(sfcday.order_seq) = 1 then '00'+rtrim(ltrim(convert(char(3),sfcday.order_seq)))
											  when len(sfcday.order_seq) = 2 then '0'+ rtrim(ltrim(convert(char(3),sfcday.order_seq)))
												else rtrim(ltrim(convert(char(3),sfcday.order_seq))) end) sfcday_key
  FROM sfcday left outer join sfcuse on sfcday.order_no = sfcuse.order_no
										     and  sfcday.sfc_date  = sfcuse.use_date
					left outer join groupitem on sfcday.assembly = groupitem.item_no  
					left outer join scene on sfcday.scene_code = scene.scene_code     
 WHERE sfcday.sfc_date  between :arg_start and :arg_start + ' 23:59:59:999' 
   and sfcday.wc_no           = :arg_wc 
   and sfcday.area_no         = :as_area   
/*
  FROM sfcday
     , groupitem
     , scene
     , sfcuse
 WHERE sfcday.sfc_date  between :arg_start and :arg_start + ' 23:59:59:999' 
   and sfcday.wc_no           = :arg_wc 
   and sfcday.area_no         = :as_area   
   and sfcday.order_no       *= sfcuse.order_no
   and  sfcday.sfc_date       *= sfcuse.use_date
   and sfcday.assembly       *= groupitem.item_no 
   and sfcday.scene_code     *= scene.scene_code     
*/" update="sfcday" updatewhere=0 updatekeyinplace=no arguments=(("arg_start", date),("arg_wc", string),("as_area", string)) )
