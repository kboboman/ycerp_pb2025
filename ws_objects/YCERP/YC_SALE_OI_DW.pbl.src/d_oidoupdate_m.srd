compute(band=footer alignment="1" expression="sum(if ( do_curr_code = 'WON', if (rlse_acc_qty < 0,  truncate(price  *  rlse_acc_qty,0),  truncate(price  *  rlse_acc_qty + 0.00001,0)) , truncate(price * rlse_acc_qty + 0.00001, 2))  for all) + sum(  if(  rlse_amount <> 0, if( sale_tax_sign  = 'Y',    if( do_curr_code = 'WON', truncate( rlse_amount * 0.1, 0), truncate( rlse_amount * 0.1 + 0.0001 , 2)) , 0), 0) for all)"border="0" color="0" x="2377" y="8" height="68" width="512" format="#,##0" html.valueishtml="0"  name=compute_1 visible="1"  font.face="굴림체" font.height="-11" font.weight="700"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
