table(column=(type=char(10) update=yes updatewhereclause=yes name=order_no dbname="purdet.order_no" initial=" " )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="purdet.item_no" initial=" " )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="purdet.qa" )
 column=(type=datetime update=yes updatewhereclause=yes name=due_date dbname="purdet.due_date" initial=" " )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="purdet.uom" initial=" " )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=price dbname="purdet.price" initial=" " )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=order_qty dbname="purdet.order_qty" initial=" " )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=rlse_qty dbname="purdet.rlse_qty" initial=" " )
 column=(type=char(30) updatewhereclause=yes name=supp_name dbname="supp.supp_name" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="groupitem.item_name" )
 column=(type=long updatewhereclause=yes name=purdet_cnt dbname="purdet.cnt" )
 column=(type=datetime updatewhereclause=yes name=s dbname="s" )
 column=(type=datetime updatewhereclause=yes name=e dbname="e" )
 retrieve="  SELECT purdet.order_no       
       , purdet.item_no        
       , purdet.qa             
       , purdet.due_date       
       , purdet.uom            
       , purdet.price          
       , purdet.order_qty      
       , purdet.rlse_qty       
       , supp.supp_name        
       , groupitem.item_name   
       , purdet.cnt         
       , s = convert(smalldatetime, :ad_sdate, 111)
       , e = convert(smalldatetime, :ad_edate, 111)    
    FROM purdet   
       , pur      
       , supp      
       , groupitem  
   WHERE ( purdet.order_no       = pur.order_no      )   
     AND ( pur.supp_no           = supp.supp_no      )   
     AND ( purdet.item_no        = groupitem.item_no )   
     AND ( pur.order_date  BETWEEN :ad_sdate AND :ad_edate ) 
     AND ( ( :as_item  <> '%'  and purdet.item_no      = :as_item ) OR
           ( :as_item   = '%'  and purdet.item_no   LIKE '%'      )
         )
     AND ( ( :as_area   = 'S'  and pur.order_no     LIKE 'PUR%'   ) or  
           ( :as_area   = '%'  and pur.area_no      LIKE '%'      ) or
           ( pur.order_no     LIKE :as_area + '%'                 )
         )
   ORDER BY supp.supp_name ASC,   
            purdet.qa ASC   
" arguments=(("as_item", string),("ad_sdate", date),("ad_edate", date),("as_area", string))  sort="item_name A qa A order_no A due_date A " )
