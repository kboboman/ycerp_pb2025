 column=(type=decimal(4) update=yes updatewhereclause=yes name=com_qty dbname="purdet.com_qty" initial="0" )
 column=(type=char(14) update=yes updatewhereclause=yes name=purdet_sale_no dbname="purdet.sale_no" )
 column=(type=long update=yes updatewhereclause=yes name=purdet_sale_seq dbname="purdet.sale_seq" )
 column=(type=char(50) update=yes updatewhereclause=yes name=purdet_cust_name dbname="purdet.cust_name" )
 column=(type=char(50) update=yes updatewhereclause=yes name=purdet_sale_rem dbname="purdet.sale_rem" )
 column=(type=char(4) update=yes updatewhereclause=yes name=purdet_color dbname="purdet.color" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"purdet~" )  TABLE(NAME=~"groupitem~" ) COLUMN(NAME=~"purdet.order_no~") COLUMN(NAME=~"purdet.seq_no~") COLUMN(NAME=~"purdet.item_no~") COLUMN(NAME=~"purdet.qa~") COLUMN(NAME=~"purdet.due_date~") COLUMN(NAME=~"purdet.order_qty~") COLUMN(NAME=~"purdet.rlse_date~") COLUMN(NAME=~"purdet.price~") COLUMN(NAME=~"purdet.uom~") COLUMN(NAME=~"purdet.rlse_qty~") COLUMN(NAME=~"purdet.rem~") COLUMN(NAME=~"purdet.rcpt_loc~") COLUMN(NAME=~"purdet.pur_type~") COLUMN(NAME=~"purdet.product_no~") COLUMN(NAME=~"purdet.coil_no~") COLUMN(NAME=~"purdet.serial_no~") COLUMN(NAME=~"purdet.work_type~") COLUMN(NAME=~"groupitem.item_name~") COLUMN(NAME=~"purdet.cnt~") COLUMN(NAME=~"purdet.result_type~") COLUMN(NAME=~"purdet.com_qty~") COLUMN(NAME=~"purdet.sale_no~") COLUMN(NAME=~"purdet.sale_seq~") COLUMN(NAME=~"purdet.cust_name~") COLUMN(NAME=~"purdet.sale_rem~") COLUMN(NAME=~"purdet.color~")    JOIN (LEFT=~"purdet.item_no~"    OP =~"=~"RIGHT=~"groupitem.item_no~" )WHERE(    EXP1 =~"purdet.order_no~"   OP =~"=~"    EXP2 =~":as_order~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"purdet.coil_no~"   OP =~"=~"    EXP2 =~":as_coil~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"purdet.serial_no~"   OP =~"=~"    EXP2 =~":as_seq~" ) ) ORDER(NAME=~"purdet.seq_no~" ASC=yes ) ARG(NAME = ~"as_order~" TYPE = string)  ARG(NAME = ~"as_coil~" TYPE = string)  ARG(NAME = ~"as_seq~" TYPE = number) " update="purdet" updatewhere=1 updatekeyinplace=no arguments=(("as_order", string),("as_coil", string),("as_seq", number)) )
