event dw_2::itemchanged;//
datawindowchild ldwc_plan
dwItemStatus    l_status
string ls_area, ls_sdate, ls_wc, ls_loc, ls_rout, ls_defloc, ls_sfcday_key
long   ll_rowcount, i, l_count

this.accepttext()
dw_area.accepttext()

ls_wc    = dw_2.object.wc_no[1]
ls_area  = dw_area.object.area[1]
ls_sdate = string(id_date,"yyyy/mm/dd")

choose case dwo.name
	case "work_date"			// 작업일
		dw4.reset() ; dw7.reset() ; dw5.reset() ; dw8.reset()
		dw9.reset() ; dw10.reset(); dw11.reset()
		
		dw8.retrieve()						
		dw9.retrieve( ls_area, ls_sdate, ls_wc )						  
		dw10.retrieve( ls_sdate, ls_area, ls_wc )
		dw11.retrieve( ls_area, ls_sdate, ls_wc )

	case "wc_no"				// 작업장
		SELECT isnull(rout_auto, "N"), def_loc INTO :ls_rout, :ls_defloc 
		  FROM wc  
		 WHERE work_no = rtrim(:data);
		if ls_rout = "Y" then
			st_5.text = "이전공정자동수불작업장"
		else
			st_5.text = ""
		end if

//		if ls_area = "S0001" then
			SELECT def_loc INTO :ls_loc FROM wc   WHERE work_no = rtrim(:data);
			this.object.loc_no[row] = ls_loc
//		else
//			if ls_area = "S0001" then
//				this.object.loc_no[row] = ls_defloc
//			else
//				SELECT def_loc INTO :ls_loc FROM area WHERE area_no = :gs_area;
//				this.object.loc_no[row] = ls_loc
//			end if
//		end if

		dw3.reset() ; dw4.reset() ; dw5.reset() ; dw6.reset()
		dw7.reset() ; dw8.reset() ; dw9.reset()
		dw10.reset(); dw11.reset()

		dw8.retrieve()				
		dw9.retrieve( ls_area, ls_sdate, ls_wc )				
		dw10.retrieve( ls_sdate, ls_area, ls_wc )
		dw11.retrieve( ls_area, ls_sdate, ls_wc )
		
		if dw4.rowcount() > 0 and data = 'Y07' THEN /*YSP프레스*/
		
			cb_17.visible =true
			cb_23.visible =true
		
			ls_sfcday_key    = trim(dw4.object.sfcday_key[1])
				
			l_count = 0;
			
			SELECT count(*)
				 into :l_count
			from etcout		 
			where qty <> 0
			 and rem like :ls_sfcday_key+'%';		
			 
			 
			 
			 if l_count = 0 then
				cb_17.enabled = true
				cb_23.enabled = false						
			else
				cb_17.enabled = false
				cb_23.enabled = true									
			end if
		
		else			
			cb_17.visible =false
			cb_23.visible =false				
		end if

	case "loc_no"			// 입고저장소
		int li_index
		
		li_index = tab_1.SelectedTab
		choose case li_index
			case 2
//			  ls_loc = trim(data)
//			  ll_rowcount = dw4.rowcount()
//			  for i = 1 to ll_rowcount
//	           l_status = dw4.GetItemStatus(i, 0, Primary!) 
//				  if l_status = newmodified! then
//					  dw4.object.loc_no[i] = ls_loc
//				  end if
//			  next

			case 3
			  ls_loc      = trim(data)
			  ll_rowcount = dw5.rowcount()
			  for i = 1 to ll_rowcount
	           l_status = dw5.GetItemStatus(i, 0, Primary!) 
				  if l_status = newmodified! and &
				  		(isnull(dw5.object.loc_no[i]) or dw5.object.loc_no[i] = "" ) then
					  	dw5.object.loc_no[i] = ls_loc
				  end if
			  next
		end choose
end choose
this.accepttext()

is_wc   = trim(this.object.wc_no[1])
id_date = date(this.object.work_date[1])

end event

event dw_2::losefocus;this.accepttext()
end event

event dw_2::rbuttondown;//
if row < 1 then return

CHOOSE CASE dwo.name
	CASE 'work_date'
		openWithParm(w_calendar, message.stringparm)
		if message.stringparm <> 'N' then
			this.object.work_date[row] = datetime(date(message.stringparm))
		end if
END CHOOSE

this.accepttext()
id_date = date(this.object.work_date[row])

end event

type tab_1 from tab within w_mpwork_m1
integer x = 32
integer y = 432
integer width = 4581
integer height = 2016
integer taborder = 50
boolean bringtotop = true
integer textsize = -10
integer weight = 400
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
long backcolor = 79741120
boolean raggedright = true
boolean boldselectedtext = true
alignment alignment = center!
integer selectedtab = 1
tabpage_1 tabpage_1
tabpage_2 tabpage_2
tabpage_3 tabpage_3
tabpage_4 tabpage_4
tabpage_5 tabpage_5
tabpage_6 tabpage_6
end type

on tab_1.create
this.tabpage_1=create tabpage_1
this.tabpage_2=create tabpage_2
this.tabpage_3=create tabpage_3
this.tabpage_4=create tabpage_4
this.tabpage_5=create tabpage_5
this.tabpage_6=create tabpage_6
this.Control[]={this.tabpage_1,&
this.tabpage_2,&
this.tabpage_3,&
this.tabpage_4,&
this.tabpage_5,&
this.tabpage_6}
end on

on tab_1.destroy
destroy(this.tabpage_1)
destroy(this.tabpage_2)
destroy(this.tabpage_3)
destroy(this.tabpage_4)
destroy(this.tabpage_5)
destroy(this.tabpage_6)
end on

event selectionchanged;//
int    li_index
string ls_area, ls_sfcdate, ls_wcno, ls_sfcday_key
long   l_count

st_3.text = "입고"

ls_area   = dw_area.object.area[1]
li_index  = tab_1.SelectedTab
choose case li_index
	case 2
		ls_wcno  = dw_2.object.wc_no[1]
		
		if ls_wcno = 'Y07' then
			
			cb_17.visible =true
			cb_23.visible =true
		
			ls_sfcday_key    = trim(dw4.object.sfcday_key[1])
				
			l_count = 0;
			
			SELECT count(*)
				 into :l_count
			from etcout		 
			where qty <> 0
			 and rem like :ls_sfcday_key+'%';		
			 
			 if l_count = 0 then
				cb_17.enabled = true
				cb_23.enabled = false						
			else
				cb_17.enabled = false
				cb_23.enabled = true									
			end if			
			
		else
			cb_17.visible = false
			cb_23.visible = false
		end if
		
	case 3
		st_3.text = "출고"
		tab_1.tabpage_3.dw_5.setcolumn("item_item_name")
		tab_1.tabpage_3.dw_5.setfocus()

	case 5
		if is_wc = "" or isnull(is_wc) then
			MessageBox("확인","작업장을 선택하시기 바랍니다.")
		end if
		
	case 6
		if is_wc = "" or isnull(is_wc) then
			MessageBox("확인","작업장을 선택하시기 바랍니다.")
		end if
		
		tab_1.tabpage_6.dw_10.reset()
		tab_1.tabpage_6.dw_11.reset()

		tab_1.tabpage_6.dw_10.retrieve( string(id_date,"yyyy/mm/dd"), ls_area, dw_2.object.wc_no[1] )
		tab_1.tabpage_6.dw_11.retrieve( ls_area, string(id_date,"yyyy/mm/dd"), dw_2.object.wc_no[1] )
		tab_1.tabpage_6.pb_alltime.triggerevent( Clicked! )		
end choose

end event

