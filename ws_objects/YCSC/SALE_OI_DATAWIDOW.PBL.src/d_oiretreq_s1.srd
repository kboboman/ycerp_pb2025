footer(height=72 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=order_no dbname="ret.ret_no" )
 column=(type=datetime updatewhereclause=yes name=preret_date dbname="ret.preret_date" )
 column=(type=char(14) updatewhereclause=yes name=sale_no dbname="ret.sale_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene.scene_desc" )
 column=(type=long updatewhereclause=yes name=ret_qty dbname="ret_qty" )
 column=(type=long updatewhereclause=yes name=acc_qty dbname="acc_qty" )
 retrieve="  SELECT ret.ret_no
       , ret.preret_date
       , ret.sale_no
       , customer.cust_name
       , scene.scene_desc 
       , ret_qty  = 0
       , acc_qty  = 0
    FROM ret
         left outer join sale     on ret.sale_no  = sale.order_no
         left outer join customer on sale.cust_no = customer.cust_no
         left outer join scene    on sale.cust_no = scene.cust_no  and sale.scene_code = scene.scene_code 
   WHERE ( ret.cust_no          like :as_cust_no ) 
     AND ( ret.preret_date   between :ad_sorder_date and :ad_eorder_date )
     AND ( ret.process_flag     like :as_con     )    
/*
  UNION
  
  SELECT a.ret_no
       , ret.preret_date
       , a.sale_no
       , customer.cust_name
       , scene.scene_desc 
       , a.ret_qty
       , a.acc_qty
    FROM (
         SELECT ret_no, sale_no, ret_qty = sum(ret_qty), acc_qty = sum(acc_qty)
           FROM retdet
          WHERE ret_no   IN (
                             SELECT ret.ret_no
                               FROM ret
                              WHERE ( ret.cust_no        LIKE :as_cust_no )
                                AND ( ret.preret_date BETWEEN :ad_sorder_date AND :ad_eorder_date ) 
                            )
          GROUP BY ret_no, sale_no
         ) A
           LEFT OUTER JOIN RET      ON A.RET_NO     = RET.RET_NO
           LEFT OUTER JOIN CUSTOMER ON RET.CUST_NO  = CUSTOMER.CUST_NO
           LEFT OUTER JOIN SCENE    ON RET.CUST_NO  = SCENE.CUST_NO  AND RET.SPOT_CODE = SCENE.SCENE_CODE 
   WHERE a.ret_qty   > a.acc_qty
     AND ret.process_flag   = 'S'
*/" arguments=(("as_cust_no", string),("ad_sorder_date", date),("ad_eorder_date", date),("as_con", string))  sort="order_no A " )
