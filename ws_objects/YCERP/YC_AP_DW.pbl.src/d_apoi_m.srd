 column=(type=char(1) update=yes updatewhereclause=yes name=delete_flag dbname="apoiinv.delete_flag" initial="N" )
 column=(type=datetime update=yes updatewhereclause=yes name=sys_date dbname="apoiinv.sys_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=login_id dbname="apoiinv.login_id" )
 column=(type=char(40) update=yes updatewhereclause=yes name=rem dbname="apoiinv.rem" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=dc dbname="apoiinv.dc" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=rem_amt dbname="apoiinv.rem_amt" initial="0" )
 column=(type=char(10) update=yes updatewhereclause=yes name=inv_area dbname="apoiinv.inv_area" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=dc_rate dbname="apoiinv.dc_rate" initial="0" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=discount dbname="apoiinv.discount" initial="0" )
 column=(type=char(1) updatewhereclause=yes name=c_vat_flag dbname="c_vat_flag" )
 column=(type=char(1) updatewhereclause=yes name=c_apoi_flag dbname="c_apoi_flag" initial="1" values="청구	1/영수	2/" )
 column=(type=char(1) updatewhereclause=yes name=c_apoi_chk dbname="c_apoi_chk" initial="N" values="	Y/	N" )
 retrieve="  SELECT apoiinv.apoiinv_no   
       , apoiinv.supp_no      
       , apoiinv.pur_flag     
       , apoiinv.register_no  
       , apoiinv.inv_type     
       , apoiinv.oi_date      
       , apoiinv.curr_code    
       , apoiinv.gl_cur_rate  
       , apoiinv.apoiinv_cash 
       , apoiinv.apoiinv_rate 
       , apoiinv.ship_cost    
       , apoiinv.printed      
       , apoiinv.open_close   
       , apoiinv.close_date   
       , apoiinv.delete_flag  
       , apoiinv.sys_date     
       , apoiinv.login_id     
       , apoiinv.rem          
       , apoiinv.dc           
       , apoiinv.rem_amt      
       , apoiinv.inv_area     
       , apoiinv.dc_rate      
       , apoiinv.discount     
       , c_vat_flag   = ' '   
       , c_apoi_flag  = ' '   
       , c_apoi_chk   = ' '   
    FROM apoiinv              
" update="apoiinv" updatewhere=1 updatekeyinplace=no )
