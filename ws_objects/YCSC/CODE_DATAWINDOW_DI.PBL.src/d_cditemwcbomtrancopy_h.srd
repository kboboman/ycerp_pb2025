 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"bomtran~" )  TABLE(NAME=~"item~" ) COLUMN(NAME=~"bomtran.item_no~") COLUMN(NAME=~"bomtran.qa~") COLUMN(NAME=~"bomtran.assembly~") COLUMN(NAME=~"bomtran.assy_qa~") COLUMN(NAME=~"bomtran.parent_no~") COLUMN(NAME=~"bomtran.component~") COLUMN(NAME=~"bomtran.comp_qa~") COLUMN(NAME=~"bomtran.sequence~") COLUMN(NAME=~"bomtran.qpa~") COLUMN(NAME=~"bomtran.effectivity~") COLUMN(NAME=~"bomtran.obsolete~") COLUMN(NAME=~"bomtran.yield~") COLUMN(NAME=~"bomtran.bom_no~") COLUMN(NAME=~"bomtran.dirty_flag~") COLUMN(NAME=~"item.item_name~")    JOIN (LEFT=~"bomtran.item_no~"    OP =~"=~"RIGHT=~"item.item_no~" )    JOIN (LEFT=~"bomtran.qa~"    OP =~"=~"RIGHT=~"item.qa1~" )) " update="bomtran" updatewhere=0 updatekeyinplace=no  sort="parent_no D bom_no D " )
