footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="saledet.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="saledet.qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=decimal(4) updatewhereclause=yes name=itemloc_qoh dbname="qoh" )
 column=(type=datetime updatewhereclause=yes name=cdate dbname="cdate" )
 column=(type=decimal(4) updatewhereclause=yes name=rcptqty dbname="rcptqty" )
 column=(type=decimal(4) updatewhereclause=yes name=issueqty dbname="issueqty" )
 column=(type=decimal(2) updatewhereclause=yes name=notissueqty dbname="notissueqty" )
 retrieve="  SELECT           groupitem.item_name,
                            saledet.item_no,
                    		   	saledet.qa,   
                            uom         = (case groupitem.uom when 'M'  then 'EA' when 'M2' then 'EA' else groupitem.uom  end),
                            qoh         = isnull(itemloc.qoh, 0) - isnull(couteoday.rcptqty, 0) + isnull(couteoday.issueqty, 0),   
                            cdate       = convert(smalldatetime, :ad_date, 111),   
                            rcptqty     = isnull(cineoday.rcptqty, 0),   
                            issueqty    = isnull(cineoday.issueqty, 0),
                    			  notissueqty = isnull(csaledet.order_qty, 0) + isnull(crout.order_qty, 0)
    FROM saledet inner join  sale on saledet.order_no  = sale.order_no
                             inner join groupitem on saledet.item_no = groupitem.item_no
                             left outer join itemloc on saledet.item_no = itemloc.item_no
                                                          		and saledet.qa = itemloc.qa
                                                          		and itemloc.loc_no    = :as_loc
                        		 left outer join	(
                                                		      select saledet.item_no, saledet.qa, rcptqty = isnull(sum(ineoday.rcpt_qty), 0),
                                            									issueqty = isnull(sum(ineoday.issue_qty), 0)
                                                			   from saledet inner join sale on saledet.order_no = sale.order_no
                                                                               left outer join ineoday on saledet.item_no = ineoday.item_no and saledet.qa = ineoday.qa
                                                                                  	  			 and cdate  = :as_date
                                                                                  				   and ineoday.loc_no   = :as_loc                                                                               
                                                			  WHERE saledet.order_no = :as_order
                                                				         and order_date      >=  DATEADD(month, -2, convert(smalldatetime, :ad_date, 111))
                                                			  group by saledet.item_no, saledet.qa
                                            			) cineoday on saledet.item_no = cineoday.item_no and saledet.qa = cineoday.qa 
                        		  left outer join	(
                                      			             select saledet.item_no, saledet.qa, rcptqty = sum(ineoday.rcpt_qty),
                                                															 issueqty = sum(ineoday.issue_qty)
                                                              			   from saledet inner join sale on saledet.order_no = sale.order_no
                                                                                             left outer join ineoday on saledet.item_no = ineoday.item_no and saledet.qa = ineoday.qa
                                                                                                              	  			 and cdate > :as_date
                                                                                                              				   and ineoday.loc_no = :as_loc                                             
                                                			  WHERE saledet.order_no = :as_order
                                                				 and order_date      >= DATEADD(month, -2, convert(smalldatetime, :ad_date, 111))	
                                                			  group by saledet.item_no, saledet.qa
                                                		) couteoday on saledet.item_no = couteoday.item_no and saledet.qa = couteoday.qa 
                        		  left outer join	(
                                                         		  select saledet.item_no, saledet.qa,
                                                    					  order_qty = isnull(sum( saledet.order_qty  -  saledet.rlse_qty ), 0)
                                                    			   from sale inner join saledet on sale.order_no    = saledet.order_no
                                                    			  WHERE sale.order_no    = :as_order
                                                    				 and order_date      >=  DATEADD(month, -2, convert(smalldatetime, :ad_date, 111))
                                                    				 and sale.open_close  = 'O'
                                                    				 and saledet.order_qty > saledet.rlse_qty
                                                    			  group by saledet.item_no, saledet.qa
                                              			) csaledet on saledet.item_no = csaledet.item_no and saledet.qa = csaledet.qa 
                        		  left outer join	(
                                                       		 select item_no = rout.assembly, qa =  rout.assy_qa,
                                                					  order_qty = isnull(sum( saledet.order_qty  -  saledet.rlse_qty ), 0)
                                                			   from sale inner join saledet on saledet.order_no  = sale.order_no
                                                                          inner join rout on saledet.item_no = rout.item_no and saledet.qa = rout.qa
                                                				                                        and rout.item_no     <> rout.assembly
                                                			  WHERE sale.order_no    = :as_order
                                                				and order_date       >= DATEADD(month, -2, convert(smalldatetime, :ad_date, 111))
                                                				and sale.open_close   = 'O'
                                                				and saledet.order_qty > saledet.rlse_qty
                                                			 group by rout.assembly, rout.assy_qa
                                            			) crout on saledet.item_no = crout.item_no and saledet.qa = crout.qa 
   WHERE saledet.order_no   = :as_order
		and order_date       >= DATEADD(month, -2, convert(smalldatetime, :ad_date, 111))
		and sale.open_close   = 'O'
" arguments=(("as_date", string),("ad_date", date),("as_loc", string),("as_order", string))  sort="groupitem_item_name A qa A " )
