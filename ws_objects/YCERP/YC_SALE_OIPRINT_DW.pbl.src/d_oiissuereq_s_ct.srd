$PBExportHeader$d_oiissuereq_s_ct.srd
$PBExportComments$출고
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no  crosstab.dynamic = yes grid.lines=0 selected.mouse=no )
header[1](height=0 color="536870912" )
header[2](height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(20) updatewhereclause=yes name=schedule_name dbname="schedule_name" )
 column=(type=number updatewhereclause=yes name=plan_amt dbname="plan_amt" )
 retrieve="  SELECT user_name       = isnull(bb.user_name,'NoName')
       , wan_nm          = (case when substring(bb.scene_desc,1,2) IN ('서울','인천','경기','해외')
                                      AND aa.issue_schedule IN ('A','B','J','I') then '1.수도권'
                                 when substring(bb.scene_desc,1,2) NOT IN ('서울','인천','경기','해외')
                                      AND aa.issue_schedule IN ('A','B','J','I') then '2.지방'
                                 when aa.issue_schedule     IN ('F','E')         then '3.외주'
                                 when aa.issue_schedule     IN ('K')             then '4.택배'
                                 when aa.issue_schedule     IN ('D')             then '5.방문'
                                 when aa.issue_schedule     IN ('G','C')         then '6.기타'
                            end)
       , schedule_name   = aa.schedule_name
       , accept_name     = (case aa.accept_name 
                                 when '시화' then '1.'
                                 when '화곡' then '2.'
                                 when '동부' then '3.'
                                 when '대전' then '4.'
                                 when '화성' then '5.'
                            end) + aa.accept_name
       , plan_amt        = (case when convert(char(10),bb.rlse_date,111) = :as_reqdate then /* 출고일이 당일이면 상차수량 계산 */
                                      bb.price * dbo.uf_getqty(bb.item_no, bb.qa, bb.uom, dd.ship_qty)
                                 else (case when bb.issue_qty > 0 AND bb.rlse_date is null then    /* 미출고는 선정수량으로 계산 */
                                                 bb.price * dbo.uf_getqty(bb.item_no, bb.qa, bb.uom, bb.issue_qty)
                                            else 0
                                       end)
                            end)
  FROM (
            SELECT DISTINCT 
                   req_date       = a.req_date                                                               
                 , salesman       = a.salesman                                                               
                 , req_seq        = a.req_seq
                 , accept_area    = a.accept_area                                                                
                 , accept_name    = replace(c.loc_name,'저장소','')
                 , accept_user    = a.accept_user                                                            
                 , sale_no        = b.sale_no                                                                
                 , seq_no         = isnull(i.seq_no, 1)
                 , confirm_flag   = a.confirm_flag                                                             
                 , issue_schedule = b.issue_schedule                                                         
                 , schedule_name  = (case b.issue_schedule                                      
                                           when 'A' then '직출'                                   
                                           when 'B' then '생산후직출'                               
                                           when 'C' then '자동작성'                                 
                                           when 'D' then '방문'                                   
                                           when 'E' then '외주(시화)'                                   
                                           when 'F' then '외주(본사)'                                   
                                           when 'G' then '유창강건'                                   
                                           when 'H' then '지점이송'                                   
                                           when 'I' then '야간도착'                                   
                                           when 'J' then '저녁상차'                                   
                                           when 'K' then '택배/정기'                                   
                                           else           ''                                      
                                      end)                                                        
              FROM issuereq   A with (nolock)                                                            
                   LEFT OUTER JOIN issuereqdet   B with (nolock)
                     ON a.req_date  = b.req_date AND a.salesman  = b.salesman AND a.req_seq = b.req_seq
                   LEFT OUTER JOIN issuereqdet_sale I with (nolock)
                     ON b.req_date  = i.req_date AND b.salesman  = i.salesman AND b.req_seq = i.req_seq and b.seq = i.seq
                   LEFT OUTER JOIN location  C with (nolock) ON a.accept_user = c.loc_manager
             WHERE a.req_date        = :as_reqdate + ' 00:00:00'
               AND a.confirm_flag    = 'Y'  
               AND b.issue_schedule <> 'H'  /* 지점이송 */
               AND b.req_flag        = 'A'  /* 출고의뢰 */
       ) AA

       LEFT OUTER JOIN (                                                                
            SELECT DISTINCT
                   user_name    = l.user_name
                 , scene_nm     = substring(s.scene_desc,1,2)
                 , scene_desc   = s.scene_desc
                 , order_no     = a.order_no
                 , seq_no       = a.seq_no
                 , item_no      = a.item_no                                               
                 , qa           = a.qa                                                    
                 , uom          = a.uom                                                   
                 , order_qty    = a.order_qty                                             
                 , price        = a.price                                                 
                 , issue_qty    = i.issue_qty                                                 
                 , stock_qty    = a.stock_qty                                             
                 , rlse_date    = a.rlse_date                                             
                 , rlse_qty     = a.rlse_qty                                              
              FROM issuereq    IR with (nolock)                                           
                   LEFT OUTER JOIN issuereqdet  IB with (nolock)
                     ON ir.req_date  = ib.req_date AND ir.salesman  = ib.salesman AND ir.req_seq = ib.req_seq                                                       
                   LEFT OUTER JOIN issuereqdet_sale I
                     ON ib.req_date  = i.req_date  AND ib.salesman  = i.salesman  AND ib.req_seq = i.req_seq and ib.seq = i.seq
                   LEFT OUTER JOIN saledet   A with (nolock) ON i.order_no = a.order_no AND i.seq_no = a.seq_no
                   LEFT OUTER JOIN sale      B with (nolock) ON a.order_no    = b.order_no
                   LEFT OUTER JOIN customer  C with (nolock) ON b.cust_no     = c.cust_no
                   LEFT OUTER JOIN scene     S with (nolock) ON b.scene_code  = s.scene_code
                   LEFT OUTER JOIN login     L with (nolock) ON c.salesman    = l.user_id
             WHERE ir.req_date        = :as_reqdate + ' 00:00:00'
               AND ir.confirm_flag    = 'Y'  
               AND ib.issue_schedule <> 'H'  /* 지점이송 */
               AND ib.req_flag        = 'A'  /* 출고의뢰 */
               AND ((:as_inside  = 'N') OR
                    (:as_inside <> 'N') AND (c.salesman <> 'killby')
                   )                   
       ) BB ON aa.sale_no = bb.order_no AND aa.seq_no = bb.seq_no                                                    
                                                                                        
       LEFT OUTER JOIN (
            SELECT a.do_no, a.sale_no, a.seq_no, a.ship_qty, a.price, b.do_date
              FROM dodet  A
                   LEFT OUTER JOIN do  B ON a.do_no = b.do_no
             WHERE convert(char(10),b.do_date,111)  = :as_reqdate
       ) DD ON bb.order_no = dd.sale_no AND bb.seq_no = dd.seq_no
  WHERE ( aa.confirm_flag    = 'Y'                        )
    AND ( aa.issue_schedule <> 'H'                        )  /* '지점이송' */
    AND ( aa.req_date  = :as_reqdate + ' 00:00:00' )
	 AND ( bb.user_name  IS NOT NULL )
" arguments=(("as_reqdate", string),("as_inside", string))  sort="user_name A schedule_name A " )
group(level=1 header.height=0 trailer.height=80 by=("user_name" ) header.color="536870912" trailer.color="12639424" )
