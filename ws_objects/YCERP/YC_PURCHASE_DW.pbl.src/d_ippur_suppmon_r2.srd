$PBExportHeader$d_ippur_suppmon_r2.srd
$PBExportComments$자재 거래처별구매월보(1999/09/21, 이인호)
release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=472 color="536870912" )
summary(height=112 color="536870912" )
footer(height=0 color="536870912" )
detail(height=120 color="536870912" )
table(column=(type=char(30) updatewhereclause=yes name=bsupp_supp_name dbname="bsupp.supp_name" )
 column=(type=decimal(2) updatewhereclause=yes name=bpeom_balbf_amount dbname="bpeom.balbf_amount" )
 column=(type=decimal(2) updatewhereclause=yes name=mamt dbname="mamt" )
 column=(type=long updatewhereclause=yes name=yy dbname="yy" )
 column=(type=long updatewhereclause=yes name=mm dbname="mm" )
 retrieve="  SELECT bsupp.supp_name,   
         bpeom.balbf_amount,   
         mamt = (case when :ai_mon = 1 then inv_01 when :ai_mon = 2 then inv_02 when :ai_mon = 3 then inv_03 when :ai_mon = 4 then inv_04 when :ai_mon = 5 then inv_05 when :ai_mon = 6 then inv_06 when :ai_mon = 7 then inv_07 when :ai_mon = 8 then inv_08 when :ai_mon = 9 then inv_09 when :ai_mon = 10 then inv_10 when :ai_mon = 11 then inv_11 when :ai_mon = 12 then inv_12 end)  ,
		   yy = :ai_year,
			mm = :ai_mon
    FROM bsupp,   
         bpeom  
   WHERE ( bsupp.supp_no = bpeom.supp_no ) and  
         ( ( bpeom.eom_year = :ai_year ) ) and
			( ( bpeom.area_no = :as_area ) ) and
			( (case when :ai_mon = 1 then inv_01 when :ai_mon = 2 then inv_02 when :ai_mon = 3 then inv_03 when :ai_mon = 4 then inv_04 when :ai_mon = 5 then inv_05 when :ai_mon = 6 then inv_06 when :ai_mon = 7 then inv_07 when :ai_mon = 8 then inv_08 when :ai_mon = 9 then inv_09 when :ai_mon = 10 then inv_10 when :ai_mon = 11 then inv_11 when :ai_mon = 12 then inv_12 end) <> 0 )
" arguments=(("ai_year", number),("ai_mon", number),("as_area", string))  sort="bsupp_supp_name A " )
