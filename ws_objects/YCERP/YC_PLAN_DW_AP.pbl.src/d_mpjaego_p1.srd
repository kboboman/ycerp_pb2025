table(column=(type=char(14) updatewhereclause=yes name=sale_order_no dbname="sale.order_no" )
 column=(type=char(10) updatewhereclause=yes name=saledet_item_no dbname="saledet.item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_item_name dbname="item.item_name" )
 column=(type=char(20) updatewhereclause=yes name=item_qa dbname="item.qa" )
 column=(type=char(2) updatewhereclause=yes name=item_uom dbname="item.uom" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_order_qty dbname="saledet.order_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_acc_qty dbname="saledet.acc_qty" )
 column=(type=char(10) updatewhereclause=yes name=itemloc_loc_no dbname="itemloc.loc_no" )
 column=(type=decimal(4) updatewhereclause=yes name=qoh dbname="compute_0009" )
 column=(type=char(4) updatewhereclause=yes name=sale_cust_no dbname="sale.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene.scene_desc" )
 column=(type=char(80) updatewhereclause=yes name=sale_shipto_addr dbname="sale.shipto_addr" )
 column=(type=char(10) updatewhereclause=yes name=scene_scene_charge dbname="scene.scene_charge" )
 column=(type=char(15) updatewhereclause=yes name=scene_scene_tel dbname="scene.scene_tel" )
 column=(type=char(30) updatewhereclause=yes name=shipflag_name dbname="shipflag.name" )
 column=(type=char(8) updatewhereclause=yes name=compute_0017 dbname="compute_0017" )
 column=(type=datetime updatewhereclause=yes name=sale_cust_po_date dbname="sale.cust_po_date" )
 column=(type=datetime updatewhereclause=yes name=sale_due_date dbname="sale.due_date" )
 column=(type=char(80) updatewhereclause=yes name=sale_rem dbname="sale.rem" )
 column=(type=char(80) updatewhereclause=yes name=rem1 dbname="sale.rem1" )
 column=(type=char(80) updatewhereclause=yes name=rem2 dbname="sale.rem2" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name dbname="login.user_name" )
 column=(type=char(6) updatewhereclause=yes name=compute_0024 dbname="compute_0024" )
 column=(type=char(10) updatewhereclause=yes name=b_user_name dbname="sale.user_name" )
 column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_rlse_qty dbname="saledet.rlse_qty" )
 column=(type=char(50) updatewhereclause=yes name=saledet_rem dbname="saledet.rem" )
 column=(type=datetime updatewhereclause=yes name=sale_order_date dbname="sale.order_date" )
 column=(type=char(6) updatewhereclause=yes name=compute_0030 dbname="compute_0030" )
 retrieve="  SELECT DISTINCT sale.order_no
       , saledet.item_no
       , item.item_name
       , item.qa
       , item.uom
       , saledet.order_qty
       , saledet.acc_qty
       , itemloc.loc_no
       , IsNull(itemloc.qoh, 0)
       , sale.cust_no
       , customer.cust_name
       , scene.scene_desc
       , sale.shipto_addr
       , scene.scene_charge
       , scene.scene_tel
       , shipflag.name
       , (CASE sale.ship_case 
            WHEN 'J' THEN '정기화물' 
            WHEN 'T' THEN '택배' 
            WHEN 'A' THEN '오토바이' 
            WHEN 'S' THEN '선박' 
            WHEN 'P' THEN '항공' 
            ELSE '기타' 
          END)
       , sale.cust_po_date
       , sale.due_date
       , sale.rem
       , sale.rem1
       , sale.rem2
       , login.user_name
       , (CASE sale.confirm_flag WHEN 'Y' THEN '확정' ELSE '미확정' END)
       , b.user_name
       , chk = ''
       , saledet.rlse_qty
       , saledet.rem
       , sale.order_date
       , (CASE WHEN saledet.order_qty - rlse_qty > 0 THEN '미출고' ELSE '출고' END)
    FROM sale      (nolock)                                                                                                   
         LEFT OUTER JOIN saledet  (nolock) ON sale.order_no   = saledet.order_no                                              
         LEFT OUTER JOIN item     (nolock) ON saledet.item_no = item.item_no    AND saledet.qa = item.qa                      
         LEFT OUTER JOIN scene    (nolock) ON sale.scene_code = scene.scene_code                                              
         LEFT OUTER JOIN itemloc  (nolock) ON saledet.item_no = itemloc.item_no AND saledet.qa = itemloc.qa                   
         LEFT OUTER JOIN customer (nolock) ON sale.cust_no    = customer.cust_no                                              
         LEFT OUTER JOIN shipflag (nolock) ON sale.sale_flag  = shipflag.flag                                                 
         LEFT OUTER JOIN login    (nolock) ON sale.login_id   = login.user_id                                                 
         LEFT OUTER JOIN login b  (nolock) ON sale.salesman   = b.user_id                                                     
         LEFT OUTER JOIN incounu  (nolock) ON saledet.item_no = incounu.item_no                                               

"  sort="sale_order_no A saledet_item_no A item_qa A " )
