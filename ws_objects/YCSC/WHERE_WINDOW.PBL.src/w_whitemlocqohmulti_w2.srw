type dw_3 from datawindow within tabpage_1
event mousemove pbm_dwnmousemove
integer x = 1733
integer y = 260
integer width = 1312
integer height = 764
integer taborder = 200
boolean bringtotop = true
string title = "none"
string dataobject = "d_cditemalllocqoh_c"
boolean hscrollbar = true
boolean vscrollbar = true
boolean livescroll = true
borderstyle borderstyle = stylelowered!
end type

event mousemove;if row < 1 then return
this.scrolltorow(row)
end event

event clicked;//
string ls_itemno, ls_qa, ls_use
long   ll_row, ll_cnt

if row < 1 then return


//ls_itemno = dw2.object.item_no[dw2.getrow()] 오류수정
ls_itemno = dw3.object.item_item_no[row]
ls_qa     = dw3.object.qa[row]

i_item_no = dw3.object.item_item_no[row]
i_qa      = dw3.object.qa[row]

setnull(ls_use)
SELECT use_flag INTO :ls_use FROM item	 WHERE item_no = :ls_itemno AND qa = :ls_qa;
if ls_use = 'C' then
	dw3.SelectRow(0, false)
	cbx_2.checked = false

	dw_1.scrolltorow(ll_cnt)
	dw_1.setredraw( true )
	MessageBox("확인", "선택하신품목은 사용불가인 품목입니다 ~r~n" + &
							 "물품RELOAD 를 하신후에 다시 작업하여 주시기바랍니다")
	RETURN
else
	this.SelectRow(0, false)
	this.SelectRow(row,  NOT this.IsSelected(row))
	this.scrolltorow(row)	

	/* 2017.11.14  즐겨찾기에서 추가버튼 로직을 타게한다. 시작*/
	if tab_2.tabpage_7.cbx_3.checked then
		wf_fav_insert(); // 2017.11.14 조원석 itemfav 테이블에 insert 하는 함수.
	else
		cb_6.postevent(clicked!)
	end if
	/* 2017.11.14  즐겨찾기에서 추가버튼 로직을 타게한다. 끝*/	
end if

end event

event doubleclicked;if row < 1 then return
this.scrolltorow(row)
if istr_where.chk = 'M' then
else
	cb_1.postevent(clicked!)
end if

end event

event rbuttondown;//
if row < 1 then return

this.SelectRow(0, false)
this.SelectRow(row,  NOT this.IsSelected(row))
this.scrolltorow(row)

il_dw3row = row 
tab_2.tabpage_8.cb_23.triggerevent(clicked!)

end event

