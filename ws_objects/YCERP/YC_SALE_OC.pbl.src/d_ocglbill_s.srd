$PBExportHeader$d_ocglbill_s.srd
$PBExportComments$어음관리 어음선택(1998/04/23, 정재수)
release 8;
datawindow(units=0 timer_interval=0 color=79219928 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=84 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=close_date dbname="glbill.close_date" )
 column=(type=char(12) updatewhereclause=yes name=vc_no dbname="glbill.vc_no" )
 column=(type=char(12) updatewhereclause=yes name=bill_no dbname="glbill.bill_no" )
 column=(type=char(1) updatewhereclause=yes name=bill_class dbname="glbill.bill_class" )
 column=(type=char(4) updatewhereclause=yes name=bill_class1 dbname="bill_class1" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 retrieve="  SELECT glbill.close_date   
       , glbill.vc_no
       , glbill.bill_no  
       , glbill.bill_class
       , bill_class1 = (case when glbill.bill_class = ~"R~"  then ~"받을~"
                             when glbill.bill_class = ~"P~"  then ~"지급~"
                             when glbill.bill_class = ~"C~"  then ~"교환~"
                             when glbill.bill_class = ~"E~"  then ~"만기~"
                             when glbill.bill_class = ~"D~"  then ~"부도~"
                        end)
       , customer.cust_name
    FROM glbill   
         left outer join customer  on glbill.cust_no = customer.cust_no
"  sort="close_date A vc_no D " )
