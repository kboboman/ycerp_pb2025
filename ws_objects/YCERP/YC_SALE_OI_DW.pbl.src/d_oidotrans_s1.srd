 column=(type=char(4) updatewhereclause=yes name=tcust_no dbname="tcust_no" )
 column=(type=char(50) updatewhereclause=yes name=tcust_name dbname="tcust_name" )
 column=(type=char(11) updatewhereclause=yes name=tspot_code dbname="tspot_code" )
 column=(type=char(40) updatewhereclause=yes name=tscene_desc dbname="tscene_desc" )
 column=(type=char(10) updatewhereclause=yes name=tsalesman dbname="tsalesman" )
 column=(type=char(10) updatewhereclause=yes name=tr_app1 dbname="DOTRANS.tr_app1" )
 column=(type=datetime updatewhereclause=yes name=tr_appdt1 dbname="DOTRANS.tr_appdt1" )
 column=(type=char(10) updatewhereclause=yes name=tr_app2 dbname="DOTRANS.tr_app2" )
 column=(type=datetime updatewhereclause=yes name=tr_appdt2 dbname="DOTRANS.tr_appdt2" )
 column=(type=char(10) updatewhereclause=yes name=tr_app3 dbname="DOTRANS.tr_app3" )
 column=(type=datetime updatewhereclause=yes name=tr_appdt3 dbname="DOTRANS.tr_appdt3" )
 column=(type=char(10) updatewhereclause=yes name=tr_app4 dbname="DOTRANS.tr_app4" )
 column=(type=datetime updatewhereclause=yes name=tr_appdt4 dbname="DOTRANS.tr_appdt4" )
 column=(type=char(10) updatewhereclause=yes name=tr_app5 dbname="DOTRANS.tr_app5" )
 column=(type=datetime updatewhereclause=yes name=tr_appdt5 dbname="DOTRANS.tr_appdt5" )
 column=(type=char(1) updatewhereclause=yes name=tr_return dbname="DOTRANS.tr_return" )
 column=(type=char(10) updatewhereclause=yes name=tr_apph dbname="DOTRANS.tr_apph" )
 column=(type=datetime updatewhereclause=yes name=tr_appdth dbname="DOTRANS.tr_appdth" )
 column=(type=decimal(0) updatewhereclause=yes name=trans_amt dbname="trans_amt" )
 column=(type=decimal(0) updatewhereclause=yes name=tamt dbname="tamt" )
 column=(type=char(1) updatewhereclause=yes name=apply_end dbname="apply_end" )
 column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" )
 retrieve="SELECT trans_no    = a.trans_no
     , tr_type     = (case when a.tr_type = 'MOVE' then '이관'
                           when a.tr_type = 'NEXT' then '이월'
                           when a.tr_type = 'SPOT' then '현장'
                           when a.tr_type = 'DO'   then '송장'
                      end)
     , tr_date     = a.tr_date
     , user_id     = a.user_id
     , team_code   = a.team_code
     , a.tr_ewolfix
     , docheck     = (SELECT count(*) FROM do WHERE do_no IN ( SELECT do_no FROM dotransdet WHERE trans_no = a.trans_no ))

     , fcust_no    = a.fcust_no
     , fcust_name  = b.cust_name
     , fspot_code  = a.fspot_code
     , fscene_desc = s1.scene_desc
     , fsalesman   = a.fsalesman
     
     , tcust_no    = a.tcust_no
     , tcust_name  = c.cust_name
     , tspot_code  = a.tspot_code
     , tscene_desc = s2.scene_desc
     , tsalesman   = a.tsalesman

     , a.tr_app1   , a.tr_appdt1
     , a.tr_app2   , a.tr_appdt2
     , a.tr_app3   , a.tr_appdt3
     , a.tr_app4   , a.tr_appdt4
     , a.tr_app5   , a.tr_appdt5
     , a.tr_return

     , a.tr_apph   , a.tr_appdth

     , trans_amt   = a.tr_transamt
     , tamt        = z.tamt
     , apply_end   = isnull(a.apply_end,'N')
     , chk         = 'N'
  FROM dotrans  A with(nolock)
       LEFT OUTER JOIN customer  B with(nolock) ON  a.fcust_no     = b.cust_no
       LEFT OUTER JOIN scene    S1 with(nolock) ON  a.fspot_code  = s1.scene_code
       LEFT OUTER JOIN customer  C with(nolock) ON  a.tcust_no    = c.cust_no
       LEFT OUTER JOIN scene    S2 with(nolock) ON  a.tspot_code  = s2.scene_code
       LEFT OUTER JOIN (
            /* 금액 적산하기 */
            SELECT fcust_no  = a.fcust_no
                 , tr_type  = a.tr_type
                 , trans_no = a.trans_no
                 , amt      = a.tr_transamt
                 , tamt     = sum(b.tr_transamt)
              FROM dotrans A with(nolock) INNER JOIN dotrans B  with(nolock) ON a.fcust_no   = B.fcust_no 
                                  AND a.tr_type    = B.tr_type 
                                  AND a.trans_no  >= b.trans_no 
                                  AND B.tr_date  BETWEEN :ad_sdate AND :ad_edate
             WHERE a.tr_date  BETWEEN :ad_sdate AND :ad_edate
             GROUP BY a.fcust_no, a.tr_type, a.trans_no, a.tr_transamt
          /* ORDER BY a.fcust_no, a.tr_type, a.trans_no */
       ) Z  ON a.fcust_no   = z.fcust_no AND a.tr_type = z.tr_type AND a.trans_no = z.trans_no
 WHERE ( a.tr_date  BETWEEN :ad_sdate AND :ad_edate )
   AND ((a.user_id  LIKE :as_userid               ) OR
        (a.tr_app1  LIKE :as_userid               ) OR
        (a.tr_app2  LIKE :as_userid               ) OR
        (a.tr_app3  LIKE :as_userid               ) OR
        (a.tr_app4  LIKE :as_userid               ) OR
        (a.tr_app5  LIKE :as_userid               ) OR
        (a.tr_apph  LIKE :as_userid               ) OR
        (:as_userid  = '%' AND a.user_id LIKE '%' ) 
       )
   AND ((:as_trapp5 = 'ALL' ) OR
        (:as_trapp5 = 'NO'  AND a.tr_appdt5 is null     ) OR
        (:as_trapp5 = 'YES' AND a.tr_appdt5 is not null )
       )
 ORDER BY a.fcust_no, a.tr_type, a.trans_no
" arguments=(("as_userid", string),("ad_sdate", date),("ad_edate", date),("as_trapp5", string)) )
