footer(height=0 color="536870912" )
detail(height=92 color="536870912" )
table(column=(type=decimal(0) update=yes updatewhereclause=yes identity=yes name=personal_id dbname="bogo_personal_connection.personal_id" )
 column=(type=char(20) update=yes updatewhereclause=yes name=name dbname="bogo_personal_connection.name" )
 column=(type=char(20) update=yes updatewhereclause=yes name=tel dbname="bogo_personal_connection.tel" )
 column=(type=char(2) update=yes updatewhereclause=yes name=kind dbname="bogo_personal_connection.kind" values="건설사	01/설계사	02/감리처	03/시공업체	04/시행사	05/" )
 column=(type=char(50) update=yes updatewhereclause=yes name=company dbname="company" )
 column=(type=char(20) update=yes updatewhereclause=yes name=level dbname="bogo_personal_connection.level" )
 column=(type=char(20) update=yes updatewhereclause=yes name=job dbname="bogo_personal_connection.job" )
 column=(type=char(100) update=yes updatewhereclause=yes name=personal_story dbname="bogo_personal_connection.personal_story" )
 column=(type=char(8) update=yes updatewhereclause=yes name=write_date dbname="bogo_personal_connection.write_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=write_user_id dbname="bogo_personal_connection.write_user_id" )
 column=(type=char(10) updatewhereclause=yes name=v_presale_all_user_write_user_name dbname="V_PRESALE_ALL_USER.write_user_name" )
 column=(type=char(8) update=yes updatewhereclause=yes name=modify_date dbname="bogo_personal_connection.modify_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=modify_user_id dbname="bogo_personal_connection.modify_user_id" )
 column=(type=char(10) updatewhereclause=yes name=v_presale_all_user_modify_user_name dbname="V_PRESALE_ALL_USER.modify_user_name" )
 retrieve="select    bogo_personal_connection.personal_id,
              bogo_personal_connection.name,
              bogo_personal_connection.tel,
              bogo_personal_connection.kind,
		    case when bogo_personal_connection.kind = '01' then sale_bogo_code.code_name
				   else bogo_personal_connection.company end company, 
              bogo_personal_connection.level,
              bogo_personal_connection.job,
              bogo_personal_connection.personal_story,
              bogo_personal_connection.write_date,
              bogo_personal_connection.write_user_id,
              b.user_name write_user_name,
              bogo_personal_connection.modify_date,
              bogo_personal_connection.modify_user_id,
              c.user_name modify_user_name
from bogo_personal_connection with(nolock) left outer join V_PRESALE_ALL_USER b on bogo_personal_connection.write_user_id = b.user_id
												  left outer join V_PRESALE_ALL_USER c on bogo_personal_connection.write_user_id = c.user_id
												  left outer join sale_bogo_code with(nolock) on  bogo_personal_connection.company_code = sale_bogo_code.code 
                                                                          										          and bogo_personal_connection.gubun = sale_bogo_code.gubun
where bogo_personal_connection.gubun = :as_gubun
								  
" arguments=(("as_gubun", string))  sort="name A kind A company A " )
