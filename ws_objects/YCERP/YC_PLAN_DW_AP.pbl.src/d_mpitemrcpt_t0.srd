 retrieve="PBSELECT( VERSION(400) DISTINCT ()TABLE(NAME=~"item~" )  TABLE(NAME=~"wc~" )  TABLE(NAME=~"location~" ) COLUMN(NAME=~"item.uom~") COLUMN(NAME=~"item.source~") COLUMN(NAME=~"item.qoh~") COLUMN(NAME=~"item.sales_reserved~") COLUMN(NAME=~"item.prodn_reserved~") COLUMN(NAME=~"item.item_wc~") COLUMN(NAME=~"item.safety_stock~") COLUMN(NAME=~"item.lot~") COLUMN(NAME=~"item.std_burden~") COLUMN(NAME=~"item.std_subcontract~") COLUMN(NAME=~"item.std_machine~") COLUMN(NAME=~"item.heft~") COLUMN(NAME=~"item.volume~") COLUMN(NAME=~"item.item_no~") COLUMN(NAME=~"item.qa~") COLUMN(NAME=~"item.loc_no~") COLUMN(NAME=~"item.item_name~") COLUMN(NAME=~"wc.work_name~") COLUMN(NAME=~"wc.work_type~") COLUMN(NAME=~"location.loc_name~") COLUMN(NAME=~"location.position~") COLUMN(NAME=~"location.loc_manager~") COLUMN(NAME=~"wc.work_manager~") COLUMN(NAME=~"wc.capacity~")    JOIN (LEFT=~"item.item_wc~"    OP =~"=~"RIGHT=~"wc.work_no~"    OUTER1 =~"item.item_wc~" )    JOIN (LEFT=~"item.loc_no~"    OP =~"=~"RIGHT=~"location.loc_no~" )WHERE(    EXP1 =~"item.item_no~"   OP =~"=~"    EXP2 =~":as_itemno~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"item.qa~"   OP =~"=~"    EXP2 =~":as_qa~" ) ) ARG(NAME = ~"as_itemno~" TYPE = string)  ARG(NAME = ~"as_qa~" TYPE = string) " arguments=(("as_itemno", string),("as_qa", string)) )
