table(column=(type=char(10) updatewhereclause=yes name=work_no dbname="wc.work_no" initial=" " )
 column=(type=char(10) updatewhereclause=yes name=work_name dbname="wc.work_name" initial=" " )
 column=(type=char(10) updatewhereclause=yes name=def_loc dbname="wc.def_loc" )
 column=(type=char(1) updatewhereclause=yes name=work_type dbname="wc.work_type" )
 column=(type=char(10) updatewhereclause=yes name=area_no dbname="wc.area_no" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="login.user_name" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="wc.user_id" )
 column=(type=char(1) updatewhereclause=yes name=use_yn dbname="use_yn" )
 retrieve="  SELECT wc.work_no
       , wc.work_name
       , wc.def_loc  
       , wc.work_type
       , wc.area_no
       , l.user_name
       , wc.user_id
       , use_yn = (case when wc.use_yn is null then 'Y' else wc.use_yn end)
    FROM wc
         LEFT OUTER JOIN login L ON wc.user_id = l.user_id   
   ORDER BY work_type, work_no
" )
