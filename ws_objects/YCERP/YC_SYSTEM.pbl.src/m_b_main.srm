type m_4 from menu within m_utility
end type

event clicked;
gs_chkpass_str lstr_pass

openwithparm(w_chkpass,lstr_pass)
lstr_pass = message.powerobjectparm
if lstr_pass.chk = false then
	return
end if
open(w_s_main)  // 시스템관리 메인윈도우 오픈
end event

on m_4.create
call super::create
this.text = "시스템관리"
end on

on m_4.destroy
call super::destroy
end on

type m_window from menu within m_b_main
m_layered m_layered
m_cascade m_cascade
end type

on m_window.create
call super::create
this.text = "윈도우(&Window)"
this.m_layered=create m_layered
this.m_cascade=create m_cascade
this.Item[UpperBound(this.Item)+1]=this.m_layered
this.Item[UpperBound(this.Item)+1]=this.m_cascade
end on

on m_window.destroy
call super::destroy
destroy(this.m_layered)
destroy(this.m_cascade)
end on

type m_layered from menu within m_window
end type

on m_layered.create
call super::create
this.text = "Layered"
end on

event clicked;parentwindow.ArrangeSheets(Layer!)  // Cascade!,Layer!,Tile!,TileHorizontal!,Icons!
end event

on m_layered.destroy
call super::destroy
end on

type m_cascade from menu within m_window
end type

on m_cascade.create
call super::create
this.text = "Cascade"
end on

event clicked;parentwindow.ArrangeSheets(Cascade!)  // Cascade!,Layer!,Tile!,TileHorizontal!,Icons! 
end event

on m_cascade.destroy
call super::destroy
end on

