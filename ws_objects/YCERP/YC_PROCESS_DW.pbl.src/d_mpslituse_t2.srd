datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="12639424" )
detail(height=72 color="536870912" )
table(column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(10) updatewhereclause=yes name=sfcuse_use_date dbname="use_date" )
 column=(type=char(20) updatewhereclause=yes name=sfcuse_qa dbname="sfcuse.qa" )
 column=(type=char(20) updatewhereclause=yes name=sfcuse_coil_no dbname="sfcuse.coil_no" )
 column=(type=decimal(4) updatewhereclause=yes name=sfcuse_unit_qty dbname="sfcuse.unit_qty" )
 column=(type=long updatewhereclause=yes name=sfcuse_cnt dbname="sfcuse.cnt" )
 column=(type=datetime updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=datetime updatewhereclause=yes name=edate dbname="edate" )
 column=(type=char(10) updatewhereclause=yes name=wc_work_name dbname="wc.work_name" )
 retrieve="  SELECT groupitem.item_name   
       , convert(char(10), sfcuse.use_date,121) use_date       
       , sfcuse.qa             
       , sfcuse.coil_no        
       , sfcuse.unit_qty       
       , sfcuse.cnt            
       , sdate = convert(smalldatetime, :ad_start, 111)   
       , edate = convert(smalldatetime, :ad_end, 111)     
       , wc.work_name  
FROM sfcuse INNER JOIN GROUPITEM ON sfcuse.item_no = groupitem.item_no      
                        LEFT OUTER JOIN wc ON sfcuse.wc_no = wc.work_no
   WHERE  ( sfcuse.use_date     BETWEEN convert(datetime,  :ad_start +' 00:00:00' ) and convert(datetime,  :ad_end + ' 23:59:59' ) ) AND
                   ( sfcuse.coil_no     IS NOT NULL                  ) " arguments=(("ad_start", date),("ad_end", date))  sort="sfcuse_use_date A groupitem_item_name A mid(sfcuse_qa,5, 6) A sfcuse_qa A sfcuse_unit_qty A " )
