$PBExportHeader$d_sliting_d.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 selected.mouse=no )
header(height=88 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=88 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=order_no dbname="coilsliting.order_no" )
 column=(type=long updatewhereclause=yes name=coilsliting_seq dbname="coilsliting.seq" )
 column=(type=decimal(1) updatewhereclause=yes name=swid dbname="swid" )
 column=(type=long updatewhereclause=yes name=coilsliting_cnt dbname="coilsliting.cnt" )
 column=(type=decimal(4) updatewhereclause=yes name=coilsliting_unit_qty dbname="coilsliting.unit_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=thin dbname="thin" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(20) updatewhereclause=yes name=coilsfcday_coil_no dbname="coilsfcday.coil_no" )
 column=(type=decimal(1) updatewhereclause=yes name=qc_chk1 dbname="coilsfcday.qc_chk1" )
 column=(type=decimal(1) updatewhereclause=yes name=qc_chk2 dbname="coilsfcday.qc_chk2" )
 column=(type=decimal(1) updatewhereclause=yes name=qc_chk3 dbname="coilsfcday.qc_chk3" )
 column=(type=datetime updatewhereclause=yes name=coilsfcday_sfc_date dbname="coilsfcday.sfc_date" )
 column=(type=char(14) updatewhereclause=yes name=coilsfcday_order_no dbname="coilsfcday.order_no" )
 column=(type=long updatewhereclause=yes name=coilsfcday_seq dbname="coilsfcday.seq" )
 retrieve="SELECT coilsliting.order_no
     , coilsliting.seq   
     , swid = convert (decimal (5,1), substring(coilsliting.qa,5,4) + '.' + substring(coilsliting.qa, 10,1))
     , coilsliting.cnt
     , coilsliting.unit_qty
     , thin = convert (decimal (3,2), substring(coilsliting.qa,1,1) + '.' + substring(coilsliting.qa, 2,2))   
     , groupitem.item_name
     , coilsfcday.coil_no 
     , coilsfcday.qc_chk1    
     , coilsfcday.qc_chk2    
     , coilsfcday.qc_chk3 
     , coilsfcday.sfc_date
     , coilsfcday.order_no
     , coilsfcday.seq
  FROM coilorderdet with(nolock) inner join coilsliting with(nolock) on coilorderdet.order_no = coilsliting.order_no 
						   inner join groupitem with(nolock) on coilsliting.item_no = groupitem.item_no
						   left outer join coilsfcday with(nolock) on coilsliting.order_no = coilsfcday.order_no
                                                                        				    and coilsliting.seq = coilsfcday.seq		                        
 WHERE ( coilorderdet.coilorder_order = :as_order_no         ) 
        and ( coilorderdet.order_seq       = :an_order_seq        ) 

/*
  FROM coilsliting  
       , coilorderdet 
       , coilsfcday   
       , groupitem
 WHERE ( coilsliting.item_no          = groupitem.item_no    ) 
   and ( coilorderdet.order_no        = coilsliting.order_no ) 
   and ( coilsliting.order_no        *= coilsfcday.order_no  ) 
   and ( coilsliting.seq             *= coilsfcday.seq       ) 
   and ( coilorderdet.coilorder_order = :as_order_no         ) 
   and ( coilorderdet.order_seq       = :an_order_seq        ) 

*/" arguments=(("as_order_no", string),("an_order_seq", number))  sort="coilsliting_seq A " )
