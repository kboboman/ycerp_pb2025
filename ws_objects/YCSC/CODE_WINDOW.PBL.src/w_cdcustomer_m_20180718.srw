type cb_xls from commandbutton within tabpage_7
integer x = 64
integer y = 8
integer width = 402
integer height = 80
integer taborder = 60
integer textsize = -10
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "엑셀 열기"
end type

event clicked;// 거래처마스터_변경 필드명 전체 가져오기
string ls_type, ls_itemcd, ls_itemnm, ls_bigo, ls_field, ls_rows, ls_width
long   ll_row,  iCol, iRow, iCols

Pointer oldpointer // Declares a pointer variable
oldpointer = SetPointer(HourGlass!)
dw_26.reset()

ls_type = "거래처마스터_변경"
iRow    = 0
DECLARE codemst_item CURSOR FOR  
   SELECT item_cd, item_nm, bigo FROM codemst WHERE type = :ls_type AND use_yn = 'Y' ORDER BY sort;
	 
OPEN codemst_item;
FETCH codemst_item INTO :ls_itemcd, :ls_itemnm, :ls_bigo;
Do While sqlca.sqlcode = 0
	iRow = iRow + 1
	
	ll_row = dw_26.insertrow(0)
	dw_26.object.chk[ll_row]   = "N"   
	dw_26.object.cols[ll_row]  = ls_itemnm
	dw_26.object.field[ll_row] = ls_itemcd
	
   FETCH codemst_item INTO :ls_itemcd, :ls_itemnm, :ls_bigo;
Loop
CLOSE codemst_item;

iCols = long(dw_27.object.datawindow.column.count) + 1
for iCol = 1 to iCols							// dw_27 SEQ, 선택, 코드, 거래처, 사업자번호
	ls_field = dw_27.Describe("#" + String( iCol ) + ".Name")
	choose case lower(ls_field)
		case "seq", "chk", "cust_no", "cust_name"
		case else
			dw_27.Modify( ls_field + ".width=0" )
		   dw_27.Modify( ls_field + ".visible=0" )
	end choose
next

for iRow = 1 to dw_26.rowcount()
	ls_width = "0"
	ls_rows = dw_26.object.field[iRow]
	choose case ls_rows
		case "seq", "chk"
			ls_width = "180"
		case "cust_no"
			ls_width = "250"
		case "cust_name"
			ls_width = "635"
			
		case "salesman"
			ls_width = "310"
			dw_26.object.chk[iRow] = "Y"
		case "collect_ymd"
			ls_width = "310"
			dw_26.object.chk[iRow] = "Y"
		case "level_grade", "credit_level", "price_level"
			ls_width = "300"
			dw_26.object.chk[iRow] = "Y"
			
		case else
			ls_width = "350"
			dw_26.object.chk[iRow] = "Y"
	end choose
	
   dw_27.Modify( ls_rows + "_t.width=" + ls_width )
	dw_27.Modify( ls_rows + ".width="   + ls_width )
   dw_27.Modify( ls_rows + ".visible=1" )
next
	
dw_26.ScrollToRow( 1 )
if dw_26.rowcount() < 1 then return


//
Integer iRet
Long    ll_status
Boolean SWExit = True
	
if IsValid(OleExcel) then DESTROY OleExcel
if IsValid(xlSheet)  then DESTROY xlSheet

mle_1.text = ""
dw_27.reset()

ddlb_sheet.Reset()
cb_import.enabled = false
hpb_1.position    = 0
cb_excute.enabled = false

String ls_filename, named
String defext = ""
String Filter = "Microsoft Excel Files (*.xls*),*.xls*"
iRet = GetFileOpenName("Microsoft Excel Files", ls_filename, named, defext, filter)
if iRet <> 1 then return

if ls_filename <> "" then
	OleExcel = CREATE OleObject
	xlSheet  = CREATE OleObject

	iRet = OleExcel.ConnectToNewObject("excel.application") 
	if iRet <> 0 then DESTROY OleExcel 

	// Visible = True의 경우 엑셀 프로그램이 띄워지며 
	// False인 경우 아이콘화된다. 
	OleExcel.Application.Visible = false //true

	// 엑셀을 로드한 후 Empty Sheet를 연다. 
	OleExcel.WorkBooks.Open(ls_filename) 

	Integer ii, iSheetCount, rownbr
	String  ls_Sheet
	
	iSheetCount = OleExcel.Application.Sheets.Count
	for ii = 1 to iSheetCount
		ls_Sheet = OleExcel.Application.Sheets(ii).Name
		rownbr = tab_1.tabpage_7.ddlb_sheet.AddItem(ls_Sheet)
	next
	
	if iSheetCount > 0 then
		ii_Sheet =  1
		ddlb_sheet.enabled = true
	end if
else
	return
end if

DESTROY xlSheet
DESTROY OleExcel

SetPointer(oldpointer)
dw_26.enabled = false
ddlb_sheet.setfocus()
MessageBox("확인","엑셀 파일의 Sheet를 선택하세요.")

end event

type dw_26 from datawindow within tabpage_7
integer x = 9
integer y = 200
integer width = 850
integer height = 2192
integer taborder = 121
string title = "none"
string dataobject = "d_cdcustomer_msthd"
boolean hscrollbar = true
boolean vscrollbar = true
boolean livescroll = true
borderstyle borderstyle = stylelowered!
end type

event clicked;// 
long   ll_cnt
string ls_chk, ls_field

if row < 1 or row > this.rowcount() then return

dw_26.ScrollToRow( row )

choose case dwo.name
	case "chk"
		ll_cnt  = this.object.chk_cnt[1]
		if ll_cnt = 0 then
			cbx_all.checked = false
		elseif ll_cnt = this.rowcount() then
			cbx_all.checked = true
		end if

		ls_field = this.object.field[row]
		if isnull(ls_field) or ls_field = "" then
		else
			ls_chk  = this.object.chk[row]
			choose case ls_chk 
				case "Y"
					dw_27.Modify( ls_field + ".visible=0" )
				case "N"
					dw_27.Modify( ls_field + ".visible=1" )
				end choose				
		end if
end choose

end event

