event itemerror;string ls_data

CHOOSE CASE dwo.name
//	CASE 'issue_loc'
//		this.object.issue_lot[row] = ls_data
	CASE 'item_no'
		setnull(ls_data)
		this.object.item_no[row] = ls_data
		this.object.qa[row] = ls_data
		this.object.uom1[row] = ls_data
		this.object.groupitem_item_name1[row] = ls_data
END CHOOSE

return 2
end event

