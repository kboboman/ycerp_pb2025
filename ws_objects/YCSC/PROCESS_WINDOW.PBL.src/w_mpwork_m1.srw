string text = "재고이력검색"
end type

event clicked;long ll_row

ll_row = dw5.getrow()
if ll_row < 1 then return

gs_where lst_where

int ls_a
ls_a = dw5.GetClickedColumn()

lst_where.str1 = trim(dw5.object.item_no[ll_row])
lst_where.str2 = trim(dw5.object.qa[ll_row])
lst_where.str3 = trim(dw_2.object.loc_no[1])
lst_where.name = trim(dw5.object.item_item_name[ll_row])

openwithparm(w_whinaudit_w, lst_where)
w_whinaudit_w.WindowState = Normal!
