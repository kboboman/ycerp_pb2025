$PBExportHeader$d_osareaytotal_r.srd
$PBExportComments$사업장별 년 매출 총괄현황(2003/03/26,이인호)
release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=216 color="536870912" )
summary(height=76 color="536870912" )
footer(height=0 color="536870912" )
detail(height=84 color="536870912" )
table(column=(type=char(2) updatewhereclause=yes name=area dbname="area" values="전체	%/화곡	H/시화	S/반월	B/" )
 column=(type=long updatewhereclause=yes name=year dbname="year" )
 column=(type=long updatewhereclause=yes name=month dbname="month" )
 column=(type=decimal(4) updatewhereclause=yes name=amount dbname="amount" )
 column=(type=decimal(4) updatewhereclause=yes name=vat dbname="vat" )
 column=(type=decimal(4) updatewhereclause=yes name=total dbname="total" )
 retrieve="select area= substring(aroiinv_no,1, 1),
		 year = datepart(year, oi_date), 
		 month = datepart(month,oi_date),
		 amount = sum(aroiinv_cash - discount),
		 vat = sum(aroiinv_rate),
	    total =  sum(aroiinv_cash - discount) + sum(aroiinv_rate)
from aroiinv 
where substring(aroiinv_no,1, 1) like :as_area
and datepart(year,oi_date) = :ai_year
and delete_flag = 'N'
group by substring(aroiinv_no,1, 1), datepart(year, oi_date), datepart(month,oi_date)" arguments=(("as_area", string),("ai_year", number))  sort="area D year A month A " )
group(level=1 header.height=0 trailer.height=76 by=("area" ) header.color="536870912" trailer.color="15780518" )
column(band=detail id=1 alignment="2" tabsequence=32766 border="0" color="0" x="0" y="4" height="60" width="311" format="[general]"  name=area ddlb.limit=0 ddlb.allowedit=no ddlb.case=any  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" font.underline="1" background.mode="1" background.color="536870912" )
