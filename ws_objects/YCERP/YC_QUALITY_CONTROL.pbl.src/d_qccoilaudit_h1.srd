$PBExportHeader$d_qccoilaudit_h1.srd
$PBExportComments$스리팅중간검사성적서(2005/06/04,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=92 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=sfc_date dbname="coilsfcday.sfc_date" )
 column=(type=char(14) updatewhereclause=yes name=order_no dbname="coilsfcday.order_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="coilmst.qa" )
 column=(type=char(20) updatewhereclause=yes name=w_coil_no dbname="coilsfcday.w_coil_no" )
 column=(type=decimal(1) updatewhereclause=yes name=wid dbname="coilsfcday.wid" )
 column=(type=long updatewhereclause=yes name=cnt dbname="coilsfcday.cnt" )
 column=(type=decimal(1) updatewhereclause=yes name=qc_chk1 dbname="coilsfcday.qc_chk1" )
 column=(type=decimal(1) updatewhereclause=yes name=qc_chk2 dbname="coilsfcday.qc_chk2" )
 column=(type=decimal(1) updatewhereclause=yes name=qc_chk3 dbname="coilsfcday.qc_chk3" )
 column=(type=char(10) updatewhereclause=yes name=wname dbname="qccoilchk.wname" )
 column=(type=long updatewhereclause=yes name=coilorderdet_tot_qty dbname="coilorderdet.tot_qty" )
 column=(type=char(10) updatewhereclause=yes name=coilsfcday_wc_no dbname="coilsfcday.wc_no" )
 retrieve="  SELECT coilsfcday.sfc_date,   
         coilsfcday.order_no,   
         coilmst.qa,   
         coilsfcday.w_coil_no,   
         coilsfcday.wid,   
         coilsfcday.cnt,   
         coilsfcday.qc_chk1,   
         coilsfcday.qc_chk2,   
         coilsfcday.qc_chk3,   
         qccoilchk.wname,
			coilorderdet.tot_qty,
      coilsfcday.wc_no
    FROM coilsfcday with(nolock) left outer join	coilmst with(nolock) on coilsfcday.w_coil_no = coilmst.coil_no and coilsfcday.wloc_no = coilmst.loc_no
			                            left outer join qccoilchk with(nolock) on coilsfcday.wc_no = qccoilchk.wc_no and coilsfcday.sfc_date = qccoilchk.sfc_date
                                  left outer join coilorderdet with(nolock) on coilsfcday.order_no = coilorderdet.order_no and coilsfcday.sfc_date = coilorderdet.order_date
   WHERE ( coilsfcday.sheet <> 'L' ) AND
			            ( coilsfcday.wc_no = :as_wc ) AND  
                  ( coilsfcday.sfc_date between :ad_start and :ad_end )     
/*
    FROM coilsfcday,   
			coilmst,
			qccoilchk ,
			coilorderdet
   WHERE ( coilsfcday.w_coil_no *= coilmst.coil_no ) AND  
         ( coilsfcday.wloc_no *= coilmst.loc_no ) AND  
         ( coilsfcday.wc_no *= qccoilchk.wc_no  ) AND  
         ( coilsfcday.sfc_date *= qccoilchk.sfc_date ) AND
			( coilsfcday.order_no *= coilorderdet.order_no ) and
			( coilsfcday.sfc_date *= coilorderdet.order_date ) and
			( coilsfcday.sheet <> 'L' ) AND
			( coilsfcday.wc_no = :as_wc ) AND  
         ( coilsfcday.sfc_date between :ad_start and :ad_end )     
*/" arguments=(("as_wc", string),("ad_start", date),("ad_end", date))  sort="sfc_date A order_no A wid A " )
group(level=1 header.height=0 trailer.height=0 by=("sfc_date" , "order_no" ) newpage=yes resetpagecount=yes header.color="536870912" trailer.color="536870912" )
