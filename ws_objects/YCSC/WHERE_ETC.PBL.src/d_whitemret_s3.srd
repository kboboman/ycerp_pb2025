table(column=(type=datetime update=yes updatewhereclause=yes key=yes name=work_date dbname="itemhand.work_date" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=seq_no dbname="itemhand.seq_no" )
 column=(type=char(60) update=yes updatewhereclause=yes name=item_name dbname="itemhand.item_name" )
 column=(type=char(40) update=yes updatewhereclause=yes name=qa dbname="itemhand.qa" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="itemhand.uom" initial="EA" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=pre_qty dbname="itemhand.pre_qty" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=rcpt_qty dbname="itemhand.rcpt_qty" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=issue_qty dbname="itemhand.issue_qty" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=qoh dbname="itemhand.qoh" initial="0" )
 column=(type=char(60) update=yes updatewhereclause=yes name=rem dbname="itemhand.rem" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"itemhand~" ) COLUMN(NAME=~"itemhand.work_date~") COLUMN(NAME=~"itemhand.seq_no~") COLUMN(NAME=~"itemhand.item_name~") COLUMN(NAME=~"itemhand.qa~") COLUMN(NAME=~"itemhand.uom~") COLUMN(NAME=~"itemhand.pre_qty~") COLUMN(NAME=~"itemhand.rcpt_qty~") COLUMN(NAME=~"itemhand.issue_qty~") COLUMN(NAME=~"itemhand.qoh~") COLUMN(NAME=~"itemhand.rem~")WHERE(    EXP1 =~"itemhand.work_date~"   OP =~"=~"    EXP2 =~":ad_date~" ) ) ARG(NAME = ~"ad_date~" TYPE = date) " update="itemhand" updatewhere=1 updatekeyinplace=no arguments=(("ad_date", date)) )
