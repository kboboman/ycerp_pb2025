$PBExportHeader$d_mpdatercpt_t.srd
$PBExportComments$기간별 입고 조회_상세(1998/5/11,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=inaudit_inaudit_time dbname="inaudit.inaudit_time" )
 column=(type=char(2) updatewhereclause=yes name=inaudit_inaudit_type dbname="inaudit.inaudit_type" )
 column=(type=char(10) updatewhereclause=yes name=inaudit_inaudit_item dbname="inaudit.inaudit_item" )
 column=(type=char(60) updatewhereclause=yes name=item_item_name dbname="item.item_name" )
 column=(type=char(20) updatewhereclause=yes name=inaudit_qa dbname="inaudit.qa" )
 column=(type=char(10) updatewhereclause=yes name=inaudit_loc_no dbname="inaudit.loc_no" )
 column=(type=decimal(2) updatewhereclause=yes name=inaudit_rcpt_qty dbname="inaudit.rcpt_qty" )
 column=(type=char(2) updatewhereclause=yes name=item_uom dbname="item.uom" )
 column=(type=char(1) updatewhereclause=yes name=item_source dbname="item.source" values="구매품	B/재공품	M/완재품	W/" )
 column=(type=char(20) updatewhereclause=yes name=iotype_remarks dbname="iotype.remarks" )
 column=(type=char(30) updatewhereclause=yes name=location_loc_name dbname="location.loc_name" )
 column=(type=datetime updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=datetime updatewhereclause=yes name=edate dbname="edate" )
 retrieve="  SELECT inaudit.inaudit_time,   
         inaudit.inaudit_type,   
         inaudit.inaudit_item,   
         item.item_name,   
         inaudit.qa,   
         inaudit.loc_no,   
         inaudit.rcpt_qty,   
         item.uom,   
         item.source,   
         iotype.remarks,   
         location.loc_name,   
         sdate = convert(smalldatetime, :as_from, 111),   
         edate = convert(smalldatetime, :as_to, 111)  
    FROM inaudit,   
         item,   
         iotype,   
         location  
   WHERE ( inaudit.inaudit_type = iotype.inaudit_type ) and  
         ( inaudit.loc_no       = location.loc_no     ) and  
         ( inaudit.inaudit_item = item.item_no        ) and  
         ( inaudit.qa           = item.qa             ) and  
         ( ( inaudit.inaudit_type    like :as_type ) AND  
           ( inaudit.loc_no          like :as_loc  ) AND  
           ( inaudit.inaudit_date between :as_from and :as_to ) 
         )
" arguments=(("as_type", string),("as_loc", string),("as_from", date),("as_to", date))  sort="inaudit_inaudit_time A " )
