compute(band=detail alignment="1" expression=" if(  aroiinv_aroiinv_rate <> 0 or aroiinv_aroiinv_cash = 0,  aroiinv_ship_cost  * 0.1 , 0)"border="0" color="0" x="3040" y="4" height="60" width="320" format="#,##0" html.valueishtml="0"  name=tot_ship visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
