table(column=(type=datetime updatewhereclause=yes name=inaudit_date dbname="inaudit_date" )
 column=(type=char(20) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(20) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=number updatewhereclause=yes name=rcpt_qty dbname="rcpt_qty" )
 column=(type=number updatewhereclause=yes name=issue_qty dbname="issue_qty" )
 column=(type=number updatewhereclause=yes name=qoh dbname="qoh" )
 retrieve="  SELECT inaudit.inaudit_time,   
         inaudit.inaudit_type,   
         inaudit.inaudit_item,   
         inaudit.qa,   
         inaudit.loc_no,   
         inaudit.rcpt_qty,   
         inaudit.destination,   
         e.cust_name,
         inaudit.issue_qty,   
         inaudit.cost,   
         inaudit_date = convert(char(10),inaudit.inaudit_date,111),   
         inaudit.order_no,   
         inaudit.serial_id,   
         inaudit.rem,   
         inaudit.unit_qty,   
         inaudit.cnt,   
         iotype.remarks,   
         item.item_name,   
         location.loc_name,   
         item.uom,   
         item.source,   
         item.qoh  
    FROM inaudit   
       , item   
       , iotype   
       , location
       , (
          SELECT cust_no, cust_name FROM customer
          UNION
          SELECT loc_no,  loc_name  FROM location
         ) e  
   WHERE ( inaudit.qa               = item.qa             ) and  
         ( inaudit.inaudit_item     = item.item_no        ) and  
         ( inaudit.inaudit_type     = iotype.inaudit_type ) and  
         ( inaudit.loc_no           = location.loc_no     ) and  
         ( inaudit.destination      = e.cust_no           ) and  
         ( ( inaudit.inaudit_item    like :as_itemno ) AND  
           ( inaudit.qa              like :as_qa     ) AND  
           ( item.source             like :as_source ) AND  
           ( inaudit.loc_no          like :as_loc    ) AND  
           ( convert(char(10),inaudit.inaudit_date,111) between :as_from and :as_to ) 
         )    
" arguments=(("as_itemno", string),("as_qa", string),("as_source", string),("as_loc", string),("as_from", string),("as_to", string))  sort="inaudit_date A item_name A qa A uom A " )
