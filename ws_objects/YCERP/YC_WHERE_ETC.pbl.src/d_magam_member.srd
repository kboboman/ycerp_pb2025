$PBExportHeader$d_magam_member.srd
$PBExportComments$매출할인 관리(다중)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=char(30) updatewhereclause=yes name=team_name dbname="team_name" )
 column=(type=char(20) updatewhereclause=yes name=user_id dbname="user_id" )
 column=(type=char(50) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(13) updatewhereclause=yes name=phone dbname="phone" )
 retrieve="SELECT  a.team_name,
                a.user_id,
                a.user_name,
                a.phone
FROM 
(
        select  (CASE WHEN b.area_no = 'B0001' THEN 'YSP' 
                               WHEN b.area_no = 'H0001' THEN '통합운영실'
                                ELSE  c.team_name end) team_name, a.item_cd user_id, a.item_nm user_name, b.phone
        from codemst a with(nolock) inner join login b with(nolock) on a.item_cd = b.user_id
                                LEFT OUTER JOIN team  c with(nolock)    ON b.team_code = c.team_code
        where a.type = '판매수주마감관리_사용가능자'
	   and b.area_no <> 'H0001'
        and a.use_yn = 'Y'
) a
order by a.team_name, a.user_name
" )
