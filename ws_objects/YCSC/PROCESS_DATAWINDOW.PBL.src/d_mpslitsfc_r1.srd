table(column=(type=datetime updatewhereclause=yes name=coilsfcday_sfc_date dbname="coilsfcday.sfc_date" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(20) updatewhereclause=yes name=coilsfcday_qa dbname="coilsfcday.qa" )
 column=(type=long updatewhereclause=yes name=coilsfcday_unit_qty dbname="coilsfcday.unit_qty" )
 column=(type=long updatewhereclause=yes name=coilsfcday_cnt dbname="coilsfcday.cnt" )
 column=(type=datetime updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=datetime updatewhereclause=yes name=edate dbname="edate" )
 column=(type=char(20) updatewhereclause=yes name=coilsfcday_coil_no dbname="coilsfcday.coil_no" )
 column=(type=char(10) updatewhereclause=yes name=wc_work_name dbname="wc.work_name" )
 retrieve="  SELECT coilsfcday.sfc_date,   
         groupitem.item_name,   
         coilsfcday.qa,   
         coilsfcday.unit_qty,   
         coilsfcday.cnt,   
         sdate = convert(smalldatetime, :ad_start, 111),   
         edate = convert(smalldatetime, :ad_end, 111),   
         coilsfcday.coil_no,   
         wc.work_name  
    FROM coilsfcday inner join groupitem on coilsfcday.item_no = groupitem.item_no
                                  left outer join wc on  coilsfcday.wc_no = wc.work_no
   WHERE ( coilsfcday.item_no = groupitem.item_no ) and  
                  ( ( coilsfcday.sfc_date between :ad_start and :ad_end ) )   
" arguments=(("ad_start", date),("ad_end", date))  sort="coilsfcday_sfc_date A groupitem_item_name A mid( coilsfcday_qa, 5,6) A coilsfcday_qa A coilsfcday_unit_qty A " )
