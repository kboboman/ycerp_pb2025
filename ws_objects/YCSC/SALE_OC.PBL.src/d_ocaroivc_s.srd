table(column=(type=char(12) updatewhereclause=yes key=yes name=vc_no dbname="aroivc.vc_no" )
 column=(type=decimal(4) updatewhereclause=yes name=amount dbname="aroivc.amount" )
 column=(type=char(1) updatewhereclause=yes name=open_close dbname="aroivc.open_close" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"aroivc~" ) COLUMN(NAME=~"aroivc.vc_no~") COLUMN(NAME=~"aroivc.amount~") COLUMN(NAME=~"aroivc.open_close~")WHERE(    EXP1 =~"aroivc.cust_no~"   OP =~"=~"    EXP2 =~":as_cust_no~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"aroivc.delete_key~"   OP =~"=~"    EXP2 =~"'N'~" ) ) ARG(NAME = ~"as_cust_no~" TYPE = string) " update="aroivc" updatewhere=0 updatekeyinplace=no arguments=(("as_cust_no", string))  sort="vc_no D " )
