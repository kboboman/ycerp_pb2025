 column=(type=char(1) updatewhereclause=yes name=c_div dbname="c_div" )
 column=(type=long updatewhereclause=yes name=rowseq dbname="rowseq" )
 retrieve="  SELECT bdinfodet.seq,   
         bdinfodet.person,   
         bdinfodet.floors,   
         bdinfodet.city,   
         bdinfodet.master,   
         bdinfodet.designoffice,   
         bdinfodet.spec,   
         bdinfodet.workarea,   
         bdinfodet.buildingcom,   
         bdinfodet.bulidingphone,   
         bdinfodet.predate,   
         bdinfodet.completiondate,   
         bdinfodet.status,   
         bdinfodet.build_no,   
         bdinfodet.project,   
         bdinfodet.quantity,   
         bdinfodet.square,   
         bdinfodet.std_chk,   
         bdinfodet.spec2,   
         bdinfodet.spec3,   
         bdinfodet.unit,   
         bdinfodet.div,   
         bdinfodet.salequantity,   
         bdinfodet.dong,   
         bdinfodet.designman,   
         bdinfodet.designphone,   
         bdinfodet.buildingman,   
         bdinfodet.builder,   
         bdinfodet.builderman,   
         bdinfodet.builderphone,   
         bdinfodet.fixeddate,   
         bdinfodet.fixedflag,   
         bdinfodet.rem,   
         bdinfodet.design_prog,   
         bdinfodet.com_prog,   
         bdinfodet.sale_prog,   
         bdinfodet.buildquantity,   
         bdinfodet.makedate,   
         bdinfodet.dperson,   
         bdinfodet.ddiv,   
         bdinfodet.dexpdate,   
         bdinfodet.cperson,   
         bdinfodet.cdiv,   
         bdinfodet.cexpdate,   
         bdinfodet.bperson,   
         bdinfodet.bdiv,   
         bdinfodet.bexpdate,   
         bdinfodet.sperson,   
         bdinfodet.sdiv,   
         bdinfodet.sexpdate,   
         bdinfodetprog.prog_date,   
         bdinfodetprog.emp_no,   
         bdinfodetprog.rem,
         '' c_div, 0 rowseq  
    FROM   bdinfodet with(nolock) inner join bdinfo with(nolock) on bdinfodet.build_no = bdinfo.build_no
                                                        left outer join bdinfodetprog with(nolock) on bdinfodet.build_no = bdinfodetprog.build_no and bdinfodet.seq = bdinfodetprog.seq
   WHERE 
         ( ( bdinfo.build_no = :arg_build_no ) AND  
         ( bdinfodet.std_chk = '1' ) AND  
         ( bdinfodet.div like :as_div ) AND  
         ( bdinfodet.spec like :as_spec ) AND  
         ( bdinfodet.project like :as_project ) AND  
         ( bdinfodet.sale_prog like :as_flag ) AND  
         ( bdinfodet.fixeddate between :ad_date1 and :ad_date2 ) AND  
         ( bdinfodet.design_prog like :as_dprog ) AND  
         ( bdinfodet.com_prog like :as_cprog ) AND  
         ( bdinfodet.city like :as_city ) AND    
         ( ( bdinfodet.person like :as_person ) OR  
         ( bdinfodet.dperson like :as_dperson ) OR  
         ( bdinfodet.cperson like :as_cperson ) OR  
         ( bdinfodet.bperson like :as_bperson ) OR  
         ( bdinfodet.sperson like :as_sperson ) ) AND  
         ( ( bdinfodet.div like :as_div ) OR  
         ( bdinfodet.ddiv like :as_ddiv ) OR  
         ( bdinfodet.cdiv like :as_cdiv ) OR  
         ( bdinfodet.bdiv like :as_bdiv ) OR  
         ( bdinfodet.sdiv like :as_sdiv ) ) ) AND    
         ( bdinfodet.organcd like :as_organcd ) AND
         ( bdinfodet.designoffice like :as_dcode )     
" arguments=(("arg_build_no", string),("as_div", string),("as_spec", string),("as_project", string),("as_flag", string),("ad_date1", date),("ad_date2", date),("as_dprog", string),("as_cprog", string),("as_city", string),("as_person", string),("as_dperson", string),("as_ddiv", string),("as_cperson", string),("as_cdiv", string),("as_bperson", string),("as_bdiv", string),("as_sperson", string),("as_sdiv", string),("as_organcd", string),("as_dcode", string))  sort="c_div A bdinfodet_project A " )
group(level=1 header.height=0 trailer.height=8 by=("c_div" ) header.color="536870912" trailer.color="536870912" )
