footer(height=0 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=do_no dbname="do_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="seq_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=char(2) updatewhereclause=yes name=com_uom dbname="com_uom" )
 column=(type=decimal(2) updatewhereclause=yes name=order_qty dbname="order_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=price dbname="price" )
 column=(type=long updatewhereclause=yes name=acc_qty dbname="acc_qty" )
 column=(type=char(10) updatewhereclause=yes name=loc_no dbname="loc_no" )
 column=(type=char(50) updatewhereclause=yes name=rem dbname="rem" )
 column=(type=char(4) updatewhereclause=yes name=sale_cust_no dbname="cust_no" )
 column=(type=char(11) updatewhereclause=yes name=sale_scene_code dbname="scene_code" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene_desc" )
 column=(type=decimal(4) updatewhereclause=yes name=qoh dbname="qoh" )
 retrieve="  SELECT do_no   = dodet.do_no         
       , seq_no  = dodet.seq_no        
       , item_no = dodet.item_no       
       , qa      = dodet.qa            
       , uom     = dodet.uom     
       , com_uom = (case groupitem.uom 
                       when 'M'  then 'EA'
                       when 'M2' then 'EA'
                       else groupitem.uom
                    end)
       , order_qty  = dodet.ship_qty       
       , price      = dodet.price           
       , acc_qty    = 0         
       , loc_no     = dodet.loc_no          
       , rem        = dodet.rem             
       , cust_no    = do.cust_no            
       , scene_code = do.spot_code         
       , item_name  = groupitem.item_name   
       , cust_name  = customer.cust_name    
       , scene_desc = scene.scene_desc    
       , qoh        = itemloc.qoh
  FROM dodet   inner join  do on dodet.do_no = do.do_no
                           inner join groupitem on dodet.item_no    = groupitem.item_no      
                           inner join customer on do.cust_no       = customer.cust_no
                           left outer join scene on do.spot_code = scene.scene_code
                           left outer join itemloc on dodet.item_no = itemloc.item_no and dodet.qa = itemloc.qa
										    and itemloc.loc_no   = :as_loc  
   WHERE dodet.do_no      = :as_dono
/*
    FROM dodet    
       , groupitem
       , do       
       , customer 
       , scene     
       , itemloc  
   WHERE ( dodet.do_no      = do.do_no     )   
     AND ( dodet.item_no    = groupitem.item_no ) 
     AND ( do.spot_code    *= scene.scene_code  )    
     AND ( do.cust_no       = customer.cust_no  )  
     AND ( dodet.item_no   *= itemloc.item_no   ) 
     AND ( dodet.qa        *= itemloc.qa        ) 
     AND ( itemloc.loc_no   = :as_loc           ) 
     AND ( dodet.do_no      = :as_dono          )
*/" arguments=(("as_dono", string),("as_loc", string))  sort="seq_no A " )
