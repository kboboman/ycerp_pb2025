 retrieve="SELECT scene.scene_code
     , scene.scene_desc
     , scene.scene_addr
     , scene.scene_tel     
  FROM scene    
 WHERE scene.cust_no  LIKE :as_custno
" update="scene" updatewhere=0 updatekeyinplace=no arguments=(("as_custno", string))  sort="scene_desc A " )
