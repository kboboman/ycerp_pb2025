	case "plan_qty"
		ls_col  = "계획량"
		ls_text = string(this.object.plan_qty[row])
	case "obj_24092413"
		ls_col  = "환산수량"
		ls_text = string(this.object.obj_24092413[row])
	case "dodet_ship_qty"
