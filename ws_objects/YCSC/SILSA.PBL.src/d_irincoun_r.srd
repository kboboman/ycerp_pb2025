table(column=(type=char(30) updatewhereclause=yes name=location_loc_name dbname="location.loc_name" )
 column=(type=char(10) updatewhereclause=yes name=itemloc_item_no dbname="itemloc.item_no" )
 column=(type=char(20) updatewhereclause=yes name=itemloc_qa dbname="itemloc.qa" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(4) updatewhereclause=yes name=ineoym_cyear dbname="ineoym.cyear" )
 column=(type=char(2) updatewhereclause=yes name=ineoym_cmon dbname="ineoym.cmon" )
 column=(type=decimal(4) updatewhereclause=yes name=ineoym_qoh dbname="ineoym.qoh" )
 column=(type=char(2) updatewhereclause=yes name=groupitem_uom dbname="uom" )
 retrieve="  SELECT location.loc_name,   
         itemloc.item_no,   
         itemloc.qa,   
         groupitem.item_name,   
         ineoym.cyear,   
         ineoym.cmon,   
         ineoym.qoh,   
         uom = (case groupitem.uom when 'M'  then 'EA'
						  					 when 'M2' then 'EA'
											 else groupitem.uom
				   end)  
    FROM itemloc left outer join ineoym on itemloc.item_no = ineoym.item_no 
                                            and itemloc.qa = ineoym.qa 
                                            and itemloc.loc_no = ineoym.loc_no
								  and ineoym.cyear = :as_year
								  and ineoym.cmon = :as_mon
                             inner join groupitem on itemloc.item_no = groupitem.item_no
                             inner join location on itemloc.loc_no = location.loc_no
   WHERE ( ( itemloc.loc_no = :as_loc  ) AND  
                    ( itemloc.item_no like :as_code ) AND  
                    ( groupitem.item_name like :as_name ) AND  
                    ( itemloc.item_no < 'PZZZ'  ) )
" arguments=(("as_loc", string),("as_year", string),("as_mon", string),("as_code", string),("as_name", string)) )
