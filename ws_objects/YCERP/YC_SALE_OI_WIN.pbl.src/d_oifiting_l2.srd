table(column=(type=char(4) updatewhereclause=yes name=cat dbname="cat" )
 column=(type=char(14) updatewhereclause=yes name=order_no dbname="order_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="seq_no" )
 column=(type=char(10) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(11) updatewhereclause=yes name=scene_code dbname="scene_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=char(50) updatewhereclause=yes name=rem dbname="rem" )
 column=(type=decimal(2) updatewhereclause=yes name=order_qty dbname="order_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=rlse_qty dbname="rlse_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=jan_qty dbname="jan_qty" )
 retrieve="SELECT cat        = a.cat
     , order_no   = a.order_no
     , seq_no     = a.seq_no
     , cust_no    = a.cust_no
     , cust_name  = a.cust_name
     , scene_code = a.scene_code
     , scene_desc = a.scene_desc
     , item_no    = a.item_no
     , item_name  = a.item_name
     , qa         = a.qa
     , uom        = a.uom
     , rem        = a.rem
     , order_qty  = a.order_qty
     , rlse_qty   = a.rlse_qty
     , jan_qty    = a.jan_qty
  FROM (
       /* 출고요청 */
       SELECT DISTINCT cat = '출하'
            , order_no     = a.order_no
            , seq_no       = a.seq_no
            , cust_no      = c.cust_no 
            , cust_name    = c.cust_name 
            , scene_code   = d.scene_code
            , scene_desc   = d.scene_desc
            , item_no      = a.item_no
            , item_name    = g.item_name
            , qa           = a.qa
            , uom          = a.uom
            , rem          = a.rem
            , order_qty    = a.order_qty
            , rlse_qty     = a.rlse_qty
            , jan_qty      = a.order_qty - a.rlse_qty
         FROM saledet A
              LEFT OUTER JOIN sale      B ON a.order_no   = b.order_no
              LEFT OUTER JOIN customer  C ON b.cust_no    = c.cust_no
              LEFT OUTER JOIN scene     D ON b.scene_code = d.scene_code
              LEFT OUTER JOIN groupitem G ON a.item_no    = g.item_no
        WHERE ( a.order_no    = :as_orderno )
          AND ( b.cust_no     = :as_custno  )
          AND ( b.scene_code  = :as_scene   )

       UNION ALL      
       /* 물품이동 */
       SELECT DISTINCT cat = '이동'
            , ask_no       = ask_det.ask_no
            , seq_no       = ask_det.seq_no
            , t_area       = ask_head.t_area
            , area_name    = area.area_name
            , ask_loc      = ask_head.ask_loc
            , loc_name     = location.loc_name
            , item_no      = ask_det.item_no
            , item_name    = groupitem.item_name
            , qa           = ask_det.qa
            , uom          = groupitem.uom
            , rem          = ask_det.rem
            , ask_qty      = ask_det.ask_qty
            , rlse_qty     = rlse_qty
            , jan_qty      = ask_det.ask_qty - rlse_qty
         FROM ask_head
              LEFT OUTER JOIN ask_det   ON ask_head.ask_no  = ask_det.ask_no
              LEFT OUTER JOIN area      ON ask_head.t_area  = area.area_no
              LEFT OUTER JOIN location  ON ask_head.ask_loc = location.loc_no
              LEFT OUTER JOIN groupitem ON ask_det.item_no  = groupitem.item_no
        WHERE ( ask_head.f_area    = :as_area    )
          AND ( ask_head.ask_no    = :as_orderno )
       ) A
" arguments=(("as_area", string),("as_custno", string),("as_scene", string),("as_orderno", string))  sort="seq_no A " )
