event mousemove;int li_x,li_y

li_x = this.x 
li_y = this.y + 156

f_usetips(st_tips,"파일저장",parent, li_x, li_y)

end event

event clicked;// ELC.COM의 UPLOAD 기준으로 작업함.
string  ls_Docname, ls_Named, ls_ExpandName, ls_orderno
integer ls_Value,   li_Pos,   li_value
long    ll_cnt
DataWindow dwxls

ls_orderno  = dw3.object.order_no[1]
dw_16.retrieve( ls_orderno )

dwxls  = dw_16

//==GF_USEPROGRAM(프로그램 사용현황)==============================================================
GF_USEPROGRAM( gs_userid, Parent.ClassName(), "E", string(gf_today(),'yyyy/mm/dd'), Parent.Title )
//================================================================================================
if dwxls.rowcount() > 0 then
	ls_DocName  = GetCurrentDirectory() + "\" + ls_orderno + ".csv"
	
	li_value = GetFileSaveName("Select File", ls_Docname, ls_Named, "CSV", "CSV(쉽표로 분리), *.CSV,")
	if li_value = 1 then
		li_Pos   = PosA(ls_Named, ".")
		ls_ExpandName = MidA(ls_Named, li_Pos + 1, LenA(ls_Named)- li_Pos)
		if ls_ExpandName = "csv" OR ls_ExpandName = "CSV" then
			dwxls.SaveAs(ls_DocName, CSV!, TRUE)
			MessageBox("확인","작업완료")
		end if
	end if
end if	

end event

