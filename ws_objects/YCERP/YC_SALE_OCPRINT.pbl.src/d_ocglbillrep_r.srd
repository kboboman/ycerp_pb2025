footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=glbill_close_date dbname="glbill.close_date" )
 column=(type=char(1) updatewhereclause=yes name=glbill_bill_class dbname="glbill.bill_class" values="받을어음	R/지급어음	P/교환어음	C/만기어음	E/부도어음	D/" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=datetime updatewhereclause=yes name=glbill_start_date dbname="glbill.start_date" )
 column=(type=char(20) updatewhereclause=yes name=glbill_bill_area dbname="glbill.bill_area" )
 column=(type=decimal(0) updatewhereclause=yes name=glbill_bill_amount dbname="glbill.bill_amount" )
 column=(type=char(20) updatewhereclause=yes name=glbill_draft dbname="glbill.draft" )
 column=(type=datetime updatewhereclause=yes name=glbill_set_date dbname="glbill.set_date" )
 column=(type=char(20) updatewhereclause=yes name=bank_bank_name dbname="bank.bank_name" )
 column=(type=char(12) updatewhereclause=yes name=glbill_bill_no dbname="glbill.bill_no" )
 column=(type=char(1) updatewhereclause=yes name=glbill_set_flag dbname="glbill.set_flag" )
 column=(type=char(2) updatewhereclause=yes name=vc_type2 dbname="glbill.vc_type2" )
 retrieve="  SELECT glbill.close_date
       , glbill.bill_class
       , customer.cust_name
       , glbill.start_date
       , glbill.bill_area
       , glbill.bill_amount
       , glbill.draft
       , glbill.set_date
       , bank.bank_name
       , glbill.bill_no
       , glbill.set_flag
       , glbill.vc_type2  
    FROM customer
       , glbill
       , bank  
   WHERE ( glbill.cust_no   = customer.cust_no ) 
     AND ( glbill.bank_code = bank.bank_code   ) 
     AND ( glbill.draft  LIKE :as_draft        ) 
     AND ( glbill.close_date  BETWEEN :as_sdate AND :as_edate )
" arguments=(("as_draft", string),("as_sdate", string),("as_edate", string))  sort="glbill_close_date D glbill_bill_no A " )
