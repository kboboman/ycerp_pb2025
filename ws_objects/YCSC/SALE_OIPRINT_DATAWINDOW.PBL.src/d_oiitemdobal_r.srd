$PBExportHeader$d_oiitemdobal_r.srd
$PBExportComments$제품별 제품출고및 미출고보고서(1998/5/14,성삼지)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=408 color="536870912" )
summary(height=0 color="536870912" )
footer(height=4 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(10) updatewhereclause=yes name=saledet_item_no dbname="saledet.item_no" )
 column=(type=char(20) updatewhereclause=yes name=saledet_qa dbname="saledet.qa" )
 column=(type=char(2) updatewhereclause=yes name=saledet_uom dbname="saledet.uom" )
 column=(type=datetime updatewhereclause=yes name=sale_due_date dbname="sale.due_date" initial=" " )
 column=(type=char(14) updatewhereclause=yes name=sale_order_no dbname="sale.order_no" initial=" " )
 column=(type=long updatewhereclause=yes name=saledet_seq_no dbname="saledet.seq_no" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_order_qty dbname="saledet.order_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_rlse_qty dbname="saledet.rlse_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=not_issue dbname="not_issue" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene.scene_desc" )
 column=(type=char(20) updatewhereclause=yes name=customer_bus_cord dbname="customer.bus_cord" )
 column=(type=char(20) updatewhereclause=yes name=customer_bus_rep dbname="customer.bus_rep" )
 column=(type=char(30) updatewhereclause=yes name=customer_industry_code dbname="customer.industry_code" )
 column=(type=char(4) updatewhereclause=yes name=sta dbname="sta" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_acc_qty dbname="saledet.acc_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=saledet_price dbname="saledet.price" )
 retrieve="  SELECT customer.cust_name,   
         saledet.item_no,   
         saledet.qa,   
         saledet.uom,   
         sale.due_date,   
         sale.order_no,   
         saledet.seq_no,   
         saledet.order_qty,
         saledet.rlse_qty,
			not_issue = dbo.uf_getqty( saledet.item_no, saledet.qa, saledet.uom, saledet.order_qty - saledet.rlse_qty),
         groupitem.item_name,   
         scene.scene_desc,   
         customer.bus_cord,   
         customer.bus_rep,   
         customer.industry_code,
			sta = DBO.uf_getsalestatus(sale.order_no, saledet.seq_no),
			saledet.acc_qty,
			saledet.price
    FROM sale,   
         saledet,   
         customer,
			scene,   
         groupitem  
   WHERE ( sale.order_no = saledet.order_no ) and  
         ( sale.cust_no = customer.cust_no ) and  
         ( sale.scene_code *= scene.scene_code ) and  
         ( groupitem.item_no = saledet.item_no ) and  
         ( ( saledet.order_qty <> saledet.rlse_qty ) )    
"  sort="saledet_item_no A saledet_qa A sale_due_date A customer_cust_name A scene_scene_desc A sale_order_no A saledet_seq_no A " )
group(level=1 header.height=72 trailer.height=80 by=("saledet_item_no" ) header.color="536870912" trailer.color="536870912" )
group(level=2 header.height=0 trailer.height=80 by=("saledet_item_no" , "left(saledet_qa,13)" ) header.color="536870912" trailer.color="536870912" )
