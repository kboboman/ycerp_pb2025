$PBExportHeader$d_oidocustprice_ct.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no  crosstab.dynamic = yes grid.lines=0 grid.columnmove=no selected.mouse=no )
header[1](height=0 color="536870912" )
header[2](height=140 color="536870912" )
header[3](height=84 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(20) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=number updatewhereclause=yes name=price dbname="price" )
 column=(type=number updatewhereclause=yes name=price_w dbname="price_w" )
 retrieve="SELECT user_name = l.user_name
     , cust_name = a.cust_name
     , item_name = g.item_name
     , price     = a.price
     , price_w   = 0 /*i.price*/
  FROM (
       SELECT cust_no   = do.cust_no
            , salesman  = c.salesman
            , cust_name = c.cust_name
            , item_no   = dodet.item_no
            , qa        = (case when dodet.uom = 'M' then substring(dodet.qa,1,13) else dodet.qa end)
            , uom       = dodet.uom
            , price     = min(dodet.price)
         FROM do
              LEFT OUTER JOIN dodet       ON do.do_no = dodet.do_no
              LEFT OUTER JOIN customer  C ON do.cust_no = c.cust_no
        WHERE ( do.do_date BETWEEN :adt_sdate AND :adt_edate )
          AND ((:as_salesman  = '%' ) OR
               (:as_salesman <> '%' AND c.salesman = :as_salesman )
              )
          AND ((:as_custno    = '%' ) OR
               (:as_custno   <> '%' AND do.cust_no = :as_custno )
              )
          AND ( dodet.item_no IN (SELECT item_no FROM avgcost WHERE use_yn = 'Y') )
          AND ((:as_inside    = '%' ) OR
               (:as_inside   <> '%' AND c.cust_no NOT IN (SELECT item_cd FROM codemst WHERE type = '내부업체' AND use_yn = 'Y') )
              )
        GROUP BY do.cust_no
               , c.salesman
               , c.cust_name
               , dodet.item_no
               , dodet.uom
               , (case when dodet.uom = 'M' then substring(dodet.qa,1,13) else dodet.qa end)
       ) A

     /*LEFT OUTER JOIN ItemCOSTS_CUST I ON a.cust_no  = i.cust_no AND a.item_no  = i.item_no 
                                       AND a.qa  = i.qa AND a.uom = i.uom AND i.use_yn = 'Y'*/
       LEFT OUTER JOIN groupitem      G ON a.item_no  = g.item_no
       LEFT OUTER JOIN login          L ON a.salesman = l.user_id
" arguments=(("as_salesman", string),("as_custno", string),("adt_sdate", datetime),("adt_edate", datetime),("as_inside", string))  sort="user_name A cust_name A " )
group(level=1 header.height=0 trailer.height=0 by=("user_name" ) header.color="536870912" trailer.color="536870912" )
