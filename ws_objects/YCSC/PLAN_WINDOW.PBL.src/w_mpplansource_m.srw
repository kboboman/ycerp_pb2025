type cbx_1 from checkbox within tabpage_1
integer x = 37
integer y = 20
integer width = 247
integer height = 64
integer textsize = -10
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
long textcolor = 16711680
long backcolor = 67108864
string text = "선택"
end type

event clicked;long   ll_row, ll_cnt
string ls_check

if trim(dw_2.object.wc_no[1]) = "" then
	if MessageBox("확인","작업장 전체를 선택 하시겠습니까?", Exclamation!, OKCancel!, 2) = 2 THEN
		this.checked = false
		dw_2.setcolumn("wc_no")
		dw_2.setfocus()
		return
	end if
end if

dw3.setredraw(false)
for ll_row = 1 to dw3.rowcount()
	if this.checked = true then
		ls_check = "선택"
		ll_cnt   = ll_cnt + 1
		dw3.object.chk[ll_row] = "Y"
	else
		ls_check = "해제"
		ll_cnt   = ll_cnt + 1
		dw3.object.chk[ll_row] = "N"
	end if
next
dw3.setredraw( true )

if ls_check = "선택" then
	if MessageBox("확인", string(ll_cnt) + "건 " + ls_check + " 완료~n~n'소재신청 ▶'을 실행 합니까?", Exclamation!, OKCancel!, 1) = 1 then
		cb_request.triggerevent(clicked!)
	end if
else
	MessageBox("확인", string(ll_cnt) + "건 " + ls_check + " 완료")
end if

end event

