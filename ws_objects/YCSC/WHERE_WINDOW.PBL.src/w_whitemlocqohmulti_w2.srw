type dw_2 from datawindow within tabpage_1
integer y = 260
integer width = 1723
integer height = 828
integer taborder = 200
string title = "none"
string dataobject = "d_itemname_all"
boolean hscrollbar = true
boolean vscrollbar = true
boolean livescroll = true
borderstyle borderstyle = stylelowered!
end type

event clicked;//
if isnull(row) or row < 1 then return

this.scrolltorow(row)

//
string ls_locno, ls_itemno
long   ll_row

ll_row = this.getrow()
if isnull(ll_row) or ll_row < 1 then return

ls_itemno  = this.object.item_no[ll_row]

ls_locno = is_loc

ls_locno = dw_loc.object.loc_no[1]
if isnull(ls_locno) or ls_locno = "" then return

dw3.setredraw(false)
dw3.reset()

///*2018.02.07 조원석 수정 대전저장소는 대전저장소로 나머지는 %  */
//if ls_locno = 'WS00000011' THEN
//	ls_locno = 'WS00000011'
//ELSE
//	ls_locno = '%'
//END IF	

dw3.retrieve( ls_locno, ls_itemno )

dw3.setredraw(true)

this.SelectRow(0, false)
this.SelectRow(ll_row, true)

//2005.07.30 도료규격추가부분//
choose case ls_itemno
	case "M2Z0POWZZZ", "M2Z0LIQKZZ", "PZZZPP7ZZZ", "PZZZPP3ZZZ", "PZZZPP1ZZZ", "PZZZPP0ZZZ"
		em_1.visible = false
		em_2.visible = false
		em_3.visible = false
		em_4.visible = false
		st_5.visible = false
		st_6.visible = false
		st_7.visible = false
		sle_paint.visible = true

	case else
		em_1.visible = true
		em_2.visible = true
		em_3.visible = true
		em_4.visible = true
		st_5.visible = true
		st_6.visible = true
		st_7.visible = true	
		sle_paint.visible = false
end choose

end event

