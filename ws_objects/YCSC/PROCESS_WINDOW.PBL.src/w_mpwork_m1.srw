event dw_2::itemchanged;datawindowchild ldwc_plan
dwItemStatus    l_status
string ls_wc, ls_loc, ls_rout
long   ll_rowcount, i

this.accepttext()
choose case dwo.name
	case 'work_date'
		dw4.reset()
		tab_1.tabpage_2.dw_7.reset()
		tab_1.tabpage_3.dw_5.reset()
		dw8.reset()
		dw8.retrieve()				
		
		dw9.reset()
		dw9.retrieve( dw_area.object.area[1], string(id_date,"yyyy/mm/dd"), dw_2.object.wc_no[1] )				
		  
		tab_1.tabpage_6.dw_10.reset()
		dw11.reset()

		tab_1.tabpage_6.dw_10.retrieve(string(id_date,"yyyy/mm/dd"), dw_area.object.area[1], dw_2.object.wc_no[1])
		dw11.retrieve(dw_area.object.area[1], string(id_date,"yyyy/mm/dd"), dw_2.object.wc_no[1])

	case 'wc_no'
		SELECT isnull(rout_auto, 'N') INTO :ls_rout FROM wc  WHERE work_no = rtrim(:data);
		if ls_rout = 'Y' then
			st_5.text = '이전공정자동수불작업장'
		else
			st_5.text = ''
		end if

		if gs_area = "S0001" then
			SELECT def_loc INTO :ls_loc FROM wc   WHERE work_no = rtrim(:data);
			this.object.loc_no[row] = ls_loc
		else
			SELECT def_loc INTO :ls_loc FROM area WHERE area_no = :gs_area;
			this.object.loc_no[row] = ls_loc
		end if

		dw3.reset()
		dw4.reset()
		dw5.reset()			
		dw6.reset()			
		tab_1.tabpage_2.dw_7.reset()
		dw8.reset()
		dw8.retrieve()		
		
		dw9.reset()
		dw9.retrieve( dw_area.object.area[1], string(id_date,"yyyy/mm/dd"), dw_2.object.wc_no[1] )				

		tab_1.tabpage_6.dw_10.reset()
		tab_1.tabpage_6.dw_10.retrieve(string(id_date,"yyyy/mm/dd"), dw_area.object.area[1], dw_2.object.wc_no[1])
		dw11.reset()
		dw11.retrieve(dw_area.object.area[1], string(id_date,"yyyy/mm/dd"), dw_2.object.wc_no[1])

	case 'loc_no'
		int li_index
		li_index = tab_1.SelectedTab
		choose case li_index
//			case 2
//			  ls_loc = trim(data)
//			  ll_rowcount = dw4.rowcount()
//			  for i = 1 to ll_rowcount
//	           l_status = dw4.GetItemStatus(i, 0, Primary!) 
//				  if l_status = newmodified! then
//					  dw4.object.loc_no[i] = ls_loc
//				  end if
//			  next

			case 3
			  ls_loc      = trim(data)
			  ll_rowcount = dw5.rowcount()
			  for i = 1 to ll_rowcount
	           l_status = dw5.GetItemStatus(i, 0, Primary!) 
				  if l_status = newmodified! and &
				  		(isnull(dw5.object.loc_no[i]) or dw5.object.loc_no[i] = '' ) then
					  	dw5.object.loc_no[i] = ls_loc
				  end if
			  next
		end choose
end choose
this.accepttext()

is_wc   = trim(this.object.wc_no[1])
id_date = date(this.object.work_date[1])

end event

event dw_2::losefocus;this.accepttext()
end event

event dw_2::rbuttondown;//
if row < 1 then return

CHOOSE CASE dwo.name
	CASE 'work_date'
		openWithParm(w_calendar, message.stringparm)
		if message.stringparm <> 'N' then
			this.object.work_date[row] = datetime(date(message.stringparm))
		end if
END CHOOSE
this.accepttext()
id_date = date(this.object.work_date[row])

end event

