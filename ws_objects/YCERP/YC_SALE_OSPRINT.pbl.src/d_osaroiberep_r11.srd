$PBExportHeader$d_osaroiberep_r11.srd
$PBExportComments$선매출현황 REPORT(1998/05/15, 정재수)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 1 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 9 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=604 color="536870912" )
summary(height=88 color="536870912" )
footer(height=0 color="536870912" )
detail(height=68 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=aroiinv_cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=datetime updatewhereclause=yes name=do_date dbname="do_date" )
 column=(type=decimal(4) updatewhereclause=yes name=do_cash dbname="do_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=do_rate dbname="do_rate" )
 column=(type=decimal(0) updatewhereclause=yes name=ship_amount dbname="ship_amount" )
 column=(type=decimal(4) updatewhereclause=yes name=do_tot dbname="do_tot" )
 column=(type=char(14) updatewhereclause=yes name=do_no dbname="do_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(10) updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=char(10) updatewhereclause=yes name=edate dbname="edate" )
 retrieve="  SELECT cust_no     = do.cust_no
       , cust_name   = c.cust_name
       , do_date     = do.do_date
       , do_cash     = do.do_cash
       , do_rate     = do.do_rate
       , ship_amount = do.ship_amount
       , do_tot      = do.do_total
       , do_no       = do.do_no
       , item_no     = dodet.item_no
       , item_name   = g.item_name
       , sdate       = (case when :as_sdate is null then '          ' else :as_sdate end)
       , edate       = (case when :as_edate is null then '          ' else :as_edate end)
    FROM do (nolock)
         LEFT OUTER JOIN dodet       (nolock) ON do.do_no      = dodet.do_no
         LEFT OUTER JOIN customer  C (nolock) ON do.cust_no    = c.cust_no
         LEFT OUTER JOIN groupitem G (nolock) ON dodet.item_no = g.item_no
   WHERE ( dodet.item_no   IN ('PZZZPB1ZZZ', 'PZZZPB2ZZZ') )	/* 선수금, 선수금 공제 */
     AND ( do.do_date      >= '2013/05/01' )
     AND ((:as_zero = 'Y' AND do.cust_no  IN (SELECT cust_no     = do.cust_no
                                                FROM do (nolock)
                                                     LEFT OUTER JOIN dodet (nolock) ON do.do_no = dodet.do_no
                                               WHERE ( dodet.item_no   IN ('PZZZPB1ZZZ', 'PZZZPB2ZZZ') )   /* 선수금, 선수금 공제 */
                                                 AND ( do.do_date      >= '2013/05/01' )
                                               GROUP BY do.cust_no
                                              HAVING sum(do.do_total) > 0
                                             )
                          AND do.cust_no  <> 'U824'  /* 은민 매입계산서 금액 회장결재건*/
          ) OR
          (:as_zero <> 'Y')
         )
" arguments=(("as_sdate", string),("as_edate", string),("as_zero", string)) )
