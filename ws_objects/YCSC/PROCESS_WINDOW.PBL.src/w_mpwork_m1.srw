event selectionchanged;int    li_index
string ls_sfcdate

li_index = tab_1.SelectedTab
st_3.text = "입고"
choose case li_index
	case 3
		st_3.text = "출고"

	case 5
		if is_wc = "" or isnull(is_wc) then
			MessageBox("확인","작업장을 선택하시기 바랍니다.")
		end if
		
	case 6
		if is_wc = "" or isnull(is_wc) then
			MessageBox("확인","작업장을 선택하시기 바랍니다.")
		end if
		
		tab_1.tabpage_6.dw_10.reset()
		tab_1.tabpage_6.dw_11.reset()

		tab_1.tabpage_6.dw_10.retrieve( string(id_date,"yyyy/mm/dd"), dw_area.object.area[1], dw_2.object.wc_no[1] )
		tab_1.tabpage_6.dw_11.retrieve( dw_area.object.area[1], string(id_date,"yyyy/mm/dd"), dw_2.object.wc_no[1] )
end choose
end event

