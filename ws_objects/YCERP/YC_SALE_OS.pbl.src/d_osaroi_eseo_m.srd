 column=(type=decimal(4) updatewhereclause=yes name=세액 dbname="세액" )
 column=(type=char(40) updatewhereclause=yes name=거래비고 dbname="거래비고" )
 retrieve="  SELECT '전송'                     = aa.esero
       , '작성일자'                 = aa.sys_date                    
       , '문서관리번호'             = aa.doc_no                      
       , '세금계산서종류'           = '01'                           
       , '세금계산서분류'           = (case when aa.tot_taxamt = 0 then '02' else '01' end)
       , '영수청구구분'             = '02'                                  
       , '공급자사업자등록번호'     = aa.saler_bizno                
       , '공급자거래처코드'         = (case when substring(aa.doc_no,1,2) = 'ZD' AND aa.oi_date > '20130630' then '0005' else '' end)
       , '공급자상호'               = aa.saler_name                     
       , '공급자대표자성명'         = '조용선'                       
       , '공급자주소'               = aa.saler_address  
       , '공급자업태'               = aa.saler_uptae                   
       , '공급자업종'               = aa.saler_upjong                  
       , '공급자담당부서명'         = '영업부'                       
       , '공급자담당자명'           = aa.saler_user                   
       , '공급자전화번호'           = aa.saler_phone                 
       , '공급자이메일'             = 'vat.sale@yoochang.com'          
       , '공급받는자구분코드'       = aa.buyer_type                  
       , '공급받는자사업자등록번호' = aa.buyer_bizno                 
       , '공급받는자거래처코드'     = aa.buyer_custno                
       , '공급받는자상호'           = aa.buyer_name                  
       , '공급받는자대표자성명'     = aa.buyer_captain
       , '공급받는자주소'           = aa.buyer_address
       , '공급받는자업태'           = aa.buyer_uptae  
       , '공급받는자업종'           = aa.buyer_upjong 
       , '공급받는자담당부서명'     = aa.buyer_team   
       , '공급받는자담당자명'       = aa.buyer_user   
       , '공급받는자전화번호'       = aa.buyer_phone  
       , '공급받는자이메일'         = aa.buyer_email  
       , '공급가액합계'             = ceiling(round(aa.tot_supplyamt,0))
       , '세액합계'                 = ceiling(round(aa.tot_taxamt,0))
       , '총금액'                   = ceiling(round(aa.tot_amt,0))   
       , '비고'                     = aa.bigo    
       , '상품일련번호'             = aa.item_seq     
       , '거래일자'                 = aa.oi_date 
       , '품목명'                   = aa.item
       , '규격'                     = aa.spec                 
       , '수량'                     = aa.qty  
       , '단가'                     = aa.unit_price           
       , '공급가액'                 = aa.supplyamt            
       , '세액'                     = aa.taxamt               
       , '거래비고'                 = aa.rem
    FROM (   
         SELECT esero          = isnull(a.esero,'N')
              , doc_no         = a.aroiinv_no
              , sys_date       = convert(char(10),a.oi_date,112)
              , saler_bizno    = d.saler_bizno
              , saler_name     = d.saler_name
              , saler_address  = d.saler_address
              , saler_uptae    = d.saler_uptae
              , saler_upjong   = d.saler_upjong
              , saler_user     = d.saler_user
              , saler_phone    = d.saler_phone              
              , buyer_type     = (case when substring(c.register_no,1,3) = '999' then '02' else '01' end)
              , buyer_bizno    = c.register_no                    
              , buyer_custno   = isnull(c.child_number ,'')                               
              , buyer_name     = isnull(c.cust_name    ,'')       
              , buyer_captain  = isnull(c.captain_name ,'')       
              , buyer_address  = isnull(c.addr         ,'')       
              , buyer_uptae    = isnull(c.industry_type,'')       
              , buyer_upjong   = isnull(c.industry_code,'')       
              , buyer_team     = ''                               
              , buyer_user     = isnull(c.vat_user,'')              
              , buyer_phone    = isnull(c.vat_phone,'')             
              , buyer_email    = isnull(c.vat_email,'')              
              , tot_supplyamt  = (a.aroiinv_cash + a.ship_cost)
              , tot_taxamt     = (a.aroiinv_rate + (a.ship_cost * 0.1))
              , tot_amt        = (a.aroiinv_cash + a.ship_cost) + (a.aroiinv_rate + (a.ship_cost * 0.1))
              , bigo           = isnull(a.rem,'')                 
              , do_no          = b.do_no
              , item_seq       = b.oi_no
              , oi_date        = substring(b.do_no,3,8)  
              , item           = dbo.uf_getitemname(b.item_no)    
              , spec           = b.qa                             
              , qty            = ceiling(round(b.ship_qty,0))                       
              , unit_price     = b.price                          
              , supplyamt      = b.ori_amount                     
              , taxamt         = b.rate_cash    
              , rem            = isnull(f.scene_desc,'')
           FROM aroiinv  A
                RIGHT OUTER JOIN aroi     B   ON a.aroiinv_no  = b.aroiinv_no
                LEFT  OUTER JOIN customer C   ON a.cust_no     = c.cust_no   
                LEFT  OUTER JOIN aroiinv_esero D ON substring(a.aroiinv_no,1,2) = d.area  and c.salesman  = d.id
                LEFT  OUTER JOIN do       E   ON b.do_no       = e.do_no
                LEFT  OUTER JOIN scene    F   ON a.cust_no     = f.cust_no  and e.spot_code = f.scene_code            
          WHERE ( a.sale_flag         IN ( 'D','L','E' ) ) 
            AND ( convert(char(10),a.oi_date,111)      BETWEEN :arg_start AND :arg_end ) 
            AND ( a.delete_flag        = 'N'             ) 
            AND ( c.salesman        LIKE :arg_salesman   ) 
            AND ( c.cust_no         LIKE :arg_cust       )

          /*AND d.saler_bizno IS NOT NULL*/
            
         UNION ALL

         SELECT esero = (case when d.id is null then 'N' else isnull(e.esero,'N') end )  /*esero          = isnull(e.esero,'N')                          */
              , doc_no         = a.inv_no
              , sys_date       = convert(char(10),e.oi_date,112)            
              , saler_bizno    = d.saler_bizno
              , saler_name     = d.saler_name
              , saler_address  = d.saler_address
              , saler_uptae    = d.saler_uptae
              , saler_upjong   = d.saler_upjong
              , saler_user     = d.saler_user
              , saler_phone    = d.saler_phone              
              , buyer_type     = (case when substring(c.register_no,1,3) = '999' then '02' else '01' end)
              , buyer_bizno    = c.register_no                                       
              , buyer_custno   = ''                                                  
              , buyer_name     = c.cust_name                                         
              , buyer_captain  = c.captain_name                                      
              , buyer_address  = c.addr                                              
              , buyer_uptae    = c.industry_type                                     
              , buyer_upjong   = c.industry_code                                     
              , buyer_team     = ''                                                  
              , buyer_user     = isnull(c.vat_user ,'')                                 
              , buyer_phone    = isnull(c.vat_phone,'')                                
              , buyer_email    = isnull(c.vat_email,'')                                 
              , tot_supplyamt  = (e.aroiinv_cash + e.ship_cost)
              , tot_taxamt     = (e.aroiinv_rate + (e.ship_cost * 0.1))
              , tot_amt        = (e.aroiinv_cash + e.ship_cost) + (e.aroiinv_rate + (e.ship_cost * 0.1))
              , bigo           = isnull(e.rem,'')                                    
              , do_no          = b.do_no
              , item_seq       = b.oi_no                                            
              , oi_date        = substring(b.do_no,3,8)  
              , item           = '운반비'                       
              , spec           = ''                                                
              , qty            = 1                                          
              , unit_price     = a.ship_amount                                             
              , supplyamt      = a.ship_amount                                
              , taxamt         = a.ship_amount * 0.1                                         
              , rem            = isnull(a.scene_desc,'')
          FROM (
               SELECT DISTINCT a.inv_no
                    , a.do_no
                    , a.cust_no
                    , a.do_cash
                    , a.ship_amount
                    , scene_desc = isnull(scene_desc,'')
                 FROM do  A
                      LEFT OUTER JOIN scene B  ON a.cust_no = b.cust_no AND a.spot_code = b.scene_code
                WHERE ( substring(a.inv_no,3,6)  = substring(replace(:arg_start,'/',''),1,6) ) 
                  AND ( a.ship_amount        <> 0   ) 
                  AND ( a.ship_flag           = 'D' ) 
                  AND ( a.shipamt_case        = 'R' )
               ) A
               LEFT OUTER JOIN (
                    SELECT do_no, oi_no = max(oi_no) + 1
                      FROM dodet
                     WHERE substring(do_no,3,6)  = substring(replace(:arg_start,'/',''),1,6)
                     GROUP BY do_no
               ) B  ON a.do_no   = b.do_no
               LEFT OUTER JOIN  customer      C  ON a.cust_no     = c.cust_no
               LEFT OUTER JOIN  aroiinv_esero D  ON substring(a.inv_no,1,2) = d.area  AND c.salesman     = d.id
               LEFT OUTER JOIN  aroiinv       E  ON a.inv_no      = e.aroiinv_no      AND e.delete_flag  = 'n'
         WHERE ( substring(a.inv_no,3,6)  = substring(replace(:arg_start,'/',''),1,6) )
           AND ( c.salesman            LIKE :arg_salesman )
           AND ( c.cust_no             LIKE :arg_cust     )
         ) AA         
     WHERE aa.esero        LIKE :arg_esero
     ORDER BY aa.buyer_bizno, aa.doc_no, aa.rem, aa.oi_date, aa.item_seq
" arguments=(("arg_cust", string),("arg_start", string),("arg_end", string),("arg_salesman", string),("arg_esero", string)) )
