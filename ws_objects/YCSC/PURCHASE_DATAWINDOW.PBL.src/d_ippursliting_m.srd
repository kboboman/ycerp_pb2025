 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"coilsliting~" )  TABLE(NAME=~"coilorder~" )  TABLE(NAME=~"groupitem~" )  TABLE(NAME=~"supp~" )  TABLE(NAME=~"coilorderdet~" ) COLUMN(NAME=~"coilsliting.order_no~") COLUMN(NAME=~"coilsliting.seq~") COLUMN(NAME=~"coilsliting.coil_no~") COLUMN(NAME=~"coilsliting.wid~") COLUMN(NAME=~"coilsliting.item_no~") COLUMN(NAME=~"coilsliting.qa~") COLUMN(NAME=~"coilsliting.cnt~") COLUMN(NAME=~"coilsliting.length~") COLUMN(NAME=~"coilsliting.proc_flag~") COLUMN(NAME=~"coilorder.supp_no~") COLUMN(NAME=~"groupitem.item_name~") COLUMN(NAME=~"supp.supp_name~") COLUMN(NAME=~"groupitem.uom~") COLUMN(NAME=~"coilorder.due_date~") COLUMN(NAME=~"coilsliting.rem~") COLUMN(NAME=~"coilsliting.unit_qty~") COLUMN(NAME=~"coilsliting.sheet~") COLUMN(NAME=~"coilsliting.loc_no~")    JOIN (LEFT=~"coilorder.supp_no~"    OP =~"=~"RIGHT=~"supp.supp_no~"    OUTER1 =~"coilorder.supp_no~" )    JOIN (LEFT=~"coilsliting.item_no~"    OP =~"=~"RIGHT=~"groupitem.item_no~" )    JOIN (LEFT=~"coilsliting.order_no~"    OP =~"=~"RIGHT=~"coilorderdet.order_no~" )    JOIN (LEFT=~"coilorderdet.coilorder_order~"    OP =~"=~"RIGHT=~"coilorder.order_no~" )WHERE(    EXP1 =~"coilsliting.order_no~"   OP =~"like~"    EXP2 =~":as_order~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"coilorder.wc_place~"   OP =~"=~"    EXP2 =~"'O'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"coilorderdet.proc_flag~"   OP =~"=~"    EXP2 =~"'M'~" ) ) ARG(NAME = ~"as_order~" TYPE = string) " arguments=(("as_order", string))  sort="coilsliting_order_no A coilsliting_seq A " )
