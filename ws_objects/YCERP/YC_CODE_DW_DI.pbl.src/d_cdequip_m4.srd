table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=equip_code dbname="EQUIP_CAPA.EQUIP_CODE" )
 column=(type=char(4) update=yes updatewhereclause=yes key=yes name=year dbname="EQUIP_CAPA.YEAR" )
 column=(type=char(4) update=yes updatewhereclause=yes name=uom dbname="EQUIP_CAPA.UOM" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=product_qty dbname="EQUIP_CAPA.PRODUCT_QTY" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=product_percent dbname="EQUIP_CAPA.PRODUCT_PERCENT" )
 retrieve="SELECT EQUIP_CODE,
		 YEAR,
       UOM,
		 PRODUCT_QTY,
		 PRODUCT_PERCENT
  FROM EQUIP_CAPA
WHERE EQUIP_CODE = :ARG_EQUIP_CODE
" update="EQUIP_CAPA" updatewhere=1 updatekeyinplace=no arguments=(("arg_equip_code", string))  sort="year D " )
