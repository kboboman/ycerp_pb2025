 column=(type=decimal(4) updatewhereclause=yes name=unit_cost dbname="estimate_det.unit_cost" initial="0" )
 column=(type=decimal(4) updatewhereclause=yes name=item_amt dbname="estimate_det.item_amt" initial="0" )
