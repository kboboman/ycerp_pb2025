integer x = 2766
integer y = 160
integer width = 265
integer height = 88
integer taborder = 180
boolean bringtotop = true
integer textsize = -9
integer weight = 400
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
boolean enabled = false
string text = "추가"
end type

event clicked;long ll_row, ll_cnt
string  ls_item_no, ls_qa, ls_new_qa, ls_type_check, ls_locno
pointer oldpointer // Declares a pointer variable

oldpointer = SetPointer(HourGlass!)
//2005.07.30 도료규격추가부분시작//
if sle_paint.Visible = true then
	ls_new_qa = sle_paint.text
	ls_type_check = 'P'		//도료
	if ls_new_qa = '' then
		MessageBox("확인","규격을 입력해주세요.")
		sle_paint.Setfocus()
		return
	End If
//2005.07.30 도료규격추가부분끝//	
else
	ls_new_qa = em_1.text + 'X' + em_2.text + 'X' + em_3.text + 'X' + em_4.text
	ls_type_check = 'J'		//도료이외(철골)
end if

if MessageBox("확인","  규격 = [" + ls_new_qa + "]을 저장하시겠습니까?", Exclamation!, OKCancel!, 2) = 2 then
	return
end if

dw_3.accepttext()
ll_row = dw_2.getrow()

ls_item_no = dw_2.object.item_no[ll_row]
ls_qa = trim(ls_new_qa)
dw_3.setredraw(false)
dw_3.SetFilter('')
dw_3.Filter( )
ll_row = dw_3.Find( "qa = '" + ls_qa + "'", 1, dw_3.RowCount())
if ll_row > 0 then
	MessageBox("확인","이미 자료가 있습니다.")
	dw_3.ScrollToRow(ll_row)
	dw_3.setredraw(true)
	return
end if

if GF_ITEMINSERT(ls_item_no, ls_qa) = false then
else
	MessageBox('확인','규격이 추가되었습니다')
	
	ls_locno  = dw_loc.object.loc_no[1]
	
	/*2018.02.07 조원석 수정 대전저장소는 대전저장소로 나머지는 %  */
	if ls_locno = 'WS00000011' THEN
		ls_locno = 'WS00000011'
	ELSE
		ls_locno = '%'
	END IF	
	
//	dw_3.retrieve(is_loc, ls_item_no )   2018.02.07 //
	dw_3.retrieve(ls_locno, ls_item_no ) /* 2018.02.07 조원석 수정 */
	
	ll_row = dw_3.Find( "qa = '" + ls_qa + "'", 1, dw_3.RowCount())
	IF ll_row > 0 THEN
		dw_3.ScrollToRow(ll_row)
	end if
end if

dw_3.setredraw(true)
cb_ins.enabled = false
cbx_1.checked = false

end event

