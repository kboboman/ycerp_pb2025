compute(band=detail alignment="0" expression="case( trim(uom) when 'M' then  left(qa, 13)  when 'M2' then left(qa, 3) when 'SS' then left(qa, 3) else qa)"border="0" color="0" x="1312" y="8" height="60" width="617" format="[general]" html.valueishtml="0"  name=c_qa visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
column(band=detail id=3 alignment="1" tabsequence=32766 border="0" color="0" x="2080" y="4" height="60" width="453" format="[general]" html.valueishtml="0"  name=ship_qty  tag="매출수량" visible="1" edit.limit=0 edit.case=any edit.focusrectangle=no edit.autoselect=yes edit.autohscroll=yes edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="2" font.pitch="2" font.charset="129" background.mode="1" background.color="536870912" )
compute(band=detail alignment="1" expression="if(left( item_no ,1) = 'P' and mid(item_no, 3,1) = 'Y' and (mid(item_no, 7,1) = 'A' or mid(item_no, 7,1) = 'B' or mid(item_no, 7,1) = 'C' or mid(item_no, 7,1) = 'D' or left(item_no, 5) = 'PCYSZ'), ship_qty, if(uom = 'M2' or uom = 'SS',truncate( long(mid( qa ,5,4)) * long(mid(qa,10,4)) *   ship_qty / 1000000+ 0.00001, 2), if(uom = 'M',if(  ship_qty < 0 , truncate(long(mid(  qa , 15,5)) *    ship_qty / 1000 - 0.00001,2), truncate(long(mid(  qa , 15,5)) *   ship_qty / 1000 + 0.00001,2)) ,      ship_qty )))"border="0" color="0" x="2542" y="4" height="60" width="521" format="[general]" html.valueishtml="0"  name=cqty visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
compute(band=detail alignment="1" expression="truncate( (  ori_amount - if( aroiinv_curr_code = 'WON', truncate(   ori_amount *  aroi_dc_rate / 100, 0 ),  truncate(   ori_amount *  aroi_dc_rate / 100, 2 )))  *  aroiinv_gl_cur_rate , 0 )"border="0" color="0" x="3072" y="4" height="60" width="549" format="#,##0.00" html.valueishtml="0"  name=c_ori_amount visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
compute(band=detail alignment="1" expression="truncate( (   rate_cash - if( aroiinv_curr_code = 'WON', truncate(    rate_cash *  aroi_dc_rate / 100, 0 ),  truncate(    rate_cash *  aroi_dc_rate / 100 + 0.0001, 2 )))  *  aroiinv_gl_cur_rate , 0 )"border="0" color="0" x="3630" y="0" height="60" width="558" format="#,##0.00" html.valueishtml="0"  name=c_rate_cash visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
