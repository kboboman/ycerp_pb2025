type m_utility from menu within m_b_main
m_plock m_plock
m_password m_password
m_-4 m_-4
m_mess m_mess
m_4 m_4
end type

on m_utility.create
call super::create
this.text = "유틸리티(&Utility)"
this.m_plock=create m_plock
this.m_password=create m_password
this.m_-4=create m_-4
this.m_mess=create m_mess
this.m_4=create m_4
this.Item[UpperBound(this.Item)+1]=this.m_plock
this.Item[UpperBound(this.Item)+1]=this.m_password
this.Item[UpperBound(this.Item)+1]=this.m_-4
this.Item[UpperBound(this.Item)+1]=this.m_mess
this.Item[UpperBound(this.Item)+1]=this.m_4
end on

on m_utility.destroy
call super::destroy
destroy(this.m_plock)
destroy(this.m_password)
destroy(this.m_-4)
destroy(this.m_mess)
destroy(this.m_4)
end on

