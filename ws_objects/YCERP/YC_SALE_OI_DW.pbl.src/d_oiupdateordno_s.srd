$PBExportComments$수정가능한출고번호(1998/4/23,성삼지)
release 8;
datawindow(units=0 timer_interval=0 color=67108864 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=72 color="536870912" )
summary(height=0 color="536870912" )
footer(height=68 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=do_no dbname="do_no" )
 column=(type=char(12) updatewhereclause=yes name=inv_no dbname="inv_no" )
 retrieve="      SELECT do.do_no  
       , do.inv_no/*, dodet.loc_no*/
    FROM do /*INNER JOIN dodet on do.do_no = dodet.do_no*/"  sort="do_no A " )
text(band=header alignment="2" text="출고번호" border="6" color="0" x="9" y="8" height="60" width="507" html.valueishtml="0"  name=t_1 visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="67108864" )
