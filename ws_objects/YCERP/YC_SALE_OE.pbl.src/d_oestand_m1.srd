table(column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="basis_det.item_no" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=asc_item dbname="basis_det.asc_item" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=asc_qa dbname="basis_det.asc_qa" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="basis_det.uom" )
 column=(type=decimal(3) update=yes updatewhereclause=yes name=asc_qty dbname="basis_det.asc_qty" initial="0" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=std_cost dbname="basis_det.std_cost" initial="0" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=std_amount dbname="basis_det.std_amount" initial="0" )
 column=(type=char(30) update=yes updatewhereclause=yes name=rem dbname="basis_det.rem" )
 retrieve="  SELECT groupitem.item_name,   
         basis_det.item_no,   
         basis_det.asc_item,   
         basis_det.asc_qa,   
         basis_det.uom,   
         basis_det.asc_qty,   
         basis_det.std_cost,   
         basis_det.std_amount,   
         basis_det.rem  
    FROM basis_det 
         LEFT OUTER JOIN groupitem  ON basis_det.asc_item = groupitem.item_no  
   WHERE basis_det.item_no = :item_no    
" update="basis_det" updatewhere=0 updatekeyinplace=no arguments=(("item_no", string)) )
