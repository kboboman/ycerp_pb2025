 retrieve="SELECT	item_no, convert (decimal (5,1), substring(qa,5,4) + '.' + substring(qa, 10,1)), cnt
  FROM	inspdet
 WHERE	insp_no  =  :ag_insp_no
   AND	oi_no    =  :ag_row" arguments=(("ag_insp_no", string),("ag_row", number)) )
