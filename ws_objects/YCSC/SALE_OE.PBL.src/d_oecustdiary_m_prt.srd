table(column=(type=datetime updatewhereclause=yes name=diary_date dbname="custdiary.diary_date" )
 column=(type=char(10) updatewhereclause=yes name=emp_no dbname="custdiary.emp_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="custdiary.seq_no" initial="1" )
