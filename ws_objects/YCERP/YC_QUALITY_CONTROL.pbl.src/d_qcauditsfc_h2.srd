 column=(type=char(10) updatewhereclause=yes name=wname dbname="qcsfcchk.wname" )
 retrieve="  SELECT qcsfcday2.area_no,   
         qcsfcday2.sfc_date,   
         qcsfcday2.wc_no,   
         qcsfcday2.item_no,   
         qcsfcday2.item_name,   
         qcsfcday2.qc_date,   
         qcsfcday2.qc_code,   
         qcsfcday2.qc_user,   
         qcsfcday2.height_r1,   
         qcsfcday2.height_r2,   
         qcsfcday2.height_r3,   
         qcsfcday2.height_r4,   
         qcsfcday2.height_r5,   
         qcsfcday2.height_k1,   
         qcsfcday2.height_k2,   
         qcsfcday2.height_k3,   
         qcsfcday2.height_k4,   
         qcsfcday2.height_k5,   
         qcsfcday2.side1,   
         qcsfcday2.side2,   
         qcsfcday2.side3,   
         qcsfcday2.side4,   
         qcsfcday2.side5,   
         qcsfcday2.rib1,   
         qcsfcday2.rib2,   
         qcsfcday2.rib3,   
         qcsfcday2.rib4,   
         qcsfcday2.rib5,   
         qcsfcday2.length_r1,   
         qcsfcday2.length_r2,   
         qcsfcday2.length_r3,   
         qcsfcday2.length_r4,   
         qcsfcday2.length_r5,   
         qcsfcday2.length_k1,   
         qcsfcday2.length_k2,   
         qcsfcday2.length_k3,   
         qcsfcday2.length_k4,   
         qcsfcday2.length_k5, 
	   qcsfcchk.wname
    FROM qcsfcday2 WITH(NOLOCK) LEFT OUTER JOIN  qcsfcchk  WITH(NOLOCK) ON qcsfcday2.area_no = qcsfcchk.area_no
                                                                                                                                              AND qcsfcday2.wc_no = qcsfcchk.wc_no
                                                                                                                                              AND qcsfcday2.sfc_date = qcsfcchk.sfc_date
   WHERE ( qcsfcday2.area_no = :as_area ) AND  
                   ( qcsfcday2.wc_no = :as_wc ) AND  
                   ( qcsfcday2.sfc_date = :ad_date )
/*
    FROM qcsfcday2, qcsfcchk  
   WHERE ( qcsfcday2.area_no = :as_area ) AND  
         ( qcsfcday2.wc_no = :as_wc ) AND  
         ( qcsfcday2.sfc_date = :ad_date ) AND
			( qcsfcday2.area_no *= qcsfcchk.area_no ) AND  
         ( qcsfcday2.wc_no *= qcsfcchk.wc_no ) AND  
         ( qcsfcday2.sfc_date *= qcsfcchk.sfc_date )      
*/" arguments=(("as_area", string),("as_wc", string),("ad_date", date)) )
