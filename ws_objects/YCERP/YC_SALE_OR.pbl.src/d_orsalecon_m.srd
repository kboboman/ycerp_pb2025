 column=(type=decimal(4) update=yes updatewhereclause=yes name=sale_amount dbname="sale.sale_amount" initial="0" )
 column=(type=char(1) update=yes updatewhereclause=yes name=open_close dbname="sale.open_close" initial="O" values="등록	O/마감	C/초과	Z/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=close_type dbname="sale.close_type" initial=" " values="자동	A/수동	M/" )
 column=(type=datetime update=yes updatewhereclause=yes name=close_date dbname="sale.close_date" initial=" " )
 column=(type=char(80) update=yes updatewhereclause=yes name=shipto_addr dbname="sale.shipto_addr" initial=" " )
 column=(type=char(80) update=yes updatewhereclause=yes name=rem dbname="sale.rem" initial=" " )
 column=(type=long update=yes updatewhereclause=yes name=revision_no dbname="sale.revision_no" initial=" " )
 column=(type=datetime update=yes updatewhereclause=yes name=revision_date dbname="sale.revision_date" initial=" " )
 column=(type=datetime update=yes updatewhereclause=yes name=input_date dbname="sale.input_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=login_id dbname="sale.login_id" )
 column=(type=char(1) update=yes updatewhereclause=yes name=sale_confirm_flag dbname="sale.confirm_flag" values="수주확정	T/수주확정	N" )
 column=(type=char(1) updatewhereclause=yes name=confirm_flag dbname="confirm_flag" values="수주확정	T/수주확정	N" )
 column=(type=char(1) updatewhereclause=yes name=sale_confirm_flag_view dbname="sale.confirm_flag_view" values="수주	N/확정	T/생산	Y/" )
 column=(type=char(10) update=yes updatewhereclause=yes name=sale_confirm_user dbname="sale.confirm_user" )
 column=(type=datetime update=yes updatewhereclause=yes name=sale_confirm_date dbname="sale.confirm_date" )
 column=(type=char(20) update=yes updatewhereclause=yes name=tel_no dbname="sale.tel_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=telno_cap dbname="sale.telno_cap" )
 column=(type=char(1) update=yes updatewhereclause=yes name=ship_case dbname="sale.ship_case" initial="E" values="정기화물	J/택배	T/오토바이	A/선박	S/항공	P/기타	E/" )
 column=(type=char(80) update=yes updatewhereclause=yes name=rem1 dbname="sale.rem1" )
 column=(type=char(80) update=yes updatewhereclause=yes name=rem2 dbname="sale.rem2" )
 column=(type=char(1) updatewhereclause=yes name=protect dbname="protect" initial="Y" )
 column=(type=char(1) update=yes updatewhereclause=yes name=shipamt_case dbname="sale.shipamt_case" initial="R" values="현금	C/외상	R/" )
 column=(type=char(10) update=yes updatewhereclause=yes name=area_no dbname="sale.area_no" )
 column=(type=datetime update=yes updatewhereclause=yes name=plan_date dbname="sale.plan_date" )
 column=(type=char(1) update=yes updatewhereclause=yes name=ysp_confirm dbname="sale.ysp_confirm" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=ysp_qty dbname="sale.ysp_qty" )
 column=(type=char(4) update=yes updatewhereclause=yes name=color dbname="sale.color" )
 column=(type=char(1) update=yes updatewhereclause=yes name=type dbname="sale.type" values="일체형	A/분리형	P/ U-형	U/기타	E/" )
 column=(type=long update=yes updatewhereclause=yes name=class dbname="sale.class" initial="65" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=ysp_qty2 dbname="sale.ysp_qty2" )
 column=(type=char(10) update=yes updatewhereclause=yes name=org_user dbname="sale.org_user" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="login.user_name" )
 column=(type=char(1) update=yes updatewhereclause=yes name=do_reserved dbname="sale.do_reserved" values="출고예약	Y/출고예약	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=sale_tracking dbname="sale.tracking" values="다공정	Y/다공정	N" )
 column=(type=datetime update=yes updatewhereclause=yes name=tracking_date dbname="sale.tracking_date" )
 column=(type=decimal(1) updatewhereclause=yes name=saleamt dbname="saleamt" )
 column=(type=char(1) update=yes updatewhereclause=yes name=pre_sale_yn dbname="sale.pre_sale_yn" values="선수금	Y/선수금	N" )
 column=(type=decimal(0) updatewhereclause=yes name=credit_limit dbname="credit_limit" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(1) updatewhereclause=yes name=credit_level dbname="customer.credit_level" )
 column=(type=decimal(4) updatewhereclause=yes name=balance_amt dbname="customer.balance_amt" )
 column=(type=decimal(4) updatewhereclause=yes name=bill_amount dbname="customer.bill_amount" )
 column=(type=char(1) updatewhereclause=yes name=utong_yn dbname="utong_yn" )
 column=(type=char(240) update=yes updatewhereclause=yes name=sale_make_rem dbname="sale.make_rem" )
 column=(type=char(10) updatewhereclause=yes name=issuereq_confirm dbname="issuereq_confirm" )
 column=(type=char(1) update=yes updatewhereclause=yes name=orexceed_gb dbname="sale.orexceed_gb" )
 column=(type=char(10) update=yes updatewhereclause=yes name=orexceed_confirm_user dbname="sale.orexceed_confirm_user" )
 column=(type=datetime update=yes updatewhereclause=yes name=orexceed_confirm_date dbname="sale.orexceed_confirm_date" )
 column=(type=char(100) update=yes updatewhereclause=yes name=orexceed_confirm_rem dbname="sale.orexceed_confirm_rem" )
 retrieve="SELECT 
	sale.order_no,   
	sale.cust_no,   
	sale.scene_code,   
	sale.order_date,   
	sale.due_date,   
	sale.estimate_no,   
	sale.sale_flag,   
	sale.curr_code,   
	sale.cust_po_no,   
	sale.cust_po_date,   
	sale.ship_flag,   
	sale.fob,   
	sale.salesman,   
	sale.tax_sign,   
	sale.sale_tax,   
	sale.sale_amount,   
	sale.open_close,   
	sale.close_type,   
	sale.close_date,   
	sale.shipto_addr,   
	sale.rem,   
	sale.revision_no,   
	sale.revision_date,   
	sale.input_date,   
	sale.login_id, 
	sale.confirm_flag,
	(case when sale.confirm_flag = 'T' then 'T' 
			  when sale.confirm_flag = 'Y' then 'T'
	else 'N' end ) confirm_flag,   
	sale.confirm_flag confirm_flag_view,   
	sale.confirm_user,   
	sale.confirm_date,   
	sale.tel_no,   
	sale.telno_cap,   
	sale.ship_case,   
	sale.rem1,   
	sale.rem2,   
	protect = '',   
	sale.shipamt_case,   
	sale.area_no,   
	sale.plan_date,   
	sale.ysp_confirm,   
	sale.ysp_qty,   
	sale.color,   
	sale.type,   
	sale.class,   
	sale.ysp_qty2,
	sale.org_user,
	login.user_name,
	sale.do_reserved,
	sale.tracking,
	sale.tracking_date,
	saleamt = 0.0,
	sale.pre_sale_yn,
	isnull(orexceed.limit_amt,customer.credit_limit) credit_limit,
	customer.cust_name,
	customer.credit_level,   
	customer.balance_amt,   
	customer.bill_amount,   
	isnull(scene.utong_yn, 'N') utong_yn,
	sale.make_rem,
	dbo.uf_sale_issuereq_confirm(sale.order_no) issuereq_confirm,
	sale.orexceed_gb	orexceed_gb,
	sale.orexceed_confirm_user	orexceed_confirm_user,
	sale.orexceed_confirm_date	orexceed_confirm_date,
	sale.orexceed_confirm_rem	orexceed_confirm_rem
FROM sale	LEFT OUTER JOIN customer 	ON sale.cust_no  = customer.cust_no
         	LEFT OUTER JOIN login    	ON sale.org_user = login.user_id
				LEFT OUTER JOIN scene 		ON sale.cust_no = scene.cust_no and sale.scene_code = scene.scene_code
				LEFT OUTER JOIN orexceed	ON orexceed.cust_no = sale.cust_no 
													and (convert(varchar(8),sale.order_date,112) between orexceed.start_date and orexceed.end_date)
													and orexceed.use_yn = 'Y'  
WHERE 
	 sale.order_no = :as_order_no" update="sale" updatewhere=0 updatekeyinplace=no arguments=(("as_order_no", string)) )
