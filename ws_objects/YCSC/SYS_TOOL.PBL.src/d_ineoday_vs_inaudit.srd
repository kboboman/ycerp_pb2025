$PBExportHeader$d_ineoday_vs_inaudit.srd
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=68 color="536870912" )
footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(8) updatewhereclause=yes name=ineoday_cdate dbname="ineoday.cdate" )
 column=(type=char(10) updatewhereclause=yes name=ineoday_item_no dbname="ineoday.item_no" )
 column=(type=char(20) updatewhereclause=yes name=ineoday_qa dbname="ineoday.qa" )
 column=(type=char(10) updatewhereclause=yes name=ineoday_loc_no dbname="ineoday.loc_no" )
 column=(type=decimal(4) updatewhereclause=yes name=ineoday_rcpt_qty dbname="ineoday.rcpt_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=ineoday_issue_qty dbname="ineoday.issue_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=arcpt dbname="arcpt" )
 column=(type=decimal(2) updatewhereclause=yes name=aissue dbname="aissue" )
 retrieve="  SELECT ineoday.cdate,   
         ineoday.item_no,   
         ineoday.qa,   
         ineoday.loc_no,   
         ineoday.rcpt_qty,   
         ineoday.issue_qty,   
         arcpt = sum(inaudit.rcpt_qty),   
         aissue = sum(inaudit.issue_qty)  
    FROM inaudit,   
         ineoday  
   WHERE ( inaudit.qa = ineoday.qa ) and  
         ( inaudit.inaudit_item = ineoday.item_no ) and  
         ( inaudit.loc_no = ineoday.loc_no ) and  
         ( ( inaudit.inaudit_date >= :as_date ) AND  
         ( convert(char(8), inaudit.inaudit_date, 112) = ineoday.cdate ) )   
GROUP BY ineoday.cdate,   
         ineoday.item_no,   
         ineoday.qa,   
         ineoday.loc_no,   
         ineoday.rcpt_qty,   
         ineoday.issue_qty   
" arguments=(("as_date", date))  sort="ineoday_cdate D ineoday_loc_no A ineoday_item_no A ineoday_qa A " )
