event clicked;string ls_date, ls_wc_no[], ls_area

ls_date		= em_2.text
ls_wc_no[1]	= dw_6.object.wc_no[1]
ls_area		= dw_area.object.area[1]

if ls_area = 'S0001' then

		if ls_wc_no[1] = 'F00' THEN
			ls_wc_no[1] = 'F01'
			ls_wc_no[2] = 'F02'
			ls_wc_no[3] = 'F03'
			ls_wc_no[4] = 'F05'
			ls_wc_no[5] = 'F06'
			ls_wc_no[6] = 'F07'
			ls_wc_no[7] = 'F08'
			ls_wc_no[8] = 'F09'
			ls_wc_no[9] = 'F10'
			ls_wc_no[10] = 'F11'
			ls_wc_no[11] = 'F12'
			ls_wc_no[12] = 'F13'
			ls_wc_no[13] = 'F15'
			ls_wc_no[14] = 'F16'
			ls_wc_no[15] = 'F17'
			ls_wc_no[16] = 'F18'
			ls_wc_no[17] = 'F19'
			ls_wc_no[18] = 'F20'	
			ls_wc_no[19] = 'F21'
			ls_wc_no[20] = 'F22'	
			ls_wc_no[21] = 'F23'		
			ls_wc_no[22] = 'F24'		
		elseif ls_wc_no[1] = 'B00' THEN			
			ls_wc_no[1] = 'B01'
			ls_wc_no[2] = 'B02'
			ls_wc_no[3] = 'C01'
		elseif ls_wc_no[1] = 'D00' THEN						
			ls_wc_no[1] = 'D01'			
		elseif ls_wc_no[1] = 'P00' THEN					
			ls_wc_no[1] = 'P01'
			ls_wc_no[2] = 'P02'
			ls_wc_no[3] = 'P03'
			ls_wc_no[4] = 'P04'
			ls_wc_no[5] = 'P05'
			ls_wc_no[6] = 'P06'
			ls_wc_no[7] = 'P07'
		elseif ls_wc_no[1] = 'S00' THEN			
			ls_wc_no[1] = 'S01'			
		elseif ls_wc_no[1] = 'U00' THEN						
			ls_wc_no[1]  = 'U01'
			ls_wc_no[2]  = 'U02'
			ls_wc_no[3]  = 'U03'
			ls_wc_no[4]  = 'U04'
			ls_wc_no[5]  = 'U05'
			ls_wc_no[6]  = 'U06'
			ls_wc_no[7]  = 'U07'
			ls_wc_no[8]  = 'U08'
			ls_wc_no[9]  = 'U09'
			ls_wc_no[10] = 'U10'
			ls_wc_no[11] = 'U11'
			ls_wc_no[12] = 'U12'
		else
			ls_wc_no[1]  = dw_6.object.wc_no[1]
		end if
		
elseif ls_area = 'T0001' then
	
		if ls_wc_no[1] = 'T00' THEN
			ls_wc_no[1] = 'T01'
			ls_wc_no[2] = 'T02'
			ls_wc_no[3] = 'T03'
			ls_wc_no[4] = 'T05'
			ls_wc_no[5] = 'T06'
			ls_wc_no[6] = 'T07'
			ls_wc_no[7] = 'T08'
			ls_wc_no[8] = 'T09'
			ls_wc_no[9] = 'T10'
			ls_wc_no[10] = 'T11'
			ls_wc_no[11] = 'T12'
			ls_wc_no[12] = 'T13'
			ls_wc_no[13] = 'T15'
			ls_wc_no[14] = 'T16'
			ls_wc_no[15] = 'T17'
			ls_wc_no[16] = 'T18'
			ls_wc_no[17] = 'T19'
			ls_wc_no[18] = 'T20'		
		elseif ls_wc_no[1] = 'H00' THEN
			ls_wc_no[1] = 'H01'
		else			
			ls_wc_no[1]  = dw_6.object.wc_no[1]
		end if	
end if	

dw_19.height = tab_1.tabpage_2.dw_17.height + 500
dw_19.x      = tab_1.tabpage_2.dw_17.x + tab_1.tabpage_2.dw_17.width/4
