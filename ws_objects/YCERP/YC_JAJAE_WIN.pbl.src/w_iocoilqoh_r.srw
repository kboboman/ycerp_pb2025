event clicked;// 재고제외

string ls_stock

if this.checked = true then
	ls_stock = " coilmst_loc_no not in ('G0086','WS00000003') AND coilmst_qcnt <> 0 "
else
	ls_stock = ""
end if

dw_1.setfilter( ls_stock )
dw_1.filter()
dw_1.groupcalc()

end event

