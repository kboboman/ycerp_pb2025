$PBExportComments$YSP수주접수헤더(2003/01/08,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=68 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=order_no dbname="sale.order_no" initial=" " )
 column=(type=datetime updatewhereclause=yes name=due_date dbname="sale.due_date" initial=" " )
 column=(type=datetime updatewhereclause=yes name=order_date dbname="sale.order_date" initial=" " )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene.scene_desc" )
 retrieve="  SELECT sale.order_no
       , sale.due_date
       , sale.order_date  
       , customer.cust_name
       , scene.scene_desc
    FROM sale
         LEFT OUTER JOIN CUSTOMER  ON sale.cust_no  = customer.cust_no  
         LEFT OUTER JOIN SCENE     ON sale.cust_no  = scene.cust_no AND sale.scene_code = scene.scene_code
   WHERE ( sale.open_close      = 'O' ) 
     AND ( sale.confirm_flag    = 'Y' ) 
     AND ( ( sale.ysp_confirm   = :as_flag ) or 
			  ( :as_flag = 'N' and sale.ysp_confirm is null) 
         ) 
     AND ( sale.area_no         = 'B0001' )   
     and ( order_date     between :ad_start and :ad_end)
   ORDER BY sale.order_date DESC   
" arguments=(("as_flag", string),("ad_start", date),("ad_end", date))  sort="order_date D order_no D " )
