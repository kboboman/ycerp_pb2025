table(column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=char(20) update=yes updatewhereclause=yes name=metrial dbname="metrial" )
 column=(type=char(30) update=yes updatewhereclause=yes name=assembly dbname="assembly" )
