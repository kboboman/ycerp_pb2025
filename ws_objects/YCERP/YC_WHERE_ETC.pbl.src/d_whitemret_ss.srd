$PBExportHeader$d_whitemret_ss.srd
$PBExportComments$품목별 재고현황(생산계획)(2001/10/16,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="553648127" )
footer(height=80 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=decimal(4) updatewhereclause=yes name=itemloc_qoh dbname="qoh" )
 column=(type=datetime updatewhereclause=yes name=cdate dbname="cdate" )
 column=(type=decimal(4) updatewhereclause=yes name=rcptqty dbname="rcptqty" )
 column=(type=decimal(4) updatewhereclause=yes name=issueqty dbname="issueqty" )
 column=(type=decimal(2) updatewhereclause=yes name=notissueqty dbname="notissueqty" )
 column=(type=long updatewhereclause=yes name=incounu_save_qty dbname="save_qty" )
 retrieve="  SELECT item_name   = groupitem.item_name
               , item_no     = incounu.item_no    
               , qa          = incounu.qa            
               , uom         = (case groupitem.uom when 'M'  then 'EA' when 'M2' then 'EA' else groupitem.uom  end) 
               , qoh         = isnull(itemloc.qoh, 0) - isnull(couteoday.rcptqty, 0) + isnull(couteoday.issueqty, 0) 
               , cdate       = convert(smalldatetime, :ad_date, 111)   
               , rcptqty     = isnull(cineoday.rcptqty, 0)             
               , issueqty    = isnull(cineoday.issueqty, 0)         
               , notissueqty = isnull(csaledet.order_qty, 0) + isnull(crout.order_qty, 0)
               , save_qty    = incounu.save_qty
    FROM incounu left outer join itemloc on incounu.item_no = itemloc.item_no
                                                       AND incounu.qa         = itemloc.qa
                                                       AND incounu.loc_no  = itemloc.loc_no
                              inner join groupitem on incounu.item_no = groupitem.item_no
                              left outer join  (
                                                            SELECT item_no  = incounu.item_no
                                                                 , qa       = incounu.qa
                                                                 , rcptqty  = isnull(sum(ineoday.rcpt_qty) , 0)
                                                                 , issueqty = isnull(sum(ineoday.issue_qty), 0)
                                                              FROM incounu  /* 담당자별 실사품목 */    
                                                                 , ineoday  /* 저장소일별 물품재고 */
                                                             WHERE incounu.user_id = :as_user
                                                               AND incounu.loc_no  = :as_loc
                                                               AND ineoday.item_no = incounu.item_no
                                                               AND ineoday.qa      = incounu.qa
                                                               AND ineoday.loc_no  = incounu.loc_no
                                                               AND cdate           = :as_date
                                                             GROUP by incounu.item_no, incounu.qa
                                                             
                                                            UNION ALL          
                                                            SELECT item_no  = '', qa = '', rcptqty = 0 , issueqty = 0 
                                                     ) cineoday on incounu.item_no = cineoday.item_no 
                                                                   AND incounu.qa = cineoday.qa 
                              left outer join (
                                                          SELECT item_no  = incounu.item_no
                                                               , qa       = incounu.qa
                                                               , rcptqty  = isnull(sum(ineoday.rcpt_qty) , 0)
                                                               , issueqty = isnull(sum(ineoday.issue_qty), 0)
                                                            FROM incounu  /* 담당자별 실사품목 */ 
                                                               , ineoday  /* 저장소일별 물품재고 */
                                                           WHERE incounu.user_id  = :as_user
                                                             AND incounu.loc_no   = :as_loc
                                                             AND ineoday.item_no  = incounu.item_no
                                                             AND ineoday.qa       = incounu.qa
                                                             AND ineoday.loc_no   = incounu.loc_no
                                                             AND cdate            > :as_date
                                                           GROUP BY incounu.item_no, incounu.qa
                                                           
                                                          UNION ALL          
                                                          SELECT item_no = '', qa = '', rcptqty = 0 , issueqty = 0 
                                                     ) couteoday on incounu.item_no  = couteoday.item_no 
                                                                      AND incounu.qa         = couteoday.qa 
                              left outer join (
                                                          SELECT item_no   = incounu.item_no
                                                               , qa        = incounu.qa
                                                               , order_qty = isnull(sum( saledet.order_qty  -  saledet.rlse_qty ), 0)
                                                            FROM incounu /* 담당자별 실사품목 */
                                                               , sale    /*판매수주헤더 */  
                                                               , saledet /*판매수주상세 */  
                                                           WHERE incounu.loc_no   = :as_loc
                                                             AND incounu.user_id  = :as_user
                                                             AND saledet.item_no  = incounu.item_no 
                                                             AND saledet.qa       = incounu.qa 
                                                             AND ( ( :as_area = 'S0001' and ( ( sale.area_no like :as_area ) or (sale.area_no = 'H0001') ) )
                                                                or ( :as_area = 'B0001' and ( sale.area_no = :as_area ) )
                                                                or ( :as_area = 'T0001' and ( sale.area_no = :as_area ) )
                                                                or ( :as_area = '%'     and ( sale.area_no like :as_area ) ) 
                                                                 )
                                                             AND sale.order_no      = saledet.order_no
                                                             AND sale.open_close    = 'O'
                                                             AND order_date        >= DATEADD(month, -2, convert(smalldatetime, :ad_date, 111))
                                                             AND order_date        <= :ad_date
                                                             AND saledet.order_qty  > saledet.rlse_qty
                                                           GROUP BY incounu.item_no, incounu.qa                                                 
                                                          UNION ALL          
                                                          SELECT item_no = '', qa = '', order_qty = 0 
                                                    ) csaledet on incounu.item_no = csaledet.item_no 
                                                                 AND incounu.qa = csaledet.qa 
                            left outer join (
                                                      SELECT item_no   = rout.assembly
                                                           , qa        = rout.assy_qa
                                                           , order_qty = isnull(sum( saledet.order_qty  -  saledet.rlse_qty ), 0)
                                                        FROM incounu  /* 담당자별 실사품목 */ 
                                                           , sale     /*판매수주헤더 */
                                                           , saledet  /*판매수주상세 */
                                                           , rout     /* 공정(제품별작업장) */
                                                       WHERE incounu.loc_no    = :as_loc
                                                         AND incounu.user_id   = :as_user
                                                         AND rout.assembly     = incounu.item_no 
                                                         AND rout.assy_qa      = incounu.qa 
                                                         AND rout.item_no     <> rout.assembly
                                                         AND saledet.item_no   = rout.item_no
                                                         AND saledet.qa        = rout.qa
                                                         AND ( ( :as_area = 'S0001' and ( ( sale.area_no like :as_area ) or (sale.area_no = 'H0001') ) )
                                                            or ( :as_area = 'B0001' and ( sale.area_no = :as_area ) )
                                                            or ( :as_area = 'T0001' and ( sale.area_no = :as_area ) )
                                                            or ( :as_area = '%'     and ( sale.area_no   like :as_area ) ) 
                                                             )
                                                         AND sale.order_no       = saledet.order_no
                                                         AND sale.open_close     = 'O'
                                                         AND sale.order_date    >= DATEADD(month, -2, convert(smalldatetime, :ad_date, 111))
                                                         AND saledet.order_qty   > saledet.rlse_qty
                                                         AND sale.order_date    <= :ad_date
                                                       GROUP BY rout.assembly, rout.assy_qa
                                                       
                                                      UNION ALL          
                                                      SELECT item_no = '', qa = '', order_qty = 0 
                                                ) crout on   incounu.item_no = crout.item_no 
                                                            AND incounu.qa = crout.qa 
   WHERE incounu.loc_no      = :as_loc
         AND incounu.user_id     = :as_user
/*  
SELECT item_name   = groupitem.item_name
       , item_no     = incounu.item_no    
       , qa          = incounu.qa            
       , uom         = (case groupitem.uom when 'M'  then 'EA' when 'M2' then 'EA' else groupitem.uom  end) 
       , qoh         = isnull(itemloc.qoh, 0) - isnull(couteoday.rcptqty, 0) + isnull(couteoday.issueqty, 0) 
       , cdate       = convert(smalldatetime, :ad_date, 111)   
       , rcptqty     = isnull(cineoday.rcptqty, 0)             
       , issueqty    = isnull(cineoday.issueqty, 0)         
       , notissueqty = isnull(csaledet.order_qty, 0) + isnull(crout.order_qty, 0)
       , save_qty    = incounu.save_qty
    FROM itemloc     /* 저장소별물품재고 */
       , groupitem   /* 물품그룹 */
       , incounu     /* 담당자별 실사품목 */  
       , (
          SELECT item_no  = incounu.item_no
               , qa       = incounu.qa
               , rcptqty  = isnull(sum(ineoday.rcpt_qty) , 0)
               , issueqty = isnull(sum(ineoday.issue_qty), 0)
            FROM incounu  /* 담당자별 실사품목 */    
               , ineoday  /* 저장소일별 물품재고 */
           WHERE incounu.user_id = :as_user
             AND incounu.loc_no  = :as_loc
             AND ineoday.item_no = incounu.item_no
             AND ineoday.qa      = incounu.qa
             AND ineoday.loc_no  = incounu.loc_no
             AND cdate           = :as_date
           GROUP by incounu.item_no, incounu.qa
           
          UNION ALL          
          SELECT item_no  = '', qa = '', rcptqty = 0 , issueqty = 0 
         ) cineoday
       , (
          SELECT item_no  = incounu.item_no
               , qa       = incounu.qa
               , rcptqty  = isnull(sum(ineoday.rcpt_qty) , 0)
               , issueqty = isnull(sum(ineoday.issue_qty), 0)
            FROM incounu  /* 담당자별 실사품목 */ 
               , ineoday  /* 저장소일별 물품재고 */
           WHERE incounu.user_id  = :as_user
             AND incounu.loc_no   = :as_loc
             AND ineoday.item_no  = incounu.item_no
             AND ineoday.qa       = incounu.qa
             AND ineoday.loc_no   = incounu.loc_no
             AND cdate            > :as_date
           GROUP BY incounu.item_no, incounu.qa
           
          UNION ALL          
          SELECT item_no = '', qa = '', rcptqty = 0 , issueqty = 0 
         ) couteoday
       , (
          SELECT item_no   = incounu.item_no
               , qa        = incounu.qa
               , order_qty = isnull(sum( saledet.order_qty  -  saledet.rlse_qty ), 0)
            FROM incounu /* 담당자별 실사품목 */
               , sale    /*판매수주헤더 */  
               , saledet /*판매수주상세 */  
           WHERE incounu.loc_no   = :as_loc
             AND incounu.user_id  = :as_user
             AND saledet.item_no  = incounu.item_no 
             AND saledet.qa       = incounu.qa 
             AND ( ( :as_area = 'S0001' and ( ( sale.area_no like :as_area ) or (sale.area_no = 'H0001') ) )
                or ( :as_area = 'B0001' and ( sale.area_no = :as_area ) )
                or ( :as_area = 'T0001' and ( sale.area_no = :as_area ) )
                or ( :as_area = '%'     and ( sale.area_no like :as_area ) ) 
                 )
             AND sale.order_no      = saledet.order_no
             AND sale.open_close    = 'O'
             AND order_date        >= DATEADD(month, -2, convert(smalldatetime, :ad_date, 111))
             AND order_date        <= :ad_date
             AND saledet.order_qty  > saledet.rlse_qty
           GROUP BY incounu.item_no, incounu.qa
           
          UNION ALL          
          SELECT item_no = '', qa = '', order_qty = 0 
         ) csaledet
       , (
          SELECT item_no   = rout.assembly
               , qa        = rout.assy_qa
               , order_qty = isnull(sum( saledet.order_qty  -  saledet.rlse_qty ), 0)
            FROM incounu  /* 담당자별 실사품목 */ 
               , sale     /*판매수주헤더 */
               , saledet  /*판매수주상세 */
               , rout     /* 공정(제품별작업장) */
           WHERE incounu.loc_no    = :as_loc
             AND incounu.user_id   = :as_user
             AND rout.assembly     = incounu.item_no 
             AND rout.assy_qa      = incounu.qa 
             AND rout.item_no     <> rout.assembly
             AND saledet.item_no   = rout.item_no
             AND saledet.qa        = rout.qa
             AND ( ( :as_area = 'S0001' and ( ( sale.area_no like :as_area ) or (sale.area_no = 'H0001') ) )
                or ( :as_area = 'B0001' and ( sale.area_no = :as_area ) )
                or ( :as_area = 'T0001' and ( sale.area_no = :as_area ) )
                or ( :as_area = '%'     and ( sale.area_no   like :as_area ) ) 
                 )
             AND sale.order_no       = saledet.order_no
             AND sale.open_close     = 'O'
             AND sale.order_date    >= DATEADD(month, -2, convert(smalldatetime, :ad_date, 111))
             AND saledet.order_qty   > saledet.rlse_qty
             AND sale.order_date    <= :ad_date
           GROUP BY rout.assembly, rout.assy_qa
           
          UNION ALL          
          SELECT item_no = '', qa = '', order_qty = 0 
         ) crout
   WHERE incounu.loc_no      = :as_loc
     AND incounu.item_no    *= itemloc.item_no
     AND incounu.qa         *= itemloc.qa
     AND incounu.loc_no     *= itemloc.loc_no
     AND incounu.user_id     = :as_user
     AND incounu.item_no    *= cineoday.item_no 
     AND incounu.qa         *= cineoday.qa 
     AND incounu.item_no    *= couteoday.item_no 
     AND incounu.qa         *= couteoday.qa 
     AND incounu.item_no    *= csaledet.item_no 
     AND incounu.qa         *= csaledet.qa 
     AND incounu.item_no    *= crout.item_no 
     AND incounu.qa         *= crout.qa 
     AND incounu.item_no     = groupitem.item_no 
*/" arguments=(("ad_date", date),("as_date", string),("as_user", string),("as_loc", string),("as_area", string))  sort="groupitem_item_name A qa A " )
