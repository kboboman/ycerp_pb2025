detail(height=88 color="536870912" )
table(column=(type=char(4) update=yes updatewhereclause=yes key=yes name=cust_no dbname="cust_no" )
 column=(type=long update=yes updatewhereclause=yes name=cust_idx dbname="cust_idx" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=long updatewhereclause=yes name=mgr_sort dbname="mgr_sort" )
 column=(type=char(50) updatewhereclause=yes name=mgr_type dbname="mgr_type" )
 column=(type=char(10) updatewhereclause=yes name=salesman dbname="salesman" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 retrieve="  SELECT cust_no      = isnull(cs.cust_no,  a.cust_no)
       , cust_idx     = isnull(cs.cust_idx, 0)
       , user_name    = a.user_name   
       , mgr_sort     = a.mgr_sort
       , mgr_type     = a.mgr_type
       , salesman     = a.salesman
       , cust_name    = a.cust_name   
    FROM customer_sort CS
         FULL JOIN (
              SELECT user_name    = login.user_name   
                   , mgr_sort     = isnull((SELECT sort FROM codemst WHERE type = 'MGR_TYPE' and use_yn = 'Y' and item_cd = customer.mgr_type),99)
                   , mgr_type     = (SELECT item_nm FROM codemst WHERE type = 'MGR_TYPE' and use_yn = 'Y' and item_cd = customer.mgr_type)
                   , cust_name    = customer.cust_name   
                   , salesman     = customer.salesman   
                   , cust_no      = customer.cust_no   
                FROM customer
                     LEFT OUTER JOIN login    ON customer.salesman = login.user_id 
               WHERE ( customer.open_close <> 'C' )        
         ) A ON cs.cust_no = a.cust_no
   WHERE ((:as_salesman   = '%' AND a.salesman  LIKE '%') OR
          (:as_salesman  <> '%' AND a.salesman     = :as_salesman)
         )
 " update="customer_sort" updatewhere=0 updatekeyinplace=no arguments=(("as_salesman", string))  sort="user_name A cust_idx A mgr_sort A cust_name A " )
