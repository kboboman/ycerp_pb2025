table(column=(type=char(12) update=yes updatewhereclause=yes key=yes name=driver dbname="docar.driver" )
 column=(type=char(10) update=yes updatewhereclause=yes name=name dbname="docar.name" )
 column=(type=char(40) update=yes updatewhereclause=yes name=cargo_name dbname="docar.cargo_name" )
