$PBExportHeader$d_cdqa_s.srd
$PBExportComments$물품규격리스트(1998/02/21,곽용덕)
release 8;
datawindow(units=0 timer_interval=0 color=67108864 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="item.item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item.item_name" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=qa dbname="item.qa" initial="000X0000X0000X00000" )
 column=(type=decimal(4) updatewhereclause=yes name=qoh dbname="item.qoh" initial="0" )
 column=(type=char(1) updatewhereclause=yes name=save_stock dbname="item.save_stock" values="	Y/	N" )
 column=(type=char(30) updatewhereclause=yes name=loc_no dbname="loc_no" )
 column=(type=char(6) updatewhereclause=yes name=source dbname="source" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="item.uom" )
 column=(type=char(1) update=yes updatewhereclause=yes name=use_flag dbname="item.use_flag" values="	C/	Y" )
 retrieve="  SELECT item.item_no,   
         item.item_name,   
         item.qa,   
         item.qoh,   
         item.save_stock,
         loc_no  = (select loc_name from location where loc_no = item.loc_no),
         source  = (case when item.source = ~"B~" then ~"구매품~"
                         when item.source = ~"M~" then ~"반제품~"
                         when item.source = ~"W~" then ~"완제품~"
                    end),
         item.uom,
         item.use_flag  
    FROM item  
   WHERE item.item_no = :as_item   
   ORDER BY item.item_no ASC,   
            item.qa ASC   
" update="item" updatewhere=1 updatekeyinplace=yes arguments=(("as_item", string))  sort="qa A " )
