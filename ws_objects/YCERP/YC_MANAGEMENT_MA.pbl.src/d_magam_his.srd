footer(height=80 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=char(4) update=yes updatewhereclause=yes name=yyyy dbname="magam_his.yyyy" )
 column=(type=char(2) update=yes updatewhereclause=yes name=mm dbname="magam_his.mm" )
 column=(type=datetime update=yes updatewhereclause=yes name=w_date dbname="magam_his.w_date" )
 column=(type=char(10) updatewhereclause=yes name=compute_0004 dbname="compute_0004" )
 column=(type=char(255) updatewhereclause=yes name=w_desc dbname="magam_his.w_desc" )
 column=(type=char(4) updatewhereclause=yes name=w_kubun dbname="w_kubun" )
 retrieve="  SELECT yyyy
       , mm
       , w_date
       , dbo.kf_NmSearch(user_id)
       , w_desc
       , w_kubun = (case when w_kubun = '00' then '수불' else w_kubun end)
    FROM magam_his  
   WHERE yyyy = :al_yyyy    
" arguments=(("al_yyyy", string))  sort="mm D " )
