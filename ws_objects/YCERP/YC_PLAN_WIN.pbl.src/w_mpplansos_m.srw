end event

type dw_6 from datawindow within tabpage_2
string tag = "d_mpplansosdet_m"
integer x = 9
integer y = 656
integer width = 4270
integer height = 1232
integer taborder = 70
string title = "d_mpplansosdet_excel"
string dataobject = "d_mpplansosdet_m"
boolean hscrollbar = true
boolean vscrollbar = true
boolean hsplitscroll = true
boolean livescroll = true
borderstyle borderstyle = stylelowered!
end type

event rbuttondown;int    li_int
string ls_sale

if row < 1 then return
this.scrolltorow(row)

m_manager NewMenu

NewMenu = CREATE m_manager
gs_print_control = ""
li_int = m_manager.m_plan.PopMenu(parentwindow().PointerX(), parentwindow().PointerY())

ls_sale = this.object.sale_no[row]
choose case gs_print_control
	case "SALE", "PROC"
		Open(w_whsaleproc_w)
		w_whsaleproc_w.sle_1.text = ls_sale
		w_whsaleproc_w.pb_1.postevent(clicked!)
end choose

end event

event getfocus;is_dwidx = "dw6"
end event

event clicked;//
is_dw = "dw_6"
GF_DWTitle2ddlb( this, ddlb_fld, ddlb_dwtitles )
GF_DWClick2Info(this, ddlb_fld, ddlb_op, sle_value, row, dwo.name, ddlb_dwtitles)

if isnull(row) OR row < 1 then RETURN

//
string ls_col, ls_tabseq, ls_protect, ls_chkmodify

choose case dwo.name
	case "no", "chk"
		cbx_col.text = " 채우기"
		cbx_col.enabled = false
		RETURN
		
	case else		
		ls_col     = dwo.name
		ls_tabseq  = this.Describe(ls_col + ".TabSequence")
		ls_protect = this.Describe(ls_col + ".Protect")
		
		em_value.text = ""		
		if ls_tabseq = "0" OR ls_protect = "1" then
			cbx_col.enabled = false
			cbx_col.text  = "채우기"
		else
			cbx_col.enabled = true
			cbx_col.text  = "채우기(" + ddlb_fld.text + ")"
		end if
end choose

//
is_coltype = this.Describe(ls_col+".ColType")
is_colname = dwo.name

// 다중선택
ls_chkmodify = this.object.chk_modify[row]
if ls_chkmodify = "Y" then
else
	WF_MULTI_SELECT(this, row)
end if

end event

