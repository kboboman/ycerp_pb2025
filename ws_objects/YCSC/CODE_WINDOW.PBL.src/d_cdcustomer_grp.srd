table(column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" values="오류	N/정상	Y/" )
 column=(type=char(4) update=yes updatewhereclause=yes key=yes name=customer_grp_cust_no dbname="customer_grp.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
