on m_retrieve.create
call super::create
this.text = "조회(&Retrieve)"
this.m_itemstatus_check=create m_itemstatus_check
this.m_item_udpate_delete=create m_item_udpate_delete
this.m_2=create m_2
this.m_-2=create m_-2
this.m_sysprogram=create m_sysprogram
this.m_sysprogram2=create m_sysprogram2
this.m_-3=create m_-3
this.m_pgm=create m_pgm
this.m_itemvsitemcostcompare=create m_itemvsitemcostcompare
this.m_cust_aroi=create m_cust_aroi
this.m_amt=create m_amt
this.Item[UpperBound(this.Item)+1]=this.m_itemstatus_check
this.Item[UpperBound(this.Item)+1]=this.m_item_udpate_delete
this.Item[UpperBound(this.Item)+1]=this.m_2
this.Item[UpperBound(this.Item)+1]=this.m_-2
this.Item[UpperBound(this.Item)+1]=this.m_sysprogram
this.Item[UpperBound(this.Item)+1]=this.m_sysprogram2
this.Item[UpperBound(this.Item)+1]=this.m_-3
this.Item[UpperBound(this.Item)+1]=this.m_pgm
this.Item[UpperBound(this.Item)+1]=this.m_itemvsitemcostcompare
this.Item[UpperBound(this.Item)+1]=this.m_cust_aroi
this.Item[UpperBound(this.Item)+1]=this.m_amt
end on

on m_retrieve.destroy
call super::destroy
destroy(this.m_itemstatus_check)
destroy(this.m_item_udpate_delete)
destroy(this.m_2)
destroy(this.m_-2)
destroy(this.m_sysprogram)
destroy(this.m_sysprogram2)
destroy(this.m_-3)
destroy(this.m_pgm)
destroy(this.m_itemvsitemcostcompare)
destroy(this.m_cust_aroi)
destroy(this.m_amt)
end on

