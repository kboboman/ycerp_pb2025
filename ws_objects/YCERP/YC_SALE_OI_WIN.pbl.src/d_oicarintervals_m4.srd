table(column=(type=char(12) updatewhereclause=yes name=username dbname="username" )
 column=(type=char(8) update=yes updatewhereclause=yes key=yes name=cardate dbname="cardate" )
 column=(type=char(12) update=yes updatewhereclause=yes key=yes name=car_no dbname="car_no" )
 column=(type=datetime update=yes updatewhereclause=yes key=yes name=req_date dbname="req_date" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=salesman dbname="salesman" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=req_seq dbname="req_seq" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=seq dbname="car_carriagedet.seq" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(11) updatewhereclause=yes name=scene_code dbname="scene_code" )
 column=(type=char(1) updatewhereclause=yes name=issuereqdet_issue_schedule dbname="issuereqdet.issue_schedule" values="직출	A/생산후 직출	B/저녁상차	J/택배//정기	K/방문	D/야간도착	I/외주(시화)	E/외주(본사)	F/유창강건	G/지점이송	H/자동작성	C/" )
 column=(type=char(14) updatewhereclause=yes name=issuereqdet_sale_no dbname="issuereqdet.sale_no" )
 column=(type=char(60) updatewhereclause=yes name=issuereqdet_rem dbname="issuereqdet.rem" )
 column=(type=char(10) updatewhereclause=yes name=accept_area dbname="issuereq.accept_area" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(14) update=yes updatewhereclause=yes key=yes name=order_no dbname="car_carriagedet.order_no" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=seq_no dbname="car_carriagedet.seq_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="car_carriagedet.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="car_carriagedet.qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="saledet.uom" )
 column=(type=decimal(2) updatewhereclause=yes name=order_qty dbname="saledet.order_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=rlse_qty dbname="rlse_qty" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=issue_qty dbname="issue_qty" )
 column=(type=decimal(3) update=yes updatewhereclause=yes name=jungrang dbname="car_carriagedet.jungrang" )
 column=(type=char(1) updatewhereclause=yes name=chk dbname="CHK" values="	Y/	N" )
 retrieve="SELECT DISTINCT username = rtrim(login_a.user_name) + cast(issuereqdet.req_seq as char(2))
       , car_carriagedet.cardate       cardate         /* Key1 */
       , car_carriagedet.car_no       car_no       /* Key1 */
       , car_carriagedet.req_date     req_date        /* Key1 */
       , car_carriagedet.salesman    salesman         /* Key1 */
       , car_carriagedet.req_seq       req_seq       /* Key1 */
	  , car_carriagedet.seq              seq
       , issuereqdet.cust_no             cust_no     /* Key1 */
       , issuereqdet.scene_code        scene_code  /* Key1 */
       , issuereqdet.issue_schedule   issue_schedule
       , issuereqdet.sale_no                sale_no       
       , issuereqdet.rem                      rem      
       , issuereq.accept_area             accept_area
       , groupitem.item_name             item_name
       , car_carriagedet.order_no order_no
       , car_carriagedet.seq_no seq_no
       , car_carriagedet.item_no item_no
       , car_carriagedet.qa qa
       , saledet.uom uom
       , saledet.order_qty order_qty
       , saledet.rlse_qty rlse_qty
/*       , qty  = saledet.order_qty - saledet.rlse_qty*/
	  , car_carriagedet.issue_qty issue_qty
       , round(car_carriagedet.jungrang,0,1)  jungrang
       , 'N' CHK
    FROM issuereq  with(nolock)    
         LEFT OUTER JOIN issuereqdet   with(nolock)  ON issuereq.req_date = issuereqdet.req_date AND issuereq.salesman = issuereqdet.salesman AND issuereq.req_seq = issuereqdet.req_seq    
         LEFT OUTER JOIN login login_a  with(nolock)  ON issuereq.salesman    = login_a.user_id 
         LEFT OUTER JOIN login login_b   with(nolock) ON issuereq.accept_user = login_b.user_id  
	    LEFT OUTER JOIN car_carriagedet on issuereqdet.req_date = car_carriagedet.req_date and issuereqdet.salesman = car_carriagedet.salesman and issuereqdet.req_seq = car_carriagedet.req_seq and  issuereqdet.seq = car_carriagedet.seq
         LEFT OUTER JOIN saledet   with(nolock) ON car_carriagedet.order_no = saledet.order_no and car_carriagedet.seq_no = saledet.seq_no
         LEFT OUTER JOIN groupitem  with(nolock)  ON car_carriagedet.item_no = groupitem.item_no
   WHERE ( issuereq.confirm_flag    = 'Y' )
     AND ( issuereqdet.req_flag     = 'A' )
     AND ( car_carriagedet.cardate = :as_date)
     AND ( car_carriagedet.car_no =  :as_car_no)" update="car_carriagedet" updatewhere=0 updatekeyinplace=no arguments=(("as_date", string),("as_car_no", string))  sort="req_date A req_seq D issuereqdet_sale_no A seq_no A " )
