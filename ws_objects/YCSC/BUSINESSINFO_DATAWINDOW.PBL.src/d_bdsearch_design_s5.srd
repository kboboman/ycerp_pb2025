table(column=(type=char(4) updatewhereclause=yes key=yes name=comcode dbname="bdcom.comcode" )
 column=(type=char(60) updatewhereclause=yes name=address dbname="bdcom.address" )
 column=(type=char(10) updatewhereclause=yes name=damdang dbname="bdcom.damdang" )
 column=(type=char(15) updatewhereclause=yes name=phone dbname="bdcom.phone" )
 column=(type=char(30) updatewhereclause=yes name=comname dbname="bdcom.comname" )
 column=(type=char(15) updatewhereclause=yes name=fax_no dbname="bdcom.fax_no" )
 column=(type=char(60) updatewhereclause=yes name=rem1 dbname="rem1" )
 column=(type=char(60) updatewhereclause=yes name=rem2 dbname="rem2" )
 column=(type=char(60) updatewhereclause=yes name=rem3 dbname="rem3" )
 column=(type=long updatewhereclause=yes name=per_cnt dbname="bdcom.per_cnt" )
 retrieve="  SELECT bdcom.comcode,   
         bdcom.address,   
         bdcom.damdang,   
         bdcom.phone,   
         bdcom.comname,   
         bdcom.fax_no,   
         bdcom.rem1,   
         bdcom.rem2,   
         bdcom.rem3,   
         bdcom.per_cnt  
    FROM bdcom  
   WHERE bdcom.comname like :as_cd 
	  and	bdcom.comcode like 'B%'   
" update="bdcom" updatewhere=0 updatekeyinplace=no arguments=(("as_cd", string)) )
