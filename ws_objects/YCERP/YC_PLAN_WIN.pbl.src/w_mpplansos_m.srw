type cbx_metrial from checkbox within tabpage_2
integer x = 1701
integer y = 8
integer width = 352
integer height = 60
integer textsize = -9
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
long textcolor = 128
long backcolor = 67108864
string text = "소재체크"
boolean checked = true
end type

event clicked;//
string  ls_itemno, ls_qa3, ls_metrial
long    ll_row
integer li_ret

if this.checked = false then RETURN

li_ret = MessageBox("확인","소재신청 내역중 품목과 두께가 일치하는 소재를 체크 하시겠습니까?",Exclamation!, YesNoCancel!, 1)
if li_ret = 3 then RETURN

dw6.setredraw( false )
for ll_row = 1 to dw6.rowcount()
	ls_itemno    = dw6.object.item_no[ll_row]
	ls_qa3       = LeftA(dw6.object.qa[ll_row],3)
	
	// 소재체크
	if cbx_metrial.checked = true then
		SELECT TOP 1 metrial INTO :ls_metrial 
		  FROM itemsosdet 
       WHERE item_no = :ls_itemno AND left(qa,3) = :ls_qa3;
		if isnull(ls_metrial) OR ls_metrial = "" then
		else
			if li_ret = 1 then
				dw6.object.metrial[ll_row] = ls_metrial	// 소재
			else
				dw6.object.metrial[ll_row] = ls_qa3			// 두께
			end if
		end if
	end if
next
dw6.setredraw( true )
this.checked = false

end event

