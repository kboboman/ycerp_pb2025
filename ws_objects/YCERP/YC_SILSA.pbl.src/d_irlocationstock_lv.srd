footer(height=80 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=loc_no dbname="loc_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_nm dbname="item_nm" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=decimal(2) updatewhereclause=yes name=balbf_qty dbname="balbf_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=rqty dbname="rqty" )
 column=(type=decimal(2) updatewhereclause=yes name=iqty dbname="iqty" )
 retrieve="SELECT loc_no    = a.loc_no  
     , item_no   = a.item_no 
     , item_nm   = b.item_name
     , qa        = a.qa      
     , balbf_qty = a.balbf_qty
     , rqty      = a.rqty
     , iqty      = a.iqty
  FROM (
       SELECT loc_no    = a.loc_no  
            , item_no   = a.item_no 
            , qa        = a.qa      
            , balbf_qty = sum(a.balbf_qty)
            , rqty      = sum(a.rqty)
            , iqty      = sum(a.iqty)
         FROM (
              /* 지점재고(전월) */
              SELECT loc_no        = a.loc_no
                   , item_no       = a.item_no
                   , qa            = a.qa
                   , uom           = a.uom
                   , balbf_qty     = a.balbf_qty + (case when :as_mm = '01' then 0
                                                         when :as_mm = '02' then R01 - I01
                                                         when :as_mm = '03' then R02 - I02
                                                         when :as_mm = '04' then R03 - I03
                                                         when :as_mm = '05' then R04 - I04
                                                         when :as_mm = '06' then R05 - I05
                                                         when :as_mm = '07' then R06 - I06
                                                         when :as_mm = '08' then R07 - I07
                                                         when :as_mm = '09' then R08 - I08
                                                         when :as_mm = '10' then R09 - I09
                                                         when :as_mm = '11' then R10 - I10
                                                         when :as_mm = '12' then R11 - I11
                                                    end)
                   , rqty = 0
                   , iqty = 0
                FROM v_ineoymloc A   WITH (NOLOCK)
               WHERE a.loc_no      = :as_locno
                 AND a.yyyy        = :as_yyyy
       
              /* 지점재고(당월) */
              UNION ALL
              SELECT loc_no    = a.loc_no
                   , item_no   = a.item_no
                   , qa        = a.qa
                   , uom       = ''
                   , balbf_qty = 0
                   , rqty       = a.rcpt_qty
                   , iqty       = a.issue_qty
                FROM ( 
                     SELECT loc_no        = a.loc_no
                          , inaudit_time  = a.inaudit_time
                          , inaudit_date  = a.inaudit_date
                          , item_no       = a.inaudit_item
                          , qa            = a.qa
                          , inaudit_type  = a.inaudit_type
                          , order_no      = a.order_no
                          , rcpt_qty      = a.rcpt_qty
                          , issue_qty     = a.issue_qty
                          , user_id       = a.user_id
                          , destination   = a.destination
                          , tbl_name      = 'INAUDIT'
                       FROM inaudit A    WITH (NOLOCK)
                      WHERE a.loc_no        = :as_locno
                        AND convert(char(10),a.inaudit_date,111) between :as_sdate and :as_edate
                     
                     UNION ALL
                     SELECT loc_no        = a.loc_no
                          , inaudit_time  = a.inaudit_time
                          , inaudit_date  = a.inaudit_date
                          , item_no       = a.inaudit_item
                          , qa            = a.qa
                          , inaudit_type  = a.inaudit_type
                          , order_no      = a.order_no
                          , rcpt_qty      = a.rcpt_qty
                          , issue_qty     = a.issue_qty
                          , user_id       = a.user_id
                          , destination   = a.destination
                          , tbl_name      = 'INAUDIT_LOC'
                       FROM inaudit_loc A   WITH (NOLOCK)
                      WHERE a.loc_no        = :as_locno
                        AND convert(char(10),a.inaudit_date,111) between :as_sdate and :as_edate
                     ) A
              ) A 
        GROUP BY a.loc_no, a.item_no, a.qa
       ) A
       LEFT OUTER JOIN groupitem B  ON a.item_no = b.item_no
" arguments=(("as_locno", string),("as_yyyy", string),("as_mm", string),("as_sdate", string),("as_edate", string))  sort="loc_no A item_nm A qa A " )
