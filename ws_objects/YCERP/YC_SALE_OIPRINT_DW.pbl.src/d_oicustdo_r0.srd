table(column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=char(30) updatewhereclause=yes name=team_team_name dbname="team_name" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_cash dbname="do_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_rate dbname="do_rate" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_total dbname="do_total" )
 column=(type=char(1) updatewhereclause=yes name=do_shipamt_case dbname="shipamt_case" )
 column=(type=char(50) updatewhereclause=yes name=category dbname="category" )
 column=(type=char(10) updatewhereclause=yes name=dodet_item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=dodet_qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=dodet_uom dbname="uom" )
 column=(type=decimal(2) updatewhereclause=yes name=dodet_ship_qty dbname="ship_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=c_acc_qty dbname="c_acc_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=dodet_price dbname="price" )
 column=(type=decimal(8) updatewhereclause=yes name=amt dbname="amt" )
 column=(type=decimal(4) updatewhereclause=yes name=dodet_rate_cash dbname="rate_cash" )
 column=(type=char(14) updatewhereclause=yes name=do_do_no dbname="do_no" )
 column=(type=char(10) updatewhereclause=yes name=do_date dbname="do_date" )
 column=(type=char(30) updatewhereclause=yes name=ship_flag dbname="ship_flag" )
 column=(type=decimal(0) updatewhereclause=yes name=do_ship_amount dbname="ship_amount" )
 column=(type=char(14) updatewhereclause=yes name=dodet_sale_no dbname="sale_no" )
 column=(type=decimal(10) updatewhereclause=yes name=dan dbname="dan" )
 retrieve="  SELECT user_name    = f.user_name
       , cust_no      = b.cust_no   
       , cust_name    = d.cust_name   
       , scene_desc   = e.scene_desc   
       , team_name    = h.team_name
       , user_name    = f.user_name
       , do_cash      = b.do_cash   
       , do_rate      = b.do_rate   
       , do_total     = b.do_total   
       , shipamt_case = b.shipamt_case   
       , category     = (case when g.category is null then '99) 미분류' else cm.item_nm end)
       , item_no      = a.item_no   
       , item_name    = c.item_name   
       , qa           = a.qa   
       , uom          = a.uom   
       , ship_qty     = a.ship_qty   
       , c_acc_qty    = round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1)
       , price        = a.price   
       , amt          = round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty) * a.price,2,1)
       , rate_cash    = a.rate_cash
       , do_no        = b.do_no   
       , do_date      = convert(char(10),b.do_date,111)
       , ship_flag    = dbo.uf_getshipflag(b.ship_flag)   
       , ship_amount  = b.ship_amount   
       , sale_no      = a.sale_no
       , dan          = (case when a.uom = 'M'  
                              then i.thick * i.width * (case when substring(i.item_no,3,1) = 'A' then 2.72 else 8.12 end) / 1000
                              else 0
                         end)
    FROM dodet     A      
         LEFT OUTER JOIN do        B ON a.do_no     = b.do_no
         LEFT OUTER JOIN groupitem C ON a.item_no   = c.item_no
         LEFT OUTER JOIN customer  D ON b.cust_no   = d.cust_no
         LEFT OUTER JOIN scene     E ON b.spot_code = e.scene_code  
         LEFT OUTER JOIN login     F ON d.salesman  = f.user_id  
         LEFT OUTER JOIN itemtop10 G ON a.item_no   = g.item_no  
         LEFT OUTER JOIN team      H ON f.team_code = h.team_code
         LEFT OUTER JOIN itemcoil  I ON a.item_no   = i.item_no  AND substring(a.qa,1,13) = i.qa and i.seq_no = 1
         LEFT OUTER JOIN (
              SELECT item_cd, item_nm FROM codemst with (nolock) WHERE type = 'ITEMTOP10' AND use_yn = 'Y'
         ) CM ON g.category = cm.item_cd
  /*WHERE ( b.do_date  BETWEEN :as_sdate + ' 00:00:00.000' AND :as_edate + ' 23:59:59.999' )*/
/*      WHERE ( convert(char(10), b.do_date,111)  BETWEEN :as_sdate  AND :as_edate  )*/
WHERE ( convert(char(10), b.do_date ,111)  BETWEEN :as_sdate  AND :as_edate )
     AND ( b.do_no       LIKE :as_area )
     AND ((:as_custno    = '%'  ) OR 
          (:as_custno    = 'ALL') OR 
          (:as_custno   <> 'ALL' AND b.cust_no  = :as_custno)
         )
     AND ((:as_salesman  = '%'  ) OR
          (:as_salesman <> '%'   AND d.salesman = :as_salesman)
         )
" arguments=(("as_area", string),("as_custno", string),("as_salesman", string),("as_sdate", string),("as_edate", string)) )
