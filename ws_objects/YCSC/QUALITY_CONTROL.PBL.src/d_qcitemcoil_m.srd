 column=(type=char(10) update=yes updatewhereclause=yes name=supp_no dbname="supp_no" values="(주)금강강업	M0045/은성강업	Z0076/조양종합금속(주)	M0031/창광스틸	P0057/창화철강(주)시화	P0015/" )
 column=(type=char(20) update=yes updatewhereclause=yes name=rem1 dbname="rem1" )
 column=(type=char(50) update=yes updatewhereclause=yes name=rem2 dbname="rem2" )
 retrieve="  SELECT itemcoil.item_no     
       , itemcoil.qa          
       , itemcoil.seq_no      
       , itemcoil.coil_item   
       , itemcoil.thick       
       , itemcoil.width       
       , itemcoil.weight       
       , itemcoil.wc_place    
       , itemcoil.supp_no     
       , itemcoil.rem1        
       , itemcoil.rem2  
    FROM itemcoil
" update="itemcoil" updatewhere=0 updatekeyinplace=no  sort="item_no A qa A seq_no A " )
