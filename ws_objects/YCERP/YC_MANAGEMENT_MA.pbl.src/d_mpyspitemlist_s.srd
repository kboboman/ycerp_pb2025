$PBExportHeader$d_mpyspitemlist_s.srd
$PBExportComments$YSP TYPE별 생산리스트(일별)(2003/06/02,정갑용)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=char(60) updatewhereclause=yes name=group1 dbname="group1" )
 column=(type=char(60) updatewhereclause=yes name=group2 dbname="group2" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(14) updatewhereclause=yes name=mon dbname="mon" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=decimal(4) updatewhereclause=yes name=m2_qty dbname="m2_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=make_qty dbname="make_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=sum_qty dbname="sum_qty" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(6) updatewhereclause=yes name=flag dbname="flag" )
 retrieve="  SELECT yspgroup.group1       
       , yspgroup.group2       
       , groupitem.item_name   
       , mon     = right(convert(char(4), datepart(year, sfcday.sfc_date)),2) + 
               '/' + right('00' + rtrim(convert(char(2), datepart(month, sfcday.sfc_date))) ,2) +
               '/' + right('00' + rtrim(convert(char(2), datepart(day,   sfcday.sfc_date))) ,2)
       , qa      = sfcday.assembly_qa   
       , m2_qty  = dbo.UF_GetYSPM2( sfcday.assembly, sfcday.assembly_qa, 1.0 )
       , sfcday.make_qty
       , sum_qty = dbo.UF_GetYSPM2( sfcday.assembly, sfcday.assembly_qa, sfcday.make_qty )
       , item_no = sfcday.assembly
       , flag    = '작업장'
    FROM sfcday      
       , groupitem
       , itemcalc 
       , UF_YSPGroupTBL() yspgroup
   WHERE ( sfcday.assembly         = yspgroup.item_no  )                        
     AND ( sfcday.assembly         = itemcalc.item_no  )                        
     AND ( sfcday.assembly         = groupitem.item_no )                        
     AND ( sfcday.sfc_date   between :ad_start and :ad_end  + ' 23:59:59:999') 
     AND ((:as_area   = '%') OR
          (:as_area  <> '%' AND sfcday.area_no LIKE :as_area)
         )
     AND ( sfcday.wc_no            = 'Y05'   )
     
  UNION ALL
  SELECT yspgroup.group1   
       , yspgroup.group2   
       , groupitem.item_name   
       , mon     = right(convert(char(4), datepart(year, insp.insp_date)),2) + 
               '/' + right('00' + rtrim(convert(char(2), datepart(month, insp.insp_date))) ,2) +
               '/' + right('00' + rtrim(convert(char(2), datepart(day,   insp.insp_date))) ,2)
       , inspdet.qa 
       , m2_qty  = dbo.UF_GetYSPM2( inspdet.item_no, inspdet.qa, 1.0 )
       , inspdet.rcpt_qty
       , sum_qty = dbo.UF_GetYSPM2( inspdet.item_no, inspdet.qa, inspdet.rcpt_qty )
       , inspdet.item_no
       , flag    = '외주'
    FROM insp        
       , inspdet     
       , groupitem
       , itemcalc 
       , supp     
       , UF_YSPGroupTBL() yspgroup
   WHERE ( inspdet.item_no        = yspgroup.item_no  )      
     AND ( inspdet.item_no        = itemcalc.item_no  )      
     AND ( inspdet.item_no        = groupitem.item_no )      
     AND ( inspdet.insp_no        = insp.insp_no      )     
     AND ( insp.supp_no           = supp.supp_no      )     
     AND ( supp.yspsub_flag       = 'Y'               )     
     AND ( insp.insp_date   between :ad_start and :ad_end ) 
     AND ((:as_area   = '%') OR
          (:as_area  <> '%' AND insp.area_no LIKE :as_area)
         )
" arguments=(("as_area", string),("ad_start", date),("ad_end", date))  sort="group1 A group2 A item_name A qa A mon A " )
