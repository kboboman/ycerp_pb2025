$PBExportHeader$d_ocshipburden_s.srd
$PBExportComments$운반비부담내역서 (2002/08/28,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="10789024" )
detail(height=84 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=do_do_no dbname="do.do_no" )
 column=(type=decimal(0) updatewhereclause=yes name=ship_amount dbname="do.ship_amount" )
 column=(type=char(60) updatewhereclause=yes name=do_driver dbname="do.driver" )
 column=(type=char(1) updatewhereclause=yes name=do_shipamt_case dbname="do.shipamt_case" values="현금	C/외상	R/" )
 column=(type=char(4) updatewhereclause=yes name=do_cust_no dbname="do.cust_no" )
 column=(type=char(10) updatewhereclause=yes name=docar_name dbname="docar.name" )
 column=(type=char(40) updatewhereclause=yes name=docar_cargo_name dbname="docar.cargo_name" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 column=(type=char(1) updatewhereclause=yes name=ship_close dbname="do.ship_close" values="	C/	O" )
 column=(type=datetime updatewhereclause=yes name=do_ship_date dbname="do.ship_date" )
 column=(type=char(10) updatewhereclause=yes name=close_user dbname="do.close_user" )
 column=(type=char(10) updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=char(10) updatewhereclause=yes name=edate dbname="edate" )
 column=(type=char(180) updatewhereclause=yes name=sale_no dbname="sale_no" )
 retrieve="  SELECT do.do_no             
       , do.ship_amount       
       , do.driver            
       , do.shipamt_case      
       , do.cust_no           
       , docar.name           
       , docar.cargo_name     
       , customer.cust_name   
       , scene.scene_desc     
       , do.ship_close        
       , do.ship_date         
       , do.close_user     
       , sdate   = (case when :as_sdate = '' then '          ' else :as_sdate end)
       , edate   = (case when :as_edate = '' then '          ' else :as_edate end)
       , sale_no = DBO.uf_getdosaleno(do.do_no)
    FROM do with(nolock) inner join customer with(nolock) on do.cust_no    = customer.cust_no
                      left outer join docar with(nolock) on do.driver       = docar.driver
                      left outer join scene with(nolock) on do.spot_code  = scene.scene_code
     WHERE ( ( do.do_no               like :as_area + '%'        ) AND  
           ( convert(char(10),do.ship_date,111)  between :as_sdate and :as_edate ) AND  
           ( do.ship_flag              = 'B'                   ) AND  
           ( do.ship_close          like :as_flag              ) AND  
           ( do.cust_no             like :as_cust              ) AND  
           ( do.driver              like :as_drv               ) AND  
           ( (:as_amt =  '1' or ( :as_amt = '2' and ship_amount <> 0 ) or  ( :as_amt = '3' and ship_amount = 0 )  ) ) 
         )
/*
    FROM customer   
       , do         
       , scene      
       , docar  
   WHERE ( do.spot_code               *= scene.scene_code )   
     AND ( do.driver                  *= docar.driver     )   
     AND ( do.cust_no                  = customer.cust_no )   
     AND ( ( do.do_no               like :as_area + '%'        ) AND  
           ( convert(char(10),do.ship_date,111)  between :as_sdate and :as_edate ) AND  
           ( do.ship_flag              = 'B'                   ) AND  
           ( do.ship_close          like :as_flag              ) AND  
           ( do.cust_no             like :as_cust              ) AND  
           ( do.driver              like :as_drv               ) AND  
           ( (:as_amt =  '1' or ( :as_amt = '2' and ship_amount <> 0 ) or  ( :as_amt = '3' and ship_amount = 0 )  ) ) 
         )

*/         
  UNION ALL
  
  SELECT ask_head.ask_no             
       , ask_head.ship_amount        
       , ask_head.driver             
       , shipamt_case = ''        
       , cust_no      = ''           
       , docar.name                  
       , docar.cargo_name            
       , cust_name    = '(주)유창'  
       , scene_desc   = '시화사업장'
       , ask_head.ship_close         
       , ask_head.ship_date          
       , ask_head.close_user      
       , sdate   = (case when :as_sdate = '' then '          ' else :as_sdate end)
       , edate   = (case when :as_edate = '' then '          ' else :as_edate end)
       , sale_no      = ''
        FROM ask_head with(nolock) left outer join docar with(nolock) on ask_head.driver  = docar.driver
    WHERE ( ( :as_area                  = 'S'          ) AND
           ( convert(char(10),ask_head.ship_date,111)  between :as_sdate and :as_edate ) AND  
           ( ask_head.ship_close    like :as_flag     ) AND  
           ( :as_cust                  = '%'          ) AND  
           ( ask_head.driver        like :as_drv      ) AND  
           ( (:as_amt =  '1' or ( :as_amt = '2' and ship_amount <> 0 ) or  ( :as_amt = '3' and ship_amount = 0 )  ) ) 
         )
/*
    FROM ask_head,   
         docar
   WHERE ( ask_head.driver            *= docar.driver )   
     AND ( ( :as_area                  = 'S'          ) AND
           ( convert(char(10),ask_head.ship_date,111)  between :as_sdate and :as_edate ) AND  
           ( ask_head.ship_close    like :as_flag     ) AND  
           ( :as_cust                  = '%'          ) AND  
           ( ask_head.driver        like :as_drv      ) AND  
           ( (:as_amt =  '1' or ( :as_amt = '2' and ship_amount <> 0 ) or  ( :as_amt = '3' and ship_amount = 0 )  ) ) 
         )


*/
         
  UNION ALL
  
  SELECT dbo.uf_getdatestring(doshipetc.etc_date)
       , doshipetc.ship_amount    
       , doshipetc.driver         
       , doshipetc.shipamt_case   
       , doshipetc.cust_no        
       , doshipetc.drv_name       
       , doshipetc.cargo_name     
       , customer.cust_name       
       , scene.scene_desc         
       , doshipetc.ship_close     
       , doshipetc.etc_date       
       , doshipetc.user_id     
       , sdate   = (case when :as_sdate = '' then '          ' else :as_sdate end)
       , edate   = (case when :as_edate = '' then '          ' else :as_edate end)
       , sale_no = doshipetc.sale_no
    FROM doshipetc with(nolock) inner join customer with(nolock) on doshipetc.cust_no = customer.cust_no
                                                       left outer join scene with(nolock) on  doshipetc.scene_code    = scene.scene_code
    WHERE   ( ( doshipetc.etc_area     like :as_area + '%'        ) AND  
           ( convert(char(10),doshipetc.etc_date,111)  between :as_sdate and :as_edate ) AND  
           ( doshipetc.ship_flag       = 'B'                   ) AND  
           ( doshipetc.etc_flag     like :as_flag              ) AND  
           ( doshipetc.cust_no      like :as_cust              ) AND  
           ( doshipetc.driver       like :as_drv               ) AND  
           ( (:as_amt =  '1' or ( :as_amt = '2' and ship_amount <> 0 ) or  ( :as_amt = '3' and ship_amount = 0 )  ) ) 
         )
/*
    FROM customer    
       , doshipetc   
       , scene  
   WHERE ( doshipetc.scene_code       *= scene.scene_code )   
     AND ( doshipetc.cust_no           = customer.cust_no )   
     AND ( ( doshipetc.etc_area     like :as_area + '%'        ) AND  
           ( convert(char(10),doshipetc.etc_date,111)  between :as_sdate and :as_edate ) AND  
           ( doshipetc.ship_flag       = 'B'                   ) AND  
           ( doshipetc.etc_flag     like :as_flag              ) AND  
           ( doshipetc.cust_no      like :as_cust              ) AND  
           ( doshipetc.driver       like :as_drv               ) AND  
           ( (:as_amt =  '1' or ( :as_amt = '2' and ship_amount <> 0 ) or  ( :as_amt = '3' and ship_amount = 0 )  ) ) 
         )
*/" arguments=(("as_area", string),("as_sdate", string),("as_edate", string),("as_flag", string),("as_cust", string),("as_drv", string),("as_amt", string))  sort="customer_cust_name A scene_scene_desc A do_do_no A " )
