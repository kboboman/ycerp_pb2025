table(column=(type=char(60) updatewhereclause=yes name=item_item_name dbname="GroupItem.item_name" )
 column=(type=char(17) update=yes updatewhereclause=yes key=yes name=order_no dbname="sfcuse.order_no" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=wc_no dbname="sfcuse.wc_no" )
 column=(type=datetime update=yes updatewhereclause=yes key=yes name=use_date dbname="sfcuse.use_date" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="sfcuse.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=qa dbname="sfcuse.qa" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="sfcuse.uom" )
 column=(type=decimal(4) update=yes updatewhereclause=yes key=yes name=use_qty dbname="sfcuse.use_qty" initial="0" )
 column=(type=char(20) update=yes updatewhereclause=yes name=coil_no dbname="sfcuse.coil_no" )
 column=(type=char(4) update=yes updatewhereclause=yes name=color dbname="sfcuse.color" )
 column=(type=char(4) update=yes updatewhereclause=yes name=color_type dbname="sfcuse.color_type" values="분체	분체/액체	액체/" )
 column=(type=char(10) update=yes updatewhereclause=yes name=loc_no dbname="sfcuse.loc_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=coil_type dbname="sfcuse.coil_type" initial="N" )
 column=(type=long update=yes updatewhereclause=yes name=sfcuse_cnt dbname="sfcuse.cnt" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=sfcuse_unit_qty dbname="sfcuse.unit_qty" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=sfcuse_mod_qty dbname="sfcuse.mod_qty" initial="0" )
 column=(type=char(1) update=yes updatewhereclause=yes name=sfcuse_division dbname="sfcuse.division" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=sfcuse_mod_len dbname="sfcuse.mod_len" initial="0" )
 column=(type=long update=yes updatewhereclause=yes name=sfcuse_seq dbname="sfcuse.seq" )
 column=(type=long updatewhereclause=yes name=qcnt dbname="qcnt" )
 column=(type=decimal(1) update=yes updatewhereclause=yes name=sfcuse_wid dbname="sfcuse.wid" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=rem_qty dbname="sfcuse.rem_qty" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=rem_len dbname="sfcuse.rem_len" initial="0" )
 column=(type=char(20) update=yes updatewhereclause=yes name=rem_lot dbname="sfcuse.rem_lot" )
 column=(type=char(20) update=yes updatewhereclause=yes name=rem_qa dbname="sfcuse.rem_qa" )
 column=(type=long update=yes updatewhereclause=yes name=rem_cnt dbname="sfcuse.rem_cnt" )
 column=(type=char(2) updatewhereclause=yes name=etc_no dbname="etc_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=area_no dbname="sfcuse.area_no" )
 column=(type=char(50) updatewhereclause=yes name=item_paint_no dbname="item.paint_no" )
 column=(type=char(50) updatewhereclause=yes name=item_paint_name dbname="item.paint_name" )
 column=(type=char(50) updatewhereclause=yes name=item_paint_company dbname="item.paint_company" )
 retrieve="  SELECT groupitem.item_name,   
         sfcuse.order_no,   
         sfcuse.wc_no,   
         sfcuse.use_date,   
         sfcuse.item_no,   
         sfcuse.qa,   
         sfcuse.uom,   
         sfcuse.use_qty,   
         sfcuse.coil_no,   
         sfcuse.color,   
         sfcuse.color_type,   
         sfcuse.loc_no,   
         sfcuse.coil_type,   
         sfcuse.cnt,   
         sfcuse.unit_qty,   
         sfcuse.mod_qty,   
         sfcuse.division,   
         sfcuse.mod_len,   
         sfcuse.seq,   
         qcnt = 0,   
         sfcuse.wid,   
         sfcuse.rem_qty,   
         sfcuse.rem_len,   
         sfcuse.rem_lot,   
         sfcuse.rem_qa,   
         sfcuse.rem_cnt,   
         etc_no = '  ',   
         sfcuse.area_no,
	    item.paint_no,
	    item.paint_name,
	    item.paint_company
    FROM sfcuse inner join  groupitem on sfcuse.item_no    = groupitem.item_no
					  inner join  item on sfcuse.item_no  = item.item_no and sfcuse.qa  = item.qa
	where ( sfcuse.area_no    = :as_area  ) 
     AND ( convert( char(10), sfcuse.use_date,112 )   = :arg_date ) 
/*	AND sfcuse.use_date between :arg_date + ' 00:00:00:000'  and :arg_date + ' 23:59:59:999' */
     AND ( sfcuse.wc_no      = :arg_wc   ) 

" update="sfcuse" updatewhere=0 updatekeyinplace=no arguments=(("as_area", string),("arg_date", string),("arg_wc", string))  sort="order_no A " )
