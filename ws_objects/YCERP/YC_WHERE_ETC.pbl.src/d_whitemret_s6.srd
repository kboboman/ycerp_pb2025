$PBExportComments$품목별 재고현황(발주현황)(2004/09/09,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no  crosstab.dynamic = yes grid.lines=0 grid.columnmove=no selected.mouse=no )
header[1](height=0 color="536870912" )
header[2](height=76 color="536870912" )
header[3](height=76 color="536870912" )
summary(height=72 color="536870912" )
footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=supp_name dbname="supp_name" )
 column=(type=char(20) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=number updatewhereclause=yes name=oqty dbname="oqty" )
 column=(type=number updatewhereclause=yes name=rqty dbname="rqty" )
 retrieve="  SELECT supp.supp_no,supp.supp_name, purdet.item_no, groupitem.item_name, 
			cdate = convert(char(10),cday.ddate,111), oqty = sum(purdet.order_qty), rqty = sum(purdet.rlse_qty)  
    FROM pur,   
         purdet,   
         groupitem,   
         supp,
			dbo.uf_getdaytbl(:ad_start, :ad_end) cday  
   WHERE ( pur.order_no = purdet.order_no ) and  
         ( purdet.item_no = groupitem.item_no ) and  
         ( pur.supp_no = supp.supp_no ) and
         ( ( cday.ddate = pur.order_date ) AND  
         ( pur.order_date between :ad_start and :ad_end ) AND  
         ( pur.supp_no like :as_supp ) AND  
         ( pur.po_print = 'Y' ) AND  
         ( pur.open_close = 'O' ) )  AND  
         ( ( pur.order_no like :as_area + ~"%~" ) or
			  ( :as_area = 'S' and pur.order_no like 'PUR%')  ) 
group by  supp.supp_no,supp.supp_name, purdet.item_no, groupitem.item_name, cday.ddate
order by  supp.supp_no,supp.supp_name, purdet.item_no, groupitem.item_name, cday.ddate
" arguments=(("as_area", string),("as_supp", string),("ad_start", date),("ad_end", date))  sort="supp_name A item_name A " )
group(level=1 header.height=0 trailer.height=72 by=("supp_name" ) header.color="536870912" trailer.color="536870912" )
