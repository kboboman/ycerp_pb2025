public function boolean wf_move7 ();long    ll_rowcount1,ll_cnt,ll_find,ll_row,ll_count, ll_cnt2
string  ls_plan,ls_order,ls_uom,ls_supp,ls_qa,ls_item,ls_subcon,ls_qa1
decimal {4} lr_cost
dec{6}  ld_rate

dw_1.accepttext()
dw10.accepttext()
ll_count = 0

setnull(ls_supp)
for ll_cnt2 = 1 to dw12.rowcount()
	dw12.scrolltorow(ll_cnt2)
	ll_count ++
	if dw12.isselected(ll_cnt2) then
		for ll_cnt = 1 to dw10.rowcount()
			ls_supp = trim(dw10.object.coilorder_supp_no[ll_cnt])
			exit
		next
	end if
next

if ll_count = 0 then
	messagebox('오류','외주스리팅가공 대상물품을 선택하십시요.',exclamation!)
	return false
end if

if dw_1.rowcount() < 1 then 
	pb_insert.triggerevent(clicked!)
	dw_1.object.supp_no[1] = ls_supp
else
	if ls_supp <> '' and not isnull(ls_supp) then
		dw_1.object.supp_no[1] = ls_supp
	end if
end if	

ls_supp = trim(dw_1.object.supp_no[1])
if isnull(ls_supp) or ls_supp=""  then
	MessageBox("오류","발주헤더에 거래처를 입력하십시오.", Exclamation!)
	dw12.selectrow(0,false)
	return false
end if	

dw_1.object.subcon[1] = 'C' //외주스리팅가공
ll_rowcount1 = dw3.rowcount()

for ll_cnt = 1 to dw10.rowcount()	
	ls_plan = trim(dw10.object.coilsliting_order_no[ll_cnt])
	if ll_rowcount1 < 1 then
		ll_find = 0
	else
		ll_find = dw3.find("product_no = '" + ls_plan + "'",1,dw3.rowcount())
	end if
	if ll_find = 0 then
		ls_item = trim(dw10.object.coilsliting_item_no[ll_cnt])
		ls_qa   = trim(dw10.object.coilsliting_qa[ll_cnt])
		ls_uom  = trim(dw10.object.groupitem_uom[ll_cnt])
		/*2019.08.14 jowonsuk  최근단가가 기본이다. */
		if cbx_danga.checked then			
			lr_cost = wf_price1(ls_supp, ls_item, ls_qa, ls_uom)
		else
			lr_cost = wf_price (ls_supp, ls_item, ls_qa, ls_uom)
		end if
		ll_row  = dw3.insertrow(0)
		dw3.object.seq_no[ll_row]     = ll_row
		dw3.object.price[ll_row]      = lr_cost
		dw3.object.cprice[ll_row]     = lr_cost
		dw3.object.uom[ll_row]        = dw10.object.groupitem_uom[ll_cnt]
		dw3.object.order_no[ll_row]   = ls_order  // 발주번호
		dw3.object.product_no[ll_row] = ls_plan   // 코일생산계획번호
		dw3.object.purdet_serial_no[ll_row] = dw10.object.coilsliting_seq[ll_cnt] // 코일생산계획순번
		dw3.object.item_no[ll_row]    = ls_item
		dw3.object.qa[ll_row]         = ls_qa
		dw3.object.item_item_name[ll_row]  = dw10.object.groupitem_item_name[ll_cnt]
		IF dw10.object.coilsliting_sheet[ll_cnt] = 'C' OR &
		   dw10.object.coilsliting_sheet[ll_cnt] = 'L' then // C; coil , S; sheet
			dw3.object.order_qty[ll_row]  = dw10.object.coilsliting_unit_qty[ll_cnt] &
													* dw10.object.coilsliting_cnt[ll_cnt]
		ELSE
			dw3.object.order_qty[ll_row]  = dw10.object.coilsliting_cnt[ll_cnt]
		end if
		
		dw3.object.unit_qty[ll_row] = dw10.object.coilsliting_unit_qty[ll_cnt]  //단중
		dw3.object.cnt[ll_row]      =  dw10.object.coilsliting_cnt[ll_cnt]  //스리팅갯수
		
		if dw10.object.groupitem_uom[ll_cnt] = 'SH' then	
		
			IF  MidA(ls_item, 4, 1 ) = '2' THEN   /*jowonsuk 2018.06.20 단위가 SH 이고, SHEET가 아닐때는 환산 수량을 따라간다 */
			
					dw3.object.com_uom[ll_row] = dw10.object.groupitem_uom[ll_cnt]
					dw3.object.com_qty[ll_row] = dw10.object.coilsliting_unit_qty[ll_cnt] &
														* dw10.object.coilsliting_cnt[ll_cnt]							
			ELSE			
		
					if MidA(ls_item, 3, 1 )= 'A' then		/*중분류 A가 알루미늄, 스틸; SELECT al_rate, st_rate INTO :ia_rate, :is_rate FROM globals  */
						ld_rate = ia_rate	/*알루미늄 비중 */
					else
						ld_rate = is_rate	/*스틸 비중 */
					end if
					
					dw3.object.com_qty[ll_row] = ld_rate * (real(MidA(ls_qa,1,3)) / 100.0) * (real(MidA(ls_qa,5,4)) / 1000.0) * (real(MidA(ls_qa,10,4)) / 1000.0) * dw3.object.order_qty[ll_row]
					dw3.object.yrate[ll_row]   = ld_rate
					dw3.object.com_uom[ll_row] = 'KG'
					
			END IF	
			
		else	// 단위 SH 외 
			dw3.object.com_uom[ll_row] = dw10.object.groupitem_uom[ll_cnt]
			dw3.object.com_qty[ll_row] = dw10.object.coilsliting_unit_qty[ll_cnt] &
												* dw10.object.coilsliting_cnt[ll_cnt]
		end if
		
		if is_round = 'Y' then
			dw3.object.amt[ll_row] = round(dw3.object.com_qty[ll_row] + dw3.object.price[ll_row],0 )
		else
			dw3.object.amt[ll_row] = truncate(dw3.object.com_qty[ll_row] + dw3.object.price[ll_row],0 )
		end if
		dw3.object.rlse_date[ll_row]  = wf_today()
		dw3.object.due_date[ll_row]   = dw10.object.coilorder_due_date[ll_cnt]
		dw3.object.sale_no[ll_row]    = ''
		dw3.object.sale_seq[ll_row]   = 0
		dw3.object.cust_name[ll_row]  = '외주스리팅'
		dw3.object.color[ll_row]      = ''
		dw3.object.sale_rem[ll_row]   = dw10.object.coilsliting_rem[ll_cnt]
		dw3.object.pur_type[ll_row]   = 'C'
		dw3.object.work_type[ll_row]  = dw10.object.coilsliting_sheet[ll_cnt]
		dw3.object.coil_no[ll_row]    = dw10.object.coilsliting_coil_no[ll_cnt] // 원코일번호
		dw3.object.rcpt_loc[ll_row]   = dw10.object.loc_no[ll_cnt]              // 원코일저장소
    //dw3.object.cnt[ll_row]        = dw10.object.coilsliting_cnt[ll_cnt]     // 스리팅갯수
	 
		dw10.RowsMove ( ll_cnt, ll_cnt, Primary!, dw10, 1, Filter! )
		ll_cnt = ll_cnt - 1
	end if
next

MessageBox('확인','외주스리팅가공 대상물품이 이동되었습니다.',information!)
//dw10.selectrow(0,false)

return true


end function

public function boolean wf_move6 ();long ll_rowcount,ll_rowcount1,ll_cnt,ll_find,ll_row,ll_count
string ls_plan,ls_order,ls_uom,ls_supp,ls_qa,ls_item,ls_subcon,ls_qa1, ls_loc
decimal {4} lr_cost
dec {6} ld_rate

dw_1.accepttext()
dw8.accepttext()

if dw_1.rowcount() < 1 then 
	MessageBox("오류","발주헤더를 입력하십시오.", Exclamation!)
	dw8.selectrow(0,false)
	return false
end if	

ls_supp = trim(dw_1.object.supp_no[1])

if isnull(ls_supp) or ls_supp=""  then
	MessageBox("오류","발주헤더에 거래처를 입력하십시오.", Exclamation!)
	dw8.selectrow(0,false)
	return false
end if	
dw_1.object.subcon[1] = "J"

ll_rowcount1 = dw3.rowcount()
ll_rowcount  = dw8.rowcount()

ls_supp = trim(dw_1.object.supp_no[1])
ll_count = 0
for ll_cnt = 1 to ll_rowcount
	if dw8.isselected(ll_cnt) then
		ls_loc = trim(dw8.object.issue_loc[ll_cnt])
		if ls_loc = '' or isnull(ls_loc) then
			MessageBox("오류","자재가공 대상물품의 출고저장소를 입력하십시오.", Exclamation!)
			tab_1.selecttab(6)
			return false
		end if
      ll_count ++
	end if
next
if ll_count = 0 then
	messagebox('오류','자재가공대상물품을 선택하십시요.',exclamation!)
	return false
end if

for ll_cnt = 1 to ll_rowcount
	if dw8.isselected(ll_cnt) then
		ls_plan = trim(dw8.object.order_no[ll_cnt])
		if ll_rowcount1 < 1 then
			ll_find = 0
		else
		   ll_find = dw3.find("product_no = '" + ls_plan + "'",1,dw3.rowcount())
		end if
		if ll_find = 0 then
			ls_item = trim(dw8.object.item_no[ll_cnt])
			ls_qa   = trim(dw8.object.qa[ll_cnt])
			ls_uom  = trim(dw8.object.uom1[ll_cnt])
			/*2019.08.14 jowonsuk  최근단가가 기본이다. */
			if cbx_danga.checked then			
			 	lr_cost = wf_price1(ls_supp, ls_item, ls_qa, ls_uom)
			else
				lr_cost = wf_price (ls_supp, ls_item, ls_qa, ls_uom)
			end if			 

			ll_row = dw3.insertrow(0)
			dw3.object.seq_no[ll_row] = ll_row
			dw3.object.price[ll_row] = lr_cost
			dw3.object.cprice[ll_row] = lr_cost

			dw3.object.com_uom[ll_row] = ls_uom
			dw3.object.uom[ll_row] = gf_uom(ls_uom)
			dw3.object.order_qty[ll_row]  = dw8.object.order_qty[ll_cnt]
			// 2004/02/25일 추가 분 start
		     dw3.object.com_qty[ll_row]  =  dw8.object.order_qty[ll_cnt]
			  
			if dw8.object.uom1[ll_cnt] = 'SH' then
				dw3.object.cnt[ll_row]   =  dw8.object.order_qty[ll_cnt]  //SHEET 장수
				dw3.object.unit_qty[ll_row] = ld_rate * (real(MidA(ls_qa,1,3)) / 100.0) * (real(MidA(ls_qa,5,4)) / 1000.0) * (real(MidA(ls_qa,10,4)) / 1000.0)  //단중
				if MidA(ls_item, 3, 1 )= 'A' then
					ld_rate = ia_rate
				else
					ld_rate = is_rate
				end if
	//			dw3.object.com_qty[ll_row] = ld_rate * (real(mid(ls_qa,1,3)) / 100.0) * (real(mid(ls_qa,5,4)) / 1000.0) * (real(mid(ls_qa,10,4)) / 1000.0) * dw3.object.order_qty[ll_row]
				dw3.object.yrate[ll_row]  = ld_rate
			else
				dw3.object.unit_qty[ll_row] = dw8.object.order_qty[ll_cnt]
				dw3.object.cnt[ll_row]   =  1
			end if
			// 2004/02/25일 추가 분 end
//			dw3.object.com_qty[ll_row] = gf_getqty(ls_item, ls_qa, ls_uom, dw8.object.order_qty[ll_cnt])
			if is_round = 'Y' then
				dw3.object.amt[ll_row] = round(dw3.object.com_qty[ll_row] + dw3.object.price[ll_row],0 )
			else
				dw3.object.amt[ll_row] = truncate(dw3.object.com_qty[ll_row] + dw3.object.price[ll_row],0 )
			end if

			dw3.object.order_no[ll_row]   = ls_order
			dw3.object.product_no[ll_row] = ls_plan
			dw3.object.purdet_serial_no[ll_row] = 0
			dw3.object.item_no[ll_row]    = ls_item
			dw3.object.qa[ll_row]         = ls_qa
         		dw3.object.item_item_name[ll_row]  =  dw8.object.groupitem_item_name1[ll_cnt]
			dw3.object.due_date[ll_row]   =  wf_today()
			dw3.object.rlse_date[ll_row]  =  wf_today()
   			dw3.object.pur_type[ll_row]   =  'J'
//			dw3.object.coil_no[ll_row]      =  dw8.object.issue_lot[ll_cnt] //원코일번호
//			dw8.RowsMove ( ll_cnt, ll_cnt, Primary!, dw8, 1, Filter! )
//			ll_cnt = ll_cnt - 1
		end if
	end if
next
messagebox('확인','자재가공 대상물품이 이동되었습니다.',information!)
//dw8.selectrow(0,false)
return true
end function

public function boolean wf_outproc (string arg_subcon, long arg_row);long     ll_foundrow, ll_count, li_cnt, ll_row, ll_cnt
datetime ldt_date
string   ls_order, ls_item, ls_qa, ls_destination, ls_newloc, ls_temp, ls_suppname
string   ls_old_time, ls_pur, ls_wcoil, ls_oc, ls_flag, ls_wloc, ls_issue_lot, ls_product_no
real     lr_newqty
dec {1}  ld_w_wid
dec {2}  ld_yrate
dec {3}  lr_sheet_unitqty
int      li_seq, li_wunit_qty, li_wcoilcnt
string   ls_coilorderdet_order[], ls_type, ls_sqlerrtext


// 발주구분 : 외주구매'Y', 자재가공'J', 외주가공'P', 외주스리팅가공시'C' 의 처리.
dw_1.accepttext()
dw3.accepttext()
dw4.accepttext()

////////////////////////////////////////////////////////////////////////////
// 외주가공형태 추가 (2001/07/19)
////////////////////////////////////////////////////////////////////////////
// J:자재가공, P:외주가공 일때만 적용(inaudit 추가 안함)
//
// A.명송 외주가공 플로우	
//		1. 스리팅 코일 이동
//		2. 제품 생산계획
//			- 임의 생산계획 작성후 명송에서 받은 작업일보에서 해당 제품 입고
//		3. 스리팅 코일 수불 
//			- 작업일보에서 잔량 및 사용량 등록
//		4. 수주접수후 외주생산계획작성
//		5. 제품 외주 가공 발주
//			- 출고되는 스리팅코일은 로트번호없는 스리팅코드로만 외주가공 발주
//		6. 입고
//			- 제품입고시에 명송에 있는 제품을 사용한것으로 해야함
//
// B. 통일 외주가공 플로우	
//		1. 코일 이동 - 외주발주에 의한 코일이동시 스리팅 수불 안함
//		2. 수주접수후 외주생산계획 작성
//		3. 외주가공발주 
//			- 출고되는 스리팅코일은 로트번호없는 스리팅코드로만 외주가공 발주
//		4. 입고 - 입고시 스리팅코일의 사용을 추가 해야함	
////////////////////////////////////////////////////////////////////////////

ls_newloc = trim(dw_1.object.supp_no[1])

setnull(ls_type)
SELECT type INTO :ls_type FROM supp WHERE supp_no = :ls_newloc; 

ls_order      = trim(dw_1.object.order_no[1])
ls_product_no = trim(dw3.object.product_no[arg_row])
ls_coilorderdet_order[1] = ls_product_no
li_seq        = dw3.object.purdet_serial_no[arg_row]  // 코일생산계획순번
ldt_date      = wf_today()
ls_old_time   = string(now(),'hh:mm:ss:fff')

// 발주구분 : 외주구매'Y', 자재가공'J', 외주가공'P', 외주스리팅가공시'C' 의 처리.
choose case arg_subcon
	case 'C' // 외주스리팅 가공
		// 원코일 이동은 안한다.(코일 이동은 별도의 "코일이동관리"에서 이동 시킴)
		SELECT coil_no, wid, proc_flag, loc_no INTO :ls_wcoil, :ld_w_wid, :ls_flag, :ls_wloc 
		  FROM coilorderdet
		 WHERE order_no = :ls_product_no;
		if sqlca.sqlcode <> 0 then
			ls_sqlerrtext = sqlca.sqlerrtext
			ROLLBACK;
			MessageBox('오류1','select수행중 오류가 발생하였습니다.~r~n' + ls_sqlerrtext,exclamation!)
			RETURN false
		end if
		
		if ls_flag = "M" then		// 코일생산계획 진행여부(O,M,P,C)
			UPDATE coilorderdet SET proc_flag = 'P' WHERE order_no = :ls_product_no; // 외주발주중
			if sqlca.sqlcode < 0 then
				ls_sqlerrtext = sqlca.sqlerrtext
				ROLLBACK;
				MessageBox('오류18','item수행중 오류가 발생하였습니다.~r~n' + ls_sqlerrtext,exclamation!)
				RETURN false
			end if
				
			// 외주상태만변경(외주발주작성)
			UPDATE coilmst SET open_close = 'S' WHERE coil_no = :ls_wcoil	AND loc_no = :ls_wloc;
			if sqlca.sqlcode <> 0 then
				ls_sqlerrtext = sqlca.sqlerrtext
				ROLLBACK;
				MessageBox('update오류15',"코일마스터[coilmst]UPDATE시 오류가 발생했습니다.~r~n" + ls_sqlerrtext,exclamation!)
				RETURN false
			end if
			
			dw_9.retrieve(ls_coilorderdet_order)
			for ll_row = 1 to dw_9.rowcount()
				ls_wcoil = dw_9.object.coil_no[ll_row]
				ls_wloc  = dw_9.object.loc_no[ll_row]
				
				// 외주상태만변경(외주발주작성)
				UPDATE coilmst SET open_close = 'S' WHERE coil_no = :ls_wcoil AND loc_no = :ls_wloc;
				if sqlca.sqlcode <> 0 then
					ls_sqlerrtext = sqlca.sqlerrtext
					ROLLBACK;
					MessageBox('오류19',"코일마스터[coilmst]update시 오류가 발생했습니다.~r~n" + ls_sqlerrtext,exclamation!)
					RETURN false
				end if
			next
			
			ls_destination = ls_wloc
		else
			RETURN true  // 이미처리 되었기 때문에 RETURN true 한다.
		end if
		
/////////////////////
// 발주구분 : 외주구매'Y', 자재가공'J', 외주가공'P', 외주스리팅가공시'C' 의 처리.
	case 'Y'
		SELECT COUNT(*) INTO :li_cnt FROM sudodet1 WHERE sudo_type = 'A' AND order_no = :ls_product_no;
		if li_cnt > 0 then
			UPDATE sudodet1 SET sudo_type = 'B' WHERE order_no = :ls_product_no;  
			if sqlca.sqlcode < 0 then
				ls_sqlerrtext = sqlca.sqlerrtext
				ROLLBACK;
				MessageBox('오류15','sudodet1수행중 오류가 발생하였습니다.~r~n' + ls_sqlerrtext,exclamation!)
				RETURN false
			end if				  
		else
			ROLLBACK;
			MessageBox('오류16','sudodet1자료가 이미 처리 되었습니다. 재조회 하십시요.',exclamation!)
			RETURN false
		end if
		
////////////////
// 발주구분 : 외주구매'Y', 자재가공'J', 외주가공'P', 외주스리팅가공시'C' 의 처리.
	case 'P'
		ll_foundrow = dw4.Find( "order_no = '" + ls_product_no + "'", 1, dw4.rowcount())
		if isnull(ll_foundrow) or ll_foundrow = 0 then
			ROLLBACK;
			MessageBox('오류2', '가공출고내역을 찾을수 없습니다.',exclamation!)
			tab_1.selecttab(2)
			RETURN false
		end if

		ldt_date = datetime(date(string(dw4.object.issue_date[ll_foundrow],'yyyy/mm/dd')))
		ls_item  = trim(dw4.object.component[ll_foundrow])

		UPDATE sudodet SET sudo_type = 'B', out_type = "B" WHERE order_no = :ls_product_no;
		if sqlca.sqlcode < 0 then
			ls_sqlerrtext = sqlca.sqlerrtext
			ROLLBACK;
			MessageBox('오류4','sudodet update수행중 오류가 발생하였습니다.~r~n' + ls_sqlerrtext,exclamation!)
			RETURN false
		end if		
		 
       	lr_newqty 		 = dw4.object.issue_qty[ll_foundrow]
       	ls_qa     		 = trim(dw4.object.component_qa[ll_foundrow])
	 //  ls_product_no  = trim(dw4.object.order_no[ll_foundrow])
       	ls_destination = trim(dw4.object.issue_loc[ll_foundrow])
	//   ls_issue_lot   = trim(dw4.object.issue_lot[ll_foundrow])
       if isnull(ls_destination) or ls_destination = "" then
			 ROLLBACK;
	       MessageBox('오류5', '출고저장소를 등록하십시요.',exclamation!)
	       RETURN false
       end if
		 
////////////////
// 발주구분 : 외주구매'Y', 자재가공'J', 외주가공'P', 외주스리팅가공시'C' 의 처리.
	case 'J'
		ll_foundrow = dw8.Find( "order_no = '"+ ls_product_no +"'", 1, dw8.rowcount())
		if isnull(ll_foundrow) or ll_foundrow = 0 then
			ROLLBACK;
			MessageBox('오류6', '가공출고내역을 찾을수 없습니다.~r~n' + ls_sqlerrtext,exclamation!)
			tab_1.selecttab(6)
			RETURN false
		end if		 
		ls_item = trim(dw8.object.assy_item[ll_foundrow])
		 
		UPDATE jajaesudo SET out_type = 'Y', flag = "Y", order_dt = getdate() WHERE order_no = :ls_product_no;
		if sqlca.sqlcode < 0 then
			ls_sqlerrtext = sqlca.sqlerrtext
			ROLLBACK;
			MessageBox('오류8','jajaesudo update수행중 오류가 발생하였습니다.~r~n' + ls_sqlerrtext,exclamation!)
			RETURN false
		end if
		 
		lr_newqty      = dw8.object.out_qty[ll_foundrow]
		ls_qa          = trim(dw8.object.assy_qa[ll_foundrow])
		ls_destination = trim(dw8.object.issue_loc[ll_foundrow])
	// ls_issue_lot   = trim(dw8.object.issue_lot[ll_foundrow])
      if isnull(ls_destination) or ls_destination = "" then
			ROLLBACK;
			MessageBox('오류10','출고저장소를 등록하십시요~r~n',exclamation!)
			RETURN false
      end if				 
end choose	 

ls_pur = trim(dw_1.object.order_no[1])

SELECT loc_no INTO :ls_temp FROM location WHERE loc_no = :ls_newloc;
choose case sqlca.sqlcode
	case 0
	case 100
		SELECT supp_name INTO :ls_suppname FROM supp WHERE supp_no = :ls_newloc;
		ls_suppname = trim(ls_suppname)
		
		INSERT INTO location (loc_no, loc_name, loc_type) VALUES (:ls_newloc, :ls_suppname, 'Y');
		if sqlca.sqlcode < 0 then
			ls_sqlerrtext = sqlca.sqlerrtext
			ROLLBACK;
			MessageBox('오류11','저장소 추가중 오류가 발생하였습니다.~r~n' + ls_sqlerrtext,exclamation!)
			RETURN false
		end if
	case else
		ROLLBACK;
		MessageBox('오류12','저장소 검색중 오류가 발생하였습니다.~r~n' + ls_sqlerrtext,exclamation!)
		RETURN false
end choose

//////////////////////////////////////////////////////////////////////////////////////
// 발주구분 : 외주구매'Y', 자재가공'J', 외주가공'P', 외주스리팅가공시'C' 의 처리.
// 원코일 이동은 안한다..에의한 RETURN
//////////////////////////////////////////////////////////////////////////////////////
if arg_subcon = "Y" OR arg_subcon = "C" then RETURN true
//////////////////////////////////////////////////////////////////////////////////////

if arg_subcon <> "C" then // 'J' or 'P'
	// A.명송, B.통일과 같은 경우는 inaudit 추가 안함
	if ls_type = "A" or ls_type = "B" then RETURN true
		
	li_seq = dw3.object.seq_no[arg_row]  // 발주순번

//	// [IL]저장소출고 로직입니다.	
//	for ll_count = 1 to 100000
//		IF ls_old_time <> string(now(),'hh:mm:ss:fff') then
//			ls_old_time  = string(now(),'hh:mm:ss:fff')
//			exit
//		end if	
//	next		
	
	INSERT INTO inaudit (inaudit_time,inaudit_date,inaudit_item,qa,order_no,rcpt_qty,issue_qty,loc_no, 
	  	    serial_id,inaudit_type,cost,cnt, destination, user_id)
	VALUES (getdate(),:ldt_date,:ls_item,:ls_qa,:ls_order,0,:lr_newqty,:ls_destination, 
		    :ls_issue_lot,'IL',0,:li_seq, :ls_newloc, :gs_userid);
	if sqlca.sqlcode < 0 then
		ls_sqlerrtext = sqlca.sqlerrtext
		ROLLBACK;
		MessageBox('오류13','[pb_save][inaudit] insert중 DB오류가 발생했습니다.~r~n' + ls_sqlerrtext,exclamation!)		
		RETURN false
	end if
	
//	for ll_count = 1 to 100000
//		IF ls_old_time <> string(now(),'hh:mm:ss:fff') then
//			ls_old_time  = string(now(),'hh:mm:ss:fff')	
//			exit
//		end if	
//	next		
				
	// [RL]저장소입고 로직입니다.	
	INSERT INTO inaudit (inaudit_time,inaudit_date,inaudit_item,qa,order_no,rcpt_qty,issue_qty,loc_no, 
	  	    serial_id,inaudit_type,cost,cnt,destination, user_id)
	VALUES (getdate(),:ldt_date,:ls_item,:ls_qa,:ls_order,:lr_newqty,0,:ls_newloc, 
		    :ls_issue_lot,'RL',0,:li_seq, :ls_destination, :gs_userid);
	if sqlca.sqlcode < 0 then
		ls_sqlerrtext = sqlca.sqlerrtext
		ROLLBACK;
		MessageBox('오류14','[pb_save][inaudit] insert중 DB오류가 발생했습니다.~r~n' + ls_sqlerrtext,exclamation!)		
		RETURN false
	end if
else
	if ls_oc <> 'S' and not isnull(ls_oc) then
		// [IL]외주출고 로직입니다.
//		for ll_count = 1 to 100000
//			IF ls_old_time <> string(now(),'hh:mm:ss:fff') then
//				ls_old_time  = string(now(),'hh:mm:ss:fff')	
//				exit
//			end if	
//		next		
		
		INSERT INTO inaudit (inaudit_time, inaudit_date, inaudit_item, qa, loc_no, inaudit_type, order_no,
			    rcpt_qty, issue_qty, cost, destination, serial_id, rem, unit_qty, cnt, com_qty, user_id)  
		VALUES (getdate(), :ldt_date, :ls_item, :ls_qa, :ls_destination, 'IL', :ls_order,
			    0, :lr_newqty, 0, :ls_newloc, :ls_wcoil, '', :li_wunit_qty, :li_wcoilcnt, :li_seq, :gs_userid);			 
		if sqlca.sqlcode < 0 then
			ls_sqlerrtext = sqlca.sqlerrtext
			ROLLBACK;
			MessageBox('오류26','[pb_save][inaudit] insert중 DB오류가 발생했습니다.~r~n' + ls_sqlerrtext,exclamation!)			
			RETURN false
		end if	

		// [RL]외주저장소입고 로직입니다.	
//		for ll_count = 1 to 100000
//			IF ls_old_time <> string(now(),'hh:mm:ss:fff') then
//				ls_old_time  = string(now(),'hh:mm:ss:fff')	
//				exit
//			end if	
//		next		
		
		INSERT INTO inaudit (inaudit_time, inaudit_date, inaudit_item, qa, loc_no, inaudit_type, order_no,
			    rcpt_qty, issue_qty, cost, destination, serial_id, rem, unit_qty, cnt, com_qty, user_id)  
		VALUES (getdate(), :ldt_date, :ls_item, :ls_qa, :ls_newloc, 'RL', :ls_order,
			    :lr_newqty, 0, 0, :ls_destination, :ls_wcoil, '', :li_wunit_qty, :li_wcoilcnt, :li_seq, :gs_userid);			 
		if sqlca.sqlcode < 0 then
			ls_sqlerrtext = sqlca.sqlerrtext
			ROLLBACK;
			MessageBox('오류17','[pb_save][inaudit] insert중 DB오류가 발생했습니다.~r~n' + ls_sqlerrtext,exclamation!)			
			RETURN false
		end if	
	end if
end if

RETURN true

end function

public function boolean wf_deleteproc (string arg_subcon, long arg_row);//
datetime ldt_date
long   i, ll_rowcount, ll_row, ll_count
int    li_cnt, li_seq, li_wunit_qty, li_wcoilcnt
real   lr_qty
string ls_old_time, ls_destination, ls_issue_lot, ls_wloc
string ls_item, ls_qa, ls_item2, ls_qa2, ls_subcon, ls_purtype,  ls_proc, ls_flag
string ls_wcoil, ls_loc, ls_supp, ls_order, ls_product, ls_array[1], ls_sqlerrtext
dec{1} ld_w_wid, lr_newqty

ls_order    = trim(dw_1.object.order_no[1])
ls_item     = trim(dw3.GetItemString(arg_row, "item_no", Delete!, TRUE))
ls_qa       = trim(dw3.GetItemString(arg_row, "qa", Delete!, TRUE))
ls_supp     = trim(dw_1.object.supp_no[1])
lr_qty      = dw3.GetItemNumber(arg_row, "order_qty", Delete!, TRUE)
ls_product  = trim(dw3.GetItemString(arg_row, "product_no", Delete!, TRUE))
ldt_date    = wf_today()
ls_old_time = string(now(),'hh:mm:ss:fff')

// 발주구분 : 외주구매'Y', 자재가공'J', 외주가공'P', 외주스리팅가공시'C' 의 처리.
choose case arg_subcon
	case 'P' // 외주가공'
	// ls_wcoil = trim(dw3.GetItemString(arg_row, "coil_no", Delete!, TRUE))
		SELECT issue_lot, issue_loc, issue_qty, component, component_qa
		  INTO :ls_wcoil, :ls_loc, :lr_newqty, :ls_item, :ls_qa 
		  FROM sudodet 
		 WHERE sudo_type IN( 'B', 'C')  AND order_no = :ls_product;
		if sqlca.sqlcode = 0 then
			UPDATE sudodet SET sudo_type = 'A' WHERE order_no = :ls_product;
			if sqlca.sqlcode < 0 then
				ls_sqlerrtext = sqlca.sqlerrtext 
				ROLLBACK;
				MessageBox('오류1','sudodet수행중 오류가 발생하였습니다.~r~n' + ls_sqlerrtext,exclamation!)
				RETURN FALSE
			end if				
		else
		end if

		ls_destination = ls_loc
		//ls_issue_lot   = ls_wcoil

	case 'Y' // 외주구매'
		SELECT COUNT(*) INTO :li_cnt FROM sudodet1 
		 WHERE sudo_type IN( 'B', 'C') AND order_no = :ls_product;
		if li_cnt > 0 then
			UPDATE sudodet1 SET sudo_type = 'A' WHERE order_no = :ls_product;  
			if sqlca.sqlcode < 0 then
				ls_sqlerrtext = sqlca.sqlerrtext 
				ROLLBACK;
				MessageBox('오류2','sudodet1수행중 오류가 발생하였습니다.~r~n' + ls_sqlerrtext,exclamation!)
				RETURN FALSE
			end if				  
		else
		end if

	case 'J' // 자재가공
	//	ls_wcoil = trim(dw3.GetItemString(arg_row, "coil_no", Delete!, TRUE))
		SELECT issue_lot, issue_loc, out_qty, assy_item, assy_qa
		  INTO :ls_wcoil, :ls_loc, :lr_newqty, :ls_item, :ls_qa 
		  FROM jajaesudo 
		 WHERE order_no = :ls_product;
		if sqlca.sqlcode = 0 then
		   UPDATE jajaesudo SET out_type = 'N', flag = 'N'  WHERE order_no = :ls_product;
			if sqlca.sqlcode < 0 then
				ls_sqlerrtext = sqlca.sqlerrtext 
				ROLLBACK;
				MessageBox('오류3','jajaesudo수행중 오류가 발생하였습니다.~r~n' + ls_sqlerrtext,exclamation!)
				RETURN FALSE
			end if				  
		end if
		
		ls_destination = ls_loc
		if isnull(ls_loc) or trim(ls_loc) = '' then 
			SELECT def_loc INTO :ls_loc FROM area WHERE area_no = :gs_area;
		end if
	// ls_issue_lot = ls_wcoil

	case 'C'	// 외주스리팅/sheet
		//코일 이동은 안한다..
		//코일 이동은 별도의 "코일이동관리"에서 이동 시킴
		ls_wloc = trim(dw3.GetItemString(arg_row, "rcpt_loc", Delete!, TRUE))
		SELECT coil_no, proc_flag INTO :ls_wcoil, :ls_flag 
		  FROM coilorderdet
		 WHERE order_no = :ls_product;
		if sqlca.sqlcode <> 0 then
			ls_sqlerrtext = sqlca.sqlerrtext 
			ROLLBACK;
			MessageBox('오류4','coilorderdet select수행중 오류가 발생하였습니다.~r~n' + ls_sqlerrtext,exclamation!)
			RETURN FALSE
		end if
		
		if ls_flag = "P" then			
			// 외주가공청구중
			UPDATE coilorderdet SET proc_flag = 'M' WHERE order_no = :ls_product	AND proc_flag = 'P';
			if sqlca.sqlcode < 0 then
				ls_sqlerrtext = sqlca.sqlerrtext 
				ROLLBACK;
				MessageBox('오류5','item수행중 오류가 발생하였습니다.~r~n' + ls_sqlerrtext,exclamation!)
				RETURN FALSE
			end if

			SELECT item_no INTO :ls_item  FROM coilmst WHERE coil_no = :ls_wcoil AND loc_no = :ls_supp;
			if sqlca.sqlcode = 100 then
				SELECT loc_no INTO :ls_loc FROM coilmst WHERE coil_no = :ls_wcoil	AND loc_no = :ls_wloc;
				if sqlca.sqlcode = 100 then
					SELECT loc_name INTO :ls_loc 
					  FROM coilmst, location
					 WHERE coil_no = :ls_wcoil	AND coilmst.loc_no = location.loc_no;
					if sqlca.sqlcode = 0 then
						ROLLBACK;
						MessageBox("오류6", "해당 코일이 " + trim(ls_loc) + " 로 이동되어있습니다. " &
												+ "코일이동을 삭제후에 작업하시기바랍니다")
						RETURN FALSE
					else
						ls_sqlerrtext = sqlca.sqlerrtext 
						ROLLBACK;
						MessageBox("오류6-1", "해당 코일[" + trim(ls_wcoil) + "]이 COILMST에 없습니다~r~n" + ls_sqlerrtext)
						RETURN FALSE
					end if
				end if
				ls_supp = ls_loc
			end if
			
			// 작업지시중
			UPDATE coilmst SET open_close = 'P' WHERE coil_no = :ls_wcoil	AND loc_no = :ls_supp AND open_close = 'S';
			if sqlca.sqlcode <> 0 then
				ls_sqlerrtext = sqlca.sqlerrtext 
				ROLLBACK;
				MessageBox('update오류8',"코일마스터[coilmst]UPDATE시 오류가 발생했습니다.~r~n" + ls_sqlerrtext,exclamation!)
				RETURN FALSE
			end if
			
			ls_array[1] = ls_product
			dw_9.retrieve(ls_array)
			for ll_row = 1 to dw_9.rowcount()
				ls_wcoil = dw_9.object.coil_no[ll_row]

				setnull(ls_item2)
				SELECT item_no	INTO :ls_item2 FROM coilmst WHERE coil_no = :ls_wcoil	AND loc_no = :ls_supp;
				if sqlca.sqlcode = 100 then
					SELECT loc_no INTO :ls_loc FROM coilmst WHERE coil_no = :ls_wcoil	AND loc_no = :ls_wloc;
					if sqlca.sqlcode = 100 then
						ls_sqlerrtext = sqlca.sqlerrtext 
						ROLLBACK;
						MessageBox("오류6-3", "해당 코일이 COILMST에 없습니다.~r~n" + ls_sqlerrtext)
						RETURN FALSE
					end if
					ls_supp = ls_loc
				end if
				li_wcoilcnt = dw_9.object.cnt[ll_row]

				//	UPDATE coilmst SET loc_no = :ls_loc, open_close = "P" // 외주발주중
				// 외주발주중
				UPDATE coilmst SET open_close = 'P' WHERE coil_no = :ls_wcoil	AND loc_no = :ls_supp;
				if sqlca.sqlcode <> 0 then
					ls_sqlerrtext = sqlca.sqlerrtext 
					ROLLBACK;
					MessageBox('오류19',"코일마스터[coilmst]update시 오류가 발생했습니다.~r~n" + ls_sqlerrtext,exclamation!)
					RETURN FALSE
				end if
			next
		end if
end choose	 

if arg_subcon = "J" or arg_subcon = "P"  then // 자재가공'J'/  외주가공'P'
	li_seq = dw3.GetItemNumber(arg_row, "seq_no", Delete!, TRUE)  // 발주순번
//	for ll_count = 1 to 100000
//		if ls_old_time <> string(now(),'hh:mm:ss:fff') then
//			ls_old_time  = string(now(),'hh:mm:ss:fff')
//			exit
//		end if
//	next
	
	// inaudit 입고
	INSERT INTO inaudit (inaudit_time,inaudit_date,inaudit_item,qa,order_no,rcpt_qty,issue_qty,loc_no, 
	  	    serial_id,inaudit_type,cost,cnt, destination, user_id)
	VALUES (getdate(),:ldt_date,:ls_item,:ls_qa,:ls_order,0,:lr_newqty * -1,:ls_destination, 
		    :ls_issue_lot, 'IL',0,:li_seq, :ls_supp, :gs_userid);
	if sqlca.sqlcode < 0 then
		ls_sqlerrtext = sqlca.sqlerrtext 
		ROLLBACK;
		MessageBox('오류13','[pb_save][inaudit] insert중 DB오류가 발생했습니다.~r~n' + ls_sqlerrtext,exclamation!)
		RETURN FALSE
	end if
	
	for ll_count = 1 to 100000
		if ls_old_time <> string(now(),'hh:mm:ss:fff') then
			ls_old_time  = string(now(),'hh:mm:ss:fff')	
			exit
		end if
	next
				
	// inaudit 입고
	INSERT INTO inaudit (inaudit_time,inaudit_date,inaudit_item,qa,order_no,rcpt_qty,issue_qty,loc_no, 
	  	    serial_id,inaudit_type,cost,cnt,destination, user_id)
	VALUES (getdate(),:ldt_date,:ls_item,:ls_qa,:ls_order,:lr_newqty * -1 ,0,:ls_supp, 
		    :ls_issue_lot, 'RL',0,:li_seq, :ls_destination, :gs_userid);
	if sqlca.sqlcode < 0 then
		ls_sqlerrtext = sqlca.sqlerrtext 
		ROLLBACK;
		MessageBox('오류14','[pb_save][inaudit] insert중 DB오류가 발생했습니다.~r~n' + ls_sqlerrtext,exclamation!)		
		RETURN FALSE
	end if
end if

UPDATE item SET pur_reserved = pur_reserved - :lr_qty WHERE item_no = :ls_item AND qa = :ls_qa;
if sqlca.sqlcode < 0 then
	ls_sqlerrtext = sqlca.sqlerrtext 
	ROLLBACK;
	MessageBox('오류15','item수행중 오류가 발생하였습니다.~r~n' + ls_sqlerrtext,exclamation!)
	RETURN FALSE
end if

RETURN TRUE

end function

public subroutine wf_calc (long arg_row);//
string ls_qa, ls_uom
string ls_draw_no /*추가*/
dec{6} ld_rate
dec ld_mk

dw3.accepttext()

ls_qa  = trim(dw3.object.qa[arg_row])
ls_uom = trim(dw3.object.com_uom[arg_row])
ls_draw_no =  trim(dw3.object.draw_no[arg_row])

choose case ls_uom
	case 'M'
		dw3.object.com_qty[arg_row] = (real(MidA(ls_qa,15,5)) / 1000.0) * dw3.object.order_qty[arg_row]
	case 'M2'
		dw3.object.com_qty[arg_row] = (real(MidA(ls_qa, 5,4)) / 1000.0) * (real(MidA(ls_qa,10,4)) / 1000.0) * dw3.object.order_qty[arg_row]
	case 'KG'
		if dw3.object.uom[arg_row]  = 'SH' then
			if MidA(dw3.object.item_no[arg_row], 3, 1 )= 'A' then
				ld_rate =  ia_rate
			else
				ld_rate =  is_rate
			end if
			
			dw3.object.com_qty[arg_row] = ld_rate * (real(MidA(ls_qa,1,3)) / 100.0) * (real(MidA(ls_qa,5,4)) / 1000.0) * (real(MidA(ls_qa,10,4)) / 1000.0) * dw3.object.order_qty[arg_row]
		 	dw3.object.cnt[arg_row]     = dw3.object.order_qty[arg_row] 
			dw3.accepttext()
			if Not isnull(dw3.object.order_qty[arg_row]) and dw3.object.order_qty[arg_row] <> 0 then
		 		dw3.object.unit_qty[arg_row] = truncate(dw3.object.com_qty[arg_row] / dw3.object.cnt[arg_row] , 4)
			end if
		else
							
				select MK
				INTO :ld_mk
				from suppdraw
				where draw_no = :ls_draw_no;
				
				if isnull(ld_mk) or ld_mk = 0 then
					
					dw3.object.com_qty[arg_row] = dw3.object.order_qty[arg_row] 
				
				else
	
					dw3.object.com_qty[arg_row] = ld_mk*real(MidA(ls_qa,15,5)) / 1000.0 * dw3.object.order_qty[arg_row]
					
				end if

		end if
		
	case else
		dw3.object.com_qty[arg_row] = dw3.object.order_qty[arg_row] 
end choose

dw3.accepttext()
if is_round = 'Y' then
	dw3.object.amt[arg_row] = round(dw3.object.com_qty[arg_row]    * dw3.object.price[arg_row],0 )
else
	dw3.object.amt[arg_row] = truncate(dw3.object.com_qty[arg_row] * dw3.object.price[arg_row],0 )
end if

end subroutine

public subroutine wf_calc_yrate (long arg_row);string ls_qa, ls_uom
dec{6} ld_rate

ls_qa = trim(dw3.object.qa[arg_row])
ls_uom = trim(dw3.object.uom[arg_row])
choose case ls_uom
	case 'SH'
		ld_rate = dw3.object.yrate[arg_row]
		dw3.object.com_qty[arg_row] = ld_rate * (real(MidA(ls_qa,1,3)) / 100.0) * (real(MidA(ls_qa,5,4)) / 1000.0) * (real(MidA(ls_qa,10,4)) / 1000.0) * dw3.object.order_qty[arg_row]
	case else
		dw3.object.com_qty[arg_row] = dw3.object.order_qty[arg_row] 
end choose

if is_round = 'Y' then
	dw3.object.amt[arg_row] = round(dw3.object.com_qty[arg_row] + dw3.object.price[arg_row],0 )
else
	dw3.object.amt[arg_row] = truncate(dw3.object.com_qty[arg_row] + dw3.object.price[arg_row],0 )
end if

end subroutine

public function decimal wf_price (string as_supp, string as_item, string as_qa, string as_uom);decimal {4} ld_cost
decimal {5} ld_m_kg
string  ls_qa1, ls_yyyymm
int     li_qa5

ld_cost = 0

/*
select a.amount
  into :ld_cost
from supplier_unit_det a inner join ( select supp_no, max(ver) ver
											  from supplier_unit
											where  yyyymm >= convert(char(6), getdate() )
 											    and use_yn = 'Y'
											 group by supp_no
										     ) b on a.supp_no = b.supp_no and a.ver = b.ver
where a.supp_no = :as_supp
	and  a.item_no = :as_item
	and  a.qa = :as_qa;
	
	
if sqlca.sqlcode = 100 then
	 :ld_cost = 0
END IF


	
*/
/* 2019년 1월 31일 jowonsuk  거래처별 단가 반영 예정 
*/
ls_yyyymm  = LeftA(string(dw_1.object.order_date[1]),4)+MidA(string(dw_1.object.order_date[1]),6,2)

select a.amount
  into :ld_cost
from supplier_unit_det a inner join ( select supp_no, max(ver) ver
											  from supplier_unit
											where  yyyymm <= :ls_yyyymm
												 and use_yn = 'Y'
											 group by supp_no
											  ) b on a.supp_no = b.supp_no and a.ver = b.ver
where a.supp_no = :as_supp
	and  a.item_no = :as_item
	and  a.qa = :as_qa;		
	
if sqlca.sqlcode <> 0 then 
	ld_cost = 0
end if

/*
if sqlca.sqlcode <> 0 then 
	select price_a into :ld_cost from item
	 where item_no = :as_item
		and qa = :as_qa;
	if sqlca.sqlcode <> 0 then ld_cost = 0
end if
*/	
/*	

select suppgroup.price into :ld_cost 
  from suppgroup, suppgroupdet
 where suppgroup.supp_no    = suppgroupdet.supp_no
   and suppgroupdet.supp_no = :as_supp
   and item_no              = :as_item;
	
if sqlca.sqlcode <> 0 then 
	
	choose case trim(as_uom)
		case 'M'
			ls_qa1 = mid(as_qa,1,13)
			li_qa5 = integer(mid(as_qa,15,5))
			select amount, m_kg into :ld_cost, :ld_m_kg from supplier 
			 where item_no = :as_item and qa = :ls_qa1 and supp_no = :as_supp;	
			ld_cost = (li_qa5 * ld_m_kg) / 1000

		case else
			
			select amount into :ld_cost from supplier 
			 where item_no = :as_item and qa = :as_qa and supp_no = :as_supp;
			 
	end choose
	
	if sqlca.sqlcode <> 0 then 
		select price_a into :ld_cost from item
		 where item_no = :as_item
			and qa = :as_qa;
		if sqlca.sqlcode <> 0 then ld_cost = 0
	end if
	
end if

*/

//return truncate(ld_cost, 0 )
return ld_cost
end function

public function boolean wf_sel (long arg_row);string ls_supp, ls_item, ls_qa, ls_name, ls_uom
decimal {4} ld_cost

ls_supp = trim(dw_1.object.supp_no[1])
ls_item = trim(dw3.object.item_no[arg_row])
ls_qa = trim(dw3.object.qa[arg_row])
select item_name, uom into :ls_name, :ls_uom from item
where item_no = :ls_item
 and qa = :ls_qa;
if sqlca.sqlcode = 100 then 
	is_flag = '2'
	return false
end if
dw3.object.com_uom[arg_row] = trim(ls_uom)
CHOOSE CASE trim(ls_uom)
case 'M', 'M2'
	dw3.object.uom[arg_row] = 'EA'
CASE ELSE
	dw3.object.uom[arg_row] = trim(ls_uom)
END CHOOSE
dw3.object.item_item_name[arg_row] = ls_name
if dw3.object.price[arg_row] = 0 or isnull(dw3.object.price[arg_row]) then
	/*2019.08.14 jowonsuk  최근단가가 기본이다. */
	if cbx_danga.checked then			
		ld_cost = wf_price1(ls_supp, ls_item, ls_qa, ls_uom)
	else
		ld_cost = wf_price (ls_supp, ls_item, ls_qa, ls_uom)
	end if	
	
	dw3.object.price[arg_row] = ld_cost
	dw3.object.cprice[arg_row] = ld_cost
end if
wf_calc(arg_row)
return true

end function

public subroutine wf_calc2 (integer arg_row);string ls_uom

dw3.accepttext()
ls_uom = trim(dw3.object.com_uom[arg_row])
choose case ls_uom
	case 'KG'
		if dw3.object.uom[arg_row]  = 'SH' then
			if not isnull(dw3.object.order_qty[arg_row]) and dw3.object.order_qty[arg_row] <> 0 then
		 		dw3.object.unit_qty[arg_row] = truncate(dw3.object.com_qty[arg_row] / dw3.object.cnt[arg_row] , 4)
			end if
		end if
	case 'SH'
		dw3.object.unit_qty[arg_row] = 1
end choose

dw3.accepttext()
if is_round = 'Y' then
	dw3.object.amt[arg_row] = round(dw3.object.com_qty[arg_row]    * dw3.object.price[arg_row],0 )
else
	dw3.object.amt[arg_row] = truncate(dw3.object.com_qty[arg_row] * dw3.object.price[arg_row],0 )
end if

end subroutine

public function boolean wf_dw3chk ();long ll_row
date ld_date
string ls_subcon, ls_supp

dw_1.accepttext()
dw3.accepttext()
if dw_1.rowcount() < 1 then return false

if trim(dw_1.object.po_print[1]) = 'Y' then
	MessageBox("경고", "[pb_compute][dw_1] 벌써, 확정되었읍니다.", Exclamation!)
	return false
end if
ls_subcon = trim(dw_1.object.subcon[1])
ls_supp = trim(dw_1.object.supp_no[1])

if isnull(ls_supp) or ls_supp=""  then
	MessageBox("오류","거래처를 입력하십시오.", Exclamation!)
	dw_1.setcolumn('supp_no')
	dw_1.setfocus()
	return false
end if	

if isnull(ls_subcon) or ls_subcon=""  then
	MessageBox("오류","발주구분을 입력하십시오.", Exclamation!)
	dw_1.setcolumn('subcon')
	dw_1.setfocus()
	return false
end if

choose case ls_subcon
	case 'N','L','W'
	case else
		return false
end choose
if dw3.rowcount() < 1 and dw3.dataobject <> 'd_ippurdet' then
	dw3.dataobject = 'd_ippurdet'
	dw3.settransobject(sqlca)
end if
return true
end function

public function boolean wf_itemselect (datawindow arg_dw, string arg_ms, integer ai_row, integer ai_flag);//
gs_where2 lstr_where
long ll_row, ll_cnt, ll_row1

arg_dw.accepttext()

lstr_where.chk = arg_ms //'M' //M:multi S:single
ll_row1 = arg_dw.rowcount() + 1
if arg_ms = 'S' then
	if arg_dw = dw3 or ai_flag = 8 then
		lstr_where.str1[1] = arg_dw.object.item_no[ai_row]
		lstr_where.str2[1] = arg_dw.object.qa[ai_row]
	elseif arg_dw = dw4 then
		lstr_where.chk1 = tab_1.tabpage_2.dw_loc.object.loc_no[1]
		lstr_where.str1[1] = arg_dw.object.component[ai_row]
		lstr_where.str2[1] = arg_dw.object.component_qa[ai_row]
	else
		lstr_where.chk1 = arg_dw.object.issue_loc[ai_row]
		lstr_where.str1[1] = arg_dw.object.assy_item[ai_row]
		lstr_where.str2[1] = arg_dw.object.assy_qa[ai_row]
	end if
end if

openwithparm(w_whitemlocqohmulti_w,lstr_where)
lstr_where = Message.PowerObjectParm
if lstr_where.chk <> "Y" then return false

string ls_supp
dec {3} ld_cost
date ld_date
long ll,kk

ll = UpperBound(lstr_where.str1)
kk = UpperBound(lstr_where.str2)
arg_dw.SETREDRAW(FALSE)
for ll_row = 1 to UpperBound(lstr_where.str1)	
	if arg_ms = 'M' then
		ll_cnt = arg_dw.insertrow(0)
	else
		ll_row1 = ai_row
		ll_cnt  = ai_row
	end if
//	arg_dw.object.item_no[ll_cnt] = lstr_where.str1[ll_row]
//	arg_dw.object.qa[ll_cnt]      = lstr_where.str2[ll_row]
//	arg_dw.object.uom[ll_cnt]     = lstr_where.str3[ll_row]
//	arg_dw.object.item_item_name[ll_cnt] = lstr_where.name[ll_row]

	if arg_dw = dw3 then				// 발주서내역
		if arg_ms = 'M' then
			arg_dw.object.seq_no[ll_cnt]     = ll_cnt
			arg_dw.object.order_no[ll_cnt]   = trim(dw_1.object.order_no[1])
			arg_dw.object.rlse_date[ll_cnt]  = wf_today()
			arg_dw.object.purdet_serial_no[ll_cnt] = 0
			arg_dw.object.pur_type[ll_cnt]   = trim(dw_1.object.subcon[1])
			ld_date = DATE(dw_1.object.order_date[1])
			arg_dw.object.due_date[ll_cnt]   = RelativeDate( ld_date, dw_1.object.termS[1] )
		end if
		arg_dw.object.item_no[ll_cnt]  = lstr_where.str1[ll_row]
		arg_dw.object.qa[ll_cnt]       = lstr_where.str2[ll_row]
		arg_dw.object.com_uom[ll_cnt]  = lstr_where.str3[ll_row]
		
		choose case lstr_where.str3[ll_row]
			case 'M', 'M2'
				arg_dw.object.uom[ll_cnt] = 'EA'
			case else
				arg_dw.object.uom[ll_cnt] = lstr_where.str3[ll_row]
		end choose		
		arg_dw.object.item_item_name[ll_cnt] = lstr_where.name[ll_row]
		
		ls_supp =  dw_1.object.supp_no[1]
		if arg_dw.object.price[ll_cnt] = 0 or isnull(arg_dw.object.price[ll_cnt]) then
			/*2019.08.14 jowonsuk  최근단가가 기본이다. */
			if cbx_danga.checked then			
				ld_cost = wf_price1( ls_supp, lstr_where.str1[ll_row], lstr_where.str2[ll_row], lstr_where.str3[ll_row] )
			else
				ld_cost = wf_price( ls_supp, lstr_where.str1[ll_row], lstr_where.str2[ll_row], lstr_where.str3[ll_row] )
			end if				 
			 
			 arg_dw.object.price[ll_cnt]  = ld_cost
			 arg_dw.object.cprice[ll_cnt] = ld_cost
		end if
		
		dw_1.object.subcon.protect = true
		arg_dw.setcolumn('order_qty')
		
	elseif arg_dw = dw4 then		// 외주가공내역
		arg_dw.object.component[ll_cnt]    = lstr_where.str1[ll_row]
		arg_dw.object.component_qa[ll_cnt] = lstr_where.str2[ll_row]
		arg_dw.object.comp_uom[ll_cnt]     = lstr_where.str3[ll_row]
		arg_dw.object.itemname2[ll_cnt]    = lstr_where.name[ll_row]
		arg_dw.setcolumn('issue_qty')
		
	elseif arg_dw = dw8 then		// 자재가공내역
		if arg_ms = 'M' or ai_flag = 8 then
			arg_dw.object.item_no[ll_cnt]   = lstr_where.str1[ll_row]
			arg_dw.object.qa[ll_cnt]        = lstr_where.str2[ll_row]
			arg_dw.object.uom1[ll_cnt]      = lstr_where.str3[ll_row]
			arg_dw.object.groupitem_item_name1[ll_cnt] = lstr_where.name[ll_row]
		else
			arg_dw.object.assy_item[ll_cnt] = lstr_where.str1[ll_row]
			arg_dw.object.assy_qa[ll_cnt]   = lstr_where.str2[ll_row]
			arg_dw.object.uom2[ll_cnt]      = lstr_where.str3[ll_row]
			arg_dw.object.groupitem_item_name2[ll_cnt] = lstr_where.name[ll_row]
		end if
		arg_dw.setcolumn('order_qty')
	end if
next

dw_2.accepttext()
arg_dw.setfocus()
arg_dw.accepttext()
arg_dw.scrolltorow(ll_row1)

arg_dw.SETREDRAW(TRUE)
return true

end function

public function boolean wf_move4_new ();//
long    ll_rowcount, ll_rowcount1, ll_cnt,  ll_find, ll_row, ll_count, l_net
string  ls_plan, ls_order, ls_uom, ls_supp, ls_qa, ls_item, ls_subcon, ls_qa1, ls_scene, ls_saleno, ls_item_name
decimal {4} lr_cost, lr_qty
datetime ldt_due_date

dw_1.accepttext()
dw17.accepttext()

if dw_1.rowcount() < 1 then 
	MessageBox("오류","발주헤더를 입력하십시오.", Exclamation!)
	dw17.selectrow(0,false)
	RETURN false
end if	

ls_order  = trim(dw_1.object.order_no[1])
ls_subcon = trim(dw_1.object.subcon[1])

/* 2020.04.07 jowonsuk subcon 외주가공 */
//if ls_subcon = "Y" OR ls_subcon = "J" or ls_subcon = "P"  then
if ls_subcon = "Y" OR ls_subcon = "J"  then
	MessageBox("오류","구매발주가 아닙니다.", Exclamation!)
	dw17.selectrow(0,false)
	RETURN false
end if	

ls_supp = trim(dw_1.object.supp_no[1])
if isnull(ls_supp) or ls_supp = "" then
	MessageBox("오류","발주헤더에 거래처를 입력하십시오.", Exclamation!)
	dw17.selectrow(0,false)
	RETURN false
end if	

ll_rowcount1 = dw3.rowcount()
ll_rowcount  = dw17.rowcount()

ll_count = 0
for ll_cnt = 1 to ll_rowcount
	if dw17.isselected(ll_cnt) then
      ll_count ++
	end if
next
if ll_count = 0 then
	MessageBox('오류','수주대상물품을 선택하십시요.',exclamation!)
	RETURN false
end if

for ll_cnt = 1 to ll_rowcount
	
	if dw17.isselected(ll_cnt) then
		
		/*2019-10-28 jowonsuk 내용 수정 넘길건지 뺄건지 선택 가능하도록*/
		if dw17.object.rout_count[ll_cnt] = 'N' then

			ls_item_name = dw17.object.item_name[ll_cnt]
			
			l_net = MessageBox('확인',  string(ll_cnt) + '행 ' + ls_item_name +  ' 품목이 제품별공정관리에 등록되지 않았습니다. 발주에서 수기등록하시겠습니까?', Exclamation!, OKCancel!, 2)
			
			if l_net = 1 then
			else
				continue // 해당내역은 넘어가지 않도록한다. 		
			end if 
			
		end if		
		
		if ll_rowcount1 < 1 then
			ll_find = 0
		else
		   ll_find = dw3.find("item_no = '" + ls_item + "' and qa = '" + ls_qa + "'",1,dw3.rowcount())
		end if
		
		if ll_find = 0 then
			ls_item = trim(dw17.object.assembly[ll_cnt])
/*			ls_qa   = trim(dw17.object.assy_qa[ll_cnt])*/
			ls_qa   = trim(dw17.object.qa[ll_cnt])
			ls_uom  = trim(dw17.object.assembly_uom[ll_cnt])
			/*2019.08.14 jowonsuk  최근단가가 기본이다. */
			if cbx_danga.checked then			
			 	lr_cost = wf_price1(ls_supp, ls_item, ls_qa, ls_uom)
			else
				lr_cost = wf_price (ls_supp, ls_item, ls_qa, ls_uom)
			end if						 

			ll_row = dw3.insertrow(0)
			dw3.object.seq_no[ll_row]   = ll_row
			dw3.object.price[ll_row]    = lr_cost
			dw3.object.cprice[ll_row]   = lr_cost
			dw3.object.com_uom[ll_row]  = dw17.object.uom[ll_cnt]
			dw3.object.uom[ll_row]      = gf_uom(ls_uom)
			dw3.object.order_no[ll_row] = ls_order
			dw3.object.item_no[ll_row]  = ls_item
			dw3.object.qa[ll_row]       = ls_qa
			dw3.object.due_date[ll_row] = wf_today()
        		dw3.object.item_item_name[ll_row]  =  dw17.object.assembly_name[ll_cnt]
				  
			if dw17.object.req_qty[ll_cnt] < 0 then
				lr_qty = dw17.object.req_qty[ll_cnt] * -1
			else
				lr_qty = dw17.object.saledetqty[ll_cnt]
			end if
			
			dw3.object.com_qty[ll_row] = gf_getqty(ls_item, ls_qa, ls_uom, lr_qty)
			if is_round = 'Y' then
				dw3.object.amt[ll_row] = round(dw3.object.com_qty[ll_row] + dw3.object.price[ll_row],0 )
			else
				dw3.object.amt[ll_row] = truncate(dw3.object.com_qty[ll_row] + dw3.object.price[ll_row],0 )
			end if

			setnull(ls_scene)
			ls_saleno  = dw17.object.order_no[ll_cnt]
			dw3.object.sale_no[ll_row]    =  ls_saleno
			dw3.object.sale_seq[ll_row]   =  dw17.object.seq_no[ll_cnt]
			dw3.object.sale_rem[ll_row]   =  dw17.object.saledet_rem[ll_cnt]
			
			SELECT due_date, scene.scene_desc
			  INTO :ldt_due_date, :ls_scene 
			  FROM sale
			       LEFT OUTER JOIN scene ON sale.scene_code = scene.scene_code
			 WHERE order_no = :ls_saleno;
			if isnull(ls_scene) OR trim(ls_scene) = "" then
				ls_scene = ""
			else
				ls_scene = "/" + ls_scene
			end if
			
			dw3.object.cust_name[ll_row] = dw17.object.cust_name[ll_cnt] + ls_scene
			dw3.object.order_qty[ll_row] = lr_qty
//			dw3.object.com_qty[ll_row]   = lr_qty
			dw3.object.unit_qty[ll_row]  = lr_qty
			dw3.object.cnt[ll_row]       = 1
			dw3.object.rlse_date[ll_row] = ldt_due_date		// 확정일자
        		dw3.object.pur_type[ll_row]  = "N"
        		dw3.object.color[ll_row]     = dw17.object.color[ll_cnt]
        		dw3.object.rout_count[ll_row]     = dw17.object.rout_count[ll_cnt]				  
			
			dw17.RowsMove ( ll_cnt, ll_cnt, Primary!, dw17, 1, Filter! )
			
			ll_cnt = ll_cnt - 1
			
		end if
	end if
next

if ib_auto = true then
else
	MessageBox('확인','수주대상물품이 이동 되었습니다.',information!)
end if
//dw17.selectrow(0,false)
RETURN true

end function

public function decimal wf_price1 (string as_supp, string as_item, string as_qa, string as_uom);decimal {4} ld_cost
decimal {5} ld_m_kg
string  ls_qa1, ls_yyyymm
int     li_qa5

ld_cost = 0

//ls_yyyymm  = left(string(dw_1.object.order_date[1]),4)+mid(string(dw_1.object.order_date[1]),6,2)
//
//select a.amount
//  into :ld_cost
//from supplier_unit_det a inner join ( select supp_no, max(ver) ver
//											  from supplier_unit
//											where  yyyymm <= :ls_yyyymm
//												 and use_yn = 'Y'
//											 group by supp_no
//											  ) b on a.supp_no = b.supp_no and a.ver = b.ver
//where a.supp_no = :as_supp
//	and  a.item_no = :as_item
//	and  a.qa = :as_qa;		
	
	
SELECT TOP 1 MAX(A.PRICE)   AS PRICE 
     INTO :ld_cost
  FROM INSPDET A
		    INNER JOIN INSP B 
			ON A.INSP_NO    = B.INSP_NO
		  AND A.ITEM_NO     = :as_item  
		  AND A.QA   		    = :as_qa
 WHERE B.SUPP_NO        = :as_supp
 
	AND A.PRICE          <> 0
 GROUP BY CONVERT(CHAR(10), B.INSP_DATE, 111)
 ORDER BY CONVERT(CHAR(10), B.INSP_DATE, 111) DESC ;	
	
if sqlca.sqlcode <> 0 then 
	ld_cost = 0
end if

return ld_cost
end function

