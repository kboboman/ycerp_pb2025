footer(height=0 color="536870912" )
detail(height=84 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes name=user_id dbname="Level_log.user_id" )
 column=(type=char(50) update=yes updatewhereclause=yes name=user_desc dbname="Level_log.user_desc" )
 column=(type=char(8) update=yes updatewhereclause=yes name=acc_date dbname="Level_log.acc_date" )
 column=(type=char(12) update=yes updatewhereclause=yes name=acc_time dbname="Level_log.acc_time" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name dbname="login.user_name" )
 column=(type=char(4099) updatewhereclause=no name=level_log_se_etc dbname="Level_log.se_etc" )
 retrieve="  SELECT Level_log.user_id,   
         Level_log.user_desc,   
         Level_log.acc_date,   
         Level_log.acc_time,
			login.user_name,
			Level_log.se_etc
    FROM Level_log Level_log right join login login on Level_log.user_id = login.user_id
  WHERE Level_log.acc_date Between Replace(:as_start_date,'/','') and Replace(:as_end_date,'/','');" arguments=(("as_start_date", string),("as_end_date", string)) )
