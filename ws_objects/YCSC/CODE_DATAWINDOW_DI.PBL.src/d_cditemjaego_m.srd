release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=84 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="itemjaego.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=qa dbname="itemjaego.qa" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" initial=" " )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=area_no dbname="itemjaego.area_no" )
 retrieve="  SELECT itemjaego.item_no
       , itemjaego.qa
       , groupitem.item_name
       , itemjaego.area_no  
    FROM itemjaego
       , groupitem  
   WHERE ( itemjaego.item_no = groupitem.item_no )
     and ( itemjaego.area_no = :as_area          )   
   ORDER BY itemjaego.item_no ASC,   
            itemjaego.qa ASC   
" update="itemjaego" updatewhere=1 updatekeyinplace=no arguments=(("as_area", string)) )
