$PBExportComments$지점거래처_사업장
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=68 color="8421504" )
detail(height=68 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(4) updatewhereclause=yes name=cat dbname="cat" )
 retrieve="  SELECT cust_no   = customer.cust_no
       , cust_name = customer.cust_name
       , user_name = login.user_name  
       , cat       = 'CUST'
    FROM customer 
         LEFT OUTER JOIN login ON customer.salesman = login.user_id 
   WHERE customer.open_close <> 'C'

  UNION ALL
  SELECT cust_no   = area.area_no
       , cust_name = area.area_name
       , user_name = login.user_name  
       , cat       = 'AREA'
    FROM area
         LEFT OUTER JOIN login ON area.issue_accept_user = login.user_id
   WHERE area.real_area  = 'Y'
"  sort="cat A cust_name A " )
compute(band=footer alignment="2" expression="rowcount()"border="0" color="0" x="9" y="4" height="60" width="160" format="[GENERAL]" html.valueishtml="0"  name=compute_1 visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="553648127" )
