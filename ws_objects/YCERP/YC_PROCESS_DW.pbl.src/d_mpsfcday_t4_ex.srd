compute(band=detail alignment="1" expression=" if(left(  sfcday_assembly   ,1) = 'P' and mid(  sfcday_assembly  , 3,1) = 'Y' and (mid(  sfcday_assembly  , 7,1) = 'A' or mid(  sfcday_assembly , 7,1) = 'B' or mid(  sfcday_assembly , 7,1) = 'C' or mid(  sfcday_assembly , 7,1) = 'D'),    sfcday_plan_qty , if(  sfcday_uom = 'M2' or  sfcday_uom = 'SS' ,truncate( long(mid(   sfcday_assembly_qa ,5,4)) * long(mid(   sfcday_assembly_qa ,10,4)) *       sfcday_plan_qty / 1000000, 2), if(  sfcday_uom = 'M', if (   sfcday_plan_qty < 0 , truncate(long(mid(  sfcday_assembly_qa , 15,5)) *    sfcday_plan_qty / 1000 - 0.00001,2), truncate(long(mid(  sfcday_assembly_qa , 15,5)) *   sfcday_plan_qty / 1000 + 0.00001,2)) ,      sfcday_plan_qty ))) "border="2" color="0" x="4475" y="8" height="60" width="270" format="#,##0" html.valueishtml="0"  name=compute_5 visible="1"  font.face="굴림체" font.height="-9" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="553648127" )
