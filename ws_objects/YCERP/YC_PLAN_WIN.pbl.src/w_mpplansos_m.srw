type cb_request from commandbutton within tabpage_1
integer x = 265
integer y = 12
integer width = 434
integer height = 68
integer taborder = 100
boolean bringtotop = true
integer textsize = -9
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "소재신청 ▶"
end type

event clicked;// 소재신청 ▶
string ls_check, ls_itemno, ls_qa[], ls_orderno, ls_col, ls_divid, ls_metrial
long   ll_row,   ll_newrow, ll_cnt, ll_dw6_cnt

if dw_2.object.wc_no[1] = "" then
	if MessageBox("확인","전체 작업장 소재를 신청 하시겠습니까?", Exclamation!, OKCancel!, 2) = 2 then
		dw_2.setcolumn("wc_no")
		dw_2.setfocus()
		RETURN
	end if
end if

if dw5.rowcount() > 0 then ls_divid = dw5.object.div_id[1]
if isnull(ls_divid) OR ls_divid = "" then		// 미결재인 경우
	tab_1.selecttab(2)
	if MessageBox("확인","신규 소재신청 하시겠습니까?", Exclamation!, YesNo!, 2) = 1 then
		dw5.reset() ; dw6.reset()
		
		ll_row = dw5.insertrow(0)
		dw5.setfocus()
	else
		// 기존 내용에 추가하기
	end if
else	// 결재완료분은 수정할 수 없음
	if MessageBox("확인","신규 소재신청 하시겠습니까?", Exclamation!, YesNo!, 2) = 1 then
		ll_row = dw5.insertrow(0)
//		ll_row = dw6.insertrow(0)
		dw6.scrolltorow(ll_row)	
		dw5.setfocus()
	else
		RETURN
	end if	
end if


dw6.setredraw( false )
ll_dw6_cnt = dw6.rowcount()
for ll_row = 1 to dw3.rowcount()
	ls_check = dw3.object.chk[ll_row]
	
   if ls_check = "Y" then
		ll_cnt = ll_cnt + 1
		
		ll_newrow = dw6.insertrow(0)
		//dw6.ScrollToRow(ll_newrow)

		GF_SPLIT(dw3.object.qa[ll_row], "X", ls_qa)
		
		dw6.object.seq[ll_newrow]        = ll_dw6_cnt + ll_row                  // 순번
		dw6.object.sale_no[ll_newrow]    = dw3.object.sale_no[ll_row]    			// 수주번호
		dw6.object.seq_no[ll_newrow]     = dw3.object.seq_no[ll_row]     			// 수주순번
		dw6.object.cust_no[ll_newrow]    = dw3.object.cust_no[ll_row] 				// 거래처
		dw6.object.cust_name[ll_newrow]  = dw3.object.cust_name[ll_row] 			// 거래처명
		dw6.object.scene_desc[ll_newrow] = dw3.object.scene_desc[ll_row] 			// 현장명
		dw6.object.item_no[ll_newrow]    = dw3.object.item_no[ll_row] 				// 품목
		dw6.object.item_name[ll_newrow]  = dw3.object.item_name1[ll_row] 			// 품목명
		dw6.object.qa[ll_newrow]         = dw3.object.qa[ll_row]         			// 규격
		dw6.object.color[ll_newrow]      = dw3.object.color_name[ll_row] 			// 색상
		dw6.object.qty[ll_newrow]        = dw3.object.order_qty[ll_row]			// 주문수량
		dw6.object.salerem[ll_newrow]    = dw3.object.routtempnew_rem[ll_row]	// 수주비고
		
		ls_itemno = dw6.object.item_no[ll_newrow]
		dw6.object.metrial[ll_newrow]    = ls_qa[1]								// 신청소재
		// 소재체크
		if tab_1.tabpage_2.cbx_metrial.checked = true then
			SELECT TOP 1 metrial INTO :ls_metrial 
			  FROM itemsosdet 
			 WHERE item_no = :ls_itemno AND left(qa,3) = :ls_qa[1];
			if isnull(ls_metrial) OR ls_metrial = "" then
			else
				dw6.object.metrial[ll_newrow] = ls_metrial
			end if
		end if
		
		dw6.object.assembly[ll_newrow]   = dw3.object.item_name1[ll_row]	// 절곡명
		dw6.object.w1[ll_newrow]         = long(ls_qa[2])
		dw6.object.w2[ll_newrow]         = 0
		dw6.object.h1[ll_newrow]         = long(ls_qa[3])
		dw6.object.h2[ll_newrow]         = 0		
		dw6.object.width[ll_newrow]      = 0			// 소재W
		dw6.object.height[ll_newrow]     = 0			// 소재H
		
		dw6.object.askrem[ll_newrow]     = ""			// 신청비고
		dw6.object.rem[ll_newrow]        = ""			// 비고
	end if	
next
dw6.scrolltorow( 1 )
dw6.setredraw( true )

// 복사한 row 삭제하기 
for ll_row = dw3.rowcount() to 1 step -1
	ls_check = dw3.object.chk[ll_row]
   if ls_check = "Y" then
		dw3.deleterow( ll_row )
	end if	
next

cbx_1.checked = false			// 전체
tab_1.selecttab(2)				// 소재신청
dw5.setcolumn("subject")		// 제목
dw5.setfocus()

MessageBox("확인", string(ll_cnt) + " 건 소재신청 자료 복사완료!")

end event

