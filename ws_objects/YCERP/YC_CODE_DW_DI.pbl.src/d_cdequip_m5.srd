 retrieve="SELECT EQUIP_CODE,
       	 KIND,
		 SEQ,
		 GUBUN,
		 SPEC1,
		 SPEC2,
		 SPEC3,
		 SPEC_VALUE1,
		 SPEC_VALUE2,
		 SPEC_VALUE3,
		 ETC
  FROM EQUIPDET
WHERE EQUIP_CODE = :ARG_EQUIP_CODE
  AND KIND = '3'
" update="EQUIPDET" updatewhere=1 updatekeyinplace=no arguments=(("arg_equip_code", string)) )
