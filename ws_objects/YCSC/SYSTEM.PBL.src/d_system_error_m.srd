detail(height=1560 color="536870912" )
table(column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" )
 column=(type=char(10) updatewhereclause=yes key=yes name=user_id dbname="user_id" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=datetime updatewhereclause=yes key=yes name=msg_date dbname="msg_date" )
 column=(type=char(10) updatewhereclause=yes key=yes name=errornum dbname="errornum" )
 column=(type=char(255) updatewhereclause=yes name=swhere dbname="swhere" )
 column=(type=char(255) updatewhereclause=yes name=object dbname="object" )
 column=(type=char(255) updatewhereclause=yes name=sevent dbname="sevent" )
 column=(type=char(255) updatewhereclause=yes name=line dbname="line" )
 column=(type=char(255) updatewhereclause=yes name=message dbname="message" )
 column=(type=char(15) updatewhereclause=yes name=version dbname="version" )
 column=(type=datetime update=yes updatewhereclause=yes name=close_date dbname="close_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=close_id dbname="close_id" )
 column=(type=char(10) updatewhereclause=yes name=close_name dbname="close_name" )
 column=(type=char(2) update=yes updatewhereclause=yes name=rec_status dbname="rec_status" values="접수	A/보류	H/진행중	P/취소	C/완료	Y/" )
 column=(type=char(255) update=yes updatewhereclause=yes name=ret_message dbname="ret_message" )
 retrieve="  SELECT chk        = 'N'   
       , user_id    = a.user_id    
       , user_name  = b.user_name
       , msg_date   = a.msg_date   
       , errornum   = a.errornum   
       , swhere     = a.swhere     
       , object     = a.object     
       , sevent     = a.sevent     
       , line       = a.line       
       , message    = a.message    
       , version    = a.version    
       , close_date = a.close_date 
       , close_id   = a.close_id   
       , close_name = c.user_name
       , rec_status = a.rec_status
       , ret_message= a.ret_message
    FROM system_error A
         LEFT OUTER JOIN login B  ON a.user_id  = b.user_id   
         LEFT OUTER JOIN login C  ON a.close_id = c.user_id   
   WHERE (a.user_id  = :as_userid   )
     AND (a.msg_date = :ad_msgdate  )
     AND (a.errornum = :as_errornum )
" update="system_error" updatewhere=1 updatekeyinplace=no arguments=(("as_userid", string),("ad_msgdate", datetime),("as_errornum", string)) )
