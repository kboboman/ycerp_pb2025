$PBExportHeader$d_oeesti_s.srd
$PBExportComments$견적서 선택(1998/03/26, 정재수)
release 8;
datawindow(units=0 timer_interval=0 color=79219928 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes key=yes name=estimate_no dbname="estimate_head.estimate_no" )
 column=(type=char(1) updatewhereclause=yes name=esti_flag dbname="estimate_head.esti_flag" values="완결	Y/미결	N/보류	B/" )
 column=(type=char(60) updatewhereclause=yes name=cust_name dbname="estimate_head.cust_name" )
 retrieve="SELECT estimate_no,   esti_flag,   cust_name  
FROM estimate_head  
WHERE ( estimate_date between :ad_start and :ad_end ) AND  
	   ( system_no like :as_item or ( :as_item = '%' and system_no is null ) ) and   
	esti_flag like :as_flag AND  
	cust_name like :as_cust AND  
   user_id like :as_userid AND
	( scene_desc like :as_scene 
	 or ( :as_scene = '%' and (scene_desc is null or rtrim(scene_desc) = '') ) )" update="estimate_head" updatewhere=0 updatekeyinplace=no arguments=(("ad_start", date),("ad_end", date),("as_flag", string),("as_cust", string),("as_scene", string),("as_item", string),("as_userid", string))  sort="estimate_no D " )
text(band=header alignment="2" text="견적번호" border="6" color="0" x="9" y="12" height="60" width="512" html.valueishtml="0"  name=t_1 visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="79219928" )
text(band=header alignment="2" text="상태" border="6" color="0" x="530" y="12" height="60" width="160" html.valueishtml="0"  name=t_2 visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="79219928" )
text(band=header alignment="2" text="거래처" border="6" color="0" x="699" y="12" height="60" width="1019" html.valueishtml="0"  name=t_3 visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="79219928" )
column(band=detail id=2 alignment="2" tabsequence=32766 border="0" color="0~tcase(  esti_flag  when 'Y' then rgb(0,0,0) when 'N' then rgb(255, 0, 0) when 'B' then rgb(0, 0, 255))" x="530" y="4" height="60" width="160" format="[general]" html.valueishtml="0"  name=esti_flag visible="1" ddlb.limit=0 ddlb.allowedit=no ddlb.case=any ddlb.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="0" background.color="536870912~tif(getrow()=currentrow(), rgb(254, 252, 175), 78682240)" )
column(band=detail id=3 alignment="0" tabsequence=32766 border="0" color="0" x="699" y="4" height="60" width="1019" format="[general]" html.valueishtml="0"  name=cust_name visible="1" edit.limit=0 edit.case=any edit.autoselect=yes edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="0" background.color="536870912~tif(getrow()=currentrow(), rgb(254, 252, 175), 78682240)" )
column(band=detail id=1 alignment="0" tabsequence=32766 border="0" color="0" x="9" y="4" height="60" width="512" format="[general]" html.valueishtml="0"  name=estimate_no  tag="견적서번호" visible="1" edit.limit=14 edit.case=any edit.autoselect=no edit.autohscroll=yes edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="0" background.color="536870912~tif(getrow()=currentrow(), rgb(254, 252, 175), 78682240)" )
compute(band=footer alignment="2" expression="rowcount()"border="0" color="0" x="9" y="8" height="60" width="512" format="#,##0" html.valueishtml="0"  name=compute_1 visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
