table(column=(type=char(10) updatewhereclause=yes name=a_loc_no dbname="GroupItem.loc_no" )
 column=(type=char(30) updatewhereclause=yes name=c_loc_name dbname="GroupItem.loc_name" )
 column=(type=char(10) updatewhereclause=yes name=a_item_no dbname="GroupItem.item_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(20) updatewhereclause=yes name=a_qa dbname="GroupItem.qa" )
 column=(type=decimal(4) updatewhereclause=yes name=a_stock_qty dbname="stock_qty" )
 column=(type=long updatewhereclause=yes name=coil_stock_qty dbname="coil_stock_qty" )
 retrieve="         select a.loc_no loc_no,
                    c.loc_name loc_name,
                    a.item_no item_no,
                    b.item_name item_name,
                    a.qa qa,
                    SUM(a.stock_qty) stock_qty,
                    SUM(isnull(a.RCPT_QTY,0)) coil_stock_qty
          from 
          (                                      
                  select  
                  		 a.loc_no,
                  		 a.item_no,
                  		 a.qa,
                  		 sum(a.qty) stock_qty,
					0 RCPT_QTY
                  	from 
                  	(

                  				select 
                  						loc_no, 
                  						inaudit_item item_no, 
                  						qa, 
              							(isnull(rcpt_qty,0)) - (isnull(issue_qty,0)) QTY
                  				from inaudit with(nolock, index(inaudit_pk))
                  			     where inaudit_date  BETWEEN convert(datetime, substring(:as_date,1,6)+'01 00:00:00' ) and   dateadd(day, -1, dateadd(month, 1, convert(datetime, substring(:as_date,1,6)+'01 23:59:59') ))
                  				union all
                  				select  loc_no,                                 
                  						  item_no,
                  						  qa,           
               							 stock_qty qty
                  				from item_stock with(nolock)
                  				where stock_date = convert(char(8), dateadd(day, -1, convert(datetime, substring(:as_date,1,6)+'01') ),112)					
                 
                      ) a
                      group by 
					 a.loc_no,
					 a.item_no,
					 a.qa
				UNION ALL

				 SELECT  LOC_NO, 
							ITEM_NO, 
							 QA,            
							  0 STOCK_QTY,                                           
							 SUM(UNIT_QTY*QCNT) RCPT_QTY
					FROM COILMST
				where open_close in ( :as_oc )
					 and rcpt_date >= dateadd( year, -20, convert(datetime, :as_date) )
				GROUP BY ITEM_NO, 
								  QA, 
								  LOC_NO
								union all
				  SELECT LOC_NO, 
							  ITEM_NO, 
							QA,       
							0 STOCK_QTY,                                                     
							SUM(QCNT) RCPT_QTY
					FROM sheetmst
					where open_close in ( :as_oc )
					and rcpt_date >= dateadd( year, -20, convert(datetime, :as_date) )
					GROUP BY ITEM_NO, 
											  QA, 
											  LOC_NO       

          ) a inner join groupitem b with(nolock) on a.item_no = b.item_no
               inner join location  c  with(nolock) on a.loc_no = c.loc_no
        WHERE a.loc_no like :as_loc
             and  a.item_no like :as_item
             and substring(a.item_no,4,1) in ('1','2')
             and b.item_name NOT like '%LOSS%'
GROUP BY a.loc_no,
                    c.loc_name,
                    a.item_no,
                    b.item_name,
                    a.qa" arguments=(("as_loc", string),("as_item", string),("as_oc", stringlist),("as_date", string))  sort="a_loc_no A groupitem_item_name A a_qa A " )
