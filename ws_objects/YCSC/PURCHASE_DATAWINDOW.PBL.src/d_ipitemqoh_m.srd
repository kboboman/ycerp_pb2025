 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"itemqoh~" ) COLUMN(NAME=~"itemqoh.item_no~") COLUMN(NAME=~"itemqoh.qa~") COLUMN(NAME=~"itemqoh.loc_no~") COLUMN(NAME=~"itemqoh.item_name~") COLUMN(NAME=~"itemqoh.uom~") COLUMN(NAME=~"itemqoh.qoh~") COLUMN(NAME=~"itemqoh.pur_reserved~") COLUMN(NAME=~"itemqoh.reorder~") COLUMN(NAME=~"itemqoh.sales_reserved~")WHERE(    EXP1 =~"itemqoh.loc_no~"   OP =~"=~"    EXP2 =~":as_loc~" ) ) ARG(NAME = ~"as_loc~" TYPE = string) " filter=" lessqoh > 0"arguments=(("as_loc", string)) )
