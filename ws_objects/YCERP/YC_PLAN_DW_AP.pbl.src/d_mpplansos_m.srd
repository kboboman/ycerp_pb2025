$PBExportComments$생산계획 소재신청
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=464 color="536870912" )
table(column=(type=char(14) update=yes updatewhereclause=yes key=yes name=sos_no dbname="itemsos.sos_no" )
 column=(type=datetime update=yes updatewhereclause=yes key=yes name=sos_date dbname="itemsos.sos_date" )
 column=(type=char(50) update=yes updatewhereclause=yes name=subject dbname="itemsos.subject" )
 column=(type=char(100) update=yes updatewhereclause=yes name=bigo dbname="itemsos.bigo" )
 column=(type=char(10) update=yes updatewhereclause=yes name=user_id dbname="itemsos.user_id" )
 column=(type=char(10) updatewhereclause=yes name=user_nm dbname="user_nm" )
 column=(type=char(1) updatewhereclause=yes name=team_chk dbname="team_chk" values="	Y/	N" )
 column=(type=char(10) update=yes updatewhereclause=yes name=team_id dbname="itemsos.team_id" )
 column=(type=char(10) updatewhereclause=yes name=team_nm dbname="team_nm" )
 column=(type=char(1) updatewhereclause=yes name=div_chk dbname="div_chk" values="	Y/	N" )
 column=(type=char(10) update=yes updatewhereclause=yes name=div_id dbname="itemsos.div_id" )
 column=(type=char(10) updatewhereclause=yes name=div_nm dbname="div_nm" )
 column=(type=datetime update=yes updatewhereclause=yes name=sysdate dbname="itemsos.sysdate" )
 retrieve="  SELECT itemsos.sos_no,   
         itemsos.sos_date,
         itemsos.subject,   
         itemsos.bigo,   
         itemsos.user_id,   
         user_nm    = a.user_name,   
         team_chk   = (case when itemsos.team_id <> '' then 'Y' else 'N' end),
         itemsos.team_id,   
         team_nm    = b.user_name,
         div_chk    = (case when itemsos.div_id  <> '' then 'Y' else 'N' end),
         itemsos.div_id,   
         div_nm     = c.user_name,   
         itemsos.sysdate  
    FROM itemsos
         LEFT OUTER JOIN login a ON itemsos.user_id = a.user_id
         LEFT OUTER JOIN login b ON itemsos.team_id = b.user_id
         LEFT OUTER JOIN login c ON itemsos.div_id  = c.user_id
   WHERE itemsos.sos_no   = :as_sosno
" update="itemsos" updatewhere=0 updatekeyinplace=no arguments=(("as_sosno", string)) )
