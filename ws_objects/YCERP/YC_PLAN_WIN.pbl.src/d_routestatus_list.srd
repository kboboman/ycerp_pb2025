footer(height=68 color="8421504" )
detail(height=64 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=wc_no dbname="wc_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(1) updatewhereclause=yes name=pur_type dbname="pur_type" )
 column=(type=char(25) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=datetime updatewhereclause=yes name=get_date dbname="get_date" )
 column=(type=long updatewhereclause=yes name=routchk dbname="routchk" )
 column=(type=datetime updatewhereclause=yes name=due_date dbname="due_date" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(11) updatewhereclause=yes name=scene_code dbname="scene_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=char(14) updatewhereclause=yes name=order_no dbname="order_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="seq_no" )
 column=(type=char(10) updatewhereclause=yes name=wc1 dbname="wc1" )
 column=(type=char(10) updatewhereclause=yes name=wc2 dbname="wc2" )
 column=(type=char(10) updatewhereclause=yes name=wc3 dbname="wc3" )
 column=(type=char(10) updatewhereclause=yes name=wc1_nm dbname="wc1_nm" )
 column=(type=char(10) updatewhereclause=yes name=wc2_nm dbname="wc2_nm" )
 column=(type=char(10) updatewhereclause=yes name=wc3_nm dbname="wc3_nm" )
 column=(type=decimal(2) updatewhereclause=yes name=order_qty dbname="order_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=rlse_qty dbname="rlse_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=jan_qty dbname="jan_qty" )
 column=(type=decimal(5) updatewhereclause=yes name=calc_qty dbname="calc_qty" )
 retrieve="   SELECT wc_no       = a.wc_no
        , item_no     = a.item_no
        , item_name   = a.item_name
        , pur_type    = a.pur_type
        , qa          = a.qa
        , get_date    = getdate()
        , routchk     = datediff(day, getdate(), a.due_date)
        , due_date    = a.due_date
        , cust_no     = a.cust_no
        , cust_name   = a.cust_name
        , scene_code  = a.scene_code
        , scene_desc  = a.scene_desc
        , order_no    = a.order_no
        , seq_no      = a.seq_no
        , wc1         = a.wc1
        , wc2         = a.wc2
        , wc3         = a.wc3
        , wc1_nm      = isnull(w1.work_name,'')
        , wc2_nm      = isnull(w2.work_name,'')
        , wc3_nm      = isnull(w3.work_name,'')
        , order_qty   = a.order_qty
        , rlse_qty    = a.rlse_qty 
        , jan_qty     = a.jan_qty  
        , calc_qty    = a.calc_qty
     FROM (
          SELECT wc_no       = a.wc_no
               , item_no     = a.item_no
               , item_name   = a.item_name
               , pur_type    = a.pur_type
               , qa          = a.qa
               , due_date    = a.due_date
               , cust_no     = a.cust_no
               , cust_name   = c.cust_name
               , scene_code  = a.scene_code
               , scene_desc  = s.scene_desc
               , order_no    = a.order_no
               , seq_no      = a.seq_no
               , wc1         = max(a.wc1)
               , wc2         = max(a.wc2)
               , wc3         = max(a.wc3)
               , order_qty   = sum(a.order_qty)
               , rlse_qty    = sum(a.rlse_qty )
               , jan_qty     = sum(a.jan_qty  )
               , calc_qty    = sum(a.calc_qty )
            FROM (
                 /* 수주 한달전 부터 잔량이 존재하는 것(routstatus format) */
                 SELECT wc_no       = (SELECT top 1 wc_no from rout where item_no = sd.item_no and qa = sd.qa order by operation desc)
                      , item_no     = sd.item_no
                      , item_name   = r.item_name
                      , pur_type    = r.pur_type
                      , qa          = sd.qa
                      , qa19        = sd.qa19
                      , wc1         = (case when r.operation = 1 then r.wc_no else '' end)
                      , wc2         = (case when r.operation = 2 then r.wc_no else '' end)
                      , wc3         = (case when r.operation = 3 then r.wc_no else '' end)
                      , due_date    = sd.due_date
                      , order_qty   = (case when r.operation = 1 then sd.order_qty else 0 end)
                      , rlse_qty    = (case when r.operation = 1 then sd.rlse_qty  else 0 end)
                      , jan_qty     = (case when r.operation = 1 then sd.order_qty - sd.rlse_qty else 0 end)

                      , calc_qty    = (case when :as_wcno = 'P02' 
                                                 then (case when r.operation = 1 then 
                                                                 isnull(DBO.UF_GetItemCalc_PUB( 'P02', sd.item_no, sd.qa19, (sd.order_qty - sd.rlse_qty) ),0)
                                                            else 0
                                                       end)
                                            else (case when r.operation = 1 then 
                                                            isnull(DBO.UF_GetQty(sd.item_no, sd.qa19, sd.uom, (sd.order_qty - sd.rlse_qty) ), 0)
                                                       else 0
                                                  end)
                                       end)

                      , cust_no     = sd.cust_no
                      , scene_code  = sd.scene_code
                      , order_no    = sd.order_no
                      , seq_no      = sd.seq_no
                   FROM (
									SELECT s.cust_no, s.scene_code, sd.order_no, sd.seq_no, s.due_date
										  , sd.item_no, qa = left(sd.qa,14) + '00000', qa19 = sd.qa, sd.uom, sd.order_qty, sd.rlse_qty
									  FROM saledet SD with (nolock)
											 LEFT OUTER JOIN sale S with (nolock) ON sd.order_no  = s.order_no
									 WHERE (s.open_close     = 'O'             )
										AND (s.order_date    >= dateadd(month, -1, getdate() ) )
                        		) SD
                        LEFT OUTER JOIN (
													  SELECT a.item_no
															 , g.item_name
															 , g.pur_type
															 , a.qa
															 , operation  = a.operation
															 , wc_no      = a.wc_no
														 FROM (
																		/* 공정품목 */
																		SELECT r.item_no, r.qa, r.operation, r.wc_no
																		  FROM rout R with (nolock) 
																		 WHERE r.item_no IN (SELECT DISTINCT item_no FROM rout with (nolock) WHERE wc_no LIKE :as_wcno)
																) a
																LEFT OUTER JOIN groupitem G with (nolock) ON a.item_no = g.item_no AND g.use_flag = 'Y'
														WHERE g.item_name is not null
														  AND a.item_no    = :as_itemno
                        							) R ON sd.item_no = r.item_no AND sd.qa = r.qa
                  WHERE (sd.order_qty     - sd.rlse_qty > 0 )
                    AND (sd.due_date      = :as_duedate     )                       
                    AND (r.operation     is not null        )
                    AND ((:as_purtype = '%' OR r.pur_type = :as_purtype))
                 ) A
                 LEFT OUTER JOIN customer C with (nolock) ON a.cust_no    = c.cust_no
                 LEFT OUTER JOIN scene    S with (nolock) ON a.scene_code = s.scene_code
           GROUP BY a.wc_no
                  , a.item_no     
                  , a.item_name
                  , a.pur_type
                  , a.qa          
                  , a.due_date    
                  , a.cust_no
                  , c.cust_name
                  , a.scene_code
                  , s.scene_desc
                  , a.order_no
                  , a.seq_no
          ) A
          LEFT OUTER JOIN wc  w1 with (nolock) ON a.wc1 = w1.work_no
          LEFT OUTER JOIN wc  w2 with (nolock) ON a.wc2 = w2.work_no
          LEFT OUTER JOIN wc  w3 with (nolock) ON a.wc3 = w3.work_no
" arguments=(("as_wcno", string),("as_itemno", string),("as_duedate", string),("as_purtype", string))  sort="cust_name A scene_desc A item_name A " )
