 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"purdet~" )  TABLE(NAME=~"pur~" )  TABLE(NAME=~"groupitem~" )  TABLE(NAME=~"supp~" ) COLUMN(NAME=~"purdet.order_no~") COLUMN(NAME=~"purdet.seq_no~") COLUMN(NAME=~"purdet.item_no~") COLUMN(NAME=~"purdet.qa~") COLUMN(NAME=~"purdet.due_date~") COLUMN(NAME=~"purdet.order_qty~") COLUMN(NAME=~"purdet.rlse_date~") COLUMN(NAME=~"purdet.price~") COLUMN(NAME=~"purdet.uom~") COLUMN(NAME=~"purdet.rlse_qty~") COLUMN(NAME=~"purdet.product_no~") COLUMN(NAME=~"purdet.rcpt_loc~") COLUMN(NAME=~"purdet.pur_type~") COLUMN(NAME=~"purdet.rem~") COLUMN(NAME=~"purdet.coil_no~") COLUMN(NAME=~"purdet.serial_no~") COLUMN(NAME=~"purdet.work_type~") COLUMN(NAME=~"purdet.cnt~") COLUMN(NAME=~"pur.subcon~") COLUMN(NAME=~"groupitem.item_name~") COMPUTE(NAME=~"convert(decimal(15,4),0) rcpt_qty~") COLUMN(NAME=~"purdet.result_type~") COLUMN(NAME=~"purdet.com_qty~") COMPUTE(NAME=~"'N' chk~") COLUMN(NAME=~"purdet.sale_no~") COLUMN(NAME=~"purdet.sale_seq~") COLUMN(NAME=~"purdet.cust_name~") COLUMN(NAME=~"purdet.sale_rem~") COLUMN(NAME=~"purdet.color~") COLUMN(NAME=~"pur.fob~") COLUMN(NAME=~"pur.shipto_addr~") COLUMN(NAME=~"pur.curr_code~") COLUMN(NAME=~"pur.tax_sign~") COLUMN(NAME=~"purdet.unit_qty~") COLUMN(NAME=~"purdet.com_uom~") COLUMN(NAME=~"supp.round~")    JOIN (LEFT=~"purdet.order_no~"    OP =~"=~"RIGHT=~"pur.order_no~" )    JOIN (LEFT=~"purdet.item_no~"    OP =~"=~"RIGHT=~"groupitem.item_no~" )    JOIN (LEFT=~"pur.supp_no~"    OP =~"=~"RIGHT=~"supp.supp_no~" )WHERE(    EXP1 =~"pur.supp_no~"   OP =~"=~"    EXP2 =~":arg_supp~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"pur.po_print~"   OP =~"=~"    EXP2 =~"'Y'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"pur.open_close~"   OP =~"=~"    EXP2 =~"'O'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"purdet.result_type~"   OP =~"not in~"    EXP2 =~"('E','C')~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"pur.subcon~"   OP =~"=~"    EXP2 =~"'C'~" ) ) ARG(NAME = ~"arg_supp~" TYPE = string) " update="purdet" updatewhere=0 updatekeyinplace=yes arguments=(("arg_supp", string))  sort="order_no A seq_no A " )
