table(column=(type=char(14) update=yes updatewhereclause=yes key=yes name=do_no dbname="dodet.do_no" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=oi_no dbname="dodet.oi_no" )
 column=(type=long update=yes updatewhereclause=yes name=seq_no dbname="dodet.seq_no" )
