table(column=(type=char(14) update=yes updatewhereclause=yes key=yes name=do_no dbname="dodet.do_no" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=oi_no dbname="dodet.oi_no" )
 column=(type=long update=yes updatewhereclause=yes name=seq_no dbname="dodet.seq_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="dodet.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="dodet.qa" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa_cust dbname="dodet.qa_cust" )
 column=(type=decimal(2) updatewhereclause=yes name=ori_ship dbname="ori_ship" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=ship_qty dbname="dodet.ship_qty" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=price dbname="dodet.price" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=aroi_qty dbname="dodet.aroi_qty" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="dodet.uom" )
 column=(type=char(14) update=yes updatewhereclause=yes name=sale_no dbname="dodet.sale_no" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=rate_cash dbname="dodet.rate_cash" )
 column=(type=char(50) update=yes updatewhereclause=yes name=rem dbname="dodet.rem" )
 column=(type=char(3) updatewhereclause=yes name=do_curr_code dbname="do.curr_code" )
 column=(type=long updatewhereclause=yes name=sort_qty dbname="sort_qty" )
 column=(type=char(12) update=yes updatewhereclause=yes name=do_rem dbname="dodet.do_rem" )
 column=(type=char(20) update=yes updatewhereclause=yes name=coil_no dbname="dodet.coil_no" )
 column=(type=long update=yes updatewhereclause=yes name=cnt dbname="dodet.cnt" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="GroupItem.item_name" )
 column=(type=char(1) updatewhereclause=yes name=source dbname="GroupItem.source" )
 column=(type=char(10) update=yes updatewhereclause=yes name=loc_no dbname="dodet.loc_no" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=stock_qty dbname="dodet.stock_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=stock_o_qty dbname="dodet.stock_o_qty" )
 column=(type=char(1) updatewhereclause=yes name=tax_sign dbname="tax_sign" )
 column=(type=char(1) updatewhereclause=yes name=issue_flag dbname="issue_flag" initial="Y" values="미수불	Y/미수불	N" )
 column=(type=char(1) updatewhereclause=yes name=do_do_case dbname="do.do_case" )
 column=(type=decimal(4) updatewhereclause=yes name=price_org dbname="price_org" )
 column=(type=char(1) updatewhereclause=yes name=round dbname="customer.round" )
 column=(type=decimal(5) updatewhereclause=yes name=calc_qty dbname="calc_qty" )
 retrieve="  SELECT dodet.do_no   
       , dodet.oi_no   
       , dodet.seq_no   
       , dodet.item_no   
       , dodet.qa   
       , dodet.qa_cust   
       , ori_ship = dodet.ship_qty   
       , dodet.ship_qty   
       , dodet.price   
       , dodet.aroi_qty   
       , dodet.uom   
       , dodet.sale_no   
       , dodet.rate_cash   
       , dodet.rem   
       , do.curr_code   
       , sort_qty    = (case when price > 0 then 0 else 1 end)
       , dodet.do_rem   
       , dodet.coil_no   
       , dodet.cnt   
       , groupitem.item_name   
       , groupitem.source   
       , dodet.loc_no   
       , dodet.stock_qty   
       , dodet.stock_qty stock_o_qty   
       , tax_sign   = (SELECT tax_sign FROM sale WHERE sale.order_no = dodet.sale_no)
       , issue_flag = 'N'
       , do.do_case   
       , price_org  = dodet.price   
       , customer.round 
       , dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty) calc_qty
    FROM dodet   
         LEFT OUTER JOIN do        ON dodet.do_no    = do.do_no
         LEFT OUTER JOIN customer  ON do.cust_no     = customer.cust_no
         LEFT OUTER JOIN groupitem ON dodet.item_no  = groupitem.item_no
   WHERE ( dodet.do_no  = :as_dono )
" update="dodet" updatewhere=0 updatekeyinplace=no arguments=(("as_dono", string))  sort="oi_no A " )
