table(column=(type=char(10) updatewhereclause=yes name=itemloc_item_no dbname="itemloc.item_no" initial=" " )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" initial=" " )
 column=(type=char(20) updatewhereclause=yes name=itemloc_qa dbname="itemloc.qa" )
 column=(type=char(2) updatewhereclause=yes name=groupitem_uom dbname="groupitem.uom" initial=" " )
 column=(type=decimal(4) updatewhereclause=yes name=qoh dbname="qoh" )
 column=(type=decimal(4) updatewhereclause=yes name=reserved dbname="reserved" )
 column=(type=char(10) updatewhereclause=yes name=itemjaego_item_no dbname="itemjaego.item_no" )
 retrieve="  SELECT itemloc.item_no
       , groupitem.item_name
       , itemloc.qa
       , groupitem.uom
       , sum(itemloc.qoh) qoh
       , sum(itemloc.reserved) reserved
       , itemjaego.item_no  
    FROM itemloc 
         LEFT OUTER JOIN itemjaego ON itemloc.item_no = itemjaego.item_no AND itemloc.qa = itemjaego.qa
       , groupitem
       , location  
   WHERE ( itemloc.item_no    = groupitem.item_no ) 
     and ( itemloc.loc_no     = location.loc_no   ) 
     and ( ( location.loc_type      = 'N'       ) AND  
           ( itemloc.item_no     like :arg_str  ) AND  
           ( groupitem.item_name like :arg_name ) AND  
           ( itemjaego.area_no      = :as_area  ) 
         )   
   GROUP BY itemloc.item_no
          , itemloc.qa
          , itemjaego.item_no
          , groupitem.item_no
          , groupitem.uom
          , groupitem.item_name  
   ORDER BY itemloc.item_no ASC,   
            itemloc.qa ASC   
" filter="isNull( itemjaego_item_no )"arguments=(("arg_str", string),("arg_name", string),("as_area", string)) )
