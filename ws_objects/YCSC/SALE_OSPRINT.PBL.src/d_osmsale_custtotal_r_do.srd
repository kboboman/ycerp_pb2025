footer(height=68 color="12639424" )
detail(height=80 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=decimal(6) updatewhereclause=yes name=day_doamt dbname="day_doamt" )
 retrieve="  SELECT cust_no          = a.cust_no        
       , day_doamt        = a.amt
    FROM (                     
           SELECT aa.cust_no   
                , amt = aa.amt /* + BB.SHIP_AMOUNT 운반비 제외 */
             FROM (/* 출고 합계금액으로 변경 */
                   SELECT a.cust_no, amt = sum(a.do_total) / 1.1
                     FROM do  A
                          LEFT OUTER JOIN customer  C ON a.cust_no = c.cust_no
                    WHERE ( a.do_date         = :ad_date      )
                      AND ( a.sale_flag      IN ('D','L','E') )
                      AND ( c.credit_level   IN ( :as_level ) )
                      AND ( c.salesman     LIKE :as_salesman  )
                      AND ( c.open_close   LIKE :as_openclose )
                    GROUP BY a.cust_no
                  ) AA,
                  (SELECT a.cust_no
                        , ship_amount = sum(a.ship_amount * 1.1)
                     FROM do  A
                          LEFT OUTER JOIN customer  C ON a.cust_no = c.cust_no
                    WHERE ( a.do_date         = :ad_date      )
                      AND ( a.sale_flag      IN ('D','L','E') )
                      AND ( c.credit_level   IN ( :as_level ) )
                      AND ( c.salesman     LIKE :as_salesman  )
                      AND ( c.open_close   LIKE :as_openclose )
                    GROUP BY a.cust_no
                   ) BB
             WHERE aa.cust_no   = bb.cust_no
         ) A
     ORDER BY a.cust_no
" arguments=(("ad_date", date),("as_salesman", string),("as_level", stringlist),("as_openclose", string)) )
