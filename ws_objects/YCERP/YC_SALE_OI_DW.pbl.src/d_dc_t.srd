 column=(type=char(5) updatewhereclause=yes name=dc_balteam dbname="dc_balteam" )
 column=(type=char(5) updatewhereclause=yes name=dc_hyupteam dbname="dc_hyupteam" )
 column=(type=char(4) updatewhereclause=yes name=dc_type dbname="dc_type" )
 column=(type=decimal(4) updatewhereclause=yes name=price dbname="price" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_name dbname="scene_name" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(30) updatewhereclause=yes name=team_name dbname="team_name" )
 retrieve="  SELECT dc_no        = a.dc_no       
       , dc_date      = convert(char(10),a.dc_date,111)
       , user_id      = a.user_id     
       , team_code    = a.team_code   
       , do_no        = a.do_no     
       , cust_no      = a.cust_no     
       , scene_code   = a.scene_code  
       , dc_title     = a.dc_title    
       , dc_app1      = a.dc_app1     
       , dc_appdt1    = isnull(convert(char(16),a.dc_appdt1,120),'')
       , dc_app2      = a.dc_app2     
       , dc_appdt2    = isnull(convert(char(16),a.dc_appdt2,120),'')
       , dc_app3      = a.dc_app3     
       , dc_appdt3    = isnull(convert(char(16),a.dc_appdt3,120),'')
       , dc_app4      = a.dc_app4     
       , dc_appdt4    = isnull(convert(char(16),a.dc_appdt4,120),'')
       , dc_app5      = a.dc_app5     
       , dc_appdt5    = isnull(convert(char(16),a.dc_appdt5,120),'')
       , dc_balteam   = a.dc_balteam  
       , dc_hyupteam  = a.dc_hyupteam 
       , dc_type      = a.dc_type
       , price        = b.price
       , cust_name    = c.cust_name
       , scene_name   = e.scene_desc
       , user_name    = d.user_name
       , team_name    = f.team_name
    FROM dc  a
         LEFT OUTER JOIN dcdet    b ON a.dc_no      = b.dc_no
         LEFT OUTER JOIN customer c ON a.cust_no    = c.cust_no
         LEFT OUTER JOIN login    d ON a.user_id    = d.user_id
         LEFT OUTER JOIN scene    e ON a.scene_code = e.scene_code
         LEFT OUTER JOIN team     f ON a.team_code  = f.team_code
   WHERE convert(char(10),a.dc_date,111)     BETWEEN :as_sdate AND :as_edate
     AND ((a.dc_app3     LIKE :as_app3 + '%') or     /* 본부장전결 */
          (:as_app3   = 'TOP' And b.price > 100000)
         )" arguments=(("as_sdate", string),("as_edate", string),("as_app3", string))  sort="dc_no D " )
