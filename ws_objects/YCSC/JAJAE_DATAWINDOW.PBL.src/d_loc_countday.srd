$PBExportHeader$d_loc_countday.srd
$PBExportComments$저장소 실사일자
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=loc_no dbname="location.loc_no" )
 column=(type=char(30) update=yes updatewhereclause=yes name=loc_name dbname="location.loc_name" )
 column=(type=char(10) update=yes updatewhereclause=yes name=count_date dbname="count_date" )
 column=(type=char(6) update=yes updatewhereclause=yes name=loc_type dbname="loc_type" )
 column=(type=char(10) update=yes updatewhereclause=yes name=area_no dbname="area_no" )
 column=(type=long update=yes updatewhereclause=yes name=seq dbname="seq" )
 retrieve="SELECT loc_no
     , loc_name
     , count_date = convert(char(10), count_date, 111)
     , loc_type   = (case when loc_type = 'N' then '사내'
                          when loc_type = 'Y' then '사외'
                          when loc_type = 'W' then '작업장'
                     end)
     , area_no    = isnull(area_no,'')
     , seq        = (case when loc_type = 'N' then 1
                          when loc_type = 'W' then 2
                          else 3
                     end)
  FROM LOCATION 
 WHERE use_yn ='Y'
 ORDER BY seq, loc_no
" update="LOCATION" updatewhere=1 updatekeyinplace=no )
