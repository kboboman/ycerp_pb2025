table(column=(type=char(60) updatewhereclause=yes name=item_name dbname="groupitem.item_name" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="mpsdet.item_no" )
 column=(type=char(2) updatewhereclause=yes name=groupitem_uom dbname="groupitem.uom" )
 retrieve="PBSELECT( VERSION(400) DISTINCT ()TABLE(NAME=~"mpsdet~" )  TABLE(NAME=~"mps~" )  TABLE(NAME=~"groupitem~" ) COLUMN(NAME=~"groupitem.item_name~") COLUMN(NAME=~"mpsdet.item_no~") COLUMN(NAME=~"groupitem.uom~")    JOIN (LEFT=~"mpsdet.order_no~"    OP =~"=~"RIGHT=~"mps.order_no~" )    JOIN (LEFT=~"mpsdet.item_no~"    OP =~"=~"RIGHT=~"groupitem.item_no~" )WHERE(    EXP1 =~"mps.start_date~"   OP =~"between~"    EXP2 =~":ad_start and :ad_end~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"mps.open_close~"   OP =~"<>~"    EXP2 =~"'C'~" ) ) ARG(NAME = ~"ad_start~" TYPE = date)  ARG(NAME = ~"ad_end~" TYPE = date) " arguments=(("ad_start", date),("ad_end", date))  sort="item_name A " )
