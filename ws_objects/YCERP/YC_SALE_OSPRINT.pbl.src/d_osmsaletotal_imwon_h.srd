 retrieve="  SELECT opeom.cust_no   
       , opeom.balbf_amount   
       , opeom.inv_01   
       , opeom.inv_02   
       , opeom.inv_03   
       , opeom.inv_04   
       , opeom.inv_05   
       , opeom.inv_06   
       , opeom.inv_07   
       , opeom.inv_08   
       , opeom.inv_09   
       , opeom.inv_10   
       , opeom.inv_11   
       , opeom.inv_12   
       , opeom.coll_01   
       , opeom.coll_02   
       , opeom.coll_03   
       , opeom.coll_04   
       , opeom.coll_05   
       , opeom.coll_06   
       , opeom.coll_07   
       , opeom.coll_08   
       , opeom.coll_09   
       , opeom.coll_10   
       , opeom.coll_11   
       , opeom.coll_12   
       , customer.salesman 
       , customer.credit_level   
       , customer.level_grade   
       , login.user_name   
       , customer.cust_name   
       , cust_aim.inv_01   
       , cust_aim.inv_02   
       , cust_aim.inv_03   
       , cust_aim.inv_04   
       , cust_aim.inv_05   
       , cust_aim.inv_06   
       , cust_aim.inv_07   
       , cust_aim.inv_08   
       , cust_aim.inv_09   
       , cust_aim.inv_10   
       , cust_aim.inv_11   
       , cust_aim.inv_12   
       , cust_aim.coll_01   
       , cust_aim.coll_02   
       , cust_aim.coll_03   
       , cust_aim.coll_04   
       , cust_aim.coll_05   
       , cust_aim.coll_06   
       , cust_aim.coll_07   
       , cust_aim.coll_08   
       , cust_aim.coll_09   
       , cust_aim.coll_10   
       , cust_aim.coll_11   
       , cust_aim.coll_12   
       , cust_aim.mod_01   
       , cust_aim.mod_02   
       , cust_aim.mod_03   
       , cust_aim.mod_04   
       , cust_aim.mod_05   
       , cust_aim.mod_06   
       , cust_aim.mod_07   
       , cust_aim.mod_08   
       , cust_aim.mod_09   
       , cust_aim.mod_10   
       , cust_aim.mod_11   
       , cust_aim.mod_12   
       , cust_aim.del_01   
       , cust_aim.del_02   
       , cust_aim.del_03   
       , cust_aim.del_04   
       , cust_aim.del_05   
       , cust_aim.del_06   
       , cust_aim.del_07   
       , cust_aim.del_08   
       , cust_aim.del_09   
       , cust_aim.del_10   
       , cust_aim.del_11   
       , cust_aim.del_12
       , collect_ymd = convert(char(10),customer.collect_ymd,111)
       , reg_no      = customer.register_no
       , customer.price_level
       , mgr_type    = (SELECT item_nm FROM codemst WHERE type = 'MGR_TYPE' and use_yn = 'Y' and item_cd = customer.mgr_type)
       , mgr_sort    = isnull((SELECT sort FROM codemst WHERE type = 'MGR_TYPE' and use_yn = 'Y' and item_cd = customer.mgr_type),99)
       , colllevel   = v_customer.colllevel
       , cust_idx    = cs.cust_idx
       , custname_sort = replace(replace(replace(customer.cust_name,'(주)',''),'(재)',''),'(사)','')
       , customer.class  
       , top_level   = customer.top_level	
	    , convert(int, dbo.uf_toplevel_sort(customer.top_level)) GRAND_LEVEL
      , customer.rotate
      , '2' gubun
    FROM opeom with(nolock) inner JOIN cust_aim with(nolock)  ON opeom.cust_no = cust_aim.cust_code AND datepart(year,opeom.eom_year) = datepart(year,cust_aim.tar_year)
                                                                                                                                                                                  AND datepart(year,cust_aim.tar_year)    = :an_year 
         LEFT OUTER JOIN customer with(nolock)  ON opeom.cust_no = customer.cust_no  
         LEFT OUTER JOIN v_customer with(nolock) ON opeom.cust_no = v_customer.cid  
         LEFT OUTER JOIN login with(nolock) ON customer.salesman = login.user_id 
         LEFT OUTER JOIN customer_sort CS with(nolock)  ON opeom.cust_no = cs.cust_no
   WHERE ( datepart(year,opeom.eom_year)       = :an_year )      
          and  ( customer.imwon_user_id  LIKE :as_saleman )    " arguments=(("an_year", number),("as_saleman", string))  sort="cust_idx A login_user_name A grand_level A mgr_sort A customer_cust_name A " )
group(level=1 header.height=0 trailer.height=72 by=("cust_no" ) header.color="536870912" trailer.color="12639424" )
