datawindow(units=0 timer_interval=0 color=79741120 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=item_no dbname="item.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="item.qa" )
 column=(type=decimal(4) updatewhereclause=yes name=item_qoh dbname="item.qoh" )
 column=(type=decimal(4) updatewhereclause=yes name=sumqoh dbname="sumqoh" )
 retrieve="PBSELECT( VERSION(400) DISTINCT ()TABLE(NAME=~"item~" )  TABLE(NAME=~"itemloc~" ) COLUMN(NAME=~"item.item_no~") COLUMN(NAME=~"item.qa~") COLUMN(NAME=~"item.qoh~") COMPUTE(NAME=~"sum(itemloc.qoh) sumqoh~")    JOIN (LEFT=~"item.item_no~"    OP =~"=~"RIGHT=~"itemloc.item_no~"    OUTER1 =~"item.item_no~" )    JOIN (LEFT=~"item.qa~"    OP =~"=~"RIGHT=~"itemloc.qa~"    OUTER1 =~"item.qa~" )WHERE(    EXP1 =~"item.item_no~"   OP =~"like~"    EXP2 =~":as_item~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"item.item_name~"   OP =~"like~"    EXP2 =~":as_name~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"(item.qoh~"   OP =~"<~"    EXP2 =~"0~"    LOGIC =~"or~" ) WHERE(    EXP1 =~"itemloc.qoh~"   OP =~"<~"    EXP2 =~"0 )~" )  GROUP(NAME=~"item.item_no~") GROUP(NAME=~"item.qa~") GROUP(NAME=~"item.qoh~")   HAVING (   EXP1 =~"item.qoh~"   OP =~"=~"    EXP2 =~"sum(itemloc.qoh)~" )) ARG(NAME = ~"as_item~" TYPE = string)  ARG(NAME = ~"as_name~" TYPE = string) " arguments=(("as_item", string),("as_name", string)) )
column(band=detail id=1 alignment="0" tabsequence=32766 border="5" color="0" x="1065" y="4" height="60" width="352" format="[general]"  name=item_no  tag="물품코드" edit.limit=10 edit.case=any edit.autoselect=yes edit.autohscroll=yes  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="0" background.color="536870912~tif (getrow() = currentrow(), RGB(254,252,175), 78682240)" )
column(band=detail id=2 alignment="0" tabsequence=32766 border="5" color="0" x="1440" y="4" height="60" width="640" format="[general]"  name=qa edit.limit=0 edit.case=any edit.autoselect=yes  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
column(band=detail id=3 alignment="0" tabsequence=32766 border="5" color="0" x="2103" y="4" height="60" width="512" format="[general]"  name=item_qoh edit.limit=0 edit.case=any edit.autoselect=yes  font.face="굴림체" font.height="-10" font.weight="400"  font.family="2" font.pitch="2" font.charset="129" background.mode="1" background.color="536870912" )
column(band=detail id=4 alignment="0" tabsequence=32766 border="5" color="0" x="2638" y="4" height="60" width="512" format="[general]"  name=sumqoh edit.limit=0 edit.case=any edit.autoselect=yes  font.face="굴림체" font.height="-10" font.weight="400"  font.family="2" font.pitch="2" font.charset="129" background.mode="1" background.color="536870912" )

