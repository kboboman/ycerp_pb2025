 column=(type=long updatewhereclause=yes name=oi_no dbname="oi_no" )
 column=(type=char(20) updatewhereclause=yes name=lot_no dbname="lot_no" )
 column=(type=long updatewhereclause=yes name=serial_no dbname="serial_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
