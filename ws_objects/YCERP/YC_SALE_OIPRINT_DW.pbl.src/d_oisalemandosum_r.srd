$PBExportComments$영업사원 출고현황 집계표
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="79741120" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(4) updatewhereclause=yes name=do_cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(11) updatewhereclause=yes name=do_spot_code dbname="spot_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=decimal(1) updatewhereclause=yes name=ship_amount dbname="ship_amount" )
 column=(type=decimal(4) updatewhereclause=yes name=do_rate dbname="do_rate" )
 column=(type=decimal(4) updatewhereclause=yes name=do_cash dbname="do_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=do_total dbname="do_total" )
 retrieve="  SELECT distinct user_name   = a.user_name          
       , cust_no     = a.cust_no            
       , cust_name   = a.cust_name
       , spot_code   = a.spot_code     
       , scene_desc  = a.scene_desc  
       , ship_amount = sum(a.ship_amount)
       , do_rate     = sum(a.do_rate )
       , do_cash     = sum(a.do_cash )
       , do_total    = sum(a.do_total)
    FROM (
         SELECT /*user_name   = e.user_name*/
               user_name = m.user_name          
              , cust_no     = a.cust_no            
              , cust_name   = d.cust_name
              , spot_code   = a.spot_code     
              , scene_desc  = f.scene_desc  
              , do_no       = a.do_no
              , do_date     = convert(char(10), a.do_date, 111)
              , ship_amount = (case when a.ship_flag = 'D' and a.shipamt_case = 'R' then (case when a.do_rate <> 0 then a.ship_amount * 1.1 else a.ship_amount end) else 0 end)
              , do_rate     = a.do_rate            
              , do_cash     = a.do_cash            
              , do_total    = a.do_total                                
           FROM UF_MyCustomers( :as_salesman ) M
                LEFT OUTER JOIN customer D ON m.cust_no     = d.cust_no
                LEFT OUTER JOIN do        A ON m.cust_no     = a.cust_no
                LEFT OUTER JOIN scene  F ON a.spot_code   = f.scene_code 
                LEFT OUTER JOIN login    E ON d.salesman    = e.user_id
          WHERE ( a.area_no        LIKE :as_area ) 
            AND ( convert(char(10), a.do_date, 111)     BETWEEN :as_sdate AND :as_edate ) 
            AND ((:as_team  = '%' AND m.cust_no   LIKE '%'  ) OR 
                 (:as_team <> '%' AND m.salesman     = :as_salesman )
                )
            AND ((:as_custno  = '%'   AND m.cust_no   LIKE '%'  ) OR 
                 (:as_custno  = 'ALL' AND m.cust_no   LIKE '%'  ) OR 
                 (:as_custno <> 'ALL' AND m.cust_no      = :as_custno )
                )
         ) A
   GROUP BY a.user_name          
          , a.cust_no            
          , a.cust_name
          , a.spot_code     
          , a.scene_desc  
   ORDER BY a.user_name, a.cust_name, a.scene_desc
   " arguments=(("as_area", string),("as_custno", string),("as_sdate", string),("as_edate", string),("as_salesman", string),("as_team", string)) )
