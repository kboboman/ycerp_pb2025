table(column=(type=char(14) update=yes updatewhereclause=yes name=order_no dbname="order_no" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(11) updatewhereclause=yes name=scene_code dbname="scene_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=char(10) update=yes updatewhereclause=yes name=user_id dbname="user_id" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=datetime update=yes updatewhereclause=yes name=input_date dbname="input_date" )
 column=(type=char(10) updatewhereclause=yes name=recv_id dbname="recv_id" )
 column=(type=char(10) updatewhereclause=yes name=recv_name dbname="recv_name" )
 column=(type=char(10) update=yes updatewhereclause=yes name=accept_user dbname="accept_user" )
 column=(type=char(10) updatewhereclause=yes name=accept_name dbname="accept_name" )
 column=(type=datetime update=yes updatewhereclause=yes name=accept_date dbname="accept_date" )
 column=(type=char(1) updatewhereclause=yes name=open_close dbname="open_close" values="	C/	O" )
 column=(type=char(1) updatewhereclause=yes name=close_type dbname="close_type" values="수동	M/자동	A/" )
 column=(type=datetime updatewhereclause=yes name=close_date dbname="close_date" )
 column=(type=long updatewhereclause=yes name=ret_time dbname="ret_time" )
 column=(type=char(4099) updatewhereclause=no name=bigo dbname="bigo" )
 retrieve="  SELECT order_no     = sc.order_no   
       , cust_no      = sc.cust_no
       , cust_name    = c.cust_name
       , scene_code   = sc.scene_code
       , scene_desc   = s.scene_desc
       , user_id      = sc.user_id   
       , user_name    = l1.user_name
       , input_date   = sc.input_date   
       , recv_id      = sc.recv_id
       , recv_name    = l3.user_name
       , accept_user  = sc.accept_user  
       , accept_name  = l2.user_name
       , accept_date  = sc.accept_date  
       , open_close   = sale.open_close
       , close_type   = sale.close_type
       , close_date   = sale.close_date
       , ret_time     = datediff(mi, sc.input_date, sale.close_date)
       , bigo         = sc.bigo
    FROM sale_close SC
         LEFT OUTER JOIN login L1   ON sc.user_id     = l1.user_id
         LEFT OUTER JOIN login L2   ON sc.accept_user = l2.user_id
         LEFT OUTER JOIN login L3   ON sc.recv_id     = l3.user_id
         LEFT OUTER JOIN customer C ON sc.cust_no     = c.cust_no  
         LEFT OUTER JOIN SCENE    S ON sc.scene_code  = s.scene_code
         LEFT OUTER JOIN sale       ON sc.order_no    = sale.order_no
   WHERE (sc.input_date  between :as_sdate + ' 00:00:00.000' AND :as_edate + ' 23:59:59.999')
" arguments=(("as_sdate", string),("as_edate", string))  sort="input_date D " )
