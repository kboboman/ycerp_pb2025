 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 retrieve="select 
	 distinct A.cust_no
	,B.cust_name  
from 
	orexceed A left outer join customer B on A.cust_no = B.cust_no
order by 
	B.cust_name" )
