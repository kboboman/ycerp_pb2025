$PBExportHeader$d_iractio_s.srd
$PBExportComments$실사차이보고서(2000/09/02,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="12639424" )
detail(height=80 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=itemloc_item_no dbname="item_no" )
 column=(type=char(20) updatewhereclause=yes name=itemloc_qa dbname="qa" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=char(2) updatewhereclause=yes name=groupitem_uom dbname="uom" )
 column=(type=char(30) updatewhereclause=yes name=itemloc_loc_name dbname="loc_name" )
 column=(type=char(26) updatewhereclause=yes name=title dbname="title" )
 column=(type=decimal(4) updatewhereclause=yes name=qoh dbname="qoh" initial="0" )
 column=(type=decimal(2) updatewhereclause=yes name=eom_qoh dbname="eom_qoh" )
 retrieve="SELECT item_no,   
		qa,   
		item_name,   
		uom,
		loc_name,
		title,
		qoh = isnull(SUM(eom_qoh),0),   /* 실사수량 */
		eom_qoh = isnull(SUM(cineoym.eom_qoh),0) - isnull(SUM(cineoym.def_qty),0)
	FROM
			( SELECT ineoym.item_no,   
						ineoym.qa,   
						groupitem.item_name,   
						uom = dbo.uf_getuom(groupitem.uom),   
						eom_qoh = ineoym.qoh,
						def_qty = 0,
						loc_name,
						title =  convert(char(4),:as_year) + '년 ' + convert(char(2), :as_mon) + '월 실사차이보고서'
				 FROM ineoym,   
						groupitem,
						location 
				WHERE ( ineoym.item_no = groupitem.item_no ) and  
						( ineoym.item_no < 'PZZZ' ) and
						( ineoym.item_no NOT IN ('GZZZMISZZZ', 'GCYZZZZZZZ') ) and
						( use_flag <> 'C' ) and 
						( ineoym.loc_no = location.loc_no) and  
						( ( ineoym.loc_no = :as_loc ) AND  
						( ineoym.cyear = :as_year ) AND  
						( ineoym.cmon = :as_mon ) AND  
						( NOT(groupitem.uom = 'M2' and groupitem.item_no like 'PCY%') ) and
					/* ( left(ineoym.item_no, 2) <> ~"M1~" AND left(ineoym.item_no, 2) <> ~"M3~") AND */
						( ineoym.item_no like :as_item AND  
						groupitem.item_name like :as_name) )          
			union all
			  SELECT item_no = inaudit.inaudit_item,   
						inaudit.qa,   
						groupitem.item_name,   
						uom = dbo.uf_getuom(groupitem.uom),   
						eom_qoh = 0,
						def_qty = inaudit.rcpt_qty - inaudit.issue_qty,
						loc_name,
						title =  convert(char(4),:as_year) + '년 ' + convert(char(2), :as_mon) + '월 실사차이보고서'
				 FROM inaudit,   
						location,
						groupitem  
				WHERE ( ( DATEPART(year, inaudit.inaudit_date) = :as_year ) AND  
						( DATEPART(month, inaudit.inaudit_date) = :as_mon )  ) AND  
						( inaudit.inaudit_type in ('RX', 'IX')  ) AND  
					/*	( inaudit.inaudit_item not like ~"M1%~" AND inaudit.inaudit_item not like  ~"M3%~") AND */
						( inaudit.inaudit_item like :as_item ) AND  
						( inaudit.loc_no = :as_loc ) and  
						( inaudit.loc_no = location.loc_no ) and  
						( inaudit.inaudit_item = groupitem.item_no ) and  
						( NOT(groupitem.uom = 'M2' and groupitem.item_no like 'PCY%') )  AND 
						( groupitem.item_no < 'PZZZ' ) and
						( groupitem.item_no NOT IN ('GZZZMISZZZ', 'GCYZZZZZZZ') ) and
						( use_flag <> 'C' ) and 
						( groupitem.item_name like :as_name) ) cineoym 
GROUP BY item_no,   
		qa,   
		item_name,   
		uom,
		loc_name,
		title











" arguments=(("as_loc", string),("as_year", string),("as_mon", string),("as_item", string),("as_name", string))  sort="itemloc_item_no A itemloc_qa A " )
