$PBExportHeader$d_mpsfcrelsort.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=88 color="536870912" )
summary(height=0 color="536870912" )
footer(height=92 color="8421504" )
detail(height=92 color="536870912" )
table(column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" )
 column=(type=char(10) updatewhereclause=yes name=area_no dbname="area_no" )
 column=(type=char(10) updatewhereclause=yes name=wc_no dbname="wc_no" )
 column=(type=char(10) updatewhereclause=yes name=work_nm dbname="work_nm" )
 column=(type=char(1) updatewhereclause=yes name=overtime dbname="overtime" )
 column=(type=decimal(4) updatewhereclause=yes name=calc_qty dbname="calc_qty" )
 column=(type=char(30) updatewhereclause=yes name=rem dbname="rem" )
 retrieve="  SELECT chk        = 'N'
       , area_no    = a.area_no
       , wc_no      = a.wc_no
       , work_nm    = a.work_nm
       , overtime   = isnull(a.overtime,'')
       , calc_qty   = sum(a.calc_qty)
       , rem        = wc.bigo
    FROM (
         SELECT order_no   = mpsorder.order_no
              , area_no    = mpsorder.area_no
              , wc_no      = mpsorder.wc_no
              , work_nm    = wc.work_name
              , calc_qty   = dbo.uf_getqty(mpsdet.item_no, mpsdet.qa, mpsdet.uom, mpsdet.order_qty)
              , seq        = mpsorder.seq
              , overtime   = (case when mpsorder.overtime = 'N' then null else mpsorder.overtime end)
           FROM mpsorder 
                LEFT OUTER JOIN mpsdet ON mpsorder.order_no = mpsdet.mpsorder_order
                LEFT OUTER JOIN wc     ON mpsorder.wc_no    = wc.work_no
          WHERE mpsorder.area_no    LIKE :as_area
            AND mpsorder.order_date    = :adt_workdate
            AND mpsorder.wc_no   between 'F01' and 'F99'
         ) A
         LEFT OUTER JOIN wc     ON a.wc_no = wc.work_no
   GROUP BY a.area_no   
          , a.wc_no     
          , a.work_nm 
          , a.overtime  
          , wc.bigo" arguments=(("as_area", string),("adt_workdate", datetime))  sort="area_no A wc_no A " )
