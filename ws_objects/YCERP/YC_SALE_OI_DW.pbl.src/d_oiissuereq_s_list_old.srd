 column=(type=decimal(2) updatewhereclause=yes name=rlse_qty dbname="rlse_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=ship_qty dbname="ship_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=jan dbname="jan" )
 column=(type=decimal(8) updatewhereclause=yes name=plan_amt dbname="plan_amt" )
 column=(type=decimal(4) updatewhereclause=yes name=qoh dbname="qoh" )
