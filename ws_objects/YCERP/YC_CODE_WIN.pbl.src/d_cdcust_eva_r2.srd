$PBExportHeader$d_cdcust_eva_r2.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=72 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=88 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=yyyy dbname="cust_eva.yyyy" )
 column=(type=char(1) updatewhereclause=yes name=bungi dbname="cust_eva.bungi" values="1분기	A/2분기	B/상반기	C/3분기	D/4분기	E/하반기	F/" )
 column=(type=decimal(1) updatewhereclause=yes name=eva_code01 dbname="eva_code01" )
 column=(type=decimal(1) updatewhereclause=yes name=eva_code02 dbname="eva_code02" )
 column=(type=decimal(1) updatewhereclause=yes name=eva_code03 dbname="eva_code03" )
 column=(type=decimal(1) updatewhereclause=yes name=eva_code04 dbname="eva_code04" )
 column=(type=decimal(1) updatewhereclause=yes name=eva_code05 dbname="eva_code05" )
 column=(type=decimal(1) updatewhereclause=yes name=eva_code06 dbname="eva_code06" )
 column=(type=decimal(1) updatewhereclause=yes name=eva_code07 dbname="eva_code07" )
 column=(type=decimal(1) updatewhereclause=yes name=eva_code08 dbname="eva_code08" )
 column=(type=decimal(1) updatewhereclause=yes name=eva_code09 dbname="eva_code09" )
 column=(type=decimal(1) updatewhereclause=yes name=eva_code10 dbname="eva_code10" )
 column=(type=decimal(1) updatewhereclause=yes name=sum_value dbname="sum_value" )
 retrieve="select yyyy, 
              bungi, 
            sum(case when substring(eva_code,1,2) = '01' then value else 0 end ) eva_code01,
            sum(case when substring(eva_code,1,2) = '02' then value else 0 end ) eva_code02,
            sum(case when substring(eva_code,1,2) = '03' then value else 0 end ) eva_code03,
            sum(case when substring(eva_code,1,2) = '04' then value else 0 end ) eva_code04,
            sum(case when substring(eva_code,1,2) = '05' then value else 0 end ) eva_code05,
            sum(case when substring(eva_code,1,2) = '06' then value else 0 end ) eva_code06,
            sum(case when substring(eva_code,1,2) = '07' then value else 0 end ) eva_code07,
            sum(case when substring(eva_code,1,2) = '08' then value else 0 end ) eva_code08,
            sum(case when substring(eva_code,1,2) = '09' then value else 0 end ) eva_code09,
            sum(case when substring(eva_code,1,2) = '10' then value else 0 end ) eva_code10,
            sum(value) sum_value
 from dbo.cust_eva
where cust_no = :as_cust_no
group by yyyy, bungi" arguments=(("as_cust_no", string))  sort="yyyy A bungi A " )
