 retrieve="PBSELECT( VERSION(400) DISTINCT ()TABLE(NAME=~"saledet~" )  TABLE(NAME=~"sale~" )  TABLE(NAME=~"groupitem~" ) COLUMN(NAME=~"saledet.item_no~") COLUMN(NAME=~"saledet.qa~") COLUMN(NAME=~"groupitem.item_name~")    JOIN (LEFT=~"sale.order_no~"    OP =~"=~"RIGHT=~"saledet.order_no~" )    JOIN (LEFT=~"saledet.item_no~"    OP =~"=~"RIGHT=~"groupitem.item_no~" )WHERE(    EXP1 =~"sale.scene_code~"   OP =~"=~"    EXP2 =~":as_scene~" ) ) ARG(NAME = ~"as_scene~" TYPE = string) " arguments=(("as_scene", string))  sort="groupitem_item_name A saledet_qa A " )
