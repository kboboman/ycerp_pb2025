table(column=(type=char(14) updatewhereclause=yes name=order_no dbname="saledet.order_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="saledet.seq_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="saledet.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="saledet.qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=char(2) updatewhereclause=yes name=com_uom dbname="com_uom" )
 column=(type=decimal(2) updatewhereclause=yes name=order_qty dbname="saledet.order_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=price dbname="saledet.price" )
 column=(type=decimal(2) updatewhereclause=yes name=acc_qty dbname="saledet.acc_qty" )
 column=(type=char(1) updatewhereclause=yes name=saledet_text dbname="saledet.saledet_text" )
 column=(type=char(1) updatewhereclause=yes name=action dbname="saledet.action" )
 column=(type=decimal(2) updatewhereclause=yes name=sol_qty dbname="saledet.sol_qty" )
 column=(type=char(10) updatewhereclause=yes name=loc_no dbname="saledet.loc_no" )
 column=(type=decimal(2) updatewhereclause=yes name=issue_qty dbname="saledet.issue_qty" )
 column=(type=datetime updatewhereclause=yes name=rlse_date dbname="saledet.rlse_date" )
 column=(type=decimal(2) updatewhereclause=yes name=rlse_qty dbname="saledet.rlse_qty" )
 column=(type=char(50) updatewhereclause=yes name=rem dbname="saledet.rem" )
 column=(type=decimal(2) updatewhereclause=yes name=plan_qty dbname="saledet.plan_qty" )
 column=(type=datetime updatewhereclause=yes name=plan_close dbname="saledet.plan_close" )
 column=(type=char(4) updatewhereclause=yes name=color dbname="saledet.color" )
 column=(type=decimal(4) updatewhereclause=yes name=price_be dbname="saledet.price_be" )
 column=(type=char(12) updatewhereclause=yes name=do_rem dbname="saledet.do_rem" )
 column=(type=char(4) updatewhereclause=yes name=sale_cust_no dbname="sale.cust_no" )
 column=(type=char(11) updatewhereclause=yes name=sale_scene_code dbname="sale.scene_code" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="GroupItem.item_name" )
 column=(type=char(10) updatewhereclause=yes name=color_color_name dbname="color.color_name" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 column=(type=decimal(4) updatewhereclause=yes name=qoh dbname="itemloc.qoh" )
 retrieve="  SELECT saledet.order_no,   
         saledet.seq_no,   
         saledet.item_no,   
         saledet.qa,   
         uom = saledet.uom  ,   
         com_uom = (case groupitem.uom when 'M'  then 'EA'
						  					 when 'M2' then 'EA'
											 else groupitem.uom
				   end)  ,   
         saledet.order_qty,   
         saledet.price,   
         saledet.acc_qty,   
         saledet.saledet_text,   
         saledet.action,   
         saledet.sol_qty,   
         saledet.loc_no,   
         saledet.issue_qty,   
         saledet.rlse_date,   
         saledet.rlse_qty,   
         saledet.rem,   
         saledet.plan_qty,   
         saledet.plan_close,   
         saledet.color,   
         saledet.price_be,   
         saledet.do_rem,   
         sale.cust_no,   
         sale.scene_code,   
         groupitem.item_name,   
         color.color_name,   
         customer.cust_name,   
         scene.scene_desc, 
			itemloc.qoh
FROM saledet with(nolock) inner join sale with(nolock) on saledet.order_no = sale.order_no
        		             inner join groupitem with(nolock) on saledet.item_no = groupitem.item_no
        		             left outer join color with(nolock) on saledet.color = color.color_code
        		             left outer join scene with(nolock) on  sale.scene_code = scene.scene_code
                         inner join customer with(nolock) on sale.cust_no = customer.cust_no
                         left outer join itemloc with(nolock) on saledet.item_no = itemloc.item_no and saledet.qa = itemloc.qa 
                                                                          and itemloc.loc_no = :as_loc
 WHERE ( (:as_sel = 'S' and ( saledet.order_no = :as_order ) )    
                   OR (:as_sel = 'c' and ( sale.cust_no = :as_order ) )   )
" arguments=(("as_order", string),("as_sel", string),("as_loc", string))  sort="seq_no A " )
