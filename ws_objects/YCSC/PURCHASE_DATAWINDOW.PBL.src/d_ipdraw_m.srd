$PBExportHeader$d_ipdraw_m.srd
$PBExportComments$도면번호관리(2001/07/24, 이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=supp_no dbname="supp_no" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=draw_no dbname="draw_no" )
 column=(type=decimal(6) update=yes updatewhereclause=yes name=mk dbname="mk" )
 column=(type=char(30) update=yes updatewhereclause=yes name=rem dbname="rem" )
 column=(type=char(30) updatewhereclause=yes name=supp_name dbname="supp_name" )
 column=(type=long updatewhereclause=yes name=cnt dbname="cnt" )
 retrieve="  SELECT suppdraw.supp_no
       , suppdraw.draw_no
       , suppdraw.mk
       , suppdraw.rem
       , supp.supp_name
       , cnt = isnull(c.cnt, 0)
    FROM suppdraw
         LEFT OUTER JOIN supp  ON suppdraw.supp_no = supp.supp_no
         LEFT OUTER JOIN (
              SELECT supp_no, draw_no, cnt = count(item_no)
                FROM suppdrawdet 
               WHERE supp_no   LIKE :as_suppno
               GROUP BY supp_no, draw_no
         )  C ON suppdraw.supp_no = c.supp_no AND suppdraw.draw_no = c.draw_no
   WHERE suppdraw.supp_no      LIKE :as_suppno
" update="suppdraw" updatewhere=0 updatekeyinplace=no arguments=(("as_suppno", string))  sort="supp_no A draw_no A " )
