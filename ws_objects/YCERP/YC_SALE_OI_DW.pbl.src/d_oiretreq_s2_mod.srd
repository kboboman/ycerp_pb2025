footer(height=76 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=order_no dbname="order_no" )
 column=(type=long updatewhereclause=yes name=order_date dbname="order_date" )
 column=(type=datetime updatewhereclause=yes name=due_date dbname="due_date" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="customer.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(11) updatewhereclause=yes name=scene_code dbname="scene.scene_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene.scene_desc" )
 column=(type=char(1) updatewhereclause=yes name=sale_flag dbname="sale_flag" values="내수	D/수출	E/LC	L/" )
 column=(type=char(14) updatewhereclause=yes name=ret_no dbname="ret_no" )
 retrieve="  SELECT order_no   = a.sale_no
       , order_date = null
       , due_date   = ret.preret_date
       , customer.cust_no
       , customer.cust_name
       , scene.scene_code 
       , scene.scene_desc 
       , sale_flag = ''
       , ret_no    = a.ret_no
    FROM (
         SELECT ret_no, sale_no, ret_qty = sum(ret_qty), acc_qty = sum(acc_qty)
           FROM retdet
          WHERE ret_no   IN (
                             SELECT ret.ret_no
                               FROM ret
                              WHERE ( ret.cust_no        LIKE :as_cust_no )
                                AND ( ret.rcpt_area      LIKE :as_area    )
                                AND ( ret.preret_date BETWEEN :ad_sorder_date AND :ad_eorder_date ) 
                            )
          GROUP BY ret_no, sale_no
         ) A
           LEFT OUTER JOIN RET      ON A.RET_NO     = RET.RET_NO
           LEFT OUTER JOIN CUSTOMER ON RET.CUST_NO  = CUSTOMER.CUST_NO
           LEFT OUTER JOIN SCENE    ON RET.CUST_NO  = SCENE.CUST_NO  AND RET.SPOT_CODE = SCENE.SCENE_CODE 
   WHERE a.ret_qty   > a.acc_qty
     AND ret.process_flag   IN ('I','S')
     " arguments=(("as_area", string),("as_cust_no", string),("ad_sorder_date", date),("ad_eorder_date", date)) )
