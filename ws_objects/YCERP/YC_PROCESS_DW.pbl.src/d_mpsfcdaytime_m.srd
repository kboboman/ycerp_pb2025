release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=84 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=area_no dbname="area_no" )
 column=(type=datetime update=yes updatewhereclause=yes key=yes name=sfc_date dbname="sfc_date" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=wc_no dbname="wc_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=gettype dbname="gettype" values="자동	A/수동	M/" )
 column=(type=decimal(1) update=yes updatewhereclause=yes name=all_time dbname="all_time" initial="0" )
 column=(type=decimal(1) update=yes updatewhereclause=yes name=daytime dbname="daytime" initial="0" )
 column=(type=decimal(1) update=yes updatewhereclause=yes name=overtime dbname="overtime" initial="0" )
 column=(type=decimal(1) update=yes updatewhereclause=yes name=time1 dbname="time1" initial="0" )
 column=(type=decimal(1) update=yes updatewhereclause=yes name=time2 dbname="time2" initial="0" )
 column=(type=decimal(1) update=yes updatewhereclause=yes name=time3 dbname="time3" initial="0" )
 column=(type=decimal(1) update=yes updatewhereclause=yes name=time4 dbname="time4" initial="0" )
 column=(type=decimal(1) update=yes updatewhereclause=yes name=time5 dbname="time5" initial="0" )
 column=(type=real update=yes updatewhereclause=yes name=typea dbname="typea" initial="0" )
 column=(type=real update=yes updatewhereclause=yes name=typeb dbname="typeb" initial="0" )
 column=(type=real update=yes updatewhereclause=yes name=typec dbname="typec" initial="0" )
 column=(type=real update=yes updatewhereclause=yes name=typed dbname="typed" initial="0" )
 retrieve="SELECT area_no  = a.area_no
     , sfc_date = convert(datetime, a.sfc_date,111)
     , wc_no    = a.wc_no
     , gettype  = a.gettype
     , all_time = a.all_time
     , daytime  = a.daytime
     , overtime = a.overtime
     , time1    = isnull(a.time1, 0)
     , time2    = isnull(a.time2, 0)
     , time3    = isnull(a.time3, 0)
     , time4    = isnull(a.time4, 0)
     , time5    = isnull(a.time5, 0)
     , typea    = isnull(a.typea, 0)
     , typeb    = isnull(a.typeb, 0)
     , typec    = isnull(a.typec, 0)
     , typed    = isnull(a.typed, 0)
  FROM sfcdaywork  A   
 WHERE a.area_no       = :as_areano                     
   AND convert(char(10), a.sfc_date,111)  = :as_sfcdate
   AND a.wc_no         = :as_wcno                       
" update="sfcdaywork" updatewhere=0 updatekeyinplace=no arguments=(("as_areano", string),("as_sfcdate", string),("as_wcno", string)) )
