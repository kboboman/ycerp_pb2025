$PBExportHeader$d_apglbill_r.srd
$PBExportComments$어음현황 REPORT(1999/05/25, 이인호)
release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=468 color="536870912" )
summary(height=68 color="536870912" )
footer(height=0 color="536870912" )
detail(height=68 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=apbill_close_date dbname="apbill.close_date" )
 column=(type=char(1) updatewhereclause=yes name=apbill_bill_class dbname="apbill.bill_class" values="지급어음	P/받을어음	R/교환어음	C/만기어음	E/부도어음	D/" )
 column=(type=char(30) updatewhereclause=yes name=supp_supp_name dbname="supp.supp_name" )
 column=(type=datetime updatewhereclause=yes name=apbill_start_date dbname="apbill.start_date" )
 column=(type=char(20) updatewhereclause=yes name=apbill_bill_area dbname="apbill.bill_area" )
 column=(type=decimal(0) updatewhereclause=yes name=apbill_bill_amount dbname="apbill.bill_amount" )
 column=(type=char(20) updatewhereclause=yes name=apbill_draft dbname="apbill.draft" )
 column=(type=datetime updatewhereclause=yes name=apbill_set_date dbname="apbill.set_date" )
 column=(type=char(10) updatewhereclause=yes name=c_start dbname="c_start" )
 column=(type=char(10) updatewhereclause=yes name=c_end dbname="c_end" )
 column=(type=char(20) updatewhereclause=yes name=bank_bank_name dbname="bank.bank_name" )
 column=(type=char(12) updatewhereclause=yes name=apbill_bill_no dbname="apbill.bill_no" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"supp~" )  TABLE(NAME=~"apbill~" )  TABLE(NAME=~"bank~" ) COLUMN(NAME=~"apbill.close_date~") COLUMN(NAME=~"apbill.bill_class~") COLUMN(NAME=~"supp.supp_name~") COLUMN(NAME=~"apbill.start_date~") COLUMN(NAME=~"apbill.bill_area~") COLUMN(NAME=~"apbill.bill_amount~") COLUMN(NAME=~"apbill.draft~") COLUMN(NAME=~"apbill.set_date~") COMPUTE(NAME=~"'          ' c_start~") COMPUTE(NAME=~"'          ' c_end~") COLUMN(NAME=~"bank.bank_name~") COLUMN(NAME=~"apbill.bill_no~")    JOIN (LEFT=~"apbill.supp_no~"    OP =~"=~"RIGHT=~"supp.supp_no~" )    JOIN (LEFT=~"apbill.bank_code~"    OP =~"=~"RIGHT=~"bank.bank_code~" )WHERE(    EXP1 =~"( ( apbill.bill_class~"   OP =~"in~"    EXP2 =~"( :asa_class ) )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( apbill.set_flag~"   OP =~"in~"    EXP2 =~"( :asa_flag ) )~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"( apbill.close_date~"   OP =~"between~"    EXP2 =~":ad_start and :ad_end ) )~" ) ) ARG(NAME = ~"asa_class~" TYPE = stringlist)  ARG(NAME = ~"asa_flag~" TYPE = stringlist)  ARG(NAME = ~"ad_start~" TYPE = date)  ARG(NAME = ~"ad_end~" TYPE = date) " arguments=(("asa_class", stringlist),("asa_flag", stringlist),("ad_start", date),("ad_end", date)) )
