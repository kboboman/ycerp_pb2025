$PBExportComments$물품별구매내역(1998/05/13,곽용덕)
release 8;
datawindow(units=0 timer_interval=60000 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=548 color="536870912" )
summary(height=88 color="536870912" )
footer(height=0 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=decimal(2) updatewhereclause=yes name=inspdet_rcpt_qty dbname="inspdet.rcpt_qty" )
 column=(type=char(2) updatewhereclause=yes name=inspdet_uom dbname="inspdet.uom" )
 column=(type=decimal(4) updatewhereclause=yes name=inspdet_price dbname="inspdet.price" )
 column=(type=long updatewhereclause=yes name=inspdet_seq_no dbname="inspdet.seq_no" )
 column=(type=char(10) updatewhereclause=yes name=pur_order_no dbname="pur.order_no" )
 column=(type=char(10) updatewhereclause=yes name=inspdet_loc_no dbname="inspdet.loc_no" )
 column=(type=char(20) updatewhereclause=yes name=inspdet_qa dbname="inspdet.qa" )
 column=(type=long updatewhereclause=yes name=inspdet_cnt dbname="inspdet.cnt" )
 column=(type=decimal(4) updatewhereclause=yes name=inspdet_comqty dbname="inspdet.comqty" )
 column=(type=long updatewhereclause=yes name=inspdet_oi_no dbname="inspdet.oi_no" )
 column=(type=char(14) updatewhereclause=yes name=inspdet_insp_no dbname="inspdet.insp_no" )
 column=(type=datetime updatewhereclause=yes name=insp_insp_date dbname="insp.insp_date" )
 column=(type=char(30) updatewhereclause=yes name=supp_supp_name dbname="supp.supp_name" )
 column=(type=datetime updatewhereclause=yes name=s dbname="s" )
 column=(type=datetime updatewhereclause=yes name=e dbname="e" )
 column=(type=decimal(8) updatewhereclause=yes name=camt dbname="camt" )
 retrieve="  SELECT groupitem.item_name,   
         inspdet.rcpt_qty,   
         inspdet.uom,   
         inspdet.price,   
         inspdet.seq_no,   
         pur.order_no,   
         inspdet.loc_no,   
         inspdet.qa,   
         inspdet.cnt,   
         inspdet.comqty,   
         inspdet.oi_no,   
         inspdet.insp_no,   
         insp.insp_date,   
         supp.supp_name,
		s = convert(smalldatetime, :arg_date1, 111),   
         e = convert(smalldatetime, :arg_date2, 111),
	   camt  = isnull((case when supp.round = 'Y' then ROUND(comqty * inspdet.price, 0, 0) 
											else ROUND(comqty * inspdet.price, 0, 1) 
									 end), 0)

    FROM groupitem,   
         pur,   
         inspdet,   
         insp,   
         supp  
   WHERE ( groupitem.item_no = inspdet.item_no ) and  
         ( pur.order_no = inspdet.pur_no ) and  
         ( insp.insp_no = inspdet.insp_no ) and  
         ( insp.supp_no = supp.supp_no ) and  
         ( ( inspdet.item_no = :arg_item ) AND  
         ( insp.insp_date between :arg_date1 and :arg_date2  )  AND  
         ( ( inspdet.pur_no like left(:as_area,1) + ~"%~" ) or
			  ( left(:as_area,1) = 'S' and inspdet.pur_no like 'PUR%')))      
" arguments=(("arg_item", string),("arg_date1", date),("arg_date2", date),("as_area", string)) )
group(level=1 header.height=0 trailer.height=0 by=("groupitem_item_name" ) newpage=yes header.color="536870912" trailer.color="536870912" )
