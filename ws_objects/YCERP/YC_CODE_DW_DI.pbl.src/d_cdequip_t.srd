release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=88 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=area_area_name dbname="area.area_name" )
 column=(type=char(10) updatewhereclause=yes name=wc_work_name dbname="wc.work_name" )
 column=(type=char(6) updatewhereclause=yes name=equip_equip_code dbname="EQUIP.equip_code" )
 column=(type=char(40) updatewhereclause=yes name=equip_equip_name dbname="EQUIP.equip_name" )
 retrieve="select  b.area_name,
		 c.work_name,
		 a.equip_code, 
     	      a.equip_name
  from equip a left outer join area b on a.factory = b.area_no
               left outer join wc c on a.re_wc = c.work_no               
 where a.factory like :arg_factory
   and isnull(a.re_wc,'%') like :arg_wc
" arguments=(("arg_factory", string),("arg_wc", string))  sort="area_area_name A wc_work_name A equip_equip_code A " )
