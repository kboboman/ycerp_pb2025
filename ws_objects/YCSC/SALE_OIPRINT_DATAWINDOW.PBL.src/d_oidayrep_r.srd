$PBExportHeader$d_oidayrep_r.srd
$PBExportComments$일자별 제품출고 현황출력(1999/6/21,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=576 color="536870912" )
summary(height=92 color="536870912" )
footer(height=0 color="536870912" )
detail(height=144 color="536870912" )
table(column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(11) updatewhereclause=yes name=do_spot_code dbname="do.spot_code" )
 column=(type=datetime updatewhereclause=yes name=do_do_date dbname="do.do_date" )
 column=(type=char(14) updatewhereclause=yes name=do_do_no dbname="do.do_no" )
 column=(type=long updatewhereclause=yes name=dodet_oi_no dbname="dodet.oi_no" )
 column=(type=char(10) updatewhereclause=yes name=dodet_item_no dbname="dodet.item_no" )
 column=(type=char(20) updatewhereclause=yes name=dodet_qa dbname="dodet.qa" )
 column=(type=char(2) updatewhereclause=yes name=dodet_uom dbname="dodet.uom" )
 column=(type=decimal(2) updatewhereclause=yes name=dodet_ship_qty dbname="dodet.ship_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=c_acc_qty dbname="c_acc_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=dodet_price dbname="price" )
 column=(type=decimal(4) updatewhereclause=yes name=dodet_rate_cash dbname="rate_cash" )
 column=(type=char(4) updatewhereclause=yes name=do_cust_no dbname="do.cust_no" )
 column=(type=char(10) updatewhereclause=yes name=do_fob dbname="do.fob" )
 column=(type=char(1) updatewhereclause=yes name=do_ship_flag dbname="do.ship_flag" )
 column=(type=decimal(0) updatewhereclause=yes name=do_ship_amount dbname="ship_amount" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_rate dbname="do_rate" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_total dbname="do_total" )
 column=(type=char(15) updatewhereclause=yes name=bus_tel dbname="customer.bus_tel" )
 column=(type=char(15) updatewhereclause=yes name=tel_no dbname="customer.tel_no" )
 column=(type=char(3) updatewhereclause=yes name=do_curr_code dbname="do.curr_code" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_cash dbname="do_cash" )
 column=(type=char(14) updatewhereclause=yes name=dodet_sale_no dbname="dodet.sale_no" )
 column=(type=long updatewhereclause=yes name=dodet_seq_no dbname="dodet.seq_no" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 column=(type=char(1) updatewhereclause=yes name=round dbname="customer.round" )
 retrieve="  SELECT customer.cust_name,   
         do.spot_code,   
         do.do_date,   
         do.do_no,   
         dodet.oi_no,   
         dodet.item_no,   
         dodet.qa,   
         dodet.uom,   
         dodet.ship_qty,   
			c_acc_qty = round(dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty),2,1),
         price = (case when :as_ret = '%' then dodet.price else 0 end ),   
         rate_cash = (case when :as_ret = '%' then dodet.rate_cash else 0 end ),   
         do.cust_no,   
         do.fob,   
         do.ship_flag,   
         ship_amount = (case when :as_ret = '%' then do.ship_amount else 0 end ),   
         do_rate = (case when :as_ret = '%' then do.do_rate else 0 end ),   
         do_total = (case when :as_ret = '%' then do.do_total else 0 end ),   
         customer.bus_tel,   
         customer.tel_no,   
         do.curr_code,   
         groupitem.item_name,   
         do_cash = (case when :as_ret = '%' then do.do_cash else 0 end ),   
         dodet.sale_no,   
         dodet.seq_no,   
         scene.scene_desc,   
         customer.round  
FROM do with(nolock) inner join dodet with(nolock) on do.do_no = dodet.do_no 
							  inner join groupitem with(nolock)  on dodet.item_no = groupitem.item_no
							  inner join customer with(nolock)  on do.cust_no = customer.cust_no
                                       left outer join scene  with(nolock) on do.cust_no = scene.cust_no and do.spot_code = scene.scene_code
							  inner join sale with(nolock) on dodet.sale_no = sale.order_no
WHERE      ( do.do_date between :ad_start and :ad_end ) 
           AND ( ( (:as_area = 'S0001' or :as_area = 'H0001' ) and sale.area_no <> 'B0001') or ( sale.area_no like :as_area ) ) 
           AND sale.salesman like :as_userid  
" arguments=(("ad_start", date),("ad_end", date),("as_area", string),("as_ret", string),("as_userid", string))  sort="do_do_date A customer_cust_name A do_spot_code A do_do_no A dodet_oi_no A " )
group(level=1 header.height=0 trailer.height=80 by=("do_cust_no" ) header.color="536870912" trailer.color="536870912" )
