$PBExportHeader$d_orsaledaysum_list.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=88 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=org_user dbname="org_user" )
 column=(type=datetime updatewhereclause=yes name=sale_input_date dbname="sale.input_date" )
 column=(type=char(4) updatewhereclause=yes name=sale_cust_no dbname="sale.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(11) updatewhereclause=yes name=sale_scene_code dbname="sale.scene_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 column=(type=char(14) updatewhereclause=yes name=sale_order_no dbname="sale.order_no" )
 column=(type=char(3) updatewhereclause=yes name=seq_no dbname="seq_no" )
 column=(type=char(10) updatewhereclause=yes name=saledet_item_no dbname="saledet.item_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(20) updatewhereclause=yes name=saledet_qa dbname="saledet.qa" )
 column=(type=char(2) updatewhereclause=yes name=saledet_uom dbname="saledet.uom" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_order_qty dbname="saledet.order_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_acc_qty dbname="saledet.acc_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=saledet_price dbname="saledet.price" )
 column=(type=decimal(6) updatewhereclause=yes name=amt dbname="amt" )
 column=(type=char(1) updatewhereclause=yes name=open_close dbname="open_close" )
 retrieve="  SELECT org_user   = (SELECT user_name FROM login WHERE user_id = sale.org_user)
       , sale.input_date      
       , sale.cust_no         
       , customer.cust_name   
       , sale.scene_code      
       , scene.scene_desc     
       , sale.order_no        
       , seq_no     = convert(char(3),saledet.seq_no)
       , saledet.item_no
       , groupitem.item_name      
       , saledet.qa           
       , saledet.uom          
       , saledet.order_qty    
       , saledet.acc_qty      
       , saledet.price
       , amt        = saledet.acc_qty * saledet.price
       , open_close = sale.open_close
    FROM saledet with (nolock) 
         LEFT OUTER JOIN sale        with (nolock) ON saledet.order_no = sale.order_no
         LEFT OUTER JOIN customer    with (nolock) ON sale.cust_no     = customer.cust_no
         LEFT OUTER JOIN scene       with (nolock) ON sale.scene_code  = scene.scene_code
         LEFT OUTER JOIN groupitem   with (nolock) ON saledet.item_no  = groupitem.item_no
   WHERE (sale.input_date BETWEEN :ad_sdate + ' 00:00:00' AND :ad_edate + ' 23:59:59')
     AND ((:as_openclose  = 'Y'  AND sale.open_close LIKE '%') OR
/*          (:as_openclose <> 'Y'  AND sale.open_close  NOT IN ('X','C')) 한도초과 */
             (:as_openclose <> 'Y'  AND sale.open_close = 'O' )
         )           
     AND ((:as_salesman   = '%'  AND sale.org_user LIKE :as_salesman) OR
          (:as_salesman  <> '%'  AND sale.org_user    = :as_salesman)
         )" arguments=(("as_openclose", string),("ad_sdate", date),("ad_edate", date),("as_salesman", string))  sort="sale_input_date A sale_order_no A seq_no A " )
