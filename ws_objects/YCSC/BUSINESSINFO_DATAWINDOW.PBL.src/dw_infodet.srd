 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"bdinfo~" )  TABLE(NAME=~"bdinfodet~" ) COLUMN(NAME=~"bdinfodet.build_no~") COLUMN(NAME=~"bdinfodet.seq~") COLUMN(NAME=~"bdinfodet.status~") COLUMN(NAME=~"bdinfodet.completiondate~") COLUMN(NAME=~"bdinfodet.predate~") COLUMN(NAME=~"bdinfodet.workarea~") COLUMN(NAME=~"bdinfodet.bulidingphone~") COLUMN(NAME=~"bdinfodet.buildingcom~") COLUMN(NAME=~"bdinfodet.floors~") COLUMN(NAME=~"bdinfodet.city~") COLUMN(NAME=~"bdinfodet.dong~") COLUMN(NAME=~"bdinfodet.spec~") COLUMN(NAME=~"bdinfodet.master~") COLUMN(NAME=~"bdinfodet.quantity~") COLUMN(NAME=~"bdinfodet.designoffice~") COLUMN(NAME=~"bdinfodet.square~") COLUMN(NAME=~"bdinfodet.project~") COLUMN(NAME=~"bdinfodet.person~") COLUMN(NAME=~"bdinfodet.std_chk~")    JOIN (LEFT=~"bdinfodet.build_no~"    OP =~"=~"RIGHT=~"bdinfo.build_no~" )WHERE(    EXP1 =~"bdinfo.build_no~"   OP =~"=~"    EXP2 =~":arg_build_no~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"bdinfodet.std_chk~"   OP =~"=~"    EXP2 =~"'1'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"bdinfodet.etmt_chk~"   OP =~"=~"    EXP2 =~"'0'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"bdinfodet.bid_chk~"   OP =~"=~"    EXP2 =~"'0'~" ) ) ARG(NAME = ~"arg_build_no~" TYPE = string) " arguments=(("arg_build_no", string)) )
