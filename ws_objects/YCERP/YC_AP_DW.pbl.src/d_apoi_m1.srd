footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes key=yes name=insp_no dbname="inspdet.insp_no" )
 column=(type=long updatewhereclause=yes key=yes name=oi_no dbname="inspdet.oi_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="inspdet.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="inspdet.qa" )
 column=(type=decimal(2) updatewhereclause=yes name=rcpt_qty dbname="inspdet.rcpt_qty" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="inspdet.uom" )
 column=(type=decimal(4) updatewhereclause=yes name=price dbname="inspdet.price" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=apoi_qty dbname="inspdet.apoi_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=rate_cash dbname="inspdet.rate_cash" )
 column=(type=char(14) updatewhereclause=yes name=pur_no dbname="inspdet.pur_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="inspdet.seq_no" )
 column=(type=char(50) updatewhereclause=yes name=rem dbname="inspdet.rem" )
 column=(type=char(10) updatewhereclause=yes name=loc_no dbname="inspdet.loc_no" )
 column=(type=long updatewhereclause=yes name=cnt dbname="inspdet.cnt" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=comqty dbname="inspdet.comqty" )
 column=(type=char(3) updatewhereclause=yes name=insp_curr_code dbname="insp.curr_code" )
 column=(type=decimal(2) updatewhereclause=yes name=a_qty dbname="a_qty" )
 column=(type=char(1) updatewhereclause=yes name=pick dbname="pick" initial="N" values="	Y/	N" )
 column=(type=decimal(3) updatewhereclause=yes name=a_price dbname="a_price" )
 column=(type=char(1) updatewhereclause=yes name=class dbname="class" initial="B" values="A	A/B	B/C	C/" )
 column=(type=char(1) updatewhereclause=yes name=insp_flag dbname="insp.insp_flag" values="상품	S/원자재	W/부자재	B/외주가공	Y/" )
 column=(type=long updatewhereclause=yes name=amt dbname="amt" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 retrieve="  SELECT inspdet.insp_no                                         
       , inspdet.oi_no                                           
       , inspdet.item_no                                         
       , inspdet.qa                                              
       , inspdet.rcpt_qty                                        
       , inspdet.uom                                             
       , inspdet.price                                           
       , inspdet.apoi_qty                                        
       , inspdet.rate_cash                                       
       , inspdet.pur_no                                          
       , inspdet.seq_no                                          
       , inspdet.rem                                             
       , inspdet.loc_no                                          
       , inspdet.cnt                                             
       , inspdet.comqty                                          
       , insp.curr_code                                          
       , a_qty     = 0000000.00                                  
       , pick      = 'N'                                         
       , a_price   = 0000000.000                                 
       , class     = 'B'                                         
       , insp.insp_flag                                          
       , amt       = 0                                           
       , groupitem.item_name      
    FROM inspdet with(nolock) inner join  groupitem with(nolock) on inspdet.item_no = groupitem.item_no                                                
                                     inner join insp with(nolock) on inspdet.insp_no  = insp.insp_no                                                        
   WHERE  ( ( insp.supp_no          = :as_supp_no               ) AND  
           ( insp.insp_date  BETWEEN :ad_sdate AND :ad_edate   ) AND  
           ( inspdet.apoi_qty     <> inspdet.rcpt_qty          ) AND  
           ( ( insp.area_no     LIKE :as_area + '%'            ) or 
             ( :as_area    = 'S' AND inspdet.pur_no LIKE 'PUR%') or 
             ( :as_area    = 'B' AND insp.area_no   LIKE 'C%'  ) 
           ) 
         ) 
     AND ( insp.insp_flag  = :as_flag )              
/*                               
    FROM inspdet,                                                
         insp,                                                   
         groupitem                                               
   WHERE ( inspdet.item_no *= groupitem.item_no )              
     and ( inspdet.insp_no  = insp.insp_no      )                   
     and ( ( insp.supp_no          = :as_supp_no               ) AND  
           ( insp.insp_date  BETWEEN :ad_sdate AND :ad_edate   ) AND  
           ( inspdet.apoi_qty     <> inspdet.rcpt_qty          ) AND  
           ( ( insp.area_no     LIKE :as_area + '%'            ) or 
             ( :as_area    = 'S' AND inspdet.pur_no LIKE 'PUR%') or 
             ( :as_area    = 'B' AND insp.area_no   LIKE 'C%'  ) 
           ) 
         ) 
     AND ( insp.insp_flag  = :as_flag )                             
*/" update="inspdet" updatewhere=0 updatekeyinplace=yes arguments=(("as_supp_no", string),("ad_sdate", date),("ad_edate", date),("as_area", string),("as_flag", string))  sort="insp_no A oi_no A " )
