release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(17) updatewhereclause=yes name=product_no dbname="product_no" )
 column=(type=char(14) updatewhereclause=yes name=coilorder dbname="coilorder" )
 column=(type=char(14) updatewhereclause=yes name=pur_no dbname="pur_no" )
 column=(type=char(14) updatewhereclause=yes name=insp_no dbname="insp_no" )
 column=(type=long updatewhereclause=yes name=oi_no dbname="oi_no" )
 column=(type=char(20) updatewhereclause=yes name=lot_no dbname="lot_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=char(10) updatewhereclause=yes name=loc_no dbname="loc_no" )
 column=(type=char(30) updatewhereclause=yes name=loc_name dbname="loc_name" )
 column=(type=long updatewhereclause=yes name=cnt dbname="cnt" )
 column=(type=decimal(4) updatewhereclause=yes name=com_qty dbname="com_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=unit_qty dbname="unit_qty" )
 column=(type=char(20) updatewhereclause=yes name=coil_no dbname="coil_no" )
 column=(type=long updatewhereclause=yes name=coilno_seq dbname="coilno_seq" )
 column=(type=char(1) updatewhereclause=yes name=work_type dbname="work_type" )
 column=(type=long updatewhereclause=yes name=cnt1 dbname="cnt1" )
 column=(type=decimal(4) updatewhereclause=yes name=com_qty1 dbname="com_qty1" )
 column=(type=decimal(4) updatewhereclause=yes name=unit_qty1 dbname="unit_qty1" )
 column=(type=char(20) updatewhereclause=yes name=rcpt_loc dbname="rcpt_loc" )
 column=(type=char(30) updatewhereclause=yes name=rcpt_locname dbname="rcpt_locname" )
 retrieve="  SELECT product_no  = b.product_no  
       , coilorder   = e.coilorder_order
       , pur_no      = a.pur_no  
       , insp_no     = a.insp_no    
       , oi_no       = a.oi_no      
       , lot_no      = a.coil_no    
       , item_name   = f.item_name
       , qa          = a.qa            
       , uom         = a.uom        
       , loc_no      = a.loc_no    
       , loc_name    = c.loc_name 
       , cnt         = a.cnt        
       , com_qty     = a.comqty    
       , unit_qty    = a.unit_qty   

       , coil_no     = b.coil_no
       , coilno_seq  = b.serial_no
       , work_type   = b.work_type
       , cnt1        = b.cnt
       , com_qty1    = b.com_qty
       , unit_qty1   = b.unit_qty   
       , rcpt_loc    = b.rcpt_loc
       , rcpt_locname= d.loc_name
    FROM inspdet    a
       , purdet     b
       , location   c  
       , location   d  
       , coilorderdet e
       , groupitem    f
   WHERE a.pur_no      = b.order_no 
     AND a.loc_no      = c.loc_no
     AND b.rcpt_loc    = d.loc_no
     AND a.coil_no     = e.coil_no
     AND a.item_no     = f.item_no
     AND b.product_no  = :as_productno
     AND a.pur_no      = :as_purno
   ORDER BY insp_no, oi_no   
" arguments=(("as_productno", string),("as_purno", string)) )
