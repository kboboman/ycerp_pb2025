table(column=(type=char(11) update=yes updatewhereclause=yes key=yes name=scene_code dbname="scene.scene_code" )
 column=(type=char(40) update=yes updatewhereclause=yes name=scene_desc dbname="scene.scene_desc" )
 column=(type=char(80) updatewhereclause=yes name=scene_addr dbname="scene.scene_addr" )
