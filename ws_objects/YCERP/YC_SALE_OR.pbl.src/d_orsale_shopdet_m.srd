 column=(type=char(4) update=yes updatewhereclause=yes name=color dbname="saleshopdet.color" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=price_be dbname="saleshopdet.price_be" )
 column=(type=char(12) update=yes updatewhereclause=yes name=do_rem dbname="saleshopdet.do_rem" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=stock_qty dbname="saleshopdet.stock_qty" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=stock_issue dbname="saleshopdet.stock_issue" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=stock_do dbname="saleshopdet.stock_do" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=price_last dbname="saleshopdet.price_last" )
 column=(type=decimal(3) update=yes updatewhereclause=yes name=danjung dbname="saleshopdet.danjung" )
 column=(type=decimal(3) update=yes updatewhereclause=yes name=jungrang dbname="saleshopdet.jungrang" )
 retrieve="  SELECT saleshopdet.order_no   
       , saleshopdet.seq_no   
       , saleshopdet.item_no   
       , saleshopdet.qa   
       , saleshopdet.uom   
       , saleshopdet.order_qty   
       , saleshopdet.price   
       , saleshopdet.acc_qty   
       , saleshopdet.saledet_text   
       , saleshopdet.action   
       , saleshopdet.sol_qty   
       , saleshopdet.loc_no   
       , saleshopdet.issue_qty   
       , saleshopdet.rlse_date   
       , saleshopdet.rlse_qty   
       , saleshopdet.rem   
       , saleshopdet.plan_qty   
       , saleshopdet.plan_close   
       , saleshopdet.color   
       , saleshopdet.price_be   
       , saleshopdet.do_rem   
       , saleshopdet.stock_qty   
       , saleshopdet.stock_issue   
       , saleshopdet.stock_do   
       , saleshopdet.price_last   
       , saleshopdet.danjung   
       , saleshopdet.jungrang  
    FROM saleshopdet
         LEFT OUTER JOIN saleshop ON saleshopdet.order_no = saleshop.order_no
   WHERE ((:as_orderno   = '%' AND saleshopdet.order_no LIKE '%'        ) OR
          (:as_orderno  <> '%' AND saleshopdet.order_no    = :as_orderno)
         )
     AND ( saleshop.order_date between :as_sdate AND :as_edate )
" update="saleshopdet" updatewhere=1 updatekeyinplace=no arguments=(("as_orderno", string),("as_sdate", string),("as_edate", string)) )
