table(column=(type=long updatewhereclause=yes name=seq dbname="seq" )
 column=(type=char(20) updatewhereclause=yes name=area dbname="area" )
 column=(type=char(20) updatewhereclause=yes name=sector dbname="sector" )
 column=(type=char(20) updatewhereclause=yes name=team dbname="team" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="user_id" )
 column=(type=char(20) updatewhereclause=yes name=login_user_name dbname="user_name" )
 column=(type=char(10) updatewhereclause=yes name=login_rank dbname="rank" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=decimal(9) updatewhereclause=yes name=top01 dbname="top01" )
 column=(type=decimal(9) updatewhereclause=yes name=top02 dbname="top02" )
 column=(type=decimal(9) updatewhereclause=yes name=top03 dbname="top03" )
 column=(type=decimal(9) updatewhereclause=yes name=top04 dbname="top04" )
 column=(type=decimal(9) updatewhereclause=yes name=top05 dbname="top05" )
 column=(type=decimal(9) updatewhereclause=yes name=top06 dbname="top06" )
 column=(type=decimal(9) updatewhereclause=yes name=top07 dbname="top07" )
 column=(type=decimal(9) updatewhereclause=yes name=top08 dbname="top08" )
 column=(type=decimal(9) updatewhereclause=yes name=top09 dbname="top09" )
 column=(type=decimal(9) updatewhereclause=yes name=top10 dbname="top10" )
 column=(type=decimal(9) updatewhereclause=yes name=top11 dbname="top11" )
 column=(type=decimal(9) updatewhereclause=yes name=top12 dbname="top12" )
 column=(type=decimal(9) updatewhereclause=yes name=top13 dbname="top13" )
 column=(type=decimal(9) updatewhereclause=yes name=top17 dbname="top17" )
 column=(type=decimal(9) updatewhereclause=yes name=top18 dbname="top18" )
 column=(type=decimal(9) updatewhereclause=yes name=topsum dbname="topsum" )
 column=(type=decimal(6) updatewhereclause=yes name=do_total dbname="do_total" )
 column=(type=char(100) updatewhereclause=yes name=title dbname="title" )
 retrieve="select
	  aa.seq   		seq                     /* 순서       */  
	, aa.area      area                    /* 권역       */
	, aa.sector    sector                  /* 본부       */
	, aa.team      team                    /* 팀         */
	, aa.user_id   user_id                 /* 담당자     */
	, aa.user_name user_name               /* 담당자명   */
	, aa.rank      rank                    /* 직책       */          
	, aa.cust_no	cust_no	
	, aa.cust_name cust_name
	, aa.top01 		top01
	, aa.top02 		top02
	, aa.top03 		top03
	, aa.top04 		top04
	, aa.top05 		top05
	, aa.top06 		top06
	, aa.top07 		top07
	, aa.top08 		top08
	, aa.top09 		top09
	, aa.top10 		top10
	, aa.top11 		top11
	, aa.top12 		top12
	, aa.top13 		top13
	, aa.top17 		top17
	, aa.top18 		top18
	, aa.topsum 	topsum
	, aa.do_total	do_total
	, substring(:as_sdate,1,4) + '년' +  substring(:as_sdate,6,2) + '월' + substring(:as_sdate,9,2) + '일' + ' - ' + substring(:as_edate,1,4) + '년' +  substring(:as_edate,6,2) + '월' + substring(:as_edate,9,2) + '일' + ' 전략제품 매출실적(거래처)' as title
from
	(
	select   
		  seq   			= 	o.seq                     /* 순서       */  
		, area        	= 	o.area                    /* 권역       */
		, sector      	= 	o.sector                  /* 본부       */
		, team        	= 	o.team                    /* 팀         */
		, user_id     	= 	o.user_id                 /* 담당자     */
		, user_name   	= 	o.user_name               /* 담당자명   */
		, rank        	= 	o.rank                    /* 직책       */          
		, cust_no	  	= 	d.cust_no	
		, cust_name   	= 	d.cust_name
		, sum(c.top01) 	top01
		, sum(c.top02) 	top02
		, sum(c.top03) 	top03
		, sum(c.top04) 	top04
		, sum(c.top05) 	top05
		, sum(c.top06) 	top06
		, sum(c.top07) 	top07
		, sum(c.top08) 	top08
		, sum(c.top09) 	top09
		, sum(c.top10) 	top10
		, sum(c.top11) 	top11
		, sum(c.top12) 	top12
		, sum(c.top13) 	top13
		, sum(c.top17) 	top17
		, sum(c.top18) 	top18
		, sum(c.topsum) 	topsum
		, sum(b.do_total) do_total
	from 
		customer d with(nolock)	left outer join (                               
																SELECT 
																	b.cust_no, sum(b.do_total) / 1.1/1000 do_total
																FROM 
																	do B with(nolock)
																WHERE 
																	convert(char(8),(case when 'ISSUE' = :as_flag then ( case when b.do_date > b.issue_date then b.issue_date else b.do_date end  ) else b.do_date end),112) between substring(:as_sdate,1,4)+substring(:as_sdate,6,2)+substring(:as_sdate,9,2) and  substring(:as_edate,1,4)+substring(:as_edate,6,2)+substring(:as_edate,9,2)
																group by 
																	b.cust_no
																) b on d.cust_no = b.cust_no
										left outer join (
																SELECT 
																	b.cust_no
																	, TOP01 = sum( case when g.category = 'TOP1001' then (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) else 0 end )/1000
																	, TOP02 = sum( case when g.category = 'TOP1002' then (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) else 0 end )/1000
																	, TOP03 = sum( case when g.category = 'TOP1003' then (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) else 0 end )/1000
																	, TOP04 = sum( case when g.category = 'TOP1004' then (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) else 0 end )/1000
																	, TOP05 = sum( case when g.category = 'TOP1019' then (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) else 0 end )/1000
																	, TOP06 = sum( case when g.category = 'TOP1005' then (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) else 0 end )/1000            
																	, TOP07 = sum( case when g.category = 'TOP1006' then (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) else 0 end )/1000
																	, TOP08 = sum( case when g.category = 'TOP1007' then (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) else 0 end )/1000
																	, TOP09 = sum( case when g.category = 'TOP1008' then (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) else 0 end )/1000
																	, TOP10 = sum( case when g.category = 'TOP1009' then (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) else 0 end )/1000
																	, TOP11 = sum( case when g.category = 'TOP1010' then (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) else 0 end )/1000
																	, TOP12 = sum( case when g.category = 'TOP1011' then (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) else 0 end )/1000
																	, TOP13 = sum( case when g.category = 'TOP1012' then (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) else 0 end )/1000
																	, TOP17 = sum( case when g.category = 'TOP1017' then (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) else 0 end )/1000
																	, TOP18 = sum( case when g.category = 'TOP1018' then (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) else 0 end )/1000
																	, TOPSUM = sum( (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) )/1000
																FROM 
																	dodet A with(nolock) inner join do B with(nolock) ON a.do_no = b.do_no
																								inner  join itemtop10 g with(nolock) on a.item_no   = g.item_no  and g.category in (select item_cd  from codemst where type = 'ITEMTOP10' and prt_yn = 'Y')
																WHERE 
																	convert(char(8),(case when 'ISSUE' = :as_flag then ( case when b.do_date > b.issue_date then b.issue_date else b.do_date end  ) else b.do_date end),112) between substring(:as_sdate,1,4)+substring(:as_sdate,6,2)+substring(:as_sdate,9,2) and  substring(:as_edate,1,4)+substring(:as_edate,6,2)+substring(:as_edate,9,2)
																group by 
																	b.cust_no) c on d.cust_no = c.cust_no
										LEFT OUTER JOIN codemst   M  with(nolock) ON d.cust_no  = m.item_cd  AND m.type = '내부업체' AND m.use_yn ='Y'                          
										left outer join (
																SELECT 
																	DISTINCT  seq	= a.seq          /* 순서       */
																	, area         = a.area         /* 권역       */
																	, sector       = a.sector       /* 본부       */
																	, team         = a.team         /* 팀         */
																	, user_id      = a.user_id      /* 담당자     */
																	, user_name   	= a.user_name    /* 담당자명   */
																	, rank         = a.rank         /* 직책       */
																FROM 
																	(
																	SELECT 
																		seq         = a.seq          /* 순서       */
																		, area        = a.area         /* 권역       */
																		, sector      = a.sector       /* 본부       */
																		, team        = a.team         /* 팀         */
																		, user_id     = a.user_id      /* 담당자     */
																		, user_name   = a.user_name    /* 담당자명   */
																		, rank        = a.rank         /* 직책       */                                                         
																	FROM 
																		UF_MyMembers( '%' ) M LEFT OUTER JOIN opeom_org A with(nolock) ON m.user_id = a.user_id                                                         
																	UNION ALL
																	/* 내부업체(insite) */
																	SELECT 
																		seq         = a.seq          /* 순서       */
																		, area        = a.area         /* 권역       */
																		, sector      = a.sector       /* 본부       */
																		, team        = a.team         /* 팀         */
																		, user_id     = a.user_id      /* 담당자     */
																		, user_name   = a.user_name    /* 담당자명   */
																		, rank        = a.rank         /* 직책       */
																	FROM 
																		opeom_org A  with(nolock)
																	WHERE (a.user_id     = 'insite')
																	) A
																) O  ON o.user_id = (case when m.item_cd IS NOT NULL then 'insite' else d.salesman end)
	WHERE 
		d.cust_flag   = 'N'
	AND  
		d.cust_type <> 'E'
	AND 
		o.seq  IS NOT NULL
	AND
		c.topsum > 0
	AND
		d.salesman	LIKE :as_user_id
	AND
		d.cust_no	LIKE :as_cust_no
	group by 
		o.seq
		, o.area
		, o.sector
		, o.team
		, o.user_id 
		, o.user_name
		, o.rank
		, d.cust_no
		, d.cust_name) aa" arguments=(("as_sdate", string),("as_edate", string),("as_flag", string),("as_user_id", string),("as_cust_no", string))  sort="seq A user_id A " )
group(level=1 header.height=0 trailer.height=100 by=("area" ) header.color="536870912" trailer.color="536870912" )
