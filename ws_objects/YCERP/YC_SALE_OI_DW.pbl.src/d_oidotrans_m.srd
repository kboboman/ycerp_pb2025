 column=(type=char(20) updatewhereclause=yes name=rank4 dbname="rank4" )
 column=(type=char(4) updatewhereclause=yes name=rank5 dbname="rank5" )
 column=(type=char(4) updatewhereclause=yes name=rankh dbname="rankh" )
 column=(type=char(5) updatewhereclause=yes name=rankh1 dbname="rankh1" )
 column=(type=char(5) updatewhereclause=yes name=rankh2 dbname="rankh2" )
 column=(type=char(1) updatewhereclause=yes name=cc_flag dbname="cc_flag" )
 retrieve="SELECT 
	  a.trans_no
	, a.tr_type
	, a.tr_date
	, a.team_code
	, t.team_name
	, a.user_id
	, l.user_name
	, a.tr_balteam
	, a.tr_hyupteam
	, a.tr_transamt
	
	, a.tr_ewolfix
	, a.apply_end
	, a.tr_app1
	, a.tr_appdt1
	, a.tr_app2
	, a.tr_appdt2
	, a.tr_app3
	, a.tr_appdt3
	, a.tr_app4
	, a.tr_appdt4
	, a.tr_app5
	, a.tr_appdt5
	, a.tr_return
	, a.tr_apph
	, a.tr_apph1
	, a.tr_apph2
	, a.tr_appdth
	, a.tr_appdth1
	, a.tr_appdth2
	
	, a.fcust_no
	, a.fspot_code
	, a.fsalesman
	, a.fregister_no
	, a.fcredit_level
	, a.flevel_grade
	, a.fprice_level
	, a.fcaptain_name
	, a.funpaid_amt
	, fcollect_day = cast(a.fcollect_day as varchar(25))
	
	, a.tcust_no
	, a.tspot_code
	, a.tsalesman
	, a.tregister_no
	, a.tcredit_level
	, a.tlevel_grade
	, a.tprice_level
	, a.tcaptain_name
	, a.tunpaid_amt
	, tcollect_day = cast(a.tcollect_day as varchar(25))
	
	, a.tr_content
	
	, user1   = substring(rtrim(l1.user_name),1,2) + char(13) + substring(rtrim(l1.user_name),3,2) + (case when l1.user_name is null or l1.user_name = '' then '' else '인' end)
	, user2   = substring(rtrim(l2.user_name),1,2) + char(13) + substring(rtrim(l2.user_name),3,2) + (case when l2.user_name is null or l2.user_name = '' then '' else '인' end)
	, user3   = substring(rtrim(l3.user_name),1,2) + char(13) + substring(rtrim(l3.user_name),3,2) + (case when l3.user_name is null or l3.user_name = '' then '' else '인' end)
	, user4   = substring(rtrim(l4.user_name),1,2) + char(13) + substring(rtrim(l4.user_name),3,2) + (case when l4.user_name is null or l4.user_name = '' then '' else '인' end)
	, user5   = substring(rtrim(l5.user_name),1,2) + char(13) + substring(rtrim(l5.user_name),3,2) + (case when l5.user_name is null or l5.user_name = '' then '' else '인' end)
	, userh   = substring(rtrim(l6.user_name),1,2) + char(13) + substring(rtrim(l6.user_name),3,2) + (case when l6.user_name is null or l6.user_name = '' then '' else ''   end)
	, userh1	 = substring(rtrim(l7.user_name),1,2) + char(13) + substring(rtrim(l7.user_name),3,2) + (case when l7.user_name is null or l7.user_name = '' then '' else ''   end)
	, userh2	 = substring(rtrim(l8.user_name),1,2) + char(13) + substring(rtrim(l8.user_name),3,2) + (case when l8.user_name is null or l8.user_name = '' then '' else ''   end)
	
	, rank1   = l1.rank
	, rank2   = l2.rank
	, rank3   = l3.rank
	, rank4   = l4.rank
	, rank5   = '승인' /* l5.rank */
	, rankh   = '협조' /* l5.rank */
	, rankh1   = '협조1' /* l5.rank */
	, rankh2   = '협조2' /* l5.rank */
	, cc_flag = (case when a.trans_no is null OR a.trans_no = '' then '0' 
						 else '1' 
					end)
FROM 
	dotrans a with(nolock)
		LEFT OUTER JOIN dotransdet b  with(nolock) ON a.trans_no = b.trans_no
		LEFT OUTER JOIN login      l  with(nolock) ON a.user_id  = l.user_id
		LEFT OUTER JOIN team       t	with(nolock) ON a.team_code= t.team_code
		LEFT OUTER JOIN login      l1 with(nolock) ON a.tr_app1  = l1.user_id
		LEFT OUTER JOIN login      l2 with(nolock) ON a.tr_app2  = l2.user_id
		LEFT OUTER JOIN login      l3 with(nolock) ON a.tr_app3  = l3.user_id
		LEFT OUTER JOIN login      l4 with(nolock) ON a.tr_app4  = l4.user_id
		LEFT OUTER JOIN login      l5 with(nolock) ON a.tr_app5  = l5.user_id
		LEFT OUTER JOIN login      l6 with(nolock) ON a.tr_apph  = l6.user_id
		LEFT OUTER JOIN login      l7 with(nolock) ON a.tr_apph1  = l7.user_id
		LEFT OUTER JOIN login      l8 with(nolock) ON a.tr_apph2  = l8.user_id
WHERE 
	a.trans_no = :as_transno
" update="dotrans" updatewhere=0 updatekeyinplace=no arguments=(("as_transno", string)) )
