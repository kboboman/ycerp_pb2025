$PBExportHeader$d_cdlocation_c6.srd
$PBExportComments$저장소 DropDownDataWindow(1998/02/06 - 김구현)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=loc_no dbname="LOC_NO" )
 column=(type=char(30) updatewhereclause=yes name=loc_name dbname="LOC_NAME" )
 column=(type=char(30) updatewhereclause=yes name=position dbname="location.POSITION" )
 column=(type=char(15) updatewhereclause=yes name=tel_no dbname="location.TEL_NO" )
 column=(type=char(10) updatewhereclause=yes name=loc_manager dbname="location.LOC_MANAGER" )
 column=(type=char(1) updatewhereclause=yes name=loc_type dbname="LOC_TYPE" )
 column=(type=char(10) updatewhereclause=yes name=area_no dbname="location.AREA_NO" )
 column=(type=char(30) updatewhereclause=yes name=rem dbname="location.REM" )
 column=(type=char(1) updatewhereclause=yes name=use_yn dbname="location.USE_YN" )
 column=(type=char(30) updatewhereclause=yes name=loc_sort dbname="LOC_SORT" )
 retrieve="  SELECT  '%' LOC_NO,
                      '전체' LOC_NAME,
                      NULL POSITION,
                      NULL TEL_NO,
                      NULL LOC_MANAGER,
                      'N' LOC_TYPE,
                      NULL AREA_NO,
                      NULL REM,
                      NULL USE_YN,
				 'A00'  LOC_SORT
  union all
  SELECT location.loc_no,   
         location.loc_name,   
         location.position,   
         location.tel_no,   
         location.loc_manager,   
         location.loc_type,   
         area_no = isnull(location.area_no,''),
         location.rem,   
         location.use_yn,
	    ( case when  location.loc_type <> 'Y' then location.loc_no else  location.loc_name end ) loc_sort  
    FROM location"  sort="loc_type A if (   loc_type <> 'Y', loc_no,  loc_name ) A " )
