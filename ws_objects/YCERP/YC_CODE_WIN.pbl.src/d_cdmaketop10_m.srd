table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=work_no dbname="maketop10.work_no" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=cat1 dbname="maketop10.cat1" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=cat2 dbname="maketop10.cat2" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="maketop10.item_no" )
 column=(type=char(60) update=yes updatewhereclause=yes name=item_name dbname="maketop10.item_name" )
 column=(type=datetime update=yes updatewhereclause=yes name=sys_date dbname="maketop10.sys_date" )
 column=(type=char(1) update=yes updatewhereclause=yes name=use_yn dbname="maketop10.use_yn" values="	Y/	N" )
 retrieve="  SELECT maketop10.work_no
       , maketop10.cat1
       , maketop10.cat2
       , maketop10.item_no
       , maketop10.item_name
       , maketop10.sys_date
       , maketop10.use_yn
    FROM maketop10 
   WHERE ((:as_wcno  = 'A00' AND maketop10.work_no LIKE '%') OR
          (:as_wcno <> 'A00' AND maketop10.work_no    = :as_wcno)
         ) 

" update="maketop10" updatewhere=0 updatekeyinplace=no arguments=(("as_wcno", string))  sort="work_no A cat1 A cat2 A item_name A " )
