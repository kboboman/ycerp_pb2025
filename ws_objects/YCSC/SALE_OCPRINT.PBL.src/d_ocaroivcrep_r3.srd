compute(band=detail alignment="1" expression="if( aroivc_rcpt_type = 'B', 0,  if( aroivc_vc_type = 'R',aroivc_amount, 0 -  aroivc_amount ) )"border="0" color="0" x="2359" y="4" height="60" width="448" format="#,##0"  name=c_cash visible="1~tif( aroivc_rcpt_type = 'B', 0, 1)"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
