table(column=(type=long updatewhereclause=yes name=apoi_seq_no dbname="apoi.seq_no" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=rcpt_qty dbname="inspdet.rcpt_qty" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=apoi_qty dbname="inspdet.apoi_qty" )
 column=(type=char(14) update=yes updatewhereclause=yes key=yes name=insp_no dbname="inspdet.insp_no" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=oi_no dbname="inspdet.oi_no" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"apoi~" )  TABLE(NAME=~"inspdet~" ) COLUMN(NAME=~"apoi.seq_no~") COLUMN(NAME=~"inspdet.rcpt_qty~") COLUMN(NAME=~"inspdet.apoi_qty~") COLUMN(NAME=~"inspdet.insp_no~") COLUMN(NAME=~"inspdet.oi_no~")    JOIN (LEFT=~"apoi.oi_no~"    OP =~"=~"RIGHT=~"inspdet.oi_no~" )    JOIN (LEFT=~"apoi.insp_no~"    OP =~"=~"RIGHT=~"inspdet.insp_no~" )WHERE(    EXP1 =~"( ( apoi.apoiinv_no~"   OP =~"=~"    EXP2 =~":as_apoiinv_no ) )~" ) ) ARG(NAME = ~"as_apoiinv_no~" TYPE = string) " update="inspdet" updatewhere=0 updatekeyinplace=yes arguments=(("as_apoiinv_no", string))  sort="apoi_seq_no A " )
