 retrieve="PBSELECT( VERSION(400) DISTINCT ()TABLE(NAME=~"saledet~" )  TABLE(NAME=~"groupitem~" ) COLUMN(NAME=~"saledet.order_no~") COLUMN(NAME=~"saledet.seq_no~") COLUMN(NAME=~"saledet.item_no~") COLUMN(NAME=~"saledet.qa~") COLUMN(NAME=~"saledet.uom~") COLUMN(NAME=~"saledet.order_qty~") COLUMN(NAME=~"saledet.price~") COLUMN(NAME=~"saledet.acc_qty~") COLUMN(NAME=~"saledet.saledet_text~") COLUMN(NAME=~"saledet.action~") COLUMN(NAME=~"saledet.sol_qty~") COLUMN(NAME=~"saledet.loc_no~") COLUMN(NAME=~"saledet.issue_qty~") COLUMN(NAME=~"saledet.rlse_date~") COLUMN(NAME=~"saledet.rlse_qty~") COLUMN(NAME=~"saledet.rem~") COLUMN(NAME=~"saledet.plan_qty~") COLUMN(NAME=~"saledet.plan_close~") COLUMN(NAME=~"saledet.color~") COLUMN(NAME=~"saledet.price_be~") COLUMN(NAME=~"groupitem.item_name~") COLUMN(NAME=~"saledet.do_rem~") COLUMN(NAME=~"saledet.stock_qty~") COLUMN(NAME=~"saledet.stock_issue~") COMPUTE(NAME=~"sel = case when saledet.issue_qty > 0 then 'Y' else 'N' end~") COLUMN(NAME=~"saledet.stock_do~")    JOIN (LEFT=~"saledet.item_no~"    OP =~"=~"RIGHT=~"groupitem.item_no~"    OUTER1 =~"saledet.item_no~" )WHERE(    EXP1 =~"saledet.order_no~"   OP =~"=~"    EXP2 =~":aa~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"saledet.order_qty~"   OP =~">~"    EXP2 =~"saledet.rlse_qty~" ) ) ARG(NAME = ~"aa~" TYPE = string) " update="saledet" updatewhere=0 updatekeyinplace=yes arguments=(("aa", string))  sort="saledet_order_no A saledet_seq_no A " )
