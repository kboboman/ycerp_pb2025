			ls_col = "wc1 "
		case "1작업명"
			ls_col = "wcnm1 "			
		case "1제품"
			ls_col = "assy1 "
		case "1제품명"
			ls_col = "assynm1 "
		case "2공정"
			ls_col = "op2 "
		case "2작업"
			ls_col = "wc2 "
		case "2작업명"
			ls_col = "wcnm2 "			
		case "2제품"
			ls_col = "assy2 "
		case "2제품명"
			ls_col = "assynm2 "
		case "3공정"
			ls_col = "op3 "
		case "3작업"
			ls_col = "wc3 "
		case "3작업명"
			ls_col = "wcnm3 "			
		case "3제품"
			ls_col = "assy3 "
		case "3제품명"
			ls_col = "assynm3 "
	end choose		

	if trim(ddlb_5.text) = "LIKE" then
		ls_column = ls_col + trim(ddlb_5.text) + " '%" + trim(sle_3.text) + "%' "
	else
		choose case ls_col
			case "work_date ", "napgi_date "
				ls_column = ls_col + trim(ddlb_5.text) + "datetime('" + trim(sle_3.text) + "') "
			case "chk ", "op1 ", "op2 ", "op3 "
				ls_column = ls_col + trim(ddlb_5.text) + " "  + trim(sle_3.text) + " "
			case else
				ls_column = ls_col + trim(ddlb_5.text) + " '" + trim(sle_3.text) + "' "
		end choose 
	end if
end if

if ls_column = "" then
	ls_temp = ls_column
else
	ls_temp = "(" + ls_column + ")"
end if

if ls_value <> "" then
	if ls_temp = "" then
		ls_temp = ls_value
	else
		ls_temp = "(" + ls_temp + ") AND (" + trim(ls_value) + ")"
	end if
end if

dw7.setfilter(ls_temp)
dw7.filter()

dw7.scrolltorow(1)


end event

