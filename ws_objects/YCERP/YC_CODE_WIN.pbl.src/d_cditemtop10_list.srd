$PBExportHeader$d_cditemtop10_list.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=84 color="536870912" )
summary(height=0 color="536870912" )
footer(height=88 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" values="	Y/	N" )
 column=(type=char(20) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(50) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=long updatewhereclause=yes name=sort dbname="sort" )
 column=(type=long updatewhereclause=yes name=cnt dbname="cnt" )
 retrieve="  SELECT chk       = 'N'
       , item_no   = codemst.item_cd
       , item_name = codemst.item_nm
       , sort      = codemst.sort
       , cnt       = (SELECT count(*) FROM itemtop10 WHERE category = codemst.item_cd)
    FROM codemst
   WHERE codemst.type   = 'ITEMTOP10' 
     AND codemst.use_yn = 'Y'"  sort="sort A " )
