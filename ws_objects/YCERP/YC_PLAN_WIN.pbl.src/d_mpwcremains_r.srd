compute(band=footer alignment="2" expression="count( item_name for all DISTINCT item_name )"border="0" color="33554432" x="1467" y="4" height="72" width="1381" format="[GENERAL]" html.valueishtml="0"  name=compute_6 visible="1"  font.face="굴림체" font.height="-11" font.weight="700"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="553648127" )

sparse(names="work_name	calc_sum")htmltable(border="1" )
