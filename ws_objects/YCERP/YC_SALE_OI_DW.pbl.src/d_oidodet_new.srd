 column=(type=char(20) update=yes updatewhereclause=yes name=qa_cust dbname="dodet.qa_cust" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=ship_qty dbname="dodet.ship_qty" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=price dbname="dodet.price" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=aroi_qty dbname="dodet.aroi_qty" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="dodet.uom" )
 column=(type=char(14) update=yes updatewhereclause=yes name=sale_no dbname="dodet.sale_no" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=rate_cash dbname="dodet.rate_cash" )
 column=(type=char(50) update=yes updatewhereclause=yes name=rem dbname="dodet.rem" )
 column=(type=decimal(1) updatewhereclause=yes name=c_acc_aty dbname="c_acc_aty" )
 column=(type=char(12) update=yes updatewhereclause=yes name=do_rem dbname="dodet.do_rem" )
 column=(type=char(20) update=yes updatewhereclause=yes name=coil_no dbname="dodet.coil_no" )
 column=(type=long update=yes updatewhereclause=yes name=cnt dbname="dodet.cnt" )
 column=(type=char(10) update=yes updatewhereclause=yes name=loc_no dbname="dodet.loc_no" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=stock_qty dbname="dodet.stock_qty" )
 column=(type=datetime update=yes updatewhereclause=yes name=req_date dbname="dodet.req_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=salesman dbname="dodet.salesman" )
 column=(type=long update=yes updatewhereclause=yes name=req_seq dbname="dodet.req_seq" )
 column=(type=long update=yes updatewhereclause=yes name=seq dbname="dodet.seq" )
 retrieve="  SELECT dodet.do_no       
       , dodet.oi_no       
       , dodet.seq_no      
       , dodet.item_no     
       , dodet.qa          
       , dodet.qa_cust     
       , dodet.ship_qty    
       , dodet.price       
       , dodet.aroi_qty    
       , dodet.uom         
       , dodet.sale_no     
       , dodet.rate_cash   
       , dodet.rem         
       , c_acc_aty   = 0.0      
       , dodet.do_rem      
       , dodet.coil_no     
       , dodet.cnt         
       , dodet.loc_no      
       , dodet.stock_qty
       , dodet.req_date
       , dodet.salesman
       , dodet.req_seq
       , dodet.seq
    FROM dodet   
" update="dodet" updatewhere=1 updatekeyinplace=no )
