boolean livescroll = true
borderstyle borderstyle = stylelowered!
end type

event keydown;//
long   ll_row, i
string ls_wc,  ls_wc1, ls_flag

if keyflags = 1 then
   if keydown(KeyLeftButton!) then
		ll_row = il_row
      if ll_row < 1 then return

      this.accepttext()
		for i = ll_row to 1 step -1
			 if i <> ll_row then
				 if this.IsSelected(i) = true then exit
			 end if
          this.SelectRow(i, NOT this.IsSelected(i))
		next
	end if
end if
end event

event itemchanged;string ls_item, ls_qa, ls_uom, ls_itemname, ls_loc, ls_supp, ls_wc
string ls_type, ls_coil, ls_null
int li_ret
real lr_cost, lr_modqty, lr_locqty

dw_2.accepttext()
this.accepttext()
ls_item = trim(this.object.item_no[row])
if isnull(ls_item) then return 0

ls_loc = trim(dw_2.object.loc_no[1])
setnull(ls_null)
choose case dwo.name
	case 'item_no', 'qa'
		ls_qa = trim(this.object.qa[row])
		select item_name, uom into :ls_item, :ls_uom from item
		where item_no = :ls_item
		 and qa = :ls_qa;
		if sqlca.sqlcode = 100 then 
			return 1
		end if
		this.object.rem_qa[row] = ls_null
		if MidA(ls_item, 4, 1) = "1" then
			wf_coildddw(dw5, ls_item, ls_qa, ls_loc )
		elseif MidA(ls_item, 4, 1) = "2" then
			wf_sheetdddw(dw5, ls_item, ls_qa, ls_loc)
		else
			wf_cleardddw(dw5)
		end if

		this.object.item_item_name[row] = ls_item
		ls_item = trim(this.object.item_no[row])
		this.object.uom[row] = trim(ls_uom)

	case 'coil_no'
		this.getchild('coil_no',idwc_coil)
		if idwc_coil.rowcount() > 0 then
			this.object.loc_no[row] = trim(idwc_coil.getitemstring(idwc_coil.getrow(),'loc_no'))
			this.object.sfcuse_cnt[row] = 0
			this.object.qa[row] = trim(idwc_coil.getitemstring(idwc_coil.getrow(),'qa'))
			this.object.qcnt[row] = idwc_coil.getitemnumber(idwc_coil.getrow(),'qcnt')
			if MidA(ls_item, 4, 1) = "1" then //coil
				this.object.sfcuse_mod_len[row] = idwc_coil.getitemnumber(idwc_coil.getrow(),'length')
				this.object.sfcuse_wid[row] = idwc_coil.getitemnumber(idwc_coil.getrow(),'wid')
				this.object.sfcuse_unit_qty[row] = idwc_coil.getitemnumber(idwc_coil.getrow(),'unit_qty')
				this.object.sfcuse_mod_qty[row] = this.object.sfcuse_unit_qty[row] * this.object.sfcuse_cnt[row]
				this.object.use_qty[row] = this.object.sfcuse_unit_qty[row] * this.object.sfcuse_cnt[row]
				this.object.etc_no[row] = idwc_coil.getitemstring(idwc_coil.getrow(),'coilmst_etc_no')
		elseif MidA(ls_item, 4, 1) = "2" then
				this.getchild("rem_qa", idwc_qa)
				gs_ds_qaall.ShareData(idwc_qa)
				idwc_qa.setfilter("item_no = '" + ls_item + "'")
				idwc_qa.filter()
			end if
		end if
		this.setcolumn('sfcuse_cnt')
		this.setfocus()

//	case 'loc_no'
//		  lr_locqty = idwc_loc.getitemnumber(idwc_loc.getrow(),'itemloc_qoh')
//		  if this.object.use_qty[row] > lr_locqty then
//			  return 1
//		  end if

	case 'sfcuse_cnt', 'use_qty'
		if MidA(ls_item, 4, 1) = "2" then //sheet
			this.object.sfcuse_mod_qty[row] =  this.object.sfcuse_cnt[row]
			this.object.use_qty[row] = this.object.sfcuse_cnt[row]
		else
			this.object.sfcuse_mod_qty[row] = this.object.sfcuse_unit_qty[row] * this.object.sfcuse_cnt[row]
			this.object.use_qty[row] = this.object.sfcuse_unit_qty[row] * this.object.sfcuse_cnt[row]
		end if
end choose
return 0

end event

event itemerror;string ls_null, ls_item, ls_qa

choose case dwo.name
	case 'item_no', 'qa', 'item_name'
		this.object.loc_no[row] = ''
		setnull(ls_null)
		this.object.loc_no[row] =ls_null
//	case 'loc_no'
//		messagebox("","저장소수량이 사용수량보다 부족합니다")
end choose
return 2
end event

event rowfocuschanged;//
long ll_row
string ls_item, ls_qa, ls_null, ls_loc
dwItemStatus l_status
	
this.accepttext()

ll_row = this.getrow()
if ll_row < 1 then return

ls_item = this.object.item_no[ll_row]
ls_qa   = this.object.qa[ll_row]
ls_loc  = dw_2.object.loc_no[1]
if isnull(ls_item) or isnull(ls_qa) or isnull(ls_loc) then return

dw_2.accepttext()
l_status = this.GetItemStatus(ll_row,0, Primary!)

if l_status = New! or l_status = NewModified!  then
	if MidA(ls_item, 4, 1) = "1" then
		wf_coildddw(dw5, ls_item, ls_qa, ls_loc)
	elseif MidA(ls_item, 4, 1) = "2" then
		wf_sheetdddw(dw5, ls_item, ls_qa, ls_loc)
	else
		wf_cleardddw(dw5)
	end if

	if ls_item = '' or isnull(ls_item) then
	else
		idwc_qa.setfilter("item_no = '" + ls_item + "'")
		idwc_qa.filter()
	end if
end if

end event

event doubleclicked;gs_coil lst_code
dwItemStatus l_status

l_status = this.GetItemStatus(row,0, Primary!)
if l_status = NotModified! then return

CHOOSE CASE dwo.name
	CASE 'item_no','qa',"item_item_name"
		if wf_itemselect(dw5,'S',row) = true then
		end if

//		cb_5.triggerevent(clicked!)
	CASE 'coil_no'
		long ll_row
		string ls_coil
		
		ll_row = dw5.getrow()
		lst_code.loc_no = this.object.loc_no[1]
		ls_coil = this.object.coil_no[ll_row]
		openwithparm(w_whcoil_w, lst_code)
		lst_code = message.powerobjectparm
		
		if lst_code.chk = "N" then 
			if isnull(ls_coil) or trim(ls_coil) = '' then
				this.setcolumn('coil_no')
			else
				this.setcolumn('sfcuse_cnt')
			end if
			return 1
		else
			dw5.SETREDRAW(false)
			this.object.sfcuse_mod_len[ll_row] = lst_code.length
			this.object.sfcuse_wid[ll_row] = lst_code.wid
			this.object.sfcuse_unit_qty[ll_row] = lst_code.unit_qty
			this.object.sfcuse_mod_qty[ll_row] = 0
			this.object.use_qty[ll_row] = 0
			this.object.etc_no[ll_row] = lst_code.etc_no
			this.object.item_item_name[ll_row] = lst_code.item_name
			this.object.item_no[ll_row] = lst_code.item_no
			this.object.qa[ll_row] = lst_code.qa
			this.object.uom[ll_row] = lst_code.uom
			this.object.coil_no[ll_row] = lst_code.coil_no
			this.object.loc_no[ll_row] = lst_code.loc_no
			this.object.sfcuse_cnt[ll_row] = 0
			this.object.qcnt[ll_row] = lst_code.qcnt
			is_clause2 = " and item_no = ~~'" + lst_code.item_no + "~~'"  &
						 + " and qa = ~~'" + lst_code.qa + "~~'"
			is_where1 = "DataWindow.Table.Select='"  + is_select2 + is_clause2 + "'"		
			wf_retrievechild(idwc_loc,is_where1)
		
			if MidA(lst_code.item_no, 4, 1) = "1" then
				wf_coildddw(dw5, lst_code.item_no, lst_code.qa,lst_code.loc_no )
			elseif MidA(lst_code.item_no, 4, 1) = "2" then
				wf_sheetdddw(dw5, lst_code.item_no, lst_code.qa, lst_code.loc_no)
			else
				wf_cleardddw(dw5)
			end if
			dw5.SETREDRAW(TRUE)
			this.setcolumn('sfcuse_cnt')
		end if
END CHOOSE

end event

