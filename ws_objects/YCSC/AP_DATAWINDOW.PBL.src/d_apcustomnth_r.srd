table(column=(type=char(16) updatewhereclause=yes name=eom_date dbname="eom_date" )
 column=(type=char(70) updatewhereclause=yes name=supp_name dbname="appeom.supp_name" )
 column=(type=datetime updatewhereclause=yes name=apoi_date dbname="appeom.apoi_date" )
 column=(type=char(14) updatewhereclause=yes name=inspap_no dbname="appeom.inspap_no" )
