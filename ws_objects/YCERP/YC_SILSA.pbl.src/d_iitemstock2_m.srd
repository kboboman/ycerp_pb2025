text(band=header alignment="2" text="생산/입고량" border="6" color="33554432" x="4210" y="8" height="60" width="407" html.valueishtml="0"  name=real_in_qty_t visible="1"  font.face="굴림체" font.height="-10" font.weight="700"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="67108864" )
text(band=header alignment="2" text="가입고" border="6" color="33554432" x="4626" y="8" height="60" width="407" html.valueishtml="0"  name=real_intemp_qty_t visible="1"  font.face="굴림체" font.height="-10" font.weight="700"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="67108864" )
text(band=header alignment="2" text="반품" border="6" color="33554432" x="5042" y="8" height="60" width="411" html.valueishtml="0"  name=real_ret_qty_t visible="1"  font.face="굴림체" font.height="-10" font.weight="700"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="67108864" )
text(band=header alignment="2" text="출고량" border="6" color="33554432" x="5463" y="8" height="60" width="402" html.valueishtml="0"  name=real_out_qty_t visible="1"  font.face="굴림체" font.height="-10" font.weight="700"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="67108864" )
text(band=header alignment="2" text="전일재고량" border="6" color="33554432" x="2962" y="8" height="60" width="407" html.valueishtml="0"  name=real_before_qty_t visible="1"  font.face="굴림체" font.height="-10" font.weight="700"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="67108864" )
text(band=header alignment="2" text="재고량" border="6" color="33554432" x="3378" y="8" height="60" width="402" html.valueishtml="0"  name=real_stock_qty_t visible="1"  font.face="굴림체" font.height="-10" font.weight="700"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="67108864" )
