 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"apeom~" ) COLUMN(NAME=~"apeom.supp_no~") COLUMN(NAME=~"apeom.eom_year~") COLUMN(NAME=~"apeom.balbf_amount~") COLUMN(NAME=~"apeom.inv_01~") COLUMN(NAME=~"apeom.inv_02~") COLUMN(NAME=~"apeom.inv_03~") COLUMN(NAME=~"apeom.inv_04~") COLUMN(NAME=~"apeom.inv_05~") COLUMN(NAME=~"apeom.inv_06~") COLUMN(NAME=~"apeom.inv_07~") COLUMN(NAME=~"apeom.inv_08~") COLUMN(NAME=~"apeom.inv_09~") COLUMN(NAME=~"apeom.inv_10~") COLUMN(NAME=~"apeom.inv_11~") COLUMN(NAME=~"apeom.inv_12~") COLUMN(NAME=~"apeom.coll_01~") COLUMN(NAME=~"apeom.coll_02~") COLUMN(NAME=~"apeom.coll_03~") COLUMN(NAME=~"apeom.coll_04~") COLUMN(NAME=~"apeom.coll_05~") COLUMN(NAME=~"apeom.coll_06~") COLUMN(NAME=~"apeom.coll_07~") COLUMN(NAME=~"apeom.coll_08~") COLUMN(NAME=~"apeom.coll_09~") COLUMN(NAME=~"apeom.coll_10~") COLUMN(NAME=~"apeom.coll_11~") COLUMN(NAME=~"apeom.coll_12~") COLUMN(NAME=~"apeom.make_date~") COLUMN(NAME=~"apeom.make_user~")WHERE(    EXP1 =~"apeom.supp_no~"   OP =~"like~"    EXP2 =~":aa~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"datepart(year,apeom.eom_year)~"   OP =~"=~"    EXP2 =~":bb~" ) ) ARG(NAME = ~"aa~" TYPE = string)  ARG(NAME = ~"bb~" TYPE = number) " arguments=(("aa", string),("bb", number)) )
