table(column=(type=char(14) updatewhereclause=yes name=order_no dbname="order_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="seq_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=decimal(2) updatewhereclause=yes name=order_qty dbname="order_qty" initial="0" )
 column=(type=decimal(4) updatewhereclause=yes name=price dbname="price" initial="0" )
 column=(type=decimal(2) updatewhereclause=yes name=acc_qty dbname="acc_qty" initial="0" )
 column=(type=char(1) updatewhereclause=yes name=saledet_text dbname="saledet_text" initial="N" )
 column=(type=char(1) updatewhereclause=yes name=saledet_action dbname="action" )
 column=(type=decimal(2) updatewhereclause=yes name=sol_qty dbname="sol_qty" initial="0" )
 column=(type=char(10) updatewhereclause=yes name=saledet_loc_no dbname="loc_no" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_issue_qty dbname="issue_qty" initial="0" )
 column=(type=datetime updatewhereclause=yes name=rlse_date dbname="rlse_date" )
 column=(type=decimal(2) updatewhereclause=yes name=rlse_qty dbname="rlse_qty" initial="0" )
 column=(type=char(50) updatewhereclause=yes name=rem dbname="rem" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_plan_qty dbname="plan_qty" initial="0" )
 column=(type=datetime updatewhereclause=yes name=plan_close dbname="plan_close" )
 column=(type=char(4) updatewhereclause=yes name=color dbname="color" )
 column=(type=decimal(4) updatewhereclause=yes name=price_be dbname="price_be" initial="0" )
 column=(type=char(12) updatewhereclause=yes name=saledet_do_rem dbname="do_rem" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_stock_qty dbname="stock_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_stock_issue dbname="stock_issue" )
 column=(type=decimal(0) updatewhereclause=yes name=saledet_stock_do dbname="stock_do" )
 column=(type=char(10) updatewhereclause=yes name=color_color_name dbname="color_name" )
 column=(type=char(60) updatewhereclause=yes name=item_item_name dbname="item_name" )
 column=(type=decimal(4) updatewhereclause=yes name=item_price_a dbname="price_a" )
 column=(type=decimal(0) updatewhereclause=yes name=saledet_amt dbname="amt" )
 retrieve="  SELECT saledet.order_no,   
         saledet.seq_no,   
         saledet.item_no,   
         saledet.qa,   
         saledet.uom,   
         saledet.order_qty,   
         saledet.price,   
         saledet.acc_qty,   
         saledet.saledet_text,   
         saledet.action,   
         saledet.sol_qty,   
         saledet.loc_no,   
         saledet.issue_qty,   
         saledet.rlse_date,   
         saledet.rlse_qty,   
         saledet.rem,   
         saledet.plan_qty,   
			isnull(dbo.uf_mpsdet_plan_date(saledet.order_no, saledet.seq_no ), saledet.plan_close) plan_close, 
         saledet.color,   
         saledet.price_be,   
         saledet.do_rem,   
         saledet.stock_qty,   
         saledet.stock_issue,   
         saledet.stock_do,
			color.color_name,  
         item.item_name,   
         item.price_a,   
         999999999999999 amt
    FROM saledet left outer join item on saledet.item_no = item.item_no 
                                     AND saledet.qa = item.qa
                 left outer join color on saledet.color = color.color_code 
					  left outer join ( 
												 select sale_no, seq_no, max(sfc_date) sfcday
												  from sfcday 
												  where sale_no = :as_order_no
												  group by sale_no, seq_no
                                 ) sf on sf.sale_no = saledet.order_no and sf.seq_no = saledet.seq_no
   WHERE saledet.order_no = :as_order_no" arguments=(("as_order_no", string))  sort="seq_no A " )
