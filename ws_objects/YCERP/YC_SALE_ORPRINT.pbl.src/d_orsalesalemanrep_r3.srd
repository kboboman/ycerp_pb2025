$PBExportHeader$d_orsalesalemanrep_r3.srd
$PBExportComments$영업사원별 수주현황 DISPLAY(1998/05/13, 정재수)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="79741120" )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=sale_cust_no dbname="cust_no" initial=" " )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="cust_name" )
 column=(type=char(11) updatewhereclause=yes name=sale_scene_code dbname="scene_code" initial=" " )
 column=(type=char(14) updatewhereclause=yes name=sale_order_no dbname="order_no" initial=" " )
 column=(type=char(1) updatewhereclause=yes name=sale_sale_flag dbname="sale_flag" initial=" " values="내수	D/수출	E/L//C	L/" )
 column=(type=char(3) updatewhereclause=yes name=sale_curr_code dbname="curr_code" initial=" " )
 column=(type=datetime updatewhereclause=yes name=sale_order_date dbname="order_date" initial=" " )
 column=(type=datetime updatewhereclause=yes name=sale_due_date dbname="due_date" initial=" " )
 column=(type=char(4) updatewhereclause=yes name=confirm_flag dbname="confirm_flag" )
 column=(type=char(1) updatewhereclause=yes name=sale_tracking dbname="tracking" )
 column=(type=long updatewhereclause=yes name=saledet_seq_no dbname="seq_no" )
 column=(type=char(10) updatewhereclause=yes name=saledet_item_no dbname="item_no" )
 column=(type=char(20) updatewhereclause=yes name=saledet_qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=saledet_uom dbname="uom" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_order_qty dbname="order_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_acc_qty dbname="acc_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=saledet_price dbname="price" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene_desc" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name dbname="user_name" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=char(10) updatewhereclause=yes name=c_start dbname="c_start" )
 column=(type=char(10) updatewhereclause=yes name=c_end dbname="c_end" )
 column=(type=char(50) updatewhereclause=yes name=rem dbname="rem" )
 column=(type=char(15) updatewhereclause=yes name=cust_po_no dbname="cust_po_no" )
 column=(type=char(10) updatewhereclause=yes name=org_name dbname="org_name" )
 retrieve="SELECT 
	distinct s.cust_no   
	, c.cust_name   
	, s.scene_code   
	, s.order_no   
	, s.sale_flag   
	, s.curr_code   
	, s.order_date   
	, s.due_date   
	, confirm_flag = (case	when s.confirm_flag = 'N' then '등록'
									when s.confirm_flag = 'T' then '수주'
									when s.confirm_flag = 'Y' then '생산'
						 	end)
	, tracking = isnull(s.tracking,'')
	, sd.seq_no   
	, sd.item_no   
	, sd.qa   
	, sd.uom   
	, sd.order_qty   
	, sd.acc_qty   
	, sd.price   
	, sc.scene_desc   
	, l.user_name   
	, g.item_name  
	, c_start = (case when :as_sdate = '' then space(10) else :as_sdate end)  
	, c_end   = (case when :as_edate = '' then space(10) else :as_edate end)  
	, sd.rem	rem
	, s.cust_po_no	cust_po_no
	, ll.user_name	org_name
FROM 
	UF_MyCustomers( :as_salesman ) M
	LEFT OUTER JOIN customer   C ON m.cust_no     = c.cust_no
	LEFT OUTER JOIN sale       S ON m.cust_no     = s.cust_no AND s.open_close  = 'O'
	LEFT OUTER JOIN saledet   SD ON s.order_no    = sd.order_no 
	LEFT OUTER JOIN groupitem  G ON sd.item_no    = g.item_no
	LEFT OUTER JOIN scene     SC ON s.scene_code  = sc.scene_code
	LEFT OUTER JOIN login      L ON c.salesman    = l.user_id
	LEFT OUTER JOIN login      LL ON s.org_user   = ll.user_id
WHERE 
	((:as_output  = 'Y' AND sd.order_qty - sd.rlse_qty > 0 ) OR (:as_output <> 'Y' AND sd.order_qty > 0 ))
AND 
	( s.area_no        LIKE :as_area ) 
AND 
	( s.order_date  BETWEEN :as_sdate AND :as_edate ) 
AND 
	((:as_team  = '%' AND m.cust_no   LIKE '%'  ) OR (:as_team <> '%' AND m.salesman     = :as_salesman )	)
AND ((:as_custno  = '%'   AND m.cust_no   LIKE '%'  ) OR 
	 (:as_custno  = 'ALL' AND m.cust_no   LIKE '%'  ) OR 
	 (:as_custno <> 'ALL' AND m.cust_no      = :as_custno ))
AND ((:as_inside  = '%') OR
	 (:as_inside <> '%' AND c.cust_no NOT IN (SELECT item_cd FROM codemst WHERE type = '내부업체' AND use_yn = 'Y') ))" arguments=(("as_area", string),("as_custno", string),("as_sdate", string),("as_edate", string),("as_salesman", string),("as_team", string),("as_inside", string),("as_output", string))  sort="login_user_name A sale_order_no A sale_order_date A saledet_seq_no A customer_cust_name A sale_scene_code A " )
group(level=1 header.height=0 trailer.height=72 by=("login_user_name" ) header.color="536870912" trailer.color="536870912" )
group(level=2 header.height=0 trailer.height=0 by=("sale_cust_no" ) header.color="536870912" trailer.color="553648127" )
group(level=3 header.height=0 trailer.height=72 by=("sale_scene_code" ) header.color="536870912" trailer.color="536870912" )
group(level=4 header.height=0 trailer.height=68 by=("sale_order_no" ) header.color="536870912" trailer.color="536870912" )
