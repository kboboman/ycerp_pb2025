$PBExportHeader$d_ipbpur_allmon_part_r.srd
$PBExportComments$조업자재 거래처별/부서별구매월보(상세2)(1999/07/03, 이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=92 color="79741120" )
summary(height=96 color="12639424" )
footer(height=0 color="536870912" )
detail(height=108 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=bpart_part_name dbname="bpart.part_name" )
 column=(type=char(30) updatewhereclause=yes name=bitem_item_name dbname="bitem.item_name" )
 column=(type=decimal(4) updatewhereclause=yes name=aa dbname="compute_0003" )
 retrieve="  SELECT bpart.part_name,   
                bitem.item_name,   
         round( SUM(AMOUNT), 0, 1 )
    FROM binitem left outer join bpart on binitem.part_code = bpart.part_no
                              left outer join bitem on binitem.item_no = bitem.item_no
   WHERE ( 
                    ( datepart(year, binitem.in_date) = :ai_yy ) AND  
                    ( datepart(month, binitem.in_date) = :ai_mm ) AND  
                    ( binitem.area_no = :as_area ) 
                 )   
GROUP BY bpart.part_name,   
         bitem.item_name   
/*
    FROM binitem,   
         bpart,   
         bitem  
   WHERE ( binitem.part_code *= bpart.part_no) and  
         ( binitem.item_no *= bitem.item_no) and  
         ( ( datepart(year, binitem.in_date) = :ai_yy ) AND  
         ( datepart(month, binitem.in_date) = :ai_mm ) AND  
         ( binitem.area_no = :as_area ) )   
GROUP BY bpart.part_name,   
         bitem.item_name   
*/" arguments=(("ai_yy", number),("ai_mm", number),("as_area", string))  sort="bpart_part_name A bitem_item_name A " )
group(level=1 header.height=0 trailer.height=88 by=("bpart_part_name" ) header.color="536870912" trailer.color="553648127" )
