integer x = 1719
integer y = 4
integer width = 1339
integer height = 88
integer taborder = 81
boolean bringtotop = true
integer textsize = -10
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "수주물품별 재고현황(NEW) 가져오기"
end type

event clicked;//======================================================================
// 수주물품별 재고현황(NEW) : dw_jaego
// 거래처 검사 -> cb_14(검색) -> dw_6 선택 -> pb_5(물품이동) 반복수행
//======================================================================
long   ll_row, ll_seqno, ll_y, ll_cnt, ll_dw17row
string ls_orderno, ls_itemno, ls_qa, ls_uom, ls_supp, ls_sale_no, ls_sqlerrtext

string	    ls_item_name, ls_assembly,	 ls_assembly_name, ls_assembly_uom, ls_assy_qa, ls_wc_no, ls_work_name,	ls_order_no, ls_rem, ls_cust_name, ls_color	, ls_rout_count
long        l_operation,	 l_qoh, l_seq_no
decimal  l_saledetqty, l_pur_qty


DECLARE saledet_rout_cursor CURSOR FOR  
  SELECT /*saledet.item_no                  
			 , saledet.qa                       
			 */
			   groupitem.item_name              
			 , groupitem.uom        			 
			 , rout.assembly
			 , a.item_name assembly_name
			 , a.uom assembly_uom
			 , rout.assy_qa
			 , rout.wc_no
			 , wc.work_name
			 , rout.operation			
			 , qoh        = isnull(item.qoh, 0)  
			 , saledet.order_no                 
			 , saledet.seq_no                
			 , saledet.rem                   
			 , customer.cust_name               
			 , saledetqty = saledet.order_qty
			 , pur_qty    = isnull(sum(purdet.order_qty), 0 )
			 , color      = saledet.color
	 	      , isnull(( select ( case when item_no is  null then 'N' else 'Y' end ) from item with(nolock) WHERE  item.item_no = rout.assembly and item.qa =  saledet.qa ), 'N' ) rout_count
    FROM saledet WITH(NOLOCK) inner join  sale WITH(NOLOCK) on saledet.order_no  = sale.order_no
                                                                                                   AND  sale.open_close        = 'O'  
                                                                                                   AND sale.confirm_flag     IN ('T', 'Y')
                                     inner join customer WITH(NOLOCK) on sale.cust_no           = customer.cust_no      
                                     inner join  groupitem WITH(NOLOCK)  on saledet.item_no = groupitem.item_no                                     
                                     left outer join purdet WITH(NOLOCK) on saledet.order_no  = purdet.sale_no    AND  saledet.seq_no  = purdet.sale_seq  
							left outer join  item  WITH(NOLOCK)   on saledet.item_no  = item.item_no and saledet.qa   = item.qa
/*                                     left outer join rout with(nolock) on saledet .item_no = rout.item_no and saledet.qa = rout.qa*/
                                     left outer join rout with(nolock) on item .item_no = rout.item_no and item.qa1 = rout.qa
                                     left outer join groupitem a with(NOLOCK) on  rout.assembly = a.item_no 
                                     left outer join wc with(nolock) on rout.wc_no = wc.work_no
      WHERE saledet.order_no = :ls_sale_no
		    and saledet.seq_no   = :ll_seqno 
		    and saledet.item_no  = :ls_itemno
		    and saledet.qa           = :ls_qa
   GROUP BY saledet.item_no    
                   , saledet.qa            
                   , groupitem.item_name   
                   , groupitem.uom         
                   , qoh                
                   , saledet.order_no      
                   , saledet.seq_no     
                   , saledet.rem        
                   , customer.cust_name    
                   , saledet.order_qty
                   , saledet.color
                   , rout.assembly
                   , a.item_name                   
                   , rout.assy_qa
                   , rout.wc_no      
                   , wc.work_name         
                   , rout.operation
			   , a.uom;


if dw_1.rowcount() < 1 then
	MessageBox("오류","거래처 정보를 입력 하십시오.", Exclamation!)
	return
end if

ls_supp = trim(dw_1.object.supp_no[1])
if isnull(ls_supp) or ls_supp = "" then
	MessageBox("오류","거래처를 입력하십시오.", Exclamation!)
	dw_1.setcolumn('supp_no')
	dw_1.setfocus()
	return
end if	

//======================================================================
// 거래처 검사 -> cb_14(검색) -> dw_6 선택 -> pb_5(물품이동) 반복수행
//======================================================================
ib_auto = true
//======================================================================
for ll_row = 1 to dw_jaego.rowcount()
	cb_30.text = "수주물품별 재고현황(NEW) 가져오기 " + string(ll_row) + " / " + string(dw_jaego.rowcount())
	is_orderno = dw_jaego.object.order_no[ll_row]		// 수주번호
	// !!########-###
	em_4.text  = ls_orderno //left(ls_orderno,10) + right(ls_orderno,3)
	em_4.text  = LeftA(dw_jaego.object.order_no[ll_row],10) + RightA(dw_jaego.object.order_no[ll_row],3)	

	ls_sale_no = dw_jaego.object.order_no[ll_row]
	ll_seqno     = dw_jaego.object.seq_no[ll_row]  	// 순번
	ls_itemno  = dw_jaego.object.item_no[ll_row]  	// 품목
	ls_qa         = dw_jaego.object.qa[ll_row]   	   // 규격
	
	 ib_move = true
	 
	OPEN saledet_rout_cursor;
	
		FETCH saledet_rout_cursor INTO   :ls_item_name, :ls_uom,  :ls_assembly,	 :ls_assembly_name, :ls_assembly_uom,
													 :ls_assy_qa, :ls_wc_no, :ls_work_name,	:l_operation,	 :l_qoh, :ls_order_no, :l_seq_no, :ls_rem, :ls_cust_name,
													 :l_saledetqty, :l_pur_qty, :ls_color, :ls_rout_count;
		
		Do While sqlca.sqlcode = 0
	
				 ll_dw17row = dw17.insertrow(0)		 
				
				  dw17.object.item_no[ll_dw17row]								= ls_itemno
				  dw17.object.qa[ll_dw17row]                      					= ls_qa 
				  dw17.object.item_name[ll_dw17row]   						= ls_item_name          
				  dw17.object.uom[ll_dw17row]        							= ls_uom		 
				  dw17.object.assembly[ll_dw17row]							= ls_assembly
				  dw17.object.assembly_name[ll_dw17row]					= ls_assembly_name
				  dw17.object.assembly_uom[ll_dw17row]					= ls_assembly_uom
				  dw17.object.assy_qa[ll_dw17row]								= ls_assy_qa
				  dw17.object.wc_no[ll_dw17row]								= ls_wc_no
				  dw17.object.work_name[ll_dw17row]							= ls_work_name
				  dw17.object.operation[ll_dw17row]							= l_operation
				  dw17.object.qoh[ll_dw17row]									= l_qoh
				  dw17.object.order_no[ll_dw17row]                 				= ls_order_no
				  dw17.object.seq_no[ll_dw17row]                					= l_seq_no
				  dw17.object.saledet_rem[ll_dw17row]                  			= ls_rem
				  dw17.object.cust_name[ll_dw17row]               				= ls_cust_name
				  dw17.object.saledetqty[ll_dw17row]							= l_saledetqty
				  dw17.object.pur_qty[ll_dw17row]								= l_pur_qty
				  dw17.object.color[ll_dw17row]									= ls_color
				  dw17.object.rout_count[ll_dw17row]							= ls_rout_count				  
				
		
				if sqlca.sqlcode < 0 then
					 ib_move = false
					ls_sqlerrtext = string(sqlca.sqlerrtext)
					ROLLBACK;				
					MessageBox('오류32','[saledet_rout_cursor] select 중 DB오류가 발생했습니다.~r~n' + ls_sqlerrtext, exclamation!)
					RETURN 0
				end if					 
			
					
				FETCH saledet_rout_cursor INTO   :ls_item_name, :ls_uom,  :ls_assembly,	 :ls_assembly_name, :ls_assembly_uom,
															 :ls_assy_qa, :ls_wc_no, :ls_work_name,	:l_operation,	 :l_qoh, :ls_order_no, :l_seq_no, :ls_rem, :ls_cust_name,
															 :l_saledetqty, :l_pur_qty, :ls_color, :ls_rout_count;
			
		Loop
	
	CLOSE saledet_rout_cursor;
	

	if ib_move = false then 
		MessageBox("확인", "물품이동 작업에서 오류가 발생하였습니다.")
		exit
	end if
	
next

//
ib_auto = false
ib_move = false
dw_jaego.reset()
cb_30.text    = "수주물품별 재고현황(NEW) 가져오기"
cb_30.enabled = false	// 수주물품별 재고현황(NEW) 가져오기
MessageBox("확인", "수주물품별 재고현황(NEW) 가져오기 작업완료.")

end event

