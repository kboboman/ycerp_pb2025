detail(height=76 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="GroupItem.item_no" )
 column=(type=char(60) update=yes updatewhereclause=yes name=item_name dbname="GroupItem.item_name" )
 column=(type=char(10) update=yes updatewhereclause=yes name=user_id dbname="GroupItem.user_id" )
 column=(type=datetime update=yes updatewhereclause=yes name=sys_date dbname="GroupItem.sys_date" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="GroupItem.uom" )
 column=(type=char(1) updatewhereclause=yes name=source dbname="GroupItem.source" values="구매품	B/반제품	M/완제품	W/스리팅	E/" )
 column=(type=char(1) updatewhereclause=yes name=use_flag dbname="GroupItem.use_flag" initial="Y" )
 column=(type=char(1) updatewhereclause=yes name=qa_rule dbname="GroupItem.qa_rule" )
 column=(type=long updatewhereclause=yes name=cnt dbname="cnt" )
 column=(type=char(50) updatewhereclause=yes name=category dbname="category" )
 column=(type=char(10) updatewhereclause=yes name=ctype dbname="ctype" )
 retrieve="  SELECT groupitem.item_no
       , groupitem.item_name   
       , groupitem.user_id   
       , groupitem.sys_date   
       , groupitem.uom   
       , groupitem.source   
       , groupitem.use_flag   
       , groupitem.qa_rule 
       , cnt   = (SELECT count(*) FROM item WITH(NOLOCK) WHERE item_no = groupitem.item_no)
       , category = codemst.item_nm
       , ctype    = itemtop10.type
    FROM groupitem WITH(NOLOCK)
         LEFT OUTER JOIN itemtop10  WITH(NOLOCK) ON groupitem.item_no = itemtop10.item_no
         LEFT OUTER JOIN codemst  WITH(NOLOCK)  ON itemtop10.category= codemst.item_cd
                                   AND codemst.type   = 'ITEMTOP10' AND codemst.use_yn = 'Y'
" update="groupitem" updatewhere=1 updatekeyinplace=no  sort="use_flag D source A item_name A " )
