$PBExportHeader$d_cdcustmaster_r_sales.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=88 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=customer_cust_no dbname="customer.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(10) updatewhereclause=yes name=customer_salesman dbname="customer.salesman" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name dbname="login.user_name" )
 column=(type=char(10) updatewhereclause=yes name=top_level dbname="top_level" )
 column=(type=char(10) updatewhereclause=yes name=toplevel dbname="toplevel" )
 column=(type=long updatewhereclause=yes name=cust_idx dbname="cust_idx" )
 column=(type=long updatewhereclause=yes name=cust_sort dbname="cust_sort" )
 column=(type=char(50) updatewhereclause=yes name=mgr_type dbname="mgr_type" )
 column=(type=long updatewhereclause=yes name=mgr_sort dbname="mgr_sort" )
 column=(type=decimal(2) updatewhereclause=yes name=opeom_amt dbname="opeom_amt" )
 column=(type=char(1) updatewhereclause=yes name=open_close dbname="open_close" )
 column=(type=char(255) updatewhereclause=yes name=custname_sort dbname="custname_sort" )
 retrieve="SELECT customer.cust_no
     , customer.cust_name
     , customer.salesman
     , login.user_name

     , top_level  = customer.top_level
/*     , toplevel   = (case substring(customer.top_level,1,2)
								when 'A+' then '1'
								when 'A'  then '2'
								when 'B+' then '3'
								when 'B'  then '4'
								when 'C'  then '5'
								when '채' then '6'
								else '7'
                     end)
*/
     , dbo.uf_toplevel_sort(customer.top_level) toplevel
/*
     , toplevel   = (case substring(customer.top_level,1,2)
								when 'Aa' then 1
								when 'Ab'  then 2
								when 'Ac'  then 3
								when 'Ba' then 4
								when 'Bb'  then 5
								when 'Bc'  then 6
								when 'Ca' then 7
								when 'Cb'  then 8
								when 'Cc'  then 9
								else 10
                     end)
*/
     , cust_idx   = isnull(cs.cust_idx, 0)
     , cust_sort  = 0
     , mgr_type   = (SELECT item_nm FROM codemst WHERE type = 'MGR_TYPE' AND use_yn = 'Y' AND item_cd = customer.mgr_type)
     , mgr_sort   = isnull((SELECT sort    FROM codemst WHERE type = 'MGR_TYPE' AND use_yn = 'Y' AND item_cd = customer.mgr_type),99)
     , opeom_amt  = opeom.balbf_amount + 
                   ( opeom.inv_01  + opeom.inv_02  + opeom.inv_03  + opeom.inv_04  + opeom.inv_05  + opeom.inv_06    + 
                     opeom.inv_07  + opeom.inv_08  + opeom.inv_09  + opeom.inv_10  + opeom.inv_11  + opeom.inv_12  ) - 
                   ( opeom.coll_01 + opeom.coll_02 + opeom.coll_03 + opeom.coll_04 + opeom.coll_05 + opeom.coll_06   + 
                     opeom.coll_07 + opeom.coll_08 + opeom.coll_09 + opeom.coll_10 + opeom.coll_11 + opeom.coll_12 )
     , customer.open_close
     , custname_sort = replace(replace(replace(customer.cust_name,'(주)',''),'(재)',''),'(사)','')
  FROM opeom    (nolock)
       LEFT OUTER JOIN customer (nolock)         ON opeom.cust_no     = customer.cust_no
       LEFT OUTER JOIN customer_sort cs (nolock) ON customer.cust_no  = cs.cust_no
       LEFT OUTER JOIN login    (nolock)         ON customer.salesman = login.user_id
 WHERE ( datepart(year,opeom.eom_year) = :as_year )
   AND ( customer.salesman = :as_salesman         )
   AND ( ( :as_open  = '%' and customer.open_close LIKE '%' ) OR
         ( :as_open <> '%' and customer.open_close    = 'O' )           
       )
 ORDER BY login.user_name, customer.top_level, cust_sort, mgr_sort, customer.cust_name
" arguments=(("as_open", string),("as_salesman", string),("as_year", number))  sort="cust_idx A login_user_name A mgr_sort A cust_sort A customer_cust_name A " )
