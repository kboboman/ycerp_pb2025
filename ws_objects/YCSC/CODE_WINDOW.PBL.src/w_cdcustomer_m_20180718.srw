type pb_exinsert from picturebutton within tabpage_4
integer x = 2400
integer y = 4
integer width = 187
integer height = 144
integer taborder = 52
boolean bringtotop = true
integer textsize = -10
integer weight = 400
fontpitch fontpitch = variable!
fontfamily fontfamily = swiss!
string facename = "Arial"
string picturename = "c:\bmp\pencil.bmp"
string disabledname = "c:\bmp\pencil.bmp"
alignment htextalign = left!
end type

event clicked;long ll_row, ll_front, ll_seq
string ls_cust_no, ls_ex_name
datetime ls_ex_year
if gf_permission('판매거래처관리edit', gs_userid) = 'N' then
//if gs_userid = 'chahc' then
	messagebox('확인', '권한이 없습니다. 전산실에 문의 하십시요.')
	return
end if

ll_row = tab_1.tabpage_4.dw_17.getrow()
ls_cust_no = tab_1.tabpage_4.st_2.text
if isnull(ls_cust_no) or ls_cust_no = ""  then
	messagebox("확인","판매거래처가 선택되지 않았습니다.",information!)
	return
end if
if ll_row > 0 then
   tab_1.tabpage_4.dw_17.accepttext()
	ls_ex_year = tab_1.tabpage_4.dw_17.getitemdatetime(tab_1.tabpage_4.dw_17.rowcount(), "ex_year")
	ls_ex_name = tab_1.tabpage_4.dw_17.getitemstring(tab_1.tabpage_4.dw_17.rowcount(), "ex_name")

	if isnull(ls_ex_year) then
		messagebox("확인","해당년월을 입력하세요!",information!)
		tab_1.tabpage_4.dw_17.scrolltorow(tab_1.tabpage_4.dw_17.rowcount())
		tab_1.tabpage_4.dw_17.setcolumn("ex_year")
		tab_1.tabpage_4.dw_17.setfocus()
		return
	elseif isnull(ls_ex_name) or ls_ex_name = ""  then
		messagebox("확인","공사명을 입력하세요!",information!)
		tab_1.tabpage_4.dw_17.scrolltorow(tab_1.tabpage_4.dw_17.rowcount())
		tab_1.tabpage_4.dw_17.setcolumn("ex_name")
		tab_1.tabpage_4.dw_17.setfocus()
		return
	end if
end if

ll_row = tab_1.tabpage_4.dw_17.insertrow(0)
tab_1.tabpage_4.dw_17.object.cust_no[ll_row]= trim(ls_cust_no)
tab_1.tabpage_4.dw_17.scrolltorow(ll_row)
tab_1.tabpage_4.dw_17.setcolumn("ex_year")
tab_1.tabpage_4.dw_17.setfocus()





end event

