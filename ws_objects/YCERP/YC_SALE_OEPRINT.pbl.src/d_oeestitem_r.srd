$PBExportHeader$d_oeestitem_r.srd
$PBExportComments$품목별 견적현황 조회(2001/05/25, 이인호)
release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=500 color="536870912" )
summary(height=68 color="536870912" )
footer(height=0 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=char(60) updatewhereclause=yes name=estimate_head_scene_desc dbname="estimate_head.scene_desc" )
 column=(type=long updatewhereclause=yes name=estimate_det_seq_no dbname="estimate_det.seq_no" )
 column=(type=char(10) updatewhereclause=yes name=estimate_det_item_no dbname="estimate_det.item_no" )
 column=(type=char(20) updatewhereclause=yes name=estimate_det_qa dbname="estimate_det.qa" )
 column=(type=char(2) updatewhereclause=yes name=estimate_det_uom dbname="estimate_det.uom" )
 column=(type=decimal(3) updatewhereclause=yes name=estimate_det_order_qty dbname="estimate_det.order_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=estimate_det_acc_qty dbname="estimate_det.acc_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=estimate_det_unit_cost dbname="estimate_det.unit_cost" )
 column=(type=decimal(4) updatewhereclause=yes name=estimate_det_item_amt dbname="estimate_det.item_amt" )
 column=(type=datetime updatewhereclause=yes name=c_start dbname="c_start" )
 column=(type=datetime updatewhereclause=yes name=c_end dbname="c_end" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(60) updatewhereclause=yes name=estimate_head_cust_name dbname="estimate_head.cust_name" )
 column=(type=char(1) updatewhereclause=yes name=estimate_head_esti_flag dbname="estimate_head.esti_flag" values="완결	Y/미결	B/보류	N/수주성공	S/" )
 column=(type=char(4) updatewhereclause=yes name=estimate_head_cust_no dbname="estimate_head.cust_no" )
 column=(type=char(14) updatewhereclause=yes name=estimate_head_estimate_no dbname="estimate_head.estimate_no" )
 retrieve="  SELECT estimate_head.scene_desc,   
         estimate_det.seq_no,   
         estimate_det.item_no,   
         estimate_det.qa,   
         estimate_det.uom,   
         estimate_det.order_qty,   
         estimate_det.acc_qty,   
         estimate_det.unit_cost,   
         estimate_det.item_amt,   
         c_start = convert(smalldatetime, :ad_start, 111),   
         c_end = convert(smalldatetime, :ad_end, 111),   
         groupitem.item_name,   
         estimate_head.cust_name,   
         estimate_head.esti_flag,   
         estimate_head.cust_no,   
         estimate_head.estimate_no  
    FROM estimate_det,   
         estimate_head,   
         groupitem  
   WHERE ( estimate_det.estimate_no = estimate_head.estimate_no ) and  
         ( estimate_det.item_no = groupitem.item_no ) and  
         ( ( estimate_head.estimate_date between :ad_start and :ad_end ) )    
		and groupitem.item_name like :as_item
			and estimate_head.esti_flag like :as_flag
" arguments=(("ad_start", date),("ad_end", date),("as_item", string),("as_flag", string))  sort="groupitem_item_name A estimate_head_cust_name A estimate_head_estimate_no A estimate_det_seq_no A " )
group(level=1 header.height=72 trailer.height=76 by=("groupitem_item_name" ) header.color="536870912" trailer.color="536870912" )
group(level=2 header.height=0 trailer.height=76 by=("estimate_head_cust_name" ) header.color="536870912" trailer.color="536870912" )
