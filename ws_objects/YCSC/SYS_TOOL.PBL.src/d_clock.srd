$PBExportHeader$d_clock.srd
$PBExportComments$Clock  using datawindow refresh timer
release 6;
datawindow(units=0 timer_interval=5000 color=79741120 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 1 print.margin.right = 1 print.margin.top = 1 print.margin.bottom = 1 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=0 color="536870912" )
table(column=(type=date updatewhereclause=yes name=x dbname="x" )
 )
compute(band=header alignment="0" expression="today()"border="0" color="16711680" x="0" y="8" height="64" width="754" format="yyyy년mm월dd일 h:mm:ss AM/PM"  font.face="굴림체" font.height="-9" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="78682240" )
compute(band=header alignment="0" expression="gf_messcount()"border="0" color="255" x="763" y="8" height="64" width="133" format="#,##0"  font.face="궁서체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="79741120" )
htmltable(border="1" cellpadding="0" cellspacing="0" generatecss="no" nowrap="yes")