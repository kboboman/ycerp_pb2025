footer(height=76 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=long updatewhereclause=yes name=qcnt dbname="qcnt" )
 column=(type=char(13) update=yes updatewhereclause=yes key=yes name=move_no dbname="itemmovedet.move_no" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=seq dbname="itemmovedet.seq" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="itemmovedet.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="itemmovedet.qa" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=move_qty dbname="itemmovedet.move_qty" )
 column=(type=char(20) update=yes updatewhereclause=yes name=lot_no dbname="itemmovedet.lot_no" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=cnt dbname="itemmovedet.cnt" initial="0" )
 column=(type=char(60) update=yes updatewhereclause=yes name=rem dbname="itemmovedet.rem" )
 column=(type=long update=yes updatewhereclause=yes name=pre_seq dbname="itemmovedet.pre_seq" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="GroupItem.uom" )
 column=(type=char(1) updatewhereclause=yes name=os dbname="os" )
 retrieve="  SELECT qcnt = 0,   
         itemmovedet.move_no,   
         itemmovedet.seq,   
         itemmovedet.item_no,   
         itemmovedet.qa,   
         itemmovedet.move_qty,   
         itemmovedet.lot_no,   
         itemmovedet.cnt,   
         itemmovedet.rem,   
         itemmovedet.pre_seq,   
         groupitem.item_name,   
         groupitem.uom,   
         os = ' '  
    FROM itemmovedet left outer join groupitem  on itemmovedet.item_no = groupitem.item_no
   WHERE ( ( itemmovedet.move_no = :as_no ) )    
" update="itemmovedet" updatewhere=0 updatekeyinplace=no arguments=(("as_no", string))  sort="seq A " )
