detail(height=72 color="536870912" )
table(column=(type=char(30) updatewhereclause=yes name=coil_supp_name dbname="supp.supp_name" )
 column=(type=datetime updatewhereclause=yes name=insp_insp_date dbname="insp.insp_date" )
 column=(type=decimal(4) updatewhereclause=yes name=inspdet_price dbname="inspdet.price" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=long updatewhereclause=yes name=year dbname="year" )
 column=(type=long updatewhereclause=yes name=mon dbname="mon" )
 column=(type=char(20) updatewhereclause=yes name=sheetmst_sheet_no dbname="sheetmst.sheet_no" )
 column=(type=char(20) updatewhereclause=yes name=sheetmst_qa dbname="sheetmst.qa" )
 column=(type=long updatewhereclause=yes name=sheetmst_cnt dbname="sheetmst.cnt" )
 column=(type=decimal(3) updatewhereclause=yes name=sheetmst_rcpt_qty dbname="sheetmst.rcpt_qty" )
 retrieve="  SELECT supp.supp_name,   
         insp.insp_date,   
         inspdet.price,   
         groupitem.item_name,   
         year = datepart(year, insp.insp_date),   
         mon = datepart(month, insp.insp_date),   
         sheetmst.sheet_no,   
         sheetmst.qa,   
         sheetmst.cnt,   
         sheetmst.rcpt_qty  
    FROM supp,   
         insp,   
         inspdet,   
         groupitem,   
         sheetmst  
   WHERE ( insp.insp_no = inspdet.insp_no ) and  
         ( insp.supp_no = supp.supp_no ) and  
         ( inspdet.item_no = groupitem.item_no ) and  
         ( inspdet.coil_no = sheetmst.sheet_no ) and  
         ( ( datepart(year, insp.insp_date) = :as_year ) AND  
         ( datepart(month, insp.insp_date) = :as_month ) AND  
         ( insp.pur_flag = 'N' ) )    
" arguments=(("as_year", number),("as_month", number)) )
