$PBExportHeader$d_cbriefing_t.srd
$PBExportComments$현설정보관리[2001.03.15,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=84 color="536870912" )
summary(height=0 color="536870912" )
footer(height=68 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=sale_no dbname="cestimate.SALE_NO" )
 column=(type=char(30) updatewhereclause=yes name=cust_no dbname="CUST_NO" )
 column=(type=char(50) updatewhereclause=yes name=scene_no dbname="SCENE_NO" )
 column=(type=datetime updatewhereclause=yes name=briefing_date dbname="cestimate.BRIEFING_DATE" )
 column=(type=datetime updatewhereclause=yes name=tender_date dbname="cestimate.TENDER_DATE" )
 retrieve="  SELECT CESTIMATE.SALE_NO,                                      
         CUST_NO  = CCUSTOMER.CUST_NAME,                          
         SCENE_NO = CSCENE.SCENE_NAME,                           
         CESTIMATE.BRIEFING_DATE,                                
         CESTIMATE.TENDER_DATE                                   
    FROM CESTIMATE left outer join CCUSTOMER      on  CESTIMATE.CUST_NO    = CCUSTOMER.CUST_NO
							  left outer join CSCENE              on   CESTIMATE.SCENE_NO = CSCENE.SCENE_NO
     WHERE ( BRIEFING_DATE      BETWEEN :AD_START AND :AD_END ) 
/*     AND ( ('Y' = :AS_TOP_CHK     AND CESTIMATE.TOP_SIGN IS NOT NULL) OR
           ('N' = :AS_TOP_CHK     AND CESTIMATE.TOP_SIGN IS NULL)
         )
*/" arguments=(("ad_start", date),("ad_end", date),("as_top_chk", string))  sort="briefing_date D " )
