table(column=(type=char(4) update=yes updatewhereclause=yes name=cust_no dbname="aroiinv.cust_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=sale_flag dbname="aroiinv.sale_flag" )
 column=(type=char(20) update=yes updatewhereclause=yes name=register_no dbname="aroiinv.register_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=inv_type dbname="aroiinv.inv_type" )
 column=(type=datetime update=yes updatewhereclause=yes name=oi_date dbname="aroiinv.oi_date" )
 column=(type=char(3) update=yes updatewhereclause=yes name=curr_code dbname="aroiinv.curr_code" initial="WON" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=gl_cur_rate dbname="aroiinv.gl_cur_rate" initial="1" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=aroiinv_cash dbname="aroiinv.aroiinv_cash" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=aroiinv_rate dbname="aroiinv.aroiinv_rate" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=ship_cost dbname="aroiinv.ship_cost" initial="0" )
 column=(type=char(1) update=yes updatewhereclause=yes name=printed dbname="aroiinv.printed" initial="N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=open_close dbname="aroiinv.open_close" initial="O" )
 column=(type=datetime update=yes updatewhereclause=yes name=close_date dbname="aroiinv.close_date" )
 column=(type=char(1) update=yes updatewhereclause=yes name=delete_flag dbname="aroiinv.delete_flag" initial="N" )
 column=(type=datetime update=yes updatewhereclause=yes name=sys_date dbname="aroiinv.sys_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=login_id dbname="aroiinv.login_id" )
 column=(type=char(40) update=yes updatewhereclause=yes name=rem dbname="aroiinv.rem" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=dc dbname="aroiinv.dc" initial="0" )
 column=(type=char(1) updatewhereclause=yes name=c_vat_flag dbname="c_vat_flag" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=rem_amt dbname="aroiinv.rem_amt" initial="0" )
 column=(type=char(3) update=yes updatewhereclause=yes name=inv_area dbname="aroiinv.inv_area" initial="H01" )
 column=(type=char(1) updatewhereclause=yes name=c_aroi_flag dbname="c_aroi_flag" initial="1" values="청구	1/영수	2/" )
 column=(type=char(1) updatewhereclause=yes name=c_aroi_chk dbname="c_aroi_chk" initial="N" values="	Y/	N" )
 column=(type=long updatewhereclause=yes name=c_rate dbname="aroiinv.c_rate" initial="0" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=dc_rate dbname="aroiinv.dc_rate" initial="0" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=discount dbname="aroiinv.discount" initial="0" )
 column=(type=char(12) update=yes updatewhereclause=yes key=yes name=aroiinv_no dbname="aroiinv.aroiinv_no" )
 retrieve="  SELECT aroiinv.cust_no,   
         aroiinv.sale_flag,   
         aroiinv.register_no,   
         aroiinv.inv_type,   
         aroiinv.oi_date,   
         aroiinv.curr_code,   
         aroiinv.gl_cur_rate,   
         aroiinv.aroiinv_cash,   
         aroiinv.aroiinv_rate,   
         aroiinv.ship_cost,   
         aroiinv.printed,   
         aroiinv.open_close,   
         aroiinv.close_date,   
         aroiinv.delete_flag,   
         aroiinv.sys_date,   
         aroiinv.login_id,   
         aroiinv.rem,   
         aroiinv.dc,   
         ' ' c_vat_flag,   
         aroiinv.rem_amt,   
         aroiinv.inv_area,   
         ' ' c_aroi_flag,   
         ' ' c_aroi_chk,   
         0 c_rate,   
         aroiinv.dc_rate,   
         aroiinv.discount,   
         aroiinv.aroiinv_no  
    FROM aroiinv   
" update="aroiinv" updatewhere=0 updatekeyinplace=no )
