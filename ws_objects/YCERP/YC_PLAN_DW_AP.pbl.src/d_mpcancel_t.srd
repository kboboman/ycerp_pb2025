release 8;
datawindow(units=0 timer_interval=0 color=78160032 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(17) updatewhereclause=yes name=order_no dbname="mps.order_no" )
 column=(type=char(10) updatewhereclause=yes name=work_name dbname="wc.work_name" )
 retrieve="  SELECT mps.order_no
       , wc.work_name  
    FROM mps 
         LEFT OUTER JOIN wc ON mps.wc_no = wc.work_no  
   WHERE ( mps.open_close = 'P' ) 
     AND ( mps.start_date between :as_start and :as_end ) 
     AND ( mps.area_no    = :as_area )    
" arguments=(("as_start", date),("as_end", date),("as_area", string))  sort="order_no D " )
