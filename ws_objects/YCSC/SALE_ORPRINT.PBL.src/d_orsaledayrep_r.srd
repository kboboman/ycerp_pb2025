$PBExportHeader$d_orsaledayrep_r.srd
$PBExportComments$수주일보 DISPLAY(1998/05/12, 정재수)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="79741120" )
summary(height=0 color="536870912" )
footer(height=68 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=cust_no dbname="sale.cust_no" initial=" " )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=char(11) updatewhereclause=yes name=sale_scene_code dbname="sale.scene_code" initial=" " )
 column=(type=char(14) updatewhereclause=yes name=sale_order_no dbname="sale.order_no" initial=" " )
 column=(type=char(1) updatewhereclause=yes name=sale_sale_flag dbname="sale.sale_flag" initial=" " values="내수	D/수출	E/L//C	L/" )
 column=(type=char(3) updatewhereclause=yes name=sale_curr_code dbname="sale.curr_code" initial=" " )
 column=(type=datetime updatewhereclause=yes name=sale_order_date dbname="sale.order_date" initial=" " )
 column=(type=datetime updatewhereclause=yes name=sale_cust_po_date dbname="sale.cust_po_date" )
 column=(type=datetime updatewhereclause=yes name=sale_due_date dbname="sale.due_date" initial=" " )
 column=(type=long updatewhereclause=yes name=saledet_seq_no dbname="saledet.seq_no" )
 column=(type=char(10) updatewhereclause=yes name=saledet_item_no dbname="saledet.item_no" )
 column=(type=char(20) updatewhereclause=yes name=saledet_qa dbname="saledet.qa" )
 column=(type=char(2) updatewhereclause=yes name=saledet_uom dbname="saledet.uom" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_order_qty dbname="saledet.order_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_acc_qty dbname="saledet.acc_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=saledet_price dbname="saledet.price" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene.scene_desc" )
 column=(type=datetime updatewhereclause=yes name=c_start dbname="c_start" )
 column=(type=datetime updatewhereclause=yes name=c_end dbname="c_end" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(8) updatewhereclause=yes name=c_text dbname="c_text" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_rlse_qty dbname="rlse_qty" )
 column=(type=char(30) updatewhereclause=yes name=sale_ship_flag dbname="ship_flag" )
 column=(type=char(10) updatewhereclause=yes name=color_color_name dbname="color_name" )
 column=(type=char(10) updatewhereclause=yes name=wc_work_name dbname="wc.work_name" )
 retrieve="  SELECT sale.cust_no         
       , customer.cust_name   
       , sale.scene_code      
       , sale.order_no        
       , sale.sale_flag       
       , sale.curr_code       
       , sale.order_date      
       , sale.cust_po_date    
       , sale.due_date        
       , saledet.seq_no       
       , saledet.item_no      
       , saledet.qa           
       , saledet.uom          
       , saledet.order_qty    
       , saledet.acc_qty      
       , saledet.price        
       , scene.scene_desc     
       , c_start    = convert(smalldatetime, :ad_start, 111)   
       , c_end      = convert(smalldatetime, :ad_end,   111)     
       , groupitem.item_name   
       , '        ' c_text     
       , rlse_qty   = isnull(saledet.rlse_qty,0)        
       , ship_flag  = dbo.uf_getshipflag(sale.ship_flag)   
       , color_name = isnull(color.color_name,'')       
       , wc.work_name
    FROM saledet 
         LEFT OUTER JOIN SALE      ON SALEDET.ORDER_NO = SALE.ORDER_NO
         LEFT OUTER JOIN CUSTOMER  ON SALE.CUST_NO     = CUSTOMER.CUST_NO
         LEFT OUTER JOIN COLOR     ON SALEDET.COLOR    = COLOR.COLOR_CODE
         LEFT OUTER JOIN SCENE     ON SALE.SCENE_CODE  = SCENE.SCENE_CODE
         LEFT OUTER JOIN GROUPITEM ON SALEDET.ITEM_NO  = GROUPITEM.ITEM_NO
         LEFT OUTER JOIN ROUT      ON SALEDET.ITEM_NO  = ROUT.ITEM_NO 
                                  AND SUBSTRING(SALEDET.QA,1,14) + '00000' = ROUT.QA
         LEFT OUTER JOIN WC        ON ROUT.WC_NO       = WC.WORK_NO
         
   WHERE ( sale.open_close        NOT IN ('X','C')        )    
     AND ( sale.cust_no          LIKE :as_cust            )    
     AND ( customer.salesman     LIKE :as_ret             )    
     AND ( sale.sale_flag          IN (:asa_sale_flag)    )    
     AND ( sale.order_date    BETWEEN :ad_start and :ad_end )  
     AND ( sale.confirm_flag       IN (:asa_confirm_flag) )    
     AND ( sale.order_no         LIKE :as_area            )    
     AND ( sale.ship_flag        LIKE :as_f               )    
     AND ( sale.salesman         LIKE :as_userid          )    
     AND ( :as_class = 'A' OR ( :as_class = 'P' AND  customer.credit_level IN ('D', 'E', 'F') )) 
     AND ( ROUT.OPERATION         = 1 OR ROUT.OPERATION  IS NULL )
" arguments=(("asa_sale_flag", stringlist),("ad_start", date),("ad_end", date),("asa_confirm_flag", stringlist),("as_area", string),("as_f", string),("as_cust", string),("as_ret", string),("as_class", string),("as_userid", string))  sort="cust_name A sale_scene_code A sale_order_date A sale_order_no A saledet_seq_no A " )
group(level=1 header.height=0 trailer.height=68 by=("cust_no" ) header.color="536870912" trailer.color="553648127" )
group(level=2 header.height=0 trailer.height=72 by=("sale_scene_code" ) header.color="536870912" trailer.color="553648127" )
