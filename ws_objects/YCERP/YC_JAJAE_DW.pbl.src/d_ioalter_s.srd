footer(height=68 color="8421504" )
detail(height=320 color="536870912" )
table(column=(type=datetime update=yes updatewhereclause=yes key=yes name=alter_time dbname="itemalter.alter_time" )
 column=(type=datetime update=yes updatewhereclause=yes name=alter_date dbname="itemalter.alter_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=src_item dbname="itemalter.src_item" )
 column=(type=char(20) update=yes updatewhereclause=yes name=src_qa dbname="itemalter.src_qa" )
 column=(type=char(10) update=yes updatewhereclause=yes name=src_loc dbname="itemalter.src_loc" )
 column=(type=char(17) update=yes updatewhereclause=yes name=order_no dbname="itemalter.order_no" )
 column=(type=long update=yes updatewhereclause=yes name=seq dbname="itemalter.seq" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=src_qty dbname="itemalter.src_qty" )
 column=(type=char(20) update=yes updatewhereclause=yes name=src_lot dbname="itemalter.src_lot" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=tar_item dbname="itemalter.tar_item" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=tar_qa dbname="itemalter.tar_qa" )
 column=(type=char(10) update=yes updatewhereclause=yes name=tar_loc dbname="itemalter.tar_loc" )
 column=(type=char(20) update=yes updatewhereclause=yes name=tar_lot dbname="itemalter.tar_lot" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=tar_qty dbname="itemalter.tar_qty" )
 column=(type=char(10) update=yes updatewhereclause=yes name=user_id dbname="itemalter.user_id" )
 column=(type=char(60) update=yes updatewhereclause=yes name=rem dbname="itemalter.rem" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(1) update=yes updatewhereclause=yes name=issue_flag dbname="itemalter.issue_flag" values="출고	Y/미출고	N/" )
 retrieve="  SELECT itemalter.alter_time    
       , itemalter.alter_date    
       , itemalter.src_item      
       , itemalter.src_qa        
       , itemalter.src_loc       
       , itemalter.order_no      
       , itemalter.seq           
       , itemalter.src_qty       
       , itemalter.src_lot       
       , itemalter.tar_item      
       , itemalter.tar_qa        
       , itemalter.tar_loc       
       , itemalter.tar_lot       
       , itemalter.tar_qty       
       , itemalter.user_id       
       , itemalter.rem           
       , groupitem_a.item_name   
       , groupitem_b.item_name   
       , itemalter.issue_flag    
  FROM itemalter left outer join groupitem groupitem_a on  itemalter.src_item  = groupitem_a.item_no
                             left outer join groupitem groupitem_b  on itemalter.tar_item  = groupitem_b.item_no
   WHERE ( 
                          ( itemalter.alter_time BETWEEN :ad_start AND :ad_end  + ' 23:59:59:999'  ) AND  
                         (itemalter.src_loc   LIKE :as_loc OR itemalter.tar_loc   LIKE :as_loc) 
                   )
/*
    FROM itemalter
       , groupitem groupitem_a
       , groupitem groupitem_b  
   WHERE ( itemalter.src_item     *= groupitem_a.item_no) 
     and ( itemalter.tar_item     *= groupitem_b.item_no) 
     and ( ( itemalter.alter_time BETWEEN :ad_start AND :ad_end  + ~" 23:59:59:999~"  ) AND  
           (itemalter.src_loc   LIKE :as_loc OR itemalter.tar_loc   LIKE :as_loc) 
         )
*/" update="itemalter" updatewhere=0 updatekeyinplace=no arguments=(("ad_start", date),("ad_end", date),("as_loc", string))  sort="alter_time A " )
