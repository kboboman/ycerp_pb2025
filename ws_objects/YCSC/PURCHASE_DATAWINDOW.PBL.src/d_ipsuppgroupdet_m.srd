 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"suppgroupdet~" )  TABLE(NAME=~"groupitem~" ) COLUMN(NAME=~"suppgroupdet.supp_no~") COLUMN(NAME=~"suppgroupdet.group_no~") COLUMN(NAME=~"suppgroupdet.item_no~") COLUMN(NAME=~"suppgroupdet.price~") COLUMN(NAME=~"groupitem.item_name~")    JOIN (LEFT=~"suppgroupdet.item_no~"    OP =~"=~"RIGHT=~"groupitem.item_no~" )WHERE(    EXP1 =~"suppgroupdet.supp_no~"   OP =~"=~"    EXP2 =~":as_supp~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"suppgroupdet.group_no~"   OP =~"=~"    EXP2 =~":as_group~" ) ) ARG(NAME = ~"as_supp~" TYPE = string)  ARG(NAME = ~"as_group~" TYPE = string) " update="suppgroupdet" updatewhere=0 updatekeyinplace=no arguments=(("as_supp", string),("as_group", string)) )
