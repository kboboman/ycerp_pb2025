table(column=(type=char(17) update=yes updatewhereclause=yes name=order_no dbname="sfcuse.order_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=wc_no dbname="sfcuse.wc_no" )
 column=(type=datetime update=yes updatewhereclause=yes name=use_date dbname="sfcuse.use_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="sfcuse.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="sfcuse.qa" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="sfcuse.uom" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=use_qty dbname="sfcuse.use_qty" )
 column=(type=char(20) update=yes updatewhereclause=yes name=coil_no dbname="sfcuse.coil_no" )
 column=(type=char(4) update=yes updatewhereclause=yes name=color dbname="sfcuse.color" )
 column=(type=char(4) update=yes updatewhereclause=yes name=color_type dbname="sfcuse.color_type" )
 column=(type=char(10) updatewhereclause=yes name=color_color_name dbname="color.color_name" )
 column=(type=decimal(4) updatewhereclause=yes name=sfcuse_cnt dbname="cnt" initial=" " )
 column=(type=decimal(4) updatewhereclause=yes name=sfcuse_unit_qty dbname="sfcuse.unit_qty" initial=" " )
 column=(type=decimal(4) updatewhereclause=yes name=sfcuse_mod_qty dbname="sfcuse.mod_qty" initial=" " )
 column=(type=decimal(4) updatewhereclause=yes name=sfcuse_mod_len dbname="sfcuse.mod_len" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" initial=" " )
 column=(type=char(10) updatewhereclause=yes name=wc_work_name dbname="wc.work_name" )
 column=(type=char(10) updatewhereclause=yes name=sfcuse_area_no dbname="sfcuse.area_no" )
 retrieve="  SELECT sfcuse.order_no       
       , sfcuse.wc_no          
       , sfcuse.use_date       
       , sfcuse.item_no        
       , sfcuse.qa             
       , sfcuse.uom            
       , sfcuse.use_qty        
       , sfcuse.coil_no        
       , sfcuse.color          
       , sfcuse.color_type     
       , color.color_name      
       , SUM( case when sfcuse.cnt  = 0 then sfcuse.use_qty else sfcuse.cnt end ) cnt /* 2018.05.23 jowonsuk 없으면 사용수량으로 사용 */
       , sfcuse.unit_qty       
       , sfcuse.mod_qty        
       , sfcuse.mod_len        
       , groupitem.item_name   
       , wc.work_name  
       , sfcuse.area_no 
    FROM sfcuse  left outer join color  on sfcuse.color = color.color_code
       				   inner join groupitem   on sfcuse.item_no = groupitem.item_no 
					   inner join wc on sfcuse.wc_no            = wc.work_no
   WHERE ( ( sfcuse.wc_no LIKE (CASE WHEN :AS_WC = '%' THEN '%' ELSE :AS_WC+'%' END)  )
       AND    ( convert(char(10),sfcuse.use_date,111)  BETWEEN :ad_start AND :ad_end )
       AND    ( RTRIM(sfcuse.area_no)     LIKE :as_area ) 
         )  
GROUP BY sfcuse.order_no       
       , sfcuse.wc_no          
       , sfcuse.use_date       
       , sfcuse.item_no        
       , sfcuse.qa             
       , sfcuse.uom            
       , sfcuse.use_qty        
       , sfcuse.coil_no        
       , sfcuse.color          
       , sfcuse.color_type     
       , color.color_name      
       , sfcuse.unit_qty       
       , sfcuse.mod_qty        
       , sfcuse.mod_len        
       , groupitem.item_name   
       , wc.work_name  
       , sfcuse.area_no   

/*SELECT sfcuse.order_no       
       , sfcuse.wc_no          
       , sfcuse.use_date       
       , sfcuse.item_no        
       , sfcuse.qa             
       , sfcuse.uom            
       , sfcuse.use_qty        
       , sfcuse.coil_no        
       , sfcuse.color          
       , sfcuse.color_type     
       , color.color_name      
       , ( case when sfcuse.cnt  = 0 then sfcuse.use_qty else sfcuse.cnt end ) cnt /* 2018.05.23 jowonsuk 없으면 사용수량으로 사용 */
       , sfcuse.unit_qty       
       , sfcuse.mod_qty        
       , sfcuse.mod_len        
       , groupitem.item_name   
       , wc.work_name  
    FROM sfcuse  left outer join color  on sfcuse.color = color.color_code
       				   inner join groupitem   on sfcuse.item_no = groupitem.item_no 
					   inner join wc on sfcuse.wc_no            = wc.work_no
   WHERE ( ( sfcuse.wc_no LIKE (CASE WHEN :AS_WC = '%' THEN '%' ELSE :AS_WC+'%' END)  )
       AND    ( convert(char(10),sfcuse.use_date,111)  BETWEEN :ad_start AND :ad_end )
       AND    ( sfcuse.area_no     LIKE :as_area ) 
         )   
*/
/*
    FROM sfcuse      
       , color       
       , groupitem   
       , wc  
   WHERE ( sfcuse.color           *= color.color_code     ) 
     AND ( sfcuse.item_no          = groupitem.item_no    ) 
     AND ( sfcuse.wc_no            = wc.work_no           ) 
/*     AND (( wc.work_name       LIKE ltrim(:as_wc + '%')   ) AND  */
	  AND ( ( sfcuse.wc_no LIKE (CASE WHEN :AS_WC = '%' THEN '%' ELSE :AS_WC+'%' END)  )
       AND    ( convert(char(10),sfcuse.use_date,111)  BETWEEN :ad_start AND :ad_end )
       AND    ( sfcuse.area_no     LIKE :as_area ) 
         )   
*/" arguments=(("as_area", string),("as_wc", string),("ad_start", string),("ad_end", string))  sort="wc_no A item_no A qa A order_no A " )
