$PBExportComments$구매발주관리(1998/02/10,곽용덕)
release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=780 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=order_no dbname="pur.order_no" initial=" " )
 column=(type=char(10) update=yes updatewhereclause=yes name=supp_no dbname="pur.supp_no" initial=" " )
 column=(type=char(80) update=yes updatewhereclause=yes name=shipto_addr dbname="pur.shipto_addr" initial=" " )
 column=(type=char(3) update=yes updatewhereclause=yes name=curr_code dbname="pur.curr_code" initial="WON" )
 column=(type=datetime update=yes updatewhereclause=yes name=order_date dbname="pur.order_date" initial=" " )
 column=(type=char(10) update=yes updatewhereclause=yes name=buyer dbname="pur.buyer" initial=" " )
 column=(type=long update=yes updatewhereclause=yes name=terms dbname="pur.terms" initial=" " )
 column=(type=char(10) update=yes updatewhereclause=yes name=fob dbname="pur.fob" initial="현금" values="어음	어음/현금	현금/" )
 column=(type=long update=yes updatewhereclause=yes name=revision_no dbname="pur.revision_no" initial="0 " )
 column=(type=datetime update=yes updatewhereclause=yes name=revision_date dbname="pur.revision_date" initial=" " )
 column=(type=char(1) update=yes updatewhereclause=yes name=po_print dbname="pur.po_print" initial="N" values="Yes	Y/No	N/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=open_close dbname="pur.open_close" initial="O" values="Open	O/Close	C/" )
 column=(type=datetime update=yes updatewhereclause=yes name=close_date dbname="pur.close_date" initial=" " )
 column=(type=char(1) update=yes updatewhereclause=yes name=close_type dbname="pur.close_type" initial=" " )
 column=(type=char(1) update=yes updatewhereclause=yes name=subcon dbname="pur.subcon" values="구매	N/외주구매	Y/자재가공	J/외주가공	P/외주스리팅//SHEET	C/수입	L/" )
 column=(type=char(100) update=yes updatewhereclause=yes name=rem dbname="pur.rem" )
 column=(type=char(1) update=yes updatewhereclause=yes name=pur_tax_sign dbname="pur.tax_sign" initial="Y" values="	Y/	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=cyber dbname="pur.cyber" initial="N" values="일반	N/Cyber	C/" )
 column=(type=char(10) update=yes updatewhereclause=yes name=area_no dbname="pur.area_no" )
 column=(type=char(15) update=yes updatewhereclause=yes name=shipto_tel dbname="pur.shipto_tel" )
 column=(type=char(255) update=yes updatewhereclause=yes name=cham dbname="pur.cham" )
 retrieve="  SELECT pur.order_no,   
         pur.supp_no,   
         pur.shipto_addr,   
         pur.curr_code,   
         pur.order_date,   
         pur.buyer,   
         pur.terms,   
         pur.fob,   
         pur.revision_no,   
         pur.revision_date,   
         pur.po_print,   
         pur.open_close,   
         pur.close_date,   
         pur.close_type,   
         pur.subcon,   
         pur.rem,   
         pur.tax_sign,   
         pur.cyber,   
         pur.area_no,  
			pur.shipto_tel,
			pur.cham
    FROM pur  
   WHERE pur.order_no = :as_order    
" update="pur" updatewhere=1 updatekeyinplace=no arguments=(("as_order", string)) )
