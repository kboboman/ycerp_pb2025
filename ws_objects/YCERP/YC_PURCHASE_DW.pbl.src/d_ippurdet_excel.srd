 column=(type=decimal(4) updatewhereclause=yes name=purdet_com_qty dbname="com_qty" )
 column=(type=char(14) updatewhereclause=yes name=purdet_sale_no dbname="sale_no" )
 column=(type=long updatewhereclause=yes name=purdet_sale_seq dbname="sale_seq" )
 column=(type=char(50) updatewhereclause=yes name=purdet_cust_name dbname="cust_name" )
 column=(type=char(50) updatewhereclause=yes name=purdet_sale_rem dbname="sale_rem" )
 column=(type=char(10) updatewhereclause=yes name=purdet_color dbname="color" )
 column=(type=decimal(4) updatewhereclause=yes name=purdet_unit_qty dbname="unit_qty" )
 column=(type=char(20) updatewhereclause=yes name=purdet_draw_no dbname="draw_no" )
 column=(type=char(2) updatewhereclause=yes name=purdet_com_uom dbname="com_uom" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=decimal(4) updatewhereclause=yes name=cprice dbname="cprice" )
 column=(type=decimal(6) updatewhereclause=yes name=yrate dbname="yrate" )
 column=(type=decimal(8) updatewhereclause=yes name=amt dbname="amt" )
 column=(type=char(1) updatewhereclause=yes name=pur_po_print dbname="po_print" )
 column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" )
 column=(type=char(80) updatewhereclause=yes name=supply_addr dbname="supply_addr" )
 column=(type=char(15) updatewhereclause=yes name=supply_tel dbname="supply_tel" )
 column=(type=char(255) updatewhereclause=yes name=cham dbname="cham" )
 column=(type=char(12) updatewhereclause=yes name=register_no dbname="register_no" )
 retrieve="  SELECT order_no    = purdet.order_no   
       , seq_no      = purdet.seq_no   
       , item_no     = purdet.item_no   
       , qa          = purdet.qa   
       , due_date    = purdet.due_date   
       , order_qty   = purdet.order_qty   
       , rlse_date   = purdet.rlse_date   
       , price       = purdet.price   
       , uom         = purdet.uom   
       , rlse_qty    = purdet.rlse_qty   
       , product_no  = purdet.product_no   
       , rcpt_loc    = purdet.rcpt_loc   
       , pur_type    = purdet.pur_type   
       , rem         = purdet.rem   
       , coil_no     = purdet.coil_no   
       , serial_no   = purdet.serial_no   
       , work_type   = purdet.work_type   
       , cnt         = purdet.cnt   
       , result_type = purdet.result_type   
       , com_qty     = purdet.com_qty   
       , sale_no     = purdet.sale_no   
       , sale_seq    = purdet.sale_seq   
       , cust_name   = purdet.cust_name   
       , sale_rem    = purdet.sale_rem   
       , color       = (SELECT color_name FROM color WHERE color_code = purdet.color)
       , unit_qty    = purdet.unit_qty   
       , draw_no     = purdet.draw_no   
       , com_uom     = purdet.com_uom   
       , item_name   = groupitem.item_name   
       , cprice      = 00000000.0000
       , yrate       = 00.000000
       , amt         = (case when supp.round = 'Y' then round(purdet.com_qty * purdet.price, 0) else round(purdet.com_qty * purdet.price, 0, 1) end)   
       , po_print    = pur.po_print  
       , chk         = 'N'
       , supply_addr = pur.supply_addr
       , supply_tel  = pur.supply_tel
       , cham        = replace(pur.cham,char(10),'^')
       , register_no = supp.register_no
    FROM purdet   
       , groupitem   
       , pur   
       , supp  
   WHERE ( purdet.item_no    = groupitem.item_no )   
     AND ( purdet.order_no   = pur.order_no      )   
     AND ( pur.supp_no       = supp.supp_no      )   
     AND ( purdet.order_no   = :as_orderno       )   
" arguments=(("as_orderno", string)) )
