$PBExportComments$담당자별item실사재고추가(2001/10/08,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=item_no dbname="incounu.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="incounu.qa" )
 column=(type=decimal(4) updatewhereclause=yes name=eom_qoh dbname="eom_qoh" )
 column=(type=char(2) updatewhereclause=yes name=groupitem_uom dbname="GroupItem.uom" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 retrieve="  SELECT incounu.item_no,   
         incounu.qa,   
         eom_qoh = isnull(itemloc.qoh, 0) - isnull(cday.rcpt, 0) + isnull(cday.issue, 0),  
         groupitem.uom,   
         groupitem.item_name  
    FROM incounu with(nolock) inner join groupitem with(nolock) on  incounu.item_no = groupitem.item_no
                                      left outer join    (
                                                                              select item_no, qa, rcpt = sum(rcpt_qty), issue = sum(issue_qty) 
                                                                                  from ineoday with(nolock)
                                                                      			  where cdate > rtrim(:as_year) + rtrim(:as_mon) + '99'
                                                                      			    and loc_no = :as_loc 
                                                                      				group by item_no, qa
                                                                 ) cday  on incounu.item_no = cday.item_no and incounu.qa = cday.qa
                                      inner join item with(nolock) on incounu.item_no = item.item_no and incounu.qa = item.qa
                                      left outer join itemloc with(nolock) on    incounu.item_no = itemloc.item_no and   incounu.qa = itemloc.qa and incounu.loc_no = itemloc.loc_no
where    ( groupitem.use_flag <> 'C') and  
              ( item.use_flag <> 'C') and  
              ( ( incounu.user_id like :as_user ) AND  
              ( incounu.loc_no = :as_loc ) )    
/*
    FROM incounu,   
         groupitem ,   
         item ,   
         itemloc ,   
         (select item_no, qa, rcpt = sum(rcpt_qty), issue = sum(issue_qty) from ineoday
			  where cdate > rtrim(:as_year) + rtrim(:as_mon) + '99'
			    and loc_no = :as_loc 
				group by item_no, qa) cday 
   WHERE ( incounu.item_no = groupitem.item_no ) and  
         ( incounu.item_no *= cday.item_no) and  
         ( incounu.qa *= cday.qa) and  
         ( incounu.item_no = item.item_no) and  
         ( incounu.qa = item.qa) and  
         ( groupitem.use_flag <> 'C') and  
         ( item.use_flag <> 'C') and  
         ( incounu.item_no *= itemloc.item_no) and  
         ( incounu.qa *= itemloc.qa) and  
         ( incounu.loc_no *= itemloc.loc_no) and  
         ( ( incounu.user_id like :as_user ) AND  
         ( incounu.loc_no = :as_loc ) )    
*/" arguments=(("as_year", string),("as_mon", string),("as_user", string),("as_loc", string))  sort="groupitem_item_name A qa A " )
