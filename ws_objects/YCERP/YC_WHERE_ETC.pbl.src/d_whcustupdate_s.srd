$PBExportComments$거래처변경(출고번호)(2005/01/14, 이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" values="	Y/	N/	0" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="do.cust_no" )
 column=(type=char(14) updatewhereclause=yes key=yes name=do_no dbname="do.do_no" )
 column=(type=datetime updatewhereclause=yes name=do_date dbname="do.do_date" )
 column=(type=char(4) updatewhereclause=yes name=tcust_no dbname="do.tcust_no" )
 column=(type=char(11) updatewhereclause=yes name=tspot_code dbname="do.tspot_code" )
 column=(type=char(1) updatewhereclause=yes name=invoice_print dbname="do.invoice_print" )
 column=(type=char(1) updatewhereclause=yes name=apply_end dbname="do.apply_end" )
 retrieve="SELECT chk = 'N'
     , do.cust_no
     , do.do_no 
     , do.do_date
     , a.tcust_no
     , a.tspot_code
     , do.invoice_print
     , a.apply_end
  FROM do
       LEFT OUTER JOIN (
            SELECT a.fcust_no, b.scene_code, a.tcust_no, a.tspot_code, b.do_no, a.apply_end
              FROM dotrans a
                   LEFT OUTER JOIN dotransdet b ON a.trans_no = b.trans_no
             WHERE a.apply_end  = 'Y'
               AND a.fcust_no   = :as_cust
               AND (( :as_flag = 'C' and a.fcust_no = :as_cust ) OR
                    ( :as_flag = 'S' and a.fcust_no = :as_cust and b.scene_code = :as_scene ) 
                   )
       ) A on do.do_no = a.do_no
 WHERE do.invoice_print = 'N' 
   AND (( :as_flag = 'C' and cust_no = :as_cust ) OR
        ( :as_flag = 'S' and cust_no = :as_cust and spot_code = :as_scene ) 
       )
   AND ( a.apply_end = 'Y' )

/*
SELECT do_no 
  FROM do
 WHERE invoice_print = 'N' 
   AND (( :as_flag = 'C' and cust_no = :as_cust ) OR
        ( :as_flag = 'S' and cust_no = :as_cust and spot_code = :as_scene ) 
       ) 
*/
" update="do" updatewhere=0 updatekeyinplace=no arguments=(("as_flag", string),("as_cust", string),("as_scene", string))  sort="do_no A " )
