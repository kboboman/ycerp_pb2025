 column=(type=char(50) update=yes updatewhereclause=yes name=etc dbname="SSceneDET.etc" )
 retrieve="  SELECT SSceneDET.scene_code,   
         SSceneDET.sc_no,   
         SSceneDET.construct,   
         SSceneDET.sale_primary,   
         SSceneDET.sale_second,   
         SSceneDET.site_manager,   
         SSceneDET.site_official,   
         SSceneDET.site_phone,   
         SSceneDET.site_mobile,   
         SSceneDET.etc  
    FROM SSceneDET  
   WHERE SSceneDET.scene_code = :as_scene    
 " update="SSceneDET" updatewhere=1 updatekeyinplace=no arguments=(("as_scene", string))  sort="scene_code A sc_no A " )
