 retrieve="  SELECT qcsfcday3.area_no,   
         qcsfcday3.sfc_date,   
         qcsfcday3.wc_no,   
         qcsfcday3.item_no,   
         qcsfcday3.item_name,   
         qcsfcday3.qc_date,   
         qcsfcday3.qc_code,   
         qcsfcday3.qc_user,   
         qcsfcday3.length_x1,   
         qcsfcday3.length_x2,   
         qcsfcday3.length_x3,   
         qcsfcday3.length_x4,   
         qcsfcday3.length_x5,   
         qcsfcday3.width1_x1,   
         qcsfcday3.width1_x2,   
         qcsfcday3.width1_x3,   
         qcsfcday3.width1_x4,   
         qcsfcday3.width1_x5,   
         qcsfcday3.width2_x1,   
         qcsfcday3.width2_x2,   
         qcsfcday3.width2_x3,   
         qcsfcday3.width2_x4,   
         qcsfcday3.width2_x5,   
         qcsfcday3.height1_x1,   
         qcsfcday3.height1_x2,   
         qcsfcday3.height1_x3,   
         qcsfcday3.height1_x4,   
         qcsfcday3.height1_x5,   
         qcsfcday3.height2_x1,   
         qcsfcday3.height2_x2,   
         qcsfcday3.height2_x3,   
         qcsfcday3.height2_x4,   
         qcsfcday3.height2_x5, 
		wname
FROM qcsfcday3 with(nolock) left outer join  qcsfcchk with(nolock) on qcsfcday3.area_no = qcsfcchk.area_no
                                                                                                             AND qcsfcday3.wc_no = qcsfcchk.wc_no
                                                                                                             AND qcsfcday3.sfc_date = qcsfcchk.sfc_date 
   WHERE ( qcsfcday3.area_no = :as_area ) AND  
         ( qcsfcday3.wc_no = :as_wc ) AND  
         ( qcsfcday3.sfc_date = :ad_date )" arguments=(("as_area", string),("as_wc", string),("ad_date", date)) )
