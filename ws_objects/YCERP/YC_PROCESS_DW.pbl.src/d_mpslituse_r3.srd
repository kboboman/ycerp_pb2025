$PBExportHeader$d_mpslituse_r3.srd
$PBExportComments$스리팅코일사용현황조회(판매)(2001/05/08,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=400 color="536870912" )
summary(height=84 color="536870912" )
footer(height=0 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=datetime updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=datetime updatewhereclause=yes name=edate dbname="edate" )
 column=(type=datetime updatewhereclause=yes name=do_do_date dbname="do_date" )
 column=(type=char(20) updatewhereclause=yes name=dodet_qa dbname="qa" )
 column=(type=char(20) updatewhereclause=yes name=dodet_coil_no dbname="coil_no" )
 column=(type=decimal(2) updatewhereclause=yes name=dodet_cnt dbname="cnt" )
 column=(type=char(14) updatewhereclause=yes name=do_no dbname="do_no" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="cust_name" )
 column=(type=decimal(4) updatewhereclause=yes name=coilmst_unit_qty dbname="unit_qty" )
 column=(type=char(2) updatewhereclause=yes name=coilmst_etc_no dbname="etc_no" )
 column=(type=char(1) updatewhereclause=yes name=as_flag dbname="as_flag" )
 retrieve="  SELECT groupitem.item_name                              
       , sdate    = convert(smalldatetime, :ad_start, 111)   
       , edate    = convert(smalldatetime, :ad_end, 111)     
       , do.do_date                                       
       , dodet.qa                                         
       , dodet.coil_no                                    
       , cnt      = (dodet.ship_qty)
       , dodet.do_no
       , customer.cust_name                            
       , coilsheet.unit_qty                                 
       , coilsheet.etc_no  
       , as_flag  = :as_flag
   FROM dodet left outer join groupitem on dodet.item_no = groupitem.item_no
					inner join do on dodet.do_no = do.do_no
					inner join  customer  on do.cust_no = customer.cust_no
					inner join   (
										SELECT loc_no, coil_no,  unit_qty, etc_no, flag  FROM coilmst
										UNION
										SELECT loc_no, sheet_no, unit_qty, '',     flag  FROM sheetmst         
							 	  ) coilsheet on dodet.coil_no         = coilsheet.coil_no and dodet.loc_no          = coilsheet.loc_no                    
/*
   WHERE ( dodet.item_no        *= groupitem.item_no )   
     AND ( dodet.do_no           = do.do_no          )   
     AND ( dodet.coil_no         = coilsheet.coil_no )   
     AND ( dodet.loc_no          = coilsheet.loc_no  )   
     AND ( do.cust_no            = customer.cust_no  )   
     AND ((:as_area    = '%'   AND do.area_no   LIKE '%' ) or 
          (:as_area   <> '%'   AND do.area_no      = :as_area )
         )
     AND ( ( do.do_date    BETWEEN :ad_start AND :ad_end ) AND  
           ( coilsheet.flag      = :as_flag              ) AND  
           ( dodet.coil_no  IS NOT NULL                  ) 
         )    
*/" arguments=(("as_area", string),("ad_start", date),("ad_end", date),("as_flag", string))  sort="do_do_date A groupitem_item_name A mid(dodet_qa, 5, 6) A dodet_qa A " )
group(level=1 header.height=68 trailer.height=72 by=("do_do_date" ) header.color="536870912" trailer.color="536870912" )
group(level=2 header.height=0 trailer.height=76 by=("groupitem_item_name" ) header.color="536870912" trailer.color="536870912" )
