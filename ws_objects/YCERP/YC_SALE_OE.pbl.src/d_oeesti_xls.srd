datawindow(units=0 timer_interval=0 color=79741120 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="553648127" )
footer(height=0 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=estimate_head_cust_no dbname="estimate_head.cust_no" )
 column=(type=char(11) updatewhereclause=yes name=estimate_head_scene_code dbname="estimate_head.scene_code" )
 column=(type=datetime updatewhereclause=yes name=estimate_head_estimate_date dbname="estimate_head.estimate_date" )
 column=(type=char(60) updatewhereclause=yes name=cust_name dbname="estimate_head.cust_name" )
 column=(type=char(60) updatewhereclause=yes name=scene_desc dbname="estimate_head.scene_desc" )
 column=(type=char(1) updatewhereclause=yes name=estimate_head_esti_case dbname="estimate_head.esti_case" )
 column=(type=char(1) updatewhereclause=yes name=estimate_head_sale_succ dbname="estimate_head.sale_succ" )
 column=(type=char(10) updatewhereclause=yes name=estimate_head_emp_no dbname="estimate_head.emp_no" )
 column=(type=decimal(4) updatewhereclause=yes name=esti_amount dbname="estimate_head.esti_amount" )
 column=(type=decimal(4) updatewhereclause=yes name=esti_tax dbname="estimate_head.esti_tax" )
 column=(type=decimal(4) updatewhereclause=yes name=esti_total dbname="estimate_head.esti_total" )
 column=(type=char(60) updatewhereclause=yes name=estimate_head_rem dbname="estimate_head.rem" )
 column=(type=char(1) updatewhereclause=yes name=estimate_head_vat_flag dbname="estimate_head.vat_flag" )
 column=(type=char(14) updatewhereclause=yes name=estimate_no dbname="estimate_det.estimate_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="estimate_det.seq_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="estimate_det.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="estimate_det.qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="estimate_det.uom" )
 column=(type=decimal(3) updatewhereclause=yes name=order_qty dbname="estimate_det.order_qty" initial="0" )
 column=(type=decimal(2) updatewhereclause=yes name=acc_qty dbname="estimate_det.acc_qty" initial="0" )
 column=(type=decimal(4) updatewhereclause=yes name=unit_cost dbname="estimate_det.unit_cost" initial="0" )
 column=(type=decimal(4) updatewhereclause=yes name=item_amt dbname="estimate_det.item_amt" initial="0" )
 column=(type=char(30) updatewhereclause=yes name=rem dbname="estimate_det.rem" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="GroupItem.item_name" )
 retrieve="  SELECT estimate_head.cust_no,   
         estimate_head.scene_code,   
         estimate_head.estimate_date,   
         estimate_head.cust_name,   
         estimate_head.scene_desc,   
         estimate_head.esti_case,   
         estimate_head.sale_succ,  
         estimate_head.emp_no,   
         estimate_head.esti_amount,   
         estimate_head.esti_tax,   
         estimate_head.esti_total,   
         estimate_head.rem,   
         estimate_head.vat_flag,   
         estimate_det.estimate_no,   
         estimate_det.seq_no,   
         estimate_det.item_no,   
         estimate_det.qa,   
         estimate_det.uom,   
         estimate_det.order_qty,   
         estimate_det.acc_qty,   
         estimate_det.unit_cost,   
         estimate_det.item_amt,   
         estimate_det.rem,   
         groupitem.item_name
	from estimate_det inner join estimate_head on estimate_det.estimate_no = estimate_head.estimate_no
					 	    left outer join groupitem on  estimate_det.item_no = groupitem.item_no
    where ( estimate_det.estimate_no  = :est_no  )    
/*
    FROM estimate_det
       , estimate_head  
       , groupitem  
   WHERE ( estimate_det.estimate_no *= estimate_head.estimate_no)
     and ( estimate_det.item_no     *= groupitem.item_no        ) 
     and ( estimate_det.estimate_no  = :est_no                  )    

*/
" arguments=(("est_no", string))  sort="seq_no A " )
