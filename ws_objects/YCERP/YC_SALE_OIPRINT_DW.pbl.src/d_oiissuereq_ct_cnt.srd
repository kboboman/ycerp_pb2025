$PBExportHeader$d_oiissuereq_ct_cnt.srd
$PBExportComments$출고의뢰 집계건수
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no  crosstab.dynamic = yes grid.lines=0 grid.columnmove=no selected.mouse=no )
header[1](height=0 color="536870912" )
header[2](height=68 color="15780518" )
summary(height=0 color="553648127" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=wan_nm dbname="wan_nm" )
 column=(type=char(20) updatewhereclause=yes name=schedule_name dbname="schedule_name" )
 column=(type=number updatewhereclause=yes name=scene_cnt dbname="scene_cnt" )
 retrieve="  SELECT wan_nm         = a.wan_nm
       , schedule_name  = a.schedule_name
       , accept_name    = (case a.accept_name 
                                when '시화' then '1.'
                                when '화곡' then '2.'
                                when '동부' then '3.'
                                when '대전' then '4.'
                                when '화성' then '5.'
                           end) + a.accept_name
       , scene_cnt      = count(*)     
    FROM ( /* 출고건수 */
         SELECT DISTINCT 
                wan_nm         = (case when left(c.scene_desc,2) IN ('서울','인천','경기','해외')
                                            AND a.issue_schedule IN ('A','B','J','I') then '1.수도권'
                                       when left(c.scene_desc,2) NOT IN ('서울','인천','경기','해외')
                                            AND a.issue_schedule IN ('A','B','J','I') then '2.지방'
                                       when a.issue_schedule     IN ('F','E')         then '3.외주'
                                       when a.issue_schedule     IN ('K')             then '4.택배'
                                       when a.issue_schedule     IN ('D')             then '5.방문'
                                       when a.issue_schedule     IN ('G','C')         then '6.기타'
                                  end)
              , schedule_name  = (case a.issue_schedule              
                                       when 'A' then '직출'          
                                       when 'B' then '생산후직출'    
                                       when 'C' then '자동작성'      
                                       when 'D' then '방문'          
                                       when 'E' then '외주(시화)'    
                                       when 'F' then '외주(본사)'    
                                       when 'G' then '유창강건'      
                                       when 'H' then '지점이송'      
                                       when 'I' then '야간도착'      
                                       when 'J' then '저녁상차'      
                                       when 'K' then '택배/정기'     
                                       else           ''             
                                  end)                               
              , accept_name = replace(e.loc_name,'저장소','')
              , cust_no     = c.cust_no
              , scene_code  = c.scene_code
           FROM issuereq   D with (nolock)                                                            
                LEFT OUTER JOIN issuereqdet   A with (nolock)
                  ON d.req_date  = a.req_date AND d.salesman  = a.salesman AND d.req_seq = a.req_seq
                LEFT OUTER JOIN issuereqdet_sale I with (nolock)
                  ON a.req_date  = i.req_date AND a.salesman  = d.salesman AND a.req_seq = i.req_seq AND a.seq = i.seq
                LEFT OUTER JOIN saledet  b ON a.sale_no     = b.order_no
                LEFT OUTER JOIN sale     f ON a.sale_no     = f.order_no
                LEFT OUTER JOIN customer g ON a.cust_no     = g.cust_no
                LEFT OUTER JOIN scene    c ON a.scene_code  = c.scene_code
                LEFT OUTER JOIN location e ON d.accept_user = e.loc_manager
          WHERE a.req_date        = :as_reqdate + ' 00:00:00'
            AND a.req_flag        = 'A'    /* 출고의뢰 */
            AND a.issue_schedule <> 'H'    /* 지점이송 */
            AND d.confirm_flag    = 'Y'    /* 확정 */
            AND ((:as_inside  = 'N') OR
                 (:as_inside <> 'N') AND (g.salesman <> 'killby')
                )                               
        ) A
    GROUP BY a.wan_nm, a.schedule_name, a.accept_name
" arguments=(("as_reqdate", string),("as_inside", string))  sort="wan_nm A schedule_name A " )
group(level=1 header.height=0 trailer.height=80 by=("wan_nm" ) header.color="536870912" trailer.color="12639424" )
