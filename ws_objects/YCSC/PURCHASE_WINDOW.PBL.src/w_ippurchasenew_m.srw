type cb_26 from commandbutton within tabpage_1
integer x = 1202
integer y = 12
integer width = 512
integer height = 80
integer taborder = 150
integer textsize = -10
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "도면번호 매칭"
end type

event clicked;// 도면번호 매칭
long   ll_row, ll_cnt
string ls_po_print, ls_suppno, ls_drawno, ls_drawtemp, ls_itemno, ls_qa13

debugbreak()
ls_suppno   = dw_1.object.supp_no[1]	// 구매처
SELECT count(*) INTO :ll_cnt FROM suppdraw WHERE supp_no = :ls_suppno;
if ll_cnt < 1 then
	MessageBox("확인","해당하는 구매처의 도면번호가 등록되어 있지 않습니다.~r~r(기준정보->구매처별 도면관리)")
	RETURN
end if

ll_cnt = 0		// Clear
ls_po_print = dw_1.object.po_print[1]	// 발주번호 확정

for ll_row = 1 to dw_3.rowcount()
	ls_itemno = dw_3.object.item_no[ll_row]
	ls_qa13   = LeftA(dw_3.object.qa[ll_row],13)
	ls_drawno = dw_3.object.draw_no[ll_row]
	
	if isnull(ls_drawno) or ls_drawno = "" then	// 신규등록
		SELECT draw_no INTO :ls_drawtemp 
		  FROM suppdrawdet 
		 WHERE supp_no = :ls_suppno AND item_no = :ls_itemno AND qa = :ls_qa13;
	else														// 등록분 확인
		SELECT draw_no INTO :ls_drawtemp 
		  FROM suppdrawdet 
		 WHERE supp_no = :ls_suppno AND draw_no = :ls_drawno AND item_no = :ls_itemno AND qa = :ls_qa13;
	end if

	if isnull(ls_drawtemp) or ls_drawtemp = "" then		// 미등록
	else
		if ls_po_print = "Y" then	// 확정분
			if dw_3.object.draw_no[ll_row] = ls_drawtemp then	// 체크
			else
				ll_cnt = ll_cnt + 1										// 매칭오류
			end if
		else								// 미확정
			dw_3.object.draw_no[ll_row] = ls_drawtemp		// 등록된 도면번호 적용
			wf_calc( ll_row )
		end if
	end if
next

if ll_cnt > 0 then
	MessageBox("확인", string(ll_cnt) + " 건이 매칭오류 입니다.")
end if

end event

