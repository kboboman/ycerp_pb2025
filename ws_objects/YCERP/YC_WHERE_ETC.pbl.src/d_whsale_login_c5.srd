detail(height=68 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=user_id dbname="login.user_id" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="login.user_name" )
 column=(type=char(5) updatewhereclause=yes name=team_code dbname="login.team_code" )
 column=(type=char(30) updatewhereclause=yes name=team_team_name dbname="team.team_name" )
 retrieve="  SELECT login.user_id
       , login.user_name
       , login.team_code
       , team.team_name 
    FROM login, TEAM
   WHERE login.team_code  = team.team_code
   AND LOGIN.use_flag = 'Y'
   and ( team.team_code in ('74000', '77000', '78000') or team.team_code like '9%' or login.user_name in ( '박수진', '한미란') )
   order by team.team_code asc

"  sort="team_code A user_name A " )
