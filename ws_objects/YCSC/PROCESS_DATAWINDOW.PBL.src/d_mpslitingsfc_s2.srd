detail(height=72 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=order_no dbname="order_no" )
 column=(type=number updatewhereclause=yes name=order_seq dbname="order_seq" )
 column=(type=char(20) updatewhereclause=yes name=coil_no dbname="coil_no" )
 column=(type=char(20) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=number updatewhereclause=yes name=thin dbname="thin" )
 column=(type=number updatewhereclause=yes name=wid dbname="wid" )
 column=(type=number updatewhereclause=yes name=wlen dbname="wlen" )
 column=(type=number updatewhereclause=yes name=length dbname="length" )
 column=(type=number updatewhereclause=yes name=swid dbname="swid" )
 column=(type=number updatewhereclause=yes name=val dbname="val" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"coilmst~" )  TABLE(NAME=~"coilorder~" )  TABLE(NAME=~"coilorderdet~" )  TABLE(NAME=~"coilsliting~" )  TABLE(NAME=~"groupitem~" ) COLUMN(NAME=~"coilorder.order_no~") COLUMN(NAME=~"coilorderdet.order_seq~") COLUMN(NAME=~"coilorderdet.coil_no~") COLUMN(NAME=~"groupitem.item_name~") COLUMN(NAME=~"coilorderdet.wid~") COLUMN(NAME=~"coilsliting.seq~") COLUMN(NAME=~"coilsliting.cnt~") COLUMN(NAME=~"coilsliting.length~") COMPUTE(NAME=~"wlen = coilmst.unit_qty * coilmst.qcnt~") COMPUTE(NAME=~"thin = convert (decimal (3,2), substring(coilmst.qa,1,1) + ~~~".~~~" + substring(coilmst.qa, 2,2))~") COMPUTE(NAME=~"swid = convert (decimal (5,1), substring(coilsliting.qa,5,4) + ~~~".~~~" + substring(coilsliting.qa, 10,1))~")    JOIN (LEFT=~"coilorderdet.order_no~"    OP =~"=~"RIGHT=~"coilsliting.order_no~" )    JOIN (LEFT=~"coilorder.order_no~"    OP =~"=~"RIGHT=~"coilorderdet.coilorder_order~" )    JOIN (LEFT=~"coilorderdet.coil_no~"    OP =~"=~"RIGHT=~"coilmst.coil_no~" )    JOIN (LEFT=~"coilmst.item_no~"    OP =~"=~"RIGHT=~"groupitem.item_no~" )    JOIN (LEFT=~"coilorderdet.loc_no~"    OP =~"=~"RIGHT=~"coilmst.loc_no~" )WHERE(    EXP1 =~"coilorderdet.proc_flag~"   OP =~"=~"    EXP2 =~"'M'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"coilorder.wc_place~"   OP =~"=~"    EXP2 =~"'I'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"coilorder.wc_no~"   OP =~"=~"    EXP2 =~":as_wc~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"coilsliting.sheet~"   OP =~"=~"    EXP2 =~"'C'~" ) ) ARG(NAME = ~"as_wc~" TYPE = string) " arguments=(("as_wc", string))  sort="order_no A order_seq A coil_no A item_name A thin A wid A wlen A length A " )
