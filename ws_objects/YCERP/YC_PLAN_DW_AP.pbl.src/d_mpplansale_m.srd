footer(height=64 color="8421504" )
detail(height=60 color="553648127" )
table(column=(type=long update=yes updatewhereclause=yes key=yes name=division dbname="RoutTempNew.division" initial="1" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=wc_no dbname="RoutTempNew.wc_no" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=operation dbname="RoutTempNew.operation" initial="1" )
 column=(type=char(14) update=yes updatewhereclause=yes key=yes name=sale_no dbname="RoutTempNew.sale_no" initial="NO_SALE" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=seq_no dbname="RoutTempNew.seq_no" initial="0" )
 column=(type=datetime update=yes updatewhereclause=yes name=work_date dbname="RoutTempNew.work_date" )
 column=(type=char(1) update=yes updatewhereclause=yes name=process_flag dbname="RoutTempNew.process_flag" initial="Y" values="가능	Y/불가	N/완료	E/진행	P/" )
 column=(type=long update=yes updatewhereclause=yes name=work_per dbname="RoutTempNew.work_per" initial="0" )
 column=(type=char(4) update=yes updatewhereclause=yes name=cust_no dbname="RoutTempNew.cust_no" )
 column=(type=char(11) update=yes updatewhereclause=yes name=scene_code dbname="RoutTempNew.scene_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 column=(type=datetime update=yes updatewhereclause=yes name=napgi_date dbname="RoutTempNew.napgi_date" )
 column=(type=datetime update=yes updatewhereclause=yes name=make_napgi_date dbname="RoutTempNew.make_napgi_date" )
 column=(type=char(1) update=yes updatewhereclause=yes name=suju_type dbname="RoutTempNew.suju_type" values="Y.S.P	Y/시화	E/" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="RoutTempNew.item_no" initial="NO_ITEM" )
 column=(type=char(60) updatewhereclause=yes name=item_name1 dbname="item_name1" initial="NO_ITEM" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="RoutTempNew.qa" initial="NO_QA" )
 column=(type=char(4) update=yes updatewhereclause=yes name=item_color dbname="RoutTempNew.item_color" initial="0000" )
 column=(type=char(10) updatewhereclause=yes name=color_name dbname="color_name" initial="무도장" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=order_qty dbname="RoutTempNew.order_qty" initial="0" )
 column=(type=char(10) update=yes updatewhereclause=yes name=assy_item dbname="RoutTempNew.assy_item" )
 column=(type=char(20) update=yes updatewhereclause=yes name=assy_qa dbname="RoutTempNew.assy_qa" )
 column=(type=long update=yes updatewhereclause=yes name=bom_no dbname="RoutTempNew.bom_no" initial="0" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="RoutTempNew.uom" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=plan_qty dbname="RoutTempNew.plan_qty" initial="0" )
 column=(type=decimal(4) updatewhereclause=yes name=plan_qty_org dbname="plan_qty_org" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=setup_time dbname="RoutTempNew.setup_time" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=work_time dbname="RoutTempNew.work_time" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=make_qty dbname="RoutTempNew.make_qty" initial="0" )
 column=(type=char(1) update=yes updatewhereclause=yes name=plan_flag dbname="RoutTempNew.plan_flag" initial="N" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=qpa dbname="RoutTempNew.qpa" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=reserved_qty dbname="RoutTempNew.reserved_qty" initial="0" )
 column=(type=char(50) update=yes updatewhereclause=yes name=routtempnew_rem dbname="RoutTempNew.rem" )
 column=(type=char(10) update=yes updatewhereclause=yes name=routtempnew_area_no dbname="RoutTempNew.area_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(1) updatewhereclause=yes name=groupitem_source dbname="GroupItem.source" )
 column=(type=char(2) updatewhereclause=yes name=groupitem_uom dbname="GroupItem.uom" )
 column=(type=char(1) updatewhereclause=yes name=open_close dbname="open_close" )
 column=(type=char(52) updatewhereclause=yes name=customer_cust_name dbname="cust_name" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=long updatewhereclause=yes name=pri dbname="pri" )
 column=(type=decimal(2) updatewhereclause=yes name=dodet_ship_qty dbname="ship_qty" )
 column=(type=decimal(5) updatewhereclause=yes name=calc_qty dbname="calc_qty" )
 column=(type=char(1) updatewhereclause=yes name=attch dbname="attch" )
 column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" values="	Y/	N" )
 column=(type=char(1) updatewhereclause=yes name=utong_yn dbname="SCENE.utong_yn" )
 column=(type=long updatewhereclause=yes name=top_level_star dbname="top_level_star" )
 column=(type=char(248) updatewhereclause=yes name=total_rem dbname="total_rem" )
 retrieve="SELECT 
	routtempnew.division   
	, routtempnew.wc_no   
	, routtempnew.operation   
	, routtempnew.sale_no   
	, routtempnew.seq_no            
	, routtempnew.work_date   
	, routtempnew.process_flag   
	, routtempnew.work_per   
	, routtempnew.cust_no   
	, routtempnew.scene_code   
	, scene.scene_desc   
	, routtempnew.napgi_date  
	, routtempnew.make_napgi_date
	, routtempnew.suju_type   
	, routtempnew.item_no   
	, item_name1 = (case when routtempnew.item_no = 'NO_ITEM' then 'NO_ITEM' else groupitem1.item_name end )   
	, routtempnew.qa   
	, routtempnew.item_color   
	, color_name = color.color_name   
	, routtempnew.order_qty   
	, routtempnew.assy_item   
	, routtempnew.assy_qa   
	, routtempnew.bom_no   
	, routtempnew.uom   
	, routtempnew.plan_qty   
	, plan_qty_org = routtempnew.plan_qty   
	, routtempnew.setup_time   
	, routtempnew.work_time   
	, routtempnew.make_qty   
	, routtempnew.plan_flag   
	, routtempnew.qpa   
	, routtempnew.reserved_qty   
	, routtempnew.rem   
	, routtempnew.area_no   
	, groupitem.item_name
	, groupitem.source
	, groupitem.uom
	, isnull(sale.open_close, 'O') open_close
	, ( CASE WHEN customer.top_level = 'A大' then '**'
				WHEN customer.top_level = 'B大'  then '*'
				ELSE ''
				END ) + customer.cust_name  cust_name
	, user_name = (SELECT user_name FROM login WHERE user_id = customer.salesman)
	, pri       = 0   
	, ship_qty  = dbo.uf_getdosumqty(routtempnew.sale_no, routtempnew.seq_no)
	, calc_qty = dbo.uf_getqty(routtempnew.assy_item, routtempnew.assy_qa, routtempnew.uom, routtempnew.plan_qty)
	, attch     = (case when salepic.order_no is null then '' else 'O' end)
	, chk       = 'N'
	, scene.utong_yn
	, (CASE WHEN SUBSTRING(customer.top_level,1,1) = 'A' then 1
			  WHEN SUBSTRING(customer.top_level,1,1) = 'B'  then 2 
			  ELSE 3
			  END ) top_level_star 
	, '[' + rtrim(sale.rem) + '] ' + '[' + rtrim(sale.rem1) + '] ' + '['+ rtrim(sale.rem2) + ']'	total_rem
FROM routtempnew	left outer join groupitem with(nolock) on  routtempnew.assy_item   = groupitem.item_no
						left outer join groupitem groupitem1 with(nolock) on routtempnew.item_no = groupitem1.item_no
						left outer join customer with(nolock) on routtempnew.cust_no = customer.cust_no
						left outer join scene with(nolock) on routtempnew.scene_code = scene.scene_code
						left outer join sale with(nolock) on routtempnew.sale_no = sale.order_no and ( sale.order_date  >= DATEadd(month, :as_pre_month*2 ,getdate() ) )
						left outer join salepic with(nolock) on routtempnew.sale_no = salepic.order_no 
						left outer join color  with(nolock) on routtempnew.item_color = color.color_code
WHERE 
	( routtempnew.napgi_date     >= DATEadd(month, :as_pre_month ,getdate())   )  
AND
	( routtempnew.process_flag <> 'C' ) 
AND  
	( routtempnew.work_date    >= DATEadd(month, :as_pre_month ,getdate()) ) 
AND 
	( routtempnew.area_no = :as_area_no ) 
AND                                           
	( routtempnew.plan_flag = 'N' )    
AND
	(( '%' = :as_chk) or ( '%' <> :as_chk and ( routtempnew.order_qty <> isnull(dbo.uf_getdosumqty(routtempnew.sale_no, routtempnew.seq_no),0) or isnull(routtempnew.order_qty,0) = 0)  ))
AND 
	(isnull(customer.sale_control,'N') <> 'A' )
                        " update="routtempnew" updatewhere=0 updatekeyinplace=no filter=" open_close = 'O'"arguments=(("as_area_no", string),("as_pre_month", number),("as_chk", string))  sort="wc_no A item_name1 A scene_scene_desc A sale_no A seq_no A division A " )
group(level=1 header.height=0 trailer.height=68 by=("if(  wc_no  = 'F19' or  wc_no  = 'F20' or  wc_no  = 'F21' , item_no , left(qa, 13) )" ) header.color="536870912" trailer.color="15780518" )
