$PBExportHeader$d_sysusercnt_t.srd
$PBExportComments$사용자 프로그램 사용현황(2001/08/14,이대준)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=84 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=user_name dbname="USER_NAME" )
 column=(type=datetime updatewhereclause=yes name=use_day dbname="USE_DAY" initial="today" )
 column=(type=char(30) updatewhereclause=yes name=window_id dbname="WINDOW_ID" )
 column=(type=char(50) updatewhereclause=yes name=window_title dbname="WINDOW_TITLE" )
 column=(type=char(1) updatewhereclause=yes name=flag dbname="FLAG" values="조회	R/저장	S/출력	P/엑셀	E/열기	O/" )
 column=(type=long updatewhereclause=yes name=use_count dbname="USE_COUNT" )
 column=(type=datetime updatewhereclause=yes name=start_date dbname="START_DATE" )
 column=(type=datetime updatewhereclause=yes name=end_date dbname="END_DATE" )
 column=(type=char(10) updatewhereclause=yes name=sysusercnt_user_id dbname="SYSUserCnt.USER_ID" )
 retrieve="  SELECT DISTINCT 
         USER_NAME   = B.USER_NAME   
       , USE_DAY     = A.USE_DAY              
       , WINDOW_ID   = A.WINDOW_ID            
       , WINDOW_TITLE= A.WINDOW_TITLE            
       , FLAG        = A.FLAG                 
       , USE_COUNT   = A.USE_COUNT         
       , START_DATE  = CONVERT(SMALLDATETIME, :as_start, 111)
       , END_DATE    = CONVERT(SMALLDATETIME, :as_end,   111)
       , A.USER_ID
    FROM SYSUSERCNT A
         LEFT OUTER JOIN LOGIN B  ON A.USER_ID = B.USER_ID
   WHERE ( A.USE_DAY     BETWEEN :as_start AND :as_end )
     AND ( A.USER_ID        LIKE :as_userid            )
     AND ( A.WINDOW_TITLE   LIKE :as_title             )
   ORDER BY USE_DAY DESC, USER_NAME
" arguments=(("as_start", string),("as_end", string),("as_userid", string),("as_title", string)) )
group(level=1 header.height=0 trailer.height=80 by=("use_day" , "user_name" ) header.color="536870912" trailer.color="15780518" )
