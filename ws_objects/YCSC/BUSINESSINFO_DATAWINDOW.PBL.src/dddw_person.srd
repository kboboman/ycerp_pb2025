 column=(type=char(10) updatewhereclause=yes name=kor_name dbname="per_mast.kor_name" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"per_mast~" ) COLUMN(NAME=~"per_mast.person_no~") COLUMN(NAME=~"per_mast.kor_name~")WHERE(    EXP1 =~"per_mast.person_no~"   OP =~"<>~"    EXP2 =~"'00000007'~" ) ) "  sort="kor_name A " )
column(band=detail id=2 alignment="0" tabsequence=32766 border="0" color="0" x="9" y="4" height="64" width="375" format="[general]"  name=kor_name edit.limit=0 edit.case=any edit.autoselect=yes  font.face="굴림" font.height="-10" font.weight="400"  font.family="2" font.pitch="2" font.charset="129" background.mode="2" background.color="16777215" )
