$PBExportHeader$d_cditem_fitting_m.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=92 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=area_no dbname="item_fitting.area_no" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="item_fitting.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=qa dbname="item_fitting.qa" )
 column=(type=char(10) update=yes updatewhereclause=yes name=loc_no dbname="item_fitting.loc_no" )
 column=(type=char(50) update=yes updatewhereclause=yes name=rem dbname="item_fitting.rem" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item.item_name" )
 retrieve="  SELECT a.area_no
       , a.item_no   
       , a.qa   
       , a.loc_no   
       , a.rem
		 , b.item_name  
    FROM item_fitting a
       ,	item		    b
   WHERE a.item_no = b.item_no
	  AND	a.qa      = b.qa
     AND ((:as_area  = '%' and area_no LIKE '%'     ) OR
          (:as_area <> '%' and area_no LIKE :as_area) 
         )
  " update="item_fitting" updatewhere=0 updatekeyinplace=no arguments=(("as_area", string))  sort="area_no A item_name A qa A " )
