compute(band=detail alignment="1" expression="if(left( item_no ,1) = 'P' and mid(item_no, 3,1) = 'Y' and (mid(item_no, 7,1) = 'A' or mid(item_no, 7,1) = 'B' or mid(item_no, 7,1) = 'C' or mid(item_no, 7,1) = 'D'),a_qty, if(uom = 'M2',truncate( long(mid( qa ,5,4)) * long(mid(qa,10,4)) *   a_qty / 1000000, 2), if(uom = 'M', truncate(long(mid(qa, 15,5)) *  a_qty / 1000 + 0.000001 ,2),  a_qty )))"border="5" color="0" x="2171" y="92" height="60" width="384" format="#,###.00"  name=acc_qty  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
