if isnull(ll_row) OR ll_row < 1 then RETURN

st_name.text = trim(this.object.groupitem_item_name[currentrow]) &
					+ '~n~r     규격   = ' + trim(this.object.qa[currentrow]) &
					+ '~n~r     현재고 = ' + string(this.object.qoh[currentrow], "#,##0") 
					
