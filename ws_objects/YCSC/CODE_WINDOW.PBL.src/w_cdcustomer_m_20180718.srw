event clicked;long ll_row
string ls_cust_no, ls_salesman, ls_newselect

dw_1.accepttext( )
if tab_1.tabpage_6.cbx_2.checked = true then
	is_custno2 = '%'
else
	is_custno2 = upper(dw_1.object.cust_no[1])
end if

if isnull(is_custno2) or trim(is_custno2) = '' then
	messagebox('확인', '상단의 거래처를 선택후 작업하세요.')
	return
end if

if tab_1.tabpage_6.cbx_3.checked = true then
	ls_newselect = is_select + " WHERE cust_no like '" + is_custno2 + "' and ipgum_date between '" + tab_1.tabpage_6.em_2.text + "' and '" + tab_1.tabpage_6.em_3.text + " 23:59:59' "
else
	ls_newselect = is_select + " WHERE cust_no like '" + is_custno2 + "'"
end if

tab_1.tabpage_6.dw_21.setsqlselect(ls_newselect)
