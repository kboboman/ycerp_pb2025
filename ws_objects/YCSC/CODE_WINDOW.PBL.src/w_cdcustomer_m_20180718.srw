event open;//==GF_USEPROGRAM(프로그램 사용현황)===========================================================
GF_USEPROGRAM( gs_userid, THIS.ClassName(), "O", string(gf_today(),'yyyy/mm/dd'), THIS.Title )
//=============================================================================================

long   ll_row
string ls_open, ls_zero, ls_salesman

dw_3.visible  = false
dw_9.visible  = false
dw_10.visible = false
dw_11.visible = false
dw_12.visible = false
dw_13.visible = false
dw_14.visible = false
dw_16.visible = false

dw_15.visible = false	// PRINT
dw_15.x       = 229
dw_15.y       = 776
dw_15.width   = 4288
dw_15.height  = 1444

dw_24.visible = false	// 순수거래처명
dw_24.x       = 2976
dw_24.y       = 236
dw_24.width   = 2222
dw_24.height  = 1880

dw_28.visible = false	// 영업담당 이력(수주기준)
dw_28.x       = 3479	
dw_28.y       = 456
dw_28.width   = 1152
dw_28.height  = 2496

dw_rem.visible = false	// 거래처 비고 History
dw_rem.x       = 992		
dw_rem.y       = 700
dw_rem.width   = 2642
dw_rem.height  = 1328

dw_25.visible  = false
tab_1.tabpage_1.st_salecontrol.border = false		

if GF_PERMISSION('판매거래처관리OPEN', gs_userid) = 'Y' then
	if gs_username = "조용재" then
		cbx_open.checked = true
	else
		cbx_open.checked = false
	end if
	tab_1.tabpage_1.dw_5.Object.last_tn_date.TabSequence = 1
else
	cbx_open.checked = true
	pb_print.enabled = false
	pb_insert.enabled = false
	tab_1.tabpage_1.dw_5.Object.open_close.TabSequence   = 0
	tab_1.tabpage_1.dw_5.Object.credit_level.TabSequence = 0
	tab_1.tabpage_1.dw_5.object.cust_name.tabsequence    = 0
	tab_1.tabpage_1.dw_5.object.register_no.tabsequence  = 0
	tab_1.tabpage_1.dw_5.object.captain_name.tabsequence = 0
	tab_1.tabpage_1.dw_5.object.cust_flag.tabsequence    = 0
	tab_1.tabpage_1.dw_5.object.cust_type.tabsequence    = 0
	tab_1.tabpage_1.dw_5.object.resident_card.tabsequence= 0
	tab_1.tabpage_1.dw_5.object.start_date.tabsequence   = 0
end if

tab_1.tabpage_2.dw_4.settransobject(sqlca)
tab_1.tabpage_1.dw_5.SetTransObject(SQLCA)
tab_1.tabpage_4.dw_17.SetTransObject(SQLCA)
tab_1.tabpage_4.dw_8.SetTransObject(SQLCA)
tab_1.tabpage_3.dw_6.SetTransObject(SQLCA)
tab_1.tabpage_3.dw_23.SetTransObject(SQLCA)
tab_1.tabpage_3.dw_7.SetTransObject(SQLCA)
tab_1.tabpage_3.dw_29.SetTransObject(SQLCA)
tab_1.tabpage_1.dw_20.SetTransObject(SQLCA)
dw_15.SetTransObject(SQLCA)
is_dwsql = dw_10.describe("datawindow.table.select")
dw_11.settransobject(sqlca)
is_dovcsql = dw_11.describe("datawindow.table.select")
dw_12.settransobject(sqlca)
is_teamsql = dw_12.describe("datawindow.table.select")
dw_13.settransobject(sqlca)
is_mansql = dw_13.describe("datawindow.table.select")
dw_16.settransobject(sqlca)
is_custdorsql = dw_16.describe("datawindow.table.select")

dw_9.settransobject(sqlca)
dw_1.settransobject(sqlca)
dw_28.SetTransObject(SQLCA)

/////////////////////////////////////////////
//// 담당자별 거래처
/////////////////////////////////////////////
//dw_salesman.settransobject(sqlca)	
//dw_salesman.insertrow(1)
//dw_salesman.getchild("user",idwc_user)
//idwc_user.insertrow(1)
//idwc_user.setitem(1,"user_id","%")
//idwc_user.setitem(1,"user_name","전체")
//idwc_user.accepttext()
//dw_salesman.object.user[1] = "%"
ls_salesman = "%"

///////////////////////////////////////////
// 사용불가 제외
///////////////////////////////////////////
if cbx_open.checked = true then
	ls_open = "O"
else
	ls_open = "%"
end if

///////////////////////////////////////////
// 잔액제로 제외
///////////////////////////////////////////
if cbx_zero.checked = true then
	ls_zero = "Y"
else
	ls_zero = "%"
end if

dw_1.insertrow(0)
dw_1.getchild("cust_no", idwc_cust)
idwc_cust.settransobject(sqlca)
ll_row = idwc_cust.retrieve( ls_open, ls_zero, ls_salesman )
if ll_row = 0 then MessageBox("확인", "거래처 데이터가 존재하지 않습니다.")

idwc_cust.setsort('cust_no, cust_name')
idwc_cust.sort()
//================================//
dw_1.getchild("cust_name", idwc_cust_name)
idwc_cust_name.settransobject(sqlca)
ll_row = idwc_cust_name.retrieve( ls_open, ls_zero, ls_salesman )
if ll_row = 0 then MessageBox("확인", "거래처 데이터가 존재하지 않습니다.")

idwc_cust_name.setsort('cust_name, cust_no')
idwc_cust_name.sort()
//================================//
dw_1.getchild("icube_no", idwc_icube)
idwc_icube.settransobject(sqlca)
ll_row = idwc_icube.retrieve( ls_open, ls_salesman )
if ll_row = 0 then MessageBox("확인", "거래처 데이터가 존재하지 않습니다.")

idwc_icube.setsort('icube_no, cust_name')
idwc_icube.sort()
///////////////////////////////////////////

pb_insert.enabled = true

tab_1.tabpage_5.dw_18.settransobject(sqlca)
tab_1.tabpage_5.dw_19.settransobject(sqlca)
tab_1.tabpage_6.dw_21.settransobject(sqlca)
tab_1.tabpage_6.dw_22.settransobject(sqlca)
is_select = tab_1.tabpage_6.dw_21.getsqlselect()

dw_24.SetTransObject(SQLCA)   // 거래처검색 조건 데이터윈도우(090403)
dw_25.SetTransObject(SQLCA)	// 거래처리스트
tab_1.tabpage_7.dw_27.settransobject(sqlca)	// 엑셀 가져오기

tab_1.tabpage_7.ddlb_sheet.enabled = false
tab_1.tabpage_7.cb_import.enabled  = false
tab_1.tabpage_7.hpb_1.position     = 0
tab_1.tabpage_7.cb_excute.enabled  = false

if LeftA(gs_print_control,1) = "V" then
	string ls_custno
	ls_custno = MidA(gs_print_control,2,4)
	tab_1.tabpage_1.dw_5.retrieve(ls_custno)
end if

dw_1.setcolumn("cust_name")
dw_1.setfocus()

end event

event resize;call super::resize;//
tab_1.width  = newwidth  - 73
tab_1.height = newheight - 504

// 공사예상현장
tab_1.tabpage_4.gb_5.width   = tab_1.width  - 69
tab_1.tabpage_4.gb_5.height  = tab_1.height - 1312

tab_1.tabpage_4.dw_8.height  = tab_1.height - 1392

// 매출/수금내역
tab_1.tabpage_3.gb_8.width   = tab_1.width  - 50
tab_1.tabpage_3.gb_8.height  = tab_1.height - 1072

tab_1.tabpage_3.dw_7.width   = (tab_1.width - 37) / 2
tab_1.tabpage_3.dw_7.height  = tab_1.tabpage_3.gb_8.height - 52

tab_1.tabpage_3.dw_29.x      = tab_1.tabpage_3.dw_7.x + tab_1.tabpage_3.dw_7.width + 10
tab_1.tabpage_3.dw_29.width  = (tab_1.width - 37) / 2
tab_1.tabpage_3.dw_29.height = tab_1.tabpage_3.gb_8.height - 52

// 매출통제 일괄변경
tab_1.tabpage_5.dw_18.width  = tab_1.width  - 64
tab_1.tabpage_5.dw_18.height = tab_1.height - 328

// 영업관리
tab_1.tabpage_6.dw_21.width  = tab_1.width  - 55
tab_1.tabpage_6.dw_21.height = tab_1.height - 1040

tab_1.tabpage_6.dw_22.width  = tab_1.width  - 55
tab_1.tabpage_6.dw_22.height = tab_1.height - 1752

// 거래처 일괄변경
tab_1.tabpage_7.dw_26.height = tab_1.height - 336

tab_1.tabpage_7.dw_27.width  = tab_1.width  - 933

tab_1.tabpage_7.mle_1.width  = tab_1.width  - 933
tab_1.tabpage_7.mle_1.height = tab_1.height - 1652

// 여신현황 출력 
dw_15.x  = tab_1.x
dw_15.y  = tab_1.y
dw_15.width  = tab_1.width
dw_15.height = tab_1.height

end event

type pb_save from w_inheritance`pb_save within w_cdcustomer_m_20180718
integer x = 3598
end type

event pb_save::clicked;dwitemstatus l_status, l_status_rem
boolean lb_update_chk = false

if gf_permission('판매거래처관리edit', gs_userid) = 'Y' then
else
	messagebox('확인', '권한이 없습니다. 전산실에 문의 하십시요.')
	return
end if

if tab_1.selectedtab = 7 then
	messagebox("확인", "[[[ 판매거래처 변경작업 실행 ]]] 버튼을 실행하세요.")
	return
end if

if messagebox("저장","저장하시겠습니까?",information!,okcancel!,1) = 2 then
	return
end if
//===============사용자별 프로그램 사용현황=================================
gf_usecount(gs_userid,parent.classname(),"S",string(today(),'yyyy/mm/dd'))
//==========================================================================

tab_1.tabpage_2.dw_4.accepttext()
tab_1.tabpage_1.dw_5.accepttext()
tab_1.tabpage_1.dw_rem_i.accepttext()
if tab_1.tabpage_1.dw_5.rowcount() < 1 then 
	messagebox('오류', '거래처선택 오류, 거래처를 다시 조회후 작업하세요. ')
	return
end if

if  LeftA(tab_1.tabpage_1.dw_5.object.cust_no[1], 1) = 'S' or &
    LeftA(tab_1.tabpage_1.dw_5.object.cust_no[1], 1) = 'L' or &
    LeftA(tab_1.tabpage_1.dw_5.object.cust_no[1], 1) = 'K' or &
    LeftA(tab_1.tabpage_1.dw_5.object.cust_no[1], 1) = 'N' or &
    LeftA(tab_1.tabpage_1.dw_5.object.cust_no[1], 1) = 'H' or &
    LeftA(tab_1.tabpage_1.dw_5.object.cust_no[1], 1) = 'I' or &
    LeftA(tab_1.tabpage_1.dw_5.object.cust_no[1], 1) = 'J' or &
    LeftA(tab_1.tabpage_1.dw_5.object.cust_no[1], 1) = 'T' or & 
    LeftA(tab_1.tabpage_1.dw_5.object.cust_no[1], 1) = 'U' or & 
    LeftA(tab_1.tabpage_1.dw_5.object.cust_no[1], 1) = 'V' then
else
	 messagebox("거래처 등록오류","거래처 코드 첫자는 'S','L','N','H','I','J','K','T','U','V'만 가능합니다!")
	 return	 
end if

tab_1.tabpage_3.dw_6.accepttext()
IF (isnull(tab_1.tabpage_1.dw_5.object.register_no[1])   or trim(tab_1.tabpage_1.dw_5.object.register_no[1])   = '') and &
   (isnull(tab_1.tabpage_1.dw_5.object.resident_card[1]) or trim(tab_1.tabpage_1.dw_5.object.resident_card[1]) = '') then
	messagebox("오류","사업자등록번호나 주민등록번호를 반드시 입력하십시오.")
	return
else
	string ls_register
	long   ll_cnt

	ls_register = tab_1.tabpage_1.dw_5.object.register_no[1]
	SELECT count(*) INTO :ll_cnt FROM CUSTOMER WHERE register_no   = :ls_register;
	if ll_cnt > 0 then
		if messagebox("오류","사업자등록번호 중복 입니다.~n~n계속 진행 하시겠습니까?", Exclamation!, YesNo!, 2) = 2 then
			return
		end if
	end if
end if


String	ls_rgno
long		ll_len

ls_rgno = tab_1.tabpage_1.dw_5.object.register_no[1]
ll_len = LenA(ls_rgno)

IF ll_len < 12 then //사업자등록번호 자릿수 체크
	messagebox("오류","사업자등록번호 자릿수를 확인하여 주시기 바랍니다.")
	return
END IF


setpointer(hourglass!)
if tab_1.tabpage_2.dw_4.rowcount() > 0 then
	if tab_1.tabpage_1.dw_5.rowcount() > 0 then
		if wf_nullchk(tab_1.tabpage_2.dw_4) = false then
			return
		elseif wf_nullchk(tab_1.tabpage_1.dw_5) = false then
			return
		end if
		
		l_status = tab_1.tabpage_1.dw_5.getitemstatus(1, 0, primary!)
		if l_status = newmodified! then
			lb_update_chk = wf_update3(tab_1.tabpage_2.dw_4, tab_1.tabpage_1.dw_5, tab_1.tabpage_3.dw_6, "Y")
	   else
			//// 판매담당자가 변경될 경우 이전 담당자를 전임판매담당자로 자동 변환/////
         if (isnull(is_salesman) or trim(is_salesman) = '') then
			else
            if is_salesman <> tab_1.tabpage_1.dw_5.object.salesman[1] then
					tab_1.tabpage_1.dw_5.object.pre_salesman[1] = is_salesman
				end if
			end if
			//// 변환 끝 ///	
			lb_update_chk = wf_update2(tab_1.tabpage_2.dw_4, tab_1.tabpage_1.dw_5, "Y")
	   end if
	end if
else
	messagebox("오류","입력된 정보가 없습니다.")
	return
end if

if lb_update_chk = true then
	string ls_sale_control, ls_cust_no, ls_text
	
	ls_sale_control = tab_1.tabpage_1.dw_5.object.sale_control[1]
	ls_cust_no      = tab_1.tabpage_1.dw_5.object.cust_no[1]
	if isnull(ls_sale_control) then ls_sale_control = 'N'

	string ls_s_sms_yn, ls_s_area_no, ls_s_tel
	ls_s_tel = 'chulha_t_0'	// 본사

	if is_sale_control <> ls_sale_control then
		if ls_sale_control = 'A' or ls_sale_control = 'Y' then
			ls_text = '매출 통제대상으로 선정되었습니다.'
		else
			ls_text = '매출 통제대상에서 해제되었습니다.'
		end if

		string ls_s_cust_name, ls_s_scene_desc, ls_s_do_date, ls_s_hp_no, ls_s_scene_tel, ls_s_cust_tel, ls_s_msg, ls_s_stel
		SELECT top 1 b.cust_name, replace(substring(ltrim(rtrim(isnull(d.hp_no,''))),1,13), '-', '')
		  INTO :ls_s_cust_name, :ls_s_hp_no				
		  FROM customer b, salehp d
		 WHERE b.salesman = d.user_id
		   AND b.cust_no  = :ls_cust_no;

		ls_s_msg = '[유창]' + ls_s_cust_name + '는 ' + ls_text 

		SELECT TOP 1 Replace(substring(ltrim(rtrim(isnull(d.hp_no,''))),1,13), '-', '') into :ls_s_stel
		  FROM salehp d
		 WHERE user_id = :ls_s_tel;
		
		choose case LeftA(ls_s_hp_no,3)
			case '010','011','016','017','018','019'
			case else
				ls_s_hp_no = ''
		end choose

		//=====================================
		// GW SMS Profile 
		//=====================================
		String TRAN_PHONE, TRAN_CALLBACK, TRAN_STATUS, TRAN_MSG
		String SMSSERVER

		SELECT ITEM_NM INTO :SMSSERVER FROM CODEMST
		 WHERE ITEM_CD = 'SMSSERVER' AND USE_YN = 'Y';
		IF SMSSERVER = "" THEN SMSSERVER = "192.168.1.5"
		
		IF SMSSERVER <> "192.168.1.5" THEN
			Transaction SQLCA1
			If Not IsValid(SQLCA1) Then SQLCA1 = CREATE Transaction
		
			SQLCA1.DBMS       = "MSS Microsoft SQL Server 8.x"
			SQLCA1.Database   = "SMS"
			SQLCA1.LogID      = "db_user"		// INSERT Only
			SQLCA1.LogPass    = ""
			SQLCA1.ServerName = SMSSERVER
			SQLCA1.UserID     = ""
			SQLCA1.DBPass     = ""
			SQLCA1.Lock       = "ReadOnly"
			SQLCA1.DbParm     = "CursorLock='ReadOnly',AppName='YCERP',Host= 'SMS LOGIN"
			SQLCA1.AutoCommit = False 
		
			CONNECT USING SQLCA1;
			IF SQLCA1.SQLCode = -1 THEN
				 MessageBox("SMS단문", "SMS단문 Database와 연결이 되지 않습니다.~r~n" + &
							  "에러코드: " + String(SQLCA1.SQLDBCode ) + "~r~n" + &
							  "에러내용: " + SQLCA1.SQLErrText, StopSign!, OK!, 1 )
			END IF
			If SQLCA1.SQLCode <> 0 then 
				  MessageBox( "MS-SQL DB Connect ERROR", SQLCA1.SQLErrText ) 
				//HALT CLOSE 
			End If 

			TRAN_CALLBACK = ls_s_stel
			TRAN_STATUS   = '1'
			//GW SMS=====================================
		END IF
		
		
		if ls_s_hp_no = '' or isnull(ls_s_hp_no) then
		else			
			choose case SMSSERVER
				case '192.168.1.5'
					INSERT  INTO  SC_TRAN ( TR_SENDDATE, TR_SENDSTAT, TR_RSLTSTAT, TR_PHONE, TR_CALLBACK, TR_MSG)
						VALUES ( GetDate(), '0', '00', :ls_s_hp_no, :ls_s_stel, :ls_s_msg);

//				case 'www.yoo-chang.co.kr', '218.159.85.109'
//					If SQLCA1.SQLCode = 0 Then 
//						TRAN_PHONE    = ls_s_hp_no
//						TRAN_MSG      = ls_s_msg
//
//						INSERT INTO EM_TRAN ( TRAN_PHONE, TRAN_CALLBACK, TRAN_STATUS, TRAN_DATE, TRAN_MSG, TRAN_ETC3 )
//				  			VALUES ( :TRAN_PHONE, :TRAN_CALLBACK, :TRAN_STATUS, GETDATE(), :TRAN_MSG, :LS_S_HP_NO) USING SQLCA1;			  
//					End If			  
				case else
			end choose												
		end if

		//GW SMS=====================================
		choose case SMSSERVER
			case 'www.yoo-chang.co.kr', '218.159.85.109'
				If SQLCA1.SQLCode = 0 Then 
					COMMIT USING SQLCA1; 
					//MessageBox( "MS-SQL INFO", "문자전송 성공" ) 
				Else 
					 MessageBox("MS-SQL ERROR", "SMS전송 오류.~r~n" + &
								  "ErrorCode: " + String(SQLCA1.SQLDBCode ) + "~r~n" + &
								  "ErrorText: " + SQLCA1.SQLErrText, StopSign!, OK!, 1 )
					 ROLLBACK USING SQLCA1; 
				End If 
				DISCONNECT USING SQLCA1;

			case else
		end choose
		//GW SMS=====================================
		
		commit using sqlca;

		is_sale_control = ls_sale_control		
	end if
end if


///////////////////////////////////////////
// 사용불가 제외
///////////////////////////////////////////
long   ll_row
string ls_open, ls_zero, ls_salesman

if cbx_open.checked = true then
	ls_open = "O"
else
	ls_open = "%"
end if

ls_zero     = "%"
ls_salesman = "%"

ll_row = idwc_cust.retrieve( ls_open, ls_zero, ls_salesman )
if ll_row = 0 then MessageBox("확인", "거래처 데이터가 존재하지 않습니다.")
ll_row = idwc_cust_name.retrieve( ls_open, ls_zero, ls_salesman )
if ll_row = 0 then MessageBox("확인", "거래처 데이터가 존재하지 않습니다.")
ll_row = idwc_icube.retrieve( ls_open, ls_salesman )
if ll_row = 0 then MessageBox("확인", "거래처 데이터가 존재하지 않습니다.")
///////////////////////////////////////////

pb_insert.enabled = true

string   ls_rem
integer  li_seq
datetime ldt_today
ls_cust_no = ""
l_status_rem = tab_1.tabpage_1.dw_rem_i.getitemstatus(1, 0, primary!)

if l_status_rem <> NotModified! then
	ls_rem = tab_1.tabpage_1.dw_rem_i.object.rem[1]
	ls_cust_no = tab_1.tabpage_1.dw_5.object.cust_no[1]
	SELECT top 1 convert(datetime, convert(varchar(10), getdate(), 111))
     INTO :ldt_today
	  FROM login;

	SELECT count(*) + 1 INTO :li_seq
	  FROM customer_det
	 WHERE cust_no = :ls_cust_no AND idate   = :ldt_today;

	if isnull(ls_rem) or trim(ls_rem) = "" then ls_rem = ""
	if is_rem_old <> ls_rem then
		INSERT INTO customer_det (cust_no, idate, seq, rem, iuser) 
		VALUES (:ls_cust_no, getdate(), :li_seq, :ls_rem, :gs_userid);
		COMMIT;
		is_rem_old = ls_rem
	end if
end if

end event

type dw_1 from w_inheritance`dw_1 within w_cdcustomer_m_20180718
integer x = 50
integer y = 248
integer width = 2414
integer height = 200
integer taborder = 50
string dataobject = "d_cdcustomer_s"
boolean hscrollbar = false
boolean vscrollbar = false
boolean border = false
end type

event dw_1::itemchanged;String ls_custno, ls_custnm, ls_icubeno, ls_data
Long   ll_cnt

// 다른 프로그램에서 OpenSheet 한 경우
if isnull(data) or data = "" then
else
	tab_1.tabpage_1.dw_rem_i.insertrow(0)
	
	choose case dwo.name
		case 'cust_no'  
			ls_custno = Trim(data)
			
			setnull(ls_custnm)		
			
/*		SELECT count(*) INTO :ll_cnt FROM customer WHERE cust_no  =  :ls_custno;	*/ /*2018.04.04 조원석 count(*) -> cust_name */
		SELECT cust_name INTO :ls_custnm FROM customer WHERE cust_no  =  :ls_custno;        /*2018.04.04 조원석 count(*) -> cust_name */
		
/*		if ll_cnt <= 0 then						*/  /*2018.04.04 조원석 주석처리 */
			if isnull(ls_custno) then 						/*2018.04.04 조원석 신규반영*/
				tab_1.tabpage_1.dw_5.reset()
				tab_1.tabpage_2.dw_4.reset()
				tab_1.tabpage_3.dw_6.reset()
				tab_1.tabpage_3.dw_7.reset()
				tab_1.tabpage_3.dw_29.reset()
				Messagebox('확인','입력한 거래처코드의 거래처는 존재하지 않습니다.')
				Return
			else
				this.object.cust_name[1] = ""
				this.object.cust_name[1] = ls_custnm /*idwc_cust.getitemstring(idwc_cust.getrow(), "cust_name")	2018.04.04 조원석 주석처리 ls_custnm 반영 */		
				this.object.icube_no[1]  = ""
				this.object.icube_no[1]  = idwc_cust.getitemstring(idwc_cust.getrow(), "icube_no")

				tab_1.tabpage_1.dw_5.reset()
				tab_1.tabpage_1.dw_20.reset()
				tab_1.tabpage_1.dw_rem_i.reset()
				tab_1.tabpage_2.dw_4.reset()
				tab_1.tabpage_3.dw_6.reset()
				tab_1.tabpage_3.dw_7.reset()
				tab_1.tabpage_3.dw_29.reset()
				
				tab_1.tabpage_1.dw_5.setfocus()				
/*				
				2018.04.04 조원석 주석처리 
				tab_1.tabpage_1.dw_5.retrieve(idwc_cust.getitemstring(idwc_cust.getrow(), "cust_no"))
				tab_1.tabpage_1.dw_20.retrieve(idwc_cust.getitemstring(idwc_cust.getrow(), "cust_no"))
				tab_1.tabpage_2.dw_4.retrieve(idwc_cust.getitemstring(idwc_cust.getrow(), "cust_no"))
				tab_1.tabpage_4.dw_17.retrieve(idwc_cust.getitemstring(idwc_cust.getrow(), "cust_no"))
				tab_1.tabpage_3.dw_7.retrieve(idwc_cust.getitemstring(idwc_cust.getrow(), "cust_no"))
				tab_1.tabpage_3.dw_29.retrieve(idwc_cust.getitemstring(idwc_cust.getrow(), "cust_no"))
				tab_1.tabpage_3.dw_6.retrieve(idwc_cust.getitemstring(idwc_cust.getrow(), "cust_no"), &
														integer(string(wf_today(),'YYYY')))
*/

				/*2018.04.04 조원석 ls_custno로 반영 시작 */							
				tab_1.tabpage_1.dw_5.retrieve(ls_custno)
				tab_1.tabpage_1.dw_20.retrieve(ls_custno)
				tab_1.tabpage_2.dw_4.retrieve(ls_custno)
				tab_1.tabpage_4.dw_17.retrieve(ls_custno)
				tab_1.tabpage_3.dw_7.retrieve(ls_custno)
				tab_1.tabpage_3.dw_29.retrieve(ls_custno)
				tab_1.tabpage_3.dw_6.retrieve(ls_custno, integer(string(wf_today(),'YYYY')))														
				/*2018.04.04 조원석 ls_custno로 반영 끝 */				

			end if
			
		case 'cust_name'
			ls_custnm = Trim(data)
			SELECT count(*) INTO :ll_cnt FROM customer
			 WHERE cust_name = :ls_custnm;
			 
			 
			/* 2018.04.04 조원석 수정 
				idwc_cust_name.getrow() 제대로 작동을 하지 않음.
				cust_no 를 구하고 이걸 반영하는걸로 수정 
				
			*/
	/*		SELECT count(*) INTO :ll_cnt FROM customer WHERE cust_name  =  :ls_custnm;*/ /*2018.04.04 변경 count(*) -> cust_no */
	
			setnull(ls_custno)		/*2018.04.04 조원석 주석처리*/
			SELECT cust_no INTO :ls_custno FROM customer WHERE cust_name  =  :ls_custnm; 			 
			 
			
/*			if ll_cnt <= 0 then								*/
			if isnull(ls_custno) then 						/*2018.04.04 조원석 신규반영*/
				tab_1.tabpage_1.dw_5.reset()
				tab_1.tabpage_2.dw_4.reset()
				tab_1.tabpage_3.dw_6.reset()
				tab_1.tabpage_3.dw_7.reset()
				tab_1.tabpage_3.dw_29.reset()
				Messagebox('확인','입력한 거래처명의 거래처는 존재하지 않습니다.')
				Return
			else
				
				
				this.object.cust_name[1]  = ""						/*2018.04.04 조원석 추가 */
				this.object.cust_name[1]  =ls_custnm				/*2018.04.04 조원석 추가 */								
				this.object.cust_no[1]  = ""
				this.object.cust_no[1]  = ls_custno /*2018.03.19 조원석 신규반영*/ /*idwc_cust_name.getitemstring(idwc_cust_name.getrow(), "cust_no")	*/ /*2018.04.04 조원석 주석처리*/
				
				this.object.icube_no[1] = ""
				this.object.icube_no[1] = idwc_cust_name.getitemstring(idwc_cust_name.getrow(), "icube_no")

				tab_1.tabpage_1.dw_5.reset()
				tab_1.tabpage_1.dw_20.reset()
				tab_1.tabpage_1.dw_rem_i.reset()
				tab_1.tabpage_2.dw_4.reset()
				tab_1.tabpage_3.dw_6.reset()
				tab_1.tabpage_3.dw_7.reset()
				tab_1.tabpage_3.dw_29.reset()
				
				tab_1.tabpage_1.dw_5.setfocus()
/*				
				/*2018.04.04 조원석 ls_custno로 반영 시작 */
				tab_1.tabpage_1.dw_5.retrieve(idwc_cust_name.getitemstring(idwc_cust_name.getrow(), "cust_no"))
				tab_1.tabpage_1.dw_20.retrieve(idwc_cust_name.getitemstring(idwc_cust_name.getrow(), "cust_no"))
				tab_1.tabpage_2.dw_4.retrieve(idwc_cust_name.getitemstring(idwc_cust_name.getrow(), "cust_no"))
				tab_1.tabpage_4.dw_17.retrieve(idwc_cust_name.getitemstring(idwc_cust_name.getrow(), "cust_no"))
				tab_1.tabpage_3.dw_7.retrieve(idwc_cust_name.getitemstring(idwc_cust_name.getrow(), "cust_no"))
				tab_1.tabpage_3.dw_29.retrieve(idwc_cust_name.getitemstring(idwc_cust_name.getrow(), "cust_no"))
				tab_1.tabpage_3.dw_6.retrieve(idwc_cust_name.getitemstring(idwc_cust_name.getrow(), "cust_no"), &
														integer(string(wf_today(),'YYYY')))
				/*2018.04.04 조원석 ls_custno로 반영 시작 */														
*/

				/*2018.04.04 조원석 ls_custno로 반영 시작 */
				tab_1.tabpage_1.dw_5.retrieve(ls_custno)
				tab_1.tabpage_1.dw_20.retrieve(ls_custno)
				tab_1.tabpage_2.dw_4.retrieve(ls_custno)
				tab_1.tabpage_4.dw_17.retrieve(ls_custno)
				tab_1.tabpage_3.dw_7.retrieve(ls_custno)
				tab_1.tabpage_3.dw_29.retrieve(ls_custno)
				tab_1.tabpage_3.dw_6.retrieve(ls_custno, integer(string(wf_today(),'YYYY')))
				/*2018.04.04 조원석 ls_custno로 반영 끝 */				
				
			end if

		case 'icube_no'
			ls_icubeno = Trim(data)
			SELECT count(*) INTO :ll_cnt FROM customer
			 WHERE icube_no = :ls_icubeno;
			
			if ll_cnt <= 0 then
				tab_1.tabpage_1.dw_5.reset()
				tab_1.tabpage_2.dw_4.reset()
				tab_1.tabpage_3.dw_6.reset()
				tab_1.tabpage_3.dw_7.reset()
				tab_1.tabpage_3.dw_29.reset()
				Messagebox('확인','입력한 더존코드의 거래처는 존재하지 않습니다.')
				Return
			elseif ll_cnt > 1 then
				tab_1.tabpage_1.dw_5.reset()
				tab_1.tabpage_2.dw_4.reset()
				tab_1.tabpage_3.dw_6.reset()
				tab_1.tabpage_3.dw_7.reset()
				tab_1.tabpage_3.dw_29.reset()
				Messagebox('확인','입력한 더존코드의 거래처는 ' + string(ll_cnt) + ' 존재 합니다.')
				Return
			else
				this.object.cust_no[1]   = ""
				this.object.cust_no[1]   = idwc_icube.getitemstring(idwc_icube.getrow(), "cust_no")
				this.object.cust_name[1] = ""
				this.object.cust_name[1] = idwc_icube.getitemstring(idwc_icube.getrow(), "cust_name")
				
				tab_1.tabpage_1.dw_5.reset()
				tab_1.tabpage_1.dw_20.reset()
				tab_1.tabpage_1.dw_rem_i.reset()
				tab_1.tabpage_2.dw_4.reset()
				tab_1.tabpage_3.dw_6.reset()
				tab_1.tabpage_3.dw_7.reset()
				tab_1.tabpage_3.dw_29.reset()
				
				tab_1.tabpage_1.dw_5.setfocus()
				tab_1.tabpage_1.dw_5.retrieve(idwc_icube.getitemstring(idwc_icube.getrow(), "cust_no"))
				tab_1.tabpage_1.dw_20.retrieve(idwc_icube.getitemstring(idwc_icube.getrow(), "cust_no"))
				tab_1.tabpage_2.dw_4.retrieve(idwc_icube.getitemstring(idwc_icube.getrow(), "cust_no"))
				tab_1.tabpage_4.dw_17.retrieve(idwc_icube.getitemstring(idwc_icube.getrow(), "cust_no"))
				tab_1.tabpage_3.dw_7.retrieve(idwc_icube.getitemstring(idwc_icube.getrow(), "cust_no"))
				tab_1.tabpage_3.dw_29.retrieve(idwc_icube.getitemstring(idwc_icube.getrow(), "cust_no"))
				tab_1.tabpage_3.dw_6.retrieve(idwc_icube.getitemstring(idwc_icube.getrow(), "cust_no"), &
														integer(string(wf_today(),'YYYY')))
			end if
	end choose															
	
	tab_1.tabpage_4.st_2.text = tab_1.tabpage_1.dw_5.object.cust_no[1]
	tab_1.tabpage_4.st_3.text = tab_1.tabpage_1.dw_5.object.cust_name[1]
	tab_1.tabpage_3.st_5.text = tab_1.tabpage_1.dw_5.object.cust_no[1]
	tab_1.tabpage_3.st_6.text = tab_1.tabpage_1.dw_5.object.cust_name[1]
	
	is_salesman = tab_1.tabpage_1.dw_5.object.salesman[1]
	tab_1.tabpage_3.em_1.text = string(wf_today(),'YYYY')
	tab_1.tabpage_1.dw_5.object.cust_no.protect = true
	dw_15.retrieve(tab_1.tabpage_3.st_5.text, integer(tab_1.tabpage_3.em_1.text), tab_1.tabpage_3.st_5.text)
	tab_1.tabpage_6.cb_5.triggerevent(clicked!)

	dw_28.retrieve(tab_1.tabpage_3.st_5.text)
end if

end event

event dw_1::clicked;call super::clicked;//pb_insert.enabled = true
dw_24.Visible  =  False
end event

event dw_1::buttonclicked;call super::buttonclicked;string ls_open, ls_zero, ls_salesman

///////////////////////////////////////////
// 사용불가 제외
///////////////////////////////////////////
if cbx_open.checked = true then
	ls_open = "O"
else
	ls_open = "%"
end if

///////////////////////////////////////////
// 잔액제로 제외
///////////////////////////////////////////
if cbx_zero.checked = true then
	ls_zero = "Y"
else
	ls_zero = "%"
end if

//// 담당자
//dw_salesman.accepttext()
//ls_salesman = dw_salesman.object.user[1]
ls_salesman = "%"

choose case dwo.name
	case 'b_1'
		dw_24.Visible  =  True
		dw_24.Retrieve( '가%', ls_open, ls_zero, ls_salesman )

	case 'b_2'
		dw_24.Visible  =  True
		dw_24.Retrieve( '나%', ls_open, ls_zero, ls_salesman )
	case 'b_3'
		dw_24.Visible  =  True
		dw_24.Retrieve( '다%', ls_open, ls_zero, ls_salesman )
	case 'b_4'
		dw_24.Visible  =  True
		dw_24.Retrieve( '라%', ls_open, ls_zero, ls_salesman )
	case 'b_5'
		dw_24.Visible  =  True
		dw_24.Retrieve( '마%', ls_open, ls_zero, ls_salesman )
	case 'b_6'
		dw_24.Visible  =  True
		dw_24.Retrieve( '바%', ls_open, ls_zero, ls_salesman )
	case 'b_7'
		dw_24.Visible  =  True
		dw_24.Retrieve( '사%', ls_open, ls_zero, ls_salesman )
	case 'b_8'
		dw_24.Visible  =  True
		dw_24.Retrieve( '아%', ls_open, ls_zero, ls_salesman )
	case 'b_9'
		dw_24.Visible  =  True
		dw_24.Retrieve( '자%', ls_open, ls_zero, ls_salesman )
	case 'b_10'
		dw_24.Visible  =  True
		dw_24.Retrieve( '차%', ls_open, ls_zero, ls_salesman )
	case 'b_11'
		dw_24.Visible  =  True
		dw_24.Retrieve( '카%', ls_open, ls_zero, ls_salesman )
	case 'b_12'
		dw_24.Visible  =  True
		dw_24.Retrieve( '타%', ls_open, ls_zero, ls_salesman )
	case 'b_13'
		dw_24.Visible  =  True
		dw_24.Retrieve( '파%', ls_open, ls_zero, ls_salesman )
	case 'b_14'
		dw_24.Visible  =  True
		dw_24.Retrieve( '하%', ls_open, ls_zero, ls_salesman )
	case 'b_16'
		dw_24.Visible  =  True
		dw_24.Retrieve( 'A%', ls_open, ls_zero, ls_salesman )
	case else
		dw_24.Visible  =  False
end choose

