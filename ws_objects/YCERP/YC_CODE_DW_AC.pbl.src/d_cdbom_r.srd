$PBExportHeader$d_cdbom_r.srd
$PBExportComments$BOM관리출력(1998/04/17 - 이인호)
release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=508 color="536870912" )
summary(height=16 color="536870912" )
footer(height=0 color="536870912" )
detail(height=68 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=assembly dbname="bom.assembly" )
 column=(type=char(20) update=yes updatewhereclause=yes name=assembly_qa dbname="bom.assembly_qa" )
 column=(type=long update=yes updatewhereclause=yes name=sequence dbname="bom.sequence" )
 column=(type=char(10) update=yes updatewhereclause=yes name=component dbname="bom.component" )
 column=(type=char(20) update=yes updatewhereclause=yes name=component_qa dbname="bom.component_qa" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=qpa dbname="bom.qpa" )
 column=(type=datetime update=yes updatewhereclause=yes name=effectivity dbname="bom.effectivity" )
 column=(type=datetime update=yes updatewhereclause=yes name=obsolete dbname="bom.obsolete" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=yield dbname="bom.yield" )
 column=(type=char(30) update=yes updatewhereclause=yes name=rem dbname="bom.rem" )
 column=(type=long updatewhereclause=yes name=parent_no dbname="bom.parent_no" )
 column=(type=char(1) updatewhereclause=yes name=parent_text dbname="parent_text" )
 column=(type=char(60) updatewhereclause=yes name=item_item_name dbname="item.item_name" )
 column=(type=char(2) updatewhereclause=yes name=item_uom dbname="item.uom" )
 column=(type=char(1) updatewhereclause=yes name=item_source dbname="item.source" values="완제품	W/구매품	B/조립품	M/외주품	S/" )
 column=(type=char(1) updatewhereclause=yes name=assy_name dbname="assy_name" )
 column=(type=char(1) updatewhereclause=yes name=assy_source dbname="assy_source" values="완제품	W/구매품	B/조립품	M/외주품	S/" )
 column=(type=long updatewhereclause=yes name=need_qty dbname="bom.need_qty" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"bom~" )  TABLE(NAME=~"item~" ) COLUMN(NAME=~"bom.assembly~") COLUMN(NAME=~"bom.assembly_qa~") COLUMN(NAME=~"bom.sequence~") COLUMN(NAME=~"bom.component~") COLUMN(NAME=~"bom.component_qa~") COLUMN(NAME=~"bom.qpa~") COLUMN(NAME=~"bom.effectivity~") COLUMN(NAME=~"bom.obsolete~") COLUMN(NAME=~"bom.yield~") COLUMN(NAME=~"bom.rem~") COMPUTE(NAME=~"0 parent_no~") COMPUTE(NAME=~"'' parent_text~") COLUMN(NAME=~"item.item_name~") COLUMN(NAME=~"item.uom~") COLUMN(NAME=~"item.source~") COMPUTE(NAME=~"'' assy_name~") COMPUTE(NAME=~"'' assy_source~") COMPUTE(NAME=~"0 need_qty~")    JOIN (LEFT=~"bom.component~"    OP =~"=~"RIGHT=~"item.item_no~" )    JOIN (LEFT=~"bom.component_qa~"    OP =~"=~"RIGHT=~"item.qa1~" )) " )
group(level=1 header.height=92 trailer.height=4 by=("assembly" , "assembly_qa" ) newpage=yes header.color="536870912" trailer.color="536870912"  sort="count(assembly for group 1) A count(assembly_qa for group 1) A " )
