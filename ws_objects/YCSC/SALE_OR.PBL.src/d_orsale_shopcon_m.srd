table(column=(type=char(10) updatewhereclause=yes name=area_no dbname="area_no" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(11) updatewhereclause=yes name=scene_code dbname="scene_code" initial=" " )
 column=(type=char(14) updatewhereclause=yes name=order_no dbname="order_no" initial=" " )
 column=(type=char(15) updatewhereclause=yes name=cust_po_no dbname="cust_po_no" )
 column=(type=char(1) updatewhereclause=yes name=sale_flag dbname="sale_flag" initial=" " values="내수	D/수출	E/L//C	L/" )
 column=(type=char(3) updatewhereclause=yes name=curr_code dbname="curr_code" initial=" " )
 column=(type=datetime updatewhereclause=yes name=order_date dbname="order_date" initial=" " )
 column=(type=datetime updatewhereclause=yes name=due_date dbname="due_date" initial=" " )
 column=(type=long updatewhereclause=yes name=seq_no dbname="seq_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=decimal(2) updatewhereclause=yes name=order_qty dbname="order_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=acc_qty dbname="acc_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=price dbname="price" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=char(10) updatewhereclause=yes name=c_start dbname="c_start" )
 column=(type=char(10) updatewhereclause=yes name=c_end dbname="c_end" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(1) updatewhereclause=yes name=jupsu_flag dbname="jupsu_flag" values="접수	Y/비접수	N/" )
 column=(type=datetime updatewhereclause=yes name=jupsu_date dbname="jupsu_date" )
 column=(type=char(14) updatewhereclause=yes name=sale_no dbname="sale_no" )
 column=(type=char(1) updatewhereclause=yes name=chk_yn dbname="chk_yn" values="	Y/	N" )
 retrieve="  SELECT area_no       = c.area_no           
       , cust_no       = c.cust_no           
       , cust_name     = a.cust_name         
       , scene_code    = c.scene_code        
       , order_no      = c.order_no          
       , cust_po_no    = c.cust_po_no
       , sale_flag     = c.sale_flag         
       , curr_code     = c.curr_code         
       , order_date    = c.order_date        
       , due_date      = c.due_date          
       , seq_no        = d.seq_no         
       , item_no       = d.item_no        
       , qa            = d.qa             
       , uom           = d.uom            
       , order_qty     = d.order_qty      
       , acc_qty       = d.acc_qty        
       , price         = d.price          
       , scene_desc    = e.scene_desc           
       , c_start       = (case when :as_sdate = '' then space(10) else :as_sdate end)   
       , c_end         = (case when :as_edate = '' then space(10) else :as_edate end)
       , user_name     = f.user_name            
       , item_name     = b.item_name        
       , jupsu_flag    = (case when s.order_no is null then 'N'  else 'Y'          end)
       , jupsu_date    = (case when s.order_no is null then null else c.jupsu_date end)
       , sale_no       = s.order_no
       , chk_yn        = 'N'
    FROM saleshop     C 
         LEFT OUTER JOIN saleshopdet  D ON c.order_no = d.order_no
         LEFT OUTER JOIN sale         S ON c.order_date = s.order_date AND c.order_no = s.cust_po_no
         LEFT OUTER JOIN groupitem    B ON d.item_no  = b.item_no  
         LEFT OUTER JOIN customer     A ON c.cust_no  = a.cust_no  
         LEFT OUTER JOIN scene        E ON c.cust_no  = e.cust_no AND c.scene_code = e.scene_code
         LEFT OUTER JOIN login        F ON a.salesman = f.user_id    
   WHERE ((:as_area   = '%' AND c.area_no LIKE :as_area ) OR
          (:as_area  <> '%' AND c.area_no    = :as_area )
         )
     AND ( c.order_date   BETWEEN :as_sdate AND :as_edate )
     AND ( c.open_close       NOT IN ('X','C') )   
" arguments=(("as_area", string),("as_sdate", string),("as_edate", string))  sort="user_name A order_no A order_date A seq_no A cust_name A scene_code A " )
group(level=1 header.height=0 trailer.height=72 by=("user_name" ) header.color="536870912" trailer.color="536870912" )
group(level=2 header.height=0 trailer.height=68 by=("cust_no" , "scene_code" , "order_no" ) header.color="536870912" trailer.color="536870912" )
