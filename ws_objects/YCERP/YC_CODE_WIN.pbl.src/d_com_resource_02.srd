 retrieve="select
	 a.management_no	management_no 
	,a.affiliate_type	affiliate_type     
	,a.device_nm		device_nm        
	,a.maker_nm			maker_nm         
	,a.maker_no			maker_no          
	,a.model_nm			model_nm         
	,a.os_type			os_type            
	,a.license_type	license_type      
	,a.maker_date		maker_date        
	,a.db_info			db_info             
	,a.ip_info			ip_info              
	,a.user_nm			user_nm           
	,a.dept_nm			dept_nm           
	,a.state_m				state_m    
	,a.state_d				state_d    
	,a.enter_date		enter_date           
	,a.delivery_date	delivery_date     
	,a.return_date		return_date       
	,a.disposal_date	disposal_date    
	,a.bigo				bigo                 
	,a.input_date		input_date        
	,a.input_user		input_user         
	,a.update_date		update_date      
	,a.update_user		update_user
	,a.area				area
	,a.cpu				cpu
	,a.ram				ram
	,a.vga				vga
	,a.ssd				ssd
	,a.hdd				hdd
	,a.mac_addr			mac_addr
from
	yc_com_resource a
where
	a.management_no	= :as_management_no
order by
	a.management_no" update="yc_com_resource" updatewhere=0 updatekeyinplace=no arguments=(("as_management_no", string)) )
