ll_del = 0
dw11.accepttext()
if MessageBox("확인","저장하시겠습니까?", Exclamation!, OKCancel!, 1) = 2 then
	RETURN
end if

// 작업자 투입현황 저장
if wf_update1(dw11,"Y") = false then
