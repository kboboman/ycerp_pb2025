 retrieve="  SELECT dc_groupno   = a.dc_groupno       
       , dc_date      = a.dc_date
       , user_id      = a.user_id
       , cust_no      = a.cust_no     
       , dc_type      = a.dc_type

       , dc_app1      = a.dc_app1     
       , dc_appdt1    = a.dc_appdt1
       , dc_app2      = a.dc_app2     
       , dc_appdt2    = a.dc_appdt2
       , dc_app3      = a.dc_app3     
       , dc_appdt3    = a.dc_appdt3
       , dc_app4      = a.dc_app4     
       , dc_appdt4    = a.dc_appdt4
       , dc_app5      = a.dc_app5     
       , dc_appdt5    = a.dc_appdt5

       , dc_rem1      = a.dc_rem1
       , dc_rem2      = a.dc_rem2
       , dc_rem3      = a.dc_rem3
       , dc_rem4      = a.dc_rem4
       , dc_rem5      = a.dc_rem5
    FROM dc_group  a
   WHERE ( a.dc_groupno      = :as_groupno )
" update="dc_group" updatewhere=1 updatekeyinplace=no arguments=(("as_groupno", string)) )
