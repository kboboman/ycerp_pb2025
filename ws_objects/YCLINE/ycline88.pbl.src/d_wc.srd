table(column=(type=char(10) updatewhereclause=yes name=work_no dbname="work_no" )
 column=(type=char(10) updatewhereclause=yes name=work_name dbname="work_name" )
 column=(type=char(1) updatewhereclause=yes name=work_type dbname="work_type" )
 column=(type=char(3) updatewhereclause=yes name=work_mes dbname="work_mes" )
 column=(type=char(10) updatewhereclause=yes name=def_loc dbname="def_loc" )
 column=(type=char(10) updatewhereclause=yes name=work_manager dbname="work_manager" )
 column=(type=char(1) updatewhereclause=yes name=use_yn dbname="use_yn" )
 column=(type=char(20) updatewhereclause=yes name=work_pos dbname="work_pos" )
 column=(type=char(10) updatewhereclause=yes name=area_no dbname="area_no" )
 column=(type=decimal(4) updatewhereclause=yes name=plan_qty dbname="plan_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=make_qty dbname="make_qty" )
 retrieve="  SELECT work_no      = a.work_no
       , work_name    = a.work_name
       , work_type    = a.work_type
       , work_mes     = a.work_mes
       , def_loc      = a.def_loc
       , work_manager = a.work_manager  
       , use_yn       = a.use_yn
       , work_pos     = a.work_pos
       , area_no      = a.area_no
       , plan_qty     = a.plan_qty
       , make_qty     = a.make_qty
    FROM (
         SELECT wc.work_no
              , wc.work_name
              , wc.work_type
              , wc.work_mes
              , wc.def_loc
              , wc.work_manager  
              , wc.use_yn
              , wc.work_pos
              , wc.area_no
              , plan_qty  = isnull(A.plan_qty,0)
              , make_qty  = isnull(A.make_qty,0)
              , cat       = 'LINE'
           FROM wc   
                LEFT OUTER JOIN (
                     SELECT start_date = mps.start_date         
                          , wc_no      = mpsdet.wc_no           
                          , plan_qty   = sum(routtempnew.plan_qty)
                          , make_qty   = sum(routtempnew.make_qty)
                       FROM routtempnew
                          , mps        
                          , mpsdet     
                      WHERE mps.order_no           = mpsdet.order_no
                        AND convert(char(10),mps.start_date,111)   = convert(char(10),getdate(),111)
                        AND mpsdet.mpsorder_order IS NOT NULL
                        AND mpsdet.wc_no        LIKE '%'
                        AND mps.area_no            = :as_area
                        AND routtempnew.sale_no    = mpsdet.sale_no
                        AND routtempnew.area_no    = mps.area_no
                        AND routtempnew.seq_no     = mpsdet.seq_no
                        AND routtempnew.operation  = mpsdet.operation
                        AND routtempnew.wc_no      = mpsdet.wc_no
                        AND routtempnew.division   = mpsdet.division
                        AND routtempnew.process_flag <> 'C'
                      GROUP BY mps.start_date, mpsdet.wc_no
                ) A   ON WC.WORK_NO = A.WC_NO         
          WHERE NOT (wc.work_mes is null or rtrim(ltrim(wc.work_mes)) = '')
            AND wc.use_yn    = 'Y'
            AND wc.area_no   = :as_area

       UNION ALL

       SELECT work_no   = 'COILM',      work_name = '코일이동',  work_type = 'D', work_mes = '999'
            , def_loc   = 'WS00000000', work_manager = '현종남', use_yn = 'Y',    work_pos = '시화-1'
            , area_no   = 'S0001',      plan_qty  = 0,           make_qty  = 0,   cat      = 'LINE'

       UNION ALL
       SELECT work_no, work_name, work_type, work_mes, def_loc, work_manager
            , use_yn,  work_pos,  area_no,   plan_qty, make_qty, 'SCAN'
         FROM V_WORK
       ) A
   WHERE ((:as_cat  = '%' AND a.cat LIKE '%') OR
          (:as_cat <> '%' AND a.cat    = :as_cat)
         )
   ORDER BY work_mes



" arguments=(("as_area", string),("as_cat", string)) )
