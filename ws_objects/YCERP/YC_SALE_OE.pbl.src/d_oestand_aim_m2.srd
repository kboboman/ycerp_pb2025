table(column=(type=char(4) update=yes updatewhereclause=yes name=sid dbname="SID" )
 column=(type=char(1) update=yes updatewhereclause=yes name=sidqa dbname="SIDQA" )
 column=(type=long update=yes updatewhereclause=yes name=sidqty dbname="SIDQTY" )
 column=(type=long updatewhereclause=yes name=seq dbname="seq" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(50) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="uom" )
 column=(type=char(30) update=yes updatewhereclause=yes name=qa dbname="qa" )
 column=(type=decimal(3) updatewhereclause=yes name=qty dbname="qty" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=act_price dbname="act_price" )
 column=(type=decimal(3) update=yes updatewhereclause=yes name=act_totqty dbname="act_totqty" )
 column=(type=decimal(2) updatewhereclause=yes name=atc_amount dbname="atc_amount" )
 retrieve="  SELECT SID            = a.sid                  /* 일위대가 SID  */
       , SIDQA          = ''                     /* 일위대가 규격 */
       , SIDQTY         = null                   /* 일위대가 물량 */
       , seq            = b.seq                  /* 순번          */
       , item_no        = b.item_no              /* 자재코드      */
       , item_name      = isnull(b.itemnm_p,b.itemnm_y)        /* 자재명        */
       , uom            = b.uom                  /* 단위          */
       , qa             = b.qa_p                 /* 자재규격      */
       , qty            = b.qty                  /* 소요량        */
       , act_price      = isnull(b.amt_p,0)      /* 단가          */
       , act_totqty     = isnull(b.qty,0)        /* 총수량        */
       , atc_amount     = isnull(b.std_amount,0) /* 금액          */
    FROM nbasis_mst       a
       , nbasis_det       b
   WHERE ( a.sid        = b.sid      )   
     AND ( a.sid        = :as_sid    )
     AND ( b.cat        = '1.자재비' )
   ORDER BY b.seq
" arguments=(("as_sid", string))  sort="seq A " )
