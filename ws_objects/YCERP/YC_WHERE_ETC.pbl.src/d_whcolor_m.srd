$PBExportHeader$d_whcolor_m.srd
$PBExportComments$수주칼라코드등록(1999/06/03,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(4) update=yes updatewhereclause=yes key=yes name=color_code dbname="color.color_code" )
 column=(type=char(10) update=yes updatewhereclause=yes name=color_name dbname="color.color_name" )
 column=(type=char(60) update=yes updatewhereclause=yes name=color_lname dbname="color.color_lname" )
 column=(type=char(4) update=yes updatewhereclause=yes name=cat1 dbname="color.cat1" )
 column=(type=char(4) update=yes updatewhereclause=yes name=cat2 dbname="color.cat2" )
 column=(type=long update=yes updatewhereclause=yes name=r dbname="color.R" )
 column=(type=long update=yes updatewhereclause=yes name=g dbname="color.G" )
 column=(type=long update=yes updatewhereclause=yes name=b dbname="color.B" )
 column=(type=char(50) update=yes updatewhereclause=yes name=maker dbname="color.maker" )
 column=(type=char(20) update=yes updatewhereclause=yes name=color_type dbname="color.color_type" )
 column=(type=char(50) update=yes updatewhereclause=yes name=product_no dbname="color.product_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=sample_no dbname="color.sample_no" )
 column=(type=char(255) update=yes updatewhereclause=yes name=color_bigo dbname="color.color_bigo" )
 column=(type=char(1) update=yes updatewhereclause=yes name=handle dbname="handle" initial="Y" values="	Y/	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=use_yn dbname="use_yn" initial="Y" values="	Y/	N" )
 column=(type=datetime update=yes updatewhereclause=yes name=sys_date dbname="color.sys_date" initial="getdate()" )
 column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" values="	Y/	N" )
 retrieve="  SELECT color.color_code   
       , color.color_name   
       , color.color_lname   
       , color.cat1   
       , color.cat2   
       , color.R   
       , color.G   
       , color.B   
       , color.maker   
       , color.color_type   
       , color.product_no   
       , color.sample_no   
       , color.color_bigo   
       , handle  = isnull(color.handle, 'N')
       , use_yn  = isnull(color.use_yn, 'N')
       , color.sys_date
       , chk     = 'N'
    FROM color   
   WHERE ((:as_maker  = '%' AND (color.maker LIKE :as_maker OR color.maker IS NULL) ) OR
          (:as_maker <> '%' AND color.maker     = :as_maker)
         )
     AND ((:as_useyn  = '%' AND color.use_yn LIKE :as_useyn) OR
          (:as_useyn <> '%' AND color.use_yn    = :as_useyn)
         )" update="color" updatewhere=1 updatekeyinplace=no arguments=(("as_maker", string),("as_useyn", string))  sort="maker D color_type A product_no A " )
