pb_alltime pb_alltime
pb_5 pb_5
dw_10 dw_10
dw_11 dw_11
end type

on tabpage_6.create
this.st_16=create st_16
this.pb_alltime=create pb_alltime
this.pb_5=create pb_5
this.dw_10=create dw_10
this.dw_11=create dw_11
this.Control[]={this.st_16,&
this.pb_alltime,&
this.pb_5,&
this.dw_10,&
this.dw_11}
end on

on tabpage_6.destroy
destroy(this.st_16)
destroy(this.pb_alltime)
destroy(this.pb_5)
destroy(this.dw_10)
destroy(this.dw_11)
end on

