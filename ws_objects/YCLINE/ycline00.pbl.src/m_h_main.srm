type m_exit1 from menu within m_manage
end type

event clicked;halt close  
end event

on m_exit1.create
call super::create
this.text = "종료(Exit)~tCtrl+X"
this.shortcut = 344
end on

on m_exit1.destroy
call super::destroy
end on

type m_utility from menu within m_h_main
m_ezhelp m_ezhelp
m_winvnc m_winvnc
m_librarys m_librarys
end type

on m_utility.create
call super::create
this.text = "원격지원(&Tool)"
this.m_ezhelp=create m_ezhelp
this.m_winvnc=create m_winvnc
this.m_librarys=create m_librarys
this.Item[UpperBound(this.Item)+1]=this.m_ezhelp
this.Item[UpperBound(this.Item)+1]=this.m_winvnc
this.Item[UpperBound(this.Item)+1]=this.m_librarys
end on

on m_utility.destroy
call super::destroy
destroy(this.m_ezhelp)
destroy(this.m_winvnc)
destroy(this.m_librarys)
end on

type m_ezhelp from menu within m_utility
end type

event clicked;//
inet iinet_base
string ls_url

ls_url = "http://ezh.kr/yoochang"
GetContextService("Internet", iinet_base)
iinet_base.HyperlinkToURL( ls_url )

end event

on m_ezhelp.create
call super::create
this.text = "원격지원(&Help)~tCtrl+Alt+H"
this.shortcut = 840
end on

on m_ezhelp.destroy
call super::destroy
end on

type m_winvnc from menu within m_utility
end type

on m_winvnc.create
call super::create
this.text = "원격지원(&VNC)~tCtrl+Alt+V"
this.shortcut = 854
end on

on m_winvnc.destroy
call super::destroy
end on

event clicked;
RUN ("WinVNC.exe") 

end event

type m_librarys from menu within m_utility
end type

event clicked;//opensheet(w_orsalesaleman_r_2, parentwindow, 5, original!)
//
OpenSheetWithParm( w_librarys, This.Text + '[w_librarys]', ParentWindow, 6, Layered! )

end event

on m_librarys.create
call super::create
this.text = "Librarys 목록"
this.enabled = false
end on

on m_librarys.destroy
call super::destroy
end on

type m_window from menu within m_h_main
m_leftmenu m_leftmenu
m_layered m_layered
m_cascade m_cascade
end type

on m_window.create
call super::create
this.text = "윈도우(&Window)"
this.m_leftmenu=create m_leftmenu
this.m_layered=create m_layered
this.m_cascade=create m_cascade
this.Item[UpperBound(this.Item)+1]=this.m_leftmenu
this.Item[UpperBound(this.Item)+1]=this.m_layered
this.Item[UpperBound(this.Item)+1]=this.m_cascade
end on

on m_window.destroy
call super::destroy
destroy(this.m_leftmenu)
destroy(this.m_layered)
destroy(this.m_cascade)
end on

type m_leftmenu from menu within m_window
end type

on m_leftmenu.create
call super::create
this.visible = false
this.text = "LeftMenu"
end on

on m_leftmenu.destroy
call super::destroy
end on

event clicked;OpenSheetWithParm(w_bgr, This.Text + '[w_bgr]', ParentWindow, 6, Layered!)

end event

type m_layered from menu within m_window
end type

on m_layered.create
call super::create
this.text = "Layered"
end on

event clicked;//
parentwindow.ArrangeSheets(Layer!)  // Cascade!,Layer!,Tile!,TileHorizontal!,Icons! 
end event

on m_layered.destroy
call super::destroy
end on

type m_cascade from menu within m_window
end type

on m_cascade.create
call super::create
this.text = "Cascade"
end on

event clicked;//
parentwindow.ArrangeSheets(Cascade!)  // Cascade!,Layer!,Tile!,TileHorizontal!,Icons! 
end event

on m_cascade.destroy
call super::destroy
end on

