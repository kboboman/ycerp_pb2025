$PBExportComments$물품별수주일보(상세,전체)(1999/06/03, 이인호)
release 8;
datawindow(units=0 timer_interval=60000 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=1 selected.mouse=no )
header(height=296 color="536870912" )
summary(height=72 color="536870912" )
footer(height=4 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 column=(type=datetime updatewhereclause=yes name=sale_due_date dbname="sale.due_date" initial=" " )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" initial=" " )
 column=(type=char(20) updatewhereclause=yes name=saledet_qa dbname="saledet.qa" )
 column=(type=char(2) updatewhereclause=yes name=saledet_uom dbname="saledet.uom" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_order_qty dbname="saledet.order_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_acc_qty dbname="saledet.acc_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=saledet_price dbname="saledet.price" )
 column=(type=char(14) updatewhereclause=yes name=sale_order_no dbname="sale.order_no" initial=" " )
 column=(type=char(10) updatewhereclause=yes name=saledet_item_no dbname="saledet.item_no" )
 retrieve="  SELECT customer.cust_name,   
         scene.scene_desc,   
         sale.due_date,   
         groupitem.item_name,   
         saledet.qa,   
         saledet.uom,   
         saledet.order_qty,   
         saledet.acc_qty,   
         saledet.price,   
         sale.order_no,   
         saledet.item_no  
    FROM sale LEFT OUTER JOIN scene WITH(NOLOCK) ON sale.scene_code = scene.scene_code
                        INNER JOIN saledet WITH(NOLOCK) ON sale.order_no = saledet.order_no
                        INNER JOIN customer WITH(NOLOCK) ON sale.cust_no = customer.cust_no
                        INNER JOIN groupitem WITH(NOLOCK) ON saledet.item_no = groupitem.item_no
   WHERE  ( 
                          ( sale.open_close = 'O' ) AND  
                          ( sale.order_date between :arg_date1 and :arg_date2 ) AND  
                          ( groupitem.source like :arg_source ) 
                    ) 
ORDER BY saledet.item_no ASC,   
         saledet.qa ASC,   
         sale.due_date ASC   
/*
    FROM sale,   
         saledet,   
         customer,   
         scene,   
         groupitem  
   WHERE ( sale.scene_code *= scene.scene_code) and  
         ( sale.order_no = saledet.order_no ) and  
         ( sale.cust_no = customer.cust_no ) and  
         ( saledet.item_no = groupitem.item_no ) and  
         ( ( sale.open_close = 'O' ) AND  
         ( sale.order_date between :arg_date1 and :arg_date2 ) AND  
         groupitem.source like :arg_source )   
ORDER BY saledet.item_no ASC,   
         saledet.qa ASC,   
         sale.due_date ASC   
*/" arguments=(("arg_date1", date),("arg_date2", date),("arg_source", string))  sort="saledet_item_no A saledet_qa A sale_due_date A " )
group(level=1 header.height=0 trailer.height=80 by=("saledet_item_no" ) header.color="536870912" trailer.color="553648127" )
