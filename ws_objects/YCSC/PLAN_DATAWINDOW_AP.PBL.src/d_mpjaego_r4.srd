 retrieve="SELECT  ORDER_NO, ITEM_NO, QA, ORDER_QTY, QOH, REM, EN_DATE
  FROM  SALE_JAEGO
 WHERE  EN_DATE BETWEEN  :ag_date1  AND :ag_date2
   AND  EN_DATE IS NOT NULL" update="SALE_JAEGO" updatewhere=1 updatekeyinplace=no arguments=(("ag_date1", date),("ag_date2", date))  sort="en_date A order_no A item_no A qa A order_qty A " )
