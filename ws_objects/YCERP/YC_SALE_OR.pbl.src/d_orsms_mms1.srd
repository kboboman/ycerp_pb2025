$PBExportHeader$d_orsms_mms1.srd
$PBExportComments$MMS 전송리스트
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=136 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=88 color="536870912" )
table(column=(type=char(16) updatewhereclause=yes name=tr_senddate dbname="tr_senddate" )
 column=(type=char(50) updatewhereclause=yes name=tr_phone dbname="tr_phone" )
 column=(type=char(50) updatewhereclause=yes name=tr_phonename dbname="tr_phonename" )
 column=(type=char(1) updatewhereclause=yes name=tr_callback dbname="tr_callback" )
 column=(type=char(4099) updatewhereclause=no name=tr_msg dbname="tr_msg" )
 column=(type=char(62) updatewhereclause=yes name=tr_etc6 dbname="tr_etc6" )
 retrieve="  SELECT tr_senddate = m.send_date
       , tr_phone    = m.reserved1
       , tr_phonename= m.reserved2
       , tr_callback = ''
       , tr_msg      = m.mms_msg
       , tr_etc6     = rtrim(login.user_name) + '[' + m.reserved1 + ']'
    FROM sdk_mms_report M
       , login
   WHERE ( m.user_id = login.user_id )
     AND ( substring(m.send_date,1,8) BETWEEN replace(:as_sdate,'/','') AND replace(:as_edate,'/','') )
     AND ( m.user_id = :as_userid  OR (:as_admin = 'Y' AND m.user_id LIKE '%') )
" arguments=(("as_userid", string),("as_sdate", string),("as_edate", string),("as_admin", string)) )
