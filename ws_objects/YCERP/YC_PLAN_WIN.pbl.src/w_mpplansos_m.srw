type cb_17 from commandbutton within tabpage_3
integer x = 2395
integer y = 4
integer width = 256
integer height = 76
integer taborder = 80
boolean bringtotop = true
integer textsize = -10
integer weight = 400
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "공정CHK"
end type

event clicked;long   ll_row, op1, op2, op3, op4, op5, ll_ops
string item_no, item_nm, assy1, assy2, assy3, assy4, assy5, assynm1, assynm2, assynm3, assynm4, assynm5

for ll_row = 1 to dw7.rowcount()
	op1 = dw7.object.op1[ll_row]
	op2 = dw7.object.op2[ll_row]
	op3 = dw7.object.op3[ll_row]
	op4 = dw7.object.op4[ll_row]
	op5 = dw7.object.op5[ll_row]
	
	item_no = dw7.object.item_no[ll_row]
	item_nm = dw7.object.item_nm[ll_row]
	assy1   = dw7.object.assy1[ll_row]
	assy2   = dw7.object.assy2[ll_row]
	assy3   = dw7.object.assy3[ll_row]
	assy4   = dw7.object.assy4[ll_row]
	assy5   = dw7.object.assy5[ll_row]
	assynm1 = dw7.object.assynm1[ll_row]
	assynm2 = dw7.object.assynm2[ll_row]
	assynm3 = dw7.object.assynm3[ll_row]
	assynm4 = dw7.object.assynm4[ll_row]
	assynm5 = dw7.object.assynm5[ll_row]

	ll_ops = op1 + op2 + op3 + op4 + op5
	dw7.object.chk[ll_row] = 0
	choose case ll_ops
		case 1	// 1 공정
			if item_no <> assy1 then dw7.object.chk[ll_row] = 1
			
		case 3	// 2 공정
			if item_no <> assy2 then dw7.object.chk[ll_row] = 1
			if assy1    = assy2 then dw7.object.chk[ll_row] = 1
			// 제품의 규격에서 공정수가 다른것이 존재함
			if dw7.object.chk[ll_row] = 1 then
				if assynm1 <> assynm2 then dw7.object.chk[ll_row] = 2 
			end if
		
		case 6	// 3 공정
			if item_no <> assy3 then dw7.object.chk[ll_row] = 1
			if assy1    = assy2 then dw7.object.chk[ll_row] = 1
			if assy2    = assy3 then dw7.object.chk[ll_row] = 1
			// 제품의 규격에서 공정수가 다른것이 존재함
			if dw7.object.chk[ll_row] = 1 then
				if assynm1 <> assynm2 Or assynm2 <> assynm3 then dw7.object.chk[ll_row] = 2 
			end if

		case 10	// 4 공정
			if item_no <> assy4 then dw7.object.chk[ll_row] = 1
			if assy1    = assy2 then dw7.object.chk[ll_row] = 1
			if assy2    = assy3 then dw7.object.chk[ll_row] = 1
			if assy3    = assy4 then dw7.object.chk[ll_row] = 1
			// 제품의 규격에서 공정수가 다른것이 존재함
			if dw7.object.chk[ll_row] = 1 then
				if assynm1 <> assynm2 Or assynm2 <> assynm3 Or assynm3 <> assynm4 then dw7.object.chk[ll_row] = 2
			end if

		case 15	// 5 공정
			if item_no <> assy5 then dw7.object.chk[ll_row] = 1
			if assy1    = assy2 then dw7.object.chk[ll_row] = 1
			if assy2    = assy3 then dw7.object.chk[ll_row] = 1
			if assy3    = assy4 then dw7.object.chk[ll_row] = 1
			if assy4    = assy5 then dw7.object.chk[ll_row] = 1
			// 제품의 규격에서 공정수가 다른것이 존재함
			if dw7.object.chk[ll_row] = 1 then
				if assynm1 <> assynm2 Or assynm2 <> assynm3 Or assynm3 <> assynm4 Or assy4 <> assy5 then dw7.object.chk[ll_row] = 2
			end if
	end choose
next

end event

