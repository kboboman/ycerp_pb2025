 column=(type=char(10) updatewhereclause=yes name=login_id dbname="apoiinv.login_id" )
 column=(type=char(40) updatewhereclause=yes name=rem dbname="apoiinv.rem" )
 column=(type=decimal(0) updatewhereclause=yes name=dc dbname="apoiinv.dc" )
 column=(type=char(30) updatewhereclause=yes name=supp_name dbname="supp.supp_name" )
 column=(type=decimal(0) updatewhereclause=yes name=dc_rate dbname="apoiinv.dc_rate" )
 column=(type=decimal(0) updatewhereclause=yes name=discount dbname="apoiinv.discount" )
 column=(type=char(3) updatewhereclause=yes name=inv_area dbname="apoiinv.inv_area" )
 retrieve="  SELECT apoiinv.apoiinv_no,   
         apoiinv.supp_no,   
         apoiinv.pur_flag,   
         apoiinv.register_no,   
         apoiinv.inv_type,   
         apoiinv.oi_date,   
         apoiinv.curr_code,   
         apoiinv.gl_cur_rate,   
         apoiinv.apoiinv_cash,   
         apoiinv.apoiinv_rate,   
         apoiinv.ship_cost,   
         apoiinv.printed,   
         apoiinv.open_close,   
         apoiinv.close_date,   
         apoiinv.delete_flag,   
         apoiinv.sys_date,   
         apoiinv.login_id,   
         apoiinv.rem,   
         apoiinv.dc,   
         supp.supp_name,   
         apoiinv.dc_rate,   
         apoiinv.discount,   
         apoiinv.inv_area  
    FROM apoiinv,   
         supp  
   WHERE ( apoiinv.supp_no = supp.supp_no )    
" )
