$PBExportHeader$d_cdscene_approval.srd
$PBExportComments$현장관리 승인 적용
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=92 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=login_user_name dbname="user_name" )
 column=(type=char(4) updatewhereclause=yes name=scene_cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="cust_name" )
 column=(type=char(11) updatewhereclause=yes key=yes name=scene_scene_code dbname="scene_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene_desc" )
 column=(type=char(50) updatewhereclause=yes name=gubun dbname="gubun" )
 column=(type=char(10) updatewhereclause=yes name=scene_scene_charge dbname="scene_charge" )
 column=(type=char(10) updatewhereclause=yes name=scene_area_nm dbname="area_nm" )
 column=(type=char(20) updatewhereclause=yes name=scene_project_nm dbname="project_nm" )
 column=(type=char(20) updatewhereclause=yes name=scene_owner dbname="owner" )
 column=(type=char(80) updatewhereclause=yes name=rem dbname="rem" )
 column=(type=datetime updatewhereclause=yes name=start_date dbname="start_date" )
 column=(type=datetime updatewhereclause=yes name=end_date dbname="end_date" )
 column=(type=char(15) updatewhereclause=yes name=scene_scene_tel dbname="scene_tel" )
 column=(type=char(15) updatewhereclause=yes name=scene_scene_telcap dbname="scene_telcap" )
 column=(type=char(40) updatewhereclause=yes name=scene_scale dbname="scene_scale" )
 column=(type=char(80) updatewhereclause=yes name=scene_addr dbname="scene_addr" )
 column=(type=datetime updatewhereclause=yes name=scene_input_date dbname="input_date" )
 column=(type=datetime updatewhereclause=yes name=scene_gen_date dbname="gen_date" )
 column=(type=char(10) updatewhereclause=yes name=login_input_user_name dbname="input_user_name" )
 column=(type=char(1) update=yes updatewhereclause=yes name=approval_yn dbname="approval_yn" values="	Y/	N" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="user_id" )
 column=(type=char(10) updatewhereclause=yes name=salesman dbname="salesman" )
 retrieve="SELECT 
	 login.user_name					user_name
	,scene.cust_no   					cust_no
	,customer.cust_name  			cust_name 	
	,scene.scene_code   				scene_code
	,scene.scene_desc   				scene_desc
	,(select a.item_nm from codemst a where a.type = '현장구분' and a.use_yn = 'Y' and a.item_cd = scene.gubun ) gubun
	,scene.scene_charge				scene_charge	
	,scene.area_nm   					area_nm
	,scene.project_nm   				project_nm
	,scene.owner         			owner 	
	,isnull(scene.rem,'')			rem   
	,isnull(scene.start_date,'')	start_date   
	,isnull(scene.end_date,'')   	end_date
	,scene.scene_tel   				scene_tel
	,scene.scene_telcap   			scene_telcap
	,isnull(scene.scene_scale,'')	scene_scale   
	,isnull(scene.scene_addr,'')  scene_addr 
	,scene.input_date  				input_date
	,scene.gen_date  					gen_date
	,l2.user_name 						input_user_name
	,scene.approval_yn				approval_yn
	,scene.user_id						user_id	
	,customer.salesman				salesman
FROM scene
	LEFT OUTER JOIN customer ON scene.cust_no  = customer.cust_no
	LEFT OUTER JOIN login    ON customer.salesman = login.user_id
	LEFT OUTER JOIN login L2 ON scene.user_id  = l2.user_id
WHERE ( scene.gen_date between :ad_sdate + ' 00:00:00' AND :ad_edate + ' 23:59:59' )
AND
	isnull(scene.approval_yn,'Y') = 'N'" update="scene" updatewhere=0 updatekeyinplace=no arguments=(("ad_sdate", date),("ad_edate", date)) )
