 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"item~" )  TABLE(NAME=~"saledet~" ) COLUMN(NAME=~"saledet.order_no~") COLUMN(NAME=~"saledet.item_no~") COLUMN(NAME=~"saledet.due_date~") COLUMN(NAME=~"saledet.order_qty~") COLUMN(NAME=~"saledet.rlse_date~") COLUMN(NAME=~"saledet.price~") COLUMN(NAME=~"saledet.uom~") COLUMN(NAME=~"saledet.rlse_qty~") COLUMN(NAME=~"saledet.saledet_text~") COLUMN(NAME=~"saledet.loc_no~") COLUMN(NAME=~"saledet.issue_qty~") COLUMN(NAME=~"item.item_name~") COLUMN(NAME=~"saledet.qa~")    JOIN (LEFT=~"item.item_no~"    OP =~"=~"RIGHT=~"saledet.item_no~" )    JOIN (LEFT=~"item.qa~"    OP =~"=~"RIGHT=~"saledet.qa~" )WHERE(    EXP1 =~"saledet.order_no~"   OP =~"=~"    EXP2 =~":as_orderno~" ) ) ARG(NAME = ~"as_orderno~" TYPE = string) " arguments=(("as_orderno", string)) )
