table(column=(type=char(12) update=yes updatewhereclause=yes key=yes name=rqs_no dbname="rawmtrorderuse.rqs_no" )
 column=(type=char(23) update=yes updatewhereclause=yes key=yes name=input_dt dbname="rawmtrorderuse.input_dt" )
 column=(type=char(10) update=yes updatewhereclause=yes name=input_id dbname="rawmtrorderuse.input_id" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=used_qty dbname="rawmtrorderuse.used_qty" )
 column=(type=char(3) update=yes updatewhereclause=yes name=used_uom dbname="rawmtrorderuse.used_uom" )
 retrieve="select 
	 a.rqs_no		rqs_no
	,a.input_dt		input_dt
	,a.input_id		input_id
	,a.used_qty		used_qty
	,a.used_uom		used_uom
from 
	rawmtrorderuse a
where
	a.rqs_no	= :as_rqs_no
order by
	a.input_dt desc
" update="rawmtrorderuse" updatewhere=1 updatekeyinplace=no arguments=(("as_rqs_no", string)) )
