type dw_4 from datawindow within tabpage_1
integer x = 14
integer y = 108
integer width = 3456
integer height = 1140
integer taborder = 30
string title = "none"
string dataobject = "d_lot_trace1"
boolean hscrollbar = true
boolean vscrollbar = true
boolean hsplitscroll = true
boolean livescroll = true
borderstyle borderstyle = stylelowered!
end type

event clicked;// 스리팅계획
string ls_coilno, ls_coilorder

if this.rowcount() < 1 then RETURN

dw5.reset()		// 스리팅지시
dw6.reset()		// 발주서
dw7.reset()		// 발주입고
dw8.reset()		// 코일이동
dw9.reset()		// 작업일보등록
dw10.reset()	// 전체보기

choose case dwo.name
	case "pcoil_no"
		ls_coilno    = this.object.pcoil_no[row]
		if ls_coilno = "원코일" then
		else
			tab_1.tabpage_1.sle_lotno.text   = ls_coilno
			dw4.retrieve( ls_coilno )   	// 스리팅계획
		end if

	case else		
		ls_coilno    = this.object.coil_no[row]
		ls_coilorder = this.object.coilorder_order[row]
		dw5.retrieve( ls_coilno, ls_coilorder )		// 스리팅지시
		
		if dw5.rowcount() > 0 then
			tab_1.selectedtab = 2
			tab_1.postevent( selectionchanged! )
		end if
end choose
end event

event retrieveend;// 전체보기 실행
string ls_lotno

if this.rowcount() < 1 then RETURN

tab_1.tabpage_7.tabtextcolor = rgb(0, 0, 0)
ls_lotno = this.object.coil_no[1]

if MidA(ls_lotno,2,1) = "C" then
	dw10.retrieve( ls_lotno )
	if dw10.rowcount() > 0 then
		tab_1.tabpage_7.tabtextcolor = rgb(255, 0, 0)
	end if	
end if

end event

