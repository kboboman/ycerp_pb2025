table(column=(type=char(20) updatewhereclause=yes name=pcoil_no dbname="pcoil_no" )
 column=(type=char(20) updatewhereclause=yes name=coil_no dbname="coil_no" )
 column=(type=char(1) updatewhereclause=yes name=proc_flag dbname="proc_flag" )
 column=(type=char(1) updatewhereclause=yes name=work_type dbname="work_type" )
 column=(type=datetime updatewhereclause=yes name=order_date dbname="order_date" )
 column=(type=char(14) updatewhereclause=yes name=coilorder_order dbname="coilorder_order" )
 column=(type=long updatewhereclause=yes name=seq dbname="seq" )
 column=(type=char(1) updatewhereclause=yes name=sheet dbname="sheet" )
 column=(type=decimal(4) updatewhereclause=yes name=unit_qty dbname="unit_qty" )
 column=(type=decimal(1) updatewhereclause=yes name=wid dbname="wid" )
 column=(type=long updatewhereclause=yes name=cnt dbname="cnt" )
 column=(type=char(10) updatewhereclause=yes name=loc_no dbname="loc_no" )
 column=(type=char(30) updatewhereclause=yes name=loc_name dbname="loc_name" )
 column=(type=char(1) updatewhereclause=yes name=cproc_flag dbname="proc_flag" )
 retrieve=" SELECT pcoil_no          = d.pcoil_no
      , coil_no           = a.coil_no
      , proc_flag         = a.proc_flag
      , work_type         = a.work_type
      , order_date        = a.order_date
      , coilorder_order   = a.coilorder_order
      , seq               = b.seq
      , sheet             = b.sheet
      , unit_qty          = b.unit_qty
      , wid               = b.wid
      , cnt               = b.cnt
      , loc_no            = b.loc_no
      , loc_name          = c.loc_name
      , proc_flag         = b.proc_flag
   FROM coilorderdet a
        LEFT OUTER JOIN coilsliting  b  ON a.order_no = b.order_no
        LEFT OUTER JOIN location     c  ON b.loc_no   = c.loc_no
        LEFT OUTER JOIN coilmst      d  ON a.coil_no  = d.coil_no
  WHERE a.coil_no     = :as_lotno
  ORDER BY coilorder_order, seq
" arguments=(("as_lotno", string)) )
