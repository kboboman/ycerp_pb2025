$PBExportHeader$d_ocshipcon_s2.srd
$PBExportComments$운반비변경요청결재관리상세 (2002/08/28,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=248 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=doship_no dbname="doshipdet.doship_no" )
 column=(type=long updatewhereclause=yes name=seq dbname="doshipdet.seq" )
 column=(type=char(14) updatewhereclause=yes name=do_no dbname="doshipdet.do_no" )
 column=(type=char(1) updatewhereclause=yes name=old_shipflag dbname="doshipdet.old_shipflag" values="착불	C/대여	D/부담	B/시화방문	M/화곡방문	H/반월방문	Y/" )
 column=(type=char(1) updatewhereclause=yes name=new_shipflag dbname="doshipdet.new_shipflag" values="대여	D/부담	B/공사원가	A/재료원가	R/" )
 column=(type=char(50) updatewhereclause=yes name=ship_reason1 dbname="doshipdet.ship_reason1" )
 column=(type=datetime updatewhereclause=yes name=do_do_date dbname="do.do_date" )
 column=(type=char(1) updatewhereclause=yes name=do_ship_flag dbname="do.ship_flag" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="SCENE.scene_desc" )
 column=(type=decimal(0) updatewhereclause=yes name=do_ship_amount dbname="do.ship_amount" )
 column=(type=char(12) updatewhereclause=yes name=do_driver dbname="do.driver" )
 column=(type=char(50) updatewhereclause=yes name=ship_reason2 dbname="doshipdet.ship_reason2" )
 column=(type=char(50) updatewhereclause=yes name=ship_reason3 dbname="doshipdet.ship_reason3" )
 column=(type=char(1) updatewhereclause=yes name=do_ship_close dbname="do.ship_close" values="진행중	O/마감완료	C/" )
 column=(type=char(1) updatewhereclause=yes name=shipamt_case dbname="do.shipamt_case" )
 column=(type=char(180) updatewhereclause=yes name=sale_no dbname="sale_no" )
 retrieve="  SELECT doshipdet.doship_no,   
         doshipdet.seq,   
         doshipdet.do_no,   
         doshipdet.old_shipflag,   
         doshipdet.new_shipflag,   
         doshipdet.ship_reason1,   
         do.do_date,   
         do.ship_flag,   
         customer.cust_name,   
         scene.scene_desc,   
         do.ship_amount,   
         do.driver,   
         doshipdet.ship_reason2,   
         doshipdet.ship_reason3,   
         do.ship_close,   
         do.shipamt_case ,   
         sale_no = DBO.uf_getdosaleno(do.do_no)  
    FROM do WITH(nolock) left outer join  scene WITH(nolock) on do.spot_code = scene.scene_code
          inner join customer WITH(nolock) on do.cust_no = customer.cust_no
          inner join doshipdet WITH(nolock) on do.do_no = doshipdet.do_no
   WHERE ( ( doshipdet.doship_no = :ship_no ) )    
/*
    FROM doshipdet,   
         customer,   
         do,   
         scene  
   WHERE ( do.spot_code *= scene.scene_code) and  
         ( do.cust_no = customer.cust_no ) and  
         ( doshipdet.do_no = do.do_no ) and  
         ( ( doshipdet.doship_no = :ship_no ) )    

*/" arguments=(("ship_no", string)) )
