$PBExportHeader$d_whissuereq_s.srd
$PBExportComments$일별출고의뢰자 조회
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no rows_per_detail = 20 )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=68 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=issuereq_req_date dbname="issuereq.req_date" )
 column=(type=char(10) updatewhereclause=yes name=issuereq_salesman dbname="issuereq.salesman" )
 column=(type=long updatewhereclause=yes name=issuereq_req_seq dbname="issuereq.req_seq" )
 column=(type=char(1) updatewhereclause=yes name=issuereq_confirm_flag dbname="issuereq.confirm_flag" )
 column=(type=char(10) updatewhereclause=yes name=issuereq_accept_user dbname="issuereq.accept_user" )
 column=(type=char(12) updatewhereclause=yes name=cuser_name dbname="cuser_name" )
 retrieve="  SELECT issuereq.req_date
       , issuereq.salesman   
       , issuereq.req_seq   
       , issuereq.confirm_flag
       , issuereq.accept_user
       , cuser_name = rtrim(login.user_name) + convert(char(2), req_seq) 
    FROM login   
       , issuereq  
   WHERE ( issuereq.salesman         = login.user_id ) 
     AND ( issuereq.req_date         = :ad_date      ) 
     AND ( issuereq.accept_area   LIKE :as_area      ) 
     AND ( issuereq.confirm_flag  LIKE :as_flag      ) 
     AND ( issuereq.accept_user   LIKE :as_acceptuser)
     AND ((:as_salesman  = '%' AND issuereq.salesman LIKE :as_salesman) OR
          (:as_salesman <> '%' AND issuereq.salesman    = :as_salesman)
         )" arguments=(("as_area", string),("ad_date", date),("as_flag", string),("as_salesman", string),("as_acceptuser", string)) )
