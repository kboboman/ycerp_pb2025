 column=(type=char(255) update=yes updatewhereclause=yes name=contents dbname="sfcworkman.contents" )
 column=(type=char(100) update=yes updatewhereclause=yes name=company dbname="sfcworkman.company" )
 column=(type=char(1) update=yes updatewhereclause=yes name=booking dbname="sfcworkman.booking" )
 column=(type=char(1) update=yes updatewhereclause=yes name=absent dbname="sfcworkman.absent" values="	Y/	N" )
 column=(type=datetime update=yes updatewhereclause=yes name=sys_date dbname="sfcworkman.sys_date" )
 column=(type=long updatewhereclause=yes name=sortkey dbname="sortkey" )
 column=(type=char(10) updatewhereclause=yes name=uid_org dbname="uid_org" )
 column=(type=char(1) updatewhereclause=yes name=timecard dbname="timecard" values="	Y/	N" )
 retrieve="  SELECT chk       = 'N'
       , sfcworkman.area_no   
       , area_name = a.area_name   
       , sfcworkman.work_no   
       , sfcworkman.work_nm  
       , sfcworkman.work_day   
       , sfcworkman.user_id   
       , sfcworkman.work_stime   
       , sfcworkman.work_etime   
       , chk_time   = (case when convert(char(8),sfcworkman.work_stime,108) <= '12:00:00' AND
                                 convert(char(8),sfcworkman.work_etime,108) >= '13:00:00'  
                                 then (datediff(mi, sfcworkman.work_stime, sfcworkman.work_etime) - 60.0) / 60.0    /* 1시간공제 */
                            else datediff(mi, sfcworkman.work_stime, sfcworkman.work_etime) / 60.0                  /* 순수시간 */
                       end)
       , sfcworkman.name_kor   
       , sfcworkman.job_no 
       , sfcworkman.job_name
       , sfcworkman.confirm1   
       , sfcworkman.confirm2   
       , sfcworkman.confirm3   
       , sel        = space(2)
       , sfcworkman.man_type   
       , sfcworkman.day_labor
       , sfcworkman.contents   
       , sfcworkman.company   
       , sfcworkman.booking   
       , sfcworkman.absent
       , sfcworkman.sys_date   
       , sortkey   = (case when sfcworkman.work_nm = sfcworkman.job_name then 1
                           else 2
                      end)
       , uid_org   = sfcworkman.user_id   
       , timecard  = 'N'
    FROM sfcworkman
         LEFT OUTER JOIN area A ON sfcworkman.area_no = a.area_no   
   WHERE ((:as_area    = '%' AND sfcworkman.area_no LIKE :as_area) OR
          (:as_area   <> '%' AND sfcworkman.area_no    = :as_area)
         )
     AND ((:as_workno  = '%' AND sfcworkman.work_no LIKE :as_workno) OR
          (:as_workno <> '%' AND sfcworkman.work_no    = :as_workno)
         )
     AND ( sfcworkman.work_day  between :as_sdate AND :as_edate    )
" update="sfcworkman" updatewhere=0 updatekeyinplace=no arguments=(("as_area", string),("as_workno", string),("as_sdate", string),("as_edate", string))  sort="work_nm A work_day D sortkey A job_name A day_labor A man_type A name_kor A work_stime A " )
