$PBExportHeader$d_mpslitio_r1.srd
$PBExportComments$코일수불현황조회(원코일)(2001/05/08,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=400 color="536870912" )
summary(height=84 color="536870912" )
footer(height=0 color="536870912" )
detail(height=84 color="536870912" )
table(column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(20) updatewhereclause=yes name=coilmst_qa dbname="coilmst.qa" )
 column=(type=long updatewhereclause=yes name=cnt dbname="coilsliting.cnt" )
 column=(type=decimal(4) updatewhereclause=yes name=coilsliting_unit_qty dbname="coilsliting.unit_qty" )
 column=(type=datetime updatewhereclause=yes name=start_date dbname="start_date" )
 column=(type=datetime updatewhereclause=yes name=end_date dbname="end_date" )
 column=(type=decimal(4) updatewhereclause=yes name=tot_qty dbname="tot_qty" )
 column=(type=decimal(15) updatewhereclause=yes name=rate dbname="rate" )
 column=(type=char(14) updatewhereclause=yes name=coilorder_order_no dbname="coilorder.order_no" )
 column=(type=char(14) updatewhereclause=yes name=coilorderdet_order_no dbname="coilorderdet.order_no" )
 column=(type=decimal(1) updatewhereclause=yes name=swid dbname="swid" )
 column=(type=char(1) updatewhereclause=yes name=coilorder_wc_place dbname="coilorder.wc_place" values="내	I/외	O/" )
 column=(type=long updatewhereclause=yes name=coilsliting_seq dbname="coilsliting.seq" )
 column=(type=long updatewhereclause=yes name=coilmst_unit_qty dbname="coilmst.unit_qty" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="coilsliting.item_no" )
 column=(type=char(2) updatewhereclause=yes name=coilmst_etc_no dbname="coilmst.etc_no" )
 retrieve="  SELECT DISTINCT groupitem.item_name,   
         coilmst.qa,   
         coilsliting.cnt,   
         coilsliting.unit_qty,   
         start_date = convert(smalldatetime, :ad_start, 111),   
         end_date = convert(smalldatetime, :ad_end, 111),   
         tot_qty = coilsliting.unit_qty * coilsliting.cnt,   
         rate = ( coilsliting.unit_qty * coilsliting.cnt ) * 100 / coilmst.unit_qty,   
         coilorder.order_no,   
         coilorderdet.order_no,   
         swid = case when sheet = ~"C~" or sheet = ~"L~" then convert (decimal (5,1) , substring(coilsliting.qa,5,4) + ~".~" + substring(coilsliting.qa, 10,1)) when sheet = ~"S~" then convert (decimal (5,0) , substring(coilsliting.qa,5,4)) end,   
         coilorder.wc_place,   
         coilsliting.seq,   
         coilmst.unit_qty,   
         coilsliting.item_no,   
         coilmst.etc_no  
    FROM coilmst,   
         groupitem,   
         coilorder,   
         coilorderdet,   
         coilsliting  
   WHERE ( coilorderdet.order_no = coilsliting.order_no ) and  
         ( coilorder.order_no = coilorderdet.coilorder_order ) and  
         ( coilorderdet.coil_no = coilmst.coil_no ) and  
         ( coilmst.item_no = groupitem.item_no ) and  
         ( ( coilorder.order_date between :ad_start and :ad_end))   
" arguments=(("ad_start", date),("ad_end", date))  sort="coilorder_wc_place A coilorder_order_no A coilorderdet_order_no A coilsliting_seq A " )
group(level=1 header.height=0 trailer.height=84 by=("coilorder_order_no" , "coilorderdet_order_no" ) header.color="536870912" trailer.color="536870912" )
