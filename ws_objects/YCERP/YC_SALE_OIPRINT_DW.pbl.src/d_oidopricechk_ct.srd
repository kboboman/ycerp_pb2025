 columns = "user_name" rows = "item_name, do_cost" values = "sum(calc_qty for crosstab)" sourcenames = "user_name, cust_no, cust_name, scene_code, scene_desc, item_no, item_name, qa, uom, do_cost, calc_qty, calc_amt")
