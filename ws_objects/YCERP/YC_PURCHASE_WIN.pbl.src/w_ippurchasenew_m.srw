event doubleclicked;//
string  ls_juso, ls_tel

if isnull(row) OR row < 1 then RETURN

ls_juso   = dw_15.object.bigo[row]
ls_tel    = dw_15.object.item_nm[row]

dw_1.object.supply_addr[1]  = ls_juso
dw_1.object.supply_tel[1]   = ls_tel

dw_15.visible = false

end event

event buttonclicked;string ls_msg
int 		l_row, ll_row
long   l_sort
dwItemStatus l_status

dw_15.accepttext()

if dwo.name = 'b_insert' then	
	ll_row = this.insertrow(0)
	dw_15.object.type[ll_row] = 'PURWORD'
	dw_15.object.use_yn[ll_row] = 'Y'
	dw_15.object.category[ll_row] = 'DATA'
//	dw_15.object.sort[ll_row] = ll_row
	dw_15.object.log_dt[ll_row] = today()
elseif dwo.name = 'b_delete' then
	this.deleterow(0)
elseif dwo.name = 'b_save' then
	
//	l_sort = this.rowcount()
	
//	for ll_row = 1 to this.rowcount()	
//		
//		l_status = dw_1.GetItemStatus(ll_row,0, Primary!)
//		
//		if l_status = newmodified! then			
//			l_sort = l_sort + 1
//		elseif l_status = datamodified! then
//			
//		end if
//
//	next

	wf_update1(dw_15, 'Y')
	dw_15.retrieve()
end if
end event

