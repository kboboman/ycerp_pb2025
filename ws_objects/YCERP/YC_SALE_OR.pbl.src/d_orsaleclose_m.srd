 column=(type=char(10) updatewhereclause=yes name=salesman dbname="sale.salesman" initial=" " )
 column=(type=char(1) updatewhereclause=yes name=tax_sign dbname="sale.tax_sign" initial="N" values="	Y/	N" )
 column=(type=decimal(4) updatewhereclause=yes name=sale_tax dbname="sale.sale_tax" initial="0" )
 column=(type=decimal(4) updatewhereclause=yes name=sale_amount dbname="sale.sale_amount" initial="0" )
 column=(type=char(1) update=yes updatewhereclause=yes name=open_close dbname="sale.open_close" initial=" " values="정상	O/마감	C/취소	X/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=close_type dbname="sale.close_type" initial=" " values="자동	A/수동	M/취소	X/" )
 column=(type=datetime update=yes updatewhereclause=yes name=close_date dbname="sale.close_date" initial=" " )
 column=(type=char(80) updatewhereclause=yes name=shipto_addr dbname="sale.shipto_addr" initial=" " )
 column=(type=char(80) updatewhereclause=yes name=rem dbname="sale.rem" initial=" " )
 column=(type=long updatewhereclause=yes name=revision_no dbname="sale.revision_no" initial=" " )
 column=(type=datetime updatewhereclause=yes name=revision_date dbname="sale.revision_date" initial=" " )
 column=(type=datetime updatewhereclause=yes name=input_date dbname="sale.input_date" )
 column=(type=char(10) updatewhereclause=yes name=login_id dbname="sale.login_id" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(1) updatewhereclause=yes name=sale_confirm_flag dbname="sale.confirm_flag" initial=" " values="	Y/	N" )
 column=(type=char(10) updatewhereclause=yes name=sale_confirm_user dbname="sale.confirm_user" )
 column=(type=datetime updatewhereclause=yes name=sale_confirm_date dbname="sale.confirm_date" )
 column=(type=char(80) updatewhereclause=yes name=sale_rem1 dbname="sale.rem1" )
 column=(type=char(80) updatewhereclause=yes name=sale_rem2 dbname="sale.rem2" )
 column=(type=char(10) updatewhereclause=yes name=sale_area_no dbname="sale.area_no" )
 column=(type=decimal(2) updatewhereclause=yes name=sale_ysp_qty dbname="sale.ysp_qty" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 column=(type=char(10) updatewhereclause=yes name=color_color_name dbname="color.color_name" )
 column=(type=char(1) updatewhereclause=yes name=sale_type dbname="sale.type" )
 column=(type=decimal(2) updatewhereclause=yes name=ysp_qty2 dbname="sale.ysp_qty2" )
 column=(type=char(8) updatewhereclause=yes name=make_name dbname="make_name" )
 retrieve="  SELECT sale.order_no,   
         sale.cust_no,   
         sale.scene_code,   
         sale.order_date,   
         sale.due_date,   
         sale.estimate_no,   
         sale.sale_flag,   
         sale.curr_code,   
         sale.cust_po_no,   
         sale.cust_po_date,   
         sale.ship_flag,   
         sale.fob,   
         sale.salesman,   
         sale.tax_sign,   
         sale.sale_tax,   
         sale.sale_amount,   
         sale.open_close,   
         sale.close_type,   
         sale.close_date,   
         sale.shipto_addr,   
         sale.rem,   
         sale.revision_no,   
         sale.revision_date,   
         sale.input_date,   
         sale.login_id,   
         customer.cust_name,   
         sale.confirm_flag,   
         sale.confirm_user,   
         sale.confirm_date,   
         sale.rem1,   
         sale.rem2,   
         sale.area_no,   
         sale.ysp_qty,   
         scene.scene_desc,   
         color.color_name,   
         sale.type,   
         sale.ysp_qty2,
         (
				select (case when count(a.mpsorder_order) > 0 then '생산계획' else '' end) make_name
				  from mpsdet a 
				where a.sale_no = :as_order_no
					 and not exists (                  
											 select * 
											 from sfcday b with(nolock)
											 where b.sale_no = :as_order_no
												  and b.sale_no = a.sale_no 
												  and b.mpsorder_order  = a.mpsorder_order  
												  and b.order_seq = a.order_seq
									   )
	    ) make_name  
    FROM sale LEFT OUTER JOIN customer with(nolock) ON sale.cust_no = customer.cust_no 
                        LEFT OUTER JOIN scene with(nolock) ON sale.scene_code = scene.scene_code 
                        LEFT OUTER JOIN color with(nolock) ON sale.color = color.color_code  
   WHERE sale.order_no = :as_order_no    
" update="sale" updatewhere=1 updatekeyinplace=yes arguments=(("as_order_no", string)) )
