 retrieve="  SELECT itemtop10.category
       , itemtop10.type
       , itemtop10.item_no
       , itemtop10.item_name
       , itemtop10.sys_date
       , chk     = 'N'
    FROM itemtop10 
" update="itemtop10" updatewhere=0 updatekeyinplace=no  sort="item_name A " )
