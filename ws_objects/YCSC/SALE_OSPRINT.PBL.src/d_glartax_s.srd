table(column=(type=long updatewhereclause=yes name=chk dbname="CHK" values="	1/	0" )
 column=(type=char(12) update=yes updatewhereclause=yes key=yes name=aroiinv_no dbname="AROIINV_NO" )
 column=(type=char(255) updatewhereclause=yes name=register_no dbname="REGISTER_NO" )
 column=(type=char(3) updatewhereclause=yes name=inv_area dbname="INV_AREA" initial="S01" values="서울사업장	H01/시화사업장	S01/(주)유창내수	D01/대전영업소	Z01/" )
 column=(type=char(255) updatewhereclause=yes name=oi_date dbname="OI_DATE" )
 column=(type=decimal(4) updatewhereclause=yes name=aroiinv_cash dbname="AROIINV_CASH" )
 column=(type=decimal(4) updatewhereclause=yes name=aroiinv_rate dbname="AROIINV_RATE" )
 column=(type=decimal(4) updatewhereclause=yes name=ship_cost dbname="SHIP_COST" )
 column=(type=char(1) updatewhereclause=yes name=aroiinv_esero dbname="ESERO" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="CUST_NAME" )
 column=(type=char(12) updatewhereclause=yes name=gltrana_vat_no dbname="VAT_NO" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="CUST_NO" )
 column=(type=decimal(0) updatewhereclause=yes name=aroiinv_dc dbname="DC" )
 column=(type=decimal(0) updatewhereclause=yes name=aroiinv_dc_rate dbname="DC_RATE" )
 column=(type=decimal(0) updatewhereclause=yes name=aroiinv_discount dbname="DISCOUNT" )
 column=(type=char(1) update=yes updatewhereclause=yes name=aroiinv_open_close dbname="OPEN_CLOSE" )
 column=(type=char(6) updatewhereclause=yes name=user_name dbname="USER_NAME" )
 column=(type=char(4) updatewhereclause=yes name=team_name dbname="TEAM_NAME" )
 column=(type=char(10) updatewhereclause=yes name=user_name1 dbname="USER_NAME1" )
 column=(type=char(30) updatewhereclause=yes name=team_name1 dbname="TEAM_NAME1" )
 retrieve="  SELECT DISTINCT CHK = 1   
       , AROIINV_NO  = A.AROIINV_NO   
       , REGISTER_NO = REPLACE(A.REGISTER_NO,'-','')
       , INV_AREA    = A.INV_AREA   
       , OI_DATE     = REPLACE(CONVERT(CHAR(10),A.OI_DATE,111),'/','')
       , AROIINV_CASH= A.AROIINV_CASH   
       , AROIINV_RATE= A.AROIINV_RATE   
       , SHIP_COST   = A.SHIP_COST   
       , ESERO       = A.ESERO   
       , CUST_NAME   = B.CUST_NAME   
       , VAT_NO      = C.VAT_NO   
       , CUST_NO     = A.CUST_NO   
       , DC          = A.DC   
       , DC_RATE     = A.DC_RATE   
       , DISCOUNT    = A.DISCOUNT   
       , OPEN_CLOSE  = A.OPEN_CLOSE  
       , USER_NAME   = ISNULL(E.DUZON_SABUN,E.USER_NAME)
       , TEAM_NAME   = ISNULL(E.DUZON_DEPT, F.TEAM_NAME)
       , USER_NAME1  = E.USER_NAME
       , TEAM_NAME1  = F.TEAM_NAME
    FROM AROIINV A
         LEFT OUTER JOIN CUSTOMER  B ON A.CUST_NO     = B.CUST_NO 
         LEFT OUTER JOIN GLTRANA   C ON A.AROIINV_NO  = C.VAT_NO  
         LEFT OUTER JOIN LOGIN     E ON B.SALESMAN    = E.USER_ID
         LEFT OUTER JOIN TEAM      F ON E.TEAM_CODE   = F.TEAM_CODE
   WHERE ( CONVERT(CHAR(7),A.OI_DATE,111)   = :as_yyyymm ) 
     AND ( A.DELETE_FLAG       = 'N' ) 
     AND ( A.OPEN_CLOSE        = :as_openclose ) 
     AND ( A.INV_AREA       LIKE :as_area  )    
" update="AROIINV" updatewhere=1 updatekeyinplace=yes arguments=(("as_yyyymm", string),("as_openclose", string),("as_area", string))  sort="oi_date A aroiinv_no A " )
