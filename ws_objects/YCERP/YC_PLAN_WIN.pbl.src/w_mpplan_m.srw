event resize;call super::resize;//
This.hide()

gb_4.width   = newwidth  - (gb_4.x * 2)

tab_1.width  = newwidth  - (gb_4.x * 2)
iwidth       = tab_1.width

tab_1.height = newheight - tab_1.y - gb_4.x

tab_1.tabpage_3.dw_4.width  = tab_1.width  - 46
tab_1.tabpage_3.dw_4.height = tab_1.height - 236

tab_1.tabpage_3.dw_8.x      = 0
tab_1.tabpage_3.dw_8.y      = 104
tab_1.tabpage_3.dw_8.width  = tab_1.width  - 46
tab_1.tabpage_3.dw_8.height = tab_1.height - 236


tab_1.tabpage_4.dw_6.width  = tab_1.width  - 46
tab_1.tabpage_4.dw_6.height = tab_1.height - 236

tab_1.tabpage_4.dw_5.x      = 0
tab_1.tabpage_4.dw_5.y      = 104
tab_1.tabpage_4.dw_5.width  = tab_1.width  - 46
tab_1.tabpage_4.dw_5.height = tab_1.height - 236

// 자동생산계획 LOG
dw_11.x      = tab_1.x  + 15
dw_11.y      = tab_1.y  + 215
dw_11.width  = tab_1.width * 0.7
dw_11.height = tab_1.tabpage_4.dw_6.height

// 도장색상별 집계
tab_1.tabpage_4.dw_12.x      = 0
tab_1.tabpage_4.dw_12.y      = 104
tab_1.tabpage_4.dw_12.width  = tab_1.width  - 46
tab_1.tabpage_4.dw_12.height = tab_1.height - 236

//
dw_work.y    = em_batch.y

end event

type pb_save from w_inheritance`pb_save within w_mpplan_m
integer x = 4613
integer y = 44
integer width = 320
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
boolean underline = true
string text = "수주내역 재조회"
string picturename = ""
alignment htextalign = center!
vtextalign vtextalign = multiline!
end type

event pb_save::clicked;string	ls_colx, ls_clause,ls_where
long		l_month
string	ls_chk

//초기화
dw6.reset()
dw6.setredraw( false)
dw6.post setredraw(true)

// 계획일
if tab_1.tabpage_4.cbx_2.checked = false then
	dw6.object.pri.width = 0
end if

l_month = long(MidA(ddlb_pre_month.text,1,2))*-1

//////////////////////////////
ii_wid = 0
tab_1.selecttab(2)
//////////////////////////////

dw6.Modify("DataWindow.Trailer.1.Height=0")

if cbx_retrieve.checked = true then
	ls_chk = 'Not'
else
	ls_chk = '%'
end if

if dw6.retrieve(is_area, l_month, ls_chk) > 0 then
	ls_colx = dw6.object.work_date.x
end if

////////////////////////////////////////////////////
// 분할 작업 취소한 경우
////////////////////////////////////////////////////
tab_1.tabpage_4.cb_1.enabled = true	// 생산계획
tab_1.tabpage_4.pb_7.enabled = true // 다중추가
////////////////////////////////////////////////////

// 조회시간 설정 'yyyy-mm-dd hh:mi:ss.mmm'
SELECT convert(char(19), getdate(), 121) INTO :is_time FROM dual; 

end event

event pb_save::mousemove;//
end event

type dw_1 from w_inheritance`dw_1 within w_mpplan_m
integer x = 1001
integer y = 252
integer width = 2834
integer height = 80
string dataobject = "d_mpsale1_m"
boolean hscrollbar = false
boolean vscrollbar = false
boolean border = false
end type

event dw_1::itemchanged;string  ls_date,ls_wc,ls_order,ls_temp,ls_like
integer li_temp

this.accepttext()

choose case dwo.name
	case "start_date"		// 생산시작일
		ls_date  = string(this.object.start_date[1],'yyyymmdd')
		ls_wc    = trim(this.object.wc_no[1])
		ls_order = LeftA(is_area, 1) + ls_wc + MidA(ls_date,4,5)
		ls_like  = LeftA(is_area, 1) + ls_wc + MidA(ls_date,4,5) + '%'
		SELECT max(order_no) INTO :ls_temp FROM mps WHERE order_no LIKE :ls_like;
		if isnull(ls_temp) then 
			ls_order = ls_order + '01'
		   this.object.order_no[1] = ls_order
		else
			li_temp  = integer(MidA(ls_temp,10,2)) + 1
			ls_temp  = RightA('000' + string(li_temp),2)
			ls_order = ls_order + ls_temp
			this.object.order_no[1] = ls_order
		end if
		ii_seq = 0
		 
	case "wc_no"		// 작업장
		ls_date  = string(this.object.start_date[1],'yyyymmdd')
		ls_wc    = trim(this.object.wc_no[1])
		ls_order = LeftA(is_area, 1) + ls_wc + MidA(ls_date,4,5)
		ls_like  = LeftA(is_area, 1) + ls_wc + MidA(ls_date,4,5) + '%'
		
		SELECT max(order_no) INTO :ls_temp FROM mps WHERE order_no LIKE :ls_like;
		
		if isnull(ls_temp) then 
			ls_order = ls_order + '01'
		   this.object.order_no[1] = ls_order
		else
			li_temp  = integer(MidA(ls_temp,10,2)) + 1
			ls_temp  = RightA('000' + string(li_temp),2)
			ls_order = ls_order + ls_temp
			this.object.order_no[1] = ls_order
		end if	 

		// 자동선택
		dw7.object.wc_no[1] = ls_wc
		dw7.accepttext()
		dw7.TriggerEvent( itemchanged! )
		 
		dw7.setcolumn("wc_no")
		dw7.setfocus()
end choose

end event

event dw_1::rbuttondown;call super::rbuttondown;string ls_date,ls_wc,ls_order,ls_temp,ls_like
integer li_temp

CHOOSE CASE dwo.name
	CASE "start_date"		// 생산시작일
		openWithParm(w_calendar, message.stringparm)
		if message.stringparm <> 'N' then
			this.object.start_date[row] = datetime(date(message.stringparm))
		end if
		
		this.accepttext()
		ls_date  = string(this.object.start_date[1],'yyyymmdd')
		ls_wc    = trim(this.object.wc_no[1])
		ls_order = LeftA(is_area, 1) + ls_wc + MidA(ls_date,4,5)
		ls_like  = LeftA(is_area, 1) + ls_wc + MidA(ls_date,4,5) + '%'
		SELECT max(order_no) INTO :ls_temp FROM mps WHERE order_no LIKE :ls_like;
		if isnull(ls_temp) then 
			ls_order = ls_order + '01'
			this.object.order_no[1] = ls_order
		else
			li_temp  = integer(MidA(ls_temp,10,2)) + 1
			ls_temp  = RightA('000' + string(li_temp),2)
			ls_order = ls_order + ls_temp
			this.object.order_no[1] = ls_order
		 end if
		 ii_seq = 0
END CHOOSE
this.accepttext()

end event

