$PBExportComments$영업사원 출고현황(월별) 집계표
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no  crosstab.dynamic = yes grid.lines=0 grid.columnmove=no selected.mouse=no )
header[1](height=0 color="536870912" )
header[2](height=92 color="536870912" )
summary(height=92 color="536870912" )
footer(height=0 color="536870912" )
detail(height=92 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=담당자 dbname="담당자" )
 column=(type=char(20) updatewhereclause=yes name=판매거래처 dbname="판매거래처" )
 column=(type=char(20) updatewhereclause=yes name=현장 dbname="현장" )
 column=(type=number updatewhereclause=yes name=do_total dbname="do_total" )
 retrieve="SELECT 
	  '담당자'   	= a.user_name          
	, cust_no     	= a.cust_no            
	, '판매거래처' = a.cust_name
	, spot_code   	= a.spot_code     
	, '현장'  		= a.scene_desc  
	, do_date	  	= a.do_date
	, do_total    	= sum(a.do_total)
FROM (
	SELECT
	  		 user_name = m.user_name          
		, cust_no     = a.cust_no            
		, cust_name   = d.cust_name
		, spot_code   = a.spot_code     
		, scene_desc  = f.scene_desc  
		, do_date     = convert(char(7), a.do_date, 111)
		, do_total    = a.do_total
	FROM 
		UF_MyCustomers( :as_salesman ) M
		 LEFT OUTER JOIN customer D ON m.cust_no     = d.cust_no
		 LEFT OUTER JOIN do        A ON m.cust_no     = a.cust_no
		 LEFT OUTER JOIN scene  F ON a.spot_code   = f.scene_code 
		 LEFT OUTER JOIN login    E ON d.salesman    = e.user_id
	WHERE 
		(a.area_no        LIKE :as_area ) 
	AND 
		(convert(char(10), a.do_date, 111)     BETWEEN :as_sdate AND :as_edate ) 
	AND 
		((:as_team  = '%' AND m.cust_no   LIKE '%'  ) OR 
		(:as_team <> '%' AND m.salesman     = :as_salesman ))
	AND 
		((:as_custno  = '%'   AND m.cust_no   LIKE '%'  ) OR 
		(:as_custno  = 'ALL' AND m.cust_no   LIKE '%'  ) OR 
		(:as_custno <> 'ALL' AND m.cust_no      = :as_custno ))
	) A
GROUP BY 
     a.user_name          
	, a.cust_no            
	, a.cust_name
	, a.spot_code     
	, a.scene_desc  
   , a.do_date
ORDER BY a.user_name, a.cust_name, a.scene_desc;" arguments=(("as_area", string),("as_custno", string),("as_sdate", string),("as_edate", string),("as_salesman", string),("as_team", string))  sort="담당자 A 판매거래처 A 현장 A " )
group(level=1 header.height=0 trailer.height=92 by=("담당자" ) header.color="536870912" trailer.color="536870912" )
