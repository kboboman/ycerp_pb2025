detail(height=68 color="536870912" )
table(column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=decimal(4) updatewhereclause=yes name=itemcost_price dbname="itemcost.price" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(4) updatewhereclause=yes name=customer_cust_no dbname="customer.cust_no" )
 column=(type=char(10) updatewhereclause=yes name=custitem_item_no dbname="custitem.item_no" )
 column=(type=char(20) updatewhereclause=yes name=custitem_qa dbname="custitem.qa" )
 column=(type=char(2) updatewhereclause=yes name=custitem_uom dbname="custitem.uom" )
 column=(type=decimal(0) updatewhereclause=yes name=custitem_pre_cost dbname="custitem.pre_cost" )
 column=(type=decimal(0) updatewhereclause=yes name=custitem_price dbname="custitem.price" )
 column=(type=char(30) updatewhereclause=yes name=custitem_rem dbname="custitem.rem" )
 column=(type=datetime updatewhereclause=yes name=custitem_sys_date dbname="custitem.sys_date" )
 column=(type=char(10) updatewhereclause=yes name=custitem_user_id dbname="custitem.user_id" )
 retrieve="  SELECT customer.cust_name    
       , itemcost.price        
       , groupitem.item_name   
       , customer.cust_no      
       , custitem.item_no      
       , custitem.qa           
       , custitem.uom          
       , custitem.pre_cost     
       , custitem.price        
       , custitem.rem          
       , custitem.sys_date     
       , custitem.user_id  
    FROM customer    
       , itemcost    
       , groupitem   
       , custitem  
   WHERE ( custitem.item_no   = itemcost.item_no  )  
     AND ( custitem.qa        = itemcost.qa       )  
     AND ( custitem.item_no   = groupitem.item_no )  
     AND ( customer.cust_no   = custitem.cust_no  )  
     AND ( customer.cust_no   = :as_cust_no       )    
" arguments=(("as_cust_no", string)) )
group(level=1 header.height=0 trailer.height=12 by=("custitem_item_no" ) header.color="536870912" trailer.color="536870912" )
