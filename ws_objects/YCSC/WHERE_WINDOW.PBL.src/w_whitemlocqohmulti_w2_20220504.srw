type dw_2 from datawindow within tabpage_1
integer y = 260
integer width = 1723
integer height = 828
integer taborder = 200
string title = "none"
string dataobject = "d_itemname_all"
boolean hscrollbar = true
boolean vscrollbar = true
boolean livescroll = true
borderstyle borderstyle = stylelowered!
end type

event clicked;long ll_row

ll_row = this.getrow()
if ll_row < 1 then return
this.setredraw( false)
string ls_item

is_loc = dw_loc.object.loc_no[1]

dw3.setredraw(false)
dw3.reset()
ls_item = this.object.item_no[ll_row]
dw3.retrieve(is_loc, ls_item )
dw3.setredraw(true)
this.SelectRow(0,  false)
this.SelectRow(ll_row,  true)
this.setredraw( true)

//2005.07.30 도료규격추가부분//
If ls_item = "M2Z0POWZZZ" Or ls_item = "M2Z0LIQKZZ" Or ls_item = 'PZZZPP7ZZZ' Or ls_item = 'PZZZPP3ZZZ' Or ls_item = 'PZZZPP1ZZZ' Or ls_item = 'PZZZPP0ZZZ' Then
	em_1.Visible = false
	em_2.Visible = false
	em_3.Visible = false
	em_4.Visible = false
	st_5.Visible = false
	st_6.Visible = false
	st_7.Visible = false
	sle_paint.Visible = true
Else
	em_1.Visible = true
	em_2.Visible = true
	em_3.Visible = true
	em_4.Visible = true
	st_5.Visible = true
	st_6.Visible = true
	st_7.Visible = true	
	sle_paint.Visible = false
End If
end event

event rowfocuschanged;long ll_row

ll_row = this.getrow()
if ll_row < 1 then return
this.setredraw( false)
string ls_item

//is_loc = dw_loc.object.loc_no[1]

dw3.setredraw(false)
dw3.reset()
ls_item = this.object.item_no[ll_row]
dw3.retrieve(is_loc, ls_item )
dw3.setredraw(true)
this.SelectRow(0,  false)
this.SelectRow(ll_row,  true)
this.setredraw( true)

//2005.07.30 도료규격추가부분//
If ls_item = "M2Z0POWZZZ" Or ls_item = "M2Z0LIQKZZ" Or ls_item = 'PZZZPP7ZZZ' Or ls_item = 'PZZZPP3ZZZ' Or ls_item = 'PZZZPP1ZZZ' Or ls_item = 'PZZZPP0ZZZ' Then
	em_1.Visible = false
	em_2.Visible = false
	em_3.Visible = false
	em_4.Visible = false
	st_5.Visible = false
	st_6.Visible = false
	st_7.Visible = false
	sle_paint.Visible = true
Else
	em_1.Visible = true
	em_2.Visible = true
	em_3.Visible = true
	em_4.Visible = true
	st_5.Visible = true
	st_6.Visible = true
	st_7.Visible = true	
	sle_paint.Visible = false
End If
end event

