 column=(type=char(1) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=char(14) update=yes updatewhereclause=yes name=do_sale_no dbname="itemstockout.do_sale_no" )
 column=(type=long update=yes updatewhereclause=yes name=do_sale_seq dbname="itemstockout.do_sale_seq" )
 column=(type=char(14) update=yes updatewhereclause=yes name=do_no dbname="itemstockout.do_no" )
 column=(type=long update=yes updatewhereclause=yes name=oi_no dbname="itemstockout.oi_no" )
 retrieve="  SELECT  itemstockout.id
                 , itemstockout.seq
			 , '' qa   
			 , itemstockout.qty
			 , 0 stock_qty
		      , '' sale_no
		      , null sale_seq
		      , itemstockout.use_yn
			 , '' item_name   
			 , '' cust_name
			 , '' scene_desc
                 , do_sale_no
                 , do_sale_seq
                 , do_no
                 , oi_no
    FROM itemstockout" update="itemstockout" updatewhere=0 updatekeyinplace=no  sort="qa A sale_no A sale_seq A cust_name A scene_desc A " )
