compute(band=detail alignment="1" expression="if( aroiinv_aroiinv_rate <> 0,  truncate(aroiinv_discount * 1.1, 0), aroiinv_discount)"border="0" color="0" x="4000" y="4" height="60" width="411" format="#,##0" html.valueishtml="0"  name=tot_dis visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
