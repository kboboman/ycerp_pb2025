 retrieve="  SELECT customer.cust_no,   
         customer.cust_name,   
         customer.register_no,   
         customer.captain_name,   
         customer.resident_card,   
         customer.addr,   
         customer.business,   
         customer.bus_cord,   
         customer.bus_rep,   
         customer.bus_addr,   
         customer.bus_tel,   
         customer.tel_no,   
         customer.fax_no,   
         customer.industry_type,   
         customer.industry_code,   
         customer.cust_type,   
         customer.shipto_addr,   
         customer.terms,   
         customer.credit_level,   
         customer.credit_limit,   
         customer.curr_code,   
         customer.balance_amt,   
         customer.bill_amount,   
         customer.start_date,   
         customer.buyer1,   
         customer.buyer2,   
         customer.pre_salesman,   
         customer.salesman,   
         customer.last_tn_date,   
         customer.level_grade  
    FROM customer   
" update="customer" updatewhere=1 updatekeyinplace=no  sort="cust_name A " )
