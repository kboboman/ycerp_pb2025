table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=user_id dbname="login.user_id" )
 column=(type=char(8) update=yes updatewhereclause=yes name=password dbname="login.password" )
 column=(type=datetime update=yes updatewhereclause=yes name=pwdchanged dbname="login.pwdchanged" )
 column=(type=char(5) update=yes updatewhereclause=yes name=team_code dbname="login.team_code" )
 column=(type=char(30) update=yes updatewhereclause=yes name=rem dbname="login.rem" )
 column=(type=char(10) update=yes updatewhereclause=yes name=user_name dbname="login.user_name" )
 column=(type=char(20) update=yes updatewhereclause=yes name=rank dbname="login.rank" )
 column=(type=char(10) update=yes updatewhereclause=yes name=area_no dbname="login.area_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=group_id dbname="login.group_id" initial="1" )
 column=(type=char(1) update=yes updatewhereclause=yes name=use_flag dbname="login.use_flag" initial="Y" values="	Y/	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=duty_flag dbname="login.duty_flag" values="YSP수주입력	Y/현설정보결재	E/" )
 column=(type=char(1) updatewhereclause=yes name=update_chk dbname="update_chk" values="	Y/	N" )
 column=(type=char(10) update=yes updatewhereclause=yes name=force_update dbname="login.force_update" )
 column=(type=char(10) updatewhereclause=yes name=force_old dbname="force_old" )
 column=(type=char(10) update=yes updatewhereclause=yes name=issuereq_area dbname="login.issuereq_area" )
 column=(type=char(1) update=yes updatewhereclause=yes name=sale_price dbname="login.sale_price" values="	Y/	N" )
 column=(type=char(1) update=yes updatewhereclause=yes name=duty_flag2 dbname="login.duty_flag2" initial="N" values="가능	Y/불가	N/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=team_acc dbname="login.team_acc" initial="N" values="가능	Y/불가	N/" )
 column=(type=char(10) update=yes updatewhereclause=yes name=rank_no dbname="login.rank_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=user_level dbname="login.user_level" initial="C" )
 column=(type=char(1) update=yes updatewhereclause=yes name=ycgl_manager_chk dbname="login.ycgl_manager_chk" initial="N" values="가능	Y/불가능	N/" )
 column=(type=char(10) update=yes updatewhereclause=yes name=gw_id dbname="login.gw_id" )
 column=(type=datetime updatewhereclause=yes name=logdt dbname="login.logdt" )
 column=(type=char(13) update=yes updatewhereclause=yes name=phone dbname="login.phone" )
 column=(type=char(13) update=yes updatewhereclause=yes name=phone_office dbname="login.phone_office" )
 column=(type=char(30) updatewhereclause=yes name=team_name dbname="team.team_name" )
 column=(type=char(20) updatewhereclause=yes name=group_name dbname="sysgroup.group_name" )
 column=(type=char(6) update=yes updatewhereclause=yes name=duzon_sabun dbname="login.duzon_sabun" )
 column=(type=char(4) update=yes updatewhereclause=yes name=duzon_dept dbname="login.duzon_dept" )
 retrieve="  SELECT login.user_id                    
       , login.password                   
       , login.pwdchanged
       , login.team_code                  
       , login.rem                        
       , login.user_name                  
       , login.rank                       
       , login.area_no                    
       , login.group_id                   
       , login.use_flag                   
       , login.duty_flag                  
       , update_chk = 'N'                 
       , login.force_update               
       , force_old = login.force_update   
       , login.issuereq_area              
       , login.sale_price                 
       , login.duty_flag2                 
       , login.team_acc                   
       , login.rank_no                    
       , login.user_level                 
       , login.ycgl_manager_chk           
       , login.gw_id                      
       , login.logdt                   
       , login.phone
       , login.phone_office
       , team.team_name                
       , sysgroup.group_name           
       , duzon_sabun                   
       , duzon_dept
    FROM login  
         LEFT OUTER JOIN team     ON login.team_code = team.team_code
         LEFT OUTER JOIN sysgroup ON login.group_id  = sysgroup.group_id
   WHERE login.team_code    LIKE :as_team   
   ORDER BY login.use_flag  DESC,
            login.rank_no   ASC,   
            login.user_name ASC,   
            login.user_id   ASC   
" update="login" updatewhere=0 updatekeyinplace=no arguments=(("as_team", string))  sort="team_code A rank_no A user_level A " )
