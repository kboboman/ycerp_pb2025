$PBExportHeader$d_orsms_mms.srd
$PBExportComments$MMS 전송리스트
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=char(255) updatewhereclause=yes name=tr_senddate dbname="tr_senddate" )
 column=(type=char(255) updatewhereclause=yes name=tr_phone dbname="tr_phone" )
 column=(type=char(50) updatewhereclause=yes name=tr_phonename dbname="tr_phonename" )
 column=(type=char(20) updatewhereclause=yes name=tr_callback dbname="tr_callback" )
 column=(type=char(255) updatewhereclause=yes name=tr_msg dbname="tr_msg" )
 column=(type=char(172) updatewhereclause=yes name=tr_etc6 dbname="tr_etc6" )
 retrieve="SELECT tr_senddate
     , tr_phone
     , tr_phonename
     , tr_callback
     , tr_msg
     , tr_etc6
  FROM (
       SELECT tr_senddate = replace(replace(replace(convert(char(20),tr_senddate,120),'-',''),':',''),' ','')
            , tr_phone    = replace(tr_phone,'-','')
            , tr_phonename= ''
            , tr_callback
            , tr_msg
            , tr_etc6 = rtrim(login.user_name) + '[' + tr_etc6 + ']'
         FROM YC.DBO.sc_log
            , login
        WHERE YC.DBO.sc_log.tr_etc6  = login.user_id
          AND convert(char(10),tr_senddate,111) BETWEEN :as_sdate AND :as_edate
          AND ( tr_etc6   = :as_userid  OR (:as_admin = 'Y' AND tr_etc6   LIKE '%') )

       UNION ALL
       
       SELECT tr_senddate = s.send_date
            , tr_phone    = s.reserved1
            , tr_phonename= s.reserved2
            , tr_callback = ''
            , tr_msg      = s.sms_msg
            , tr_etc6     = rtrim(login.user_name) + '[' + s.reserved1 + ']'
         FROM YC.DBO.sdk_sms_report S
            , login
        WHERE ( s.user_id = login.user_id )
          AND ( substring(s.send_date,1,8) BETWEEN replace(:as_sdate,'/','') AND replace(:as_edate,'/','') )
          AND ( s.user_id = :as_userid  OR (:as_admin = 'Y' AND s.user_id LIKE '%') )

       UNION ALL
       
       SELECT tr_senddate = m.send_date
            , tr_phone    = m.reserved1
            , tr_phonename= m.reserved2
            , tr_callback = ''
            , tr_msg      = cast(m.mms_msg   as varchar(2000))
            , tr_etc6     = rtrim(login.user_name) + '[' + m.reserved1 + ']'
         FROM YC.DBO.sdk_mms_report M
            , login
        WHERE ( m.user_id = login.user_id )
          AND ( substring(m.send_date,1,8) BETWEEN replace(:as_sdate,'/','') AND replace(:as_edate,'/','') )
          AND ( m.user_id = :as_userid  OR (:as_admin = 'Y' AND m.user_id LIKE '%') )
       ) A
   ORDER BY tr_senddate DESC
" arguments=(("as_userid", string),("as_sdate", string),("as_edate", string),("as_admin", string))  sort="tr_senddate D " )
