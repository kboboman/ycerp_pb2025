 retrieve="  SELECT customer_control_his.log_date,   
         customer_control_his.cust_cd,   
         customer_control_his.sale_control,  
         customer_control_his.gbn,  
         customer_control_his.cust_cd2,  
         customer_control_his.user_id  
    FROM customer_control_his   
