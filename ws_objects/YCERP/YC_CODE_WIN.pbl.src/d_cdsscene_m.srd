 retrieve="  SELECT SScene.scene_code   
       , SScene.scene_desc   
       , SScene.area_nm
       , SScene.scene_use   
       , SScene.scene_scale   
       , SScene.scene_order   
       , SScene.scene_plan   
       , SScene.scene_inspect  
       , SScene.construct_time1
       , SScene.construct_time2
       , SScene.site_zip   
       , SScene.site_address   
       , SScene.make_date
       , chk   = 'N'
    FROM SScene   
   WHERE (SScene.scene_code   = :as_scene)
 " update="SScene" updatewhere=0 updatekeyinplace=no arguments=(("as_scene", string)) )
