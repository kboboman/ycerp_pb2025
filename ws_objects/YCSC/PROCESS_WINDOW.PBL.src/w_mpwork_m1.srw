type dw_4 from datawindow within tabpage_2
event keydown pbm_dwnkey
integer y = 188
integer width = 4530
integer height = 1880
integer taborder = 51
boolean bringtotop = true
string dataobject = "d_mpsfcwork_m1"
boolean hscrollbar = true
boolean vscrollbar = true
