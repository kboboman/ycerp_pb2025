$PBExportHeader$d_iitemstock_m1_new.srd
$PBExportComments$재고수불부
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=92 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes name=loc_no dbname="GroupItem.loc_no" )
 column=(type=char(10) updatewhereclause=yes name=stock_date dbname="stock_date" )
 column=(type=char(30) updatewhereclause=yes name=loc_name dbname="GroupItem.loc_name" )
 column=(type=char(20) updatewhereclause=yes name=item_no dbname="GroupItem.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="GroupItem.qa" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="GroupItem.item_name" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="GroupItem.uom" )
 column=(type=char(30) updatewhereclause=yes name=gubun dbname="code1.GUBUN" )
 column=(type=char(1) updatewhereclause=yes name=use_flag dbname="item.use_flag" )
 column=(type=decimal(4) updatewhereclause=yes name=real_before_qty dbname="real_before_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=real_in_qty dbname="real_in_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=buy_in_qty dbname="buy_in_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=ask_in_qty dbname="ask_in_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=change_in_qty dbname="change_in_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=etc_in_qty dbname="etc_in_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=move_in_qty dbname="move_in_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=real_out_qty dbname="real_out_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=real_jaje_qty dbname="real_jaje_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=real_intemp_qty dbname="real_intemp_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=real_ret_qty dbname="real_ret_qty" )
 column=(type=long updatewhereclause=yes name=real_plan_out_qty dbname="real_plan_out_qty" )
 column=(type=long updatewhereclause=yes name=real_plan_make_qty dbname="real_plan_make_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=real_etc_qty dbname="real_etc_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=dis_out_qty dbname="dis_out_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=ask_out_qty dbname="ask_out_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=change_out_qty dbname="change_out_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=move_out_qty dbname="move_out_qty" )
 column=(type=long updatewhereclause=yes name=real_not_out_qty dbname="real_NOT_out_qty" )
 column=(type=long updatewhereclause=yes name=erp_stock_qty dbname="erp_stock_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=silsa_in_qty dbname="silsa_in_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=silsa_out_qty dbname="silsa_out_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=real_stock_qty dbname="real_stock_qty" )
 column=(type=char(1) updatewhereclause=yes name=note dbname="note" )
 retrieve="	
select			  a.loc_no,
                    convert(CHAR(10), a.stock_date, 121) stock_date,
                       e.loc_name,
				  a.item_no,
				  a.qa,                                         
				  b.item_name item_name,
				  b.uom,
				  F.code_name  GUBUN,
				  item.use_flag,
				  sum(isnull(a.before_qty,0)) real_before_qty,
				  sum(isnull(a.make_qty,0))   real_in_qty,                                                             
 			        sum(isnull(a.buy_in_qty,0)) buy_in_qty,
				  sum(isnull(a.ask_in_qty,0)) ask_in_qty,
				  sum(isnull(a.change_in_qty,0)) change_in_qty,
				  sum(isnull(a.etc_in_qty,0)) 	      etc_in_qty,
				  sum(isnull(a.move_in_qty,0))    move_in_qty,
/*
    			        sum(isnull(a.ask_in_qty,0)) ask_in_qty,
   			        sum(isnull(a.change_in_qty,0)) change_in_qty,
     			        sum(isnull(a.move_in_qty,0)) move_in_qty,
*/
				   sum(isnull(a.ship_qty,0)) real_out_qty,                                                             /*출고( 판매) */
/*     			   sum(isnull(a.ask_out_qty,0)) ask_out_qty,
				   sum(isnull(a.change_out_qty,0)) change_out_qty,
				   sum(isnull(a.move_out_qty,0)) move_out_qty,     
*/     
				   sum(isnull(a.jaje_qty,0)) real_jaje_qty,							                        /* 출고(생산투입) */
				   sum(isnull(a.intemp_qty,0)) real_intemp_qty,   			                                  /*가입고*/
				   sum(isnull(a.ret_qty,0)) real_ret_qty,                                                             /*반품     */
				   sum(isnull(a.plan_out_qty,0)) real_plan_out_qty,         	                             /*출고예정 */
				   sum(isnull(a.plan_make_qty,0)) real_plan_make_qty,          		                   /*생산예정 */
/*		              sum(isnull(a.dis_out_qty,0)) dis_out_qty,         */         		                        /*제품폐기*/
				    sum(isnull(a.etc_qty,0)) 			real_etc_qty,									/*기타출고 ( 기타출고유형 추가 )*/
				    sum(isnull(a.dis_out_qty,0)) 		dis_out_qty,									/*제품 폐기*/
				     sum(isnull(a.ask_out_qty,0))      ask_out_qty,									/*물품요청출고*/
				     sum(isnull(a.change_out_qty,0)) change_out_qty,							/*물품대체 출고*/
				     sum(isnull(a.move_out_qty,0))  move_out_qty,                    		      	/*물품이동 출고*/
				     sum(isnull(a.NOT_out_qty,0)) real_NOT_out_qty,                      		     /* 미출고 */
				     sum(isnull(a.erp_stock_qty,0)) erp_stock_qty,                      		   		/* erp 재고  */
				     sum(isnull(a.silsa_in_qty,0)) silsa_in_qty,                      		   		/* erp 재고  */
				     sum(isnull(a.silsa_out_qty,0)) silsa_out_qty,                      		   		/* erp 재고  */

				    sum(
              							isnull(a.before_qty,0) +                                                                         /* 당일재고 = 전일재고 + 입고+가입고+반품-출고-기타 */
              							isnull(a.make_qty,0) +
									isnull(a.buy_in_qty,0)+
									isnull(a.ask_in_qty,0)+
									isnull(a.change_in_qty,0)+
									isnull(a.move_in_qty,0)+              
									isnull(a.etc_in_qty,0)+
               							isnull(a.silsa_in_qty,0) +
              							isnull(a.intemp_qty,0) -
              							isnull(a.ship_qty,0) -              							
                           				isnull(a.ask_out_qty,0) -
              							isnull(a.change_out_qty,0) -
              							isnull(a.move_out_qty,0) -                            
              							isnull(a.jaje_qty,0) +
              							isnull(a.ret_qty,0)  -
				                          isnull(a.dis_out_qty,0) - 
              							isnull(a.etc_qty,0) - 
               							isnull(a.silsa_out_qty,0)
  				         ) real_stock_qty,
				' ' note
				from 
				(                 

						select   loc_no,
						/*		  wc_no = null,*/
                 					  dateadd(day, 1, stock_date ) stock_date,
								  item_no,
								  qa,
								   isnull(stock_qty,0) before_qty,
								  make_qty = 0,                                                                /*생산*/
								  buy_in_qty = 0,						                                                   /*구매입고*/
                                            ask_in_qty = 0,                                  					   /*물품요청입고*/
								  change_in_qty = 0,					                                             /*물품대체입고*/
								  move_in_qty = 0, 						                                               /*물품이동입고*/
								  etc_in_qty = 0,																/* 기타입고 */
								  ship_qty = 0,							                                                     /*판매출고       */
                                            ask_out_qty = 0,                          						        /*물품요청출고*/
								  change_out_qty = 0,				            	                                /*물품대체출고*/
								  move_out_qty = 0, 					                                              /*물품이동출고*/
								  JAJE_QTY = 0,						                                                    /*자재투입출고*/
								  ret_qty =0,                                                                      /*반품입고*/
                 					  dis_out_qty = 0,                             					           /*제품폐기*/
								  etc_qty =0,                                                                      /*기타출고*/
								  intemp_qty = 0,                                                             /*가입고*/
								  plan_out_qty =0,                                                           /*출고예정량*/
								  plan_make_qty = 0,                                                        /*생산예정량*/
								  not_out_qty = 0,
							       erp_stock_qty = 0,
								  silsa_in_qty = 0,
								  silsa_out_qty = 0
						 from item_stock with(nolock)
						 where stock_date   between  convert(char(8), dateadd(day, -1, convert(datetime, substring(:as_date,1,6)+'01') ),112) and convert(char(8), dateadd(day, -1, convert(datetime, :as_date) ),112)						   
			          AND loc_no  = :as_locno
						    AND ITEM_NO = :as_item_no
						   AND QA = :as_qa
							 union all
						/*2018.07.03 jowonsuk 추가 */
						select  /*convert(char(10), dateadd(day, -1, dateadd(month, 1, convert(datetime, substring(:as_date,1,6)+'01') ) ),112) date, */            
								 loc_no,
                 					 dateadd(day, -1, dateadd(month, 1, convert(datetime, substring(:as_date,1,6)+'01') ) ) stock_date,
								 item_no,
								 qa,             								
								 before_qty = 0,
								 make_qty = 0,                                                                /*생산*/
								 buy_in_qty = 0,						                                                   /*구매입고*/
								 ask_in_qty = 0,                                  					   /*물품요청입고*/
								 change_in_qty = 0,					                                             /*물품대체입고*/
								 move_in_qty = 0, 						                                               /*물품이동입고*/
								 etc_in_qty = 0,																/* 기타입고 */
								 ship_qty = 0,							                                                     /*판매출고       */
								 ask_out_qty = 0,                          						        /*물품요청출고*/
								 change_out_qty = 0,				            	                                /*물품대체출고*/
								 move_out_qty = 0, 					                                              /*물품이동출고*/
								 JAJE_QTY = 0,						                                                    /*자재투입출고*/
								 ret_qty =0,                                                                      /*반품입고*/
								 dis_out_qty = 0,                             					           /*제품폐기*/
								 etc_qty =0,                                                                      /*기타출고*/
								 intemp_qty = 0,                                                             /*가입고*/
								 plan_out_qty =0,                                                           /*출고예정량*/
								 plan_make_qty = 0,                                                        /*생산예정량*/
								 NOT_out_qty = 0,
							       erp_stock_qty = 0,
								  silsa_in_qty = plus_qty,
								  silsa_out_qty = minus_qty
						  from silsa_itemstock with(nolock)
						where convert(char(10), dateadd(day, -1, dateadd(month, 1, convert(datetime,  ltrim(rtrim(yyyymm))+'01' ) ) ),112) =  :as_date
						AND loc_no  = :as_locno
						and item_no = :as_item_no
                                and qa = :as_qa
						and ISNULL(close_yn,'O') <> 'O'
						and plus_qty + minus_qty <> 0
						      union all
						select      loc_no
				/*						, s.wc_no
														 , batchdate  = convert(char(10), s.use_date, 111)
				*/
								, batchdate  = inaudit_date
										, inaudit_item
										, qa
										, before_qty = 0 
										, make_qty = 0
										, buy_in_qty = 0				        /*구매입고*/
										, ask_in_qty = 0                         /*물품요청입고*/
										, change_in_qty = 0  			     /*물품대체입고*/
										  , move_in_qty = 0   			     /*물품이동입고*/
										, etc_in_qty = 0						/* 기타입고 */
										, ship_qty = 0
										, ask_out_qty = 0                      /*물품요청출고*/
										, change_out_qty = 0			     /*물품대체출고*/
										, move_out_qty = sum(ISNULL(RCPT_QTY,0) + ISNULL(ISSUE_QTY,0))		          /*물품이동출고*/
												  , jaje_qty = 0
										, ret_qty = 0
												, dis_out_qty = 0                  /*제품폐기*/                                    
										, etc_qty = 0             
										, intemp_qty = 0        
										, plan_out_qty = 0
										, plan_make_qty = 0
										, NOT_out_qty = 0
										, erp_stock_qty = 0
										, silsa_in_qty = 0
										, silsa_out_qty = 0
								  from inaudit with(nolock)
								where inaudit_date  BETWEEN convert(datetime,  substring(:as_date,1,6)+'01 00:00:00' ) and convert(datetime,  :as_date + ' 23:59:59' )
								AND rtrim(ltrim(loc_no))  =  :as_locno
								AND inaudit_item = :as_item_no
								AND qa = :as_qa
								AND inaudit_type = 'IO'
										group by loc_no,
													  inaudit_date,
													  inaudit_item,
													  qa
							 union all                                           
						  SELECT  loc_no     = s.loc_no
			/*						  , wc_no      = rtrim(s.wc_no)
									  , batchdate  = convert(char(10), s.sfc_date, 111)
		*/
									  , batchdate  = s.sfc_date
									  , item_no    = s.assembly
									  , qa         = s.assembly_qa
									  , before_qty = 0 
									  , make_qty   = sum(s.make_qty)
									  , buy_in_qty = 0				     /*구매입고*/
									  , ask_in_qty = 0                         /*물품요청입고*/
									  , change_in_qty = 0  			     /*물품대체입고*/
								       , move_in_qty = 0   			     /*물품이동입고*/
									  , etc_in_qty = 0					/* 기타입고 */
									  , ship_qty   = 0
 		      			           	  , ask_out_qty = 0                      /*물품요청출고*/
								       , change_out_qty = 0			     /*물품대체출고*/
								       , move_out_qty = 0		          /*물품이동출고*/
								  	  , JAJE_QTY = 0
									  , ret_qty    = 0
                   					       , dis_out_qty = 0                  /*제품폐기*/                    
									  , etc_qty    = 0
									  , intemp_qty = 0
									  , plan_out_qty = 0
									  , plan_make_qty = 0
									  , NOT_out_qty = 0
							       	  , erp_stock_qty = 0
									  , silsa_in_qty = 0
									  , silsa_out_qty = 0
						  FROM sfcday S WITH (NOLOCK)
								 			LEFT OUTER JOIN wc  W WITH (NOLOCK) ON s.wc_no   = w.work_no
/*						 WHERE convert(char(10), s.sfc_date, 112) =  :as_date                                                */
						 WHERE  s.sfc_date BETWEEN convert(datetime,  substring(:as_date,1,6) + '01 00:00:00' ) and convert(datetime,  :as_date + ' 23:59:59' )
			                       AND s.loc_no  = :as_locno
                             AND s.assembly = :as_item_no
                             AND s.assembly_qa = :as_qa
						 group by s.loc_no,  s.sfc_date, s.assembly, s.assembly_qa
								 union all
						select   s.loc_no
		/*						, s.wc_no
                                     , batchdate  = convert(char(10), s.use_date, 111)
		*/
                , batchdate  = s.use_date
								, s.item_no
								, s.qa
								, before_qty = 0 
								, make_qty = 0
								, buy_in_qty = 0				        /*구매입고*/
								, ask_in_qty = 0                         /*물품요청입고*/
								, change_in_qty = 0  			     /*물품대체입고*/
							     , move_in_qty = 0   			     /*물품이동입고*/
								, etc_in_qty = 0						/* 기타입고 */
								, ship_qty = 0
								, ask_out_qty = 0                      /*물품요청출고*/
								, change_out_qty = 0			     /*물품대체출고*/
								, move_out_qty = 0		          /*물품이동출고*/
/*							      , JAJE_QTY = sum(isnull(s.use_qty,0) - isnull(rem_qty,0)) */
                                           , JAJE_QTY =  sum(    case when g.p4 = '1' then isnull(s.mod_qty,0) - isnull(s.rem_qty,0)
																	 when g.p4 = '2' then isnull(s.use_qty,0)  - isnull(s.rem_cnt,0)
																	 else  isnull(s.use_qty,0) - isnull(s.rem_qty,0)
																	 end 
														  )
								, ret_qty = 0
             						 , dis_out_qty = 0                  /*제품폐기*/                                    
								, etc_qty = 0             
								, intemp_qty = 0        
								, plan_out_qty = 0
								, plan_make_qty = 0
								, NOT_out_qty = 0
								, erp_stock_qty = 0
								, silsa_in_qty = 0
								, silsa_out_qty = 0
							from sfcuse S WITH (NOLOCK)
							  LEFT OUTER JOIN wc  W WITH (NOLOCK) ON s.wc_no   = w.work_no
							  INNER JOIN GROUPITEM g WITH(NOLOCK) ON s.item_no = g.item_no
/*							where convert(char(10),s.use_date, 112) =  :as_date									*/
          							where s.use_date BETWEEN convert(datetime,  substring(:as_date,1,6) + '01 00:00:00' ) and convert(datetime,  :as_date + ' 23:59:59' )
                			        AND s.loc_no  = :as_locno
                                       AND s.ITEM_NO = :as_item_no
                                       AND s.qa = :as_qa
						group by s.loc_no, s.use_date
								/*   , s.wc_no
							     , convert(char(10), s.use_date, 111)
								*/
								  , s.item_no
								  , s.qa
								  union all
						/*2018.06.14 jowonsuk 추가 */
	 						 SELECT    a.loc_no    
								    , a.sfc_date                                            
							      , a.item_no      
									 , a.qa         
									 , before_qty = 0 
									 , make_qty = 0
									 , buy_in_qty = 0				     /*구매입고*/
									 , ask_in_qty = 0                         /*물품요청입고*/
									 , change_in_qty = 0  			     /*물품대체입고*/
									 , move_in_qty = 0   			     /*물품이동입고*/
									 , etc_in_qty = 0					            /* 기타입고 */
									 , ship_qty   = 0
									 , ask_out_qty = 0                      /*물품요청출고*/
									 , change_out_qty = 0			     /*물품대체출고*/
									 , move_out_qty = 0		          /*물품이동출고*/
									 , JAJE_QTY = sum(JAJE_QTY)
									 , ret_qty    = 0
									 , dis_out_qty = 0                  /*제품폐기*/                    
									 , etc_qty    = 0
									 , intemp_qty = 0
									 , plan_out_qty = 0
									 , plan_make_qty = 0     
									 , NOT_out_qty = 0  
									 , erp_stock_qty = 0
									 , silsa_in_qty = 0
									 , silsa_out_qty = 0
									from                
								  (     
										 SELECT  distinct  coilmst.loc_no    
													 , coilsfcday.sfc_date                                            
													, coilmst.item_no      
													  , coilorderdet.COIL_NO 
													 , coilmst.qa         
													 , before_qty = 0 
													 , make_qty = 0
													 , buy_in_qty = 0				     /*구매입고*/
													 , ask_in_qty = 0                         /*물품요청입고*/
													 , change_in_qty = 0  			     /*물품대체입고*/
													 , move_in_qty = 0   			     /*물품이동입고*/
													 , etc_in_qty = 0					            /* 기타입고 */
													 , ship_qty   = 0
													 , ask_out_qty = 0                      /*물품요청출고*/
													 , change_out_qty = 0			     /*물품대체출고*/
													 , move_out_qty = 0		          /*물품이동출고*/
													 , JAJE_QTY = (isnull(coilmst.unit_qty,0)*isnull(coilorderdet.cnt,0))
													 , ret_qty    = 0
													 , dis_out_qty = 0                  /*제품폐기*/                    
													 , etc_qty    = 0
													 , intemp_qty = 0
													 , plan_out_qty = 0
													 , plan_make_qty = 0     
													 , NOT_out_qty = 0  
													 , erp_stock_qty = 0
													 , silsa_in_qty = 0
													 , silsa_out_qty = 0
											 FROM coilsfcday with(nolock) inner join coilorderdet with(nolock) on coilsfcday.order_no  = coilorderdet.order_no
																					inner join coilmst with(nolock)   on coilorderdet.coil_no      = coilmst.coil_no and coilorderdet.loc_no        = coilmst.loc_no
				/*							WHERE ( ( convert(char(10),coilsfcday.sfc_date, 112) = :as_date ) )   	*/
													where coilsfcday.sfc_date BETWEEN convert(datetime,  substring(:as_date,1,6) + '01 00:00:00' ) and convert(datetime,  :as_date + ' 23:59:59' )
													  AND coilmst.loc_no  LIKE :as_locno
													  AND coilmst.item_no = :as_item_no
													  AND  coilmst.qa = :as_qa
											union all
										 SELECT  distinct  coilmst.loc_no    
													 , coilsfcday.sfc_date                                            
													, coilmst.item_no      
													  , coilordersum.COIL_NO 
													 , coilmst.qa         
													 , before_qty = 0 
													 , make_qty = 0
													 , buy_in_qty = 0				     /*구매입고*/
													 , ask_in_qty = 0                         /*물품요청입고*/
													 , change_in_qty = 0  			     /*물품대체입고*/
													 , move_in_qty = 0   			     /*물품이동입고*/
													 , etc_in_qty = 0					            /* 기타입고 */
													 , ship_qty   = 0
													 , ask_out_qty = 0                      /*물품요청출고*/
													 , change_out_qty = 0			     /*물품대체출고*/
													 , move_out_qty = 0		          /*물품이동출고*/
													 , JAJE_QTY = (isnull(coilmst.unit_qty,0)*isnull(coilordersum.cnt,0))
													 , ret_qty    = 0
													 , dis_out_qty = 0                  /*제품폐기*/                    
													 , etc_qty    = 0
													 , intemp_qty = 0
													 , plan_out_qty = 0
													 , plan_make_qty = 0     
													 , NOT_out_qty = 0  
													 , erp_stock_qty = 0
													 , silsa_in_qty = 0
													 , silsa_out_qty = 0
											 FROM coilsfcday with(nolock) inner join coilordersum with(nolock) on coilsfcday.order_no  = coilordersum.order_no
																					inner join coilmst with(nolock)   on coilordersum.coil_no      = coilmst.coil_no and coilordersum.loc_no        = coilmst.loc_no
				/*							WHERE ( ( convert(char(10),coilsfcday.sfc_date, 112) = :as_date ) )   	*/
													where coilsfcday.sfc_date BETWEEN convert(datetime,  substring(:as_date,1,6) + '01 00:00:00' ) and convert(datetime,  :as_date + ' 23:59:59' )
													  AND coilmst.loc_no  LIKE :as_locno
													  AND coilmst.item_no = :as_item_no
													  AND  coilmst.qa = :as_qa
									  ) a
									group by 	 a.loc_no    
										          	, a.sfc_date                                            
								                , a.item_no                       
									               , a.qa         
								  /*2018.06.14 jowonsuk 추가 */
								  union all			  
							  SELECT coilsfcday.loc_no               
										 , coilsfcday.sfc_date                   
										 , coilsfcday.item_no                       
										 , coilsfcday.qa         
										 , before_qty = 0 
										 , sum(coilsfcday.unit_qty*coilsfcday.cnt) make_qty
										 , buy_in_qty = 0				     /*구매입고*/
									  	 , ask_in_qty = 0                         /*물품요청입고*/
									  	 , change_in_qty = 0  			     /*물품대체입고*/
										 , move_in_qty = 0   			     /*물품이동입고*/
									  	 , etc_in_qty = 0					/* 기타입고 */
									  	 , ship_qty   = 0
								  	 	 , ask_out_qty = 0                      /*물품요청출고*/
								  		 , change_out_qty = 0			     /*물품대체출고*/
									 	 , move_out_qty = 0		          /*물품이동출고*/
									 	 , JAJE_QTY = 0
									  	 , ret_qty    = 0
								  		 , dis_out_qty = 0                  /*제품폐기*/                    
									  	 , etc_qty    = 0
									  	 , intemp_qty = 0
									  	 , plan_out_qty = 0
									  	 , plan_make_qty = 0       
										 , NOT_out_qty = 0
										 , erp_stock_qty = 0
										 , silsa_in_qty = 0
										 , silsa_out_qty = 0
						 FROM coilsfcday with(nolock) inner join coilmst with(nolock)   on coilsfcday.w_coil_no      = coilmst.coil_no and coilsfcday.wloc_no        = coilmst.loc_no
															     inner join coilorderdet with(nolock) on coilsfcday.order_no       = coilorderdet.order_no
/*						WHERE ( ( convert(char(10),coilsfcday.sfc_date, 112) = :as_date ) )   */
									where coilsfcday.sfc_date BETWEEN convert(datetime,  substring(:as_date,1,6) + '01 00:00:00' ) and convert(datetime,  :as_date + ' 23:59:59' )
										  AND coilsfcday.loc_no  LIKE :as_locno
										  AND coilsfcday.item_no = :as_item_no
										  AND  coilsfcday.qa = :as_qa
						  group by    coilsfcday.loc_no            
                   , coilsfcday.sfc_date                 
									 , coilsfcday.item_no                       
									 , coilsfcday.qa  

								 union all
/*
						select 
								 loc_no
							  , rcpt_date
							  , item_no
							  , qa
							  , before_qty = 0 
							  , make_qty   = sum(isnull(rcpt_qty,0)) 
							  , buy_in_qty = 0				     /*구매입고*/
							  , ask_in_qty = 0                         /*물품요청입고*/
							  , change_in_qty = 0  			     /*물품대체입고*/
							  , move_in_qty = 0   			     /*물품이동입고*/
							  , etc_in_qty = 0					/* 기타입고 */
							  , ship_qty   = 0
							  , ask_out_qty = 0                      /*물품요청출고*/
							  , change_out_qty = 0			     /*물품대체출고*/
							  , move_out_qty = 0		          /*물품이동출고*/
							  , JAJE_QTY = 0
							  , ret_qty    = 0
							  , dis_out_qty = 0                  /*제품폐기*/                    
							  , etc_qty    = 0
							  , intemp_qty = 0
							  , plan_out_qty = 0
							  , plan_make_qty = 0
							  , NOT_out_qty = 0
							  , erp_stock_qty = 0
							  , silsa_in_qty = 0
							  , silsa_out_qty = 0
						from coilmst with(nolock)
						where rcpt_date BETWEEN convert(datetime,  substring(:as_date,1,6) + '01 00:00:00' ) and convert(datetime,  :as_date + ' 23:59:59' )
                    AND loc_no  = :as_locno
                    AND ITEM_NO = :as_item_no
                    AND QA = :as_qa
						and ( rem like '%잔량%' AND rem like '%입고%' )
						group by   item_no,
									  qa,
									  loc_no,
                   rcpt_date

								  union all
*/
						 SELECT loc_no  = d.loc_no
									, batchdate  = h.insp_date
					/*			, null wc_no                  
								, batchdate  = convert(char(10),h.insp_date,111)
					*/
								, d.item_no
								, qa         = d.qa     
								, before_qty = 0
								, make_qty   = 0
								, buy_in_qty = sum(isnull(d.rcpt_qty, 0))     /*구매입고*/
								, ask_in_qty = 0                         /*물품요청입고*/
								, change_in_qty = 0  			     /*물품대체입고*/
								, move_in_qty = 0   			     /*물품이동입고*/
								, etc_in_qty = 0						/* 기타입고 */
								, ship_qty   = 0
								, ask_out_qty = 0                      /*물품요청출고*/
								, change_out_qty = 0			     /*물품대체출고*/
								, move_out_qty = 0		          /*물품이동출고*/
					   		      , JAJE_QTY = 0
								, ret_qty    = 0
          					          , dis_out_qty = 0                  /*제품폐기*/ 
								, etc_qty    = 0
								, intemp_qty = 0
								, plan_out_qty = 0
								, plan_make_qty = 0
							     , NOT_out_qty = 0
								, erp_stock_qty = 0
								 , silsa_in_qty = 0
								 , silsa_out_qty = 0
							FROM inspdet D WITH (NOLOCK)
								  inner JOIN insp  H WITH (NOLOCK) ON d.insp_no = h.insp_no
/*						  WHERE  convert(char(10),h.insp_date, 112) =  :as_date 											*/
						  WHERE  h.insp_date BETWEEN convert(datetime,  substring(:as_date,1,6) + '01 00:00:00' ) and convert(datetime,  :as_date + ' 23:59:59' )   			
			                        AND d.loc_no  = :as_locno
                               AND d.ITEM_NO = :as_item_no
                               AND d.QA = :as_qa
						  group by d.loc_no, h.insp_date, d.item_no, d.qa																															 
								   union all	
						 SELECT loc_no     = a.loc_no
							  , batchdate    = b.issue_date
		/*					  , null wc_no
							  , batchdate    = convert(char(10),b.do_date,111)
		*/	
							  , a.item_no
							  , qa         = a.qa      
							  , BEFORE_QTY = 0
							  , MAKE_QTY = 0
							  , buy_in_qty = 0     /*구매입고*/
							  , ask_in_qty = 0                         /*물품요청입고*/
							  , change_in_qty = 0  			     /*물품대체입고*/
							  , move_in_qty = 0   			     /*물품이동입고*/
							  , etc_in_qty = 0					/* 기타입고 */
							  , ship_qty   = sum(isnull(a.ship_qty,0))
							  , ask_out_qty = 0                      /*물품요청출고*/
							  , change_out_qty = 0			     /*물품대체출고*/
							  , move_out_qty = 0		          /*물품이동출고*/
						       , JAJE_QTY = 0
							  , ret_qty    = 0
              					  , dis_out_qty = 0                  /*제품폐기*/                 
							  , etc_qty    = 0
							  , intemp_qty = 0           
							  , plan_out_qty = 0
							  , plan_make_qty = 0
							  , NOT_out_qty = 0
							  , erp_stock_qty = 0
							  , silsa_in_qty = 0
							  , silsa_out_qty = 0
						  FROM dodet  A with(nolock)
								 inner JOIN do  B WITH (NOLOCK) ON a.do_no   = b.do_no                                                                                                                                  
/*						 WHERE convert(char(10),b.issue_date,112) =  :as_date	*/	/*do_date 를 2018.05.18 jowonsuk */		
						 WHERE  b.issue_date BETWEEN convert(datetime,  substring(:as_date,1,6) + '01 00:00:00' ) and convert(datetime,  :as_date + ' 23:59:59' )                                    
									   and a.loc_no  = :as_locno
                      AND a.ITEM_NO = :as_item_no
                      AND a.QA = :as_qa
							   AND a.ship_qty > 0     /* 반품정리시 -수량 발생함 */
							/*   AND b.ewol    <> 'Y' */  /* 송장이월 SKIP  JOWONSUK 2018.06.13 주석처리 */
						 group by a.loc_no, b.issue_date,  a.item_no, a.qa
							union all																	
						 SELECT loc_no     = d.src_loc
								, batchdate = d.alter_date
			/*					, null wc_no 
								, batchdate = convert(char(10),d.alter_date,111)               
			*/                                      
								, d.src_item item_no
								, qa         = d.src_qa   
								, before_qty = 0
								, make_qty = 0
								, buy_in_qty = 0    				 /*구매입고*/
								, ask_in_qty = 0                         /*물품요청입고*/
								, change_in_qty = 0  			     /*물품대체입고*/
								, move_in_qty = 0   			     /*물품이동입고*/
							      , etc_in_qty = 0					/* 기타입고 */
								, ship_qty = 0
								, ask_out_qty = 0                      /*물품요청출고*/
								, change_out_qty = sum( isnull(d.src_qty, 0))			     /*물품대체출고*/
								, move_out_qty = 0		          /*물품이동출고*/
							     , JAJE_QTY = 0
								, ret_qty   = 0   
            					    , dis_out_qty = 0                  /*제품폐기*/                                 
								, etc_qty  = 0
								, intemp_qty = 0              
								, plan_out_qty = 0
								, plan_make_qty = 0
								, NOT_out_qty = 0
								, erp_stock_qty = 0
							     , silsa_in_qty = 0
								, silsa_out_qty = 0
							FROM itemalter D WITH (NOLOCK)
/*						  WHERE convert(char(10),d.alter_date, 112) =  :as_date			*/
						  WHERE d.alter_date BETWEEN convert(datetime,  substring(:as_date,1,6) + '01 00:00:00' ) and convert(datetime,  :as_date + ' 23:59:59' )           
		 	                        AND d.src_loc  = :as_locno
                               AND d.src_item = :as_item_no
                               AND d.src_qa = :as_qa
							   AND d.issue_flag  = 'Y'
 						  group by d.src_loc, d.alter_date, d.src_item, d.src_qa                                                                         
							 union all
						SELECT loc_no      = d.tar_loc
								  , batchdate  = d.alter_date
		/*						  ,  null wc_no
								  , batchdate  = convert(char(10),d.alter_date,111)
		*/
								  , item_no    = d.tar_item
								  , qa          = d.tar_qa   
								  , before_qty = 0
								  , make_qty = 0
								  , buy_in_qty = 0    								 /*구매입고*/
								  , ask_in_qty = 0									 /*물품요청입고*/
								  , change_in_qty = sum(isnull(d.tar_qty, 0))    /*물품대체입고*/
								  , move_in_qty = 0   								/*물품이동입고*/
								  , etc_in_qty = 0					/* 기타입고 */
								  , ship_qty    = 0
								  , ask_out_qty = 0                      /*물품요청출고*/
							       , change_out_qty = 0			     /*물품대체출고*/
								  , move_out_qty = 0		          /*물품이동출고*/
							       , JAJE_QTY = 0
								  , ret_qty   = 0
      					            , dis_out_qty = 0                  /*제품폐기*/                                                   
								  , etc_qty   = 0
								  , intemp_qty = 0                               
								  , plan_out_qty = 0
								  , plan_make_qty = 0
								  , NOT_out_qty = 0
								  , erp_stock_qty = 0
								  , silsa_in_qty = 0
								  , silsa_out_qty = 0
						  FROM itemalter D WITH (NOLOCK)
/*					    WHERE convert(char(10),d.alter_date, 112) =  :as_date*/
					    WHERE d.alter_date BETWEEN convert(datetime,  substring(:as_date,1,6) + '01 00:00:00' ) and convert(datetime,  :as_date + ' 23:59:59' )
                   	                AND d.tar_loc  = :as_locno
                                     AND d.tar_item = :as_item_no
                                     AND d.tar_qa = :as_qa
               group by d.tar_loc, d.tar_item, d.tar_qa, d.alter_date
							union all																														 
						  SELECT loc_no     = a.loc_no   
				/*					 , null wc_no 
									 , batchdate  = convert(char(10),a.rlse_date,111)   
				*/
									 , batchdate  = a.rlse_date
									 , a.item_no
									 , qa         = a.qa   
									 , before_qty = 0
									 , make_qty = 0
									 , buy_in_qty = 0     				/*구매입고*/
									 , ask_in_qty = 0					/*물품요청입고*/
									 , change_in_qty = 0  			     /*물품대체입고*/
									 , move_in_qty = 0   			     /*물품이동입고*/
									 , etc_in_qty = 0					/* 기타입고 */
									 , ship_qty = 0
								  	 , ask_out_qty = sum(isnull(a.rlse_qty,0))                       /*물품요청출고*/ /* jowonsuk 2018.08.08 issue_qty -> rlse_qty */
									 , change_out_qty = 0			     /*물품대체출고*/
									 , move_out_qty = 0		          /*물품이동출고*/
  									 , JAJE_QTY = 0
									 , ret_qty   = 0   
                 						  , dis_out_qty = 0                  /*제품폐기*/                                                                      
									 , etc_qty  = 0
									 , intemp_qty = 0                          
									 , plan_out_qty = 0
									 , plan_make_qty = 0
									 , NOT_out_qty = 0
								      , erp_stock_qty = 0
									 , silsa_in_qty = 0
									 , silsa_out_qty = 0
								 FROM ask_det A WITH (NOLOCK)
										LEFT OUTER JOIN ask_head B WITH (NOLOCK) ON a.ask_no = b.ask_no
/*								WHERE convert(char(10),a.rlse_date, 112) =  :as_date			*/
								WHERE a.rlse_date BETWEEN convert(datetime,  substring(:as_date,1,6) + '01 00:00:00' ) and convert(datetime,  :as_date + ' 23:59:59' )
			                         AND a.loc_no  = :as_locno
                                        AND a.ITEM_NO = :as_item_no
                                        AND a.QA = :as_qa
							group by a.loc_no,  a.rlse_date,  a.item_no, a.qa																														 
								having sum(isnull(a.rlse_qty,0))    <> 0
							 union all														 
						  SELECT  loc_no     = b.ask_loc   
/*									 , null wc_no                               
									 , batchdate  = convert(char(10),a.rlse_date,111)   
*/
									 , a.rlse_date BATCHDATE
									 , a.item_no
									 , qa         = a.qa   
									 , before_qty = 0
									 , make_qty = 0
									  , buy_in_qty = 0     				/*구매입고*/
									  , ask_in_qty = sum(isnull(a.rlse_qty,0))					/*물품요청입고*/ /* jowonsuk 2018.08.08 issue_qty -> rlse_qty */
									  , change_in_qty = 0  			     /*물품대체입고*/
									  , move_in_qty = 0   			     /*물품이동입고*/
									  , etc_in_qty = 0					/* 기타입고 */
									 , ship_qty = 0
									 , ask_out_qty = 0                      /*물품요청출고*/
									 , change_out_qty = 0			     /*물품대체출고*/
									 , move_out_qty = 0		          /*물품이동출고*/
							     		 , JAJE_QTY = 0
									 , ret_qty   =  0
         							      , dis_out_qty = 0           		       /*제품폐기*/                                                                                         
									 , etc_qty  = 0
									 , intemp_qty = 0       
									 , plan_out_qty = 0
									 , plan_make_qty = 0
									 , NOT_out_qty = 0
								      , erp_stock_qty = 0
									 , silsa_in_qty = 0
									 , silsa_out_qty = 0
							 FROM ask_det A WITH (NOLOCK)
								LEFT OUTER JOIN ask_head B ON a.ask_no = b.ask_no
/*							WHERE convert(char(10),a.rlse_date, 112) =  :as_date 					*/
							WHERE a.rlse_date BETWEEN convert(datetime,  substring(:as_date,1,6) + '01 00:00:00' ) and convert(datetime,  :as_date + ' 23:59:59' )
			                           AND b.ask_loc  = :as_locno
								 AND a.ITEM_NO = :as_item_no
								 AND a.QA = :as_qa
							group by b.ask_loc, a.rlse_date,  a.item_no,  a.qa                                  
								having sum(isnull(a.rlse_qty,0))    <> 0
							union all
							SELECT loc_no     = b.src_loc                         
/*									 , null wc_no                                              
									 , batchdate  = convert(char(10),b.move_date,111)                 
*/
									 , batchdate  = b.move_date
									 , a.item_no
									 , qa         = a.qa             
									 , before_qty = 0
									 , make_qty = 0
									  , buy_in_qty = 0     				/*구매입고*/
									  , ask_in_qty = 0					/*물품요청입고*/
									  , change_in_qty = 0  			     /*물품대체입고*/
									  , move_in_qty = 0   			     /*물품이동입고*/
									  , etc_in_qty = 0					/* 기타입고 */
									 , ship_qty = 0
									 , ask_out_qty = 0                      /*물품요청출고*/
									 , change_out_qty = 0			     /*물품대체출고*/
									 , move_out_qty = sum( case when substring(a.item_no,4,1) = '1' then (isnull(a.move_qty*a.cnt,0)) else (isnull(a.cnt,0))  end )	          /*물품이동출고*/
								      , JAJE_QTY = 0                   
									 , ret_qty   = 0   
            						       , dis_out_qty = 0                  /*제품폐기*/ 
									 , etc_qty  = 0
									 , intemp_qty = 0       
									 , plan_out_qty = 0
									 , plan_make_qty = 0
									 , NOT_out_qty = 0
								      , erp_stock_qty = 0
									 , silsa_in_qty = 0
									 , silsa_out_qty = 0
								 FROM itemmovedet A WITH (NOLOCK)  
										LEFT OUTER JOIN itemmove B WITH (NOLOCK) ON a.move_no = b.move_no
/*								WHERE convert(char(10),b.move_date, 112) =  :as_date					*/
							WHERE b.move_date BETWEEN convert(datetime,  substring(:as_date,1,6) + '01 00:00:00' ) and convert(datetime,  :as_date + ' 23:59:59' )
				 				 AND RTRIM(LTRIM(b.src_loc))  = :as_locno
                 and a.item_no = :as_item_no
                 AND a.QA = :as_qa
							  group by b.src_loc, b.move_date, a.item_no,a.qa                                         
								union all
				 		   SELECT  b.tar_loc   LOC_NO
/*									 , null wc_no                                  
									 , batchdate  = convert(char(10),b.move_date,111)           
*/      
									 , batchdate  = b.move_date
									 , a.item_no
									 , qa         = a.qa      
									 , before_qty = 0
									 , make_qty = 0
									  , buy_in_qty = 0     				/*구매입고*/
									  , ask_in_qty = 0					/*물품요청입고*/
									  , change_in_qty = 0  			     /*물품대체입고*/
									  , move_in_qty = sum( case when substring(a.item_no,4,1) = '1' then (isnull(a.move_qty*a.cnt,0)) else (isnull(a.cnt,0))  end )   			     /*물품이동입고*/
									  , etc_in_qty = 0					/* 기타입고 */
									  , ship_qty = 0
									  , ask_out_qty = 0                      /*물품요청출고*/
									  , change_out_qty = 0			     /*물품대체출고*/
									  , move_out_qty = 0		          /*물품이동출고*/
							  		  , JAJE_QTY = 0
									  , ret_qty   = 0
           						       , dis_out_qty = 0                  /*제품폐기*/                    
									 , etc_qty  = 0           
									 , intemp_qty = 0
									 , plan_out_qty = 0
									 , plan_make_qty = 0
									 , NOT_out_qty = 0
									 , erp_stock_qty = 0
									 , silsa_in_qty = 0
									 , silsa_out_qty = 0
								 FROM itemmovedet A WITH (NOLOCK)                 
								 LEFT OUTER JOIN itemmove B ON a.move_no = b.move_no              
/*								WHERE  convert(char(10),b.move_date, 112) =  :as_date 	*/
								WHERE  b.move_date BETWEEN convert(datetime,  substring(:as_date,1,6) + '01 00:00:00' ) and convert(datetime,  :as_date + ' 23:59:59' )
							           AND   RTRIM(LTRIM(b.tar_loc))  = :as_locno
									 and   a.ITEM_NO = :as_item_no
									 and   a.QA = :as_qa
								group by b.tar_loc, b.move_date  , a.item_no, a.qa        
								 union all
							SELECT loc_no
/*									  , null wc_no        
              						        , batchdate  = convert(char(10),intemp_date,111)
*/
            			, intemp_date
									 , item_no
									 , qa
									 , before_qty = 0
									 , make_qty = 0
									 , buy_in_qty = 0     				/*구매입고*/
									 , ask_in_qty = 0					/*물품요청입고*/
								  	 , change_in_qty = 0  			     /*물품대체입고*/
								  	 , move_in_qty = 0   			     /*물품이동입고*/
									  , etc_in_qty = 0					/* 기타입고 */
									 , ship_qty = 0
							   		 , JAJE_QTY = 0
									 , ask_out_qty = 0                      /*물품요청출고*/
									 , change_out_qty = 0			     /*물품대체출고*/
									 , move_out_qty = 0		          /*물품이동출고*/
									 , ret_qty   = 0
                 						 , dis_out_qty = 0                  /*제품폐기*/                    
									 , etc_qty  = 0                                                                                               
									 , intemp_qty = sum(isnull(qty ,0))
									 , plan_out_qty = 0
									 , plan_make_qty = 0
									 , NOT_out_qty = 0
								      , erp_stock_qty = 0
									 , silsa_in_qty = 0
									 , silsa_out_qty = 0
							  FROM INTEMP with(nolock)
/*							  WHERE convert(char(10),intemp_date, 112) =  :as_date				*/
							  WHERE intemp_date BETWEEN convert(datetime,  substring(:as_date,1,6) + '01 00:00:00' ) and convert(datetime,  :as_date + ' 23:59:59' )		
								  AND loc_no = :as_locno
								  AND ITEM_NO = :as_item_no
								  AND QA = :as_qa
							  group by  loc_no,  intemp_date, item_no, qa
							  union all
							  select   a.loc_no
/*									  , null wc_no          
									  , batchdate  = convert(char(10),b.ret_date,111)
*/
									  , batchdate  =b.ret_date
									  , item_no
									  , qa
									  , before_qty = 0
									  , make_qty = 0
									  , buy_in_qty = 0     				/*구매입고*/
									  , ask_in_qty = 0					/*물품요청입고*/
									  , change_in_qty = 0  			     /*물품대체입고*/
									  , move_in_qty = 0   			     /*물품이동입고*/
									  , etc_in_qty = 0					/* 기타입고 */
									  , ship_qty = 0
									  , ask_out_qty = 0                      /*물품요청출고*/
									  , change_out_qty = 0			     /*물품대체출고*/
									  , move_out_qty = 0		          /*물품이동출고*/
							      	  , JAJE_QTY = 0
									  , ret_qty   = sum(isnull(a.acc_qty,0)+isnull(a.free_qty,0))
                  						  , dis_out_qty = 0                  /*제품폐기*/                                        
									  , etc_qty  = 0                                                                                               
									  , intemp_qty = 0
									  , plan_out_qty = 0
									  , plan_make_qty = 0
									  , NOT_out_qty = 0
								       , erp_stock_qty = 0
									  , silsa_in_qty = 0
									  , silsa_out_qty = 0
							  FROM retdet a inner join ret b on a.ret_no = b.ret_no
/*							  where convert(char(10),b.ret_date, 112) =  :as_date	*/
							  where b.ret_date BETWEEN convert(datetime,  substring(:as_date,1,6) + '01 00:00:00' ) and convert(datetime,  :as_date + ' 23:59:59' )		
				 			    AND a.loc_no = :as_locno
							    AND a.ITEM_NO = :as_item_no
							   AND a.QA = :as_qa
							  group by a.loc_no, b.ret_date,  item_no, qa
							  union all
							  select   loc_no
/*									  , wc_no      
						                 , batchdate  = convert(char(10), ret_date, 111)
*/
						        , batchdate  = ret_date
									  , item_no
									  , qa
									  , before_qty = 0
									  , make_qty = 0
									  , buy_in_qty = 0     				/*구매입고*/
									  , ask_in_qty = 0					/*물품요청입고*/
									  , change_in_qty = 0  			     /*물품대체입고*/
									  , move_in_qty = 0   			     /*물품이동입고*/
									  , etc_in_qty = 0					/* 기타입고 */
									  , ship_qty = 0
									  , ask_out_qty = 0                      /*물품요청출고*/
									  , change_out_qty = 0			     /*물품대체출고*/
								    , move_out_qty = 0		          /*물품이동출고*/
							      , JAJE_QTY = 0
									  , ret_qty = sum(isnull(ret_qty,0)) 
                    , dis_out_qty = 0                  /*제품폐기*/                                        
									  , etc_qty = 0                           
									  , intemp_qty = 0
									  , plan_out_qty = 0
									  , plan_make_qty = 0
									  , NOT_out_qty = 0
								       , erp_stock_qty = 0
									  , silsa_in_qty = 0
									  , silsa_out_qty = 0
								from sfcret
/*						  	   where convert(char(10), ret_date, 112) =  :as_date 	*/
                     where ret_date between convert(datetime,  substring(:as_date,1,6) + '01 00:00:00' ) and convert(datetime,  :as_date + ' 23:59:59' )  	
							      AND LOC_NO = :as_locno
                     AND ITEM_NO = :as_item_no
                     AND QA = :as_qa
							group by loc_no,  ret_date,  item_no, qa
			        union all
										 SELECT   a.LOC_NO
													  /*, WC_NO  = null
											            , convert(char(10), b.aban_date, 111) 
													*/
											      , b.aban_date
													  , a.ITEM_NO
													  , a.QA
													  , before_qty = 0 
													  , make_qty   = 0
													  , buy_in_qty = 0     				/*구매입고*/
													  , ask_in_qty = 0					/*물품요청입고*/
													  , change_in_qty = 0  			     /*물품대체입고*/
													  , move_in_qty = 0   			     /*물품이동입고*/
				 								     , etc_in_qty = 0						/* 기타입고 */
													  , ship_qty   = 0
													  , ask_out_qty = 0                      /*물품요청출고*/
													  , change_out_qty = 0			     /*물품대체출고*/
													  , move_out_qty = 0		          /*물품이동출고*/
							     		 		 , JAJE_QTY = 0
													  , ret_qty    = 0
                        	  , dis_out_qty = sum(ISNULL(a.QTY,0))   /*제품폐기*/                    
													  , etc_qty    = 0
													  , intemp_qty = 0
													  , plan_out_qty  = 0
													  , plan_make_qty = 0
													  , NOT_out_qty = 0
													  , erp_stock_qty = 0
													  , silsa_in_qty = 0
												  	  , silsa_out_qty = 0
										 FROM itemabandet a  WITH(NOLOCK) inner join itemaban b  WITH(NOLOCK) on a.aban_no = b.aban_no
/*										 WHERE convert(char(10), b.aban_date, 112) =  :as_date			*/
										 WHERE b.aban_date between convert(datetime,  substring(:as_date,1,6) + '01 00:00:00' ) and convert(datetime,  :as_date + ' 23:59:59' )  
											  AND a.LOC_NO = :as_locno
											 AND a.ITEM_NO = :as_item_no
											 AND a.QA = :as_qa
						                     group by a.loc_no, b.aban_date, a.item_no, a.qa
										union all
										select     loc_no
                          ,etcout_date
												  , item_no
												  , qa
												  , before_qty = 0 
												  , make_qty   = 0
												  , buy_in_qty = 0     				/*구매입고*/
												  , ask_in_qty = 0					/*물품요청입고*/
												  , change_in_qty = 0  			     /*물품대체입고*/
												  , move_in_qty = 0   			     /*물품이동입고*/
		  									       , etc_in_qty = sum(case when etc_kind >= '51' then ISNULL(QTY,0) else 0 end )						/* 기타입고 */
												  , ship_qty   = 0
				  								  , ask_out_qty = 0                      /*물품요청출고*/
												  , change_out_qty = 0			     /*물품대체출고*/
												  , move_out_qty = 0		          /*물품이동출고*/
										   		  , JAJE_QTY = 0
												  , ret_qty    = 0
                          								  , dis_out_qty = 0                  /*제품폐기*/                    
												  , etc_qty    = sum(case when etc_kind <= '50' then ISNULL(QTY,0) else 0 end )
												  , intemp_qty = 0
												  , plan_out_qty  = 0
												  , plan_make_qty = 0    
												  , NOT_out_qty = 0
												  , erp_stock_qty = 0
										            , silsa_in_qty = 0
										 		  , silsa_out_qty = 0
										from etcout  WITH(NOLOCK)
/* 										     where convert(char(10), etcout_date, 112) =  :as_date			*/
 										     where etcout_date between convert(datetime,  substring(:as_date,1,6) + '01 00:00:00' ) and convert(datetime,  :as_date + ' 23:59:59' )  											  
											 AND LOC_NO = :as_locno
											 AND ITEM_NO = :as_item_no
											 AND QA = :as_qa
						                     group by loc_no, etcout_date, item_no, qa				

				) a inner  join groupitem  b with(nolock) on a.item_no = b.item_no
					inner  join location e with(nolock) on a.loc_no = e.loc_no
					inner join code1 f on b.p1 = f.code
					inner join item with(nolock) on a.item_no = item.item_no and a.qa = item.qa
						where b.p1 like :as_gubun
						   and a.loc_no is not null

          			      and  b.cost_yn <> 'Y' /*2018.04.12 조원석 비용 제외 */
					group by  a.loc_no,
				                  	e.loc_name,
                            convert(CHAR(10), a.stock_date, 121),
								a.item_no,
								a.qa,
								b.item_name,
								f.code_name,
								item.use_flag,
								b.uom
					having    sum(
											abs(isnull(a.before_qty,0)) +
											abs(isnull(a.make_qty,0)) +
											abs(isnull(a.buy_in_qty,0)) +
											abs(isnull(a.ask_in_qty,0)) +
											abs(isnull(a.change_in_qty,0)) +
											abs(isnull(a.move_in_qty,0)) +              
											abs(isnull(a.etc_in_qty,0)) +
											abs(isnull(a.intemp_qty,0)) +
											abs(isnull(a.ship_qty,0)) +
											abs(isnull(a.ask_out_qty,0)) +
											abs(isnull(a.change_out_qty,0)) +
											abs(isnull(a.move_out_qty,0)) +
											abs(isnull(a.jaje_qty,0)) +
											abs(isnull(a.ret_qty,0))  +
											abs(isnull(a.dis_out_qty,0)) +
											abs(isnull(a.etc_qty,0)) +
							  			     abs(isnull(a.plan_out_qty,0)) +
 										     abs(isnull(a.plan_make_qty,0)) +
											abs(isnull(a.not_out_qty,0))
									) <> 0" arguments=(("as_gubun", string),("as_locno", string),("as_date", string),("as_item_no", string),("as_qa", string))  sort="stock_date A " )
text(band=header alignment="2" text="발생일자" border="6" color="33554432" x="9" y="8" height="60" width="384" html.valueishtml="0"  name=t_1 visible="1"  font.face="굴림체" font.height="-10" font.weight="700"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="67108864" )
