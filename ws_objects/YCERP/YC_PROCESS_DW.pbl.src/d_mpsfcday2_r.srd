 column=(type=char(20) updatewhereclause=yes name=wc_work_name dbname="wc.work_name" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"sfcuse~" )  TABLE(NAME=~"color~" )  TABLE(NAME=~"groupitem~" )  TABLE(NAME=~"wc~" ) COLUMN(NAME=~"sfcuse.order_no~") COLUMN(NAME=~"sfcuse.wc_no~") COLUMN(NAME=~"sfcuse.use_date~") COLUMN(NAME=~"sfcuse.item_no~") COLUMN(NAME=~"sfcuse.qa~") COLUMN(NAME=~"sfcuse.uom~") COLUMN(NAME=~"sfcuse.use_qty~") COLUMN(NAME=~"sfcuse.coil_no~") COLUMN(NAME=~"sfcuse.color~") COLUMN(NAME=~"sfcuse.color_type~") COLUMN(NAME=~"color.color_name~") COLUMN(NAME=~"sfcuse.cnt~") COLUMN(NAME=~"sfcuse.unit_qty~") COLUMN(NAME=~"sfcuse.mod_qty~") COLUMN(NAME=~"sfcuse.mod_len~") COLUMN(NAME=~"groupitem.item_name~") COLUMN(NAME=~"wc.work_name~")    JOIN (LEFT=~"sfcuse.color~"    OP =~"=~"RIGHT=~"color.color_code~"    OUTER1 =~"sfcuse.color~" )    JOIN (LEFT=~"sfcuse.item_no~"    OP =~"=~"RIGHT=~"groupitem.item_no~" )    JOIN (LEFT=~"sfcuse.wc_no~"    OP =~"=~"RIGHT=~"wc.work_no~" )WHERE(    EXP1 =~"wc.work_name~"   OP =~"like~"    EXP2 =~":as_wc~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"sfcuse.use_date~"   OP =~"between~"    EXP2 =~":ad_start and :ad_end~" ) ) ORDER(NAME=~"sfcuse.wc_no~" ASC=yes )  ORDER(NAME=~"sfcuse.item_no~" ASC=yes )  ORDER(NAME=~"sfcuse.qa~" ASC=yes ) ARG(NAME = ~"as_wc~" TYPE = string)  ARG(NAME = ~"ad_start~" TYPE = date)  ARG(NAME = ~"ad_end~" TYPE = date) " arguments=(("as_wc", string),("ad_start", date),("ad_end", date))  sort="wc_no A item_no A qa A order_no A " )
