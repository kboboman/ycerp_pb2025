footer(height=0 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=number updatewhereclause=yes name=ship_qty dbname="ship_qty" )
 retrieve="  SELECT groupitem.item_name                              
       , sdate    = convert(smalldatetime, :ad_start, 111)   
       , edate    = convert(smalldatetime, :ad_end, 111)     
       , do.do_date                                       
       , dodet.qa                                         
       , dodet.coil_no                                    
       , cnt      = dodet.cnt
       , ship_qty = dodet.ship_qty
       , dodet.do_no
       , dodet.oi_no
       , customer.cust_name                            
       , coilsheet.unit_qty                                 
       , coilsheet.etc_no  
       , as_flag  = :as_flag
FROM dodet with(nolock) inner join groupitem with(nolock) on dodet.item_no = groupitem.item_no
                           inner join do with(nolock)on dodet.do_no           = do.do_no                           
                           inner join customer  with(nolock) on do.cust_no            = customer.cust_no
                           inner join  (
										select     loc_no = coilmst.loc_no
														 , coil_no= coilmst.coil_no
														 , unit_qty = (case when coilmst.loc_no = 'WS00000000'
																						 then isnull( inspdet.unit_qty , coilmst.unit_qty ) 
																				  else coilmst.unit_qty 
																			end ) /* 스리팅 판매분의 단중은 시화저장소일 경우만 입고단중으로 표기 */
														 , etc_no   = coilmst.etc_no
														 , flag     = coilmst.flag  
										from coilmst with(nolock) inner join 
												  (
														SELECT unit_qty, coil_no
														FROM inspdet with(nolock)
														group by unit_qty, coil_no
														having count(insp_no) = 1
												  ) inspdet
										on coilmst.coil_no = inspdet.coil_no
													  UNION
													  SELECT loc_no, sheet_no, unit_qty, '',     flag  FROM sheetmst with(nolock)
                             ) coilsheet on   dodet.coil_no         = coilsheet.coil_no 
                                            AND  dodet.loc_no          = coilsheet.loc_no  
   WHERE ((:as_area    = '%'   AND do.area_no   LIKE '%' ) or 
                    (:as_area   <> '%'   AND do.area_no      = :as_area )
                   )
         AND ( ( do.do_date    BETWEEN :ad_start AND :ad_end ) AND  
                    ( coilsheet.flag      = :as_flag              ) AND  
                    ( dodet.coil_no  IS NOT NULL                  ) 
                 )    
/*
    FROM groupitem   
       , dodet       
       , do          
       , customer  
       , (
         /* SELECT loc_no, coil_no,  unit_qty, etc_no, flag  FROM coilmst */
            SELECT loc_no = coilmst.loc_no
                 , coil_no= coilmst.coil_no
                 , unit_qty = (case when coilmst.loc_no = 'WS00000000'
                                         then isnull( (SELECT unit_qty FROM inspdet WHERE coil_no = coilmst.coil_no) , coilmst.unit_qty ) 
                                    else coilmst.unit_qty 
                               end ) /* 스리팅 판매분의 단중은 시화저장소일 경우만 입고단중으로 표기 */
                 , etc_no   = coilmst.etc_no
                 , flag     = coilmst.flag  
              FROM coilmst

            UNION
            SELECT loc_no, sheet_no, unit_qty, '',     flag  FROM sheetmst         
         ) coilsheet
   WHERE ( dodet.item_no        *= groupitem.item_no )   
     AND ( dodet.do_no           = do.do_no          )   
     AND ( dodet.coil_no         = coilsheet.coil_no )   
     AND ( dodet.loc_no          = coilsheet.loc_no  )   
     AND ( do.cust_no            = customer.cust_no  )   
     AND ((:as_area    = '%'   AND do.area_no   LIKE '%' ) or 
          (:as_area   <> '%'   AND do.area_no      = :as_area )
         )
     AND ( ( do.do_date    BETWEEN :ad_start AND :ad_end ) AND  
           ( coilsheet.flag      = :as_flag              ) AND  
           ( dodet.coil_no  IS NOT NULL                  ) 
         )    
*/" arguments=(("as_area", string),("ad_start", date),("ad_end", date),("as_flag", string))  sort="item_name A qa A " )
