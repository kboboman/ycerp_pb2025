$PBExportHeader$d_oiitemsum_r.srd
$PBExportComments$판매거래처별 출고물품집계조회(2000/02/15,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=408 color="536870912" )
summary(height=76 color="553648127" )
footer(height=0 color="536870912" )
detail(height=68 color="536870912" )
table(column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=decimal(6) updatewhereclause=yes name=cprice dbname="cprice" )
 column=(type=decimal(4) updatewhereclause=yes name=chqty dbname="chqty" )
 column=(type=decimal(8) updatewhereclause=yes name=csum dbname="csum" )
 column=(type=decimal(4) updatewhereclause=yes name=ccash dbname="ccash" )
 column=(type=char(10) updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=char(10) updatewhereclause=yes name=edate dbname="edate" )
 retrieve="  SELECT distinct c.cust_name
       , scene.scene_desc
       , groupitem.item_name
       , dodet.qa
       , dodet.uom
       , cprice = avg( dodet.price )
       , chqty  = sum( dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty))
       , csum   = sum((case when c.round = 'Y' then 
                                 round((dodet.price * dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty)), 0,0)
						          else round((dodet.price * dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty)), 0,1) 
                       end)
                     )
		 , ccash = sum(dodet.rate_cash )
       , sdate = (case when :as_sdate = '' then space(10) else :as_sdate end)
       , edate = (case when :as_edate = '' then space(10) else :as_edate end)
    FROM UF_MyCustomers( :as_salesman ) M
         LEFT OUTER JOIN customer C ON m.cust_no     = c.cust_no
         LEFT OUTER JOIN do         ON c.cust_no     = do.cust_no
         LEFT OUTER JOIN dodet      ON do.do_no      = dodet.do_no
         LEFT OUTER JOIN groupitem  ON dodet.item_no = groupitem.item_no
         LEFT OUTER JOIN scene      ON do.spot_code  = scene.scene_code 
         LEFT OUTER JOIN login      ON c.salesman    = login.user_id
   WHERE ( do.do_no           LIKE :as_area          )
     AND ( do.do_date      BETWEEN :as_sdate and :as_edate )
     AND ((:as_team  = '%' AND m.cust_no   LIKE '%'  ) OR 
          (:as_team <> '%' AND m.salesman     = :as_salesman )
         )
     AND ((:as_custno  = '%'   AND m.cust_no   LIKE '%'  ) OR 
          (:as_custno  = 'ALL' AND m.cust_no   LIKE '%'  ) OR 
          (:as_custno <> 'ALL' AND m.cust_no      = :as_custno )
         )
 	group by c.cust_name,  
            scene.scene_desc,   
            groupitem.item_name,   
            dodet.qa,   
            dodet.uom
	order by c.cust_name,  
            scene.scene_desc,   
            groupitem.item_name,   
            dodet.qa,   
            dodet.uom
" arguments=(("as_area", string),("as_custno", string),("as_sdate", string),("as_edate", string),("as_salesman", string),("as_team", string)) )
group(level=1 header.height=0 trailer.height=76 by=("cust_name" ) newpage=yes header.color="536870912" trailer.color="553648127" )
