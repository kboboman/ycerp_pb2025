table(column=(type=char(14) updatewhereclause=yes name=do_do_no dbname="do.do_no" )
 column=(type=datetime updatewhereclause=yes name=do_do_date dbname="do.do_date" )
 column=(type=char(80) updatewhereclause=yes name=do_shipto_addr dbname="do.shipto_addr" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_cash dbname="do.do_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_rate dbname="do.do_rate" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_total dbname="do.do_total" )
 column=(type=char(13) updatewhereclause=yes name=do_dr_hp dbname="do.dr_hp" )
 column=(type=long updatewhereclause=yes name=dodet_oi_no dbname="dodet.oi_no" )
