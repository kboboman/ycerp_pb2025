compute(band=summary alignment="1" expression="sum(환산수량 for all )"border="0" color="33554432" x="434" y="4" height="72" width="384" format="[general]" html.valueishtml="0"  name=compute_2 visible="1"  font.face="굴림체" font.height="-10" font.weight="700"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
compute(band=summary alignment="1" expression="sum(grand_sum_환산수량 for all )"border="0" color="33554432" x="827" y="4" height="72" width="686" format="[general]" html.valueishtml="0"  name=compute_3 visible="1"  font.face="굴림체" font.height="-10" font.weight="700"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
 crosstab(band = foreground  crosstabonly = yes 
 columns = "납기일자" rows = "작업장명" values = "sum(환산수량 for crosstab)" sourcenames = "사업장, 작업장, 작업장명, 작업위치, 작업장타입, 사용, 작업예정, 분할, 작업순위, 작업진행, 수주번호, 순번, 거래처, 현장명, 납기일자, 수주유형, 물품번호, 물품명, 수주물품, 수주규격, 색상코드, 색상, 환산수량, 주문량, 출고량, 계획량, 제조량, 제조물품, 제조규격, 제조단위, 계획유무, 캐파, 비고, 수주마감")htmltable(border="0" cellpadding="1" cellspacing="1" )
