type pb_retrieve from w_inheritance`pb_retrieve within w_ippurchasenew_m
integer x = 3310
integer y = 60
integer taborder = 210
end type

event pb_retrieve::clicked;//==GF_USEPROGRAM(프로그램 사용현황)==============================================================
GF_USEPROGRAM( gs_userid, Parent.ClassName(), "R", string(gf_today(),'yyyy/mm/dd'), Parent.Title )
//================================================================================================

string ls_area, ls_suppno
long   ll_row
date   ld_sdate, ld_edate

dw_area.accepttext()
ls_area   = LeftA(dw_area.object.area[1],1)

dw_11.accepttext()
ls_suppno = trim(dw_11.object.supp_no[1])
if ls_suppno = "" OR isnull(ls_suppno) then
	ls_suppno = "%"
end if 

pb_delete.enabled = true
pb_save.enabled   = true

ld_sdate = date(em_s.text)
ld_edate = date(em_e.text)
if Not IsDate(em_s.text) then
	em_s.setfocus()
	RETURN
end if

if Not IsDate(em_e.text) then
	em_e.setfocus()
	RETURN
end if

dw_2.setredraw(false)
dw_2.reset()
ll_row = dw_2.retrieve( ls_suppno, '%', '%', ld_sdate, ld_edate, ls_area ) 
if ll_row < 1 then
	dw_1.reset()
	dw3.reset()
end if
dw_2.setredraw(true)

tab_1.selecttab(1)

end event

