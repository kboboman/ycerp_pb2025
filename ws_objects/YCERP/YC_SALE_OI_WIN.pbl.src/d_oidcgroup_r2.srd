 retrieve="  SELECT dc_groupno   = a.dc_groupno       
       , dc_date      = a.dc_date
       , team_name    = f.team_name
       , user_name    = d.user_name
       , dc_app1      = a.dc_app1     
       , dc_app2      = a.dc_app2     
       , dc_app3      = a.dc_app3     
       , dc_app4      = a.dc_app4     
       , dc_app5      = a.dc_app5     
       , rank1        = h.rank1
       , rank2        = (case when a.dc_app2 = '' then '' else l2.rank end)
       , rank3        = l3.rank /* (case when a.dc_app3 = '' then '' else h.rank3 end) */
       , rank4        = l4.rank
       , rank5        = '승인' /* l5.rank */
       , user1   = substring(rtrim(l1.user_name),1,2) + char(13) + substring(rtrim(l1.user_name),3,2) + (case when l1.user_name is null or l1.user_name = '' then '' else '인' end)
       , user2   = substring(rtrim(l2.user_name),1,2) + char(13) + substring(rtrim(l2.user_name),3,2) + (case when l2.user_name is null or l2.user_name = '' then '' else '인' end)
       , user3   = substring(rtrim(l3.user_name),1,2) + char(13) + substring(rtrim(l3.user_name),3,2) + (case when l3.user_name is null or l3.user_name = '' then '' else '인' end)
       , user4   = substring(rtrim(l4.user_name),1,2) + char(13) + substring(rtrim(l4.user_name),3,2) + (case when l4.user_name is null or l4.user_name = '' then '' else '인' end)
       , user5   = substring(rtrim(l5.user_name),1,2) + char(13) + substring(rtrim(l5.user_name),3,2) + (case when l5.user_name is null or l5.user_name = '' then '' else '인' end)
       , dc_appdt1    = a.dc_appdt1
       , dc_appdt2    = a.dc_appdt2
       , dc_appdt3    = a.dc_appdt3
       , dc_appdt4    = a.dc_appdt4
       , dc_appdt5    = a.dc_appdt5
       , dc_return    = a.dc_return
       , dc_balteam   = a.dc_balteam  
       , dc_hyupteam  = a.dc_hyupteam 
       , dc_hyupuser  = a.dc_hyupuser
       , dc_hyupdt    = a.dc_hyupdt
       , cust_name    = c.cust_name
       , dc_type      = a.dc_type
       , cap_name     = a.cap_name    
       , dc_content   = a.dc_content
       , scene_name   = g.scene_desc
       , price        = b.price
       , rem          = b.rem
       , dc_rem1      = a.dc_rem1
       , dc_rem2      = a.dc_rem2
       , dc_rem3      = a.dc_rem3
       , dc_rem4      = a.dc_rem4
       , dc_rem5      = a.dc_rem5
       , level_credit = a.level_credit
       , price_level  = a.price_level 
       , terms        = a.terms       
       , shipamt_case = a.shipamt_case
       , credit_limit = a.credit_limit
       , balance_amt  = a.balance_amt 
       , main_co      = a.main_co     
       , license_name = a.license_name
       , totprice     = a.totprice       
       , calc_amt     = b.calc_amt
       , calc_rate    = b.calc_rate
    FROM dc_group  a
         LEFT OUTER JOIN dc_groupdet b ON a.dc_groupno = b.dc_groupno
         LEFT OUTER JOIN customer    c ON a.cust_no    = c.cust_no
         LEFT OUTER JOIN login       d ON a.user_id    = d.user_id
         LEFT OUTER JOIN team        f ON a.team_code  = f.team_code
         LEFT OUTER JOIN scene       g ON b.scene_code = g.scene_code

         LEFT OUTER JOIN salehp      h ON a.user_id    = h.user_id  AND h.appyn = 'Y'
         LEFT OUTER JOIN login      l1 ON a.dc_app1    = l1.user_id
         LEFT OUTER JOIN login      l2 ON a.dc_app2    = l2.user_id
         LEFT OUTER JOIN login      l3 ON a.dc_app3    = l3.user_id
         LEFT OUTER JOIN login      l4 ON a.dc_app4    = l4.user_id
         LEFT OUTER JOIN login      l5 ON a.dc_app5    = l5.user_id
         LEFT OUTER JOIN login      l6 ON a.dc_hyupuser= l6.user_id
   WHERE ( a.dc_groupno      = :as_groupno )
" arguments=(("as_groupno", string)) )
