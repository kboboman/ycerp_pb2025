summary(height=92 color="536870912" )
footer(height=0 color="536870912" )
detail(height=144 color="536870912" )
table(column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="cust_name" )
 column=(type=char(11) updatewhereclause=yes name=do_spot_code dbname="spot_code" )
 column=(type=datetime updatewhereclause=yes name=do_do_date dbname="do_date" )
 column=(type=char(14) updatewhereclause=yes name=do_do_no dbname="do_no" )
 column=(type=long updatewhereclause=yes name=dodet_oi_no dbname="oi_no" )
 column=(type=char(10) updatewhereclause=yes name=dodet_item_no dbname="item_no" )
 column=(type=char(20) updatewhereclause=yes name=dodet_qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=dodet_uom dbname="uom" )
 column=(type=decimal(2) updatewhereclause=yes name=dodet_ship_qty dbname="ship_qty" )
 column=(type=char(4) updatewhereclause=yes name=do_cust_no dbname="cust_no" )
 column=(type=char(10) updatewhereclause=yes name=do_fob dbname="fob" )
 column=(type=char(1) updatewhereclause=yes name=do_ship_flag dbname="ship_flag" )
 column=(type=decimal(0) updatewhereclause=yes name=do_ship_amount dbname="ship_amount" )
 column=(type=char(15) updatewhereclause=yes name=bus_tel dbname="bus_tel" )
 column=(type=char(15) updatewhereclause=yes name=tel_no dbname="tel_no" )
 column=(type=char(3) updatewhereclause=yes name=do_curr_code dbname="curr_code" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=char(14) updatewhereclause=yes name=dodet_sale_no dbname="sale_no" )
 column=(type=long updatewhereclause=yes name=dodet_seq_no dbname="seq_no" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene_desc" )
 column=(type=char(1) updatewhereclause=yes name=round dbname="round" )
 column=(type=decimal(4) updatewhereclause=yes name=c_acc_qty dbname="c_acc_qty" )
 column=(type=decimal(8) updatewhereclause=yes name=calc_amt dbname="calc_amt" )
 column=(type=decimal(4) updatewhereclause=yes name=price dbname="price" )
 column=(type=decimal(4) updatewhereclause=yes name=dodet_rate_cash dbname="rate_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_rate dbname="do_rate" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_total dbname="do_total" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_cash dbname="do_cash" )
 column=(type=char(50) updatewhereclause=yes name=category dbname="category" )
 column=(type=char(10) updatewhereclause=yes name=gtype dbname="gtype" )
 column=(type=char(30) updatewhereclause=yes name=loc_name dbname="loc_name" )
 column=(type=char(50) updatewhereclause=yes name=dorem dbname="dorem" )
 column=(type=char(12) updatewhereclause=yes name=driver dbname="driver" )
 column=(type=datetime updatewhereclause=yes name=prt_date dbname="prt_date" )
 retrieve="  SELECT distinct cust_name   = c.cust_name   
       , spot_code   = do.spot_code   
       , do_date     = do.do_date   
       , do_no       = do.do_no   
       , oi_no       = dodet.oi_no   
       , item_no     = dodet.item_no   
       , qa          = dodet.qa   
       , uom         = dodet.uom   
       , ship_qty    = dodet.ship_qty   
       , cust_no     = do.cust_no   
       , fob         = do.fob   
       , ship_flag   = do.ship_flag   
       , ship_amount = isnull(do.ship_amount,0)   
       , bus_tel     = c.bus_tel   
       , tel_no      = c.tel_no   
       , curr_code   = do.curr_code   
       , item_name   = g.item_name   
       , sale_no     = dodet.sale_no   
       , seq_no      = dodet.seq_no   
       , scene_desc  = scene.scene_desc   
       , round       = c.round  
       , c_acc_qty   = dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty)
       , calc_amt    = (case when :as_price = '%' then dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty) * dodet.price else 0 end)
       , price       = (case when :as_price = '%' then dodet.price     else 0 end )   
       , rate_cash   = (case when :as_price = '%' then dodet.rate_cash else 0 end )   
       , do_rate     = (case when :as_price = '%' then do.do_rate      else 0 end )   
       , do_total    = (case when :as_price = '%' then do.do_total     else 0 end )   
       , do_cash     = (case when :as_price = '%' then do.do_cash      else 0 end )   
       , category    = (SELECT item_nm  FROM codemst with (nolock) WHERE type = 'ITEMTOP10' AND use_yn = 'Y' AND item_cd = i.category)
       , gtype       = i.type       
       , loc_name    = (SELECT loc_name FROM location WHERE loc_no = dodet.loc_no)
       , dorem       = dodet.rem
       , driver      = do.driver
       , prt_date    = do.prt_date
    FROM UF_MyCustomers( :as_salesman ) M
         LEFT OUTER JOIN customer  C with (nolock) ON m.cust_no     = c.cust_no
         LEFT OUTER JOIN do          with (nolock) ON c.cust_no     = do.cust_no
         LEFT OUTER JOIN dodet       with (nolock) ON do.do_no      = dodet.do_no 
         LEFT OUTER JOIN groupitem G with (nolock) ON dodet.item_no = g.item_no 
         LEFT OUTER JOIN scene       with (nolock) ON do.cust_no    = scene.cust_no AND do.spot_code = scene.scene_code
         LEFT OUTER JOIN sale        with (nolock) ON dodet.sale_no = sale.order_no
         LEFT OUTER JOIN itemtop10 i with (nolock) ON dodet.item_no = i.item_no    
   WHERE ( do.do_date      BETWEEN :as_sdate and :as_edate )
     AND ((:as_area    = '%'   AND do.area_no  LIKE :as_area) OR
          (:as_area   <> '%'   AND do.area_no     = :as_area)
         )
     AND ((:as_team    = '%'   AND m.cust_no   LIKE '%'  ) OR 
          (:as_team   <> '%'   AND m.salesman     = :as_salesman )
         )
     AND ((:as_custno  = '%'   AND m.cust_no   LIKE '%'  ) OR 
          (:as_custno  = 'ALL' AND m.cust_no   LIKE '%'  ) OR 
          (:as_custno <> 'ALL' AND m.cust_no      = :as_custno )
         )
" arguments=(("as_area", string),("as_custno", string),("as_sdate", string),("as_edate", string),("as_salesman", string),("as_team", string),("as_price", string))  sort="do_do_date A customer_cust_name A do_spot_code A do_do_no A dodet_oi_no A " )
group(level=1 header.height=0 trailer.height=80 by=("do_cust_no" ) header.color="536870912" trailer.color="536870912" )
group(level=2 header.height=0 trailer.height=84 by=("do_do_no" ) header.color="536870912" trailer.color="553648127" )
