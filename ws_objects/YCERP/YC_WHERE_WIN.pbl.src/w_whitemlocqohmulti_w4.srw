type dw_2 from datawindow within tabpage_1
integer y = 268
integer width = 1737
integer height = 828
integer taborder = 200
string title = "none"
string dataobject = "d_itemname_all"
boolean vscrollbar = true
boolean livescroll = true
borderstyle borderstyle = stylelowered!
end type

event clicked;long ll_row
string ls_locno
string ls_item

ls_item = dw2.object.item_no[dw2.getrow()]
	
if this.object.item_no[row] = 'M2Z0LIQKZZ' or this.object.item_no[row] = 'M2Z0POWZZZ' then
	dw_7.object.cust_no[1] = ''
	dw3.dataobject = 'd_cditemalllocqoh_paint_c'
	dw3.settransobject(sqlca)
	dw3.retrieve(is_loc, ls_item )
	dw_7.visible = true
	cb_23.visible = true
	st_2.visible =  true
else
	dw3.dataobject = 'd_cditemalllocqoh_c'
	dw3.settransobject(sqlca)
	dw3.retrieve(is_loc, ls_item )
	dw_7.visible = false	
	cb_23.visible = false	
	st_2.visible =  false	
end if


end event

event rowfocuschanged;long ll_row
string ls_locno

ll_row = this.getrow()
if ll_row < 1 then return
this.setredraw( false)
string ls_item

dw_3.setredraw(false)
dw_3.reset()
ls_item = this.object.item_no[ll_row]
	
dw_3.retrieve(is_loc, ls_item )

dw_3.setredraw(true)
this.SelectRow(0,  false)
this.SelectRow(ll_row,  true)
this.setredraw( true)

//2005.07.30 도료규격추가부분//
//2024.01.03 추가 GMZ0000ZZZ
choose case ls_item
	case "M2Z0POWZZZ", "M2Z0LIQKZZ", "PZZZPP7ZZZ", "PZZZPP3ZZZ", "PZZZPP1ZZZ", "PZZZPP0ZZZ", "GMZ0000ZZZ"
		em_1.Visible = false
		em_2.Visible = false
		em_3.Visible = false
		em_4.Visible = false
		st_5.Visible = false
		st_6.Visible = false
		st_7.Visible = false
		sle_paint.Visible = true
	case Else
		em_1.Visible = true
		em_2.Visible = true
		em_3.Visible = true
		em_4.Visible = true
		st_5.Visible = true
		st_6.Visible = true
		st_7.Visible = true	
		sle_paint.Visible = false
End choose
end event

