table(column=(type=datetime updatewhereclause=yes name=work_date dbname="RoutTempNew.work_date" )
 column=(type=long updatewhereclause=yes name=routtempnew_division dbname="RoutTempNew.division" )
 column=(type=char(10) updatewhereclause=yes name=routtempnew_wc_no dbname="RoutTempNew.wc_no" )
 column=(type=long updatewhereclause=yes name=routtempnew_operation dbname="RoutTempNew.operation" )
 column=(type=char(4) updatewhereclause=yes name=process_flag dbname="process_flag" )
 column=(type=long updatewhereclause=yes name=routtempnew_work_per dbname="RoutTempNew.work_per" )
 column=(type=char(14) updatewhereclause=yes name=sale_no dbname="RoutTempNew.sale_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="RoutTempNew.seq_no" )
 column=(type=char(4) updatewhereclause=yes name=routtempnew_cust_no dbname="RoutTempNew.cust_no" )
 column=(type=char(11) updatewhereclause=yes name=routtempnew_scene_code dbname="RoutTempNew.scene_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="RoutTempNew.scene_desc" )
 column=(type=datetime updatewhereclause=yes name=napgi_date dbname="RoutTempNew.napgi_date" )
 column=(type=char(1) updatewhereclause=yes name=routtempnew_suju_type dbname="RoutTempNew.suju_type" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="RoutTempNew.item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name1 dbname="item_name1" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(4) updatewhereclause=yes name=routtempnew_item_color dbname="RoutTempNew.item_color" )
 column=(type=char(10) updatewhereclause=yes name=color_name dbname="color_name" )
 column=(type=decimal(4) updatewhereclause=yes name=order_qty dbname="RoutTempNew.order_qty" )
 column=(type=char(10) updatewhereclause=yes name=routtempnew_assy_item dbname="RoutTempNew.assy_item" )
 column=(type=char(60) updatewhereclause=yes name=g2_item_name dbname="RoutTempNew.item_name" )
 column=(type=char(20) updatewhereclause=yes name=routtempnew_assy_qa dbname="RoutTempNew.assy_qa" )
 column=(type=long updatewhereclause=yes name=routtempnew_bom_no dbname="RoutTempNew.bom_no" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="RoutTempNew.uom" )
 column=(type=decimal(4) updatewhereclause=yes name=routtempnew_plan_qty dbname="RoutTempNew.plan_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=plan_qty_org dbname="plan_qty_org" )
 column=(type=decimal(4) updatewhereclause=yes name=routtempnew_setup_time dbname="RoutTempNew.setup_time" )
 column=(type=decimal(4) updatewhereclause=yes name=routtempnew_work_time dbname="RoutTempNew.work_time" )
 column=(type=decimal(4) updatewhereclause=yes name=routtempnew_make_qty dbname="RoutTempNew.make_qty" )
 column=(type=char(1) updatewhereclause=yes name=plan_flag dbname="RoutTempNew.plan_flag" )
 column=(type=decimal(4) updatewhereclause=yes name=routtempnew_qpa dbname="RoutTempNew.qpa" )
 column=(type=decimal(4) updatewhereclause=yes name=routtempnew_reserved_qty dbname="RoutTempNew.reserved_qty" )
 column=(type=char(50) updatewhereclause=yes name=rem dbname="RoutTempNew.rem" )
 column=(type=char(10) updatewhereclause=yes name=routtempnew_area_no dbname="RoutTempNew.area_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="RoutTempNew.cust_name" )
 column=(type=long updatewhereclause=yes name=pri dbname="pri" )
 column=(type=char(1) updatewhereclause=yes name=open_close dbname="RoutTempNew.open_close" )
 column=(type=decimal(2) updatewhereclause=yes name=ship_qty dbname="ship_qty" )
 retrieve="  SELECT rn.work_date   
       , rn.division    
       , rn.wc_no   
       , rn.operation   
       , process_flag = (case rn.process_flag 
                              when 'Y' then '가능'
                              when 'N' then '불가'
                              when 'E' then '완료'
                              when 'P' then '진행'
                              else rn.process_flag
                         end)
       , rn.work_per   
       , rn.sale_no   
       , rn.seq_no   
       , rn.cust_no   
       , rn.scene_code   
       , sc.scene_desc   
       , rn.napgi_date   
       , rn.suju_type   
       , rn.item_no   
       , item_name1 = (case when rn.item_no = 'NO_ITEM' then g2.item_name else g1.item_name end )   
       , qa         = (case when rn.qa      = 'NO_QA'   then rn.assy_qa   else rn.qa        end )
       , rn.item_color   
       , color_name = color.color_name   
       , rn.order_qty   

       , rn.assy_item   
       , g2.item_name   
       , rn.assy_qa   
       , rn.bom_no   
       , rn.uom   
       , rn.plan_qty   
       , plan_qty_org = rn.plan_qty   
       , rn.setup_time   
       , rn.work_time   
       , rn.make_qty   
       , rn.plan_flag   
       , rn.qpa   
       , rn.reserved_qty   
       , rn.rem   
       , rn.area_no   
       , c.cust_name   
       , pri = 0   
       , s.open_close   
       , ship_qty = dbo.uf_getdosumqty( rn.sale_no, rn.seq_no )
    FROM routtempnew rn  (nolock) left outer join groupitem   g1  (nolock)  on rn.item_no  = g1.item_no
                                                           left outer join groupitem   g2  (nolock) on rn.assy_item       = g2.item_no
                                                           left outer join customer     c  (nolock) on rn.cust_no = c.cust_no
                                                           left outer join scene       sc  (nolock) on rn.scene_code = sc.scene_code
                                                           left outer join sale         s  (nolock) on rn.sale_no = s.order_no  
                                                                                                        AND s.open_close     = 'O'                                                           
                                                                                                         AND  s.order_date    >= '2002/01/01'    
                                                                                                         AND  s.order_date    >= DATEadd(year, -1 ,getdate())
                                                           left outer join color           (nolock) on rn.item_color = color.color_code
/*                                                           
   WHERE ( rn.cust_no        *= c.cust_no        )   
     AND ( rn.scene_code     *= sc.scene_code    )   
     AND ( rn.sale_no        *= s.order_no       )   
     AND ( rn.item_no        *= g1.item_no       )   
     AND ( rn.assy_item       = g2.item_no       )   
     AND ( rn.item_color     *= color.color_code )   
*/     
   WHERE  ( rn.process_flag <> 'C'                          ) 
     AND ( rn.work_date    >= DATEadd(year, -1 ,getdate()) )           
     AND ( rn.plan_flag       = 'N'                          )
     AND ( convert(char(10),rn.napgi_date,111) = :as_date    )
     AND ( rn.area_no         = :as_area                     ) 
     AND ( rn.item_no         = :as_itemno                   )
     AND ( (:as_wcno   = '%' AND rn.wc_no  LIKE '%'      ) OR
                (:as_wcno  <> '%' AND rn.wc_no  LIKE :as_wcno )
             )
" arguments=(("as_date", string),("as_itemno", string),("as_wcno", string),("as_area", string)) )
