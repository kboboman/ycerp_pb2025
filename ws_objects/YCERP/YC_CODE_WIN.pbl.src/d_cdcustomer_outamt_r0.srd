 retrieve="  SELECT Customer_OUTAMT.cust_no
       , Customer_OUTAMT.eom_year   
       , Customer_OUTAMT.sys_date   
       , Customer_OUTAMT.outamt   
       , Customer_OUTAMT.c_rate   
       , Customer_OUTAMT.y_rate   
       , Customer_OUTAMT.y_amt   
       , Customer_OUTAMT.s_rate1   
       , Customer_OUTAMT.s_amt1   
       , Customer_OUTAMT.s_rate2   
       , Customer_OUTAMT.s_amt2   
       , Customer_OUTAMT.s_rate3   
       , Customer_OUTAMT.s_amt3   
       , Customer_OUTAMT.s_rate4   
       , Customer_OUTAMT.s_amt4   
       , Customer_OUTAMT.s_rate5   
       , Customer_OUTAMT.s_amt5   
       , Customer_OUTAMT.s_rate6   
       , Customer_OUTAMT.s_amt6   
       , Customer_OUTAMT.s_rate7   
       , Customer_OUTAMT.s_amt7   
       , Customer_OUTAMT.s_rate8   
       , Customer_OUTAMT.s_amt8   
       , Customer_OUTAMT.s_rate9   
       , Customer_OUTAMT.s_amt9   
       , Customer_OUTAMT.s_rate10   
       , Customer_OUTAMT.s_amt10   
       , Customer_OUTAMT.s_rate11   
       , Customer_OUTAMT.s_amt11   
       , Customer_OUTAMT.s_rate12   
       , Customer_OUTAMT.s_amt12  
    FROM Customer_OUTAMT
   WHERE ( Customer_OUTAMT.cust_no  = :as_custno )
     AND ( DatePart(year, Customer_OUTAMT.eom_year) = :ai_year )
" update="Customer_OUTAMT" updatewhere=1 updatekeyinplace=no arguments=(("as_custno", string),("ai_year", number)) )
