 column=(type=char(1) update=yes updatewhereclause=yes name=coilmst_open_close dbname="coilmst.open_close" values="재고	O/계획	M/작업지시	P/외주가공	S/사용완료	C/" )
 column=(type=char(40) updatewhereclause=yes name=coilmst_rem dbname="coilmst.rem" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(30) updatewhereclause=yes name=location_loc_name dbname="location.loc_name" )
 column=(type=char(30) updatewhereclause=yes name=supp_supp_name dbname="supp.supp_name" )
 column=(type=char(2) updatewhereclause=yes name=coilmst_etc_no dbname="coilmst.etc_no" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"coilmst~" )  TABLE(NAME=~"groupitem~" )  TABLE(NAME=~"location~" )  TABLE(NAME=~"supp~" ) COLUMN(NAME=~"coilmst.coil_no~") COLUMN(NAME=~"coilmst.wid~") COLUMN(NAME=~"coilmst.item_no~") COLUMN(NAME=~"coilmst.qa~") COLUMN(NAME=~"coilmst.loc_no~") COLUMN(NAME=~"coilmst.rcpt_date~") COLUMN(NAME=~"coilmst.unit_qty~") COLUMN(NAME=~"coilmst.length~") COLUMN(NAME=~"coilmst.cnt~") COLUMN(NAME=~"coilmst.qcnt~") COLUMN(NAME=~"coilmst.color_no~") COLUMN(NAME=~"coilmst.supp_no~") COLUMN(NAME=~"coilmst.flag~") COLUMN(NAME=~"coilmst.porder_no~") COLUMN(NAME=~"coilmst.pseq_no~") COLUMN(NAME=~"coilmst.open_close~") COLUMN(NAME=~"coilmst.rem~") COLUMN(NAME=~"groupitem.item_name~") COLUMN(NAME=~"location.loc_name~") COLUMN(NAME=~"supp.supp_name~") COLUMN(NAME=~"coilmst.etc_no~")    JOIN (LEFT=~"coilmst.item_no~"    OP =~"=~"RIGHT=~"groupitem.item_no~"    OUTER1 =~"coilmst.item_no~" )    JOIN (LEFT=~"coilmst.loc_no~"    OP =~"=~"RIGHT=~"location.loc_no~"    OUTER1 =~"coilmst.loc_no~" )    JOIN (LEFT=~"coilmst.supp_no~"    OP =~"=~"RIGHT=~"supp.supp_no~"    OUTER1 =~"coilmst.supp_no~" )WHERE(    EXP1 =~"coilmst.loc_no~"   OP =~"like~"    EXP2 =~":as_loc~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"coilmst.item_no~"   OP =~"like~"    EXP2 =~":as_item~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"coilmst.flag~"   OP =~"like~"    EXP2 =~":as_flag~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"coilmst.open_close~"   OP =~"in~"    EXP2 =~":as_oc~" ) ) ARG(NAME = ~"as_loc~" TYPE = string)  ARG(NAME = ~"as_item~" TYPE = string)  ARG(NAME = ~"as_flag~" TYPE = string)  ARG(NAME = ~"as_oc~" TYPE = stringlist) " update="coilmst" updatewhere=0 updatekeyinplace=no arguments=(("as_loc", string),("as_item", string),("as_flag", string),("as_oc", stringlist))  sort="mid(coilmst_item_no,3,1) A coilmst_item_no A mid( coilmst_qa, 5, 6) A coilmst_unit_qty A " )
group(level=1 header.height=0 trailer.height=80 by=("mid(coilmst_item_no,3,1) + mid(coilmst_item_no,2,1)" ) header.color="536870912" trailer.color="15780518" )
group(level=2 header.height=0 trailer.height=68 by=("coilmst_item_no" ) header.color="536870912" trailer.color="12639424" )
group(level=3 header.height=0 trailer.height=72 by=("mid( coilmst_qa, 5, 6)" ) header.color="536870912" trailer.color="536870912" )
