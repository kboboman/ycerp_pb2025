release 8;
datawindow(units=0 timer_interval=0 color=67108864 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=88 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=build_no dbname="bdinfodet2_item.build_no" )
 column=(type=decimal(0) update=yes updatewhereclause=yes key=yes name=seq dbname="bdinfodet2_item.seq" )
 column=(type=char(3) update=yes updatewhereclause=yes key=yes name=spec_code dbname="bdinfodet2_item.spec_code" )
 column=(type=char(6) update=yes updatewhereclause=yes key=yes name=input_ym dbname="bdinfodet2_item.input_ym" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=quantity dbname="bdinfodet2_item.quantity" initial="0" )
 retrieve="  SELECT build_no,   
         seq,
			spec_code,   
         input_ym,   
         quantity  
    FROM bdinfodet2_item   
where build_no = :as_build_no
and 	seq = :adc_seq 
and	spec_code = :as_spec_code" update="bdinfodet2_item" updatewhere=0 updatekeyinplace=yes arguments=(("as_build_no", string),("adc_seq", number),("as_spec_code", string))  sort="build_no A seq A spec_code A input_ym A " )
