table(column=(type=char(10) updatewhereclause=yes name=item_no dbname="item.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="item.qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 retrieve="  SELECT item.item_no,   
         item.qa,   
         uom = groupitem.uom  
    FROM item,   
         groupitem  
   WHERE ( item.item_no = groupitem.item_no ) and  
         ( ( item.use_flag = 'Y' ) )    
"  sort="item_no A qa A " )
