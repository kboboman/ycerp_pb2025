$PBExportHeader$d_cditemwc_list.srd
$PBExportComments$제품별작업장관리(1998/03/07 - 이인호)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=long updatewhereclause=yes name=cnt dbname="cnt" )
 column=(type=long updatewhereclause=yes name=represent_cnt dbname="represent_cnt" )
 column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" )
 retrieve="  SELECT DISTINCT groupitem.item_no
       , groupitem.item_name 
       , cnt  = (SELECT count(*) FROM ITEM WITH(NOLOCK) WHERE item_no = groupitem.item_no) 
       , represent_cnt       = ( SELECT count(*) FROM  (SELECT DISTINCT ITEM_NO,  represent FROM ROUT with(nolock) ) rout  WHERE item_no = groupitem.item_no and rout.represent = 'Y' )
       , chk  = 'N'
    FROM groupitem WITH(NOLOCK)
   WHERE ( groupitem.use_flag     = 'Y' ) 

"  sort="item_name A " )
text(band=header alignment="2" text="NO" border="6" color="33554432" x="9" y="8" height="64" width="160" html.valueishtml="0"  name=t_1 visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="67108864" )
