table(column=(type=char(14) updatewhereclause=yes key=yes name=order_no dbname="saledet.order_no" )
 column=(type=long updatewhereclause=yes key=yes name=seq_no dbname="saledet.seq_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="saledet.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="saledet.qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="saledet.uom" )
 column=(type=decimal(2) updatewhereclause=yes name=order_qty dbname="saledet.order_qty" )
 column=(type=char(1) update=yes updatewhereclause=yes name=saledet_text dbname="saledet.saledet_text" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=sol_qty dbname="saledet.sol_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=rlse_qty dbname="saledet.rlse_qty" )
 column=(type=char(50) updatewhereclause=yes name=rem dbname="saledet.rem" )
 column=(type=decimal(2) updatewhereclause=yes name=planqty dbname="saledet.plan_qty" )
 column=(type=datetime updatewhereclause=yes name=plan_close dbname="saledet.plan_close" )
 column=(type=char(4) updatewhereclause=yes name=color dbname="saledet.color" )
 column=(type=datetime updatewhereclause=yes name=sale_due_date dbname="sale.due_date" initial=" " )
 column=(type=char(4) updatewhereclause=yes name=sale_cust_no dbname="sale.cust_no" initial=" " )
 column=(type=char(11) updatewhereclause=yes name=sale_scene_code dbname="sale.scene_code" initial=" " )
 column=(type=char(1) updatewhereclause=yes name=groupitem_source dbname="GroupItem.source" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(10) updatewhereclause=yes name=sale_login_id dbname="sale.login_id" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 column=(type=long updatewhereclause=yes name=routtempnew_division dbname="RoutTempNew.division" )
 retrieve="  SELECT saledet.order_no       
       , saledet.seq_no         
       , saledet.item_no         
       , saledet.qa             
       , saledet.uom            
       , saledet.order_qty      
       , saledet.saledet_text   
       , saledet.sol_qty        
       , saledet.rlse_qty       
       , saledet.rem            
       , saledet.plan_qty       
       , saledet.plan_close     
       , saledet.color          
       , sale.due_date          
       , sale.cust_no           
       , sale.scene_code        
       , groupitem.source       
       , groupitem.item_name    
       , sale.login_id          
       , customer.cust_name     
       , scene.scene_desc       
       , routtempnew.division  
    FROM sale  
         inner JOIN saledet ON sale.order_no    = saledet.order_no
         inner JOIN groupitem WITH(NOLOCK) ON saledet.item_no  = groupitem.item_no
         inner JOIN customer WITH(NOLOCK)  ON sale.cust_no     = customer.cust_no    
         inner JOIN scene  WITH(NOLOCK)    ON sale.scene_code  = scene.scene_code
	    left outer join routtempnew on saledet.order_no = routtempnew.sale_no and saledet.seq_no = routtempnew.seq_no
where ( sale.order_date     >= DATEADD(year, -2, getdate()) ) 
    AND ( saledet.order_qty    > saledet.rlse_qty   )  
/*
    FROM saledet       
       , sale          
       , groupitem     
       , routtempnew   
       , customer      
       , scene  
   WHERE ( sale.order_date     >= '2002/01/01'       ) 
     AND ( sale.order_date     >= DATEADD(year, -2, getdate()) ) 
     AND ( saledet.order_no     = sale.order_no      )  
     AND ( saledet.order_qty    > saledet.rlse_qty   )  
     AND ( saledet.item_no      = groupitem.item_no  )  
     AND ( sale.cust_no        *= customer.cust_no   )  
     AND ( sale.scene_code     *= scene.scene_code   )  
     AND ( saledet.order_no    *= routtempnew.sale_no)  
     AND ( saledet.seq_no      *= routtempnew.seq_no ) 
*/
" update="saledet" updatewhere=0 updatekeyinplace=yes filter="isnull( routtempnew_division ) 
")
