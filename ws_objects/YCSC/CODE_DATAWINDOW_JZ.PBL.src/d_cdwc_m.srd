$PBExportHeader$d_cdwc_m.srd
$PBExportComments$작업장관리(1998/02/03,성삼지)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=work_no dbname="wc.work_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=work_name dbname="wc.work_name" )
 column=(type=char(1) update=yes updatewhereclause=yes name=work_type dbname="wc.work_type" values="사내	D/외주	S/" )
 column=(type=char(10) update=yes updatewhereclause=yes name=work_manager dbname="wc.work_manager" )
 column=(type=long update=yes updatewhereclause=yes name=capacity dbname="wc.capacity" initial=" " )
 column=(type=char(20) update=yes updatewhereclause=yes name=work_pos dbname="wc.work_pos" )
 column=(type=long update=yes updatewhereclause=yes name=work_per dbname="wc.work_per" )
 column=(type=char(10) update=yes updatewhereclause=yes name=def_loc dbname="wc.def_loc" )
 column=(type=char(1) update=yes updatewhereclause=yes name=fact_wc dbname="wc.fact_wc" )
 column=(type=char(1) update=yes updatewhereclause=yes name=rout_auto dbname="wc.rout_auto" initial="N" values="Y	Y/N	N/" )
 column=(type=char(10) update=yes updatewhereclause=yes name=area_no dbname="wc.area_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=use_yn dbname="use_yn" values="사용	Y/불가	N/" )
 retrieve="  SELECT wc.work_no,   
         wc.work_name,   
         wc.work_type,   
         wc.work_manager,   
         wc.capacity,   
         wc.work_pos,   
         wc.work_per,   
         wc.def_loc,   
         wc.fact_wc,   
         wc.rout_auto,   
         wc.area_no,
         use_yn = (case when wc.use_yn is null then 'Y' else wc.use_yn end)
    FROM wc   
" update="wc" updatewhere=1 updatekeyinplace=no )
