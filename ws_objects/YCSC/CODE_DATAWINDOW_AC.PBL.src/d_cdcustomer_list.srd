 retrieve="  SELECT '거래처코드'       = a.cust_no                                                                              
		 , '상호'             = a.cust_name                                                                            
		 , '사업자번호'       = a.register_no                                                                          
		 , '대표자명'         = a.captain_name                                                                         
		 , '법인주민번호'     = a.resident_card                                                                        
		 , '부서명'           = c.team_name                                                                            
		 , '담당자(정)'       = a.salesman                                                                             
		 , '담당자정'         = (select isnull(user_name,'') from login where user_id = a.salesman)                    
		 , '이전자ID'         = a.pre_salesman                                                                         
		 , '이전담당자'       = (select isnull(user_name,'') from login where user_id = a.pre_salesman)                
       , '담당자(부)'       = a.salesman_bu
		 , '최종거래일'       = convert(char(10),a.last_tn_date,111)                                                   
		 , '사용'             = a.open_close                                                                           
		 , '매출제외'         = a.cust_flag                                                                            
		 , '반올림'           = (case when a.round = 'Y' then '반올림' when a.round = 'N' then '절사' else a.round end)
		 , '여신일자'         = convert(char(10),a.credit_day,111)                                                     
		 , '거래처구분'       = (case when a.cust_type = 'A' then '외상업체'                                           
												when a.cust_type = 'B' then '간이업체'                                           
												when a.cust_type = 'C' then '개인업체'                                           
												when a.cust_type = 'D' then '내부업체'                                           
												when a.cust_type = 'E' then '수출업체'                                           
												when a.cust_type = 'F' then '부산판매'                                           
										 end)                                                                                  
		 , '거래처우편'       = a.addr1                                                                                
		 , '거래처주소1'      = a.addr2                                                                                
		 , '거래처주소2'      = '`'+a.addr3                                                                                
		 , '거래처기존주소'   = a.addr                                                                                 
		 , '실채무자'         = a.business                                                                             
		 , '실채무자주민번호' = (case when a.bus_cord is null or a.bus_cord = '' then '' else substring(a.bus_cord,1,7) + '*******' end)
		 , '실채무자우편'     = a.bus_addr1                                                                            
		 , '실채무자주소1'    = a.bus_addr2                                                                            
		 , '실채무자주소2'    = '`'+a.bus_addr3                                                                            
		 , '실채무자이전주소' = a.bus_addr                                                                             
		 , '대표자와관계'     = a.bus_rep                                                                              
		 , '실채무자번호'     = a.bus_tel                                                                              
		 , '전화번호'         = a.tel_no                                                                               
		 , '팩스번호'         = a.fax_no                                                                               
		 , '업태'             = a.industry_type                                                                        
		 , '업종'             = a.industry_code                                                                        
		 , '결재유형'         = a.terms                                                                                
		 , '매출등급'         = a.level_grade                                                                          
		 , '신용등급'         = a.credit_level                                                                         
		 , '단가등급'         = a.price_level                                                                         
       , '종합등급'         = a.top_level
       , '영업지역'         = a.sale_address
		 , '신용한도액'       = a.credit_limit                                                                         
		 , '미수금액'         = a.balance_amt                                                                          
		 , '어음미결금액'     = a.bill_amount                                                                          
		 , '거래시작일'       = convert(char(10),a.start_date,111)                                                     
		 , '채권관리일'       = convert(char(10),a.collect_ymd,111)                                                    
		 , '구매담당자1'      = a.buyer1                                                                               
		 , '구매담당1핸폰'    = a.buyer1_hp                                                                            
		 , '구매담당자2'      = a.buyer2                                                                               
		 , '운송처우편'       = a.shipto_addr1                                                                         
		 , '운송처주소1'      = a.shipto_addr2                                                                         
		 , '운송처주소2'      = '`'+a.shipto_addr3                                                                         
		 , '운송처기존주소'   = a.shipto_addr                                                                          
		 , '매출통제'         = (case when a.sale_control = 'A' then '완전'                                            
												when a.sale_control = 'Y' then '부분'                                            
												when a.sale_control = 'N' or a.sale_control is null then '해제'                  
										 end)                                                                                  
		 , '계약일'           = a.contract_day 
		 , '계약서'           = a.contract_yn  
		 , '대표자보증'       = a.joint_head   
		 , '유한연대보증인'   = a.jointor      
		 , '보증금액'         = a.joint_amt    
		 , '담보내역내용'     = a.dambo_rem    
		 , '담보일자'         = a.dambo_ymd    
		 , '담보금액'         = a.dambo_amt    
		 , '담보비고'         = a.dambo_bigo   
		 , 'VAT담당자'        = a.vat_user                                                                             
		 , 'VAT연락처'        = a.vat_phone                                                                            
		 , 'VAT메일'          = a.vat_email                                                                            
		 , '더존'             = a.icube_no                                                                             
		 , '주거래건설사'     = d.main_co
		 , '면허명'           = d.license_name
		 , '관리'             = (SELECT item_nm FROM codemst WHERE type = 'MGR_TYPE' AND use_yn = 'Y' AND item_cd = a.mgr_type)
		 , '외형'             = rtrim(ltrim(a.outamt))
	 FROM customer  a                                                                                                 
			LEFT OUTER JOIN login    b  ON a.salesman  = b.user_id                                                         
			LEFT OUTER JOIN team     c  ON b.team_code = c.team_code                                                       
			LEFT OUTER JOIN custinfo d  ON a.cust_no   = d.cust_no                                                       
	WHERE ( ( :as_open = 'O' and a.open_close      = 'O' ) OR
			  ( :as_open = '%' and a.open_close   LIKE '%' )
			)
	  AND ( ( :as_userid  = '%' AND a.salesman  LIKE '%' ) OR
			  ( :as_userid <> '%' AND a.salesman  LIKE :as_userid ) 
			)
	  AND ( ( :as_custnm  = '%' AND a.cust_name LIKE '%' ) OR
			  ( :as_custnm <> '%' AND a.cust_name LIKE :as_custnm ) 
			)
" arguments=(("as_open", string),("as_userid", string),("as_custnm", string))  sort="상호 A " )
