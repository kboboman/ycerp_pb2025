 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"custetc~" ) COLUMN(NAME=~"custetc.cust_idno~") COLUMN(NAME=~"custetc.seq~") COLUMN(NAME=~"custetc.etc_name~") COLUMN(NAME=~"custetc.remarks~")WHERE(    EXP1 =~"custetc.cust_idno~"   OP =~"=~"    EXP2 =~":ai_idno~" ) ) ARG(NAME = ~"ai_idno~" TYPE = number) " update="custetc" updatewhere=1 updatekeyinplace=no arguments=(("ai_idno", number)) )
