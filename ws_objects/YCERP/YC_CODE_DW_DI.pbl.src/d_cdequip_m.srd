table(column=(type=char(6) update=yes updatewhereclause=yes key=yes name=equip_code dbname="EQUIP.EQUIP_CODE" )
 column=(type=char(40) update=yes updatewhereclause=yes name=equip_name dbname="EQUIP.EQUIP_NAME" )
 column=(type=char(5) update=yes updatewhereclause=yes name=factory dbname="EQUIP.FACTORY" )
 column=(type=char(3) update=yes updatewhereclause=yes name=wc dbname="EQUIP.WC" )
 column=(type=char(3) update=yes updatewhereclause=yes name=re_wc dbname="EQUIP.RE_WC" )
 column=(type=char(8) update=yes updatewhereclause=yes name=make_date dbname="EQUIP.MAKE_DATE" )
 column=(type=char(40) update=yes updatewhereclause=yes name=make_com dbname="EQUIP.MAKE_COM" )
 column=(type=char(8) update=yes updatewhereclause=yes name=setting_date dbname="EQUIP.SETTING_DATE" )
 column=(type=char(40) update=yes updatewhereclause=yes name=setting_com dbname="EQUIP.SETTING_COM" )
 column=(type=char(60) update=yes updatewhereclause=yes name=product_kind dbname="EQUIP.PRODUCT_KIND" )
 column=(type=char(60) update=yes updatewhereclause=yes name=product_qa dbname="EQUIP.PRODUCT_QA" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=price dbname="EQUIP.PRICE" )
 column=(type=long update=yes updatewhereclause=yes name=wc_ex dbname="EQUIP.WC_EX" )
 column=(type=char(200) update=yes updatewhereclause=yes name=keypoint dbname="EQUIP.KEYPOINT" )
 column=(type=char(200) update=yes updatewhereclause=yes name=auto dbname="EQUIP.AUTO" )
 column=(type=char(1) update=yes updatewhereclause=yes name=use_yn dbname="EQUIP.USE_YN" values="사용	Y/중단	N/" )
 column=(type=char(10) updatewhereclause=yes name=write_name dbname="WRITE_NAME" )
 column=(type=char(10) update=yes updatewhereclause=yes name=write_id dbname="EQUIP.WRITE_ID" )
 column=(type=char(8) update=yes updatewhereclause=yes name=write_date dbname="EQUIP.WRITE_DATE" )
 retrieve="SELECT EQUIP_CODE, 
 		     EQUIP_NAME,
		     FACTORY,
		    WC,
		    RE_WC,
		    MAKE_DATE,
		    MAKE_COM,
		    SETTING_DATE,
		    SETTING_COM,
		    PRODUCT_KIND,
		    PRODUCT_QA,
		    PRICE,
		    WC_EX,
		    KEYPOINT,
		    AUTO,
		    USE_YN,
		    ( SELECT USER_NAME FROM LOGIN WHERE LOGIN.USER_ID = EQUIP.WRITE_ID ) WRITE_NAME,
		    WRITE_ID,
		    WRITE_DATE
  FROM EQUIP
WHERE EQUIP_CODE = :ARG_EQUIP_CODE
" update="EQUIP" updatewhere=1 updatekeyinplace=no arguments=(("arg_equip_code", string)) )
