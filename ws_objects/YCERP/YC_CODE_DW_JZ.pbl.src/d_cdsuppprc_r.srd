 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(19) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=datetime updatewhereclause=yes name=date1 dbname="date1" )
 column=(type=decimal(3) updatewhereclause=yes name=prc1 dbname="prc1" )
 column=(type=datetime updatewhereclause=yes name=date2 dbname="date2" )
 column=(type=decimal(3) updatewhereclause=yes name=prc2 dbname="prc2" )
 column=(type=datetime updatewhereclause=yes name=date3 dbname="date3" )
 column=(type=decimal(3) updatewhereclause=yes name=prc3 dbname="prc3" )
 column=(type=datetime updatewhereclause=yes name=date4 dbname="date4" )
 column=(type=decimal(3) updatewhereclause=yes name=prc4 dbname="prc4" )
 column=(type=datetime updatewhereclause=yes name=date5 dbname="date5" )
 column=(type=decimal(3) updatewhereclause=yes name=prc5 dbname="prc5" )
 retrieve="  SELECT distinct
			supp_no	=	T.supp_no,
			item_no	=	T.item_no,
			item_name	=	G.item_name,
			qa			=	T.qa,
			date1		=	T.date1,
			prc1		=	T.prc1,
			date2		=	T.date2,
			prc2		=	T.prc2,
			date3		=	T.date3,
			prc3		=	T.prc3,
			date4		=	T.date4,
			prc4		=	T.prc4,
			date5		=	T.date5,
			prc5		=	T.prc5
	 FROM db_user.#w_cdsupp		T,
			item	G
	WHERE	T.item_no	=	G.item_no
	and	T.qa 		like	(substring(G.qa, 1,13) + '%')
	  AND	T.supp_no	LIKE	:as_supp_no
" arguments=(("as_supp_no", string)) )
