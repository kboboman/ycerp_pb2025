 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"saledet~" )  TABLE(NAME=~"groupitem~" )  TABLE(NAME=~"color~" )  TABLE(NAME=~"sale~" )  TABLE(NAME=~"customer~" )  TABLE(NAME=~"dodet~" ) COLUMN(NAME=~"saledet.order_no~") COLUMN(NAME=~"saledet.seq_no~") COLUMN(NAME=~"saledet.item_no~") COLUMN(NAME=~"saledet.qa~") COLUMN(NAME=~"saledet.uom~") COLUMN(NAME=~"saledet.order_qty~") COLUMN(NAME=~"saledet.price~") COLUMN(NAME=~"saledet.acc_qty~") COLUMN(NAME=~"saledet.saledet_text~") COLUMN(NAME=~"saledet.action~") COLUMN(NAME=~"saledet.sol_qty~") COLUMN(NAME=~"saledet.loc_no~") COLUMN(NAME=~"saledet.issue_qty~") COLUMN(NAME=~"saledet.rlse_date~") COLUMN(NAME=~"saledet.rlse_qty~") COLUMN(NAME=~"saledet.rem~") COLUMN(NAME=~"saledet.plan_qty~") COLUMN(NAME=~"saledet.plan_close~") COLUMN(NAME=~"saledet.color~") COLUMN(NAME=~"saledet.price_be~") COLUMN(NAME=~"saledet.do_rem~") COLUMN(NAME=~"groupitem.item_name~") COLUMN(NAME=~"color.color_name~") COLUMN(NAME=~"customer.cust_name~") COLUMN(NAME=~"sale.cust_no~") COLUMN(NAME=~"sale.scene_code~") COLUMN(NAME=~"sale.order_no~")    JOIN (LEFT=~"saledet.item_no~"    OP =~"=~"RIGHT=~"groupitem.item_no~"    OUTER1 =~"saledet.item_no~" )    JOIN (LEFT=~"saledet.color~"    OP =~"=~"RIGHT=~"color.color_code~"    OUTER1 =~"saledet.color~" )    JOIN (LEFT=~"saledet.order_no~"    OP =~"=~"RIGHT=~"sale.order_no~" )    JOIN (LEFT=~"sale.cust_no~"    OP =~"=~"RIGHT=~"customer.cust_no~" )    JOIN (LEFT=~"dodet.sale_no~"    OP =~"=~"RIGHT=~"saledet.order_no~" )    JOIN (LEFT=~"dodet.seq_no~"    OP =~"=~"RIGHT=~"saledet.seq_no~" )WHERE(    EXP1 =~"dodet.do_no~"   OP =~"=~"    EXP2 =~":as_do~" ) ) ARG(NAME = ~"as_do~" TYPE = string) " update="sale" updatewhere=0 updatekeyinplace=no arguments=(("as_do", string))  sort="order_no A seq_no A " )
