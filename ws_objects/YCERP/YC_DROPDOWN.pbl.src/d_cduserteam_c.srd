table(column=(type=char(5) updatewhereclause=yes name=team_code dbname="team.team_code" )
 column=(type=char(30) updatewhereclause=yes name=team_name dbname="team.team_name" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"team~" ) COLUMN(NAME=~"team.team_code~") COLUMN(NAME=~"team.team_name~")WHERE(    EXP1 =~"team.team_code~"   OP =~"<>~"    EXP2 =~"'13000'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"team.team_code~"   OP =~"<>~"    EXP2 =~"'00000'~" ) ) "  sort="team_name A " )
column(band=detail id=2 alignment="0" tabsequence=32766 border="0" color="0" x="9" y="4" height="56" width="992" format="[general]"  name=team_name  tag="팀명" edit.limit=30 edit.case=any edit.autoselect=yes edit.autohscroll=yes  font.face="굴림체" font.height="-10" font.weight="400"  font.family="2" font.pitch="2" font.charset="129" background.mode="1" background.color="536870912" )
