$PBExportHeader$d_mpsaleproc_s.srd
$PBExportComments$수주별작업진행관리(수주번호)(1999/06/04,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=1090519039 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=order_no dbname="sale.order_no" initial=" " )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene.scene_desc" )
 retrieve="  SELECT DISTINCT sale.order_no
       , customer.cust_name
       , scene.scene_desc  
    FROM sale 
         LEFT OUTER JOIN customer ON sale.cust_no    = customer.cust_no 
         LEFT OUTER JOIN scene    ON sale.scene_code = scene.scene_code  
   WHERE ( sale.order_date BETWEEN :as_sdate AND :as_edate ) 
     AND ((sale.cust_no       LIKE :as_custno ) OR
          (sale.order_no      LIKE :as_orderno)
         )
" arguments=(("as_sdate", string),("as_edate", string),("as_custno", string),("as_orderno", string))  sort="order_no D " )
