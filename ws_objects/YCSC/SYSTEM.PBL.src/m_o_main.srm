on m_saleq4.create
call super::create
this.text = "매출조회"
this.m_aroiq1=create m_aroiq1
this.m_5=create m_5
this.m_6=create m_6
this.m_-14=create m_-14
this.m_세금계산서미발행리스트=create m_세금계산서미발행리스트
