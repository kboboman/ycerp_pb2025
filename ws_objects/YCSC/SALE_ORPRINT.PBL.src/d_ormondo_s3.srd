table(column=(type=char(14) updatewhereclause=yes name=do_no dbname="dodet.do_no" )
 column=(type=long updatewhereclause=yes name=oi_no dbname="dodet.oi_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="dodet.seq_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="dodet.qa" )
 column=(type=decimal(2) updatewhereclause=yes name=ship_qty dbname="dodet.ship_qty" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="dodet.uom" )
 column=(type=char(50) updatewhereclause=yes name=rem dbname="dodet.rem" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"dodet~" )  TABLE(NAME=~"groupitem~" ) COLUMN(NAME=~"dodet.do_no~") COLUMN(NAME=~"dodet.oi_no~") COLUMN(NAME=~"dodet.seq_no~") COLUMN(NAME=~"dodet.qa~") COLUMN(NAME=~"dodet.ship_qty~") COLUMN(NAME=~"dodet.uom~") COLUMN(NAME=~"dodet.rem~") COLUMN(NAME=~"groupitem.item_name~")    JOIN (LEFT=~"dodet.item_no~"    OP =~"=~"RIGHT=~"groupitem.item_no~" )WHERE(    EXP1 =~"dodet.sale_no~"   OP =~"=~"    EXP2 =~":as_order~" ) ) ARG(NAME = ~"as_order~" TYPE = string) " arguments=(("as_order", string))  sort="do_no A oi_no A " )
