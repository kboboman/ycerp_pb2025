type cbx_ysp from checkbox within tabpage_4
integer x = 1509
integer y = 60
integer width = 352
integer height = 64
integer textsize = -10
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
long textcolor = 16711680
long backcolor = 67108864
string text = "YSP그룹"
end type

event clicked;/////////////////////////////////////////////////////////////////
// 일위대가 : 등록은 일위대가관리에서
// YSP그룹  : 등록은 Query 작업으로
/////////////////////////////////////////////////////////////////
string ls_itemYN
DataWindowChild ldwc_dddw

if this.checked = true then
	ls_itemYN = "N"

	dw_orstand.reset()
   dw_orstand.dataobject = "d_oryspgrp_s"
	dw_orstand.settransobject(sqlca)
	dw_orstand.insertrow(1)
	dw_orstand.object.item_no[1] = ""

	dw_orstand.Modify("item_no.dddw.Name='d_oryspgrp_dddw'")		// YSP그룹
	dw_orstand.Modify("item_no.dddw.allowedit=no")
	dw_orstand.Modify("item_no.dddw.percentwidth='350'")
	dw_orstand.Modify("item_no.dddw.displayColumn='item_name'")
	dw_orstand.Modify("item_no.dddw.DataColumn='item_no'")
	dw_orstand.Modify("item_no.dddw.vscrollbar=yes")

	dw_orstand.getchild('item_no',ldwc_dddw)
	ldwc_dddw.settransobject(sqlca)
	ldwc_dddw.retrieve( ls_itemYN )
	if ldwc_dddw.rowcount() > 0 then
		ldwc_dddw.setsort('item_name')
		ldwc_dddw.sort()
	else
		MessageBox("확인", "YSP그룹 데이터가 존재하지 않습니다.")
	end if	
else
	if cbx_useyn.checked = true then
		ls_itemYN = "Y"
	else
		ls_itemYN = "N"
	end if

	dw_orstand.reset()
   dw_orstand.dataobject = "d_orstand_s"
	dw_orstand.settransobject(sqlca)
	dw_orstand.insertrow(1)
	dw_orstand.object.item_no[1] = ""

	dw_orstand.Modify("item_no.dddw.Name='d_orstand_dddw'")		// 일위대가
	dw_orstand.Modify("item_no.dddw.allowedit=no")
	dw_orstand.Modify("item_no.dddw.percentwidth='350'")
	dw_orstand.Modify("item_no.dddw.displayColumn='item_name'")
	dw_orstand.Modify("item_no.dddw.DataColumn='item_no'")
	dw_orstand.Modify("item_no.dddw.vscrollbar=yes")

	dw_orstand.getchild('item_no',ldwc_dddw)
	ldwc_dddw.settransobject(sqlca)
	ldwc_dddw.retrieve( ls_itemYN )
	if ldwc_dddw.rowcount() > 0 then
		ldwc_dddw.setsort('item_name')
