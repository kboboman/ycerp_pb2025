table(column=(type=decimal(2) updatewhereclause=yes name=balance_amt dbname="balance_amt" )
 column=(type=char(10) updatewhereclause=yes name=supp_no dbname="apeom.supp_no" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"apeom~" ) COMPUTE(NAME=~"balance_amt = balbf_amount + inv_01 + inv_02 + inv_03 + inv_04 + inv_05 + inv_06 + inv_07 + inv_08 + inv_09 + inv_10 + inv_11 + inv_12  - coll_01 - coll_02 - coll_03 - coll_04 - coll_05 - coll_06 - coll_07 - coll_08 - coll_09 - coll_10 - coll_11 - coll_12~") COLUMN(NAME=~"apeom.supp_no~")WHERE(    EXP1 =~"datepart(year, apeom.eom_year)~"   OP =~"=~"    EXP2 =~":ai_year~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"apeom.area_no~"   OP =~"=~"    EXP2 =~":as_area~" ) ) ARG(NAME = ~"ai_year~" TYPE = number)  ARG(NAME = ~"as_area~" TYPE = string) " arguments=(("ai_year", number),("as_area", string)) )
