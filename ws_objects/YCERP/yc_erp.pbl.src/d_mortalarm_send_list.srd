$PBExportHeader$d_mortalarm_send_list.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=104 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=88 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(10) updatewhereclause=yes name=salesman dbname="salesman" )
 column=(type=char(15) updatewhereclause=yes name=hp_no dbname="hp_no" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(50) updatewhereclause=yes name=dambo_rem dbname="dambo_rem" )
 column=(type=decimal(0) updatewhereclause=yes name=dambo_amt dbname="dambo_amt" )
 column=(type=char(50) updatewhereclause=yes name=dambo_value dbname="dambo_value" )
 column=(type=datetime updatewhereclause=yes name=today dbname="today" )
 column=(type=long updatewhereclause=yes name=date_diff dbname="date_diff" )
 retrieve="select
	 a.cust_no 		cust_no
	,b.cust_name	cust_name
	,b.salesman		salesman
	,d.hp_no			hp_no
	,c.user_name	user_name
	,b.dambo_rem	dambo_rem
	,b.dambo_amt	dambo_amt
	,b.dambo_value	dambo_value
	,getdate()		today
	,datediff(day,getdate(),convert(date, replace(replace(b.dambo_value,'-',''),'/',''))) date_diff
from 
	mortalarm_list a 
		inner join customer b on a.cust_no = b.cust_no and a.use_yn = 'Y' and len(replace(replace(b.dambo_value,'-',''),'/','')) = 8
		inner join login c on c.user_id = b.salesman left outer join salehp d on b.salesman = d.user_id
" )
