$PBExportHeader$d_oicustdo_pivot_shipcost.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no  crosstab.dynamic = yes grid.lines=0 grid.columnmove=no selected.mouse=no )
header[1](height=0 color="536870912" )
header[2](height=72 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(20) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=number updatewhereclause=yes name=amt dbname="amt" )
 retrieve="  SELECT user_name    = a.user_name
       , cust_name    = a.cust_name
       , item_no      = a.item_no  
       , item_name    = a.item_name
       , category     = (case when :as_etcyn = 'Y' and a.category = 'TOP1016' then a.gtype 
                              else cm.item_nm
                         end)
       , amt          = a.amt
       , oonsong      = a.oonsong
       , do_no        = a.do_no
    FROM (
         SELECT user_name    = l.user_name
              , cust_name    = d.cust_name   
              , item_no      = a.item_no  
              , item_name    = (case when not g.item_name is null then g.item_name
                                     else (SELECT item_name FROM groupitem WHERE item_no = a.item_no)
                                end)
              , category     = isnull(g.category,'TOP1999')
              , gtype        = isnull(g.type,'99) 미분류')
              , amt          = (round(dbo.uf_getqty(a.item_no, a.qa, a.uom, a.ship_qty),2,1) * a.price) + a.rate_cash
              , oonsong      = case when a.oi_no = (select max(c.oi_no) from dodet c where c.do_no = b.do_no) then do_total else 0 end 
              , b.do_no
           FROM dodet     a      
                LEFT OUTER JOIN do b         ON a.do_no     = b.do_no
                LEFT OUTER JOIN customer  d  ON b.cust_no   = d.cust_no
                LEFT OUTER JOIN itemtop10 g  ON a.item_no   = g.item_no  
                LEFT OUTER JOIN login     l  ON d.salesman  = l.user_id
          WHERE convert(char(10),b.do_date,111) BETWEEN :as_sdate AND :as_edate
            AND b.do_no     LIKE :as_area
            AND ((:as_etcyn    = 'Y' and  g.category    = 'TOP1016') OR
                 (:as_etcyn   <> 'Y' and (g.category LIKE '%' or g.category is null) )
                ) 
         ) A
         LEFT OUTER JOIN (
              SELECT item_cd, item_nm FROM codemst with (nolock) WHERE type = 'ITEMTOP10' AND use_yn = 'Y'
         ) cm ON a.category = cm.item_cd
" arguments=(("as_area", string),("as_sdate", string),("as_edate", string),("as_etcyn", string))  sort="user_name A cust_name A " )
