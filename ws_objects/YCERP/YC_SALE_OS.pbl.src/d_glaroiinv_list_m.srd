$PBExportHeader$d_glaroiinv_list_m.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 selected.mouse=no )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=84 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=aroiinv_cust_no dbname="aroiinv.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=c_cust_name dbname="aroiinv.cust_name" )
 column=(type=char(12) updatewhereclause=yes key=yes name=aroiinv_aroiinv_no dbname="aroiinv.aroiinv_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=aroiinv_open_close dbname="aroiinv.open_close" values="해제	O/마감	T/" )
 column=(type=char(1) updatewhereclause=yes name=c_chk dbname="c_chk" )
 column=(type=char(6) updatewhereclause=yes name=delete_flag dbname="delete_flag" )
 column=(type=datetime updatewhereclause=yes name=aroiinv_sys_date dbname="aroiinv.sys_date" )
 column=(type=char(10) updatewhereclause=yes name=l_user_name dbname="aroiinv.user_name" )
 column=(type=decimal(4) updatewhereclause=yes name=aroiinv_aroiinv_cash dbname="aroiinv.aroiinv_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=aroiinv_aroiinv_rate dbname="aroiinv.aroiinv_rate" )
 column=(type=decimal(5) updatewhereclause=yes name=aroiinv_ship_cost dbname="ship_cost" )
 column=(type=decimal(5) updatewhereclause=yes name=aroiinv_tot dbname="aroiinv_tot" )
 retrieve="SELECT a.cust_no            
     , c.cust_name         
     , a.aroiinv_no         
     , a.open_close        
     , c_chk       = a.open_close
     , delete_flag = (case when a.delete_flag = 'Y' then '폐기됨' else '정상' end )
     , a.sys_date    
     , l.user_name   
     , a.aroiinv_cash
     , a.aroiinv_rate
     , ship_cost   = (a.ship_cost * 1.1)
     , aroiinv_tot = (a.aroiinv_cash + a.aroiinv_rate + (a.ship_cost * 1.1))
  FROM aroiinv a with(nolock) inner join customer c with(nolock) on a.cust_no           = c.cust_no
                              left outer join login l with(nolock) on a.login_id         = l.user_id
WHERE  a.delete_flag   LIKE :as_delete
       AND a.cust_no        LIKE :as_cust_no
       AND a.aroiinv_no    LIKE :as_aroiinv_no
       AND a.oi_date     	  BETWEEN :adt_sdate AND :adt_edate
 ORDER BY c.cust_name
        , a.aroiinv_no
/*
  FROM aroiinv a 
     , customer c
     , login l
 WHERE a.cust_no           = c.cust_no
   AND a.login_id         *= l.user_id
   AND a.delete_flag    LIKE :as_delete
   AND a.cust_no        LIKE :as_cust_no
   AND a.aroiinv_no     LIKE :as_aroiinv_no
   AND a.oi_date     BETWEEN :adt_sdate AND :adt_edate
 ORDER BY c.cust_name
        , a.aroiinv_no
*/" update="aroiinv" updatewhere=1 updatekeyinplace=yes arguments=(("as_cust_no", string),("as_aroiinv_no", string),("adt_sdate", string),("adt_edate", string),("as_delete", string)) )
