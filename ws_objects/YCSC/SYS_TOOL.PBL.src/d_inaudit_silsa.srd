 column=(type=char(17) updatewhereclause=yes name=inaudit_order_no dbname="inaudit.order_no" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"inaudit~" )  TABLE(NAME=~"iotype~" )  TABLE(NAME=~"groupitem~" )  TABLE(NAME=~"location~" ) COLUMN(NAME=~"inaudit.loc_no~") COLUMN(NAME=~"location.loc_name~") COLUMN(NAME=~"inaudit.inaudit_type~") COLUMN(NAME=~"iotype.remarks~") COLUMN(NAME=~"inaudit.inaudit_time~") COLUMN(NAME=~"inaudit.inaudit_date~") COLUMN(NAME=~"inaudit.inaudit_item~") COLUMN(NAME=~"groupitem.item_name~") COLUMN(NAME=~"inaudit.qa~") COLUMN(NAME=~"inaudit.rcpt_qty~") COLUMN(NAME=~"inaudit.issue_qty~") COLUMN(NAME=~"inaudit.order_no~")    JOIN (LEFT=~"inaudit.inaudit_item~"    OP =~"=~"RIGHT=~"groupitem.item_no~"    OUTER1 =~"inaudit.inaudit_item~" )    JOIN (LEFT=~"inaudit.inaudit_type~"    OP =~"=~"RIGHT=~"iotype.inaudit_type~"    OUTER1 =~"inaudit.inaudit_type~" )    JOIN (LEFT=~"inaudit.loc_no~"    OP =~"=~"RIGHT=~"location.loc_no~"    OUTER1 =~"inaudit.loc_no~" )WHERE(    EXP1 =~"inaudit.inaudit_time~"   OP =~">=~"    EXP2 =~"'2002/01/01'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"inaudit.inaudit_type~"   OP =~"like~"    EXP2 =~"'C%'~" ) ) "  sort="inaudit_loc_no A location_loc_name A inaudit_inaudit_time A " )
