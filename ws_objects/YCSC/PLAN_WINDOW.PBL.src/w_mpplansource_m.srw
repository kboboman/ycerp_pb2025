event rbuttondown;int    li_int
string ls_sale

if row < 1 then return
this.scrolltorow(row)

m_manager NewMenu

NewMenu = CREATE m_manager
gs_print_control = ""
li_int = m_manager.m_plan.PopMenu(parentwindow().PointerX(), parentwindow().PointerY())

ls_sale = this.object.sale_no[row]
choose case gs_print_control
	case 'SALE'
		open(w_whsaleproc_w)
		w_whsaleproc_w.sle_1.text = ls_sale
		w_whsaleproc_w.pb_1.postevent(clicked!)
end choose

end event

event clicked;// 
long   ll_cnt
string ls_col, ls_text

if row < 1 or row > this.rowcount() then return

choose case dwo.name
	case "chk"
		ls_col  = "선택"
		ls_text = this.object.chk[row]
		ll_cnt  = dw6.object.chk_cnt[1]
		if ll_cnt = 1 then
			cbx_all.checked = false
		elseif ll_cnt = this.rowcount() then
			cbx_all.checked = true
		end if
		
	case "sale_no"
		ls_col  = "수주번호"
		ls_text = this.object.sale_no[row]
	case "seq"
		ls_col  = "순번"
		ls_text = string(this.object.seq[row])
	case "item_name"
		ls_col  = "수주품목"
		ls_text = this.object.item_name[row]
	case "qa"
		ls_col  = "수주규격"
		ls_text = string(this.object.qa[row])
	case "color"
		ls_col  = "색상"
		ls_text = this.object.color[row]

	case "b1_drawno"
		ls_col  = "도면번호"
		ls_text = this.object.b1_drawno[row]
	case "b1_qa1"
		ls_col  = "폭1"
		ls_text = string(this.object.b1_qa1[row])
	case "b1_qa2"
		ls_col  = "폭2"
		ls_text = string(this.object.b1_qa2[row])
	case "b1_qa3"
		ls_col  = "길이1"
		ls_text = string(this.object.b1_qa3[row])
	case "b1_qa4"
		ls_col  = "길이2"
		ls_text = string(this.object.b1_qa4[row])
	case "qty"
		ls_col  = "수량"
		ls_text = string(this.object.qty[row])

	case "b1_cuts"
		ls_col  = "칼수"
		ls_text = string(this.object.b1_cuts[row])
	case "b1_qa5"
		ls_col  = "폭"
		ls_text = string(this.object.b1_qa1[row])
	case "b1_qa6"
		ls_col  = "길이"
		ls_text = string(this.object.b1_qa2[row])
	case "b1_qa7"
		ls_col  = "레퍼런스1"
		ls_text = string(this.object.b1_qa3[row])
	case "b1_qa8"
		ls_col  = "레퍼런스2"
		ls_text = string(this.object.b1_qa4[row])
	case "b1_rem"
		ls_col  = "절곡(비고)"
		ls_text = this.object.b1_rem[row]
	case "b1_pgmno"
		ls_col  = "프로그램NO"
		ls_text = string(this.object.b1_pgmno[row])
	case "b1_type"
		ls_col  = "TYPE"
		ls_text = this.object.b1_type[row]
		
	case "p1_qa1"
		ls_col  = "도장(폭)"
		ls_text = string(this.object.p1_qa1[row])
	case "p1_qa2"
		ls_col  = "도장(길이)"
		ls_text = string(this.object.p1_qa2[row])
	case "p1_face"
		ls_col  = "도장(면)"
		ls_text = string(this.object.p1_face[row])
	case "p1_rem"
		ls_col  = "도장(비고)"
		ls_text = this.object.p1_rem[row]
	case "p1_refcolor"
		ls_col  = "대체색상"
		ls_text = this.object.p1_refcolor[row]
	case "p1_keyno"
		ls_col  = "도장(번호)"
		ls_text = this.object.p1_keyno[row]
		//25	case "p1_keyno"	ls_col  = "도장(번호)"   X
end choose

choose case dwo.name
	case "chk", "sale_no", "seq", "item_name", "qa", "color"
		cb_agree.enabled = false
		em_value.enabled = false

	case "b1_rem","p1_rem", "p1_keyno", "b1_pgmno", "b1_type"
		cb_agree.enabled = true	
		em_value.enabled = false
		em_value.setfocus()

	case else
		cb_agree.enabled = true	
		em_value.enabled = true
		em_value.setfocus()
end choose

choose case ls_col
	case "수주번호", "수주품목", "수주규격", "색상", "절곡(비고)", "도장(비고)"
		ddlb_4.text = "LIKE"
	case else
		ddlb_4.text = "="
end choose

ddlb_col1.text  = ls_col
sle_value1.text = ls_text

end event

event dberror;choose case sqldbcode
	case -195 // Required value is NULL.
        MessageBox("Database Problem", &
            "Error inserting row " + string(row) &
            + ". Please specify a value for Employee ID.")
	case else
	// Code to handle other errors
end choose

RETURN 1 // Do not display system error message
end event

