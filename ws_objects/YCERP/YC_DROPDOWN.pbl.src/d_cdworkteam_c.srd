table(column=(type=char(2) updatewhereclause=yes name=team_cd dbname="team_cd" )
 column=(type=char(20) updatewhereclause=yes name=team_nm dbname="team_nm" )
 column=(type=char(20) updatewhereclause=yes name=dept_nm dbname="dept_nm" )
 column=(type=char(2) updatewhereclause=yes name=acc_cd dbname="acc_cd" )
 retrieve="  SELECT DISTINCT team_cd
       , team_nm
       , dept_nm
       , acc_cd
    FROM V_INSABASE
   WHERE acc_cd like :as_com
/*   and isnull(team_nm, '') <> ''*/

" arguments=(("as_com", string))  sort="team_nm A dept_nm A " )
