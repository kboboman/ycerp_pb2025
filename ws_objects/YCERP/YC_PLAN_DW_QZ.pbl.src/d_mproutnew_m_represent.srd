footer(height=0 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=long updatewhereclause=yes name=operation dbname="operation" )
 column=(type=char(1) updatewhereclause=yes name=flag dbname="flag" )
 column=(type=decimal(4) updatewhereclause=yes name=setup_time dbname="setup_time" )
 column=(type=decimal(4) updatewhereclause=yes name=run_time dbname="run_time" )
 column=(type=char(10) updatewhereclause=yes name=assembly dbname="assembly" )
 column=(type=char(20) updatewhereclause=yes name=assy_qa dbname="assy_qa" )
 column=(type=long updatewhereclause=yes name=bom_no dbname="bom_no" )
 column=(type=decimal(4) updatewhereclause=yes name=qpa dbname="qpa" )
 column=(type=long updatewhereclause=yes name=work_per dbname="work_per" )
 column=(type=char(10) updatewhereclause=yes name=wc_no dbname="wc_no" )
 column=(type=char(10) updatewhereclause=yes name=area_no dbname="area_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=char(1) updatewhereclause=yes name=source dbname="source" )
 column=(type=char(2) updatewhereclause=yes name=mp_uom dbname="mp_uom" )
 column=(type=char(1) updatewhereclause=yes name=represent dbname="represent" )
 retrieve="  SELECT distinct
		rout.operation
	  , 'Y' flag																	/*이건 전부 Y로 수정 모두 생성해야한다. 2018.05.17 jowonsuk */
       , rout.setup_time
       , rout.run_time
       , rout.assembly
       , :arg_qa assy_qa
       , rout.bom_no
       , rout.qpa
       , rout.work_per
	  , rout.wc_no
       , wc.area_no  
	  , groupitem.item_name
	  ,  groupitem.uom
	  , groupitem.source
	  ,  groupitem.mp_uom 
       ,  isnull(rout.represent, 'N') represent
    FROM rout with(nolock) inner join wc with(nolock) on rout.wc_no      = wc.work_no
				   inner join groupitem with(nolock) on rout.assembly = groupitem.item_no 
/*
				   left outer join (     /* 2020.08.06 jowonsuk 제품별공정관리에 공정관리가 없는 규격이 있으면 생성하지 않는다. */
										 select a.item_no, count(*) count
											from item a with(nolock) left outer join rout b with(nolock) on a.item_no = b.item_no and a.qa = b.qa
											where a.item_no = :arg_item
											and a.use_flag = 'Y'
											and b.item_no is null
											group by a.item_no
								    ) item on rout.item_no = item.item_no
*/
   WHERE ( rout.item_no    = :arg_item  ) 
     AND ( rout.qa   LIKE '%' )
     AND rout.represent = 'Y'
/*    AND isnull(item.count, 0) = 0*/
   ORDER BY rout.operation DESC" arguments=(("arg_item", string),("arg_qa", string))  sort="operation D " )
