 column=(type=char(3) update=yes updatewhereclause=yes name=curr_code dbname="apoiinv.curr_code" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=gl_cur_rate dbname="apoiinv.gl_cur_rate" initial="1" )
