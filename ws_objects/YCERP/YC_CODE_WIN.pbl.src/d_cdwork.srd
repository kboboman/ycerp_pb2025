table(column=(type=char(10) updatewhereclause=yes key=yes name=work_no dbname="wc.work_no" )
 column=(type=char(10) updatewhereclause=yes name=work_name dbname="wc.work_name" )
 retrieve="  SELECT DISTINCT work_no, work_name
    FROM wc
   WHERE work_no   LIKE '%00'
     AND work_type    = 'D'
     AND work_no NOT IN ('H00', 'S00')" update="wc" updatewhere=0 updatekeyinplace=no )
