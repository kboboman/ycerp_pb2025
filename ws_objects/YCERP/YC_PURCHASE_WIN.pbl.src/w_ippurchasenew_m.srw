dw_1.object.order_date[1]    = wf_today()
//dw_1.object.supp_no[1] = ls_supp

//ls_string = left(dw_area.object.area[1],1) + "P" + string(today(),'yymmdd')
//ls_like = ls_string + '%'
//setnull(ls_order)
//select max(order_no) into :ls_order from pur where order_no like :ls_like; 
//if isnull(ls_order) then
//	dw_1.object.order_no[1] = ls_string + '01'
//else
//	li_num = integer(right(trim(ls_order),2))
//	li_num++
//	ls_num = right('00000' + string(li_num),2)
//	dw_1.object.order_no[1] = ls_string + ls_num
//end if
