$PBExportHeader$d_mpsfcmon_r2.srd
$PBExportComments$생산월보조회_보고서(월별)(1998/05/08,이인호)
release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=468 color="536870912" )
summary(height=84 color="536870912" )
footer(height=0 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=sfcday_wc_no dbname="sfcday.wc_no" )
 column=(type=char(20) updatewhereclause=yes name=wc_work_name dbname="wc.work_name" initial=" " )
 column=(type=char(20) updatewhereclause=yes name=sfcday_qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=sfcday_uom dbname="sfcday.uom" )
 column=(type=char(10) updatewhereclause=yes name=sfcday_item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=decimal(4) updatewhereclause=yes name=sum_qty dbname="sum_qty" )
 column=(type=datetime updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=datetime updatewhereclause=yes name=edate dbname="edate" )
 column=(type=long updatewhereclause=yes name=sfc_yy dbname="sfc_yy" )
 column=(type=long updatewhereclause=yes name=sfc_mm dbname="sfc_mm" )
 retrieve="  SELECT sfcday.wc_no,   
         wc.work_name,   
         qa = sfcday.assembly_qa,   
         sfcday.uom,   
         item_no = sfcday.assembly,   
         groupitem.item_name,   
         sum_qty = sum(make_qty),   
         sdate = convert(smalldatetime, :ad_start, 111),   
         edate = convert(smalldatetime, :ad_end, 111),   
         sfc_yy = datepart(year, sfcday.sfc_date),   
         sfc_mm = datepart(month, sfcday.sfc_date)    
    FROM sfcday,   
         wc,   
         groupitem  
   WHERE ( sfcday.wc_no = wc.work_no ) and  
         ( sfcday.assembly = groupitem.item_no ) and  
         ( ( wc.work_name like :as_wc ) AND  
         ( sfcday.sfc_date between :ad_start and :ad_end + ~" 23:59:59:999~" ) and 
			( sfcday.area_no = :as_area ) )     
GROUP BY datepart(year, sfcday.sfc_date),   
         datepart(month, sfcday.sfc_date) ,  
         sfcday.wc_no,   
         wc.work_name,   
         sfcday.assembly_qa,   
         sfcday.uom,   
         sfcday.assembly,   
         groupitem.item_name " arguments=(("as_wc", string),("ad_start", date),("ad_end", date),("as_area", string))  sort="yymm A sfcday_wc_no A sfcday_item_no A sfcday_qa A " )
group(level=1 header.height=0 trailer.height=88 by=("sfc_yy" , "sfc_mm" ) newpage=yes header.color="536870912" trailer.color="536870912" )
group(level=2 header.height=0 trailer.height=0 by=("sfcday_wc_no" ) header.color="536870912" trailer.color="536870912" )
