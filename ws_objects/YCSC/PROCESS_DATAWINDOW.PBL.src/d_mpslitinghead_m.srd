table(column=(type=char(14) update=yes updatewhereclause=yes key=yes name=order_no dbname="coilorder.order_no" )
 column=(type=datetime update=yes updatewhereclause=yes name=order_date dbname="coilorder.order_date" )
 column=(type=datetime update=yes updatewhereclause=yes name=due_date dbname="coilorder.due_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=wc_no dbname="coilorder.wc_no" initial="S01" )
 column=(type=char(1) update=yes updatewhereclause=yes name=wc_place dbname="coilorder.wc_place" values="사내	I/외주	O/" )
 column=(type=char(10) update=yes updatewhereclause=yes name=supp_no dbname="coilorder.supp_no" initial="NO" )
 column=(type=char(1) update=yes updatewhereclause=yes name=open_close dbname="coilorder.open_close" initial="O" )
 column=(type=char(10) update=yes updatewhereclause=yes name=planner dbname="coilorder.planner" )
 column=(type=char(40) update=yes updatewhereclause=yes name=rem dbname="coilorder.rem" )
 retrieve="  SELECT coilorder.order_no,   
         coilorder.order_date,   
         coilorder.due_date,   
         coilorder.wc_no,   
         coilorder.wc_place,   
         coilorder.supp_no,   
         coilorder.open_close,   
         coilorder.planner,   
         coilorder.rem  
    FROM coilorder  
   WHERE coilorder.order_no = :arg_order    
" update="coilorder" updatewhere=1 updatekeyinplace=no arguments=(("arg_order", string)) )
