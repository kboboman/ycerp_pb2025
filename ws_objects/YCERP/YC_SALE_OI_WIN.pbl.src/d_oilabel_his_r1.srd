column(band=detail id=3 alignment="1" tabsequence=32766 border="0" color="0" x="1426" y="4" height="68" width="274" format="#,###" html.valueishtml="0"  name=number visible="1" edit.limit=0 edit.case=any edit.focusrectangle=no edit.autoselect=no edit.imemode=0  font.face="Arial" font.height="-11" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="0" background.color="16777215~tif ( getrow() = currentrow(), 12639424, rgb(255,255,255) )" )
column(band=detail id=1 alignment="2" tabsequence=32766 border="0" color="0" x="677" y="4" height="68" width="741" format="[general]" html.valueishtml="0"  name=label_no visible="1" edit.limit=0 edit.case=any edit.focusrectangle=no edit.autoselect=no edit.imemode=0  font.face="Arial" font.height="-11" font.weight="400"  font.family="2" font.pitch="2" font.charset="0" background.mode="0" background.color="16777215~tif ( getrow() = currentrow(), 12639424, rgb(255,255,255) )" )

sparse(names="sys_date")htmltable(border="1" )
