compute(band=detail alignment="1" expression="if(left( aroi_item_no ,1) = 'P' and mid(aroi_item_no, 3,1) = 'Y' and (mid(aroi_item_no, 7,1) = 'A' or mid(aroi_item_no, 7,1) = 'B' or mid(aroi_item_no, 7,1) = 'C' or mid(aroi_item_no, 7,1) = 'D' or left(aroi_item_no, 5) = 'PCYSZ'), aroi_ship_qty, if(aroi_uom = 'M2' or aroi_uom = 'SS',truncate( long(mid( aroi_qa ,5,4)) * long(mid(aroi_qa,10,4)) *   aroi_ship_qty / 1000000+ 0.00001, 2), if(aroi_uom = 'M',if(  aroi_ship_qty < 0 , truncate(long(mid(  aroi_qa , 15,5)) *    aroi_ship_qty / 1000 - 0.00001,2), truncate(long(mid(  aroi_qa , 15,5)) *   aroi_ship_qty / 1000 + 0.00001,2)) ,      aroi_ship_qty )))"border="0" color="0" x="2656" y="8" height="60" width="448" format="[general]" html.valueishtml="0"  name=h_qty visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
compute(band=detail alignment="0" expression="truncate( ( aroi_ori_amount - if( aroiinv_curr_code = 'WON', truncate(  aroi_ori_amount  *  aroi_dc_rate / 100 + 0.000001, 0 ),  truncate(  aroi_ori_amount  *  aroi_dc_rate / 100 + 0.00001, 2 )))  *  aroiinv_gl_cur_rate , 0 )"border="0" color="0" x="3159" y="12" height="60" width="475" format="[general]" html.valueishtml="0"  name=c_ori_amount visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
