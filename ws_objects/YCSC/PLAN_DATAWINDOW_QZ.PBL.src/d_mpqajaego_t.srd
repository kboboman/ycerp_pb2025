$PBExportComments$규격별재고현황(1998/10/10,곽용덕)
release 8;
datawindow(units=0 timer_interval=0 color=67108864 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=68 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=qa dbname="item.qa" )
 column=(type=decimal(4) updatewhereclause=yes name=sales_reserved dbname="item.sales_reserved" )
 column=(type=decimal(4) updatewhereclause=yes name=qoh dbname="qoh" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"item~" )  TABLE(NAME=~"itemloc~" ) COLUMN(NAME=~"item.qa~") COLUMN(NAME=~"item.sales_reserved~") COMPUTE(NAME=~"sum(itemloc.qoh) qoh~")    JOIN (LEFT=~"item.item_no~"    OP =~"=~"RIGHT=~"itemloc.item_no~"    OUTER1 =~"item.item_no~" )    JOIN (LEFT=~"item.qa~"    OP =~"=~"RIGHT=~"itemloc.qa~"    OUTER1 =~"item.qa~" )WHERE(    EXP1 =~"item.item_no~"   OP =~"=~"    EXP2 =~":arg_item~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"itemloc.loc_no~"   OP =~"in~" NEST = PBSELECT( VERSION(400) TABLE(NAME=~"location~" ) COLUMN(NAME=~"location.loc_no~")WHERE(    EXP1 =~"location.loc_type~"   OP =~"=~"    EXP2 =~"'N'~" ) ))  GROUP(NAME=~"item.qa~") GROUP(NAME=~"item.sales_reserved~")) ARG(NAME = ~"arg_item~" TYPE = string) " arguments=(("arg_item", string)) )
