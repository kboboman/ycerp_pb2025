 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"jajaesudo~" )  TABLE(NAME=~"groupitem~" ALIAS=~"groupitem_a~" )  TABLE(NAME=~"groupitem~" ALIAS=~"groupitem_b~" ) COLUMN(NAME=~"jajaesudo.order_no~") COLUMN(NAME=~"jajaesudo.item_no~") COLUMN(NAME=~"jajaesudo.qa~") COLUMN(NAME=~"jajaesudo.order_qty~") COLUMN(NAME=~"jajaesudo.assy_item~") COLUMN(NAME=~"jajaesudo.assy_qa~") COLUMN(NAME=~"jajaesudo.out_qty~") COLUMN(NAME=~"jajaesudo.flag~") COLUMN(NAME=~"groupitem_a.item_name~") COLUMN(NAME=~"groupitem_b.item_name~") COLUMN(NAME=~"groupitem_a.uom~") COLUMN(NAME=~"groupitem_b.uom~") COLUMN(NAME=~"jajaesudo.issue_loc~") COLUMN(NAME=~"jajaesudo.out_type~") COLUMN(NAME=~"jajaesudo.issue_lot~") COLUMN(NAME=~"jajaesudo.order_dt~")    JOIN (LEFT=~"jajaesudo.item_no~"    OP =~"=~"RIGHT=~"groupitem_a.item_no~" )    JOIN (LEFT=~"jajaesudo.assy_item~"    OP =~"=~"RIGHT=~"groupitem_b.item_no~" )WHERE(    EXP1 =~"jajaesudo.flag~"   OP =~"=~"    EXP2 =~"'N'~" ) ) " update="jajaesudo" updatewhere=0 updatekeyinplace=no )
