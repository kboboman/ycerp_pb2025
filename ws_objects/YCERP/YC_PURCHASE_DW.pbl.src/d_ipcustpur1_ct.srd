$PBExportHeader$d_ipcustpur1_ct.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no  crosstab.dynamic = yes grid.lines=0 grid.columnmove=no selected.mouse=no )
header[1](height=80 color="536870912" )
header[2](height=80 color="536870912" )
header[3](height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=supp_name dbname="supp_name" )
 column=(type=number updatewhereclause=yes name=cqty dbname="cqty" )
 column=(type=number updatewhereclause=yes name=cprice dbname="cprice" )
 retrieve="  SELECT item_name    = a.item_name  
       , supp_name    = a.supp_name
       , due_date     = a.due_date + (case when :as_yymm = 'Y' then a.due_days else '(' + a.due_days + ')' end)
       , cqty         = a.com_qty       
       , cprice       = a.cprice
    FROM (
         SELECT due_date     = (case when :as_yymm = 'Y' then convert(char(04),insp.insp_date,111)
                                     else convert(char(08),insp.insp_date,11)
                                end)
              , due_days     = (case when :as_yymm = 'Y' then '.' + right('00'+replace(cast(datepart(m,insp.insp_date) as char(2)),' ',''),2)+'월'
                                     else (case when datepart(dw,insp.insp_date) = 1 then '일'
                                                when datepart(dw,insp.insp_date) = 2 then '월'
                                                when datepart(dw,insp.insp_date) = 3 then '화'
                                                when datepart(dw,insp.insp_date) = 4 then '수'
                                                when datepart(dw,insp.insp_date) = 5 then '목'
                                                when datepart(dw,insp.insp_date) = 6 then '금'
                                                when datepart(dw,insp.insp_date) = 7 then '토'
                                           end)
                                end)
              , supp_no      = insp.supp_no
              , supp_name    = supp.supp_name
              , item_name    = groupitem.item_name                                
              , item_no      = groupitem.item_no                                  
              , qa           = inspdet.qa                                         
              , uom          = inspdet.uom                                        
              , crcpt_qty    = inspdet.rcpt_qty               
              , com_qty      = inspdet.comqty                 
              , cprice        = isnull((case when supp.round = 'Y' then ROUND(comqty * inspdet.price, 0, 0) 
										     else ROUND(comqty * inspdet.price, 0, 1) 
									 end), 0)
           FROM inspdet     
                LEFT OUTER JOIN insp      ON inspdet.insp_no = insp.insp_no
                LEFT OUTER JOIN groupitem ON inspdet.item_no = groupitem.item_no
                LEFT OUTER JOIN supp      ON insp.supp_no    = supp.supp_no
          WHERE ( insp.insp_date    BETWEEN :ad_sdate and :ad_edate )
            AND ((:as_itemno  = '%') OR
                 (:as_itemno <> '%' AND inspdet.item_no LIKE :as_itemno )
                )
            AND (( inspdet.pur_no     LIKE :as_area + '%'       ) OR
                 ( :as_area = 'S' AND inspdet.pur_no like 'PUR%')
                )
         ) A
" arguments=(("as_area", string),("as_itemno", string),("ad_sdate", date),("ad_edate", date),("as_yymm", string))  sort="item_name A supp_name A " )
group(level=1 header.height=0 trailer.height=80 by=("item_name" ) header.color="536870912" trailer.color="536870912" )
