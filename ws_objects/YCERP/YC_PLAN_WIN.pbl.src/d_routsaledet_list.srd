table(column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" values="	Y/	N" )
 column=(type=char(14) updatewhereclause=yes name=order_no dbname="order_no" )
 column=(type=long update=yes updatewhereclause=yes name=seq_no dbname="seq_no" )
 column=(type=datetime updatewhereclause=yes name=order_date dbname="order_date" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=datetime updatewhereclause=yes name=napgi_date dbname="napgi_date" )
 column=(type=long updatewhereclause=yes name=napgi_chk dbname="napgi_chk" )
 column=(type=decimal(2) updatewhereclause=yes name=order_qty dbname="order_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=jan_qty dbname="jan_qty" )
 column=(type=long updatewhereclause=yes name=sp0 dbname="sp0" )
 column=(type=char(10) updatewhereclause=yes name=job1 dbname="job1" )
 column=(type=char(10) updatewhereclause=yes name=w1nm dbname="w1nm" )
 column=(type=datetime updatewhereclause=yes name=job1_in dbname="job1_in" )
 column=(type=datetime updatewhereclause=yes name=job1_inchk dbname="job1_inchk" )
 column=(type=decimal(0) updatewhereclause=yes name=job1_qty dbname="job1_qty" )
 column=(type=decimal(0) updatewhereclause=yes name=job1_qty1 dbname="job1_qty1" )
 column=(type=decimal(0) updatewhereclause=yes name=job1_sqty dbname="job1_sqty" )
 column=(type=long updatewhereclause=yes name=job1_cnt dbname="job1_cnt" )
 column=(type=char(10) updatewhereclause=yes name=job2 dbname="job2" )
 column=(type=char(10) updatewhereclause=yes name=w2nm dbname="w2nm" )
 column=(type=datetime updatewhereclause=yes name=job2_in dbname="job2_in" )
 column=(type=datetime updatewhereclause=yes name=job2_inchk dbname="job2_inchk" )
 column=(type=decimal(0) updatewhereclause=yes name=job2_qty dbname="job2_qty" )
 column=(type=decimal(0) updatewhereclause=yes name=job2_qty1 dbname="job2_qty1" )
 column=(type=decimal(0) updatewhereclause=yes name=job2_sqty dbname="job2_sqty" )
 column=(type=long updatewhereclause=yes name=job2_cnt dbname="job2_cnt" )
 column=(type=char(10) updatewhereclause=yes name=job3 dbname="job3" )
 column=(type=char(10) updatewhereclause=yes name=w3nm dbname="w3nm" )
 column=(type=datetime updatewhereclause=yes name=job3_in dbname="job3_in" )
 column=(type=datetime updatewhereclause=yes name=job3_inchk dbname="job3_inchk" )
 column=(type=decimal(0) updatewhereclause=yes name=job3_qty dbname="job3_qty" )
 column=(type=decimal(0) updatewhereclause=yes name=job3_qty1 dbname="job3_qty1" )
 column=(type=decimal(0) updatewhereclause=yes name=job3_sqty dbname="job3_sqty" )
 column=(type=long updatewhereclause=yes name=job3_cnt dbname="job3_cnt" )
 column=(type=char(50) updatewhereclause=yes name=bigo dbname="bigo" )
 column=(type=char(1) updatewhereclause=yes name=uptchk dbname="uptchk" )
 column=(type=datetime updatewhereclause=yes name=tracking_date dbname="tracking_date" )
 retrieve="  SELECT chk        = 'N'
       , order_no   = a.order_no
       , seq_no     = a.seq_no
       , order_date = a.order_date
       , user_name  = a.user_name
       , cust_name  = a.cust_name
       , scene_desc = a.scene_desc
       , item_no    = a.item_no
       , item_name  = a.item_name
       , qa         = a.qa 

       , napgi_date = a.napgi_date
       , napgi_chk  = a.napgi_chk
       , order_qty  = a.order_qty
       , jan_qty    = a.jan_qty

       , sp0        = a.sp0

       , job1       = a.job1
       , w1nm       = a.w1nm       
       , job1_in    = (SELECT TOP 1 job_inchk FROM routcheckdet R1 WHERE a.order_no = r1.sale_no AND a.seq_no = r1.seq_no AND a.job1 = r1.job ORDER BY seq DESC)
       , job1_inchk = (SELECT TOP 1 job_inchk FROM routcheckdet R1 WHERE a.order_no = r1.sale_no AND a.seq_no = r1.seq_no AND a.job1 = r1.job ORDER BY seq DESC)
       , job1_qty   = isnull((SELECT TOP 1 job_qty   FROM routcheckdet R1 WHERE a.order_no = r1.sale_no AND a.seq_no = r1.seq_no AND a.job1 = r1.job ORDER BY seq DESC),0)
       , job1_qty1  = isnull((SELECT TOP 1 job_qty   FROM routcheckdet R1 WHERE a.order_no = r1.sale_no AND a.seq_no = r1.seq_no AND a.job1 = r1.job ORDER BY seq DESC),0)
       , job1_sqty  = isnull((SELECT sum(job_qty)    FROM routcheckdet R1 WHERE a.order_no = r1.sale_no AND a.seq_no = r1.seq_no AND a.job1 = r1.job),0)
       , job1_cnt   = isnull((SELECT TOP 1 seq       FROM routcheckdet R1 WHERE a.order_no = r1.sale_no AND a.seq_no = r1.seq_no AND a.job1 = r1.job ORDER BY seq DESC),0)

       , job2       = a.job2
       , w2nm       = a.w2nm      
       , job2_in    = (SELECT TOP 1 job_inchk FROM routcheckdet R2 WHERE a.order_no = r2.sale_no AND a.seq_no = r2.seq_no AND a.job2 = r2.job ORDER BY seq DESC)
       , job2_inchk = (SELECT TOP 1 job_inchk FROM routcheckdet R2 WHERE a.order_no = r2.sale_no AND a.seq_no = r2.seq_no AND a.job2 = r2.job ORDER BY seq DESC)
       , job2_qty   = isnull((SELECT TOP 1 job_qty   FROM routcheckdet R2 WHERE a.order_no = r2.sale_no AND a.seq_no = r2.seq_no AND a.job2 = r2.job ORDER BY seq DESC),0)
       , job2_qty1  = isnull((SELECT TOP 1 job_qty   FROM routcheckdet R2 WHERE a.order_no = r2.sale_no AND a.seq_no = r2.seq_no AND a.job2 = r2.job ORDER BY seq DESC),0)
       , job2_sqty  = isnull((SELECT sum(job_qty)    FROM routcheckdet R2 WHERE a.order_no = r2.sale_no AND a.seq_no = r2.seq_no AND a.job2 = r2.job),0)
       , job2_cnt   = isnull((SELECT TOP 1 seq       FROM routcheckdet R2 WHERE a.order_no = r2.sale_no AND a.seq_no = r2.seq_no AND a.job2 = r2.job ORDER BY seq DESC),0)
  
       , job3       = a.job3
       , w3nm       = a.w3nm
       , job3_in    = (SELECT TOP 1 job_inchk FROM routcheckdet R3 WHERE a.order_no = r3.sale_no AND a.seq_no = r3.seq_no AND a.job3 = r3.job ORDER BY seq DESC)
       , job3_inchk = (SELECT TOP 1 job_inchk FROM routcheckdet R3 WHERE a.order_no = r3.sale_no AND a.seq_no = r3.seq_no AND a.job3 = r3.job ORDER BY seq DESC)
       , job3_qty   = isnull((SELECT TOP 1 job_qty   FROM routcheckdet R3 WHERE a.order_no = r3.sale_no AND a.seq_no = r3.seq_no AND a.job3 = r3.job ORDER BY seq DESC),0)
       , job3_qty1  = isnull((SELECT TOP 1 job_qty   FROM routcheckdet R3 WHERE a.order_no = r3.sale_no AND a.seq_no = r3.seq_no AND a.job3 = r3.job ORDER BY seq DESC),0)
       , job3_sqty  = isnull((SELECT sum(job_qty)    FROM routcheckdet R3 WHERE a.order_no = r3.sale_no AND a.seq_no = r3.seq_no AND a.job3 = r3.job),0)
       , job3_cnt   = isnull((SELECT TOP 1 seq       FROM routcheckdet R3 WHERE a.order_no = r3.sale_no AND a.seq_no = r3.seq_no AND a.job3 = r3.job ORDER BY seq DESC),0)

       , bigo       = a.bigo
       , uptchk     = 'N'
       , tracking_date = a.tracking_date
    FROM (
         SELECT order_no   = a.order_no
              , seq_no     = a.seq_no
              , order_date = (SELECT order_date FROM sale WHERE order_no = a.order_no)
              , user_name  = a.user_name
              , cust_name  = a.cust_name
              , scene_desc = a.scene_desc
              , item_no    = a.item_no
              , item_name  = g.item_name
              , qa         = a.qa19 
         
              , napgi_date = (SELECT due_date FROM sale WHERE order_no = a.order_no)
              , napgi_chk  = datediff(day, (SELECT order_date FROM sale WHERE order_no = a.order_no), (SELECT due_date FROM sale WHERE order_no = a.order_no))
              , order_qty  = (SELECT order_qty            FROM saledet WHERE order_no = a.order_no AND seq_no = a.seq_no)
              , jan_qty    = (SELECT order_qty - rlse_qty FROM saledet WHERE order_no = a.order_no AND seq_no = a.seq_no)
         
              , sp0        = (case when rc.order_date is not null then 1 else 0 end)
              , job1       = a.wc1
              , w1nm       = isnull(w1.work_name,'')
         
              , job2       = a.wc2
              , w2nm       = isnull(w2.work_name,'')
         
              , job3       = a.wc3
              , w3nm       = isnull(w3.work_name,'')
         
              , bigo       = (SELECT rem  FROM saledet WHERE order_no = a.order_no AND seq_no = a.seq_no)
              , tracking_date = (SELECT tracking_date FROM sale WHERE order_no = a.order_no)
           FROM ( 
                     SELECT a.user_name
                          , a.cust_name
                          , a.scene_desc
                          , a.order_no
                          , a.seq_no
                          , a.item_no
                          , a.qa   
                          , a.qa19 
                          , wc1 = max((case when r.operation = 1 then r.wc_no else null end))
                          , wc2 = max((case when r.operation = 2 then r.wc_no else null end))
                          , wc3 = max((case when r.operation = 3 then r.wc_no else null end))
                       FROM (
                             SELECT l.user_name
                                  , c.cust_name
                                  , s.scene_desc
                                  , a.order_no
                                  , a.seq_no
                                  , a.item_no
                                  , qa   = left(a.qa ,14) + '00000'
                                  , qa19 = a.qa
                               FROM saledet A
                                    LEFT OUTER JOIN sale       B ON a.order_no   = b.order_no
                                    LEFT OUTER JOIN customer   C ON b.cust_no    = c.cust_no
                                    LEFT OUTER JOIN scene      S ON b.scene_code = s.scene_code
                                    LEFT OUTER JOIN login      L ON c.salesman   = l.user_id
                              WHERE (b.order_date between :as_sdate AND :as_edate)
/*                                AND (b.open_close       <> 'C') 한도초과	*/
		                      AND ( b.open_close = 'O' )
                                AND (b.tracking          = 'Y')
                                AND (a.order_qty - a.rlse_qty > 0 )
                                AND ((:as_custno  = '%' AND b.cust_no    LIKE :as_custno) OR
                                     (:as_custno <> '%' AND b.cust_no       = :as_custno)
                                    )
                                AND ((:as_scene   = '%' AND b.scene_code LIKE :as_scene ) OR
                                     (:as_scene  <> '%' AND b.scene_code    = :as_scene )
                                    )
                                AND NOT EXISTS (SELECT * FROM routcheck WHERE sale_no = a.order_no AND seq_no = a.seq_no AND del_yn = 'Y')
                            ) A
                            LEFT OUTER JOIN rout R ON a.item_no = r.item_no AND a.qa = r.qa
                      GROUP BY a.user_name, a.cust_name, a.scene_desc, a.order_no, a.seq_no, a.item_no, a.qa, a.qa19
                ) A
                LEFT OUTER JOIN routcheck RC ON a.order_no = rc.sale_no AND a.seq_no = rc.seq_no
                LEFT OUTER JOIN groupitem  G ON a.item_no  = g.item_no
                LEFT OUTER JOIN wc        W1 ON a.wc1      = w1.work_no
                LEFT OUTER JOIN wc        W2 ON a.wc2      = w2.work_no
                LEFT OUTER JOIN wc        W3 ON a.wc3      = w3.work_no
            WHERE ((:as_work1 <> 'Y' )  OR
                   (:as_work1  = 'Y' AND 
                    NOT ((w1.work_name = '' OR w1.work_name LIKE '성형%' OR w1.work_name LIKE '화성%') AND w2.work_name = '')
                   )
                  )
         ) A
" arguments=(("as_custno", string),("as_scene", string),("as_sdate", string),("as_edate", string),("as_work1", string))  sort="cust_name A scene_desc A item_name A qa A order_no A seq_no A " )
