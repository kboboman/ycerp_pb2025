$PBExportComments$대체물품현황(2001/02/27,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=660 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=320 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=alter_time dbname="itemalter.alter_time" )
 column=(type=datetime updatewhereclause=yes name=alter_date dbname="itemalter.alter_date" )
 column=(type=char(10) updatewhereclause=yes name=src_item dbname="itemalter.src_item" )
 column=(type=char(20) updatewhereclause=yes name=src_qa dbname="itemalter.src_qa" )
 column=(type=char(10) updatewhereclause=yes name=src_loc dbname="itemalter.src_loc" )
 column=(type=char(17) updatewhereclause=yes name=order_no dbname="itemalter.order_no" )
 column=(type=long updatewhereclause=yes name=seq dbname="itemalter.seq" )
 column=(type=decimal(4) updatewhereclause=yes name=src_qty dbname="itemalter.src_qty" )
 column=(type=char(20) updatewhereclause=yes name=src_lot dbname="itemalter.src_lot" )
 column=(type=char(10) updatewhereclause=yes name=tar_item dbname="itemalter.tar_item" )
 column=(type=char(20) updatewhereclause=yes name=tar_qa dbname="itemalter.tar_qa" )
 column=(type=char(10) updatewhereclause=yes name=tar_loc dbname="itemalter.tar_loc" )
 column=(type=char(20) updatewhereclause=yes name=tar_lot dbname="itemalter.tar_lot" )
 column=(type=decimal(4) updatewhereclause=yes name=tar_qty dbname="itemalter.tar_qty" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="itemalter.user_id" )
 column=(type=char(60) updatewhereclause=yes name=rem dbname="itemalter.rem" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(1) updatewhereclause=yes name=itemalter_issue_flag dbname="itemalter.issue_flag" values="반영	Y/미반영	N/" )
 retrieve="  SELECT itemalter.alter_time,   
         itemalter.alter_date,   
         itemalter.src_item,   
         itemalter.src_qa,   
         itemalter.src_loc,   
         itemalter.order_no,   
         itemalter.seq,   
         itemalter.src_qty,   
         itemalter.src_lot,   
         itemalter.tar_item,   
         itemalter.tar_qa,   
         itemalter.tar_loc,   
         itemalter.tar_lot,   
         itemalter.tar_qty,   
         itemalter.user_id,   
         itemalter.rem,   
         groupitem_a.item_name,   
         groupitem_b.item_name,   
         itemalter.issue_flag  
    FROM itemalter LEFT OUTER JOIN groupitem groupitem_a ON itemalter.src_item = groupitem_a.item_no LEFT OUTER JOIN groupitem groupitem_b ON itemalter.tar_item = groupitem_b.item_no  
   WHERE ( itemalter.alter_time between :ad_start and :ad_end  + ~" 23:59:59:999~"  ) AND  
         (itemalter.src_loc like :as_loc OR  
         itemalter.tar_loc like :as_loc)    
" arguments=(("ad_start", date),("ad_end", date),("as_loc", string))  sort="alter_time A " )
