compute(band=detail alignment="1" expression="if(left( citem  ,1) = 'P' and mid( citem , 3,1) = 'Y' and (mid( citem , 7,1) = 'A' or mid( citem , 7,1) = 'B' or mid( citem , 7,1) = 'C' or mid( citem , 7,1) = 'D' or left(citem, 5) = 'PCYSZ'),  corder , if( uom  = 'M2' or uom = 'SS',truncate( long(mid(  cqa  ,5,4)) * long(mid(  cqa ,10,4)) *     corder  / 1000000 + 0.00001, 2), if( uom  = 'M',if (corder < 0 , truncate(long(mid( cqa , 15,5)) *  corder / 1000 - 0.00001,2), truncate(long(mid( cqa , 15,5)) * corder  / 1000 + 0.00001,2)) ,    corder  )))"border="0" color="8388608" x="2222" y="8" height="60" width="325" format="#,##0.00" html.valueishtml="0"  name=compute_1 visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
