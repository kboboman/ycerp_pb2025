 column=(type=decimal(6) updatewhereclause=yes name=inv02_2 dbname="INV02_2" )
 column=(type=decimal(6) updatewhereclause=yes name=inv03_1 dbname="INV03_1" )
 column=(type=decimal(6) updatewhereclause=yes name=inv03_2 dbname="INV03_2" )
 column=(type=decimal(6) updatewhereclause=yes name=inv04_1 dbname="INV04_1" )
 column=(type=decimal(6) updatewhereclause=yes name=inv04_2 dbname="INV04_2" )
 column=(type=decimal(6) updatewhereclause=yes name=inv05_1 dbname="INV05_1" )
 column=(type=decimal(6) updatewhereclause=yes name=inv05_2 dbname="INV05_2" )
 column=(type=decimal(6) updatewhereclause=yes name=inv06_1 dbname="INV06_1" )
 column=(type=decimal(6) updatewhereclause=yes name=inv06_2 dbname="INV06_2" )
 column=(type=decimal(6) updatewhereclause=yes name=inv07_1 dbname="INV07_1" )
 column=(type=decimal(6) updatewhereclause=yes name=inv07_2 dbname="INV07_2" )
 column=(type=decimal(6) updatewhereclause=yes name=inv08_1 dbname="INV08_1" )
 column=(type=decimal(6) updatewhereclause=yes name=inv08_2 dbname="INV08_2" )
 column=(type=decimal(6) updatewhereclause=yes name=inv09_1 dbname="INV09_1" )
 column=(type=decimal(6) updatewhereclause=yes name=inv09_2 dbname="INV09_2" )
 column=(type=decimal(6) updatewhereclause=yes name=inv10_1 dbname="INV10_1" )
 column=(type=decimal(6) updatewhereclause=yes name=inv10_2 dbname="INV10_2" )
 column=(type=decimal(6) updatewhereclause=yes name=inv11_1 dbname="INV11_1" )
 column=(type=decimal(6) updatewhereclause=yes name=inv11_2 dbname="INV11_2" )
 column=(type=decimal(6) updatewhereclause=yes name=inv12_1 dbname="INV12_1" )
 column=(type=decimal(6) updatewhereclause=yes name=inv12_2 dbname="INV12_2" )
 retrieve="SELECT YEAR = DATEPART(YEAR, opeom.eom_year),
			/*순수판매=> */ 
         INV01_1 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854' 
									then opeom.inv_01 else 0 end ) / 1100,
   		/*내부판매=> 유창내장건설,카프텍제외*/  
         INV01_2 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854' 
									then 0 else opeom.inv_01 end ) / 1100,   
      
			INV02_1 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854'
										then opeom.inv_02 else 0 end ) / 1100,
         INV02_2 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854' 
										then 0 else opeom.inv_02 end ) / 1100,   
   
   		INV03_1 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854'
										then opeom.inv_03 else 0 end ) / 1100,
         INV03_2 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854' 
										then 0 else opeom.inv_03 end ) / 1100,   

   		INV04_1 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854'
										then opeom.inv_04 else 0 end ) / 1100,
         INV04_2 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854' 
										then 0 else opeom.inv_04 end ) / 1100,   

   		INV05_1 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854'
										then opeom.inv_05 else 0 end ) / 1100,
         INV05_2 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854' 
										then 0 else opeom.inv_05 end ) / 1100,   

   		INV06_1 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854'
										then opeom.inv_06 else 0 end ) / 1100,
         INV06_2 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854' 
										then 0 else opeom.inv_06 end ) / 1100,   

       	INV07_1 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854'
										then opeom.inv_07 else 0 end ) / 1100,
         INV07_2 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854' 
										then 0 else opeom.inv_07 end ) / 1100,   

         INV08_1 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854'
										then opeom.inv_08 else 0 end ) / 1100,
         INV08_2 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854' 
										then 0 else opeom.inv_08 end ) / 1100,   

       	INV09_1 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854'
										then opeom.inv_09 else 0 end ) / 1100,
         INV09_2 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854' 
										then 0 else opeom.inv_09 end ) / 1100,   

       	INV10_1 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854'
										then opeom.inv_10 else 0 end ) / 1100,
         INV10_2 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854' 
										then 0 else opeom.inv_10 end ) / 1100,   

       	INV11_1 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854'
										then opeom.inv_11 else 0 end ) / 1100,
         INV11_2 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854' 
										then 0 else opeom.inv_11 end ) / 1100,   

       	INV12_1 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854'
										then opeom.inv_12 else 0 end ) / 1100,
         INV12_2 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854' 
										then 0 else opeom.inv_12 end ) / 1100
    FROM opeom ,CUSTOMER
   WHERE DATEPART(YEAR, opeom.eom_year) = :ai_year -1
     AND opeom.CUST_NO <> 'N004'
	  AND opeom.CUST_NO = CUSTOMER.CUST_NO
	  AND CUSTOMER.cust_type <> 'E'
 GROUP BY DATEPART(YEAR, opeom.eom_year)
union
SELECT   year = DATEPART(YEAR, opeom.eom_year),   
        /*순수판매=> 수출제외,건축사업부제외*/  
         INV01_1 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854' 
									then opeom.inv_01 else 0 end ) / 1100,
   		/*내부판매=> 유창내장건설,카프텍제외*/  
         INV01_2 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854' 
									then 0 else opeom.inv_01 end ) / 1100,   
      
			INV02_1 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854'
										then opeom.inv_02 else 0 end ) / 1100,
         INV02_2 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854' 
										then 0 else opeom.inv_02 end ) / 1100,   
   
   		INV03_1 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854'
										then opeom.inv_03 else 0 end ) / 1100,
         INV03_2 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854' 
										then 0 else opeom.inv_03 end ) / 1100,   

   		INV04_1 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854'
										then opeom.inv_04 else 0 end ) / 1100,
         INV04_2 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854' 
										then 0 else opeom.inv_04 end ) / 1100,   

   		INV05_1 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854'
										then opeom.inv_05 else 0 end ) / 1100,
         INV05_2 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854' 
										then 0 else opeom.inv_05 end ) / 1100,   

   		INV06_1 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854'
										then opeom.inv_06 else 0 end ) / 1100,
         INV06_2 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854' 
										then 0 else opeom.inv_06 end ) / 1100,   

       	INV07_1 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854'
										then opeom.inv_07 else 0 end ) / 1100,
         INV07_2 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854' 
										then 0 else opeom.inv_07 end ) / 1100,   

         INV08_1 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854'
										then opeom.inv_08 else 0 end ) / 1100,
         INV08_2 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854' 
										then 0 else opeom.inv_08 end ) / 1100,   

       	INV09_1 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854'
										then opeom.inv_09 else 0 end ) / 1100,
         INV09_2 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854' 
										then 0 else opeom.inv_09 end ) / 1100,   

       	INV10_1 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854'
										then opeom.inv_10 else 0 end ) / 1100,
         INV10_2 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854' 
										then 0 else opeom.inv_10 end ) / 1100,   

       	INV11_1 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854'
										then opeom.inv_11 else 0 end ) / 1100,
         INV11_2 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854' 
										then 0 else opeom.inv_11 end ) / 1100,   

       	INV12_1 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854'
										then opeom.inv_12 else 0 end ) / 1100,
         INV12_2 = SUM( case when opeom.cust_no <> 'N002' and opeom.cust_no <> 'S854' 
										then 0 else opeom.inv_12 end ) / 1100  
    FROM opeom ,CUSTOMER
   WHERE  DATEPART(YEAR, opeom.eom_year) = :ai_year
     AND opeom.CUST_NO <> 'N004'
	  AND opeom.CUST_NO = CUSTOMER.CUST_NO
	  AND CUSTOMER.cust_type <> 'E'
 GROUP BY DATEPART(YEAR, opeom.eom_year)
;" arguments=(("ai_year", number)) )
