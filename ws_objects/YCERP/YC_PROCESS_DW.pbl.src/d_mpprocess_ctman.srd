table(column=(type=char(20) updatewhereclause=yes name=name_kor dbname="name_kor" )
 column=(type=char(20) updatewhereclause=yes name=team_nm dbname="team_nm" )
 column=(type=char(8) updatewhereclause=yes name=gt_dt dbname="gt_dt" )
 column=(type=char(40) updatewhereclause=yes name=gt_nm dbname="gt_nm" )
 column=(type=char(30) updatewhereclause=yes name=gtime dbname="gtime" )
 column=(type=decimal(1) updatewhereclause=yes name=btime dbname="btime" )
 column=(type=decimal(1) updatewhereclause=yes name=etime dbname="etime" )
 column=(type=decimal(1) updatewhereclause=yes name=ntime dbname="ntime" )
 column=(type=decimal(1) updatewhereclause=yes name=dtime dbname="dtime" )
 column=(type=decimal(0) updatewhereclause=yes name=hday dbname="hday" )
 column=(type=decimal(0) updatewhereclause=yes name=yday dbname="yday" )
 column=(type=char(80) updatewhereclause=yes name=rem dbname="rem" )
 retrieve="SELECT name_kor        = a.name_kor         
     , team_nm         = c.team_nm
     , gt_dt           = a.gt_dt            
     , gt_nm           = b.gt_nm            
     
     , gtime           = b.gtime            
     , btime           = a.btime            
     , etime           = a.etime            
     , ntime           = a.ntime            
     , dtime           = a.dtime            
     , hday            = a.hday             
     , yday            = a.yday             
     , rem             = a.rem              
  FROM ycerp.dbo.gt_info A
       LEFT OUTER JOIN ycerp.dbo.gt_item   B ON a.acc_cd = b.acc_cd AND a.gt_cd    = b.gt_cd
       LEFT OUTER JOIN ycerp.dbo.insa_base C ON a.acc_cd = c.acc_cd AND a.jumin_no = c.jumin_no AND retire_yn <> 'Y'
 WHERE ( a.acc_cd      = :as_com )
   AND ((:as_team  = '%' AND c.team_nm LIKE :as_team) OR
        (:as_team <> '%' AND c.team_nm    = :as_team)
       )
   AND ((:as_gtcd  = '%' AND a.gt_cd   LIKE :as_gtcd) OR
        (:as_gtcd <> '%' AND a.gt_cd      = :as_gtcd)
       )
   AND ( a.gt_dt     between :as_sdate AND :as_edate )
" arguments=(("as_com", string),("as_team", string),("as_gtcd", string),("as_sdate", string),("as_edate", string))  sort="team_nm A name_kor A " )
