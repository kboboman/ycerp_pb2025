 column=(type=char(20) updatewhereclause=yes name=fcollect_day dbname="fcollect_day" )
 column=(type=char(4) updatewhereclause=yes name=tcust_no dbname="tcust_no" )
 column=(type=char(50) updatewhereclause=yes name=tcust_name dbname="tcust_name" )
 column=(type=char(11) updatewhereclause=yes name=tspot_code dbname="tspot_code" )
 column=(type=char(40) updatewhereclause=yes name=tspot_name dbname="tspot_name" )
 column=(type=char(14) updatewhereclause=yes name=tregister_no dbname="tregister_no" )
 column=(type=char(20) updatewhereclause=yes name=tresident_card dbname="tresident_card" )
 column=(type=char(80) updatewhereclause=yes name=taddr dbname="taddr" )
 column=(type=char(1) updatewhereclause=yes name=tlevel_grade dbname="tlevel_grade" )
 column=(type=char(20) updatewhereclause=yes name=tcaptain_name dbname="tcaptain_name" )
 column=(type=decimal(0) updatewhereclause=yes name=tunpaid_amt dbname="tunpaid_amt" )
 column=(type=char(20) updatewhereclause=yes name=tcollect_day dbname="tcollect_day" )
 retrieve="  SELECT trans_no         = a.trans_no
		 , trans_amt     = a.trans_amt
		 , bigo          = a.bigo
		 , fcust_no      = a.fcust_no
		 , fcust_name    = b.cust_name
		 , fspot_code    = a.fspot_code
		 , fspot_name    = d.scene_desc
		 , fregister_no  = a.fregister_no
		 , fresident_card= b.resident_card
		 , faddr         = b.addr
		 , flevel_grade  = a.flevel_grade
		 , fcaptain_name = a.fcaptain_name
		 , funpaid_amt   = a.funpaid_amt
		 , fcollect_day  = a.fcollect_day
		 , tcust_no      = a.tcust_no
		 , tcust_name    = c.cust_name
		 , tspot_code    = a.tspot_code
		 , tspot_name    = e.scene_desc
		 , tregister_no  = a.tregister_no
		 , tresident_card= c.resident_card
		 , taddr         = c.addr
		 , tlevel_grade  = a.tlevel_grade
		 , tcaptain_name = a.tcaptain_name
		 , tunpaid_amt   = a.tunpaid_amt
		 , tcollect_day  = a.tcollect_day
	 FROM dotrans A
			LEFT OUTER JOIN customer B  ON A.fcust_no  = B.cust_no
			LEFT OUTER JOIN customer C  ON A.tcust_no  = C.cust_no
			LEFT OUTER JOIN scene    D  ON A.fcust_no  = D.cust_no  AND A.fspot_code = D.scene_code
			LEFT OUTER JOIN scene    E  ON A.tcust_no  = E.cust_no  AND A.tspot_code = E.scene_code
	WHERE a.trans_no = :as_trans_no

" arguments=(("as_trans_no", string)) )
