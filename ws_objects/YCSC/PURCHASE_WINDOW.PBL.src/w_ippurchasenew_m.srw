event clicked;if dw12.rowcount() < 1 then return

long ll_row
string ls_order, ls_filter

dw10.Setredraw(false)
if this.checked = true then

	dw10.retrieve('%')
	
	ls_order = 'non'  
	ls_filter = "coilsliting_order_no = '" + ls_order + "'"
	dw10.SetFilter(ls_filter)
	dw10.Filter( )
	dw10.Setredraw(true)
else
	
	ll_row = wf_rowfocuschange(dw12,'N')
	if ll_row < 1 then return
	
	ls_order = trim(dw12.object.coilorderdet_order_no[ll_row])
	ls_filter = ""
	dw10.SetFilter(ls_filter)
	dw10.Filter( )
	dw10.retrieve(ls_order)
	dw10.Setredraw(true)
end if
end event

type pb_5 from picturebutton within w_ippurchasenew_m
integer x = 2693
integer y = 52
integer width = 704
integer height = 144
integer taborder = 40
boolean bringtotop = true
integer textsize = -10
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "발주서내역으로 이동"
vtextalign vtextalign = vcenter!
end type

event clicked;// 물품이동
long   ll_cnt, ll_rowcount,i
string ls_today, ls_plan, ls_like, ls_maxplan, ls_order, ls_assy, ls_supp
dwItemStatus l_status

ib_move  = false
l_status = dw_1.GetItemStatus(1,0, Primary!)
if l_status = new! or l_status = newModified! then
else
	pb_insert.triggerevent(clicked!)
end if

ls_supp = trim(dw_1.object.supp_no[1])
if isnull(ls_supp) or ls_supp = "" then
	MessageBox("오류","거래처를 입력하십시오.", Exclamation!)
	dw_1.setcolumn('supp_no')
	dw_1.setfocus()
	return
end if	

choose case tab_1.SelectedTab
	case 7	// 외주스리팅/SHEET가공
		dw3.dataobject = "d_ippurdet2"	// 발주서내역
		dw3.settransobject(sqlca)

	case else
      if ib_auto = true then		// 자동처리시 dw3.reset() 방지
		else
			dw3.dataobject = "d_ippurdet"		// 발주서내역
			dw3.settransobject(sqlca)
		end if
end choose

dw_1.object.subcon.protect   = true
tab_1.tabpage_1.pb_3.enabled = true
tab_1.tabpage_1.pb_4.enabled = true
choose case tab_1.SelectedTab
	case 1	// 발주서내역
		
	case 2	// 외주가공내역
		if wf_move2() = false then
			dw3.reset()
			dw_1.object.subcon.protect = false
			return
		else
			dw4.selectrow(0,false)
		end if
		
	case 3	// 외주구매내역
		if wf_move3() = false then
			dw3.reset()
			dw5.RowsMove( 1, dw5.filteredcount(), Filter!, dw5, 1, Primary! )
			dw_1.object.subcon.protect = false
			return
		else
			dw5.selectrow(0,false)
		end if
		
	case 4	//	수주내역
		dw_1.object.subcon[1] = "N"
		if wf_move4() = false then
			dw3.reset()
			dw6.RowsMove( 1, dw6.filteredcount(), Filter!, dw6, 1, Primary! )
			dw_1.object.subcon.protect = false
			return
		else
			dw6.selectrow(0,false)
		end if
		
		// 현장주소, 연락처 복사하기
		string ls_shipto_addr, ls_tel_no
		if tab_1.tabpage_4.em_3.text <> "" then
			SELECT rtrim(shipto_addr), rtrim(tel_no) INTO :ls_shipto_addr, :ls_tel_no
			  FROM SALE
			 WHERE order_no    = :tab_1.tabpage_4.em_3.text;
			if isnull(ls_shipto_addr) then
			else
         	dw_1.object.cham[dw_1.getrow()] = "** 택배 발송해 주세요 **~n주소: " + ls_shipto_addr + "~n현장연락처: " + ls_tel_no
			end if
		end if
		
	case 5	// 부속자재내역
		dw_1.object.subcon[1] = "N"
		dw_1.object.subcon.protect = false
		if wf_move5() = false then
			dw3.reset()
			dw7.RowsMove ( 1, dw7.filteredcount(), Filter!, dw7, 1, Primary! )
			return
		else
			dw7.selectrow(0,false)
		end if
		
	case 6	// 자재가공내역
		ll_rowcount = dw8.rowcount()
		
		ls_today    = string(today(),'yymmdd')
		ls_plan     = 'P' + ls_today 
		ls_like     = ls_plan + '%'
		SELECT max(order_no) INTO :ls_maxplan FROM jajaesudo WHERE order_no LIKE :ls_like;
		if isnull(ls_maxplan) then
		 	ll_cnt = 1
		else
		 	ll_cnt = long(MidA(ls_maxplan,8,3)) + 1
		end if
		
		for i = 1 to ll_rowcount
			if dw8.isselected(i) then	
				ls_assy  = dw8.object.assy_item[i]
				l_status = dw8.GetItemStatus(i,0, Primary!)
				if l_status = newmodified! then
					ls_order = ls_plan + RightA('000' + string(ll_cnt),3)
					ll_cnt ++
					dw8.object.order_no[i] = ls_order
				end if
			end if
		next

		if wf_update1(dw8,"N") = true then		
			if wf_move6() = false then
				dw_1.object.subcon.protect = false
				dw3.reset()
				return
			else
				dw8.selectrow(0,false)
			end if
		else
			dw_1.object.subcon.protect = false
			dw3.reset()
			return
		end if
		
	case 7	// 외주스리팅/SHEET가공
		if tab_1.tabpage_7.cbx_2.checked = false then
			MessageBox("오류","선택 항목을 체크하시기 바랍니다.", Exclamation!)
			return
		end if
		if dw10.rowcount() < 1 then return
		
		if wf_move7() = false then
			dw3.reset()
			dw12.RowsMove( 1, dw12.filteredcount(), Filter!, dw12, 1, Primary! )
			dw_1.object.subcon.protect = false
			return
		else
			tab_1.tabpage_1.pb_3.enabled = false
			tab_1.tabpage_1.pb_4.enabled = false

			dw12.selectrow(0,false)
		end if
end choose

// 수주물품별 재고현황(NEW) 가져오기
if ib_auto = true then
else
	tab_1.selecttab(1)
end if

ib_move = true		// 물품이동 정상


end event

