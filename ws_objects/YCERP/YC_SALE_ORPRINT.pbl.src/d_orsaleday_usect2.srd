release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=4 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no  crosstab.dynamic = yes grid.lines=0 grid.columnmove=no selected.mouse=no )
header[1](height=0 color="536870912" )
header[2](height=72 color="536870912" )
header[3](height=72 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=number updatewhereclause=yes name=calc_amt dbname="calc_amt" )
 retrieve="  SELECT user_name   = a.user_name
       , item_name   = a.item_name   
       , category    = a.category
       , gtype       = a.gtype
       , due_date    = a.order_date + (case when :as_yymm = 'Y' then a.order_dates else '(' + a.order_dates + ')' end)
       , inside      = a.inside
       , calc_amt    = a.calc_amt / 1000
    FROM (
         SELECT user_name   = l.user_name
              , cust_name   = c.cust_name   
              , item_name   = g.item_name   
              , category    = (SELECT item_nm  FROM codemst with (nolock) WHERE type = 'ITEMTOP10' AND use_yn = 'Y' AND item_cd = i.category)
              , gtype       = i.type       
              , inside      = (case when v.cust_no IS NULL then '1.일반영업' else '2.계열사' end)
              , order_date  = (case when :as_yymm = 'Y' then convert(char(04),sale.order_date,111)
                                    else convert(char(08),sale.order_date,11)
                               end)
              , order_dates = replace((case when :as_yymm = 'Y' 
                                            then '.' + (case when datepart(month,sale.order_date) < 10 
                                                             then '0'+cast(datepart(month,sale.order_date) as char(2))
                                                             else cast(datepart(month,sale.order_date) as char(2))
                                                        end)+'월'
                                            else (case when datepart(dw,sale.order_date) = 1 then '일'
                                                       when datepart(dw,sale.order_date) = 2 then '월'
                                                       when datepart(dw,sale.order_date) = 3 then '화'
                                                       when datepart(dw,sale.order_date) = 4 then '수'
                                                       when datepart(dw,sale.order_date) = 5 then '목'
                                                       when datepart(dw,sale.order_date) = 6 then '금'
                                                       when datepart(dw,sale.order_date) = 7 then '토'
                                                  end)
                                       end),' ','')
              , calc_qty    = dbo.uf_getqty(saledet.item_no, saledet.qa, saledet.uom, saledet.order_qty)
              , calc_amt    = dbo.uf_getqty(saledet.item_no, saledet.qa, saledet.uom, saledet.order_qty) * saledet.price
           FROM sale   with (nolock)
                LEFT OUTER JOIN saledet     with (nolock) ON sale.order_no   = saledet.order_no 
                LEFT OUTER JOIN groupitem_use GU with (nolock) ON gu.item_no = saledet.item_no
                LEFT OUTER JOIN customer  C with (nolock) ON sale.cust_no    = c.cust_no
                LEFT OUTER JOIN login     L with (nolock) ON c.salesman    = l.user_id
                LEFT OUTER JOIN v_cust_inside  V          ON sale.cust_no    = v.cust_no
                LEFT OUTER JOIN groupitem G with (nolock) ON saledet.item_no = g.item_no 
                LEFT OUTER JOIN itemtop10 i with (nolock) ON saledet.item_no = i.item_no    
          WHERE ( sale.order_date   BETWEEN :ad_sdate AND :ad_edate )
            AND ((:as_usename   = '%') OR
                 (:as_usename  <> '%' AND gu.use_name = :as_usename)
                )
	       AND ( ISNULL(sale.confirm_flag,'N') = 'Y' )
         ) A
" arguments=(("as_usename", string),("ad_sdate", date),("ad_edate", date),("as_yymm", string))  sort="item_name A " )
