 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"itemmove~" ) COLUMN(NAME=~"itemmove.move_no~") COLUMN(NAME=~"itemmove.move_date~") COLUMN(NAME=~"itemmove.src_loc~") COLUMN(NAME=~"itemmove.tar_loc~") COLUMN(NAME=~"itemmove.log_id~") COLUMN(NAME=~"itemmove.log_date~") COLUMN(NAME=~"itemmove.flag~") COLUMN(NAME=~"itemmove.pre_move_no~")WHERE(    EXP1 =~"itemmove.move_no~"   OP =~"=~"    EXP2 =~":as_no~" ) ) ARG(NAME = ~"as_no~" TYPE = string) " update="itemmove" updatewhere=1 updatekeyinplace=no arguments=(("as_no", string)) )
