 column=(type=decimal(2) updatewhereclause=yes name=ship_qty dbname="dodet.ship_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=price dbname="dodet.price" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="dodet.uom" )
 column=(type=decimal(4) updatewhereclause=yes name=dodet_rate_cash dbname="dodet.rate_cash" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene.scene_desc" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(20) updatewhereclause=yes name=customer_captain_name dbname="customer.captain_name" )
 column=(type=char(60) updatewhereclause=yes name=do_rem dbname="do.rem" )
 column=(type=char(20) updatewhereclause=yes name=do_tel_no dbname="do.tel_no" )
 column=(type=char(3) updatewhereclause=yes name=do_curr_code dbname="do.curr_code" )
 column=(type=char(1) updatewhereclause=yes name=round dbname="customer.round" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="dodet.item_no" )
 column=(type=decimal(0) updatewhereclause=yes name=ship_amount dbname="do.ship_amount" )
 column=(type=char(1) updatewhereclause=yes name=ship_flag dbname="do.ship_flag" )
 column=(type=char(1) updatewhereclause=yes name=shipamt_case dbname="do.shipamt_case" )
 column=(type=char(14) updatewhereclause=yes name=dodet_sale_no dbname="dodet.sale_no" )
 column=(type=long updatewhereclause=yes name=dodet_seq_no dbname="dodet.seq_no" )
 column=(type=char(13) updatewhereclause=yes name=do_dr_hp dbname="do.dr_hp" )
 column=(type=datetime updatewhereclause=yes name=pdate dbname="pdate" )
 column=(type=char(1) updatewhereclause=yes name=c_chk dbname="c_chk" )
 column=(type=char(30) updatewhereclause=yes name=c_sno dbname="c_sno" )
 column=(type=char(30) updatewhereclause=yes name=c_sh dbname="c_sh" )
 column=(type=char(20) updatewhereclause=yes name=c_nm dbname="c_nm" )
 column=(type=char(40) updatewhereclause=yes name=c_js dbname="c_js" )
 retrieve="  SELECT do.do_no,   
         do.do_date,   
         do.shipto_addr,   
         do.do_cash,   
         do.do_rate,   
         do.do_total,   
         do.dr_hp,   
         dodet.oi_no,   
         dodet.qa,   
         dodet.ship_qty,   
         dodet.price,   
         dodet.uom,   
         dodet.rate_cash,   
         groupitem.item_name,   
         scene.scene_desc,   
         customer.cust_name,   
         customer.captain_name,   
         do.rem,   
         do.tel_no,   
         do.curr_code,   
         customer.round,   
         dodet.item_no,   
         do.ship_amount,   
         do.ship_flag,   
         do.shipamt_case,
         dodet.sale_no,
         dodet.seq_no,
			do.dr_hp,
			(case when
				(case when (select max(sfc_date) 
								from sfcday
								where sale_no = dodet.sale_no
								and seq_no =  dodet.seq_no) is null 
				then (select isnull(max(insp_date), convert(datetime, '3000-12-31'))
						from insp, inspdet, purdet
						where insp.insp_no = inspdet.insp_no
						and purdet.order_no = inspdet.pur_no
						and purdet.seq_no = inspdet.seq_no
						and purdet.sale_no = dodet.sale_no
						and purdet.sale_seq =  dodet.seq_no)
				end) > do.do_date
			then do.do_date
			end) as pdate,
			c_chk = :as_c_chk,
         c_sno = :as_sno,
         c_sh = :as_sh,
         c_nm = :as_nm,
         c_js = :as_js
    FROM do,   
         dodet,   
         customer,   
         scene,
         groupitem
   WHERE ( do.do_no = dodet.do_no ) and  
         ( do.cust_no = customer.cust_no) and  
         ( do.cust_no *= scene.cust_no) and  
         ( do.spot_code *= scene.scene_code ) and  
         ( dodet.item_no = groupitem.item_no ) and  
         ( ( do.do_no = :as_do_no ) )     
" arguments=(("as_do_no", string),("as_c_chk", string),("as_sno", string),("as_sh", string),("as_nm", string),("as_js", string))  sort="do_do_no A dodet_oi_no A " )
