text(band=header alignment="2" text="인맥수" border="0" color="0" x="1774" y="4" height="80" width="242" html.valueishtml="0"  name=yc_count_t visible="1"  font.face="굴림체" font.height="-11" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="15780518" )
