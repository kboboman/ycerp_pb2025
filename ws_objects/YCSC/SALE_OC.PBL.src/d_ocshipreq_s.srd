$PBExportHeader$d_ocshipreq_s.srd
$PBExportComments$운반비변경요청관리 (2002/08/28,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=doship_no dbname="doship.doship_no" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="doship.user_id" )
 column=(type=datetime updatewhereclause=yes name=doship_date dbname="doship.doship_date" )
 column=(type=char(1) updatewhereclause=yes name=process_flag dbname="doship.process_flag" values="미결	O/완결	Y/마감	C/" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"doship~" ) COLUMN(NAME=~"doship.doship_no~") COLUMN(NAME=~"doship.user_id~") COLUMN(NAME=~"doship.doship_date~") COLUMN(NAME=~"doship.process_flag~")WHERE(    EXP1 =~"doship.doship_date~"   OP =~"between~"    EXP2 =~":as_start and :as_end~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"doship.process_flag~"   OP =~"like~"    EXP2 =~":as_flag~" ) ) ARG(NAME = ~"as_start~" TYPE = date)  ARG(NAME = ~"as_end~" TYPE = date)  ARG(NAME = ~"as_flag~" TYPE = string) " arguments=(("as_start", date),("as_end", date),("as_flag", string)) )
