	if li_rc = 1 then
	else
		MessageBox("확인", "물품별 소계 계산중 오류가 발생 했습니다.[" + ls_sort + "]")
	end if
else
	MessageBox("확인", "물품별 소계 정렬중 오류가 발생 했습니다.[" + ls_sort + "]")
end if

