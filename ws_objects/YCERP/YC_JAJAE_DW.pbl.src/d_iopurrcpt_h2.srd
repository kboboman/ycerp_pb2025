$PBExportHeader$d_iopurrcpt_h2.srd
$PBExportComments$자재입고관리 구매일보(1999/06/01, 이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=104 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=88 color="536870912" )
table(column=(type=char(1) updatewhereclause=yes name=insp_insp_flag dbname="insp.insp_flag" )
 column=(type=char(30) updatewhereclause=yes name=supp_supp_name dbname="supp.supp_name" )
 column=(type=char(10) updatewhereclause=yes name=groupitem_item_group dbname="groupitem.item_group" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=datetime updatewhereclause=yes name=insp_date dbname="insp.insp_date" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="inspdet.qa" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="inspdet.uom" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=rcpt_qty dbname="inspdet.rcpt_qty" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=price dbname="inspdet.price" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=rate_cash dbname="inspdet.rate_cash" )
 column=(type=char(50) update=yes updatewhereclause=yes name=rem dbname="inspdet.rem" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=comqty dbname="inspdet.comqty" )
 column=(type=char(14) update=yes updatewhereclause=yes key=yes name=inspdet_insp_no dbname="inspdet.insp_no" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=inspdet_oi_no dbname="inspdet.oi_no" )
 column=(type=char(2) update=yes updatewhereclause=yes name=inspdet_com_uom dbname="inspdet.com_uom" )
 column=(type=char(1) updatewhereclause=yes name=supp_round dbname="supp.round" )
 retrieve="  SELECT insp.insp_flag,   
         supp.supp_name,   
         groupitem.item_group,   
         groupitem.item_name,   
         insp.insp_date,   
         inspdet.qa,   
         inspdet.uom,   
         inspdet.rcpt_qty,   
         inspdet.price,   
         inspdet.rate_cash,   
         inspdet.rem,   
         inspdet.comqty,   
         inspdet.insp_no,   
         inspdet.oi_no,   
         inspdet.com_uom,
			supp.round  
    FROM supp,   
         groupitem,   
         insp,   
         inspdet  
   WHERE ( insp.insp_no = inspdet.insp_no ) and  
         ( insp.supp_no = supp.supp_no ) and  
         ( inspdet.item_no = groupitem.item_no ) and  
         ( ( insp.insp_flag = :arg_flag ) AND  
         ( insp.log_date = :arg_date ) )     AND  
         ( ( inspdet.pur_no like :as_area + ~"%~" ) or
			  ( :as_area = ~"S~" and inspdet.pur_no like ~"PUR%~")) and
			( :as_sel = ~"A~" or ( :as_sel = ~"C~" and inspdet.coil_no is not null ) 
								 or ( :as_sel = ~"Y~" and inspdet.coil_no is null ) )

" update="inspdet" updatewhere=0 updatekeyinplace=no arguments=(("arg_flag", string),("arg_date", date),("as_area", string),("as_sel", string))  sort="supp_supp_name A inspdet_insp_no A inspdet_oi_no A groupitem_item_name A qa A " )
