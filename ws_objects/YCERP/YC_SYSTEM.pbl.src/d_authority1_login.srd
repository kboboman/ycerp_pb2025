 retrieve="  SELECT authority1.user_id,   
         authority1.group_id,   
         authority1.use_type  
    FROM authority1  
   WHERE ( authority1.user_id = :arg_userid ) AND  
         ( authority1.group_id = :arg_groupid )    
" update="authority1" updatewhere=0 updatekeyinplace=no arguments=(("arg_userid", string),("arg_groupid", string)) )
