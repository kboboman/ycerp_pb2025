$PBExportComments$견적서 선택(1998/03/26, 정재수)
release 8;
datawindow(units=0 timer_interval=0 color=79219928 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=72 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=estimate_no dbname="estimate_no" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(60) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(11) updatewhereclause=yes name=scene_code dbname="scene_code" )
 column=(type=char(60) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=char(30) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(1) updatewhereclause=yes name=esti_flag dbname="esti_flag" values="완결	Y/미결	N/보류	B/" )
 column=(type=datetime updatewhereclause=yes name=estimate_date dbname="estimate_date" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 retrieve="  SELECT distinct a.estimate_no
       , a.cust_no
       , a.cust_name 
       , a.scene_code
       , a.scene_desc 
       , b.item_name
       , a.esti_flag
       , a.estimate_date
       , c.user_name
    FROM UF_MyCustomers( :as_salesman )  M
         LEFT OUTER JOIN estimate_head A ON m.cust_no   = a.cust_no
         LEFT OUTER JOIN basis_head    B ON a.system_no = b.item_no AND b.use_flag = 'Y'
         LEFT OUTER JOIN login         C ON a.user_id   = c.user_id
   WHERE ( estimate_date BETWEEN :as_sdate AND :as_edate ) 
     AND ((:as_team    = '%'   AND m.cust_no   LIKE '%'  ) OR 
          (:as_team   <> '%'   AND m.salesman     = :as_salesman )
         )
     AND ((:as_custno  = '%'   AND m.cust_no   LIKE '%'  ) OR 
          (:as_custno  = 'ALL' AND m.cust_no   LIKE '%'  ) OR 
          (:as_custno <> 'ALL' AND m.cust_no      = :as_custno )
         )
     AND ( esti_flag  LIKE :as_flag   )
" arguments=(("as_salesman", string),("as_sdate", string),("as_edate", string),("as_custno", string),("as_team", string),("as_flag", string))  sort="estimate_no D " )
