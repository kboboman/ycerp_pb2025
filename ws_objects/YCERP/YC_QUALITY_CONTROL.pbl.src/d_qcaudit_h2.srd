$PBExportComments$성형 중간검사 성적서(성형)(2005/05/23, 이인호)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=88 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=coil_no dbname="sfcuse.coil_no" )
 column=(type=long updatewhereclause=yes name=cnt dbname="sfcuse.cnt" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="sfcuse.qa" )
 column=(type=datetime updatewhereclause=yes name=sfcuse_use_date dbname="sfcuse.use_date" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(10) updatewhereclause=yes name=sfcuse_item_no dbname="sfcuse.item_no" )
 retrieve="  SELECT sfcuse.coil_no,   
         sfcuse.cnt,   
         sfcuse.qa,   
         sfcuse.use_date,   
         groupitem.item_name,   
         sfcuse.item_no  
    FROM sfcuse,   
         groupitem,
			itemcoil  
   WHERE ( sfcuse.item_no = groupitem.item_no ) and  
         ( ( sfcuse.area_no = :as_area ) AND  
         ( sfcuse.wc_no = :as_wc ) AND  
         ( sfcuse.use_date = :ad_date ) AND  
         ( itemcoil.item_no = :as_item ) AND  
         ( substring(itemcoil.qa, 1, 13) in ( :as_qa ) ) and
			( itemcoil.coil_item = sfcuse.item_no ) and
			( itemcoil.width = case when substring(sfcuse.qa, 10, 1) <> ~"0~"
											then convert(dec(5,1),rtrim(convert(char(4), convert(integer,substring(sfcuse.qa, 5, 4)))) + ~".~" + substring(sfcuse.qa, 10, 1) )
											else convert(dec(5,1),substring(sfcuse.qa, 5, 4) + ~".0~") end )
			) " arguments=(("as_area", string),("as_wc", string),("ad_date", date),("as_item", string),("as_qa", stringlist))  sort="sfcuse_use_date A " )
group(level=1 header.height=0 trailer.height=0 by=("sfcuse_use_date" ) header.color="536870912" trailer.color="536870912" )
