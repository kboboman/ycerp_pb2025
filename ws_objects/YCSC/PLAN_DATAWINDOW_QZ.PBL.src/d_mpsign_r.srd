 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"mps~" )  TABLE(NAME=~"mpsdet~" )  TABLE(NAME=~"groupitem~" ) COLUMN(NAME=~"mpsdet.plan_no~") COLUMN(NAME=~"mpsdet.order_no~") COLUMN(NAME=~"mpsdet.wc_no~") COLUMN(NAME=~"mpsdet.sale_no~") COLUMN(NAME=~"mpsdet.seq_no~") COLUMN(NAME=~"mpsdet.item_no~") COLUMN(NAME=~"mpsdet.qa~") COLUMN(NAME=~"mpsdet.due_date~") COLUMN(NAME=~"mpsdet.uom~") COLUMN(NAME=~"mpsdet.order_qty~") COLUMN(NAME=~"mpsdet.priority~") COLUMN(NAME=~"mpsdet.suju_type~") COLUMN(NAME=~"mpsdet.work_time~") COLUMN(NAME=~"mpsdet.setup_time~") COLUMN(NAME=~"mpsdet.rcpt_type~") COLUMN(NAME=~"mpsdet.rcpt_qty~") COLUMN(NAME=~"mpsdet.napgi_date~") COLUMN(NAME=~"mpsdet.cust_no~") COLUMN(NAME=~"mpsdet.scene_code~") COLUMN(NAME=~"mpsdet.item_color~") COLUMN(NAME=~"mpsdet.work_per~") COLUMN(NAME=~"mpsdet.division~") COLUMN(NAME=~"groupitem.item_name~") COLUMN(NAME=~"mps.wc_no~") COLUMN(NAME=~"mps.start_date~")    JOIN (LEFT=~"mps.order_no~"    OP =~"=~"RIGHT=~"mpsdet.order_no~" )    JOIN (LEFT=~"mpsdet.item_no~"    OP =~"=~"RIGHT=~"groupitem.item_no~" )WHERE(    EXP1 =~"mps.order_no~"   OP =~"=~"    EXP2 =~":arg_order~" ) ) ARG(NAME = ~"arg_order~" TYPE = string) " arguments=(("arg_order", string)) )
