type cb_2 from commandbutton within tabpage_2
integer x = 2679
integer y = 572
integer width = 146
integer height = 76
integer taborder = 60
integer textsize = -10
integer weight = 400
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "필터"
end type

event clicked;String ls_custnm, ls_column, ls_value, ls_temp

ls_temp = ""
if dw6.FilteredCount() > 0 THEN
	dw6.setfilter(ls_temp)
	dw6.filter()
end if

// 필드
if trim(ddlb_col1.text) = "" then
	ls_column = ""
else
	String ls_col
	choose case trim(ddlb_col1.text)
		case "선택"
			ls_col = "chk "
		case "수주번호"
			ls_col = "sale_no "
		case "순번"
			ls_col = "seq "
		case "수주품목"
			ls_col = "item_name "
		case "수주규격"
			ls_col = "qa "
		case "색상"
			ls_col = "color "

		case "도면번호"
			ls_col = "b1_drawno "
		case "폭1"
			ls_col = "b1_qa1 "			
		case "폭2"
			ls_col = "b1_qa2 "
		case "길이1"
			ls_col = "b1_qa3 "
		case "길이2"
			ls_col = "b1_qa4 "
		case "신청수량"
			ls_col = "qty "
		case "폭"
			ls_col = "b1_qa1 "			
		case "길이"
			ls_col = "b1_qa2 "
		case "레퍼런스1"
			ls_col = "b1_qa3 "
		case "레퍼런스2"
			ls_col = "b1_qa4 "
		case "칼수"
			ls_col = "b1_cuts "
		case "절곡(비고)"
			ls_col = "b1_rem "
		case "프로그램NO"
			ls_col = "b1_pgmno "
		case "TYPE"
			ls_col = "b1_type "

		case "도장(폭)"
			ls_col = "p1_qa1 "
		case "도장(길이)"
			ls_col = "p1_qa2 "
		case "도장(면)"
			ls_col = "p1_face "
		case "도장(비고)"
			ls_col = "p1_rem "
		case "대체색상"
			ls_col = "p1_refcolor"
		case "도장(번호)"
			ls_col = "p1_keyno"
	end choose		

	if trim(ddlb_4.text) = "LIKE" then
		ls_column = ls_col + trim(ddlb_4.text) + " '%" + trim(sle_value1.text) + "%' "
	else
		choose case ls_col
			case "work_date ", "napgi_date "
				ls_column = ls_col + trim(ddlb_4.text) + "datetime('" + trim(sle_value1.text) + "') "
			case "seq_no ", "qty ", "b1_qa1 ", "b1_qa2 ", "b1_qa3 ", "b1_qa4 ", "b1_qa5 ", "b1_qa6 ", "b1_qa7 ", "b1_qa8 ", "p1_qa1 ", "p1_qa2 ", "p1_face " 
				ls_column = ls_col + trim(ddlb_4.text) + " "  + trim(sle_value1.text) + " "
			case else
				ls_column = ls_col + trim(ddlb_4.text) + " '" + trim(sle_value1.text) + "' "
		end choose 
	end if
end if

if ls_column = "" then
	ls_temp = ls_column
else
	ls_temp = "(" + ls_column + ")"
end if

if ls_value <> "" then
	if ls_temp = "" then
		ls_temp = ls_value
	else
		ls_temp = "(" + ls_temp + ") AND (" + trim(ls_value) + ")"
	end if
end if

dw6.setfilter(ls_temp)
dw6.filter()

dw6.scrolltorow(1)


end event

