table(column=(type=long updatewhereclause=yes name=syscolumns_colid dbname="syscolumns.colid" )
 column=(type=char(255) updatewhereclause=yes name=syscolumns_name dbname="syscolumns.name" )
 column=(type=char(254) updatewhereclause=yes name=pbcatcol_pbc_cmnt dbname="pbcatcol.pbc_cmnt" )
 column=(type=char(255) updatewhereclause=yes name=cdatatype dbname="cdatatype" )
 column=(type=char(255) updatewhereclause=yes name=systypes_name dbname="systypes.name" )
 column=(type=long updatewhereclause=yes name=syscolumns_prec dbname="syscolumns.prec" )
 column=(type=long updatewhereclause=yes name=syscolumns_scale dbname="syscolumns.scale" )
 column=(type=char(1) updatewhereclause=yes name=cnull dbname="cnull" )
 column=(type=char(2) updatewhereclause=yes name=pk dbname="pk" )
 column=(type=char(255) updatewhereclause=yes name=sysobjects_name dbname="sysobjects.name" )
 column=(type=char(254) updatewhereclause=yes name=pbcattbl_pbt_cmnt dbname="pbcattbl.pbt_cmnt" )
 column=(type=long updatewhereclause=yes name=syscolumns_status dbname="syscolumns.status" )
 column=(type=long updatewhereclause=yes name=syscolumns_type dbname="syscolumns.type" )
 retrieve="  SELECT dbo.syscolumns.colid 
       , dbo.syscolumns.name  
       , dbo.pbcatcol.pbc_cmnt
       , cdatatype = (CASE WHEN right( dbo.systypes.name , 1) <> 'n' THEN dbo.systypes.name
                               ELSE left(  dbo.systypes.name , LEN( dbo.systypes.name ) - 1 )
                                END)
       , dbo.systypes.name    
       , dbo.syscolumns.prec  
       , dbo.syscolumns.scale 
       , cnull     = (CASE WHEN dbo.syscolumns.status = 0 OR dbo.syscolumns.status = 16 THEN 'N' ELSE 'Y' END)
       , pk        = dbo.uf_gettablepk(dbo.syscolumns.id, dbo.syscolumns.colid)
       , dbo.sysobjects.name  
       , dbo.pbcattbl.pbt_cmnt
       , dbo.syscolumns.status
       , dbo.syscolumns.type  
    FROM dbo.syscolumns  
         LEFT OUTER JOIN dbo.systypes    ON dbo.syscolumns.xusertype = dbo.systypes.xusertype
         LEFT OUTER JOIN dbo.sysobjects  ON dbo.syscolumns.id        = dbo.sysobjects.id     /* AND dbo.systypes.uid  = dbo.sysobjects.uid*/
         LEFT OUTER JOIN dbo.pbcatcol    ON dbo.syscolumns.name      = dbo.pbcatcol.pbc_cnam  AND dbo.sysobjects.name = dbo.pbcatcol.pbc_tnam
         LEFT OUTER JOIN dbo.pbcattbl    ON dbo.sysobjects.name      = dbo.pbcattbl.pbt_tnam
   WHERE /* dbo.systypes.usertype      <> 18
     AND dbo.systypes.usertype       < 100
     AND */ dbo.sysobjects.name         = :as_tname
   ORDER BY dbo.syscolumns.colid
" arguments=(("as_tname", string))  sort="sysobjects_name A syscolumns_colid A " )
