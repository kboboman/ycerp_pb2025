 retrieve="  SELECT DISTINCT basis_head.item_no,   
         basis_head.item_name  
    FROM basis_head  
	where use_flag = 'Y'
ORDER BY basis_head.item_no ASC   
" update="basis_head" updatewhere=0 updatekeyinplace=no )
