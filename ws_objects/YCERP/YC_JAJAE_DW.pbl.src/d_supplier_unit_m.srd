detail(height=368 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=supp_no dbname="supplier_unit.supp_no" )
 column=(type=char(30) updatewhereclause=yes name=supp_supp_name dbname="supp.supp_name" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=ver dbname="supplier_unit.ver" )
 column=(type=char(6) update=yes updatewhereclause=yes name=yyyymm dbname="supplier_unit.yyyymm" )
 column=(type=char(1) update=yes updatewhereclause=yes name=use_yn dbname="supplier_unit.use_yn" values="사용	Y/종료	N/" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=insang_value dbname="supplier_unit.insang_value" )
 column=(type=char(8) update=yes updatewhereclause=yes name=write_date dbname="supplier_unit.write_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=write_user_id dbname="supplier_unit.write_user_id" )
 column=(type=char(1) update=yes updatewhereclause=yes name=insang_gubun dbname="supplier_unit.insang_gubun" values="(%)	1/금액	2/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=half_gubun dbname="supplier_unit.half_gubun" values="반영	Y/미반영	N/" )
 retrieve="  SELECT     supplier_unit.supp_no,   
			     supp.supp_name,
				supplier_unit.ver,   
				supplier_unit.yyyymm,   
				supplier_unit.use_yn,   
			     supplier_unit.insang_value,   
				supplier_unit.write_date,   
				supplier_unit.write_user_id,
                     supplier_unit.insang_gubun,
     			     supplier_unit.half_gubun    
    FROM supplier_unit inner join supp on supplier_unit.supp_no = supp.supp_no
where   supplier_unit.supp_no = :as_supp_no
    and   supplier_unit.ver = :as_ver
" update="supplier_unit" updatewhere=0 updatekeyinplace=no arguments=(("as_supp_no", string),("as_ver", number)) )
