$PBExportHeader$d_orsamp_s.srd
$PBExportComments$샘플번호선택(2003/08/20,정갑용)
release 8;
datawindow(units=0 timer_interval=0 color=79219928 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=72 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=samp_no dbname="samp.samp_no" )
 column=(type=datetime updatewhereclause=yes name=order_date dbname="samp.order_date" )
 column=(type=char(4) updatewhereclause=yes name=samp_cust_no dbname="samp.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 retrieve="  SELECT samp.samp_no
       , samp.order_date  
       , samp.cust_no
       , customer.cust_name
    FROM samp left outer join customer on samp.cust_no = customer.cust_no
    where  ( samp.order_date between :ad_sorder_date and :ad_eorder_date )   
   ORDER BY samp.order_date DESC   
" arguments=(("ad_sorder_date", date),("ad_eorder_date", date)) )
