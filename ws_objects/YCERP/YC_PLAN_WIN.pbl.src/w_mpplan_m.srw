type cb_7 from commandbutton within w_mpplan_m
integer x = 4014
integer y = 400
integer width = 160
integer height = 76
integer taborder = 90
boolean bringtotop = true
integer textsize = -9
integer weight = 400
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "필터"
end type

event clicked;//
DataWindow arg_dw

if cbx_wcno.checked = false then
	choose case IS_DW
		case "dw_1"
			arg_dw  = dw_1
		case "dw_2"
			arg_dw  = dw_2
		case "dw_4"
			arg_dw  = tab_1.tabpage_3.dw_4
		case "dw_6"
			arg_dw  = tab_1.tabpage_4.dw_6
		case "dw_11"
			arg_dw  = dw_11
	end choose
	GF_DW2Filter(arg_dw, ddlb_fld, ddlb_op, sle_value, ddlb_dwtitles)
else
	if IS_DW <> "dw_6" then RETURN
	
	string ls_custnm, ls_column, ls_value, ls_temp, ls_col, ls_wcno
	
	//ls_temp = ""
//	  ls_temp = "open_close = 'O'" 
	 
//	if dw6.FilteredCount() > 0 THEN
//		dw6.SetFilter(ls_temp)
//		dw6.Filter()
//	end if
	
	// 필드
	if trim(ddlb_fld.text) = "" then
		ls_column = ""
	else
		choose case trim(ddlb_fld.text)
			case "작업장"
				ls_col = "wc_no "
			case "수주물품"
				ls_col = "item_name1 "
			case "규격"
				ls_col = "qa "
			case "예정일자"
				ls_col = "work_date "
			case "생산납기일자"
				ls_col = "make_napgi_date "				
			case "납기일자"
				ls_col = "napgi_date "
				
			case "주문량"
				ls_col = "order_qty "
			case "계획량"
				ls_col = "plan_qty "
			case "환산수량"
				ls_col = "obj_24092413 "
			case "출고량"
				ls_col = "dodet_ship_qty "
				
			case "분할"
				ls_col = "division "
			case "색상"
				ls_col = "color_name "
			case "거래처"
				ls_col = "customer_cust_name "
				
			case "현장"
				ls_col = "scene_scene_desc "
			case "진행"
				ls_col = "process_flag "
			case "순위"
				ls_col = "operation "
			case "수주번호"
				ls_col = "sale_no "
			case "순번"
				ls_col = "seq_no "
			case "비고"
				ls_col = "routtempnew_rem "
		end choose		
	
		if trim(ddlb_op.text) = "LIKE" then
			ls_column = ls_col + trim(ddlb_op.text) + " '%" + trim(sle_value.text) + "%' "
		else
			choose case ls_col
				case "work_date ", "napgi_date ", "make_napgi_date"
					ls_column = ls_col + trim(ddlb_op.text) + "datetime('" + trim(sle_value.text) + "') "
				case "order_qty ", "plan_qty ", "obj_24092413 ", "dodet_ship_qty ", "division ", "operation ", "seq_no "
					ls_column = ls_col + trim(ddlb_op.text) + " "  + trim(sle_value.text) + " "
				case else
					ls_column = ls_col + trim(ddlb_op.text) + " '" + trim(sle_value.text) + "' "
			end choose 
		end if
	end if
	
	if ls_column = "" then
		ls_temp = ls_column
	else
		ls_temp = "(" + ls_column + ")"
	end if
	
	if ls_value <> "" then
		if ls_temp = "" then
			ls_temp = ls_value
		else
			ls_temp = "(" + ls_temp + ") AND (" + trim(ls_value) + ")"
		end if
	end if
	

	// 작업장 체크
	ls_wcno = trim(tab_1.tabpage_4.dw_7.object.wc_no[1])
	if isnull(ls_wcno) OR ls_wcno = "" then
	else
		if RightA(ls_wcno,2) = "00" then
			ls_wcno = LeftA(ls_wcno,1)
//			ls_temp = "( wc_no LIKE '" + ls_wcno + "') AND " + ls_temp
			ls_temp = "( wc_no LIKE '" + ls_wcno + "') AND " + ls_temp
		else
//			ls_temp = "( wc_no    = '" + ls_wcno + "') AND " + ls_temp
			ls_temp = "( wc_no    = '" + ls_wcno + "') AND " + ls_temp									
		end if
	end if
	
	dw6.setfilter(ls_temp + " AND (open_close = 'O')")
	dw6.filter()
	
	dw6.scrolltorow(1)
end if

end event

type cb_8 from commandbutton within w_mpplan_m
integer x = 4178
integer y = 400
integer width = 160
integer height = 76
integer taborder = 100
boolean bringtotop = true
integer textsize = -9
integer weight = 400
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "해지"
end type

event clicked;//
DataWindow arg_dw

if cbx_wcno.checked = false then
	choose case IS_DW
		case "dw_1"
			arg_dw  = dw_1
		case "dw_2"
			arg_dw  = dw_2
		case "dw_4"
			arg_dw  = tab_1.tabpage_3.dw_4
		case "dw_6"
			arg_dw  = tab_1.tabpage_4.dw_6
		case "dw_11"
			arg_dw  = dw_11
	end choose
	GF_DW2UnFilter( arg_dw )
else
	// 
	string ls_wc, ls_where
	long   ll_row
	
	ddlb_op.text    = "LIKE"
	ddlb_fld.text   = "현장명"
	sle_value.text  = ""
	
	ls_wc = tab_1.tabpage_4.dw_7.object.wc_no[1]
	if isnull(ls_wc) OR trim(ls_wc) = "" then
		dw6.setredraw(false)
//		dw6.setfilter("")
		dw6.setfilter("open_close = 'O'")

		dw6.filter()
		
		pb_save.PostEvent(clicked!)
		dw6.scrolltorow(1)
		dw6.setredraw(true)	
	else	
		ls_wc = trim(ls_wc) + "%"
		if MidA(ls_wc,2,2) = '00' then
			ls_wc    = MidA(ls_wc,1,1) + "%"
//			ls_where = "wc_no LIKE '" + ls_wc + "'"
			ls_where = "(wc_no LIKE '" + ls_wc + "') AND (open_close = 'O')"
		else
//			ls_where = "wc_no LIKE '" + ls_wc + "'"
			ls_where = "(wc_no LIKE '" + ls_wc + "') AND (open_close = 'O')"
		end if
			
		//
		dw6.SetFilter( ls_where )
		dw6.Filter()
		
		// 작업장별 수주품목이 없으면 품목별소계 DISABLE
		ll_row = dw6.RowCount()
		if ll_row > 0 then
			pb_compute.enabled = true
		else
			pb_compute.enabled = false
		end if
	end if
end if

end event

