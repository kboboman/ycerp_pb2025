table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=area_no dbname="area.area_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=area_name dbname="area.area_name" )
 column=(type=char(60) update=yes updatewhereclause=yes name=addr dbname="area.addr" )
 column=(type=char(60) update=yes updatewhereclause=yes name=tel_fax dbname="area.tel_fax" )
 column=(type=char(10) update=yes updatewhereclause=yes name=def_loc dbname="area.def_loc" )
 column=(type=char(1) update=yes updatewhereclause=yes name=real_area dbname="area.real_area" values="	Y/	N" )
 column=(type=char(10) update=yes updatewhereclause=yes name=issue_accept_user dbname="area.issue_accept_user" )
 retrieve="  SELECT area.area_no,   
         area.area_name,   
         area.addr,   
         area.tel_fax,   
         area.def_loc,   
         area.real_area,   
         area.issue_accept_user  
    FROM area   
" update="area" updatewhere=1 updatekeyinplace=no )
