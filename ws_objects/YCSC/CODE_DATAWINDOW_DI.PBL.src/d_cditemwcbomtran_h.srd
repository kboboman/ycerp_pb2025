 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=assembly dbname="bomtran.assembly" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=assy_qa dbname="bomtran.assy_qa" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=parent_no dbname="bomtran.parent_no" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=component dbname="bomtran.component" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=comp_qa dbname="bomtran.comp_qa" )
 column=(type=long update=yes updatewhereclause=yes name=sequence dbname="bomtran.sequence" )
 column=(type=decimal(5) update=yes updatewhereclause=yes name=qpa dbname="bomtran.qpa" )
 column=(type=datetime update=yes updatewhereclause=yes name=effectivity dbname="bomtran.effectivity" )
 column=(type=datetime update=yes updatewhereclause=yes name=obsolete dbname="bomtran.obsolete" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=yield dbname="bomtran.yield" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=bom_no dbname="bomtran.bom_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=dirty_flag dbname="bomtran.dirty_flag" )
 column=(type=char(60) updatewhereclause=yes name=item_item_name dbname="groupitem.item_name" )
 retrieve="  SELECT DISTINCT bomtran.item_no,   
         bomtran.qa,   
         bomtran.assembly,   
         bomtran.assy_qa,   
         bomtran.parent_no,   
         bomtran.component,   
         bomtran.comp_qa,   
         bomtran.sequence,   
         bomtran.qpa,   
         bomtran.effectivity,   
         bomtran.obsolete,   
         bomtran.yield,   
         bomtran.bom_no,   
         bomtran.dirty_flag,   
         groupitem.item_name  
    FROM bomtran,   
         groupitem  
   WHERE ( bomtran.component = groupitem.item_no ) and  
         ( ( bomtran.item_no = :as_itemno ) AND  
         ( bomtran.qa = :as_qa ) )    
" update="bomtran" updatewhere=0 updatekeyinplace=no arguments=(("as_itemno", string),("as_qa", string))  sort="parent_no D bom_no D " )
