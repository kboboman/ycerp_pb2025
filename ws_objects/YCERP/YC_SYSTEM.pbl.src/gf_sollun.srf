// 2041
lv_s_ltbl[161] = "2112122122120"
lv_s_ltbl[162] = "1231212122212"
lv_s_ltbl[163] = "1211211221220"

lv_s_yuk[1]    = "갑"
lv_s_yuk[2]    = "을"
lv_s_yuk[3]    = "병"
lv_s_yuk[4]    = "정"
lv_s_yuk[5]    = "무"
lv_s_yuk[6]    = "기"
lv_s_yuk[7]    = "경"
lv_s_yuk[8]    = "신"
lv_s_yuk[9]    = "임"
lv_s_yuk[10]   = "계"

lv_s_gap[1]    = "자"
lv_s_gap[2]    = "축"
lv_s_gap[3]    = "인"
lv_s_gap[4]    = "묘"
lv_s_gap[5]    = "진"
lv_s_gap[6]    = "사"
lv_s_gap[7]    = "오"
lv_s_gap[8]    = "미"
lv_s_gap[9]    = "신"
lv_s_gap[10]   = "유"
lv_s_gap[11]   = "술"
lv_s_gap[12]   = "해"

lv_s_week[1]   = "일"
lv_s_week[2]   = "월"
lv_s_week[3]   = "화"
lv_s_week[4]   = "수"
lv_s_week[5]   = "목"
lv_s_week[6]   = "금"
lv_s_week[7]   = "토"

lv_l_day_per_month[1]  = 31
lv_l_day_per_month[2]  = 0
lv_l_day_per_month[3]  = 31
lv_l_day_per_month[4]  = 30
lv_l_day_per_month[5]  = 31
lv_l_day_per_month[6]  = 30
lv_l_day_per_month[7]  = 31
lv_l_day_per_month[8]  = 31
lv_l_day_per_month[9]  = 30
lv_l_day_per_month[10] = 31
lv_l_day_per_month[11] = 30
lv_l_day_per_month[12] = 31


lv_l_total_day = 0

if NOT IsDate(as_date) then
	MessageBox("오류", "날짜의 입력이 잘못되었습니다.", StopSign!)
	RETURN -1
end if
 
lv_l_in_year  = long(LeftA(as_date, 4))
lv_l_in_month = long(MidA(as_date, 5, 2))
lv_l_in_day   = long(RightA(as_date, 2))

if lv_l_in_year < 1881 OR lv_l_in_year > 2043 then
	MessageBox("오류", "계산할 수 없는 날짜입니다.", StopSign!)
	RETURN -1
end if

for i = 1 to 163
	lv_l_dt[i] = 0
	
	for j = 1 to 12
		choose case MidA(lv_s_ltbl[i], j, 1)
			case "1" , "3"
				lv_l_dt[i] = lv_l_dt[i] + 29
			case "2" , "4"
				lv_l_dt[i] = lv_l_dt[i] + 30
		end choose
	next
        
	choose case MidA(lv_s_ltbl[i], 13, 1)
		case "0"
		case "1" , "3"
			lv_l_dt[i] = lv_l_dt[i] + 29
		case "2" , "4"
			lv_l_dt[i] = lv_l_dt[i] + 30
	end choose
next

// 1880년 1월 30일까지의 총일수
lv_l_total_day1 = 1880 * 365 + 1880 / 4 - 1880 / 100 + 1880 / 400 + 30
lv_l_k11        = lv_l_in_year - 1

// 입력된 년도 1년전까지의 총일수
lv_l_total_day2 = lv_l_k11 * 365 + lv_l_k11 / 4 - lv_l_k11 / 100 + lv_l_k11 / 400
    
if Mod(lv_l_in_year, 400) = 0 OR Mod(lv_l_in_year, 100) <> 0 AND Mod(lv_l_in_year, 4) = 0 then
	lv_l_day_per_month[2] = 29
else
	lv_l_day_per_month[2] = 28
end if
    
for i = 1 to lv_l_in_month - 1
	lv_l_total_day2 = lv_l_total_day2 + lv_l_day_per_month[i]
next

// 입력된 일자까지의 총일수
lv_l_total_day2 = lv_l_total_day2 + lv_l_in_day

// 1880-01-30 부터 현재까지의 총일수
lv_l_total_day  = lv_l_total_day2 - lv_l_total_day1 // + 1

// 1881년부터 현재까지의 총일수와 Table상의 숫자(음력)들의 합을 비교 반복
lv_l_total_day0 = lv_l_dt[1]
for i = 1 to 163
	if lv_l_total_day <= lv_l_total_day0 then EXIT
	
	lv_l_total_day0 = lv_l_total_day0 + lv_l_dt[i + 1]
Next

// 음력년도
lv_l_lun_year = i + 1880

as_lun_date = as_lun_date + String(lv_l_lun_year, "0000")

// 현재년도의 음력일수 감산
lv_l_total_day0 = lv_l_total_day0 - lv_l_dt[i]

// 양력 총일수에서 음력 총일수 감산 
lv_l_total_day  = lv_l_total_day - lv_l_total_day0
    
if MidA(lv_s_ltbl[i], 13, 1) = "0" then
	lv_l_count = 12
else
	lv_l_count = 13
end if

m2 = 0
for j = 1 to lv_l_count
	if MidA(lv_s_ltbl[i], j, 1) <= "2" then
		m2 ++
		m1 = Long(MidA(lv_s_ltbl[i], j, 1)) + 28
	else
		m1 = Long(MidA(lv_s_ltbl[i], j, 1)) + 26
	end if

	if lv_l_total_day <= m1 then EXIT
	
	lv_l_total_day = lv_l_total_day - m1
Next

// 요일(양력)
as_week = lv_s_week[daynumber(Date(String(as_date, "@@@@-@@-@@")))]
// 음력일자
as_lun_date = as_lun_date + String(m2, "00") + String(lv_l_total_day, "00")

// 윤달 여부 판단
if (MidA(lv_s_ltbl[lv_l_lun_year - 1880], 13, 1) <> "0" AND MidA(lv_s_ltbl[lv_l_lun_year - 1880], j, 1) > "2" ) then
	ab_yundal = TRUE
else
	ab_yundal = FALSE
end if

// 육십갑자
as_year60 = lv_s_yuk[Mod(lv_l_lun_year   + 7, 10)] + lv_s_gap[Mod(lv_l_lun_year   + 9, 12)]
as_day60  = ''  // lv_s_yuk[Mod(lv_l_total_day2 + 5, 10)] + lv_s_gap[Mod(lv_l_total_day2 + 3, 12)]

RETURN 1

end function

