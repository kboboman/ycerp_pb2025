table(column=(type=decimal(0) updatewhereclause=yes name=bill_amount dbname="glbill.bill_amount" )
 column=(type=datetime updatewhereclause=yes name=close_date dbname="glbill.close_date" )
 column=(type=datetime updatewhereclause=yes name=start_date dbname="glbill.start_date" )
 column=(type=char(6) updatewhereclause=yes name=bank_code dbname="glbill.bank_code" )
 column=(type=char(20) updatewhereclause=yes name=bill_area dbname="glbill.bill_area" )
 column=(type=char(12) updatewhereclause=yes name=vc_no dbname="glbill.vc_no" )
 column=(type=char(20) updatewhereclause=yes name=draft dbname="glbill.draft" )
 column=(type=char(12) updatewhereclause=yes name=bill_no dbname="glbill.bill_no" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"glbill~" ) COLUMN(NAME=~"glbill.bill_amount~") COLUMN(NAME=~"glbill.close_date~") COLUMN(NAME=~"glbill.start_date~") COLUMN(NAME=~"glbill.bank_code~") COLUMN(NAME=~"glbill.bill_area~") COLUMN(NAME=~"glbill.vc_no~") COLUMN(NAME=~"glbill.draft~") COLUMN(NAME=~"glbill.bill_no~")WHERE(    EXP1 =~"glbill.bill_class~"   OP =~"=~"    EXP2 =~"'R'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"glbill.set_flag~"   OP =~"=~"    EXP2 =~"'N'~" ) ) " )
column(band=detail id=8 alignment="0" tabsequence=32766 border="0" color="0" x="9" y="4" height="60" width="384" format="[general]"  name=bill_no  tag="어음번호" edit.limit=10 edit.case=any edit.autoselect=yes edit.autohscroll=yes  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
