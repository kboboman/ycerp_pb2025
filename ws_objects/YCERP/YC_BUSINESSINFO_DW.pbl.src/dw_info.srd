table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=build_no dbname="bdinfo.build_no" )
 column=(type=datetime update=yes updatewhereclause=yes name=create_date dbname="bdinfo.create_date" )
 column=(type=char(20) update=yes updatewhereclause=yes name=rem dbname="bdinfo.rem" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"bdinfo~" ) COLUMN(NAME=~"bdinfo.build_no~") COLUMN(NAME=~"bdinfo.create_date~") COLUMN(NAME=~"bdinfo.rem~")) " update="bdinfo" updatewhere=1 updatekeyinplace=no )
