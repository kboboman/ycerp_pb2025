$PBExportComments$판매매출관리 DETAIL(1998/04/13, 정재수)
release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=152 color="536870912" )
summary(height=0 color="79741120" )
footer(height=76 color="8421504" )
detail(height=168 color="536870912" )
table(column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=char(14) updatewhereclause=yes key=yes name=do_no dbname="dodet.do_no" )
 column=(type=long updatewhereclause=yes key=yes name=oi_no dbname="dodet.oi_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="dodet.seq_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="dodet.item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="dodet.qa" )
 column=(type=decimal(2) updatewhereclause=yes name=ship_qty dbname="dodet.ship_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=price dbname="dodet.price" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=aroi_qty dbname="dodet.aroi_qty" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="dodet.uom" )
 column=(type=char(14) updatewhereclause=yes name=sale_no dbname="dodet.sale_no" )
 column=(type=long updatewhereclause=yes name=vat dbname="rate_cash" )
 column=(type=char(50) updatewhereclause=yes name=rem dbname="dodet.rem" )
 column=(type=long updatewhereclause=yes name=price_a dbname="price_a" )
 column=(type=decimal(2) updatewhereclause=yes name=a_qty dbname="a_qty" initial="0" )
 column=(type=char(1) updatewhereclause=yes name=pick dbname="pick" initial="N" values="	Y/	N" )
 column=(type=decimal(3) updatewhereclause=yes name=a_price dbname="a_price" initial="0" )
 column=(type=long updatewhereclause=yes name=c_an dbname="c_an" initial="0" )
 column=(type=char(3) updatewhereclause=yes name=do_curr_code dbname="do.curr_code" )
 column=(type=char(1) updatewhereclause=yes name=sale_tax_sign dbname="sale.tax_sign" )
 column=(type=char(1) updatewhereclause=yes name=round dbname="customer.round" )
 retrieve="  SELECT cust_name  = customer.cust_name
       , scene_desc = scene.scene_desc
       , dodet.do_no
       , dodet.oi_no
       , dodet.seq_no
       , dodet.item_no
       , item_name = groupitem.item_name
       , dodet.qa
       , dodet.ship_qty
       , dodet.price
       , dodet.aroi_qty
       , dodet.uom
       , dodet.sale_no
       , rate_cash  = 0
       , dodet.rem
       , price_a    = 0 /*item.price_a*/
       , a_qty      = 0000000.00 
       , pick       = 'N' 
       , a_price    = 0000000.000 
       , c_an       = 00 
       , do.curr_code
       , sale.tax_sign
       , customer.round  
    FROM dodet WITH(NOLOCK) INNER JOIN do WITH(NOLOCK) ON dodet.do_no     = do.do_no
                                                        LEFT OUTER JOIN sale WITH(NOLOCK) ON dodet.sale_no = sale.order_no
                                                        LEFT OUTER JOIN CUSTOMER WITH(NOLOCK) ON do.cust_no  = customer.cust_no
                                                        LEFT OUTER JOIN groupitem WITH(NOLOCK) ON dodet.item_no  = groupitem.item_no
                                                        LEFT OUTER JOIN SCENE WITH(NOLOCK) ON do.CUST_NO = scene.CUST_NO AND do.spot_code = scene.scene_code
     WHERE ((do.cust_no      = :as_cust_no ) AND  
          (do.do_date   BETWEEN :ad_sdate AND  :ad_edate  ) AND  
          (dodet.ship_qty <> dodet.aroi_qty ) AND  
          (do.sale_flag    = :as_sale_flag  ) 
         )   
/*
    FROM dodet
       , do
       , sale
       , customer  
       , scene  
       , groupitem
   WHERE ( dodet.do_no     = do.do_no ) 
     and ( dodet.sale_no  *= sale.order_no) 
     and ( do.cust_no     *= customer.cust_no ) 
     and ( do.spot_code   *= scene.scene_code ) 
     and ( dodet.item_no  *= groupitem.item_no ) 
     and ((do.cust_no      = :as_cust_no ) AND  
          (do.do_date     >= :ad_sdate   ) AND  
          (do.do_date     <= :ad_edate   ) AND  
          (dodet.ship_qty <> dodet.aroi_qty ) AND  
          (do.sale_flag    = :as_sale_flag  ) 
         )   
*/
/*
  SELECT dodet.do_no,   
         dodet.oi_no,   
         dodet.seq_no,   
         dodet.item_no,   
         dodet.qa,   
         dodet.ship_qty,   
         dodet.price,   
         dodet.aroi_qty,   
         dodet.uom,   
         dodet.sale_no,   
         rate_cash = 0,   
         dodet.rem,   
         item.price_a,   
         item.item_name,   
         0000000.00 a_qty,   
         'N' pick,   
         0000000.000 a_price,   
         00 c_an,   
         do.curr_code,   
         sale.tax_sign,   
         customer.round  
    FROM dodet,   
         item,   
         do,   
         sale,   
         customer  
   WHERE ( dodet.sale_no *= sale.order_no) and  
         ( dodet.item_no *= item.item_no ) and  
         ( dodet.qa      *= item.qa ) and  
         ( dodet.do_no    = do.do_no ) and  
         ( do.cust_no     = customer.cust_no ) and  
         ( ( do.cust_no   = :as_cust_no ) AND  
           ( do.do_date  >= :ad_sdate ) AND  
           ( do.do_date  <= :ad_edate ) AND  
           ( dodet.ship_qty <> dodet.aroi_qty ) AND  
           ( do.sale_flag = :as_sale_flag ) 
         )    
*/
" update="dodet" updatewhere=0 updatekeyinplace=yes arguments=(("as_cust_no", string),("ad_sdate", date),("ad_edate", date),("as_sale_flag", string))  sort="do_no A oi_no A " )
