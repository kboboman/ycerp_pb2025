 column=(type=char(10) update=yes updatewhereclause=yes name=wc_no dbname="pattern.wc_no" )
 column=(type=char(100) update=yes updatewhereclause=yes name=bigo dbname="pattern.bigo" )
 retrieve="  SELECT pattern.pat_no,   
         pattern.seq_no,   
         pattern.wc_no , 
         pattern.bigo    
    FROM pattern   
" update="pattern" updatewhere=1 updatekeyinplace=no  sort="pat_no A seq_no A " )
