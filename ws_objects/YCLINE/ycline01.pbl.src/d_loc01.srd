$PBExportHeader$d_loc01.srd
$PBExportComments$저장소 조회
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=84 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(30) updatewhereclause=yes name=loc_name dbname="location.loc_name" )
 column=(type=char(10) updatewhereclause=yes key=yes name=loc_no dbname="location.loc_no" )
 column=(type=char(1) updatewhereclause=yes name=loc_type dbname="location.loc_type" )
 retrieve="  SELECT location.loc_name
       , location.loc_no
       , location.loc_type
    FROM location  with(nolock)
   WHERE ('C' = :as_type AND (substring(:as_wcno,1,1) = 'F' AND ( loc_no LIKE 'F%' OR loc_no LIKE 'H%' ) AND
                                                                loc_no NOT LIKE 'F9%' AND
                                                                loc_no     LIKE 'F%'  AND
                                                                loc_no NOT IN ( 'F09', 'F00' )
                             )
         ) 
      OR ('C'  = :as_type AND (substring(:as_wcno,1,1) = 'Y' AND loc_no = 'WW04' ) )	/* YSP원재료  */
      OR ('S'  = :as_type AND (substring(:as_wcno,1,1) = 'Y' AND loc_no = 'WW04' ) )	/* YSP원재료  */
      OR ('C'  = :as_type AND (substring(:as_wcno,1,1) = 'B' AND loc_no = 'WW02' ) )	/* 절곡원재료 */
      OR ('S'  = :as_type AND (substring(:as_wcno,1,1) = 'B' AND loc_no = 'WW02' ) )	/* 절곡원재료 */
      OR ('S'  = :as_type AND (substring(:as_wcno,1,1) = 'U' AND loc_no = 'WW03' ) )   /* 유압원재료 */
      OR ('SC' = :as_type AND (substring(:as_wcno,1,1) = 'U' AND loc_no = 'WW03' ) )   /* 유압원재료 */
" update="location" updatewhere=0 updatekeyinplace=no arguments=(("as_wcno", string),("as_type", string))  sort="loc_type A loc_no A " )
text(band=header alignment="2" text="저장소명" border="6" color="33554432" x="411" y="8" height="68" width="503" html.valueishtml="0"  name=loc_name_t visible="1"  font.face="굴림체" font.height="-11" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="67108864" )
