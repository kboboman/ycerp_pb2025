release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=132 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=100 color="536870912" )
table(column=(type=char(12) updatewhereclause=yes name=gubun dbname="gubun" )
 column=(type=char(10) updatewhereclause=yes name=l_loc_no dbname="issuereq.loc_no" )
 column=(type=char(10) updatewhereclause=yes name=accept_user dbname="issuereq.accept_user" )
 column=(type=char(10) updatewhereclause=yes name=accept_user_name dbname="issuereq.accept_user_name" )
 column=(type=char(10) updatewhereclause=yes name=salesman dbname="issuereq.salesman" )
 column=(type=char(10) updatewhereclause=yes name=salesman_name dbname="issuereq.salesman_name" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="issuereq.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="issuereq.scene_desc" )
 column=(type=long updatewhereclause=yes name=req_seq dbname="issuereq.req_seq" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="issuereq.item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="issuereq.item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="issuereq.qa" )
 column=(type=char(14) updatewhereclause=yes name=order_no dbname="issuereq.order_no" )
 column=(type=decimal(2) updatewhereclause=yes name=issue_qty dbname="issue_qty" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="issuereq.seq_no" )
 column=(type=decimal(2) updatewhereclause=yes name=order_qty dbname="issuereq.order_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=rlse_qty dbname="issuereq.rlse_qty" )
 column=(type=char(160) updatewhereclause=yes name=sale_rem dbname="sale_rem" )
 column=(type=char(10) updatewhereclause=yes name=issue_schedule_name dbname="issue_schedule_name" )
 retrieve="			 SELECT  '출고의뢰예정' gubun,
			              		l.loc_no,
                         a.accept_user,
                         j.user_name accept_user_name,
                       b.salesman salesman
                     , f.USER_NAME salesman_name
                     , d.cust_name cust_name
                     , e.scene_desc scene_desc
                     , a.req_seq req_seq
			               , c.item_no item_no
                     , g.item_name item_name           
		            	     , c.qa qa
                     , C.ORDER_NO order_no
			              	,  ISNULL(c.issue_qty,0) issue_qty
                     , c.seq_no seq_no
                     , h.order_qty order_qty
                     , h.rlse_qty rlse_qty
                     , rtrim(i.rem) + rtrim(i.rem1) sale_rem
				, (case b.issue_schedule                                      
							when 'A' then '직출'                                   
							when 'B' then '생산후직출'                             
							when 'C' then '자동작성'                               
							when 'D' then '방문'                                   
							when 'E' then '외주(시화)'                             
							when 'F' then '외주(본사)'                             
							when 'G' then '유창강건'                               
							when 'H' then '지점이송'                               
							when 'I' then '야간도착'                               
							when 'J' then '저녁상차'                               
							when 'K' then '택배/정기'                              
							else           ''                                      
					 end) issue_schedule_name
			 FROM issuereq   A WITH (NOLOCK)
			  LEFT OUTER JOIN issuereqdet   B WITH (NOLOCK) ON a.req_date  = b.req_date AND a.salesman = b.salesman AND a.req_seq = b.req_seq
			  LEFT OUTER JOIN issuereqdet_sale c with(nolock) on b.req_date = c.req_date and b.salesman = c.salesman and b.req_seq = c.req_seq and  b.seq = c.seq
			  LEFT OUTER JOIN saledet   h WITH (NOLOCK) ON c.order_no    = h.order_no and c.seq_no = h.seq_no
			  LEFT OUTER JOIN sale     i WITH (NOLOCK) ON b.sale_no    = i.order_no
			  LEFT OUTER JOIN location L WITH (NOLOCK) ON a.accept_user = l.loc_manager
			  LEFT OUTER JOIN login     f WITH (NOLOCK) ON b.salesman   = f.user_id
		       LEFT OUTER JOIN login     j WITH (NOLOCK) ON a.accept_user   = j.user_id
			  LEFT OUTER JOIN customer  D WITH (NOLOCK) ON b.cust_no    = d.cust_no
			  LEFT OUTER JOIN scene     E WITH (NOLOCK) ON b.scene_code = e.scene_code
			  LEFT OUTER JOIN groupitem G WITH (NOLOCK) ON c.item_no    = g.item_no
			 where a.req_date BETWEEN convert(datetime,  :as_reqdate +' 00:00:00' ) and convert(datetime,  :as_reqdate + ' 23:59:59' )
				 AND ( c.item_no    is not null     )
                      AND ( isnull(h.order_qty,0) - isnull(h.rlse_qty,0) > 0 )
				 AND ( b.req_flag    = 'A'              ) /* 출고의뢰 */
				 AND ( a.confirm_flag= 'Y'           ) /* 확정     */		
                      AND   C.ITEM_NO = :as_item_no
                      AND   C.QA = :as_qa
				 AND NOT EXISTS (
                                                                 SELECT * 
                                                                  FROM
                                                                (
                                                                            SELECT  B.SALE_NO, B.SEQ_NO, SUM(B.SHIP_QTY) SALE_QTY
                                                                            FROM DO A WITH(NOLOCK) INNER JOIN DODET B WITH(NOLOCK) ON A.DO_NO = B.DO_NO
                                                                            WHERE A.DO_DATE BETWEEN convert(datetime,  :as_reqdate +' 00:00:00' ) and convert(datetime,  :as_reqdate + ' 23:59:59' )
                                                                                    AND B.ITEM_NO = :as_item_no
                                                                                    AND B.QA = :as_qa                                                                  
                                                                            GROUP BY B.SALE_NO, B.SEQ_NO
                                                                  ) A
                                                                  WHERE A.SALE_NO = C.ORDER_NO
                                                                  AND        A.SEQ_NO = c.seq_no
                                                    )					
				 AND isnull( l.loc_no, (  case when a.accept_area = 'B0001'    then 'WS00000006'
																										  when a.accept_area = 'H0001'    then 'WS00000007'
																										  when a.accept_area = 'S0001'    then 'WS00000000'
																										  when a.accept_area = 'T0001'    then 'WS00000008'
																										  when a.accept_area = 'Z0001'    then 'WS00000011'
																										  else 'WS99999999'
																								  end
																								)
											)	LIKE :as_locno
		union all
		SELECT '물품출고예정' gubun
				                 ,  ask_det.loc_no loc_no
                        , ask_head.act_user accept_user
                        , l.user_name accept_user_name
                        , ask_head.ask_user
                         , j.user_name ask_head_user_name
                         , ask_head.f_area cust_name
                         , ''  scene_desc
                         , 0 req_seq
    			         , ask_det.item_no item_no
                         , groupitem.item_name item_name           
    			         , ask_det.qa qa
                         , ask_det.sale_no  order_no
    			                , isnull(ask_det.ask_qty,0)  - isnull(ask_det.rlse_qty,0) issue_qty
                         , 0 seq_no
                         , ask_det.ask_qty order_qty
                         , ask_det.rlse_qty rlse_qty
                         , '' sale_rem
                         , '' issue_schedule_name
				  FROM ask_det   WITH (NOLOCK)  
				    LEFT OUTER JOIN ask_head  WITH (NOLOCK) ON ask_det.ask_no = ask_head.ask_no
                         LEFT OUTER JOIN login l  WITH (NOLOCK) ON ask_head.act_user = l.user_id
                         LEFT OUTER JOIN login j  WITH (NOLOCK) ON ask_head.ask_user = j.user_id
                          LEFT OUTER JOIN groupitem  WITH (NOLOCK) ON ask_det.item_no   = groupitem.item_no
				 WHERE ( convert(char(10), ask_head.ask_date, 112) =  :as_reqdate )
					 AND ( ask_det.loc_no LIKE :as_locno )
					AND ( ask_head.proc_flag <> 'Y' )  /* 완료(Y), 부분(P), 요청(N) */ 
					AND ( ask_det.rlse_flag   = 'N'  ) /* 완료(Y), 진행(N) */
					AND ( ask_det.loc_no = (case when ask_head.f_area = 'T0001' then 'WS00000008' 
																											 when ask_head.f_area = 'S0001' then 'WS00000000' 
														  else  'WS99999999' 
													end)
							 ) 
					AND  ask_det.item_no = :as_item_no
    			           AND ask_det.qa =  :as_qa   
		union all
	SELECT   '수주출고예정' gubun,
                                        ISNULL( l.loc_no,     ( case when a.area_no = 'B0001'    then 'WS00000006'
                                                        																				 when a.area_no = 'H0001'    then 'WS00000007'
                                                        																				 when a.area_no = 'S0001'    then 'WS00000000'
                                                        																				 when a.area_no = 'T0001'    then 'WS00000008'
                                                        																				 when a.area_no = 'Z0001'    then 'WS00000011'
                                                        																				 else 'WS99999999'
                                                        																				end )
												)  loc
                      ,  a.org_user
                      , m.user_name  
                      , a.salesman
                      , n.user_name salesman_user_name
				 , c.cust_name cust_name
                      , ''  scene_desc
                      , 0 req_seq
											,  b.item_no
                      , i.item_name
				 ,  qa             = b.qa
                         , a.order_no  order_no
    			                , isnull(b.order_qty,0) - isnull(b.rlse_qty,0) issue_qty
                         , 0 seq_no
                         , b.order_qty
                         , b.rlse_qty
                         , '' sale_rem
                         , '' issue_schedule_name
									FROM sale   A WITH (NOLOCK)
										  	   INNER JOIN saledet  B WITH (NOLOCK) ON a.order_no = b.order_no
										  	   LEFT OUTER JOIN location L WITH (NOLOCK) ON a.org_user = l.loc_manager
                           LEFT OUTER JOIN login m  with(nolock) on  a.org_user = m.user_id
                           LEFT OUTER JOIN login n  with(nolock) on  a.salesman = n.user_id
                           LEFT OUTER JOIN groupitem i  with(nolock) on  b.item_no = i.item_no
					 LEFT OUTER JOIN customer c with(nolock) on a.cust_no = c.cust_no 
								  WHERE ( convert(char(10), a.order_date, 112) =  :as_reqdate )
									  AND  ISNULL( l.loc_no,     ( case when a.area_no = 'B0001'    then 'WS00000006'
																								 when a.area_no = 'H0001'    then 'WS00000007'
																								 when a.area_no = 'S0001'    then 'WS00000000'
																								 when a.area_no = 'T0001'    then 'WS00000008'
																								 when a.area_no = 'Z0001'    then 'WS00000011'
																								 else 'WS99999999'
																								end )
																) LIKE :as_locno
					         AND  b.item_no = :as_item_no
    			         AND b.qa =  :as_qa    
									 AND ( a.do_reserved = 'Y'              ) /* 출고예정 */      " arguments=(("as_locno", string),("as_reqdate", string),("as_item_no", string),("as_qa", string))  sort="gubun A salesman_name A req_seq A order_no A cust_name A scene_desc A " )
