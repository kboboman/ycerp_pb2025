$PBExportHeader$d_personal_r.srd
$PBExportComments$부자재 리스트(수주관련)
release 8;
datawindow(units=0 timer_interval=0 color=134217750 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="553648127" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=104 color="536870912" )
table(column=(type=decimal(0) updatewhereclause=yes name=personal_id dbname="personal_id" )
 column=(type=char(20) updatewhereclause=yes name=name dbname="name" )
 column=(type=char(50) updatewhereclause=yes name=company dbname="company" )
 column=(type=long updatewhereclause=yes name=bogo_personal_connection_det_yc_count dbname="yc_count" )
 retrieve="select distinct a.personal_id,
				  a.name,
				  a.company,
				  a.yc_count
from 
(
      select  bogo_personal_connection.gubun,
                  bogo_personal_connection.personal_id,
                  bogo_personal_connection.name, 
                  case when bogo_personal_connection.kind = '01' then sale_bogo_code.code_name else bogo_personal_connection.company end  company,
      		        bogo_personal_connection_det.yc_count, 
                  b.yc_user_id
      from bogo_personal_connection with(nolock) left outer join sale_bogo_code with(nolock) on bogo_personal_connection.company_code = sale_bogo_code.code
      												   left outer join bogo_personal_connection_det b with(nolock) on bogo_personal_connection.personal_id = b.personal_id
            										 left outer join	(
                                        																		select gubun, personal_id, count(*) yc_count
                                        																		from bogo_personal_connection_det with(nolock)
                                        																		 group by gubun, personal_id
      													                  				) bogo_personal_connection_det on bogo_personal_connection.personal_id = bogo_personal_connection_det.personal_id
       																						                                                  				    and bogo_personal_connection.gubun = bogo_personal_connection_det.gubun
                 where bogo_personal_connection.gubun = :as_gubun                                                                                                                
) a
where isnull(a.yc_user_id,'') like :as_person" arguments=(("as_person", string),("as_gubun", string)) )
