table(column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" values="	Y/	N" )
 column=(type=char(4) update=yes updatewhereclause=yes key=yes name=cust_no dbname="cust_no" )
 column=(type=char(11) update=yes updatewhereclause=yes key=yes name=scene_code dbname="scene_code" )
 column=(type=char(4) update=yes updatewhereclause=yes key=yes name=sid dbname="SID" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=sidqa dbname="SIDQA" )
