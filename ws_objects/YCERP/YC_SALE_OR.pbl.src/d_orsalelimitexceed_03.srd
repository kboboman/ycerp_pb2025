detail(height=584 color="536870912" )
table(column=(type=char(4) update=yes updatewhereclause=yes key=yes name=cust_no dbname="orexceed.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=char(8) update=yes updatewhereclause=yes name=start_date dbname="orexceed.start_date" )
 column=(type=char(8) update=yes updatewhereclause=yes name=end_date dbname="orexceed.end_date" )
 column=(type=char(1) update=yes updatewhereclause=yes name=use_yn dbname="orexceed.use_yn" initial="Y" values="	Y/	N" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=limit_amt dbname="orexceed.limit_amt" initial="0" )
 column=(type=char(200) update=yes updatewhereclause=yes name=bigo dbname="orexceed.bigo" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=input_date dbname="orexceed.input_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=input_id dbname="orexceed.input_id" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="login.user_name" )
 column=(type=decimal(4) updatewhereclause=yes name=credit_limit dbname="customer.credit_limit" )
 retrieve="select  
	 A.cust_no			cust_no
	,C.cust_name		cust_name
	,A.start_date		start_date
	,A.end_date			end_date
	,A.use_yn			use_yn
	,A.limit_amt     	limit_amt
	,A.bigo				bigo
	,A.input_date		input_date
	,A.input_id			input_id
	,B.user_name		user_name
	,C.credit_limit	credit_limit 
from 
	orexceed A left outer join login B on A.input_id = B.user_id
				  left outer join customer C on A.cust_no = C.cust_no
where 
	A.cust_no	= :as_custno
and
	A.input_date= :as_dt
order by 
	A.end_date desc" update="orexceed" updatewhere=0 updatekeyinplace=no arguments=(("as_custno", string),("as_dt", string)) )
