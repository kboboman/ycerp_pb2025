$PBExportComments$작업진척조회(2002/09/14,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="536870912" )
detail(height=84 color="536870912" )
table(column=(type=datetime update=yes updatewhereclause=yes name=work_date dbname="routtempnew.work_date" )
 column=(type=long update=yes updatewhereclause=yes name=division dbname="routtempnew.division" )
 column=(type=long update=yes updatewhereclause=yes name=operation dbname="routtempnew.operation" )
 column=(type=char(14) update=yes updatewhereclause=yes name=sale_no dbname="routtempnew.sale_no" )
 column=(type=long update=yes updatewhereclause=yes name=seq_no dbname="routtempnew.seq_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="routtempnew.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="routtempnew.qa" )
 column=(type=char(4) update=yes updatewhereclause=yes name=item_color dbname="routtempnew.item_color" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="routtempnew.uom" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=plan_qty dbname="routtempnew.plan_qty" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=setup_time dbname="routtempnew.setup_time" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=work_time dbname="routtempnew.work_time" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=make_qty dbname="routtempnew.make_qty" )
 column=(type=char(17) updatewhereclause=yes name=mpsdet_plan_no dbname="mpsdet.plan_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene.scene_desc" )
 retrieve="  SELECT routtempnew.work_date,   
         routtempnew.division,   
         routtempnew.operation,   
         routtempnew.sale_no,   
         routtempnew.seq_no,   
         routtempnew.item_no,   
         routtempnew.qa,   
         routtempnew.item_color,   
         routtempnew.uom,   
         routtempnew.plan_qty,   
         routtempnew.setup_time,   
         routtempnew.work_time,   
         routtempnew.make_qty,   
         mpsdet.plan_no,   
         groupitem.item_name,   
         customer.cust_name,   
         scene.scene_desc  
    FROM routtempnew   
		LEFT OUTER JOIN mpsdet ON routtempnew.division = mpsdet.division 
                               AND routtempnew.sale_no = mpsdet.sale_no AND routtempnew.seq_no = mpsdet.seq_no
         LEFT OUTER JOIN groupitem ON routtempnew.item_no   = groupitem.item_no
         LEFT OUTER JOIN customer  ON routtempnew.cust_no      = customer.cust_no 
         LEFT OUTER JOIN scene     ON routtempnew.scene_code   = scene.scene_code 
   WHERE ( ( routtempnew.wc_no     = :arg_wc  ) AND  
                    ( routtempnew.plan_flag = 'Y'      ) AND  
                    ( routtempnew.work_date   between :arg_date1 and :arg_date2 ) AND  
                    ( routtempnew.area_no   = :as_area ) 
                  )    
" arguments=(("arg_wc", string),("arg_date1", date),("arg_date2", date),("as_area", string))  sort="work_date A mpsdet_plan_no A operation A division A " )
group(level=1 header.height=72 trailer.height=76 by=("work_date" ) header.color="536870912" trailer.color="536870912" )
