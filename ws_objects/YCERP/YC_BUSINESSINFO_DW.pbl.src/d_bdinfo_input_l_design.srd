 retrieve="  SELECT bdinfodet.seq,   
         bdinfodet.person,   
         bdinfodet.floors,   
         bdinfodet.city,   
         bdinfodet.master,   
         bdinfodet.designoffice,   
         bdinfodet.spec,   
         bdinfodet.workarea,   
         bdinfodet.buildingcom,   
         bdinfodet.bulidingphone,   
         bdinfodet.predate,   
         bdinfodet.completiondate,   
         bdinfodet.status,   
         bdinfodet.build_no,   
         bdinfodet.project,   
         bdinfodet.quantity,   
         bdinfodet.square,   
         bdinfodet.std_chk,   
         bdinfodet.spec2,   
         bdinfodet.spec3,   
         bdinfodet.unit,   
         bdinfodet.div,   
         bdinfodet.salequantity,   
         bdinfodet.dong,   
         bdinfodet.designman,   
         bdinfodet.designphone,   
         bdinfodet.buildingman,   
         bdinfodet.builder,   
         bdinfodet.builderman,   
         bdinfodet.builderphone,   
         bdinfodet.fixeddate,   
         bdinfodet.fixedflag,   
         bdinfodet.rem,   
         bdinfodet.design_prog,   
         bdinfodet.com_prog,   
         bdinfodet.sale_prog,   
         bdinfodet.buildquantity,   
         bdinfodet.makedate,   
         bdinfodet.dperson,   
         bdinfodet.ddiv,   
         bdinfodet.dexpdate,   
         bdinfodet.cperson,   
         bdinfodet.cdiv,   
         bdinfodet.cexpdate,   
         bdinfodet.bperson,   
         bdinfodet.bdiv,   
         bdinfodet.bexpdate,   
         bdinfodet.sperson,   
         bdinfodet.sdiv,   
         bdinfodet.sexpdate,   
         '' c_div  
    FROM bdinfo,   
         bdinfodet  
   WHERE ( bdinfodet.build_no = bdinfo.build_no ) AND  
			( bdinfo.build_no = :arg_build_no ) AND  
         ( bdinfodet.std_chk = '1' ) AND  
         ( bdinfodet.project like :as_project )" arguments=(("arg_build_no", string),("as_div", string),("as_spec", string),("as_project", string),("as_flag", string),("ad_date1", date),("ad_date2", date),("as_dprog", string),("as_cprog", string),("as_city", string),("as_person", string),("as_dperson", string),("as_ddiv", string),("as_cperson", string),("as_cdiv", string),("as_bperson", string),("as_bdiv", string),("as_sperson", string),("as_sdiv", string),("as_organcd", string),("as_dcode", string))  sort="bdinfodet_build_no A bdinfodet_project A " )
