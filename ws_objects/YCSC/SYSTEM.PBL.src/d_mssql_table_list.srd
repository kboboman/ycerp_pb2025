$PBExportHeader$d_mssql_table_list.srd
$PBExportComments$MS-SQL 테이블 목록
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=84 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=char(5) updatewhereclause=yes name=type dbname="type" )
 column=(type=long updatewhereclause=yes name=rows dbname="rows" )
 column=(type=char(255) updatewhereclause=yes name=name dbname="name" )
 column=(type=char(254) updatewhereclause=yes name=pbt_cmnt dbname="pbt_cmnt" )
 retrieve="SELECT type     = (case when a.type = 'U' then 'TABLE'
                        when a.type = 'V' then 'VIEW'
                        else a.type
                   end)
     , rows     = (SELECT rows FROM dbo.sysindexes WHERE id = a.id AND indid < 2)
     , name     = rtrim(a.name)
     , pbt_cmnt = b.pbt_cmnt
  FROM dbo.sysobjects a  
       LEFT OUTER JOIN dbo.pbcattbl   b ON a.name = b.pbt_tnam
 WHERE a.type IN ( :as_type ) 
 ORDER BY a.type, a.name

/*
  P :  stored procedure
  X :  extended Stored Procedure
  S :  system table
  U :  user table
  T :  trigger
  K :  primary key
  F :  foreign key 
  V :  view
*/
" arguments=(("as_type", stringlist)) )
