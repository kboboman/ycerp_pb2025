$PBExportHeader$d_cdsupp_s.srd
$PBExportComments$구매거래처선택(1998/02/09,곽용덕)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=68 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes key=yes name=supp_no dbname="supp.supp_no" )
 column=(type=char(30) updatewhereclause=yes name=supp_name dbname="supp.supp_name" )
 column=(type=char(4) updatewhereclause=yes name=use_yn dbname="use_yn" )
 retrieve="  SELECT supp.supp_no
       , supp.supp_name  
       , use_yn  = (case when supp.use_yn is null then '가능'
                         when supp.use_yn  = 'Y'  then '가능'
                         when supp.use_yn  = 'N'  then '불가'
                    end)
    FROM supp   
" update="supp" updatewhere=0 updatekeyinplace=no  sort="supp_no A " )
text(band=header alignment="2" text="구매처" border="6" color="0" x="5" y="8" height="60" width="297" html.valueishtml="0"  name=t_1 visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="67108864" )
