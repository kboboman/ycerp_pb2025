 retrieve="  SELECT uom.uom_from,   
         uom.uom_to,   
         uom.from_desc,   
         uom.to_desc,   
         uom.factor  
    FROM uom   
" update="uom" updatewhere=0 updatekeyinplace=yes  sort="uom_from A uom_to A " )
