release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=116 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=96 color="536870912" )
table(column=(type=char(50) updatewhereclause=yes name=item_gubun dbname="item_gubun" )
 column=(type=decimal(12) updatewhereclause=yes name=calc_amt1 dbname="calc_amt1" )
 column=(type=decimal(12) updatewhereclause=yes name=calc_amt2 dbname="calc_amt2" )
 retrieve="SELECT  a.item_gubun,
               sum(case when a.cust_no is null then a.CALC_AMT else 0 end ) calc_amt1,
               sum(case when a.cust_no is not null then a.CALC_AMT else 0 end ) calc_amt2
FROM
(
       SELECT 	isnull(i.item_nm,'99) 미분류') item_gubun,
       v.cust_no,
       (dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty) * dodet.price)/1000 CALC_AMT
           FROM do   with (nolock)
                INNER  join dodet   with (nolock) ON do.do_no      = dodet.do_no 
                LEFT OUTER JOIN v_cust_inside  V          ON do.cust_no    = v.cust_no
                LEFT OUTER JOIN groupitem G with (nolock) ON dodet.item_no = g.item_no 
                LEFT OUTER JOIN (                
                                                    select a.item_no, a.category, a.item_name, a.type, b.item_nm
                                                      from itemtop10 a with(nolock) inner join (SELECT item_nm, item_cd  FROM codemst with(nolock) WHERE type = 'ITEMTOP10' AND use_yn = 'Y' ) b on a.category = b.item_cd                
                                                ) i ON dodet.item_no = i.item_no    
          WHERE ( do.do_date   BETWEEN :ad_sdate AND :ad_edate )
) A
group by a.item_gubun" arguments=(("ad_sdate", date),("ad_edate", date))  sort="item_gubun A " )
