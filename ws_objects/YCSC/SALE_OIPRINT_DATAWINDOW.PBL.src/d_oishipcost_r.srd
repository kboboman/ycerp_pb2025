$PBExportHeader$d_oishipcost_r.srd
$PBExportComments$거래처별 운송비 대여 현황display용 (1998/09/24, 정재수)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="79741120" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=do_do_date dbname="do.do_date" )
 column=(type=char(1) updatewhereclause=yes name=do_do_flag dbname="do.do_flag" values="정상	1/무상	2/교환	3/오류	4/" )
 column=(type=decimal(0) updatewhereclause=yes name=do_ship_amount dbname="do.ship_amount" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_rate dbname="do.do_rate" )
 column=(type=char(3) updatewhereclause=yes name=do_curr_code dbname="do.curr_code" )
 column=(type=char(14) updatewhereclause=yes name=do_do_no dbname="do.do_no" )
 column=(type=char(11) updatewhereclause=yes name=spot_code dbname="do.spot_code" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(4) updatewhereclause=yes name=do_cust_no dbname="do.cust_no" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 retrieve="  SELECT do.do_date,   
         do.do_flag,   
         do.ship_amount,   
         do.do_rate,   
         do.curr_code,   
         do.do_no,   
         do.spot_code,   
         customer.cust_name,   
         do.cust_no,   
         scene.scene_desc  
    FROM do inner join customer on do.cust_no = customer.cust_no
				 left outer join scene on do.cust_no = scene.cust_no and do.spot_code = scene.scene_code
where ( ( do.do_date between :ad_start and :ad_end ) AND  
     		   ( do.ship_flag = 'D' ) AND  
        	   ( do.ship_amount <> 0 ) )
" arguments=(("ad_start", date),("ad_end", date))  sort="customer_cust_name A spot_code A " )
group(level=1 header.height=0 trailer.height=80 by=("do_cust_no" ) header.color="553648127" trailer.color="15780518" )
group(level=2 header.height=0 trailer.height=80 by=("spot_code" ) header.color="536870912" trailer.color="12639424" )
