$PBExportHeader$d_iocoilqoh_r4.srd
$PBExportComments$원/스리팅 코일재고 규격별 집계현황(2006/01/12,정갑용)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=76 color="536870912" )
summary(height=68 color="536870912" )
footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=decimal(1) updatewhereclause=yes name=coilmst_wid dbname="coilmst.wid" )
 column=(type=char(10) updatewhereclause=yes name=coilmst_item_no dbname="coilmst.item_no" )
 column=(type=char(20) updatewhereclause=yes name=c_qa dbname="c_qa" )
 column=(type=long updatewhereclause=yes name=c_unit_qty dbname="c_unit_qty" )
 column=(type=long updatewhereclause=yes name=c_qcnt dbname="c_qcnt" )
 column=(type=long updatewhereclause=yes name=c_unit_sum dbname="c_unit_sum" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(1) updatewhereclause=yes name=coilmst_flag dbname="coilmst.flag" values="원코일	W/스리팅	S/" )
 retrieve="  SELECT coilmst.wid,   
         coilmst.item_no,   
         c_qa = substring(coilmst.qa,1,10),   
         c_unit_qty = sum(coilmst.unit_qty),   
         c_qcnt = sum(coilmst.qcnt),
			c_unit_sum = sum (coilmst.unit_qty * coilmst.qcnt),
         groupitem.item_name,
			coilmst.flag
    FROM coilmst with(nolock) left outer join groupitem with(nolock) on coilmst.item_no = groupitem.item_no
                              inner join location with(nolock) on coilmst.loc_no = location.loc_no
                              left outer join supp with(nolock) on coilmst.supp_no = supp.supp_no

   WHERE ( ( :as_work_chk = 'N' and :as_stock_chk = 'N'  and coilmst.loc_no in (:asa_loc) )   
  		  or ( :as_work_chk = 'Y' AND ( ( 'WW01' not in (:asa_loc) and coilmst.loc_no in (:asa_loc) ) 
											 or  ( ( 'WW01' in (:asa_loc)) 
												and ( coilmst.loc_no in (:asa_loc) OR ( coilmst.loc_no in ( select loc_no from location where loc_type = 'W' or loc_type = 'Y') ) ) ) ) ) 
  		 or ( :as_stock_chk = 'Y' AND ( ( 'WW01' not in (:asa_loc) and coilmst.loc_no in (:asa_loc) ) 
											 or  ( ( 'WW01' in (:asa_loc) ) 
												and ( coilmst.loc_no in (:asa_loc) OR coilmst.loc_no = 'WS00000003' ) ) ) )
			)
			and ( coilmst.item_no in (:asa_item) )
         and ( coilmst.flag like :as_flag )
         and ( coilmst.open_close in ( :as_oc ) )
 			and not exists ( select * from lossitem with(nolock) where loss_item = coilmst.item_no )
group by  coilmst.wid,   
                 coilmst.item_no,   
                 substring(coilmst.qa,1,10),   
                 groupitem.item_name,
			           coilmst.flag
order by  coilmst.item_no,  substring(coilmst.qa,1,10)
/*
    FROM coilmst,   
         groupitem,   
         location,   
         supp  
   WHERE ( coilmst.item_no *= groupitem.item_no )
	  and ( coilmst.loc_no = location.loc_no )
     and ( coilmst.supp_no *= supp.supp_no )
	  and ( ( :as_work_chk = 'N' and :as_stock_chk = 'N'  and coilmst.loc_no in (:asa_loc) )   
  		  or ( :as_work_chk = 'Y' AND ( ( 'WW01' not in (:asa_loc) and coilmst.loc_no in (:asa_loc) ) 
											 or  ( ( 'WW01' in (:asa_loc)) 
												and ( coilmst.loc_no in (:asa_loc) OR ( coilmst.loc_no in ( select loc_no from location where loc_type = 'W' or loc_type = 'Y') ) ) ) ) ) 
  		 or ( :as_stock_chk = 'Y' AND ( ( 'WW01' not in (:asa_loc) and coilmst.loc_no in (:asa_loc) ) 
											 or  ( ( 'WW01' in (:asa_loc) ) 
												and ( coilmst.loc_no in (:asa_loc) OR coilmst.loc_no = 'WS00000003' ) ) ) )
			)
			and ( coilmst.item_no in (:asa_item) )
         and ( coilmst.flag like :as_flag )
         and ( coilmst.open_close in ( :as_oc ) )
 			and not exists ( select * from lossitem where loss_item = coilmst.item_no )
group by  coilmst.wid,   
         coilmst.item_no,   
         substring(coilmst.qa,1,10),   
         groupitem.item_name,
			coilmst.flag
order by  coilmst.item_no,  substring(coilmst.qa,1,10)
*/
" arguments=(("asa_loc", stringlist),("asa_item", stringlist),("as_flag", string),("as_oc", stringlist),("as_work_chk", string),("as_stock_chk", string))  sort="mid(coilmst_item_no,3,1) A coilmst_item_no A c_qa A " )
group(level=1 header.height=0 trailer.height=80 by=("mid(coilmst_item_no,3,1) + mid(coilmst_item_no,2,1)" ) header.color="536870912" trailer.color="15780518" )
