$PBExportHeader$d_cdbom_h.srd
$PBExportComments$BOM관리(bom)(1998/04/16 - 이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=84 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=assembly dbname="bom.assembly" )
 column=(type=char(20) updatewhereclause=yes name=assembly_qa dbname="bom.assembly_qa" )
 column=(type=long updatewhereclause=yes name=sequence dbname="bom.sequence" )
 column=(type=char(10) updatewhereclause=yes name=component dbname="bom.component" )
 column=(type=char(20) updatewhereclause=yes name=component_qa dbname="bom.component_qa" )
 column=(type=decimal(4) updatewhereclause=yes name=qpa dbname="bom.qpa" )
 column=(type=datetime updatewhereclause=yes name=effectivity dbname="bom.effectivity" )
 column=(type=datetime updatewhereclause=yes name=obsolete dbname="bom.obsolete" )
 column=(type=decimal(4) updatewhereclause=yes name=yield dbname="bom.yield" initial="1" )
 column=(type=char(30) updatewhereclause=yes name=rem dbname="bom.rem" )
 column=(type=char(1) updatewhereclause=yes name=item_source dbname="item.source" )
 column=(type=char(60) updatewhereclause=yes name=item_item_name dbname="item.item_name" )
 column=(type=char(2) updatewhereclause=yes name=item_uom dbname="item.uom" )
 retrieve="PBSELECT( VERSION(400) DISTINCT ()TABLE(NAME=~"bom~" )  TABLE(NAME=~"item~" ) COLUMN(NAME=~"bom.assembly~") COLUMN(NAME=~"bom.assembly_qa~") COLUMN(NAME=~"bom.sequence~") COLUMN(NAME=~"bom.component~") COLUMN(NAME=~"bom.component_qa~") COLUMN(NAME=~"bom.qpa~") COLUMN(NAME=~"bom.effectivity~") COLUMN(NAME=~"bom.obsolete~") COLUMN(NAME=~"bom.yield~") COLUMN(NAME=~"bom.rem~") COLUMN(NAME=~"item.source~") COLUMN(NAME=~"item.item_name~") COLUMN(NAME=~"item.uom~")    JOIN (LEFT=~"bom.component~"    OP =~"=~"RIGHT=~"item.item_no~" )    JOIN (LEFT=~"bom.component_qa~"    OP =~"=~"RIGHT=~"item.qa1~" )WHERE(    EXP1 =~"bom.assembly~"   OP =~"=~"    EXP2 =~":as_itemno~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"bom.assembly_qa~"   OP =~"=~"    EXP2 =~":as_qa~" ) ) ARG(NAME = ~"as_itemno~" TYPE = string)  ARG(NAME = ~"as_qa~" TYPE = string) " arguments=(("as_itemno", string),("as_qa", string)) )
