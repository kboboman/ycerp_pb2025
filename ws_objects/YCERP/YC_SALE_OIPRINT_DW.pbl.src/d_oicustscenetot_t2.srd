table(column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=char(50) updatewhereclause=yes name=sname dbname="sname" )
 column=(type=char(4) updatewhereclause=yes name=sid dbname="sid" )
 column=(type=char(10) updatewhereclause=yes name=sidqa dbname="sidqa" )
 column=(type=decimal(3) updatewhereclause=yes name=sidqty dbname="sidqty" )
 column=(type=long updatewhereclause=yes name=seq dbname="seq" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(11) updatewhereclause=yes name=scene_code dbname="scene_code" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=char(7) updatewhereclause=yes name=do_date dbname="do_date" )
 column=(type=decimal(2) updatewhereclause=yes name=qty dbname="ship_qty" )
 column=(type=decimal(0) updatewhereclause=yes name=act_totqty dbname="act_totqty" )
 column=(type=decimal(0) updatewhereclause=yes name=act_amount dbname="act_amount" )
 column=(type=decimal(4) updatewhereclause=yes name=c_qty dbname="c_qty" )
 retrieve="  SELECT scene_desc    = a.scene_desc 
       , sname         = isnull(c.sname,'')
       , sid           = a.sid        
       , sidqa         = a.sidqa      
       , sidqty        = a.sidqty     
       , seq           = a.seq        
                       
       , cust_no       = a.cust_no    
       , cust_name     = a.cust_name  
       , scene_code    = a.scene_code 
       , item_name     = a.item_name  
       , item_no       = a.item_no    
       , qa            = a.qa         
       , uom           = a.uom        
       , do_date       = a.do_date
       , ship_qty      = a.ship_qty   
       , act_totqty    = a.act_totqty   /* 총수량   */
       , act_amount    = a.act_amount   /* 금액     */
       , c_qty         = a.c_qty        /* 환산수량 */
    FROM (
         SELECT sid         = isnull(b.sid        , a.sid        )
              , sidqa       = isnull(b.sidqa      , a.sidqa      )
              , sidqty      = isnull(b.sidqty     , a.sidqty     )
              , seq         = isnull(b.seq        , a.seq        )
       
              , cust_no     = isnull(a.cust_no    , b.cust_no    )
              , cust_name   = isnull(a.cust_name  , b.cust_name  )
              , scene_code  = isnull(a.scene_code , b.scene_code )
              , scene_desc  = isnull(a.scene_desc , b.scene_desc )
              , item_name   = isnull(a.item_name  , b.item_name  )
              , item_no     = isnull(a.item_no    , b.item_no    )
              , qa          = isnull(a.qa         , b.qa         )
              , uom         = isnull(a.uom        , b.uom        )
              , do_date     = a.do_date
              , ship_qty    = isnull(a.ship_qty   , 0            )
              , c_qty       = isnull(a.c_qty      , 0            )
              , act_totqty  = isnull(b.act_totqty , 0            ) 
              , act_amount  = isnull(b.act_amount , 0            )
           FROM (
                 SELECT sid         = '9999'
                      , sidqa       = ''
                      , sidqty      = null
                      , seq         = 32767
                      , cust_no     = do.cust_no                           
                      , cust_name   = customer.cust_name
                      , scene_code  = do.spot_code
                      , scene_desc  = scene.scene_desc
                      , item_no     = dodet.item_no                        
                      , item_name   = groupitem.item_name                  
                      , qa          = dodet.qa                             
                      , uom         = dodet.uom                            
                      , do_date     = convert(char(7),do.do_date,111)
                      , do_no       = do.do_no                             
                      , oi_no       = dodet.oi_no                          
                      , do_rate     = do.do_rate     
                      , do_cash     = do.do_cash     
                      , do_total    = do.do_total    
                      , ship_total  = (case when do.ship_flag = 'D' and do.shipamt_case = 'R' and dodet.oi_no = 1 then /* 대여, 부담 */
                                                 (case when do.do_rate <> 0 then /* 영세율이 아닌것 */
                                                            do.ship_amount * 1.1 
                                                       else do.ship_amount 
                                                  end)
                                            else 0
                                       end)
                      , ship_qty    = dodet.ship_qty
                      , c_qty       = round(dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty),2,1)
                      , c_price     = dodet.price
                      , c_amt       = (case when customer.round = 'Y' then 
                                                 round((dodet.price * round(dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty),2,1) ), 0,0)
                                            else round((dodet.price * round(dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty),2,1) ), 0,1) 
                                       end )                      
                      , c_rate      = dodet.rate_cash
                      , c_tot       = (case when customer.round = 'Y' then 
                                                 round((dodet.price * round(dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty),2,1) ), 0,0)
                                            else round((dodet.price * round(dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty),2,1) ), 0,1) 
                                       end) + dodet.rate_cash
                   FROM do           
                      , dodet        
                      , groupitem    
                      , customer  
                      , scene
                  WHERE ( do.do_no                = dodet.do_no       ) 
                    AND ( dodet.item_no           = groupitem.item_no ) 
                    AND ( do.cust_no              = customer.cust_no  )             
                    AND ( do.spot_code            = scene.scene_code  )
                    AND ( do.area_no           LIKE :as_area          )
                    AND ( convert(char(10),do.do_date,111)  BETWEEN :as_sdate AND :as_edate )
                    AND ( do.cust_no              = :as_custno        )
                    AND ( do.spot_code         LIKE :as_sceneno       )
                ) A
                
                FULL OUTER JOIN (
                   SELECT cust_no        = a.cust_no
                        , cust_name      = d.cust_name
                        , scene_code     = a.scene_code        
                        , scene_desc     = b.scene_desc        /* 현장명        */
                        , SID            = a.sid               /* 일위대가 SID  */
                        , SIDQA          = a.sidqa             /* 일위대가 규격 */
                        , SIDQTY         = a.sidqty            /* 일위대가 물량 */
                        , seq            = a.seq               /* 순번          */
                        , sub_seq        = a.sub_seq           /* 소공사순번    */
                        , subcon_name    = a.subcon_name       /* 소공사명      */
                        , con_seq        = a.con_seq           /* 공종순번      */
                        , con_name       = a.con_name          /* 공종명        */
                        , item_no        = a.item_no           /* 자재코드      */
                        , item_name      = e.item_name         /* 자재명        */
                        , uom            = a.uom               /* 단위          */
                        , qa             = c.qa_y              /* 자재규격      */
                        , act_qty        = a.act_qty           /* 소요량        */
                        , act_price      = a.act_price         /* 단가          */
                        , act_totqty     = a.act_totqty        /* 총수량        */
                        , act_amount     = a.act_amount        /* 금액          */
                     FROM custscene_bomaim a
                        , scene            b
                        , nbasis_det       c
                        , customer         d
                        , groupitem        e
                    WHERE ( a.scene_code     = b.scene_code  )   
                      AND ( a.cust_no        = d.cust_no     )
                      AND ( a.item_no        = e.item_no     )
                      AND ( a.sid            = c.sid         )   
                      AND ( a.item_no        = c.item_no     )   
                      AND ( a.cust_no        = :as_custno    )
                      AND ( a.scene_code  LIKE :as_sceneno   )
                      AND ( c.cat            = '1.자재비'    )
                ) B  ON  a.sid = b.sid and a.item_no  = b.item_no  AND a.qa = b.qa
         ) A

         LEFT OUTER JOIN nbasis_mst C  ON a.sid  = c.sid
   ORDER BY scene_code desc, sid, sidqa, sidqty, seq

" arguments=(("as_area", string),("as_sdate", string),("as_edate", string),("as_custno", string),("as_sceneno", string)) )
