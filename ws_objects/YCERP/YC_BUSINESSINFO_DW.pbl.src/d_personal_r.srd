column(band=detail id=3 alignment="0" tabsequence=32766 border="0" color="0" x="462" y="0" height="100" width="901" format="[general]" html.valueishtml="0"  name=company visible="1" edit.limit=0 edit.case=any edit.focusrectangle=no edit.autoselect=no edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="2" font.pitch="2" font.charset="129" background.mode="0" background.color="553648127~tif ( getrow() = currentrow(), rgb(254,252,175),134217750 )" )
column(band=detail id=4 alignment="1" tabsequence=32766 border="0" color="0" x="1371" y="0" height="100" width="215" format="[general]" html.valueishtml="0"  name=bogo_personal_connection_det_yc_count visible="1" edit.limit=0 edit.case=any edit.focusrectangle=no edit.autoselect=no edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="2" font.pitch="2" font.charset="129" background.mode="0" background.color="553648127~tif ( getrow() = currentrow(), rgb(254,252,175),134217750 )" )
compute(band=footer alignment="1" expression="sum( bogo_personal_connection_det_yc_count for all)"border="0" color="0" x="1371" y="4" height="60" width="215" format="[GENERAL]" html.valueishtml="0"  name=compute_2 visible="1"  font.face="굴림체" font.height="-10" font.weight="700"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="553648127" )
