table(column=(type=char(4) updatewhereclause=yes key=yes name=customer_cust_no dbname="customer.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=customer_bill_amount dbname="customer.bill_amount" )
 column=(type=decimal(0) updatewhereclause=yes name=glbillamt dbname="glbillamt" )
 retrieve="select customer.cust_no, cust_name, customer.bill_amount , glbillamt = sum(glbill.bill_amount) 
from customer, glbill
 where customer.cust_no = glbill.cust_no
 and set_flag <> 'Y'
group by customer.cust_no, cust_name, customer.bill_amount" update="customer" updatewhere=0 updatekeyinplace=yes filter=" customer_bill_amount <> glbillamt " )
