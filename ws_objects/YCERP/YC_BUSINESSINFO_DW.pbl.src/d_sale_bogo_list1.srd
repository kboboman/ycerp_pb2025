$PBExportHeader$d_sale_bogo_list1.srd
$PBExportComments$출고의뢰서(2003/09/22, 이인호)
release 8;
datawindow(units=0 timer_interval=0 color=134217750 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=252 color="536870912" )
summary(height=0 color="553648127" )
footer(height=4 color="536870912" )
detail(height=324 color="553648127"  height.autosize=yes)
table(column=(type=char(8) updatewhereclause=yes name=sale_bogo_write_date dbname="write_date" )
 column=(type=char(4099) updatewhereclause=yes name=work dbname="sale_bogo.work" )
 column=(type=char(50) updatewhereclause=yes name=sale_bogo_code_code_name dbname="sale_bogo_code.code_name" )
 column=(type=char(10) updatewhereclause=yes name=salesman1 dbname="sale_bogo_code.salesman1" )
 column=(type=char(10) updatewhereclause=yes name=v_presale_all_user_salesman1_name dbname="V_PRESALE_ALL_USER.salesman1_name" )
 column=(type=char(10) updatewhereclause=yes name=salesman2 dbname="sale_bogo_code.salesman2" )
 column=(type=char(10) updatewhereclause=yes name=v_presale_all_user_salesman2_name dbname="V_PRESALE_ALL_USER.salesman2_name" )
 column=(type=char(20) updatewhereclause=yes name=sale_bogo_code_ceo dbname="sale_bogo_code.ceo" )
 column=(type=char(100) updatewhereclause=yes name=sale_bogo_code_address dbname="sale_bogo_code.address" )
 retrieve="select substring(a.write_date, 5,4) write_date,
           a.work, 
           b.code_name, 
           b.salesman1, 
           c.user_name salesman1_name,  
           b.salesman2,
           d.user_name salesman2_name, 
           b.ceo,
           b.address
from sale_bogo a inner join sale_bogo_code b on a.gubun = b.gubun and a.code = b.code
                              left outer join dbo.V_PRESALE_ALL_USER c on b.salesman1 = c.user_id
                              left outer join dbo.V_PRESALE_ALL_USER d on b.salesman2 = d.user_id
where a.gubun = :as_gubun
and a.write_date between :as_fr_date and :as_to_date
and isnull(a.code, '') like :as_code_code
and isnull(b.END_YN,'Y') LIKE :as_end_yn
and  (ISNULL(b.salesman1, :as_person) LIKE :as_person or  ISNULL(b.salesman1, ISNULL( b.salesman2, :as_person) ) like :as_person)
and a.chk  = 'Y'" arguments=(("as_code_code", string),("as_fr_date", string),("as_to_date", string),("as_end_yn", string),("as_person", string),("as_gubun", string))  sort="sale_bogo_code_code_name A sale_bogo_write_date A " )
