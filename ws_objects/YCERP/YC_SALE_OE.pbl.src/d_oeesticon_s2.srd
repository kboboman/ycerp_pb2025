 column=(type=long updatewhereclause=yes name=seq_no dbname="estimate_det.seq_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="estimate_det.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="estimate_det.qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="estimate_det.uom" )
