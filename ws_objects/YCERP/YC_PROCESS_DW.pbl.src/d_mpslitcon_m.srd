$PBExportHeader$d_mpslitcon_m.srd
$PBExportComments$슬리팅작업지시상세(2000/06/10,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=decimal(2) updatewhereclause=yes name=thin dbname="thin" )
 column=(type=char(14) updatewhereclause=yes name=order_no dbname="coilsliting.order_no" )
 column=(type=long updatewhereclause=yes name=seq dbname="coilsliting.seq" )
 column=(type=char(20) updatewhereclause=yes name=coil_no dbname="coilsliting.coil_no" )
 column=(type=decimal(1) updatewhereclause=yes name=wid dbname="coilsliting.wid" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="coilsliting.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="coilsliting.qa" )
 column=(type=decimal(4) updatewhereclause=yes name=unit_qty dbname="coilsliting.unit_qty" )
 column=(type=long updatewhereclause=yes name=cnt dbname="coilsliting.cnt" )
 column=(type=decimal(2) updatewhereclause=yes name=length dbname="coilsliting.length" )
 column=(type=char(1) updatewhereclause=yes name=proc_flag dbname="coilsliting.proc_flag" initial="O" )
 column=(type=char(30) updatewhereclause=yes name=rem dbname="coilsliting.rem" )
 column=(type=char(1) updatewhereclause=yes name=sheet dbname="coilsliting.sheet" )
 column=(type=char(10) updatewhereclause=yes name=loc_no dbname="coilsliting.loc_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=decimal(1) updatewhereclause=yes name=swid dbname="swid" )
 retrieve="  SELECT thin = convert(decimal(3,2), substring(coilsliting.qa,1,1) + ~".~" +  substring(coilsliting.qa,2,2))
       , coilsliting.order_no    
       , coilsliting.seq         
       , coilsliting.coil_no     
       , coilsliting.wid         
       , coilsliting.item_no     
       , coilsliting.qa          
       , coilsliting.unit_qty    
       , coilsliting.cnt         
       , coilsliting.length      
       , coilsliting.proc_flag   
       , coilsliting.rem         
       , coilsliting.sheet       
       , coilsliting.loc_no      
       , groupitem.item_name     
       , swid  = (case when sheet = ~"C~" or sheet  = ~"L~" then 
                            convert(decimal(5,1), substring(qa,5,4) + ~".~" + substring(qa, 10,1))  
                       when sheet = ~"S~" then 
                            convert(decimal(5,0), substring(qa,5,4))  
                  end)  
    FROM coilsliting
       , groupitem  
   WHERE ( coilsliting.item_no  = groupitem.item_no ) 
     and ( coilsliting.order_no = :as_order         )    
" arguments=(("as_order", string))  sort="seq A " )
