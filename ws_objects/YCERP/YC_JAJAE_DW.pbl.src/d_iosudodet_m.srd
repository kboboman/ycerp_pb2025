table(column=(type=char(10) update=yes updatewhereclause=yes name=wc_no dbname="sudodet.wc_no" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="sudodet.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=qa dbname="sudodet.qa" )
 column=(type=datetime update=yes updatewhereclause=yes name=due_date dbname="sudodet.due_date" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=rcpt_qty dbname="sudodet.rcpt_qty" initial="0" )
 column=(type=char(20) update=yes updatewhereclause=yes name=component_qa dbname="sudodet.component_qa" )
 column=(type=char(2) update=yes updatewhereclause=yes name=comp_uom dbname="sudodet.comp_uom" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=plan_qty dbname="sudodet.plan_qty" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=issue_qty dbname="sudodet.issue_qty" initial="0" )
 column=(type=datetime update=yes updatewhereclause=yes name=issue_date dbname="sudodet.issue_date" initial="0" )
 column=(type=char(10) update=yes updatewhereclause=yes name=component dbname="sudodet.component" )
 column=(type=char(17) update=yes updatewhereclause=yes key=yes name=order_no dbname="sudodet.order_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=sudo_type dbname="sudodet.sudo_type" initial="A" )
 column=(type=char(60) updatewhereclause=yes name=itemname1 dbname="groupitem.item_name" )
 column=(type=char(60) updatewhereclause=yes name=itemname2 dbname="groupitem.item_name" )
 column=(type=char(2) updatewhereclause=yes name=groupitem_uom dbname="groupitem.uom" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=out_qty dbname="sudodet.out_qty" initial="0" )
 column=(type=long update=yes updatewhereclause=yes name=operation dbname="sudodet.operation" )
 column=(type=char(14) update=yes updatewhereclause=yes name=sale_no dbname="sudodet.sale_no" )
 column=(type=long update=yes updatewhereclause=yes name=seq_no dbname="sudodet.seq_no" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(50) update=yes updatewhereclause=yes name=rem dbname="sudodet.rem" )
 column=(type=char(4) update=yes updatewhereclause=yes name=color dbname="sudodet.color" )
 column=(type=char(10) update=yes updatewhereclause=yes name=area_no dbname="sudodet.area_no" )
 retrieve="  SELECT sudodet.wc_no,   
         sudodet.item_no,   
         sudodet.qa,   
         sudodet.due_date,   
         sudodet.rcpt_qty,   
         sudodet.component_qa,   
         sudodet.comp_uom,   
         sudodet.plan_qty,   
         sudodet.issue_qty,   
         sudodet.issue_date,   
         sudodet.component,   
         sudodet.order_no,   
         sudodet.sudo_type,   
         groupitem_a.item_name,   
         groupitem_b.item_name,   
         groupitem_a.uom,   
         sudodet.out_qty,   
         sudodet.operation,   
         sudodet.sale_no,   
         sudodet.seq_no,   
         customer.cust_name,   
         sudodet.rem,   
         sudodet.color,   
         sudodet.area_no  
    FROM sale LEFT OUTER JOIN customer ON sale.cust_no = customer.cust_no,   
         sudodet,   
         groupitem groupitem_a,   
         groupitem groupitem_b  
   WHERE ( sudodet.item_no = groupitem_a.item_no ) and  
         ( sudodet.component = groupitem_b.item_no ) and  
         ( sudodet.sale_no = sale.order_no ) and  
         ( ( sudodet.sudo_type in ('A','B') ) AND  
         ( sudodet.sale_no like :as_sale ) AND  
         ( sudodet.area_no = :as_area ) )    
" update="sudodet" updatewhere=0 updatekeyinplace=no arguments=(("as_sale", string),("as_area", string))  sort="order_no A sale_no A seq_no A item_no A qa A " )
