type variables
gs_where2 istr_where
string is_where, is_loc
int ii_sw = 1
datawindow dw2, dw3, dw4, dw5, dw6, dw7, dw8, dw9, dw10, dw11

end variables

forward prototypes
public subroutine wf_filter (string as_word, string as_first, string as_second)
public subroutine wf_filitem (string as_item)
public subroutine wf_filter1 (string as_flag)
end prototypes

public subroutine wf_filter (string as_word, string as_first, string as_second);string  ls_result, ls_locno
dw2.setredraw(false)

ls_result = "mid(item_name,1,2) = '" + as_word + "'or (mid(item_name,1,2) >= '" + as_first + "' and mid(item_name,1,2) < '" + as_second + "')"

dw2.SelectRow(0,  false)
dw2.setfilter(ls_result)
dw2.filter()
dw2.setredraw(true)
dw2.sort()

string ls_item
if dw2.getrow() < 1 then return
ls_item = dw2.object.item_no[dw2.getrow()]
dw3.setredraw(false)
dw3.reset()

//if is_loc = 'WS00000011' THEN
//	ls_locno =  'WS00000011'
//ELSE
////	ls_locno =  '%'
//	ls_locno =  'WS00000011'
//END IF

dw3.retrieve(is_loc, ls_item )
//dw3.retrieve(ls_locno, ls_item )
dw3.setredraw(true)
tab_1.tabpage_1.rb_code.checked = true
dw4.object.cust_no[1] = ''

end subroutine

public subroutine wf_filitem (string as_item);tab_1.tabpage_1.rb_code.checked = true
tab_1.tabpage_1.rb_code.triggerevent(clicked!)
dw4.object.cust_no[1] = as_item
tab_1.tabpage_1.cb_4.postevent(clicked!)


end subroutine

public subroutine wf_filter1 (string as_flag);
dw4.object.cust_no[1] = ''
if as_flag = '' then
	dw2.setfilter("")
else
	dw2.setfilter(" source = '" + as_flag + "' ")
end if
dw2.Filter( )

if dw2.rowcount() > 1 then
		dw2.ScrollToRow(1)
end if

end subroutine

on w_whitemlocqohmulti_w4.create
this.cb_23=create cb_23
this.dw_7=create dw_7
this.tab_1=create tab_1
this.cb_9=create cb_9
this.cbx_2=create cbx_2
this.cb_8=create cb_8
this.cb_6=create cb_6
this.cb_2=create cb_2
this.cb_1=create cb_1
this.dw_1=create dw_1
this.gb_4=create gb_4
this.dw_loc=create dw_loc
this.Control[]={this.cb_23,&
this.dw_7,&
this.tab_1,&
this.cb_9,&
this.cbx_2,&
this.cb_8,&
this.cb_6,&
this.cb_2,&
this.cb_1,&
this.dw_1,&
this.gb_4,&
this.dw_loc}
end on

on w_whitemlocqohmulti_w4.destroy
destroy(this.cb_23)
destroy(this.dw_7)
destroy(this.tab_1)
destroy(this.cb_9)
destroy(this.cbx_2)
destroy(this.cb_8)
destroy(this.cb_6)
destroy(this.cb_2)
destroy(this.cb_1)
destroy(this.dw_1)
destroy(this.gb_4)
destroy(this.dw_loc)
end on

event open;//
long ll_found

dw2 = tab_1.tabpage_1.dw_2
dw3 = tab_1.tabpage_1.dw_3
dw4 = tab_1.tabpage_1.dw_4
dw5 = tab_1.tabpage_2.dw_5
dw6 = tab_1.tabpage_2.dw_6
dw8 = tab_1.tabpage_3.dw_8
dw9 = tab_1.tabpage_4.dw_9
dw10= tab_1.tabpage_4.dw_10
dw10.visible = false
dw11= tab_1.tabpage_5.dw_11

dw2.settransobject(sqlca)						/*2018/03/13 조원석 추가 */
dw3.settransobject(sqlca)
dw5.SetTransObject(SQLCA)
dw6.SetTransObject(SQLCA)
dw8.SetTransObject(SQLCA)
dw9.SetTransObject(SQLCA)
dw10.SetTransObject(SQLCA)
dw11.SetTransObject(SQLCA)
dw_7.SetTransObject(SQLCA)

dw6.SetTransObject(SQLCA)
dw6.insertrow(1)
dw6.visible = false
dw6.object.user_id[1] =  gs_userid
istr_where = Message.PowerObjectParm
//gs_ds_ITEMall.sharedata(dw2) ???          /*2018/03/13 조원석 주석처리  */

if istr_where.chk = 'S' then
	dw_1.enabled = false
	cbx_2.enabled = false
	cb_6.enabled = false
	cb_8.enabled = false
	cb_9.enabled = false
end if

is_loc = istr_where.chk1

if isnull(is_loc) or trim(is_loc) = '' then
	select def_loc into :is_loc from area where area_no = :gs_area;
end if

///////////////////////////////////////////
// 사용불가 제외
///////////////////////////////////////////
tab_1.tabpage_4.dw_orstand.settransobject(sqlca)
tab_1.tabpage_4.dw_orstand.insertrow(1)
tab_1.tabpage_4.dw_orstand.object.item_no[1] = ""

tab_1.tabpage_4.cbx_useyn.checked = true
tab_1.tabpage_4.cbx_useyn.triggerevent( clicked! )

//dw9.object.item_no.TabSequence = 0

dw2.retrieve()							/*2018/03/13 조원석 추가 */

// 저장소
dw_loc.settransobject(sqlca)
dw_loc.insertrow(1)
dw_loc.object.loc_no[1] = is_loc
dw4.insertrow(1)
dw_7.insertrow(1)


if UpperBound(istr_where.str1) > 0 then
	if not isnull(istr_where.str1[1]) and trim(istr_where.str1[1]) <> '' then
		dw2.setsort('item_no A')
		dw2.sort()
		tab_1.tabpage_1.rb_code.checked = true
		tab_1.tabpage_1.rb_name.checked = false
		dw4.object.cust_no[1] = istr_where.str1[1]
		tab_1.tabpage_1.cb_4.triggerevent(clicked!)		// 조회
		
		dw2.SelectRow(1,  true)
		if isnull(istr_where.str2[1]) or trim(istr_where.str2[1]) = '' then
		else
			ll_found = dw3.Find("qa = '" + istr_where.str2[1] + "'", 1, dw3.RowCount())
			if ll_found > 0 then
				dw3.scrolltorow(ll_found)
				dw3.SelectRow(ll_found, true)
			end if
		end if
	else
		dw2.setsort('item_name A')
		dw2.sort()
		dw2.SelectRow(1,  true)
	end if
else
	dw2.setsort('item_name A')
	dw2.sort()
	dw2.SelectRow(1,  true)
end if
	
end event

event closequery;dw2.setfilter("")
dw2.Filter( )

end event

type cb_23 from commandbutton within w_whitemlocqohmulti_w4
boolean visible = false
integer x = 3511
integer y = 160
integer width = 229
integer height = 80
integer taborder = 200
integer textsize = -10
integer weight = 400
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "조회"
end type

event clicked;string ls_filter, ls_name, ls_locno

dw_7.accepttext()
ls_name = trim(UPPER(dw_7.object.cust_no[1]))

IF ISNULL(ls_name) OR ls_name = "" THEN 
	is_where = ""
ELSE

	ls_filter = '%' + ls_name + '%'
	is_where = " paint_name like '" + ls_filter + "'"
	
end if	

dw3.SetFilter(is_where)
dw3.Filter( )
end event

type dw_7 from datawindow within w_whitemlocqohmulti_w4
boolean visible = false
integer x = 2711
integer y = 156
integer width = 791
integer height = 88
integer taborder = 190
string title = "none"
string dataobject = "d_oecustomer_s"
boolean border = false
boolean livescroll = true
end type

event editchanged;long ll_found

tab_1.tabpage_1.dw_3.setredraw(false)

tab_1.tabpage_1.dw_3.SetSort("qa A ")
tab_1.tabpage_1.dw_3.Sort( )

ll_found = tab_1.tabpage_1.dw_3.Find("paint_name > '" + data + "'", 1, tab_1.tabpage_1.dw_3.RowCount())

tab_1.tabpage_1.dw_3.scrolltorow(ll_found)
tab_1.tabpage_1.dw_3.setredraw(true)

end event

event getfocus;long ll_row

ll_row = this.getrow()
if ll_row < 1 then return
this.SelectText(ll_row, LenA(this.GetText()))
end event

