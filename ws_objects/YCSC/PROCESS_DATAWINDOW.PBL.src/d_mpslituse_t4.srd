table(column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=datetime updatewhereclause=yes name=sdate dbname="sdate" )
 column=(type=datetime updatewhereclause=yes name=edate dbname="edate" )
 column=(type=char(10) updatewhereclause=yes name=wc_work_name dbname="wc.work_name" )
 column=(type=datetime updatewhereclause=yes name=sfcret_ret_date dbname="sfcret.ret_date" )
 column=(type=char(20) updatewhereclause=yes name=sfcret_qa dbname="sfcret.qa" )
 column=(type=char(20) updatewhereclause=yes name=sfcret_coil_no dbname="sfcret.coil_no" )
 column=(type=decimal(4) updatewhereclause=yes name=sfcret_unit_qty dbname="sfcret.unit_qty" )
 column=(type=long updatewhereclause=yes name=sfcret_cnt dbname="sfcret.cnt" )
 retrieve="  SELECT groupitem.item_name                              
       , sdate = convert(smalldatetime, :ad_start, 111)   
       , edate = convert(smalldatetime, :ad_end, 111)     
       , wc.work_name                                     
       , sfcret.ret_date                                  
       , sfcret.qa                                        
       , sfcret.coil_no                                   
       , sfcret.unit_qty                                  
       , sfcret.cnt  
    FROM groupitem   
       , wc          
       , sfcret    /* 반납 */
   WHERE ( sfcret.item_no            = groupitem.item_no )  
     AND ( sfcret.wc_no              = wc.work_no        )  
     AND ( ( sfcret.ret_date   BETWEEN :ad_start AND :ad_end ) AND  
           ( sfcret.coil_no     IS NOT NULL ) 
         )

  UNION  
  SELECT groupitem.item_name                              
       , sdate = convert(smalldatetime, :ad_start, 111)   
       , edate = convert(smalldatetime, :ad_end, 111)     
       , wc.work_name                                     
       , sfcuse.use_date                                  
       , sfcuse.rem_qa                                    
       , sfcuse.rem_lot                                   
       , sfcuse.rem_qty                                   
       , 1  
    FROM groupitem   
       , wc          
       , sfcuse    /* 사용 */
   WHERE ( sfcuse.item_no            = groupitem.item_no )  
     AND ( sfcuse.wc_no              = wc.work_no        )  
     AND ( ( sfcuse.use_date   BETWEEN :ad_start AND :ad_end ) AND  
           ( sfcuse.rem_lot     IS NOT NULL ) 
         )    
" arguments=(("ad_start", date),("ad_end", date))  sort="sfcret_ret_date A groupitem_item_name A mid( sfcret_qa, 5, 6) A sfcret_qa A sfcret_unit_qty A " )
group(level=1 header.height=80 trailer.height=68 by=("sfcret_ret_date" ) header.color="15780518" trailer.color="79741120" )
