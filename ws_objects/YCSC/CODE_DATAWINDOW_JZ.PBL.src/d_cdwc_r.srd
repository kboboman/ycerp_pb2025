release 5;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no )
header(height=485 color="536870912" )
summary(height=17 color="536870912" )
footer(height=1 color="536870912" )
detail(height=77 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes key=yes name=work_no dbname="wc.work_no" initial=" " )
 column=(type=char(20) updatewhereclause=yes name=work_name dbname="wc.work_name" initial=" " )
 column=(type=char(1) updatewhereclause=yes name=work_type dbname="wc.work_type" initial=" " values="사내	D/외주	S/" )
 column=(type=char(10) updatewhereclause=yes name=work_manager dbname="wc.work_manager" initial=" " )
 column=(type=long updatewhereclause=yes name=capacity dbname="wc.capacity" initial=" " )
 column=(type=char(20) updatewhereclause=yes name=work_pos dbname="wc.work_pos" initial=" " )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"wc~" ) COLUMN(NAME=~"wc.work_no~") COLUMN(NAME=~"wc.work_name~") COLUMN(NAME=~"wc.work_type~") COLUMN(NAME=~"wc.work_manager~") COLUMN(NAME=~"wc.capacity~") COLUMN(NAME=~"wc.work_pos~")) " update="wc" updatewhere=0 updatekeyinplace=no  sort="work_no A " )
