table(column=(type=char(14) update=yes updatewhereclause=yes key=yes name=trans_no dbname="DoTransDET.trans_no" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=seq_no dbname="DoTransDET.seq_no" )
 column=(type=char(14) update=yes updatewhereclause=yes name=do_no dbname="DoTransDET.do_no" )
