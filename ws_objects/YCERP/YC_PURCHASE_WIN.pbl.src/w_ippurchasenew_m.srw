decimal {5} ld_m_kg
gs_where lst_code

dw_1.accepttext()
this.accepttext()

DEBUGBREAK()
ls_supp = trim(dw_1.object.supp_no[1])
choose case dwo.name
//	case 'qa'
//		parent.pb_7.triggerevent(clicked!)
//		if wf_sel(row) = false then
//			MessageBox("확인","위와 같은 규격은 존재하지 않습니다!",Exclamation!)
//			return 1
