detail(height=88 color="536870912" )
table(column=(type=char(50) updatewhereclause=yes name=거래처명 dbname="거래처명" )
 column=(type=char(10) updatewhereclause=yes name=담당자 dbname="담당자" )
 column=(type=char(20) updatewhereclause=yes name=구분 dbname="구분" )
 column=(type=long updatewhereclause=yes name=순서 dbname="순서" )
 column=(type=char(50) updatewhereclause=yes name=구분내용 dbname="구분내용" )
 column=(type=long updatewhereclause=yes name=seq dbname="SEQ" )
 column=(type=char(10) updatewhereclause=yes name=적용일 dbname="적용일" )
 column=(type=char(4099) updatewhereclause=no name=내용 dbname="내용" )
 column=(type=datetime updatewhereclause=yes name=등록일자 dbname="등록일자" )
 retrieve="  SELECT '거래처명' = d.cust_name
       , '담당자'   = c.user_name
       , '구분'     = (case when a.item_cd = '100' then '기본사항'
                           when a.item_cd = '200' then '거래조건'
                           when a.item_cd = '300' then '거래동향'
                           else a.item_cd
                      end)
       , '순서'     = a.sort
       , '구분내용' = b.item_nm
       , 'SEQ'      = a.seq
       , '적용일'   = isnull(convert(char(10),a.idate,111),'')
       , '내용'     = a.bigo
       , '등록일자' = a.input_date
    FROM customer_base a
         LEFT OUTER JOIN codemst  b ON a.item_cd = b.item_cd AND a.sort = b.sort AND b.type = '거래처_이력카드'
         LEFT OUTER JOIN login    c ON a.iuser   = c.user_id
         LEFT OUTER JOIN customer d ON a.cust_no = d.cust_no
   WHERE ( convert(char(10),a.input_date,111) BETWEEN :as_sdate AND :as_edate )
   ORDER BY c.user_name, a.item_cd, a.sort, a.seq desc
" arguments=(("as_sdate", string),("as_edate", string)) )
