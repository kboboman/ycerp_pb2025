footer(height=88 color="8421504" )
detail(height=88 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(11) updatewhereclause=yes name=scene_code dbname="scene_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=datetime updatewhereclause=yes name=order_date dbname="order_date" )
 column=(type=decimal(0) updatewhereclause=yes name=pamt dbname="pamt" )
 column=(type=decimal(4) updatewhereclause=yes name=balance_amt dbname="balance_amt" )
 column=(type=decimal(4) updatewhereclause=yes name=sale_amount dbname="sale_amount" )
 retrieve="  SELECT distinct cust_no      = a.cust_no
       , user_name    = a.user_name   
       , cust_name    = a.cust_name   
       , scene_code   = a.scene_code
       , scene_desc   = a.scene_desc   
       , order_date   = a.order_date   
       , pamt         = dbo.UF_GetMonthAMT( a.cust_no, datepart(year, a.order_date), datepart(month, a.order_date) ) /* 당월매출 */
       , balance_amt  = (SELECT balance_amt FROM customer WHERE cust_no = a.cust_no) /* 미수금액 */
       , sale_amount  = a.sale_amount
    FROM (
         SELECT cust_no      = a.cust_no
              , user_name    = a.user_name   
              , cust_name    = a.cust_name   
              , scene_code   = a.scene_code
              , scene_desc   = a.scene_desc   
              , order_date   = a.order_date   
              , sale_amount  = sum(a.sale_amount)
           FROM (
                SELECT DISTINCT l.user_name
                     , m.cust_no   
                     , c.cust_name   
                     , s.scene_code
                     , sc.scene_desc   
                     , s.order_date   
                     , s.order_no
                     , s.sale_amount   
                  FROM UF_MyCustomers( :as_salesman ) M
                       LEFT OUTER JOIN customer   C ON m.cust_no     = c.cust_no
/*                       LEFT OUTER JOIN sale       S ON m.cust_no     = s.cust_no AND s.open_close NOT IN ('X','C')	 한도초과*/
                       LEFT OUTER JOIN sale       S ON m.cust_no     = s.cust_no AND s.open_close  = 'O'
                       LEFT OUTER JOIN saledet   SD ON s.order_no    = sd.order_no 
                       LEFT OUTER JOIN groupitem  G ON sd.item_no    = g.item_no
                       LEFT OUTER JOIN scene     SC ON s.scene_code  = sc.scene_code
                       LEFT OUTER JOIN login      L ON c.salesman    = l.user_id
                 WHERE ((:as_output  = 'Y' AND sd.order_qty - sd.rlse_qty > 0 ) OR /*출고분 제외*/
                        (:as_output <> 'Y' AND sd.order_qty > 0 )
                       )
                   AND ( s.area_no        LIKE :as_area ) 
                   AND ( s.order_date  BETWEEN :as_sdate AND :as_edate ) 
                   AND ((:as_team  = '%' ) OR 
                        (:as_team <> '%' AND m.salesman = :as_salesman )
                       )
                   AND ((:as_custno  = '%'   AND m.cust_no   LIKE :as_custno  ) OR 
                        (:as_custno  = 'ALL' AND m.cust_no   LIKE :as_custno  ) OR 
                        (:as_custno <> 'ALL' AND m.cust_no      = :as_custno )
                       )
                   AND ((:as_inside  = '%') OR
                        (:as_inside <> '%' AND c.cust_no NOT IN (SELECT item_cd FROM codemst WHERE type = '내부업체' AND use_yn = 'Y') )
                       )
                   AND ( sd.acc_qty * sd.price > 0 )
                ) A
            GROUP BY a.user_name
                   , a.cust_no   
                   , a.cust_name
                   , a.scene_code
                   , a.scene_desc
                   , a.order_date
         ) A
     WHERE a.sale_amount > :ad_amount
" arguments=(("as_area", string),("as_custno", string),("as_sdate", string),("as_edate", string),("as_salesman", string),("as_team", string),("as_inside", string),("as_output", string),("ad_amount", number))  sort="user_name A cust_name A scene_desc A order_date A " )
