table(column=(type=char(14) updatewhereclause=yes name=dc_groupno dbname="dc_groupno" )
 column=(type=char(50) updatewhereclause=yes name=dc_rem1 dbname="dc_rem1" )
 column=(type=char(50) updatewhereclause=yes name=dc_rem2 dbname="dc_rem2" )
 column=(type=char(50) updatewhereclause=yes name=dc_rem3 dbname="dc_rem3" )
 column=(type=char(50) updatewhereclause=yes name=dc_rem4 dbname="dc_rem4" )
 column=(type=char(50) updatewhereclause=yes name=dc_rem5 dbname="dc_rem5" )
 column=(type=char(50) updatewhereclause=yes name=dc_remh dbname="dc_remh" )
 column=(type=char(20) updatewhereclause=yes name=rank1 dbname="rank1" )
 column=(type=char(20) updatewhereclause=yes name=rank2 dbname="rank2" )
 column=(type=char(20) updatewhereclause=yes name=rank3 dbname="rank3" )
 column=(type=char(20) updatewhereclause=yes name=rank4 dbname="rank4" )
 column=(type=char(4) updatewhereclause=yes name=rank5 dbname="rank5" )
 column=(type=char(4) updatewhereclause=yes name=rankh dbname="rankh" )
 column=(type=char(1) updatewhereclause=yes name=cc_flag dbname="cc_flag" )
 retrieve="  SELECT dc_groupno = a.dc_groupno
       , dc_rem1    = a.dc_rem1      
       , dc_rem2    = a.dc_rem2      
       , dc_rem3    = a.dc_rem3      
       , dc_rem4    = a.dc_rem4      
       , dc_rem5    = a.dc_rem5   
       , dc_remh    = a.dc_remh   
       , rank1      = l1.rank
       , rank2      = l2.rank
       , rank3      = l3.rank
       , rank4      = l4.rank
       , rank5      = '승인' /* l5.rank */
       , rankh      = '협조'
       , cc_flag    = (case when (a.dc_appdt1 is not null) or (a.dc_appdt2 is not null) or
                                 (a.dc_appdt3 is not null) or (a.dc_appdt4 is not null) or
                                 (a.dc_appdt5 is not null)    then '1' 
                            else '0' 
                       end)
    FROM dc_group a       
         LEFT OUTER JOIN dc_groupdet b ON a.dc_groupno = b.dc_groupno
         LEFT OUTER JOIN customer    c ON a.cust_no    = c.cust_no
         LEFT OUTER JOIN login       d ON a.user_id    = d.user_id
         LEFT OUTER JOIN scene       e ON b.scene_code = e.scene_code
         LEFT OUTER JOIN team        f ON a.team_code  = f.team_code
         LEFT OUTER JOIN login      l1 ON a.dc_app1    = l1.user_id
         LEFT OUTER JOIN login      l2 ON a.dc_app2    = l2.user_id
         LEFT OUTER JOIN login      l3 ON a.dc_app3    = l3.user_id
         LEFT OUTER JOIN login      l4 ON a.dc_app4    = l4.user_id
         LEFT OUTER JOIN login      l5 ON a.dc_app5    = l5.user_id
         LEFT OUTER JOIN login      lh ON a.dc_apph    = lh.user_id
   WHERE a.dc_groupno  = :as_groupno
" arguments=(("as_groupno", string)) )
