table(column=(type=char(12) updatewhereclause=yes name=detl_cd dbname="detl_cd" )
 column=(type=char(100) updatewhereclause=yes name=detl_nm dbname="detl_nm" )
 column=(type=decimal(0) updatewhereclause=yes name=sort_order dbname="sort_order" )
 retrieve="select	
	a.detl_cd,
	a.detl_nm,
	a.sort_order
from	
	(
	select	
		mast_cd		mast_cd,
		detl_cd		detl_cd,
		detl_nm		detl_nm,
		sort_order	sort_order
	from	
		yc_codemst
	where	
		use_yn	= 'Y'
	and	
		detl_cd	<> 'ROOT') a		
where	
	a.mast_cd	= :as_mast_cd
order by 
	a.sort_order" arguments=(("as_mast_cd", string)) )
text(band=header alignment="2" text="Detl Nm" border="0" color="33554432" x="9" y="4" height="84" width="1120" html.valueishtml="0"  name=detl_nm_t visible="1"  font.face="맑은 고딕" font.height="-10" font.weight="400"  font.family="1" font.pitch="2" font.charset="129" background.mode="1" background.color="536870912" )
