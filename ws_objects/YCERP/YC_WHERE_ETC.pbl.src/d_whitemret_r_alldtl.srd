compute(band=footer alignment="2" expression="count(  item_no  for all )"border="0" color="33554432" x="9" y="8" height="64" width="165" format="#,##0" html.valueishtml="0"  name=compute_6 visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
