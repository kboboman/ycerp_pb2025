$PBExportHeader$d_whbdcustret_s.srd
$PBExportComments$설계영업거래처코드조회(2003/04/16,이인호)
release 6;
datawindow(units=0 timer_interval=0 color=12632256 processing=1 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(30) updatewhereclause=yes name=cust_name dbname="cust_name" )
 retrieve="  SELECT cust_no = bdcom.comcode,   
         cust_name = bdcom.comname  
    FROM bdcom  
ORDER BY bdcom.comcode ASC   
" filter="( mid ( cust_name, 1, 2) >= '다' and mid(cust_name,1,2) < '라')  or ( ( left(cust_name,1) = '(' ) and ( mid ( cust_name, pos(cust_name,')') + 1, 2) >= '다' AND mid ( cust_name, pos(cust_name,')') + 1,2) < '라'))"  sort="cust_name A " )
text(band=header alignment="2" text="상   호"border="6" color="0" x="9" y="12" height="60" width="581"  name=cust_name_t  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="12639424" )
text(band=header alignment="2" text="코 드"border="6" color="0" x="599" y="12" height="60" width="265"  name=cust_no_t  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="12639424" )
column(band=detail id=2 alignment="0" tabsequence=32766 border="5" color="0" x="9" y="4" height="60" width="581" format="[general]"  name=cust_name  tag="상호" edit.limit=50 edit.case=any edit.focusrectangle=no edit.autoselect=yes edit.autohscroll=yes  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="0" background.color="16777215~tif (getrow() = currentrow(), RGB(254,252,175), RGB(255,255,255))" )
column(band=detail id=1 alignment="2" tabsequence=32766 border="5" color="0" x="599" y="4" height="60" width="265" format="[general]"  name=cust_no  tag="코드번호" edit.limit=4 edit.case=any edit.focusrectangle=no edit.autoselect=yes edit.autohscroll=yes  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="0" background.color="16777215~tif (getrow() = currentrow(), RGB(254,252,175), RGB(255,255,255))" )
htmltable(border="1" cellpadding="0" cellspacing="0" generatecss="no" nowrap="yes")