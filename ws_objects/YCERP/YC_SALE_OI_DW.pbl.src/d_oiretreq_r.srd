 retrieve="  SELECT customer.cust_name   
       , groupitem.item_name   
       , scene.scene_desc   
       , login_a.user_name   
       , login_b.user_name   
       , color.color_name   
       , login_c.user_name   
       , retdet.ret_no   
       , retdet.ret_seq   
       , retdet.sale_no   
       , retdet.seq_no   
       , retdet.item_no   
       , retdet.color   
       , retdet.qa   
       , retdet.uom   
       , retdet.ret_qty   
       , retdet.acc_qty   
       , retdet.acc_degree   
       , retdet.decision_desc   
       , retdet.rem   
       , ret.ret_no   
       , ret.cust_no   
       , ret.spot_code   
       , ret.ship_flag   
       , ret.ship_case   
       , ret.preret_date   
       , ret.ret_date   
       , ret.sale_no   
       , ret.do_no   
       , ret.ret_agree   
       , ret.agree_desc   
       , ret.approve_top   
       , ret.approve_team   
       , ret.create_login   
       , ret.process_flag   
       , ret.ret_reason1   
       , ret.ret_reason2   
       , ret.ret_reason3   
       , ret.sale_flag  
    FROM ret 
         LEFT OUTER JOIN retdet        ON ret.ret_no       = retdet.ret_no
         LEFT OUTER JOIN customer      ON ret.cust_no      = customer.cust_no 
         LEFT OUTER JOIN scene         ON ret.spot_code    = scene.scene_code 
         LEFT OUTER JOIN login login_a ON ret.create_login = login_a.user_id  
         LEFT OUTER JOIN login login_b ON ret.approve_team = login_b.user_id  
         LEFT OUTER JOIN login login_c ON ret.approve_top  = login_c.user_id   
         LEFT OUTER JOIN color         ON retdet.color     = color.color_code
         LEFT OUTER JOIN groupitem     ON retdet.item_no   = groupitem.item_no
   WHERE ( ret.ret_no     = :as_ret )

" arguments=(("as_ret", string)) )
