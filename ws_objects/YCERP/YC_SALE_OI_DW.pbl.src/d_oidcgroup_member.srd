release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(5) updatewhereclause=yes name=team_code dbname="login.team_code" )
 column=(type=char(30) updatewhereclause=yes name=team_name dbname="team.team_name" )
 column=(type=char(10) updatewhereclause=yes name=rank_no dbname="login.rank_no" )
 column=(type=char(20) updatewhereclause=yes name=rank dbname="login.rank" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="login.user_id" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="login.user_name" )
 column=(type=char(13) updatewhereclause=yes name=phone dbname="login.phone" )
 column=(type=char(30) updatewhereclause=yes name=rem dbname="login.rem" )
 retrieve="  SELECT login.team_code                  
       , team.team_name                
       , login.rank_no                    
       , login.rank                       
       , login.user_id                    
       , login.user_name                  
       , login.phone
       , login.rem                        
    FROM login  
         LEFT OUTER JOIN team     ON login.team_code = team.team_code
/*   WHERE login.team_code    LIKE :as_team  */
     WHERE login.team_code    LIKE  replace( :as_team, '0' , '') +'%'
     AND use_flag              = 'Y' 
     AND login.user_id        <> '19840902'
   ORDER BY login.use_flag  DESC,
            login.rank_no   ASC,   
            login.user_name ASC,   
            login.user_id   ASC   
" arguments=(("as_team", string)) )
