 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"pgmreq~" ) COLUMN(NAME=~"pgmreq.user_id~") COLUMN(NAME=~"pgmreq.req_date~") COLUMN(NAME=~"pgmreq.seq_no~") COLUMN(NAME=~"pgmreq.req_user~") COLUMN(NAME=~"pgmreq.req_confirm~") COLUMN(NAME=~"pgmreq.req_team~") COLUMN(NAME=~"pgmreq.acc_user~") COLUMN(NAME=~"pgmreq.pre_date~") COLUMN(NAME=~"pgmreq.acc_confirm~") COLUMN(NAME=~"pgmreq.proc_date~") COLUMN(NAME=~"pgmreq.proc_flag~") COLUMN(NAME=~"pgmreq.module~") COLUMN(NAME=~"pgmreq.req_desc~") COLUMN(NAME=~"pgmreq.proc_desc~")WHERE(    EXP1 =~"pgmreq.user_id~"   OP =~"=~"    EXP2 =~":as_user~"    LOGIC =~"And~" ) WHERE(    EXP1 =~"pgmreq.req_date~"   OP =~"=~"    EXP2 =~":ad_date~" ) ) ARG(NAME = ~"as_user~" TYPE = string)  ARG(NAME = ~"ad_date~" TYPE = date) " update="pgmreq" updatewhere=1 updatekeyinplace=no arguments=(("as_user", string),("ad_date", date)) )
