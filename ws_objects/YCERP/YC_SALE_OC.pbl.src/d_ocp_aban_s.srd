$PBExportHeader$d_ocp_aban_s.srd
$PBExportComments$제품폐기조회(2003/05/30이규배)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=72 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes key=yes name=aban_no dbname="itemaban.aban_no" )
 column=(type=datetime updatewhereclause=yes name=aban_date dbname="itemaban.aban_date" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="itemaban.user_id" )
 column=(type=char(1) updatewhereclause=yes name=process_flag dbname="itemaban.process_flag" values="미결	O/완결	Y/마감	C/" )
 column=(type=char(50) updatewhereclause=yes name=rem dbname="itemaban.rem" )
 retrieve="  SELECT itemaban.aban_no,   
         itemaban.aban_date,   
         itemaban.user_id,   
         itemaban.process_flag,
         itemaban.rem
    FROM itemaban  
   WHERE ( itemaban.aban_date between :as_start and :as_end ) 
     AND ( itemaban.process_flag like :as_flag ) 
     AND ( :as_area  = '%' and itemaban.area_no LIKE :as_area
           OR
           :as_area <> '%' and itemaban.area_no    = :as_area
         )    
" update="itemaban" updatewhere=0 updatekeyinplace=no arguments=(("as_area", string),("as_start", date),("as_end", date),("as_flag", string)) )
