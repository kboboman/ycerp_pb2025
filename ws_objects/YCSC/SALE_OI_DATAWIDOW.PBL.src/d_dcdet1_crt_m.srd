 retrieve="  SELECT do_no        = a.do_no
       , dc_no        = a.dc_no       
       , dc_date      = a.dc_date     
       , user_id      = a.user_id     
       , team_code    = a.team_code   
       , dc_type      = a.dc_type
       , cust_no      = a.cust_no     
       , scene_code   = a.scene_code  
       , dc_title     = a.dc_title    
       , dc_app1      = a.dc_app1     
       , dc_appdt1    = a.dc_appdt1   
       , dc_app2      = a.dc_app2     
       , dc_appdt2    = a.dc_appdt2   
       , dc_app3      = a.dc_app3     
       , dc_appdt3    = a.dc_appdt3   
       , dc_app4      = a.dc_app4     
       , dc_appdt4    = a.dc_appdt4   
       , dc_app5      = a.dc_app5     
       , dc_appdt5    = a.dc_appdt5   
       , dc_balteam   = a.dc_balteam  
       , dc_hyupteam  = a.dc_hyupteam 
       , cust_name    = c.cust_name
       , scene_name   = e.scene_desc
       , user_name    = d.user_name
       , team_name    = f.team_name

       , oi_no        = b.oi_no     
       , seq_no       = b.seq_no    
       , item_no      = b.item_no   
       , qa           = b.qa        
       , qa_cust      = b.qa_cust   
       , ship_qty     = b.ship_qty  
       , price        = b.price     
       , aroi_qty     = b.aroi_qty  
       , uom          = b.uom       
       , sale_no      = b.sale_no   
       , rate_cash    = b.rate_cash 
       , rem          = b.rem       
       , do_rem       = b.do_rem    
       , coil_no      = b.coil_no   
       , cnt          = b.cnt       
       , loc_no       = b.loc_no    
       , stock_qty    = b.stock_qty 
       , dc_content   = b.dc_content
       , dc_rem1      = b.dc_rem1
       , dc_rem2      = b.dc_rem2
       , dc_rem3      = b.dc_rem3
       , dc_rem4      = b.dc_rem4
       , dc_rem5      = b.dc_rem5

       , rank1 = l1.rank
       , rank2 = l2.rank
       , rank3 = l3.rank
       , rank4 = l4.rank
       , rank5 = '승인' /* l5.rank */

       , user1 = (case when a.dc_appdt1 is null  then ''
                       else substring(rtrim(l1.user_name),1,2) + char(13) + substring(rtrim(l1.user_name),3,2) + '인'
                  end)
       , user2 = (case when a.dc_appdt2 is null  then ''
                       else substring(rtrim(l2.user_name),1,2) + char(13) + substring(rtrim(l2.user_name),3,2) + '인' 
                  end)
       , user3 = (case when a.dc_appdt3 is null  then ''
                       else substring(rtrim(l3.user_name),1,2) + char(13) + substring(rtrim(l3.user_name),3,2) + '인'
                  end)
       , user4 = (case when a.dc_appdt4 is null  then ''
                       else substring(rtrim(l4.user_name),1,2) + char(13) + substring(rtrim(l4.user_name),3,2) + '인'
                  end)
       , user5 = (case when a.dc_appdt5 is null  then ''
                       else substring(rtrim(l5.user_name),1,2) + char(13) + substring(rtrim(l5.user_name),3,2) + '인'
                  end)
    FROM dc a       
         LEFT OUTER JOIN dcdet    b ON a.dc_no      = b.dc_no
         LEFT OUTER JOIN customer c ON a.cust_no    = c.cust_no
         LEFT OUTER JOIN login    d ON a.user_id    = d.user_id
         LEFT OUTER JOIN scene    e ON a.scene_code = e.scene_code
         LEFT OUTER JOIN team     f ON a.team_code  = f.team_code
         LEFT OUTER JOIN login   l1 ON a.dc_app1    = l1.user_id
         LEFT OUTER JOIN login   l2 ON a.dc_app2    = l2.user_id
         LEFT OUTER JOIN login   l3 ON a.dc_app3    = l3.user_id
         LEFT OUTER JOIN login   l4 ON a.dc_app4    = l4.user_id
         LEFT OUTER JOIN login   l5 ON a.dc_app5    = l5.user_id
   WHERE a.dc_no  = :as_dcno

" update="dc" updatewhere=0 updatekeyinplace=no arguments=(("as_dcno", string)) )
