 column=(type=long update=yes updatewhereclause=yes name=operation dbname="sudodet.operation" )
 column=(type=char(14) update=yes updatewhereclause=yes name=sale_no dbname="sudodet.sale_no" )
 column=(type=long update=yes updatewhereclause=yes name=seq_no dbname="sudodet.seq_no" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(50) update=yes updatewhereclause=yes name=rem dbname="sudodet.rem" )
 column=(type=char(4) update=yes updatewhereclause=yes name=color dbname="sudodet.color" )
 column=(type=char(10) update=yes updatewhereclause=yes name=area_no dbname="sudodet.area_no" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"sudodet~" )  TABLE(NAME=~"groupitem~" ALIAS=~"groupitem_a~" )  TABLE(NAME=~"groupitem~" ALIAS=~"groupitem_b~" )  TABLE(NAME=~"customer~" )  TABLE(NAME=~"sale~" ) COLUMN(NAME=~"sudodet.wc_no~") COLUMN(NAME=~"sudodet.item_no~") COLUMN(NAME=~"sudodet.qa~") COLUMN(NAME=~"sudodet.due_date~") COLUMN(NAME=~"sudodet.rcpt_qty~") COLUMN(NAME=~"sudodet.component_qa~") COLUMN(NAME=~"sudodet.comp_uom~") COLUMN(NAME=~"sudodet.plan_qty~") COLUMN(NAME=~"sudodet.issue_qty~") COLUMN(NAME=~"sudodet.issue_date~") COLUMN(NAME=~"sudodet.component~") COLUMN(NAME=~"sudodet.order_no~") COLUMN(NAME=~"sudodet.sudo_type~") COLUMN(NAME=~"groupitem_a.item_name~") COLUMN(NAME=~"groupitem_b.item_name~") COLUMN(NAME=~"groupitem_a.uom~") COLUMN(NAME=~"sudodet.out_qty~") COLUMN(NAME=~"sudodet.operation~") COLUMN(NAME=~"sudodet.sale_no~") COLUMN(NAME=~"sudodet.seq_no~") COLUMN(NAME=~"customer.cust_name~") COLUMN(NAME=~"sudodet.rem~") COLUMN(NAME=~"sudodet.color~") COLUMN(NAME=~"sudodet.area_no~")    JOIN (LEFT=~"sale.cust_no~"    OP =~"=~"RIGHT=~"customer.cust_no~"    OUTER1 =~"sale.cust_no~" )    JOIN (LEFT=~"sudodet.item_no~"    OP =~"=~"RIGHT=~"groupitem_a.item_no~" )    JOIN (LEFT=~"sudodet.component~"    OP =~"=~"RIGHT=~"groupitem_b.item_no~" )    JOIN (LEFT=~"sudodet.sale_no~"    OP =~"=~"RIGHT=~"sale.order_no~" )WHERE(    EXP1 =~"sudodet.sudo_type~"   OP =~"in~"    EXP2 =~"('A','B')~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"sudodet.sale_no~"   OP =~"like~"    EXP2 =~":as_sale~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"sudodet.area_no~"   OP =~"=~"    EXP2 =~":as_area~" ) ) ARG(NAME = ~"as_sale~" TYPE = string)  ARG(NAME = ~"as_area~" TYPE = string) " update="sudodet" updatewhere=0 updatekeyinplace=no arguments=(("as_sale", string),("as_area", string))  sort="order_no A sale_no A seq_no A item_no A qa A " )
