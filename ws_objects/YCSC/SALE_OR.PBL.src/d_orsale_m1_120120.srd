 column=(type=decimal(0) updatewhereclause=yes name=saledet_amt dbname="amt" initial="0" )
 column=(type=char(4) update=yes updatewhereclause=yes name=color dbname="saledet.color" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=price_be dbname="saledet.price_be" initial="0" )
 column=(type=char(12) update=yes updatewhereclause=yes name=saledet_do_rem dbname="saledet.do_rem" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=stock_qty dbname="saledet.stock_qty" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=price_last dbname="saledet.price_last" )
 column=(type=decimal(3) update=yes updatewhereclause=yes name=danjung dbname="saledet.danjung" )
 column=(type=decimal(3) update=yes updatewhereclause=yes name=jungrang dbname="saledet.jungrang" )
 column=(type=char(1) updatewhereclause=yes name=price_date dbname="price_date" )
 retrieve="  SELECT saledet.order_no,   
         saledet.seq_no,   
         saledet.item_no,   
         saledet.qa,   
         saledet.uom,   
         saledet.order_qty,   
         saledet.price,   
         saledet.acc_qty,   
         saledet.saledet_text,   
         saledet.rlse_date,   
         saledet.rlse_qty,   
         saledet.rem,   
         saledet.plan_close,   
         item.item_name,   
         item.price_a,   
         saledet.sol_qty,   
         saledet.issue_qty,   
         saledet.plan_qty,   
         999999999999999 amt,   
         saledet.color,   
         saledet.price_be,   
         saledet.do_rem,   
         saledet.stock_qty,   
         saledet.price_last,   
         saledet.danjung,   
         saledet.jungrang ,
         '' price_date 
    FROM saledet,   
         item  
   WHERE ( saledet.item_no *= item.item_no) and  
         ( saledet.qa *= item.qa) and  
         ( ( saledet.order_no = :as_order_no ) )    
" update="saledet" updatewhere=0 updatekeyinplace=no arguments=(("as_order_no", string))  sort="seq_no A " )
