$PBExportHeader$d_cdcustyspitem_m.srd
$PBExportComments$YSP 표준단가 관리(2003/01/02, 이인호)
release 8;
datawindow(units=0 timer_interval=0 color=79219928 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=84 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=84 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=item_item_no dbname="item.item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_item_name dbname="item.item_name" )
 column=(type=char(2) updatewhereclause=yes name=item_uom dbname="item.uom" )
 column=(type=char(20) updatewhereclause=yes name=item_qa dbname="item.qa" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="custyspitem.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes key=yes name=qa dbname="custyspitem.qa" )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="custyspitem.uom" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=pre_cost dbname="custyspitem.pre_cost" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=price dbname="custyspitem.price" )
 column=(type=char(30) update=yes updatewhereclause=yes name=rem dbname="custyspitem.rem" )
 column=(type=datetime update=yes updatewhereclause=yes name=sys_date dbname="custyspitem.sys_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=user_id dbname="custyspitem.user_id" )
 column=(type=decimal(0) updatewhereclause=yes name=c_price dbname="c_price" initial="0" )
 retrieve="  SELECT item.item_no,   
         item.item_name,   
         item.uom,   
         item.qa,   
         custyspitem.item_no,   
         custyspitem.qa,   
         custyspitem.uom,   
         custyspitem.pre_cost,   
         custyspitem.price,   
         custyspitem.rem,   
         custyspitem.sys_date,   
         custyspitem.user_id,   
         c_price = custyspitem.price
    FROM item with(nolock) left outer join custyspitem with(nolock) on  item.item_no = custyspitem.item_no AND 
					 		      item.qa = custyspitem.qa 
	   		 inner join  groupitem with(nolock) on item.item_no = groupitem.item_no
   WHERE ( ( item.item_no like '%CY%' ) ) and           
         ( ( groupitem.use_flag = 'Y' ) ) and  
         ( ( item.use_flag = 'Y' ) ) 
order by item.item_name,item.qa

/*
    FROM groupitem,   
         item,
			custyspitem
   WHERE ( ( item.item_no like '%CY%' ) ) and  
         ( ( item.item_no = groupitem.item_no ) ) and  
         ( ( groupitem.use_flag = 'Y' ) ) and  
         ( ( item.use_flag = 'Y' ) ) and  
         ( ( item.item_no *= custyspitem.item_no ) AND 
			  ( item.qa *= custyspitem.qa ) )
order by item.item_name,item.qa

*/" update="custyspitem" updatewhere=0 updatekeyinplace=no  sort="item_item_name A item_qa A " )
