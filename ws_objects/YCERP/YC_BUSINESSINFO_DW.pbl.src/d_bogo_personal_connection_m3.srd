table(column=(type=decimal(0) update=yes updatewhereclause=yes key=yes name=personal_id dbname="bogo_personal_connection_code.personal_id" )
 column=(type=char(2) update=yes updatewhereclause=yes key=yes name=gubun dbname="bogo_personal_connection_code.gubun" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=code dbname="bogo_personal_connection_code.code" )
 column=(type=char(8) update=yes updatewhereclause=yes name=write_date dbname="bogo_personal_connection_code.write_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=write_user_id dbname="bogo_personal_connection_code.write_user_id" )
 retrieve="select personal_id,
           gubun,
	     code,
		write_date,
		write_user_id
from bogo_personal_connection_code
where gubun = :as_gubun
   and code = :as_code
   and convert(char(5),personal_id) like :as_personal_id
" update="bogo_personal_connection_code" updatewhere=0 updatekeyinplace=no arguments=(("as_code", string),("as_personal_id", string),("as_gubun", string)) )
