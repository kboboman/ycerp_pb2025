table(column=(type=char(30) updatewhereclause=yes name=bsupp_supp_name dbname="bsupp.supp_name" )
 column=(type=decimal(2) updatewhereclause=yes name=bpeom_balbf_amount dbname="bpeom.balbf_amount" )
 column=(type=decimal(2) updatewhereclause=yes name=mamt dbname="mamt" )
 column=(type=decimal(2) updatewhereclause=yes name=namt dbname="namt" )
 column=(type=long updatewhereclause=yes name=yy dbname="yy" )
 column=(type=long updatewhereclause=yes name=mm dbname="mm" )
 retrieve="  SELECT bsupp.supp_name
       , bpeom.balbf_amount
       , mamt = round( (case when :ai_mon = 1 then inv_01 when :ai_mon = 2 then inv_02 when :ai_mon = 3 then inv_03 when :ai_mon = 4 then inv_04 when :ai_mon = 5 then inv_05 when :ai_mon = 6 then inv_06 when :ai_mon = 7 then inv_07 when :ai_mon = 8 then inv_08 when :ai_mon = 9 then inv_09 when :ai_mon = 10 then inv_10 when :ai_mon = 11 then inv_11 when :ai_mon = 12 then inv_12 end) , 0, 1)  
       , namt = round( (case when :ai_mon = 1 then inv_01 + floor( inv_01 * 0.1)
							 when :ai_mon = 2 then inv_01 + floor( inv_01 * 0.1) + inv_02 + floor( inv_02 * 0.1) 
							 when :ai_mon = 3 then inv_01 + floor( inv_01 * 0.1) + inv_02 + floor( inv_02 * 0.1)  + inv_03 + floor( inv_03 * 0.1)  
							 when :ai_mon = 4 then inv_01 + floor( inv_01 * 0.1) + inv_02 + floor( inv_02 * 0.1)  + inv_03 + floor( inv_03 * 0.1) + inv_04 + floor( inv_04 * 0.1) 
							 when :ai_mon = 5 then inv_01 + floor( inv_01 * 0.1) + inv_02 + floor( inv_02 * 0.1)  + inv_03 + floor( inv_03 * 0.1) + inv_04 + floor( inv_04 * 0.1) + inv_05 + floor( inv_05 * 0.1) 
							 when :ai_mon = 6 then inv_01 + floor( inv_01 * 0.1) + inv_02 + floor( inv_02 * 0.1)  + inv_03 + floor( inv_03 * 0.1) + inv_04 + floor( inv_04 * 0.1) + inv_05 + floor( inv_05 * 0.1) + inv_06 + floor( inv_06 * 0.1) 
							 when :ai_mon = 7 then inv_01 + floor( inv_01 * 0.1) + inv_02 + floor( inv_02 * 0.1)  + inv_03 + floor( inv_03 * 0.1) + inv_04 + floor( inv_04 * 0.1) + inv_05 + floor( inv_05 * 0.1) + inv_06 + floor( inv_06 * 0.1) + inv_07 + floor( inv_07 * 0.1) 
							 when :ai_mon = 8 then inv_01 + floor( inv_01 * 0.1) + inv_02 + floor( inv_02 * 0.1)  + inv_03 + floor( inv_03 * 0.1) + inv_04 + floor( inv_04 * 0.1) + inv_05 + floor( inv_05 * 0.1) + inv_06 + floor( inv_06 * 0.1) + inv_07 + floor( inv_07 * 0.1) + inv_08 + floor( inv_08 * 0.1) 
							 when :ai_mon = 9 then inv_01 + floor( inv_01 * 0.1) + inv_02 + floor( inv_02 * 0.1)  + inv_03 + floor( inv_03 * 0.1) + inv_04 + floor( inv_04 * 0.1) + inv_05 + floor( inv_05 * 0.1) + inv_06 + floor( inv_06 * 0.1) + inv_07 + floor( inv_07 * 0.1) + inv_08 + floor( inv_08 * 0.1) + inv_09 + floor( inv_09 * 0.1) 
							 when :ai_mon = 10 then inv_01 + floor( inv_01 * 0.1) + inv_02 + floor( inv_02 * 0.1)  + inv_03 + floor( inv_03 * 0.1) + inv_04 + floor( inv_04 * 0.1) + inv_05 + floor( inv_05 * 0.1) + inv_06 + floor( inv_06 * 0.1) + inv_07 + floor( inv_07 * 0.1) + inv_08 + floor( inv_08 * 0.1) + inv_09 + floor( inv_09 * 0.1) + inv_10 + floor( inv_10 * 0.1) 
							 when :ai_mon = 11 then inv_01 + floor( inv_01 * 0.1) + inv_02 + floor( inv_02 * 0.1)  + inv_03 + floor( inv_03 * 0.1) + inv_04 + floor( inv_04 * 0.1) + inv_05 + floor( inv_05 * 0.1) + inv_06 + floor( inv_06 * 0.1) + inv_07 + floor( inv_07 * 0.1) + inv_08 + floor( inv_08 * 0.1) + inv_09 + floor( inv_09 * 0.1) + inv_10 + floor( inv_10 * 0.1) + inv_11 + floor( inv_11 * 0.1) 
							 when :ai_mon = 12 then inv_01 + floor( inv_01 * 0.1) + inv_02 + floor( inv_02 * 0.1)  + inv_03 + floor( inv_03 * 0.1) + inv_04 + floor( inv_04 * 0.1) + inv_05 + floor( inv_05 * 0.1) + inv_06 + floor( inv_06 * 0.1) + inv_07 + floor( inv_07 * 0.1) + inv_08 + floor( inv_08 * 0.1) + inv_09 + floor( inv_09 * 0.1) + inv_10 + floor( inv_10 * 0.1) + inv_11 + floor( inv_11 * 0.1) + inv_12 + floor( inv_12 * 0.1) end) ,0 ,1)  
       , yy = :ai_year
       , mm = :ai_mon
    FROM bsupp
         LEFT OUTER JOIN bpeom ON bsupp.supp_no = bpeom.supp_no
   WHERE ( bpeom.eom_year    = :ai_year ) 
     AND ( bpeom.area_no     = :as_area )
     AND ( case when :ai_mon = 1 then inv_01 
                when :ai_mon = 2 then inv_02 
                when :ai_mon = 3 then inv_03 
                when :ai_mon = 4 then inv_04 
                when :ai_mon = 5 then inv_05 
                when :ai_mon = 6 then inv_06 
                when :ai_mon = 7 then inv_07 
                when :ai_mon = 8 then inv_08 
                when :ai_mon = 9 then inv_09 
                when :ai_mon = 10 then inv_10 
                when :ai_mon = 11 then inv_11 
                when :ai_mon = 12 then inv_12 
            end ) <> 0
" arguments=(("ai_year", number),("ai_mon", number),("as_area", string))  sort="bsupp_supp_name A " )
