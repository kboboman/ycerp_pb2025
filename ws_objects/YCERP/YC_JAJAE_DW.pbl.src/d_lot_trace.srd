 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=decimal(2) updatewhereclause=yes name=rcpt_qty dbname="rcpt_qty" )
 column=(type=char(10) updatewhereclause=yes name=loc_no dbname="loc_no" )
 column=(type=char(30) updatewhereclause=yes name=loc_name dbname="loc_name" )
 column=(type=long updatewhereclause=yes name=cnt dbname="cnt" )
 column=(type=decimal(4) updatewhereclause=yes name=comqty dbname="comqty" )
 column=(type=decimal(4) updatewhereclause=yes name=unit_qty dbname="unit_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=order_qty dbname="order_qty" )
 column=(type=char(20) updatewhereclause=yes name=rcpt_loc dbname="rcpt_loc" )
 column=(type=char(30) updatewhereclause=yes name=rcpt_name dbname="rcpt_name" )
 column=(type=char(17) updatewhereclause=yes name=sfcorderno dbname="sfcorderno" )
 column=(type=char(10) updatewhereclause=yes name=wc_no dbname="wc_no" )
