integer x = 4512
integer y = 44
integer width = 178
integer taborder = 410
end type

event pb_print::clicked;string     ls_where, ls_sql, ls_dw5sql
w_repsuper w_print
st_print   l_print
gs_itembaldo_str  ist_code
 
if dw_2.getrow() > 0 then
	ist_code.start_no = dw_2.object.order_no[1]
	ist_code.end_no   = dw_2.object.order_no[1]
	ist_code.start_date = string(dw_2.object.order_date[dw_2.getrow()],"yyyy/mm/dd")
	ist_code.end_date   = string(dw_2.object.order_date[dw_2.getrow()],"yyyy/mm/dd")
end if

string ls_scenehp
if MessageBox("확인", "수주장의 연락처를 해당 '현장관리마스터' 번호로 출력 합니까?", Exclamation!, YesNo!, 1) = 2 then
	ls_scenehp = ""
else
	ls_scenehp = "Y"
end if

//
OpenWithParm(w_whsaledet_w, ist_code)
ist_code = message.powerobjectparm
if ist_code.okcancel = 'N' then RETURN

//==GF_USEPROGRAM(프로그램 사용현황)==============================================================
GF_USEPROGRAM( gs_userid, Parent.ClassName(), "P", string(gf_today(),'yyyy/mm/dd'), Parent.Title )
//================================================================================================

if ist_code.sel_flag = 'S' then	// 수주상황접수부
	l_print.st_print_desc = " 이 프로그램은 수주상황접수부를 출력합니다." 
	dw_5.dataobject = 'd_orsale_print2'
ELSE										// 수주내역 리스트
	l_print.st_print_desc = " 이 프로그램은 수주내역 리스트를 출력합니다." 
	dw_5.dataobject = 'd_orsale_print3'
end if

dw_5.settransobject(sqlca)
ls_dw5sql = dw_5.describe("datawindow.table.select")

if ist_code.order_flag = 'O' then
	dw_5.dataobject = 'd_orsale_print2'
	dw_5.settrans( sqlca)
	dw_5.retrieve( ls_scenehp, ist_code.start_no,  ist_code.end_no, ist_code.do_flag)
else
	dw_5.dataobject = 'd_orsale_print4'
	dw_5.settrans( sqlca)
	dw_5.retrieve( ls_scenehp, ist_code.start_date,  ist_code.end_date, ist_code.do_flag)
	
end if

l_print.st_datawindow  = dw_5
l_print.st_print_sheet = " 프린트용지 : A4"
gs_print_control       = 'DataWindow.Print.Orientation=1 DataWindow.Print.Paper.Size=9 Datawindow.Zoom=100'

// LANDSCAPE:1, PORTRAIT:2
// SIZE 9-A4, 12-B4, 13-B5 182 x 257 mm
OpenSheetWithParm(w_print, l_print, ParentWindow(), 1, Original!)

// 공정표 출력
if cbx_rout.checked = true then
	cbx_rout.PostEvent( clicked! )
end if

end event

type pb_cancel from w_inheritance`pb_cancel within w_orsale_m
integer x = 1623
integer y = 64
integer width = 151
integer height = 116
integer taborder = 30
string picturename = "c:\bmp\retrieve.bmp"
end type

event pb_cancel::mousemove;int li_x,li_y

li_x = this.x 
li_y = this.y + 156

f_usetips(st_tips,"조회",parent, li_x, li_y)

end event

event pb_cancel::clicked;//==GF_USEPROGRAM(프로그램 사용현황)==============================================================
GF_USEPROGRAM( gs_userid, Parent.ClassName(), "R", string(gf_today(),'yyyy/mm/dd'), Parent.Title )
//================================================================================================
string ls_orderno, ls_custno
long   ll_row

ROLLBACK;

pb_cancel.default = false
cb_filteroff.triggerevent(clicked!)

dw_2.reset()
dw_3.reset()

ls_orderno = trim(em_3.text) + "-" + RightA ( "000" + trim(em_4.text), 3)
if isnull(ls_orderno) OR ls_orderno = "" then RETURN

// 공무관리담당자는 거래처변경 못함
if GF_PERMISSION("공무관리담당자", gs_userid) = "Y" and  ((GF_Permission("판매관리_입력", gs_userid) <> "Y" or GF_Permission("판매관리_입력(부분)", gs_userid) = "Y") and GF_Permission("판매관리_조회", gs_userid) <> "Y" ) then
	SELECT cust_no INTO :ls_custno FROM sale with(nolock) WHERE order_no = :ls_orderno;
	if isnull(ls_custno) OR ls_custno = "" OR ls_custno <> is_custconst then RETURN
end if

pointer oldpointer
oldpointer = SetPointer(HourGlass!)

// 파일첨부
cbx_reattch.checked = false
cbx_reattch.enabled = true	

SELECT count(*) INTO :ll_row FROM sale with(nolock) WHERE order_no = :ls_orderno;

if ll_row < 1 then
	cbx_reattch.checked = false
	cbx_reattch.enabled = false	
	cbx_attch.checked = false
	cbx_attch.enabled = false
	
	em_3.SelectText(9, 2)
	em_3.setfocus()
else
	WF_Ret( ls_orderno )

	if dw_2.rowcount() > 0 then
		string  ls_start, ls_end
		decimal lr_saleamt
		
		/*2020-04-13 jowonsuk 판매수주확정 권한자는 수주, 확정인경우는 확정 풀수 있도록 개선 */		
		if GF_PERMISSION("판매수주확정", gs_userid) = 'Y' then			
			if dw_2.object.sale_confirm_flag_view[1] = 'N'  or dw_2.object.sale_confirm_flag_view[1] = 'T' then			
			end if			
		end if		
		
		// 당월 수주금액
		ls_start = string(dw_2.object.order_date[1],"yyyy/mm/01")
		// YSP 수주건
		if LeftA(dw_2.object.order_no[1],1) = "B" then
			dw_2.object.ysp_qty2.protect = 0
			dw_2.object.ysp_qty2.background.color = rgb(255, 255, 255)
			dw_2.object.ysp_qty.protect  = 0
			dw_2.object.ysp_qty.background.color  = rgb(255, 255, 255)
			dw_2.object.color.protect    = 0
			dw_2.object.color.background.color    = rgb(255, 255, 255)
			dw_2.object.class.protect    = 0
			dw_2.object.class.background.color    = rgb(255, 255, 255)
			dw_2.object.type.protect     = 0
			dw_2.object.type.background.color     = rgb(255, 255, 255)
		else
			dw_2.object.ysp_qty2.protect = 1
			dw_2.object.ysp_qty2.background.color = rgb(192,192,192)
			dw_2.object.ysp_qty.protect  = 1
			dw_2.object.ysp_qty.background.color  = rgb(192,192,192)
			dw_2.object.color.protect    = 1
			dw_2.object.color.background.color    = rgb(192,192,192)
			dw_2.object.class.protect    = 1
			dw_2.object.class.background.color    = rgb(192,192,192)
			dw_2.object.type.protect     = 1
			dw_2.object.type.background.color     = rgb(192,192,192)
		end if
	end if
	
	em_4.SelectText(1, 3)
	em_4.setfocus()
end if
SetPointer(oldpointer)

// 출고시에 수주번호+순번으로 출고수량 재 계산함으로 수정불가
cb_5.enabled = false	// 순서(상)
cb_6.enabled = false	// 순서(하)

// 기본값 변경
pb_save.default = true

// 판매관리_조회
if GF_PERMISSION("판매관리_조회", gs_userid) = "Y" then
	if GF_PERMISSION("판매관리_입력", gs_userid) = "Y" or  GF_Permission("판매관리_입력(부분)", gs_userid) = "Y" or GF_PERMISSION("판매관리_입력(영업담당)", gs_userid) = "Y" then
	else
		pb_insert.enabled = false
		pb_delete.enabled = false
		pb_save.enabled   = false

		cb_8.enabled = false		// 내보내기
		cb_3.enabled = false		// 가져오기
		pb_5.enabled = false		// 재고수주잔량
		pb_11.enabled = false	// 성형실사
		pb_8.enabled = false		// 몰딩실사
		pb_6.enabled = false		// 문자전송
		pb_9.enabled = false		// 규격=>송장규격
		pb_1.enabled = false		// 행추가
		pb_2.enabled = false		// 행삭제
	end if
end if

end event

type pb_delete from w_inheritance`pb_delete within w_orsale_m
integer x = 4878
integer y = 44
integer width = 178
integer taborder = 470
end type

event pb_delete::clicked;dwitemstatus l_status
long   ll_row, ll_count, ll_cnt
string ls_custno, ls_order_no, ls_esti_no, ls_reqno, ls_chk

if dw_2.rowcount() < 1 then return

dw_2.accepttext()
dw_3.accepttext()

l_status    = dw_2.getitemstatus(1, 0, primary!)
ls_custno   = dw_2.object.cust_no[1] 
ls_esti_no  = trim(dw_2.object.estimate_no[1])
ls_order_no = dw_2.object.order_no[1] 
ls_chk      = 'N'

if MessageBox("삭제","삭제하시겠습니까?",question!,okcancel!,2) = 2 then RETURN

SELECT count(*) INTO :ll_cnt FROM sale_close WHERE order_no = :ls_order_no;
if ll_cnt > 0 then
	MessageBox("확인","마감요청된 상태입니다. 마감취소 후 작업하시기 바랍니다")
	RETURN
end if

if WF_ConFirm('Y') = false then 
	RETURN
end if

if l_status = newmodified! OR l_status = new! then
	dw_2.reset() ;	dw_3.reset()
else
	SELECT count(*) INTO :ll_count FROM saledet WHERE order_no = :ls_order_no AND rlse_qty > 0;
	if ll_count > 0 then
		MessageBox("확인","이미 출고된 수주이므로 삭제할 수 없습니다!",information!)
	else
		// 웹 주문관리
		SELECT order_no INTO :ls_reqno FROM saleshop WHERE sale_no = :ls_order_no;
		if isnull(ls_reqno) OR ls_reqno = "" then
		else
			UPDATE saleshop 
			   SET sale_no = null, jupsu_flag = 'N', jupsu_date = null
			 WHERE sale_no = :ls_order_no;
			if sqlca.sqlcode <> 0 then
				ROLLBACK;
				MessageBox("확인","주문상태 변경[saleshop] 변경중 오류가 발생하였습니다.")
				RETURN
			end if
			
			if IsValid(w_orsale_webcon) = true then
				w_orsale_webcon.pb_retrieve.PostEvent( clicked! )
			end if
		end if
		
		// 주문관리
		SELECT order_no INTO :ls_reqno FROM saletemp WHERE sale_no = :ls_order_no;
		if isnull(ls_reqno) OR ls_reqno = "" then
		else
			UPDATE saletemp 
			   SET sale_no = null, jupsu_flag = 'N', jupsu_date = null
			 WHERE sale_no = :ls_order_no;
			if sqlca.sqlcode <> 0 then
				ROLLBACK;
				MessageBox("확인","주문상태 변경[saletemp] 변경중 오류가 발생하였습니다.")
				RETURN
			end if
		end if
		
		// 견적서
		if isnull(ls_esti_no) OR trim(ls_esti_no) = "" then
		else
			UPDATE estimate_head SET sale_succ = 'N' WHERE estimate_no = :ls_esti_no;
			if sqlca.sqlcode <> 0 then
				ROLLBACK;
				MessageBox("삭제","견적서[estimate_head] UPDATE중 오류가 발생하였습니다.")
				RETURN
			end if
		end if
		
		// 대체물품
		SELECT count(*) INTO :ll_cnt FROM itemalter WHERE order_no = :ls_order_no AND issue_flag = 'N';
		if ll_cnt > 0 then
			DELETE FROM itemalter WHERE order_no = :ls_order_no AND issue_flag = 'N';
			if sqlca.sqlcode <> 0 then
				ROLLBACK;
				MessageBox("삭제","대체물품[itemalter] 삭제중 오류가 발생하였습니다.")
				RETURN
			end if	
		end if
		
		// 외주가공내역
		SELECT count(*) INTO :ll_cnt FROM sudodet WHERE sale_no = :ls_order_no;
		if ll_cnt > 0 then
			if MessageBox("삭제","'외주가공내역[sudodet]' 이 존재합니다.~n~n" + &
			              "담당자에게 연락하시기 바랍니다.",Exclamation!, OKCancel!, 2) = 2 then
				RETURN
			end if
		end if
		
		// 이미지
		DELETE FROM SalePIC WHERE order_no = :ls_order_no;
		if sqlca.sqlcode <> 0 then
			ROLLBACK;
			MessageBox("삭제","이미지[SalePIC] 삭제중 오류가 발생하였습니다.")
			RETURN
		end if
		
		// 수주상세
		DELETE FROM saledet WHERE order_no = :ls_order_no;
		if sqlca.sqlcode <> 0 then
			ROLLBACK;
			MessageBox("삭제","수주상세[saledet] 삭제중 오류가 발생하였습니다.")
			RETURN
		end if
		dw_3.reset()
		
		// 수주헤더
		dw_2.deleterow(1)
		
		// 삭제저장
		if WF_Update1(dw_2,'Y') = false then RETURN
		
		// 수주목록
		dw_4.deleterow(dw_4.getrow())
		dw_4.accepttext()
		if dw_4.rowcount() > 0 then
			dw_2.retrieve(dw_4.getitemstring(dw_4.getrow(), "order_no"))
			dw_3.retrieve(dw_4.getitemstring(dw_4.getrow(), "order_no"))
		else
			dw_3.reset()
		end if		
	end if
end if
end event

type pb_insert from w_inheritance`pb_insert within w_orsale_m
integer x = 4695
integer y = 44
integer width = 178
integer taborder = 430
end type

event pb_insert::clicked;string ls_null, ls_team_code
long   ll_cnt

setnull( ls_null )

dw_1.reset()
dw_2.reset()
dw_3.reset()
dw_4.reset()
dw_1.insertrow(0)
dw_2.insertrow(0)

// 이미지
cbx_reattch.checked = false
cbx_reattch.enabled = false

cbx_attch.text    = "첨부하기"
cbx_attch.checked = false
cbx_attch.enabled = true
p_1.picturename   = ls_null
st_filename.text  = ""

idwc_scene.insertrow(0) 

dw_2.object.cust_no.protect = 0
dw_2.object.cust_no.background.color = 1087434968

dw_2.object.ship_flag.protect = 0
dw_2.object.ship_flag.background.color = 1087434968

// 사업장
if dw_6.object.area[1] = "B0001" then
	dw_2.object.ysp_qty2.protect = 0
	dw_2.object.ysp_qty2.background.color = rgb(255, 255, 255)
	dw_2.object.ysp_qty.protect  = 0
	dw_2.object.ysp_qty.background.color  = rgb(255, 255, 255)
	dw_2.object.color.protect    = 0
	dw_2.object.color.background.color    = rgb(255, 255, 255)
	dw_2.object.class.protect    = 0
	dw_2.object.class.background.color    = rgb(255, 255, 255)
	dw_2.object.type.protect     = 0
	dw_2.object.type.background.color     = rgb(255, 255, 255)
else
	dw_2.object.ysp_qty2.protect = 1
	dw_2.object.ysp_qty2.background.color = rgb(192,192,192)
	dw_2.object.ysp_qty.protect  = 1
	dw_2.object.ysp_qty.background.color  = rgb(192,192,192)
	dw_2.object.color.protect    = 1
	dw_2.object.color.background.color    = rgb(192,192,192)
	dw_2.object.class.protect    = 1
	dw_2.object.class.background.color    = rgb(192,192,192)
	dw_2.object.type.protect     = 1
	dw_2.object.type.background.color     = rgb(192,192,192)
end if

dw_2.object.order_date[1] = wf_today()
dw_2.object.area_no[1]    = dw_6.object.area[1]
dw_2.object.sale_confirm_flag_view[1] = 'N'
dw_2.object.sale_confirm_flag[1] = 'N'
dw_2.object.confirm_flag[1] = 'N'

// 고객주문번호
dw_2.object.cust_po_no.tabsequence = 70
dw_2.object.cust_po_no.background.color = rgb(255, 255, 255)
dw_3.modify("datawindow.readonly = no")
pb_1.enabled = true	// 추가
pb_2.enabled = true	// 삭제
pb_3.enabled = true	// 다중추가
// 출고시에 수주번호+순번으로 출고수량 재 계산함으로 수정불가
cb_5.enabled = true	// 순서(상)
cb_6.enabled = true	// 순서(하)
pb_1.enabled = false	// 라인추가

//담당자 거래처 자동 선택
select 
	team_code
into
	:ls_team_code
from 
	login 
where 
	user_id =:gs_userid
using sqlca;	

choose case ls_team_code
	case '74000'
		dw_2.setitem(1, 'cust_no', 'N219')
		dw_2.Event ItemChanged (1, dw_2.Object.cust_no, 'N219')	
	case '77000' //서부매장 송천이앤씨
		dw_2.setitem(1, 'cust_no', 'U580')
		dw_2.Event ItemChanged (1, dw_2.Object.cust_no, 'U580')	
end choose
end event

type pb_retrieve from w_inheritance`pb_retrieve within w_orsale_m
integer x = 823
integer y = 256
integer width = 137
integer height = 104
integer taborder = 170
end type

event pb_retrieve::clicked;string ls_custno, ls_sdate, ls_edate
string ls_custconst, ls_permission

dw_2.AcceptText()
dw_3.AcceptText()

IF dw_2.DeletedCount() + dw_2.ModifiedCount() + dw_3.DeletedCount() + dw_3.ModifiedCount() > 0 THEN
	if MessageBox("확인", "수주내용을 저장 하시겠습니까?", Exclamation!, OKCancel!, 2) = 1 then
		pb_save.triggerevent(clicked!)
	end if			
end if	

if GF_PERMISSION("공무관리담당자", gs_userid) = 'Y' and  ((GF_Permission("판매관리_입력", gs_userid) <> "Y" or GF_Permission("판매관리_입력(부분)", gs_userid) = "Y") and GF_Permission("판매관리_조회", gs_userid) <> "Y" ) then
	ls_permission = "Y"
	if dw_1.object.cust_no[dw_1.getrow()] = is_custconst then
		// 공무관리담당자는 거래처변경 못함
	else
		// 공무관리담당자는 등록된 복수거래처를 열람할 수 있음(2015/08/05)
		if ls_permission = 'Y' then
			SELECT top 1 rtrim(bigo) INTO :ls_custconst FROM codemst 
			 WHERE type = '공무관리담당자' AND use_yn = 'Y' AND item_cd = :gs_userid AND rtrim(bigo) <> :is_custconst;	
			if isnull(ls_custconst) OR ls_custconst = "" OR LenA(ls_custconst) <> 4 then
				MessageBox("확인1","공무관리담당자는 해당하는 거래처만 선택할 수 있습니다!",exclamation!)
				dw_1.object.cust_no[dw_1.getrow()] = is_custconst
				RETURN
			else
				if dw_1.object.cust_no[dw_1.getrow()] = ls_custconst then
					// 공무관리담당자별 거래처선택(복수거래처) 가능
				else
					MessageBox("확인1","공무관리담당자는 해당하는 거래처만 선택할 수 있습니다!",exclamation!)
					dw_1.object.cust_no[dw_1.getrow()] = is_custconst
					RETURN
				end if
			end if
		end if
	end if
end if

cb_filteroff.triggerevent(clicked!)

dw_2.reset()
dw_3.reset()
dw_4.reset()
dw_1.accepttext()

ls_custno  = trim(dw_1.object.cust_no[1])
ls_sdate   = em_1.text
ls_edate   = em_2.text
// 출고시에 수주번호+순번으로 출고수량 재 계산함으로 수정불가
cb_5.enabled = false	// 순서(상)
cb_6.enabled = false	// 순서(하)

dw_4.retrieve( ls_custno, ls_sdate, ls_edate)
dw_4.setfocus()

// 판매관리_조회
if GF_PERMISSION("판매관리_조회", gs_userid) = "Y" then
	if GF_PERMISSION("판매관리_입력", gs_userid) = "Y" or GF_Permission("판매관리_입력(부분)", gs_userid) = "Y" or GF_PERMISSION("판매관리_입력(영업담당)", gs_userid) = "Y" then
	else
		pb_insert.enabled = false
		pb_delete.enabled = false
		pb_save.enabled   = false

		cb_8.enabled = false		// 내보내기
		cb_3.enabled = false		// 가져오기
		pb_5.enabled = false		// 재고수주잔량
		pb_11.enabled = false	// 성형실사
		pb_8.enabled = false		// 몰딩실사
		pb_6.enabled = false		// 문자전송
		pb_9.enabled = false		// 규격=>송장규격
		pb_1.enabled = false		// 행추가
		pb_2.enabled = false		// 행삭제
	end if
end if
end event

