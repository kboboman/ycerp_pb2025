 retrieve="PBSELECT( VERSION(400) DISTINCT ()TABLE(NAME=~"coilorderdet~" )  TABLE(NAME=~"coilmst~" )  TABLE(NAME=~"coilorder~" ) COLUMN(NAME=~"coilorderdet.order_no~") COLUMN(NAME=~"coilorderdet.coil_no~") COLUMN(NAME=~"coilorderdet.wid~") COLUMN(NAME=~"coilorderdet.coilorder_order~") COLUMN(NAME=~"coilorderdet.order_seq~") COLUMN(NAME=~"coilmst.unit_qty~") COLUMN(NAME=~"coilorderdet.rem~") COLUMN(NAME=~"coilorderdet.loc_no~") COLUMN(NAME=~"coilmst.etc_no~")    JOIN (LEFT=~"coilorderdet.coil_no~"    OP =~"=~"RIGHT=~"coilmst.coil_no~" )    JOIN (LEFT=~"coilorderdet.coilorder_order~"    OP =~"=~"RIGHT=~"coilorder.order_no~" )    JOIN (LEFT=~"coilorderdet.loc_no~"    OP =~"=~"RIGHT=~"coilmst.loc_no~" )WHERE(    EXP1 =~"coilorder.wc_place~"   OP =~"=~"    EXP2 =~"'O'~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"coilorderdet.proc_flag~"   OP =~"=~"    EXP2 =~"'M'~" ) ) "  sort="order_seq A " )
