text(band=header alignment="2" text="가입고" border="6" color="33554432" x="2757" y="8" height="60" width="293" html.valueishtml="0"  name=real_intemp_qty_t visible="1"  font.face="굴림체" font.height="-10" font.weight="700"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="15780518" )
text(band=header alignment="2" text="반품입고" border="6" color="33554432" x="3058" y="8" height="60" width="297" html.valueishtml="0"  name=real_ret_qty_t visible="1"  font.face="굴림체" font.height="-10" font.weight="700"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="15780518" )
