 column=(type=char(10) update=yes updatewhereclause=yes name=salesman dbname="sale.salesman" initial=" " )
 column=(type=char(1) update=yes updatewhereclause=yes name=tax_sign dbname="sale.tax_sign" initial="Y" values="	Y/	N" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=sale_tax dbname="sale.sale_tax" initial="0" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=sale_amount dbname="sale.sale_amount" initial="0" )
 column=(type=char(1) update=yes updatewhereclause=yes name=open_close dbname="sale.open_close" initial="O" values="	C/	O" )
 column=(type=char(1) update=yes updatewhereclause=yes name=close_type dbname="sale.close_type" initial=" " values="자동	A/수동	M/" )
 column=(type=datetime update=yes updatewhereclause=yes name=close_date dbname="sale.close_date" initial=" " )
 column=(type=char(80) update=yes updatewhereclause=yes name=shipto_addr dbname="sale.shipto_addr" initial=" " )
 column=(type=char(80) update=yes updatewhereclause=yes name=rem dbname="sale.rem" initial=" " )
 column=(type=long update=yes updatewhereclause=yes name=revision_no dbname="sale.revision_no" initial=" " )
 column=(type=datetime update=yes updatewhereclause=yes name=revision_date dbname="sale.revision_date" initial=" " )
 column=(type=datetime update=yes updatewhereclause=yes name=input_date dbname="sale.input_date" )
 column=(type=char(10) update=yes updatewhereclause=yes name=login_id dbname="sale.login_id" )
 column=(type=char(1) update=yes updatewhereclause=yes name=sale_confirm_flag dbname="sale.confirm_flag" initial="N" values="등록	N/수주	T/생산	Y/" )
 column=(type=char(10) update=yes updatewhereclause=yes name=sale_confirm_user dbname="sale.confirm_user" )
 column=(type=datetime update=yes updatewhereclause=yes name=sale_confirm_date dbname="sale.confirm_date" )
 column=(type=char(20) update=yes updatewhereclause=yes name=tel_no dbname="sale.tel_no" )
 column=(type=char(1) update=yes updatewhereclause=yes name=ship_case dbname="sale.ship_case" initial="E" values="정기화물	J/택배	T/오토바이	A/선박	S/항공	P/기타	E/" )
 column=(type=char(80) update=yes updatewhereclause=yes name=rem1 dbname="rem1" )
 column=(type=char(80) update=yes updatewhereclause=yes name=rem2 dbname="rem2" )
 column=(type=char(1) updatewhereclause=yes name=protect dbname="protect" initial="Y" )
 column=(type=char(1) update=yes updatewhereclause=yes name=shipamt_case dbname="sale.shipamt_case" initial="R" values="현금	C/외상	R/" )
 column=(type=char(10) update=yes updatewhereclause=yes name=area_no dbname="sale.area_no" )
 column=(type=datetime update=yes updatewhereclause=yes name=plan_date dbname="sale.plan_date" )
 column=(type=char(1) update=yes updatewhereclause=yes name=ysp_confirm dbname="sale.ysp_confirm" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=ysp_qty dbname="sale.ysp_qty" )
 column=(type=char(4) update=yes updatewhereclause=yes name=color dbname="sale.color" )
 column=(type=char(1) update=yes updatewhereclause=yes name=type dbname="sale.type" values="일체형	A/분리형	P/ U-형	U/기타	E/" )
 column=(type=long update=yes updatewhereclause=yes name=class dbname="sale.class" initial="65" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=ysp_qty2 dbname="ysp_qty2" )
 column=(type=decimal(4) updatewhereclause=yes name=credit_limit dbname="customer.credit_limit" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(1) updatewhereclause=yes name=credit_level dbname="customer.credit_level" )
 retrieve="  SELECT sale.order_no,   
         sale.cust_no,   
         sale.scene_code,   
         sale.order_date,   
         sale.due_date,   
         sale.estimate_no,   
         sale.sale_flag,   
         sale.curr_code,   
         sale.cust_po_no,   
         sale.cust_po_date,   
         sale.ship_flag,   
         sale.fob,   
         sale.salesman,   
         sale.tax_sign,   
         sale.sale_tax,   
         sale.sale_amount,   
         sale.open_close,   
         sale.close_type,   
         sale.close_date,   
         sale.shipto_addr,   
         sale.rem,   
         sale.revision_no,   
         sale.revision_date,   
         sale.input_date,   
         sale.login_id,   
         sale.confirm_flag,   
         sale.confirm_user,   
         sale.confirm_date,   
         sale.tel_no,   
         sale.ship_case,   
         sale.rem1,   
         sale.rem2,   
         protect = '',   
         sale.shipamt_case,   
         sale.area_no,   
         sale.plan_date,   
         sale.ysp_confirm,   
         sale.ysp_qty,   
         sale.color,   
         sale.type,   
         sale.class,   
         sale.ysp_qty2,
         customer.credit_limit,
         customer.cust_name,
         customer.credit_level
    FROM sale
       , customer
   WHERE ( sale.order_no = :as_order_no )  
     AND ( sale.cust_no  = customer.cust_no )
" update="sale" updatewhere=0 updatekeyinplace=no arguments=(("as_order_no", string)) )
