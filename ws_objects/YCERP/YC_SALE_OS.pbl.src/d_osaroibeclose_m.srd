 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"aroiinv~" ) COLUMN(NAME=~"aroiinv.cust_no~") COLUMN(NAME=~"aroiinv.sale_flag~") COLUMN(NAME=~"aroiinv.register_no~") COLUMN(NAME=~"aroiinv.inv_type~") COLUMN(NAME=~"aroiinv.oi_date~") COLUMN(NAME=~"aroiinv.curr_code~") COLUMN(NAME=~"aroiinv.gl_cur_rate~") COLUMN(NAME=~"aroiinv.aroiinv_cash~") COLUMN(NAME=~"aroiinv.aroiinv_rate~") COLUMN(NAME=~"aroiinv.ship_cost~") COLUMN(NAME=~"aroiinv.printed~") COLUMN(NAME=~"aroiinv.open_close~") COLUMN(NAME=~"aroiinv.close_date~") COLUMN(NAME=~"aroiinv.delete_flag~") COLUMN(NAME=~"aroiinv.sys_date~") COLUMN(NAME=~"aroiinv.login_id~") COLUMN(NAME=~"aroiinv.rem~") COLUMN(NAME=~"aroiinv.dc~") COLUMN(NAME=~"aroiinv.rem_amt~") COMPUTE(NAME=~"000000000000.00 cash~") COMPUTE(NAME=~"000000000000.00 ship~") COLUMN(NAME=~"aroiinv.inv_area~") COLUMN(NAME=~"aroiinv.dc_rate~") COLUMN(NAME=~"aroiinv.aroiinv_no~") COLUMN(NAME=~"aroiinv.discount~") COMPUTE(NAME=~"' ' all_chk~") COMPUTE(NAME=~"00 rate~") COMPUTE(NAME=~"000000000000.00 vat~")WHERE(    EXP1 =~"aroiinv.aroiinv_no~"   OP =~"=~"    EXP2 =~":as_aroiinv~" ) ) ARG(NAME = ~"as_aroiinv~" TYPE = string) " update="aroiinv" updatewhere=1 updatekeyinplace=no arguments=(("as_aroiinv", string)) )
