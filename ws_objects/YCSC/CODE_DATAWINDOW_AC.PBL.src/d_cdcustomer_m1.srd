 column=(type=char(255) update=yes updatewhereclause=yes name=outamt dbname="outamt" )
 retrieve="  SELECT customer.cust_no   
       , customer.cust_name   
       , customer.register_no   
       , customer.captain_name   
       , customer.resident_card   
       , customer.cap_birthday   
       , customer.business   
       , customer.bus_cord   
       , customer.bus_rep   
       , customer.bus_tel   
       , customer.tel_no   
       , customer.fax_no   
       , customer.industry_type   
       , customer.industry_code   
       , customer.cust_type   
       , customer.terms   
       , customer.rotate   
       , customer.class
       , colllevel = (case when isnull(customer.rotate,0.0) >= 0.0 AND isnull(customer.rotate,0.0) <=  3.0 then 'A'
                           when isnull(customer.rotate,0.0) >  3.0 AND isnull(customer.rotate,0.0) <=  5.0 then 'B'
                           when isnull(customer.rotate,0.0) >  5.0 AND isnull(customer.rotate,0.0) <=  8.0 then 'C'
                           when isnull(customer.rotate,0.0) >  8.0 AND isnull(customer.rotate,0.0) <= 12.0 then 'D'
                           when isnull(customer.rotate,0.0) > 12.0                                         then 'E'
                      end) +
                     (case when isnull(balance_amt,0)  <  10000000                                       then 'A'
                           when isnull(balance_amt,0) >=  10000000 AND isnull(balance_amt,0) <  50000000 then 'B'
                           when isnull(balance_amt,0) >=  50000000 AND isnull(balance_amt,0) < 100000000 then 'C'
                           when isnull(balance_amt,0) >= 100000000 AND isnull(balance_amt,0) < 200000000 then 'D'
                           when isnull(balance_amt,0) >= 200000000 AND isnull(balance_amt,0) < 300000000 then 'E'
                           when isnull(balance_amt,0) >= 300000000                                       then 'F'
                      end)  
       , customer.top_level
       , customer.price_level   
       , customer.credit_level   
       , customer.credit_limit
       , customer.sale_address   
       , customer.curr_code   
       , customer.balance_amt   
       , customer.bill_amount   
       , customer.ewol_trans   
       , customer.start_date   
       , customer.buyer1   
       , customer.buyer2   
       , customer.pre_salesman   
       , customer.salesman
       , customer.salesman_bu   
       , customer.support
       , customer.last_tn_date   
       , customer.open_close   
       , customer.level_grade   
       , customer.cust_flag   
       , customer.round
       , customer.buyer1_hp
       , customer.credit_day
       , customer.addr1   
       , customer.addr2   
       , customer.addr3   
       , customer.bus_addr1   
       , customer.bus_addr2   
       , customer.bus_addr3   
       , customer.shipto_addr1   
       , customer.shipto_addr2   
       , customer.shipto_addr3
       , customer.addr   
       , customer.bus_addr   
       , customer.shipto_addr   
       , c_addr        = customer.addr   
       , c_bus_addr    = customer.bus_addr
       , c_shipto_addr = customer.shipto_addr
       , haddr         = (SELECT TOP 1 address FROM customer_addrhis WHERE cust_no = customer.cust_no AND addr_type = '1' ORDER BY sys_date desc)
       , hbus_addr     = (SELECT TOP 1 address FROM customer_addrhis WHERE cust_no = customer.cust_no AND addr_type = '2' ORDER BY sys_date desc)
       , hshipto_addr  = (SELECT TOP 1 address FROM customer_addrhis WHERE cust_no = customer.cust_no AND addr_type = '3' ORDER BY sys_date desc)

       , customer.sale_control
       , customer.vat_user   
       , customer.vat_phone   
       , customer.vat_email
       , customer.collect_ymd
       , customer.icube_no
       , c_salesman = (SELECT isnull(user_name,'') FROM login WHERE user_id = customer.salesman)
       , customer.contract_day
       , customer.mgr_type
       , customer.contract_yn
       , customer.catain_value
       , customer.joint_head
       , customer.jointor
       , customer.joint_amt
       , customer.joint_value
       , customer.dambo_rem
       , customer.dambo_ymd
       , customer.dambo_ymde
       , customer.dambo_amt
       , customer.dambo_value
       , customer.dambo_bigo
       , customer.cust_group
       , customer.child_number
       , customer.captain_relation
       , scene_phone = (case when scene_phone is null then 'N'
                             when scene_phone = ''    then 'N'
                             else customer.scene_phone 
                        end)
       , cost_rule   = isnull(customer.cost_rule,'L')
       , market_email= customer.market_email
       , market_user = customer.market_user
       , market_phone= customer.market_phone
       , outamt      = customer.outamt
    FROM customer  
	WHERE customer.cust_no = :as_custno    
 " update="customer" updatewhere=0 updatekeyinplace=no arguments=(("as_custno", string)) )
