footer(height=0 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=공급처코드 dbname="supplier_unit_det.공급처코드" )
 column=(type=char(30) updatewhereclause=yes name=공급처명 dbname="supp.공급처명" )
 column=(type=long updatewhereclause=yes name=버전 dbname="supplier_unit_det.버전" )
 column=(type=char(10) updatewhereclause=yes name=품목코드 dbname="supplier_unit_det.품목코드" )
 column=(type=char(60) updatewhereclause=yes name=픔목명 dbname="GroupItem.픔목명" )
 column=(type=char(20) updatewhereclause=yes name=규격 dbname="supplier_unit_det.규격" )
 column=(type=char(2) updatewhereclause=yes name=단위 dbname="supplier_unit_det.단위" )
 column=(type=decimal(4) updatewhereclause=yes name=단가 dbname="supplier_unit_det.단가" )
 column=(type=char(30) updatewhereclause=yes name=비고 dbname="supplier_unit_det.비고" )
 retrieve="select  a.supp_no 공급처코드,
               d.supp_name 공급처명,
               a.ver 버전,
               a.item_no 품목코드,
               b.item_name 픔목명,
               a.qa 규격,
               a.uom 단위,
               a.amount 단가,           
               a.rem 비고
from supplier_unit_det a inner join groupitem b on a.item_no = b.item_no
                                                         inner join supp d on a.supp_no = d.supp_no
                                          					   INNER join (
                                                                  														SELECT  supplier_unit.supp_no,                 			  
                                                                                                              		MAX(supplier_unit.ver) VER
                                                                                                    FROM supplier_unit inner join supp on supplier_unit.supp_no = supp.supp_no
                                                                                                   where yyyymm <=  convert(char(8),getdate(),112)
                                                                                                      and supplier_unit.use_yn = 'Y'
                                                                                                GROUP BY supplier_unit.supp_no
                                                                  															
                                          									                        	) c on a.supp_no = c.supp_no and a.ver = c.ver
order by a.supp_no, a.item_no, a.qa" )
