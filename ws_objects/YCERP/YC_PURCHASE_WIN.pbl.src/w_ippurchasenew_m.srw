event clicked;// 추가
string ls_orderno, ls_contents
long   ll_row, ll_seq

ls_orderno = dw_1.object.order_no[1]
if isnull(ls_orderno) OR ls_orderno = "" then RETURN

ls_contents = "" + CharA(13) + CharA(10) + &
				  "" + CharA(13) + CharA(10)

ll_row = dw_14.insertrow(0)

dw_14.object.order_no[ll_row] = ls_orderno
dw_14.object.log_date[ll_row] = GF_Today()
dw_14.object.contents[ll_row] = ls_contents
dw_14.object.user_id[ll_row]  = gs_userid

dw_14.setcolumn("contents")
dw_14.setfocus()


end event

