$PBExportHeader$d_oisalemanbaldo_r2.srd
$PBExportComments$판매거래처별 제품출고및 미출고보고서(1998/5/14,성삼지)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=500 color="536870912" )
summary(height=100 color="536870912" )
footer(height=0 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=sale_order_no dbname="sale.order_no" initial=" " )
 column=(type=datetime updatewhereclause=yes name=sale_due_date dbname="sale.due_date" initial=" " )
 column=(type=char(4) updatewhereclause=yes name=sale_cust_no dbname="sale.cust_no" initial=" " )
 column=(type=char(10) updatewhereclause=yes name=saledet_item_no dbname="saledet.item_no" )
 column=(type=char(20) updatewhereclause=yes name=saledet_qa dbname="saledet.qa" )
 column=(type=char(2) updatewhereclause=yes name=saledet_uom dbname="saledet.uom" )
 column=(type=long updatewhereclause=yes name=saledet_seq_no dbname="saledet.seq_no" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_order_qty dbname="saledet.order_qty" )
 column=(type=datetime updatewhereclause=yes name=saledet_rlse_date dbname="saledet.rlse_date" )
 column=(type=decimal(2) updatewhereclause=yes name=saledet_rlse_qty dbname="saledet.rlse_qty" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(20) updatewhereclause=yes name=customer_bus_cord dbname="customer.bus_cord" )
 column=(type=char(20) updatewhereclause=yes name=customer_bus_rep dbname="customer.bus_rep" )
 column=(type=char(30) updatewhereclause=yes name=customer_industry_code dbname="customer.industry_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=decimal(4) updatewhereclause=yes name=saledet_price dbname="saledet.price" )
 column=(type=char(10) updatewhereclause=yes name=customer_salesman dbname="customer.salesman" )
 column=(type=char(10) updatewhereclause=yes name=login_user_name dbname="login.user_name" )
 retrieve="  SELECT sale.order_no,   
         sale.due_date,   
         sale.cust_no,   
         saledet.item_no,   
         saledet.qa,   
         saledet.uom,   
         saledet.seq_no,   
         saledet.order_qty,   
         saledet.rlse_date,   
         saledet.rlse_qty,   
         customer.cust_name,   
         customer.bus_cord,   
         customer.bus_rep,   
         customer.industry_code,   
         scene.scene_desc,   
         groupitem.item_name,
		saledet.price,
		customer.salesman,
		login.user_name
     FROM sale inner join saledet on sale.order_no = saledet.order_no
                        inner join customer on sale.cust_no = customer.cust_no
				   inner join groupitem on saledet.item_no = groupitem.item_no
				   inner join login on customer.salesman  = login.user_id 
                        left outer join scene on sale.scene_code = scene.scene_code
   where ( saledet.order_qty <> saledet.rlse_qty )"  sort="customer_cust_name A scene_scene_desc A sale_order_no A saledet_seq_no A saledet_item_no A saledet_qa A sale_due_date A " )
group(level=1 header.height=0 trailer.height=92 by=("login_user_name" ) header.color="536870912" trailer.color="536870912" )
group(level=2 header.height=0 trailer.height=92 by=("sale_cust_no" ) header.color="536870912" trailer.color="536870912" )
