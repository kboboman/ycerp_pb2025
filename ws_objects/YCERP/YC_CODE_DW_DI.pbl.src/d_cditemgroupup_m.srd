 column=(type=char(1) update=yes updatewhereclause=yes name=source dbname="groupitem.source" values="구매품	B/반제품	M/완제품	W/" )
 column=(type=long update=yes updatewhereclause=yes name=pat_no dbname="groupitem.pat_no" )
 column=(type=char(2) update=yes updatewhereclause=yes name=mp_uom dbname="groupitem.mp_uom" )
 retrieve="  SELECT groupitem.item_no,   
         groupitem.item_name,   
         groupitem.user_id,   
         groupitem.sys_date,   
         groupitem.uom,   
         groupitem.source,   
         groupitem.pat_no,   
         groupitem.mp_uom  
    FROM groupitem   
" update="groupitem" updatewhere=1 updatekeyinplace=yes )
