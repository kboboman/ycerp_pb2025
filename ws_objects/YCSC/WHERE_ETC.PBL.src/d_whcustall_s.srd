table(column=(type=char(4) updatewhereclause=yes key=yes name=cust_no dbname="customer.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 column=(type=char(1) updatewhereclause=yes name=open_close dbname="customer.open_close" )
 retrieve="  SELECT customer.cust_no,   
         customer.cust_name,
         customer.open_close 
    FROM customer 
   ORDER BY customer.open_close DESC
          , customer.cust_no ASC   
" update="customer" updatewhere=0 updatekeyinplace=no  sort="open_close D cust_name A " )
