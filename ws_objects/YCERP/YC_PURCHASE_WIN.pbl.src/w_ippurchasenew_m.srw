type dw_3 from datawindow within tabpage_1
integer y = 104
integer width = 4978
integer height = 800
integer taborder = 71
string title = "d_ippurdet2"
string dataobject = "d_ippurdet"
boolean hscrollbar = true
boolean vscrollbar = true
