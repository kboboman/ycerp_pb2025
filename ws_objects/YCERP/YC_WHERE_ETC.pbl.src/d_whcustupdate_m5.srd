 column=(type=char(17) updatewhereclause=yes name=mpsdet_plan_no dbname="mpsdet.plan_no" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"groupitem~" )  TABLE(NAME=~"mps~" )  TABLE(NAME=~"mpsdet~" )  TABLE(NAME=~"wc~" ) COLUMN(NAME=~"mps.start_date~") COLUMN(NAME=~"wc.work_name~") COLUMN(NAME=~"mpsdet.operation~") COLUMN(NAME=~"mpsdet.division~") COLUMN(NAME=~"groupitem.item_name~") COLUMN(NAME=~"mpsdet.qa~") COLUMN(NAME=~"mpsdet.order_qty~") COLUMN(NAME=~"mpsdet.rcpt_qty~") COLUMN(NAME=~"mpsdet.cust_no~") COLUMN(NAME=~"mpsdet.scene_code~") COLUMN(NAME=~"mpsdet.plan_no~")    JOIN (LEFT=~"mpsdet.order_no~"    OP =~"=~"RIGHT=~"mps.order_no~" )    JOIN (LEFT=~"mpsdet.wc_no~"    OP =~"=~"RIGHT=~"wc.work_no~" )    JOIN (LEFT=~"mpsdet.item_no~"    OP =~"=~"RIGHT=~"groupitem.item_no~" )WHERE(    EXP1 =~"mpsdet.sale_no~"   OP =~"in~"    EXP2 =~"(select distinct sale_no from dodet where do_no = :as_dono)~" ) ) ARG(NAME = ~"as_dono~" TYPE = string) " arguments=(("as_dono", string))  sort="mps_start_date A wc_work_name A mpsdet_operation A mpsdet_division A " )
