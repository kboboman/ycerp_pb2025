$PBExportHeader$d_construction_r.srd
$PBExportComments$부자재 리스트(수주관련)
release 8;
datawindow(units=0 timer_interval=0 color=134217750 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="553648127" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=con_code dbname="con_code" )
 column=(type=char(50) updatewhereclause=yes name=con_name dbname="con_name" )
 column=(type=char(10) updatewhereclause=yes name=msale_construction_salesman1 dbname="salesman1" )
 column=(type=char(10) updatewhereclause=yes name=salesman1_name dbname="salesman1_name" )
 column=(type=char(10) updatewhereclause=yes name=msale_construction_salesman2 dbname="salesman2" )
 column=(type=char(1) updatewhereclause=yes name=msale_construction_yoochang_yn dbname="yoochang_yn" )
 column=(type=char(8) updatewhereclause=yes name=modify_date dbname="modify_date" )
 column=(type=char(8) updatewhereclause=yes name=msale_construction_write_date dbname="write_date" )
 column=(type=char(10) updatewhereclause=yes name=msale_construction_write_user_id dbname="write_user_id" )
 column=(type=char(4) updatewhereclause=yes name=msale_construction_cust_no dbname="cust_no" )
 column=(type=long updatewhereclause=yes name=yc_count dbname="yc_count" )
 retrieve="select  a.con_code,
           a.con_name, 
           a.salesman1, 
           b.user_name salesman1_name,
           a.salesman2, 
           a.yoochang_yn, 
		a.modify_date,
           a.write_date, 
           a.write_user_id,
           a.cust_no,
           c.yc_count
from msale_construction a left outer join V_MSALE_USER b on a.salesman1  = b.user_id
                                 left outer join (
												  select a.company_code, count(*) yc_count
												  from 
												  (
																		  select distinct company_code, name, tel
																		  from MSALE_PERSONAL_CONNECTION with(nolock)
												  ) a group by a.company_code
										) c  on a.con_code = c.company_code
where isnull(a.salesman1,'') like :as_salesman or isnull(a.salesman2,'') like :as_salesman" arguments=(("as_salesman", string))  sort="con_name A " )
text(band=header alignment="2" text="건설사명" border="0" color="0" x="311" y="4" height="84" width="942" html.valueishtml="0"  name=msale_construction_scene_name_t visible="1"  font.face="굴림체" font.height="-11" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="15780518" )
