$PBExportHeader$d_cdcustper_s.srd
$PBExportComments$고객정보관리(1998/4/23,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=long updatewhereclause=yes name=cust_idno dbname="custper.cust_idno" )
 column=(type=char(20) updatewhereclause=yes name=cust_hname dbname="custper.cust_hname" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="customer.cust_name" )
 retrieve="  SELECT DISTINCT custper.cust_idno,   
         custper.cust_hname,   
         customer.cust_name  
    FROM custper left outer join custcar on custper.cust_idno = custcar.cust_idno
				        left outer join custetc on custper.cust_idno = custetc.cust_idno
					   left outer join custfam on custper.cust_idno = custfam.cust_idno
					   left outer join custlic on custper.cust_idno = custlic.cust_idno
					   left outer join custsch on custper.cust_idno = custsch.cust_idno
					   left outer join customer on custper.cust_no = customer.cust_no
   WHERE custper.cust_idno is not null    
/*
    FROM custper,
         custcar,   
         custetc,   
         custfam,   
         custlic,   
         custsch,
			customer
   WHERE custper.cust_idno is not null    
	  and custper.cust_no *= customer.cust_no

*/
" )
