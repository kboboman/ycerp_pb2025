footer(height=0 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=do_no dbname="dodet.do_no" )
 column=(type=char(14) updatewhereclause=yes name=sale_no dbname="dodet.sale_no" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene.scene_desc" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="do.cust_no" )
 column=(type=char(11) updatewhereclause=yes name=spot_code dbname="do.spot_code" )
 retrieve="PBSELECT( VERSION(400) DISTINCT ()TABLE(NAME=~"do~" )  TABLE(NAME=~"customer~" )  TABLE(NAME=~"scene~" )  TABLE(NAME=~"dodet~" ) COLUMN(NAME=~"dodet.do_no~") COLUMN(NAME=~"dodet.sale_no~") COLUMN(NAME=~"customer.cust_name~") COLUMN(NAME=~"scene.scene_desc~") COLUMN(NAME=~"do.cust_no~") COLUMN(NAME=~"do.spot_code~")    JOIN (LEFT=~"do.spot_code~"    OP =~"=~"RIGHT=~"scene.scene_code~"    OUTER1 =~"do.spot_code~" )    JOIN (LEFT=~"do.cust_no~"    OP =~"=~"RIGHT=~"customer.cust_no~" )    JOIN (LEFT=~"dodet.do_no~"    OP =~"=~"RIGHT=~"do.do_no~" )WHERE(    EXP1 =~"do.cust_no~"   OP =~"like~"    EXP2 =~":as_cust_no~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"do.do_date~"   OP =~"between~"    EXP2 =~":ad_sorder_date and :ad_eorder_date
~" ) ) ARG(NAME = ~"as_cust_no~" TYPE = string)  ARG(NAME = ~"ad_sorder_date~" TYPE = date)  ARG(NAME = ~"ad_eorder_date~" TYPE = date) " arguments=(("as_cust_no", string),("ad_sorder_date", date),("ad_eorder_date", date))  sort="do_no A sale_no A " )
