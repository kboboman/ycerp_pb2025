event pb_compute::clicked;call super::clicked;string  ls_user, ls_date
long ll_row, ll_cnt
date ld_date
gs_where2 lstr_select

lstr_select.chk = 'M' //M:multi S:single
lstr_select.chk1 = dw_1.object.loc_no[1]
choose case tab_1.SelectedTab
	case 1
		dw3.accepttext()
		ls_user = dw3.object.user_id[1]
		ls_date = string(date(tab_1.tabpage_1.em_1.text), 'yyyymmdd')
		ld_date = date(tab_1.tabpage_1.em_1.text)
		
		openwithparm(w_whitemlocqohmulti_w, lstr_select)
		lstr_select = Message.PowerObjectParm
		if lstr_select.chk <> "Y" then return
		dw4.setredraw(false)
		dw4.dataobject = 'd_whitemret_s'
		dw4.settransobject(sqlca)
		dw4.retrieve( ld_date, ls_date, is_loc, lstr_select.str1[], lstr_select.str2[])
		dw4.SETREDRAW(TRUE)
		dw4.sharedata(dw_2)
	case 2
	case 3
		openwithparm(w_whitemlocqohmulti_w, lstr_select)
		lstr_select = Message.PowerObjectParm
		if lstr_select.chk <> "Y" then return
		dw8.setredraw(false)
		ll_cnt = 0
		for ll_row = 1 to UPPERBOUND(lstr_select.str1)
			ll_cnt = dw8.insertrow(0)
			dw8.object.groupitem_item_name[ll_cnt] = lstr_select.name[ll_row]
			dw8.object.item_no[ll_cnt] = lstr_select.str1[ll_row]
			dw8.object.qa[ll_cnt] = lstr_select.str2[ll_row]
			dw8.object.uom[ll_cnt] = lstr_select.str3[ll_row]
		next
		dw8.setredraw(TRUE)

	case 4
end choose



end event

