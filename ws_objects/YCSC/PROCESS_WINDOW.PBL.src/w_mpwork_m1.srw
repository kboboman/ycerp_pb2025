type cb_10 from commandbutton within tabpage_3
integer x = 2912
integer y = 4
integer width = 562
integer height = 80
integer taborder = 60
boolean bringtotop = true
integer textsize = -10
integer weight = 700
fontcharset fontcharset = hangeul!
