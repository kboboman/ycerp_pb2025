compute(band=detail alignment="1" expression=" if ( round = 'Y',  if( do_curr_code = 'WON', if ( com_qty < 0 ,  round( price * com_qty, 0),  round( price * com_qty, 0)) ,  round( price  *  com_qty, 2) ), if( do_curr_code = 'WON', if ( com_qty < 0 ,  truncate( price * com_qty, 0),  truncate( price * com_qty + 0.000001, 0)) ,  truncate( price  *  com_qty, 2) )) "border="0" color="0" x="5632" y="4" height="60" width="416" format="#,##0.00" html.valueishtml="0"  name=tot_amount visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
compute(band=detail alignment="1" expression=" if(left( item_no  ,1) = 'P' and mid( item_no , 3,1) = 'Y' and (mid( item_no , 7,1) = 'A' or mid( item_no , 7,1) = 'B' or mid( item_no , 7,1) = 'C' or mid( item_no , 7,1) = 'D' or left( item_no, 5) = 'PCYSZ'),  ship_qty , if( uom  = 'M2' or uom = 'SS',truncate( long(mid(  qa  ,5,4)) * long(mid( qa ,10,4)) *  ship_qty  / 1000000, 2), if( uom  = 'M',if ( ship_qty < 0 , truncate(long(mid( qa , 15,5)) *  ship_qty / 1000 - 0.00001,2), truncate(long(mid( qa , 15,5)) * ship_qty  / 1000 + 0.00001,2)) ,  ship_qty  ))) "border="0" color="0" x="4823" y="4" height="60" width="384" format="#,##0.00" html.valueishtml="0"  name=com_qty visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
