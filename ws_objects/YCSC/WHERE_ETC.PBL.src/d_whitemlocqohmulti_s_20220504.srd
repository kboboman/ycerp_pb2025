table(column=(type=char(10) updatewhereclause=yes name=loc_no dbname="item.loc_no" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="item.uom" )
 column=(type=char(1) updatewhereclause=yes name=source dbname="item.source" )
 column=(type=char(10) updatewhereclause=yes key=yes name=item_no dbname="item.item_no" )
 column=(type=char(20) updatewhereclause=yes key=yes name=qa dbname="item.qa" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item.item_name" )
 column=(type=char(14) updatewhereclause=yes name=sale_no dbname="sale_no" )
 column=(type=char(60) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=decimal(2) updatewhereclause=yes name=qoh dbname="qoh" )
 column=(type=decimal(2) updatewhereclause=yes name=order_qty dbname="order_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=price dbname="price" )
 retrieve="  SELECT item.loc_no,   
         item.uom,   
         item.source,   
         item.item_no,   
         item.qa,   
         item.item_name,   
         sale_no = convert(varchar(14), ''),   
         cust_name = convert(varchar(60), ''),   
         qoh = 0.00,
			order_qty = 0.00,
			price = 0.00  
    FROM item  
   WHERE item.use_flag <> 'C'   
ORDER BY item.item_no ASC,   
         item.qa ASC   
" update="item" updatewhere=0 updatekeyinplace=no filter=" item_no like ~"GCY%~"" sort="item_name A qa A " )
