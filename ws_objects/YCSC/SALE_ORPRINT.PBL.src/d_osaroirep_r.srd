column(band=detail id=22 alignment="1" tabsequence=32766 border="0" color="0" x="5897" y="4" height="60" width="475" format="#,##0.00" html.valueishtml="0"  name=aroi_ori_amount  tag="매출금액" visible="1" edit.limit=0 edit.case=any edit.focusrectangle=no edit.autoselect=yes edit.autohscroll=yes edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
column(band=detail id=21 alignment="1" tabsequence=32766 border="0" color="0" x="6382" y="4" height="60" width="448" format="#,##0.00" html.valueishtml="0"  name=aroi_rate_cash  tag="부과세" visible="1" edit.limit=0 edit.case=any edit.focusrectangle=no edit.autoselect=yes edit.autohscroll=yes edit.imemode=0  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
compute(band=detail alignment="1" expression=" (aroi_ori_amount +  aroi_rate_cash )  *   aroiinv_gl_cur_rate "border="0" color="0" x="6839" y="4" height="60" width="581" format="#,##0.00" html.valueishtml="0"  name=c_amt visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
