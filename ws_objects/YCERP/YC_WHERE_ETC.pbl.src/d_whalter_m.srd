 column=(type=char(20) update=yes updatewhereclause=yes name=tar_lot dbname="itemalter.tar_lot" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=tar_qty dbname="itemalter.tar_qty" )
 column=(type=decimal(2) update=yes updatewhereclause=yes name=tar_stock_qty dbname="itemalter.tar_stock_qty" )
 column=(type=char(10) update=yes updatewhereclause=yes name=user_id dbname="itemalter.user_id" )
 column=(type=char(60) update=yes updatewhereclause=yes name=rem dbname="itemalter.rem" )
 column=(type=char(14) update=yes updatewhereclause=yes name=do_no dbname="itemalter.do_no" )
 column=(type=long update=yes updatewhereclause=yes name=do_seq dbname="itemalter.do_seq" )
 column=(type=char(1) update=yes updatewhereclause=yes name=issue_flag dbname="itemalter.issue_flag" initial="Y" )
 column=(type=char(60) updatewhereclause=yes name=item_name2 dbname="GroupItem.item_name" )
 column=(type=char(2) updatewhereclause=yes name=uom2 dbname="GroupItem.uom" )
 column=(type=char(60) updatewhereclause=yes name=item_name1 dbname="GroupItem.item_name" )
 column=(type=char(2) updatewhereclause=yes name=uom1 dbname="GroupItem.uom" )
 column=(type=decimal(4) updatewhereclause=yes name=qoh dbname="qoh" )
 retrieve="  SELECT itemalter.alter_time      
       , itemalter.order_no        
       , itemalter.alter_date      
       , itemalter.src_item        
       , itemalter.src_qa          
       , itemalter.src_loc         
       , itemalter.seq             
       , itemalter.src_qty         
       , itemalter.src_stock_qty   
       , itemalter.src_lot         
       , itemalter.tar_item        
       , itemalter.tar_qa          
       , itemalter.tar_loc         
       , itemalter.tar_lot         
       , itemalter.tar_qty         
       , itemalter.tar_stock_qty   
       , itemalter.user_id         
       , itemalter.rem             
       , itemalter.do_no           
       , itemalter.do_seq          
       , itemalter.issue_flag      
       , groupitem_a.item_name     
       , groupitem_a.uom           
       , groupitem_b.item_name     
       , groupitem_b.uom           
       , qoh = 0.0000  
    FROM itemalter   
       , groupitem groupitem_a
       , groupitem groupitem_b  
   WHERE ( itemalter.tar_item = groupitem_a.item_no )   
     AND ( itemalter.src_item = groupitem_b.item_no )   
     AND ( itemalter.order_no = :as_order           )  
     AND ( itemalter.seq      = :ai_seq             )    
" update="itemalter" updatewhere=0 updatekeyinplace=no arguments=(("as_order", string),("ai_seq", number)) )
