global type gf_qrcode_create from function_object
end type

forward prototypes
global subroutine gf_qrcode_create (string arg_qrcode_name, string arg_data)
end prototypes

global subroutine gf_qrcode_create (string arg_qrcode_name, string arg_data);FILEDELETE("C:\BMP\"+arg_qrcode_name+".JPG")
	
run( "qrencode -o C:\BMP\"+arg_qrcode_name+".jpg '"+ arg_data + "' ")
end subroutine

