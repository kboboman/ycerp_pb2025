/*						 ,
				  D.PRODUCT_QTY, 
				  D.PRODUCT_PERCENT, 
				  D.UOM
*/
from equip  a left outer join  
            (  
                        select  equip_code, 
										  max(case when seq = '001' then  equip_data else '' end)  equip_data1,
										  max(case when seq = '002' then  equip_data else '' end)  equip_data2,
										  max(case when seq = '003' then  equip_data else '' end)  equip_data3,
										  max(case when seq = '004' then  equip_data else '' end)  equip_data4,
										  max(case when seq = '005' then  equip_data else '' end)  equip_data5,
										  max(case when seq = '006' then  equip_data else '' end)  equip_data6,
										  max(case when seq = '007' then  equip_data else '' end)  equip_data7,
										  max(case when seq = '008' then  equip_data else '' end)  equip_data8,
										  max(case when seq = '009' then  equip_data else '' end)  equip_data9,
										  max(case when seq = '010' then  equip_data else '' end)  equip_data10,
										  max(case when seq = '011' then  equip_data else '' end)  equip_data11,
										  max(case when seq = '012' then  equip_data else '' end)  equip_data12,              
										  max(case when seq = '013' then  equip_data else '' end)  equip_data13,              
										  max(case when seq = '014' then  equip_data else '' end)  equip_data14,              
										  max(case when seq = '015' then  equip_data else '' end)  equip_data15,              
										  max(case when seq = '016' then  equip_data else '' end)  equip_data16,              
										  max(case when seq = '017' then  equip_data else '' end)  equip_data17,              
										  max(case when seq = '018' then  equip_data else '' end)  equip_data18,              
										  max(case when seq = '001' then  data_value else '' end)  data_value1,
										  max(case when seq = '002' then  data_value else '' end)  data_value2,
										  max(case when seq = '003' then  data_value else '' end)  data_value3,
										  max(case when seq = '004' then  data_value else '' end)  data_value4,
										  max(case when seq = '005' then  data_value else '' end)  data_value5,
										  max(case when seq = '006' then  data_value else '' end ) data_value6,
										  max(case when seq = '007' then  data_value else '' end)  data_value7,
										  max(case when seq = '008' then  data_value else '' end)  data_value8,
										  max(case when seq = '009' then  data_value else '' end)  data_value9,
										  max(case when seq = '010' then  data_value else '' end)  data_value10,
										  max(case when seq = '011' then  data_value else '' end)  data_value11,
										  max(case when seq = '012' then  data_value else '' end)  data_value12,
										  max(case when seq = '013' then  data_value else '' end)  data_value13,
										  max(case when seq = '014' then  data_value else '' end)  data_value14,
										  max(case when seq = '015' then  data_value else '' end)  data_value15,
										  max(case when seq = '016' then  data_value else '' end)  data_value16,
										  max(case when seq = '017' then  data_value else '' end)  data_value17,
										  max(case when seq = '018' then  data_value else '' end)  data_value18
                         from equipdet 
                         where equip_code =  :arg_equip_code and kind = '1'
                        group by equip_code 
              ) b on a.equip_code = b.equip_code
            left outer join (  
											 select equip_code, 
											 max(case when seq = '001' then  gubun else '' end)  gubun1,
											 max(case when seq = '002' then  gubun else '' end)  gubun2,
											 max(case when seq = '003' then  gubun else '' end) gubun3,
											 max(case when seq = '004' then  gubun else '' end) gubun4,
											 max(case when seq = '005' then  gubun else '' end)  gubun5,
											 max(case when seq = '006' then  gubun else '' end)  gubun6,
											 max(case when seq = '007' then  gubun else '' end)  gubun7,
											 max(case when seq = '008' then  gubun else '' end)  gubun8,
											 max(case when seq = '009' then  gubun else '' end)  gubun9,
											 max(case when seq = '010' then  gubun else '' end)  gubun10,
/*											 max(case when seq = '011' then  gubun else '' end)  gubun11,
											 max(case when seq = '012' then  gubun else '' end)  gubun12,       
*/
											 
											 max(case when seq = '001' then  make_date else '' end)  make_date1,
											 max(case when seq = '002' then  make_date else '' end)  make_date2,
											 max(case when seq = '003' then  make_date else '' end)  make_date3,
											 max(case when seq = '004' then  make_date else '' end) make_date4,
											 max(case when seq = '005' then  make_date else '' end)  make_date5,
											 max(case when seq = '006' then  make_date else '' end ) make_date6,
											 max(case when seq = '007' then  make_date else '' end)  make_date7,
											 max(case when seq = '008' then  make_date else '' end)  make_date8,
											 max(case when seq = '009' then  make_date else '' end)  make_date9,
											 max(case when seq = '010' then  make_date else '' end)  make_date10,
/*
											 max(case when seq = '011' then  make_date else '' end)  make_date11,
											 max(case when seq = '012' then  make_date else '' end)  make_date12,
*/											 
											 max(case when seq = '001' then  make_com else '' end)  make_com1,
											 max(case when seq = '002' then  make_com else '' end)  make_com2,
											 max(case when seq = '003' then  make_com else '' end)  make_com3,
											 max(case when seq = '004' then  make_com else '' end)  make_com4,
											 max(case when seq = '005' then  make_com else '' end)  make_com5,
											 max(case when seq = '006' then  make_com else '' end ) make_com6,
											 max(case when seq = '007' then  make_com else '' end)  make_com7,
											 max(case when seq = '008' then  make_com else '' end)  make_com8,
											 max(case when seq = '009' then  make_com else '' end)  make_com9,
											 max(case when seq = '010' then  make_com else '' end)  make_com10,
/*
											 max(case when seq = '011' then  make_com else '' end)  make_com11,
											 max(case when seq = '012' then  make_com else '' end)  make_com12,
*/											 
											 max(case when seq = '001' then  spec else '' end)  spec1,
											 max(case when seq = '002' then  spec else '' end)  spec2,
											 max(case when seq = '003' then  spec else '' end)  spec3,
											 max(case when seq = '004' then  spec else '' end)  spec4,
											 max(case when seq = '005' then  spec else '' end)  spec5,
											 max(case when seq = '006' then  spec else '' end ) spec6,
											 max(case when seq = '007' then  spec else '' end)  spec7,
											 max(case when seq = '008' then  spec else '' end)  spec8,
											 max(case when seq = '009' then  spec else '' end)  spec9,
											 max(case when seq = '010' then  spec else '' end)  spec10,
/*
											 max(case when seq = '011' then  spec else '' end)  spec11,
											 max(case when seq = '012' then  spec else '' end)  spec12,
*/											 
											 max(case when seq = '001' then  special_text else '' end)  special_text1,
											 max(case when seq = '002' then  special_text else '' end)  special_text2,
											 max(case when seq = '003' then  special_text else '' end)  special_text3,
											 max(case when seq = '004' then  special_text else '' end)  special_text4,
											 max(case when seq = '005' then  special_text else '' end)  special_text5,
											 max(case when seq = '006' then  special_text else '' end ) special_text6,
											 max(case when seq = '007' then  special_text else '' end)  special_text7,
											 max(case when seq = '008' then  special_text else '' end)  special_text8,
											 max(case when seq = '009' then  special_text else '' end)  special_text9,
											 max(case when seq = '010' then  special_text else '' end)  special_text10
/*
											 max(case when seq = '011' then  special_text else '' end)  special_text11,
											 max(case when seq = '012' then  special_text else '' end)  special_text12
*/
                                 from equipdet 
                                 where equip_code =  :arg_equip_code and kind = '2'
                                group by equip_code 
            ) c on a.equip_code = c.equip_code
/*				LEFT OUTER JOIN 
            (

					SELECT EQUIP_CODE, YEAR, PRODUCT_QTY, PRODUCT_PERCENT, UOM
					  FROM EQUIP_CAPA
					 WHERE EQUIP_CODE = :ARG_EQUIP_CODE
					   and YEAR = CONVERT( CHAR(4), GETDATE(), 121) - 1

				) d ON a.equip_code = D.equip_code
*/
				left outer join 
				(
	
						 select equip_code, 
						 max(case when seq = '001' then  gubun else '' end)  spec_gubun1,
						 max(case when seq = '002' then  gubun else '' end)  spec_gubun2,
						 max(case when seq = '003' then  gubun else '' end)  spec_gubun3,
						 max(case when seq = '004' then  gubun else '' end)  spec_gubun4,
						 max(case when seq = '005' then  gubun else '' end)  spec_gubun5,
						 
						 max(case when seq = '001' then  spec1 else '' end)  spec1_1,
						 max(case when seq = '002' then  spec1 else '' end)  spec1_2,
						 max(case when seq = '003' then  spec1 else '' end)  spec1_3,
						 max(case when seq = '004' then  spec1 else '' end)  spec1_4,
						 max(case when seq = '005' then  spec1 else '' end)  spec1_5,
	
						 max(case when seq = '001' then  spec_value1 else '' end)  spec_value1_1,
						 max(case when seq = '002' then  spec_value1 else '' end)  spec_value1_2,
						 max(case when seq = '003' then  spec_value1 else '' end)  spec_value1_3,
						 max(case when seq = '004' then  spec_value1 else '' end)  spec_value1_4,
						 max(case when seq = '005' then  spec_value1 else '' end)  spec_value1_5,
	
						 max(case when seq = '001' then  spec2 else '' end)  spec2_1,
						 max(case when seq = '002' then  spec2 else '' end)  spec2_2,
						 max(case when seq = '003' then  spec2 else '' end)  spec2_3,
						 max(case when seq = '004' then  spec2 else '' end)  spec2_4,
						 max(case when seq = '005' then  spec2 else '' end)  spec2_5,
	
						 max(case when seq = '001' then  spec_value2 else '' end)  spec_value2_1,
						 max(case when seq = '002' then  spec_value2 else '' end)  spec_value2_2,
						 max(case when seq = '003' then  spec_value2 else '' end)  spec_value2_3,
						 max(case when seq = '004' then  spec_value2 else '' end)  spec_value2_4,
						 max(case when seq = '005' then  spec_value2 else '' end)  spec_value2_5,
	
						 max(case when seq = '001' then  spec3 else '' end)  spec3_1,
						 max(case when seq = '002' then  spec3 else '' end)  spec3_2,
						 max(case when seq = '003' then  spec3 else '' end)  spec3_3,
						 max(case when seq = '004' then  spec3 else '' end)  spec3_4,
						 max(case when seq = '005' then  spec3 else '' end)  spec3_5,
	
						 max(case when seq = '001' then  spec_value3 else '' end)  spec_value3_1,
						 max(case when seq = '002' then  spec_value3 else '' end)  spec_value3_2,
						 max(case when seq = '003' then  spec_value3 else '' end)  spec_value3_3,
						 max(case when seq = '004' then  spec_value3 else '' end)  spec_value3_4,
						 max(case when seq = '005' then  spec_value3 else '' end)  spec_value3_5,
	
	
						 max(case when seq = '001' then  etc else '' end)  etc1,
						 max(case when seq = '002' then  etc else '' end)  etc2,
						 max(case when seq = '003' then  etc else '' end)  etc3,
						 max(case when seq = '004' then  etc else '' end)  etc4,
						 max(case when seq = '005' then  etc else '' end)  etc5
	
						from equipdet 
						where equip_code = :arg_equip_code and kind = '3'
					  group by equip_code 					

				) e on a.equip_code = e.equip_code
            where a.equip_code = :arg_equip_code" update="equip" updatewhere=0 updatekeyinplace=no arguments=(("arg_equip_code", string)) )
