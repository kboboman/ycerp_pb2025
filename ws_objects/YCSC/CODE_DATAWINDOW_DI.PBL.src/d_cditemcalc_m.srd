$PBExportHeader$d_cditemcalc_m.srd
$PBExportComments$품목별계산식관리(1998/03/10,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=79741120 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=item_no dbname="itemcalc.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="itemcalc.qa" )
 column=(type=long update=yes updatewhereclause=yes name=calc_cd dbname="itemcalc.calc_cd" )
 column=(type=char(30) update=yes updatewhereclause=yes name=rem dbname="itemcalc.rem" values="	Y/	N" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 retrieve="  SELECT itemcalc.item_no   
       , itemcalc.qa        
       , itemcalc.calc_cd   
       , itemcalc.rem       
       , groupitem.item_name  
    FROM itemcalc
       , groupitem  
   WHERE ( itemcalc.item_no = groupitem.item_no )    
" update="itemcalc" updatewhere=0 updatekeyinplace=no )
