$PBExportHeader$d_ormondo_s2.srd
$PBExportComments$출고일자별 수주현황2(1999/7/19,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=1 selected.mouse=no )
header(height=160 color="12632256" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=68 color="553648127" )
table(column=(type=char(2) updatewhereclause=yes name=area dbname="area" values="반월	B/화곡동	H/부산	P/시화	S/" )
 column=(type=datetime updatewhereclause=yes name=due_date dbname="sale.due_date" )
 column=(type=decimal(2) updatewhereclause=yes name=issueum dbname="issueum" )
 column=(type=decimal(2) updatewhereclause=yes name=orderum dbname="orderum" )
 column=(type=long updatewhereclause=yes name=prodcnt dbname="prodcnt" )
 column=(type=char(1) updatewhereclause=yes name=prod dbname="prod" values="재고	J/       	P/" )
 column=(type=char(5) updatewhereclause=yes name=do_date dbname="do_date" )
 column=(type=char(14) updatewhereclause=yes name=order_no dbname="sale.order_no" )
 column=(type=char(4) updatewhereclause=yes name=sale_cust_no dbname="sale.cust_no" )
 column=(type=char(11) updatewhereclause=yes name=sale_scene_code dbname="sale.scene_code" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="customer.user_name" )
 retrieve="  SELECT DISTINCT area = substring(do.do_no,1,1),   
         sale.due_date,   
         issueum = sum(dodet.ship_qty),   
         orderum = sum(saledet.order_qty),   
         prodcnt =  count(itemjaego.item_no),   
         prod = case when  count(itemjaego.item_no) > 0 then 'J' else 'P' end,   
         do_date = convert(char(5), (substring( convert(char(8), do_date,11), 4,5))),   
         sale.order_no,   
         sale.cust_no,   
         sale.scene_code,
			customer.salesman user_name
from saledet with(nolock) inner join sale with(nolock) on  sale.order_no = saledet.order_no
                       inner join customer with(nolock) on sale.cust_no = customer.cust_no 
                       left outer  join scene with(nolock) on sale.cust_no    = scene.cust_no and sale.scene_code     = scene.scene_code
                       left outer join itemjaego with(nolock) on saledet.item_no = itemjaego.item_no and saledet.qa = itemjaego.qa
                                                                                  and ( itemjaego.area_no like :as_area )
                       inner join dodet with(nolock) on sale.order_no = dodet.sale_no
                       inner join do      with(nolock) on dodet.do_no = do.do_no                    
where   ( sale.open_close = 'O' ) and  
			        ( sale.salesman like :as_userid) and
               ( ( do.do_no like :as_area )  and 
      			  ( do.do_date between :ad_from and :ad_to )  and 
      			  ( customer.salesman like :as_user ))   
GROUP BY do.do_date,   
			   substring(do.do_no,1,1),
         sale.due_date,   
         sale.order_no,   
         sale.cust_no,   
         sale.scene_code,
		   	customer.salesman  

/*
    FROM sale,   
         saledet,   
         itemjaego,   
         dodet,
			customer,
			scene  
   WHERE ( saledet.item_no *= itemjaego.item_no) and  
         ( saledet.qa *= itemjaego.qa) and  
         ( itemjaego.area_no like :as_area ) and  
         ( saledet.order_no *= dodet.sale_no) and  
         ( saledet.seq_no *= dodet.seq_no) and  
         ( sale.order_no = saledet.order_no ) and  
         ( sale.cust_no = customer.cust_no ) and  
         ( sale.scene_code *= scene.scene_code ) and  
         ( sale.open_close = ~"O~" ) and  
			( sale.salesman like :as_userid) and 
         ( ( sale.order_no like :as_area ) and 
			  ( sale.order_date between :ad_from and :ad_to ) and 
			  ( customer.salesman like :as_user ) )   
GROUP BY sale.order_no,   
			substring(dodet.do_no,1,1),
         sale.due_date,   
         sale.cust_no,
         sale.scene_code,
			customer.cust_name,
			scene.scene_desc,
			customer.salesman
*/
" arguments=(("as_area", string),("ad_from", date),("ad_to", date),("as_user", string),("as_userid", string))  sort="do_date A order_no A " )
