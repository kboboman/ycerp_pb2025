table(column=(type=char(10) update=yes updatewhereclause=yes name=order_no dbname="purdet.order_no" initial=" " )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="purdet.item_no" initial=" " )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="purdet.qa" )
 column=(type=datetime update=yes updatewhereclause=yes name=due_date dbname="purdet.due_date" initial=" " )
 column=(type=char(2) update=yes updatewhereclause=yes name=uom dbname="purdet.uom" initial=" " )
 column=(type=char(2) updatewhereclause=yes name=purdet_com_uom dbname="purdet.com_uom" )
 column=(type=decimal(4) updatewhereclause=yes name=purdet_com_qty dbname="purdet.com_qty" )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=price dbname="purdet.price" initial=" " )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=order_qty dbname="purdet.order_qty" initial=" " )
 column=(type=decimal(4) update=yes updatewhereclause=yes name=rlse_qty dbname="purdet.rlse_qty" initial=" " )
 column=(type=char(30) updatewhereclause=yes name=supp_supp_name dbname="supp.supp_name" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=long updatewhereclause=yes name=purdet_cnt dbname="purdet.cnt" )
 column=(type=decimal(5) updatewhereclause=yes name=nrcpt_comqty dbname="nrcpt_comqty" )
 column=(type=datetime updatewhereclause=yes name=s dbname="s" )
 column=(type=datetime updatewhereclause=yes name=e dbname="e" )
 column=(type=char(14) updatewhereclause=yes name=purdet_sale_no dbname="purdet.sale_no" )
 retrieve="  SELECT purdet.order_no       
       , purdet.item_no        
       , purdet.qa             
       , purdet.due_date       
       , purdet.uom            
       , purdet.com_uom        
       , purdet.com_qty        
       , purdet.price          
       , purdet.order_qty      
       , purdet.rlse_qty       
       , supp.supp_name        
       , groupitem.item_name   
       , purdet.cnt         
       , nrcpt_comqty = dbo.uf_getqty( purdet.item_no,purdet.qa, purdet.com_uom, purdet.order_qty - purdet.rlse_qty)
       , s            = convert(smalldatetime, :arg_startday, 111)   
       , e            = convert(smalldatetime, :arg_endday,   111)
       , purdet.sale_no
    FROM purdet   
       , pur      
       , supp     
       , groupitem  
   WHERE ( purdet.order_no     = pur.order_no      )   
     AND ( pur.supp_no         = supp.supp_no      )   
     AND ( purdet.item_no      = groupitem.item_no )   
     AND ( ( pur.supp_no    LIKE :arg_supp ) AND  
           ( pur.open_close    = 'O'       ) AND  
           ( pur.po_print      = 'Y'       ) 
         ) 
     AND ( pur.order_date    between :arg_startday AND :arg_endday )  
     AND ( purdet.order_qty        > purdet.rlse_qty               )  
     AND ( ( pur.order_no   LIKE :as_area + '%' ) or
           ( :as_area = 'S'  AND pur.order_no like 'PUR%')
         )
   ORDER BY purdet.item_no ASC,   
            purdet.qa ASC   
" arguments=(("arg_supp", string),("arg_startday", date),("arg_endday", date),("as_area", string))  sort="item_no A qa A order_no A " )
group(level=1 header.height=0 trailer.height=72 by=("item_no" ) header.color="536870912" trailer.color="12639424" )
