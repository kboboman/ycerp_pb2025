$PBExportHeader$d_whlocqoh_s.srd
$PBExportComments$저장소현재고 DropDownDataWindow(1998/02/06 - 김구현)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=68 color="8421504" )
detail(height=72 color="553648127" )
table(column=(type=char(10) updatewhereclause=yes name=loc_no dbname="itemloc.loc_no" )
 column=(type=char(30) updatewhereclause=yes name=location_loc_name dbname="location.loc_name" )
 column=(type=char(20) updatewhereclause=yes name=itemloc_qa dbname="itemloc.qa" )
 column=(type=decimal(4) updatewhereclause=yes name=qoh dbname="itemloc.qoh" initial=" " )
 column=(type=decimal(2) updatewhereclause=yes name=notsale dbname="notsale" )
 retrieve="  SELECT itemloc.loc_no
       , location.loc_name
       , itemloc.qa
       , itemloc.qoh
       , notsale = isnull(sum(csaledet.order_qty), 0) + isnull(sum(crout.order_qty), 0)
    FROM itemloc,   
         location,  
			(select order_qty = sum( saledet.order_qty  -  saledet.rlse_qty )
			   from saledet, sale
			  WHERE saledet.order_qty > saledet.rlse_qty
				 and sale.order_no     = saledet.order_no
				 and sale.open_close   = 'O'
				 and saledet.item_no   = :as_item 
				 and saledet.qa        = :as_qa
				 and order_date       >= DATEADD(month, -2, convert(smalldatetime, getdate(), 111))
			) csaledet,

			(select order_qty = sum( saledet.order_qty  -  saledet.rlse_qty )
			   from sale, saledet, rout
			  WHERE saledet.item_no   = :as_item 
				 and saledet.qa        = :as_qa
				 and saledet.order_qty > saledet.rlse_qty
				 and sale.order_no     = saledet.order_no
				 and sale.open_close   = 'O'
				 and order_date       >= DATEADD(month, -2, convert(smalldatetime, getdate(), 111))
				 and rout.item_no      = saledet.item_no
				 and rout.qa           = saledet.qa
				 and rout.item_no     <> rout.assembly
			) crout
   WHERE ( itemloc.loc_no          = location.loc_no ) 
     and ( ( itemloc.item_no       = :as_item ) and 
           ( itemloc.qa            = :as_qa   ) and
           ( itemloc.qoh          >= 0        ) 
         )    
   group by itemloc.loc_no, itemloc.qa, location.loc_name, itemloc.qoh
   order by location.loc_name, itemloc.qa
" arguments=(("as_item", string),("as_qa", string))  sort="location_loc_name A " )
