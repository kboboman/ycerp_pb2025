$PBExportHeader$d_irtype_c.srd
$PBExportComments$입출고형태
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=char(2) updatewhereclause=yes name=io dbname="io" )
 column=(type=char(20) updatewhereclause=yes key=yes name=inaudit_type dbname="iotype.inaudit_type" )
 column=(type=char(50) updatewhereclause=yes name=remarks dbname="iotype.remarks" )
 column=(type=char(6) updatewhereclause=yes name=cat dbname="cat" )
 column=(type=char(1) updatewhereclause=yes name=useyn dbname="useyn" )
 retrieve="  SELECT io    = SUBSTRING(inaudit_type,1,1)
       , inaudit_type
       , remarks
       , cat   = 'SYSTEM'
       , useyn = (CASE WHEN SUBSTRING(inaudit_type,2,1) NOT IN ('O','P','R','S','W') THEN 'Y' ELSE 'N' END)
    FROM iotype
   WHERE SUBSTRING(inaudit_type,1,1) NOT IN ('%')

  UNION ALL
  SELECT io    = substring(item_cd,1,1)
       , inaudit_type = item_cd
       , remarks = item_nm 
       , cat   = 'LOCAL'
       , useyn = 'Y'
    FROM codemst 
   WHERE type  = '지점재고_입출형태'
" update="iotype" updatewhere=0 updatekeyinplace=no  sort="useyn D io D inaudit_type A " )
