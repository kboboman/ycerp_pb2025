 column=(type=char(71) update=yes updatewhereclause=yes name=cust_sale_address dbname="address" )
 column=(type=char(40) update=yes updatewhereclause=yes name=cust_sale_rem dbname="cust_sale.rem" )
 column=(type=char(60) updatewhereclause=yes name=cust_sale_kind_company_name1 dbname="cust_sale.kind_company_name1" )
 column=(type=char(60) updatewhereclause=yes name=cust_sale_kind_company_name2 dbname="cust_sale.kind_company_name2" )
 column=(type=char(60) updatewhereclause=yes name=cust_sale_kind_company_name3 dbname="cust_sale.kind_company_name3" )
 column=(type=char(60) updatewhereclause=yes name=cust_sale_kind_company_name4 dbname="cust_sale.kind_company_name4" )
 column=(type=char(1) updatewhereclause=yes name=cust_sale_close_yn dbname="cust_sale.close_yn" values="진행	1/완료	2/" )
 column=(type=char(8) updatewhereclause=yes name=cust_sale_write_date dbname="cust_sale.write_date" )
 column=(type=char(10) updatewhereclause=yes name=login_customer_user_name dbname="login.customer_user_name" )
 retrieve="select  a.lot_no,
           a.yyyymm,
           a.salesman,
           b.user_name,
		a.cust_no,
           c.cust_name,
           a.company_name,
           a.project_name,
           a.amt,
           a.kind_qty1,
           a.kind_amt1,
           a.kind_qty2,
           a.kind_amt2,
           a.kind_qty3,
           a.kind_amt3,          
           a.kind_qty4,
           a.kind_amt4,
           a.area_nm + ' ' + a.address address,
           a.rem,
           a.kind_company_name1,
           a.kind_company_name2,
           a.kind_company_name3,
           a.kind_company_name4,
           a.close_yn,
           a.write_date,
           d.user_name customer_user_name
from cust_sale a left outer join login b on a.salesman = b.user_id
                            left outer join customer c on a.cust_no = c.cust_no
					  left outer join login d on (case when :as_gubun = '1' then c.salesman
														    when :as_gubun = '2' then c.imwon_user_id
													 end) = d.user_id
where a.yyyymm like :as_yyyymm
     and a.close_yn like :as_close_yn
     and (case when :as_gubun = '1' then isnull(c.salesman, :as_salesman)
                     when :as_gubun = '2' then isnull(c.imwon_user_id, :as_salesman)
             end) like :as_salesman  
" arguments=(("as_yyyymm", string),("as_close_yn", string),("as_salesman", string),("as_gubun", string))  sort="cust_sale_lot_no A " )
