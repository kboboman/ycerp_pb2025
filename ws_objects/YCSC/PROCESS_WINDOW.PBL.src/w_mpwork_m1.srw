boolean livescroll = true
borderstyle borderstyle = stylelowered!
end type

event keydown;long ll_row,i
string ls_wc,ls_wc1,ls_flag
IF keyflags = 1 THEN
   IF keydown(KeyLeftButton!) THEN
		ll_row = il_row
      if ll_row < 1 then return
      this.accepttext()
		for i = ll_row to 1 step -1
			 if i <> ll_row then
				 if this.IsSelected(i) = true then
					 exit
				 end if
			 end if
          this.SelectRow(i, NOT this.IsSelected(i))
		next
	END IF
END IF
end event

event itemchanged;long ll_row,ll_cnt

long ll_rowcount,ll_rowcount1,ll_find,ll_count
string ls_plan,ls_loc,ls_assy,ls_assyqa,ls_uom,ls_qa1
real lr_qty,lr_hebe,lr_len

this.accepttext()
ll_cnt = this.getrow()
choose case dwo.name
	case 'make_qty'
		ls_assy = trim(this.object.assembly[ll_cnt])
		ls_assyqa = trim(this.object.assembly_qa[ll_cnt])
		ls_uom = trim(this.object.uom[ll_cnt])
		lr_qty = this.object.make_qty[ll_cnt]
		setnull(lr_hebe)
		select price_c into :lr_hebe from item where item_no = :ls_assy and qa = :ls_assyqa;
		if isnull(lr_hebe) then
			lr_hebe = 0
		end if
			
		choose case trim(ls_uom)
			case 'M'
		       lr_len = real(long(MidA(ls_assyqa,15,5)) / 1000.0)
				 this.object.hebe[row] = lr_len * lr_hebe * lr_qty
			case else
				 this.object.hebe[row] = lr_hebe * lr_qty
		end choose		
end choose
end event

event clicked;if row < 1 then return
if cbx_2.checked = false then return

this.selectrow(row, NOT THIS.isselected(row))
il_row = row	
	
end event

type cb_3 from commandbutton within tabpage_2
integer x = 2912
integer y = 8
integer width = 686
integer height = 84
integer taborder = 180
boolean bringtotop = true
integer textsize = -10
integer weight = 700
fontcharset fontcharset = hangeul!
fontpitch fontpitch = fixed!
fontfamily fontfamily = modern!
string facename = "굴림체"
string text = "사용자재등록으로-->"
end type

event clicked;long    ll_rowcount, ll_row, ll_found, ll_rout_cnt, ll_cnt = 0, ll_cnt2, ll_row2, ll_firstrow
string  ls_plan, ls_item, ls_qa, ls_rout_item, ls_rout_qa, ls_name, ls_uom, ls_qa1
string  ls_assy, ls_assyqa, ls_assyqa1, ls_null, ls_sale
int     li_seq
integer li_oper

if isnull(id_date) then
	MessageBox("오류","작업일자를 입력하십시오.",exclamation!)
	return
end if

if is_wc = "" or isnull(is_wc) then
	MessageBox('오류','작업장을 입력하십시오.',exclamation!)
	return
end if

dw5.setredraw(false)
ll_firstrow = 100
ll_rowcount = dw4.rowcount()

for ll_row = 1 to ll_rowcount
	if dw4.isselected(ll_row) then
		ls_plan = trim(dw4.object.order_no[ll_row])
		if dw5.rowcount() < 1 then
			dw5.retrieve(dw_area.object.area[1], id_date,is_wc)	// 사용자재등록
		end if
		
		dw5.accepttext()
		if dw5.rowcount() > 0 then
			ll_found = dw5.find("order_no = '" + ls_plan + "'",1,dw5.rowcount())
			if ll_found > 0 then
				if MessageBox("확인",string(ll_found, "000") + " 번째 자료는 이미 이동되었습니다~r~n" + &
										"재이동 하시겠습니까", Exclamation!, OKCancel!, 2) = 1 then
					ll_found = 0
				end if
			end if
		else
			ll_found = 0
		end if
		
		if ll_found = 0 then
			if LeftA(is_wc,1) = "F" then		// 성형반들
				ls_rout_item = "M3S1S30K00"	// GI 스리팅 COIL 0.30
				ls_qa        = trim(dw4.object.qa[ll_row])
				ls_rout_qa   = LeftA(ls_qa,8) + "X0000X00000"
			else
				ls_sale    = trim(dw4.object.sale_no[ll_row])
				li_seq     = dw4.object.seq_no[ll_row]
				ls_item    = trim(dw4.object.item_no[ll_row])
				ls_qa      = trim(dw4.object.qa[ll_row])
				ls_assy    = trim(dw4.object.assembly[ll_row])
				ls_assyqa  = trim(dw4.object.assembly_qa[ll_row])
				ls_qa1     = LeftA(ls_qa,13) + "X00000"
				ls_assyqa1 = LeftA(ls_assyqa,13) + "X00000"
				
				// 제품별공정
				setnull(li_oper)
				SELECT operation INTO :li_oper 
				  FROM routtempnew
				 WHERE item_no   = :ls_item   AND qa      = :ls_qa
				   AND assy_item = :ls_assy   AND assy_qa = :ls_assyqa
				   AND sale_no   = :ls_sale   AND seq_no  = :li_seq ;
				if sqlca.sqlcode = 100 or isnull(li_oper) then	// Fetched row not found
					SELECT operation INTO :li_oper 
					  FROM rout
					 WHERE item_no  = :ls_item  AND qa      = :ls_qa1
					   AND assembly = :ls_assy  AND assy_qa = :ls_assyqa1;
					if li_oper > 1 then
					   li_oper = li_oper - 1
					else
					   li_oper = 1
					end if
					 
					SELECT assembly, assy_qa INTO :ls_rout_item, :ls_rout_qa 
					  FROM rout
					 WHERE rout.item_no   = :ls_item AND rout.qa = :ls_qa1
					   AND rout.operation = :li_oper;
					ls_rout_qa = LeftA(ls_rout_qa,13) + MidA(ls_qa,14,6)
				else	// 분할?
					if li_oper > 1 then
						li_oper = li_oper - 1
					else
						li_oper = 1
					end if
							 
					SELECT assy_item, assy_qa INTO :ls_rout_item, :ls_rout_qa 
					  FROM routtempnew
					 WHERE routtempnew.item_no   = :ls_item AND routtempnew.qa = :ls_qa
					   AND routtempnew.operation = :li_oper AND sale_no = :ls_sale   AND seq_no = :li_seq;						 
					if sqlca.sqlcode = 100 or isnull(li_oper) then
						SELECT operation INTO :li_oper 
						  FROM rout
						 WHERE item_no  = :ls_item  AND qa = :ls_qa1
						   AND assembly = :ls_assy  AND assy_qa = :ls_assyqa1;
						if li_oper > 1 then
							li_oper = li_oper - 1
						else
							li_oper = 1
						end if
						 
						SELECT assembly, assy_qa INTO :ls_rout_item, :ls_rout_qa 
						  FROM rout
						 WHERE rout.item_no   = :ls_item AND rout.qa = :ls_qa1
						   AND rout.operation = :li_oper;
							
						ls_rout_qa = LeftA(ls_rout_qa,13) + MidA(ls_qa,14,6)
					end if
				end if
			end if

			ll_row2 = dw5.insertrow(0)
			if ll_firstrow > ll_row2 then ll_firstrow = ll_row2
			
		   dw5.object.use_date[ll_row2]       = id_date
		   dw5.object.wc_no[ll_row2]          = trim(dw_2.object.wc_no[1])
			dw5.object.order_no[ll_row2]       = dw4.object.order_no[ll_row]
			dw5.object.item_no[ll_row2]        = ls_rout_item
			dw5.object.qa[ll_row2]             = ls_rout_qa
			dw5.object.color[ll_row2]          = dw4.object.color[ll_row]
			SELECT item_name, uom INTO :ls_name, :ls_uom 
			  FROM groupitem
			 WHERE item_no = :ls_rout_item;
			dw5.object.item_item_name[ll_row2] = ls_name
			dw5.object.uom[ll_row2]            = ls_uom
			dw5.object.use_qty[ll_row2]        = dw4.object.make_qty[ll_row]
			ll_cnt++
			
			setnull(ls_null)
		   dw5.object.loc_no[ll_row2]  = trim(dw_2.object.loc_no[1])
		   dw5.object.area_no[ll_row2] = dw_area.object.area[1]
		end if
	end if
next

if ll_cnt > 0  then
	dw5.scrolltorow(ll_firstrow)
//	dw5.triggerevent(rowfocuschanged!)
	dw5.setredraw(true)
	tab_1.selecttab(3)
else
	MessageBox("확인","이동할 자료를 선택하십시요")
end if
dw5.setredraw(true)

cbx_2.checked = false	// 작업일보등록->사용선택
dw4.selectrow(0,false)

end event

