 column=(type=char(14) update=yes updatewhereclause=yes key=yes name=sos_no dbname="sos_no" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=seq dbname="seq" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(11) updatewhereclause=yes name=scene_code dbname="scene_code" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(4) update=yes updatewhereclause=yes name=color dbname="color" )
 column=(type=datetime update=yes updatewhereclause=yes name=prt_date dbname="prt_date" )
 column=(type=char(1) updatewhereclause=yes name=chk_modify dbname="chk_modify" )
 retrieve="  SELECT cust_name  = c.cust_name
       , scene_desc = s.scene_desc
       , metrial    = itemsosdet.metrial
       , pgm_no     = itemsosdet.pgm_no
       , assembly   = itemsosdet.assembly
       , w1         = isnull(itemsosdet.w1,0)
       , w2         = isnull(itemsosdet.w2,0)
       , h1         = isnull(itemsosdet.h1,0)
       , h2         = isnull(itemsosdet.h2,0)
       , qty        = isnull(itemsosdet.qty,0)
       , width      = isnull(itemsosdet.width,0)
       , height     = isnull(itemsosdet.height,0)
       , sale_no    = itemsosdet.sale_no
       , seq_no     = itemsosdet.seq_no  
       , salerem    = saledet.rem
       , askrem     = itemsosdet.askrem
       , rem        = itemsosdet.rem
       , chk        = 'N'   

       , sos_no     = itemsosdet.sos_no   
       , seq        = itemsosdet.seq   
       , cust_no    = sale.cust_no
       , scene_code = sale.scene_code
       , item_no    = itemsosdet.item_no   
       , item_name  = groupitem.item_name
       , qa         = itemsosdet.qa   
       , color      = itemsosdet.color   
       , prt_date   = itemsosdet.prt_date
       , chk_modify = 'N'
    FROM itemsosdet
         LEFT OUTER JOIN itemsos    (nolock) ON itemsosdet.sos_no  = itemsos.sos_no     
         LEFT OUTER JOIN saledet    (nolock) ON itemsosdet.sale_no = saledet.order_no AND itemsosdet.seq_no = saledet.seq_no
         LEFT OUTER JOIN sale       (nolock) ON itemsosdet.sale_no = sale.order_no
         LEFT OUTER JOIN customer C (nolock) ON sale.cust_no       = c.cust_no
         LEFT OUTER JOIN scene    S (nolock) ON sale.scene_code    = s.scene_code
         LEFT OUTER JOIN groupitem  (nolock) ON itemsosdet.item_no = groupitem.item_no
   WHERE itemsosdet.sos_no   = :as_sosno 
" update="itemsosdet" updatewhere=0 updatekeyinplace=no arguments=(("as_sosno", string))  sort="seq A " )
