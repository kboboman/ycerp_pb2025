$PBExportComments$선매출현황 REPORT(1998/05/15, 정재수)
release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 print.documentname="" print.orientation = 1 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 9 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=604 color="536870912" )
summary(height=80 color="536870912" )
footer(height=0 color="536870912" )
detail(height=68 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=aroiinv_cust_no dbname="aroiinv.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=datetime updatewhereclause=yes name=aroiinv_oi_date dbname="aroiinv.oi_date" )
 column=(type=decimal(4) updatewhereclause=yes name=aroiinv_aroiinv_cash dbname="aroiinv.aroiinv_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=aroiinv_aroiinv_rate dbname="aroiinv.aroiinv_rate" )
 column=(type=char(40) updatewhereclause=yes name=aroiinv_rem dbname="aroiinv.rem" )
 column=(type=decimal(4) updatewhereclause=yes name=aroiinv_rem_amt dbname="aroiinv.rem_amt" )
 column=(type=decimal(4) updatewhereclause=yes name=aroiinv_ship_cost dbname="aroiinv.ship_cost" )
 column=(type=char(12) updatewhereclause=yes name=aroiinv_aroiinv_no dbname="aroiinv.aroiinv_no" )
 column=(type=datetime updatewhereclause=yes name=c_start dbname="c_start" )
 column=(type=datetime updatewhereclause=yes name=c_end dbname="c_end" )
 retrieve="  SELECT aroiinv.cust_no,   
         customer.cust_name,   
         aroiinv.oi_date,   
         aroiinv.aroiinv_cash,   
         aroiinv.aroiinv_rate,   
         aroiinv.rem,   
         aroiinv.rem_amt,   
         aroiinv.ship_cost,   
         aroiinv.aroiinv_no , 
         c_start = convert(smalldatetime, :ad_start, 111),   
         c_end = convert(smalldatetime, :ad_end, 111)
    FROM aroiinv,   
         customer  
   WHERE ( aroiinv.cust_no = customer.cust_no ) and  
         ( ( aroiinv.inv_type = 'N' ) AND  
         ( aroiinv.oi_date between :ad_start and :ad_end ) AND  
         ( aroiinv.delete_flag = 'N' ) )    
" arguments=(("ad_start", date),("ad_end", date))  sort="customer_cust_name A aroiinv_oi_date A aroiinv_aroiinv_no A " )
group(level=1 header.height=0 trailer.height=80 by=("aroiinv_cust_no" ) header.color="536870912" trailer.color="536870912" )
