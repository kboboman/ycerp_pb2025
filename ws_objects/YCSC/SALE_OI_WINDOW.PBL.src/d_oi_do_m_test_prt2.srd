 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"customer~" )  TABLE(NAME=~"do~" )  TABLE(NAME=~"dodet~" )  TABLE(NAME=~"groupitem~" )  TABLE(NAME=~"scene~" ) COLUMN(NAME=~"do.do_no~") COLUMN(NAME=~"do.do_date~") COLUMN(NAME=~"do.shipto_addr~") COLUMN(NAME=~"do.do_cash~") COLUMN(NAME=~"do.do_rate~") COLUMN(NAME=~"do.do_total~") COLUMN(NAME=~"do.dr_hp~") COLUMN(NAME=~"dodet.oi_no~") COLUMN(NAME=~"dodet.qa~") COLUMN(NAME=~"dodet.ship_qty~") COLUMN(NAME=~"dodet.price~") COLUMN(NAME=~"dodet.uom~") COLUMN(NAME=~"dodet.rate_cash~") COLUMN(NAME=~"dodet.rem~") COLUMN(NAME=~"groupitem.item_name~") COLUMN(NAME=~"scene.scene_desc~") COLUMN(NAME=~"customer.cust_name~") COLUMN(NAME=~"customer.captain_name~") COLUMN(NAME=~"do.rem~") COLUMN(NAME=~"do.tel_no~") COLUMN(NAME=~"do.curr_code~") COLUMN(NAME=~"customer.round~") COLUMN(NAME=~"dodet.item_no~") COLUMN(NAME=~"do.ship_amount~") COLUMN(NAME=~"do.ship_flag~") COLUMN(NAME=~"do.shipamt_case~")    JOIN (LEFT=~"customer.cust_no~"    OP =~"=~"RIGHT=~"do.cust_no~" )    JOIN (LEFT=~"do.do_no~"    OP =~"=~"RIGHT=~"dodet.do_no~" )    JOIN (LEFT=~"dodet.item_no~"    OP =~"=~"RIGHT=~"groupitem.item_no~" )    JOIN (LEFT=~"do.cust_no~"    OP =~"=~"RIGHT=~"scene.cust_no~" )WHERE(    EXP1 =~"do.do_no~"   OP =~"=~"    EXP2 =~":as_cust_no~" ) ) ARG(NAME = ~"as_cust_no~" TYPE = string) " arguments=(("as_cust_no", string)) )
