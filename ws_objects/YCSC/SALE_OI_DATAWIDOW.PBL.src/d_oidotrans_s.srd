$PBExportHeader$d_oidotrans_s.srd
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 selected.mouse=no )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=80 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(14) updatewhereclause=yes name=trans_no dbname="trans_no" )
 column=(type=char(14) updatewhereclause=yes name=do_no dbname="do_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(1) updatewhereclause=yes name=cc_check dbname="cc_Check" values="	Y/	N" )
 retrieve="SELECT a.trans_no
	  , a.do_no
	  , a.cust_name
	  , a.cc_Check
  FROM (
		 SELECT a.trans_no
				, a.do_no
				, b.cust_name
				, 'Y' as cc_Check
			FROM dotransdet A
				  LEFT OUTER JOIN customer B  ON  a.cust_no  = b.cust_no
		  WHERE ( a.cust_no = :as_cust_no and :as_trans  = 'Y' and substring(a.do_no,3,8)  between :as_start and :as_end )

		 UNION 

		 SELECT 'NEW' trans_no
				, a.do_no
				, b.cust_name
				, 'N' as cc_Check
			FROM do A
				  LEFT OUTER JOIN customer B  ON  a.cust_no  = b.cust_no
		  WHERE ( a.cust_no = :as_cust_no and :as_trans  = 'N' and substring(a.do_no,3,8)  between :as_start and :as_end )
			 AND NOT EXISTS ( SELECT do_no FROM dotransdet WHERE do_no = a.do_no )
		 ) A
 ORDER BY a.trans_no, a.do_no
" arguments=(("as_cust_no", string),("as_start", string),("as_end", string),("as_trans", string)) )
