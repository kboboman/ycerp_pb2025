footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(30) updatewhereclause=yes name=loc_name dbname="location.loc_name" )
 column=(type=char(10) updatewhereclause=yes name=itemloc_item_no dbname="itemloc.item_no" )
 column=(type=char(20) updatewhereclause=yes name=itemloc_qa dbname="itemloc.qa" )
 column=(type=decimal(4) updatewhereclause=yes name=eom_qoh dbname="eom_qoh" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(4) updatewhereclause=yes name=ineoym_cyear dbname="ineoym.cyear" )
 column=(type=char(2) updatewhereclause=yes name=ineoym_cmon dbname="ineoym.cmon" )
 column=(type=decimal(4) updatewhereclause=yes name=qoh dbname="qoh" )
 column=(type=decimal(4) updatewhereclause=yes name=stock dbname="stock" )
 column=(type=char(2) updatewhereclause=yes name=groupitem_uom dbname="uom" )
 column=(type=char(22) updatewhereclause=yes name=title dbname="title" )
 retrieve="  SELECT location.loc_name
       , itemloc.item_no     
       , itemloc.qa           
       , eom_qoh = itemloc.qoh - isnull(cday.rcpt, 0) + isnull(cday.issue, 0)
       , groupitem.item_name   
       , ineoym.cyear   
       , ineoym.cmon    
       , qoh     = ineoym.qoh   
       , stock   = ineoym.stock_qty
       , uom     = (case groupitem.uom when 'M'  then 'EA'
                                       when 'M2' then 'EA'
                                       else groupitem.uom
                    end)
       , title   = convert(char(4),:as_year) + '년 ' + convert(char(2), :as_mon) + '월 실사목록표'
    FROM  itemloc with(nolock) left outer join  ineoym with(nolock) on itemloc.item_no = ineoym.item_no and  itemloc.qa = ineoym.qa and itemloc.loc_no = ineoym.loc_no
																			AND ineoym.cyear       = :as_year
																		     AND ineoym.cmon        = :as_mon
											  inner join  groupitem with(nolock) on  itemloc.item_no = groupitem.item_no          
											  inner join location with(nolock) on itemloc.loc_no       = location.loc_no
											  left outer join (
																	SELECT item_no, qa, rcpt = sum(rcpt_qty), issue = sum(issue_qty) 
																		FROM ineoday with(nolock)
																	  WHERE cdate > rtrim(:as_year) + rtrim(:as_mon) + '99'
																		 AND loc_no = :as_loc 
																	  GROUP BY item_no, qa
 															  ) cday on  itemloc.item_no = cday.item_no  and  itemloc.qa   = cday.qa
   WHERE (     
				    ( itemloc.loc_no     = :as_loc          ) AND  
                         ( itemloc.item_no like :as_item AND groupitem.use_flag = 'Y' AND groupitem.item_name like :as_name ) AND 
                         ( itemloc.item_no    < 'PZZZ'          ) 
                 )           
/*       
    FROM location 
       , itemloc     
       , ineoym      
       , groupitem   
       , (SELECT item_no, qa, rcpt = sum(rcpt_qty), issue = sum(issue_qty) 
            FROM ineoday
           WHERE cdate > rtrim(:as_year) + rtrim(:as_mon) + '99'
             AND loc_no = :as_loc 
           GROUP BY item_no, qa
         ) cday
   WHERE ( itemloc.item_no     *= ineoym.item_no    ) and  
         ( itemloc.qa          *= ineoym.qa         ) and  
         ( itemloc.loc_no      *= ineoym.loc_no     ) and  
         ( itemloc.item_no     *= cday.item_no      ) and  
         ( itemloc.qa          *= cday.qa           ) and  
         ( itemloc.item_no      = groupitem.item_no ) and
         ( itemloc.loc_no       = location.loc_no   ) and  
         ( ( itemloc.loc_no     = :as_loc         ) AND  
           ( ineoym.cyear       = :as_year        ) AND  
           ( ineoym.cmon        = :as_mon         ) AND  
           ( itemloc.item_no like :as_item AND groupitem.use_flag = 'Y' AND groupitem.item_name like :as_name ) AND 
           ( itemloc.item_no    < 'PZZZ'          ) 
         )
*/          
         
/* 
  UNION
  
  SELECT location.loc_name
       , ineoym.item_no      
       , ineoym.qa           
       , eom_qoh = 0 - isnull(cday.rcpt, 0) + isnull(cday.issue, 0)
       , groupitem.item_name          
       , ineoym.cyear                 
       , ineoym.cmon                  
       , qoh     = ineoym.qoh         
       , stock   = ineoym.stock_qty   
       , uom     = (case groupitem.uom when 'M'  then 'EA'
                                       when 'M2' then 'EA'
                                       else groupitem.uom
                    end)
       , title   = convert(char(4),:as_year) + ~"년 ~" + convert(char(2), :as_mon) + ~"월 실사목록표~"
    FROM location 
       , ineoym      
       , groupitem   
       , (SELECT item_no, qa, rcpt = sum(rcpt_qty), issue = sum(issue_qty) 
            FROM ineoday
           WHERE cdate > rtrim(:as_year) + rtrim(:as_mon) + '99'
             AND loc_no = :as_loc 
           GROUP BY item_no, qa
         ) cday
   WHERE ( ineoym.item_no     *= cday.item_no      )   
     AND ( ineoym.qa          *= cday.qa           )   
     AND ( ineoym.item_no      = groupitem.item_no )   
     AND ( ineoym.loc_no       = location.loc_no   )   
     AND ( ( ineoym.loc_no     = :as_loc  ) AND  
           ( ineoym.cyear      = :as_year ) AND  
           ( ineoym.cmon       = :as_mon  ) AND  
           ( ineoym.item_no LIKE :as_item AND groupitem.use_flag = 'Y' AND groupitem.item_name LIKE :as_name ) AND  
           ( ineoym.item_no < 'PZZZ' )
         )  
     AND ( NOT EXISTS ( SELECT * FROM itemloc WHERE itemloc.item_no = ineoym.item_no and itemloc.qa =  ineoym.qa ) )
*/
" arguments=(("as_loc", string),("as_year", string),("as_mon", string),("as_item", string),("as_name", string))  sort="groupitem_item_name A itemloc_qa A " )
