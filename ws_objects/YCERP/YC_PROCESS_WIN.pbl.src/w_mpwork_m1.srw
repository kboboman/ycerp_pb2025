type variables
string is_select1,is_where1,is_clause1, is_select2, is_clause2
string is_wc 
date   id_date

DataWindowChild idwc_coil6, idwc_qa
DataWindowChild idwc_coil,  idwc_area, idwc_loc, idwc_wc

DataWindow      dw3, dw4, dw5, dw6, dw7, dw8, dw9, dw10, dw11
int  ii_sw = 0
long il_row
gs_itembaldo_str ist_code

end variables

forward prototypes
public function boolean wf_dw3_itemchk ()
public function boolean wf_dw5_update ()
public function boolean wf_dw6_update ()
public function boolean wf_dw5_delete ()
public function boolean wf_dw5_insert ()
public subroutine wf_cleardddw (datawindow arg_dw)
public subroutine wf_coildddw (datawindow arg_dw, string as_item, string as_qa, string as_loc)
public subroutine wf_sheetdddw (datawindow arg_dw, string as_item, string as_qa, string as_loc)
public function string wf_coil (long al_row)
public function string wf_newcoil (string as_item, string as_loc)
public function boolean wf_oc (string arg_lot, string arg_loc)
public function boolean wf_itemselect (datawindow arg_dw, string arg_ms, integer ai_row)
public function boolean wf_dw4_update ()
end prototypes

public function boolean wf_dw3_itemchk ();dwItemStatus l_status
int    i, li_exist
string ls_item, ls_qa

for i = 1 to dw3.rowcount()
   l_status = dw3.GetItemStatus(i,0, Primary!)
   if l_status <> NotModified! then
		ls_item = trim(dw3.GetItemString(i, "assy_item")) 
		ls_qa   = trim(dw3.GetItemString(i, "assy_qa"))
		SELECT count(*) INTO :li_exist 
		  FROM item
		 WHERE item_no = :ls_item AND qa = :ls_qa;
		if sqlca.sqlcode = 100 or li_exist = 0 then
		   MessageBox("오류","작업일보대상항목의 " + string(i) + " 번째 물품이 잘못되었습니다.",exclamation!)
		   return false
		end if
	end if
next

return true

end function

public function boolean wf_dw5_update ();// 사용자재등록
//	((sfcuse.coil_no         IS NULL                  ) and
//	 (substring(sfcuse.item_no,1,4) IN ( 'M1A1', 'M1A2', 'M1S1', 'M1S2', 'M1Z1', 'M1Z2', 
//													 'M3A1', 'M3A2', 'M3S1', 'M3S2', 'M3Z1', 'M3Z2', 'MZZZ' )     
//	 )
//

long     ll_row,  ll_count
string   ls_item, ls_item14, ls_qa, ls_wc, ls_loc, ls_coil
int      li_exist
datetime ldt_date

dwItemStatus l_status
dw_2.accepttext()

dw5.accepttext()
for ll_row = 1 to dw5.rowcount()
   l_status = dw5.GetItemStatus(ll_row,0, Primary!)
   if l_status <> NotModified! then
		ls_loc  = trim(dw5.GetItemString(ll_row,"loc_no"))
		if ls_loc = "" or isnull(ls_loc) then
     	   		MessageBox("오류1","사용자재등록의 " + string(ll_row) + " 번째의 저장소를 입력하십시요",exclamation!)
			RETURN false
		end if
		
		ls_item   = trim(dw5.GetItemString(ll_row, "item_no")) 
		ls_qa     = trim(dw5.GetItemString(ll_row, "qa"))
		ls_coil   = trim(dw5.GetItemString(ll_row, "coil_no"))
		ls_item14 = LeftA(ls_item,4)
		
		SELECT count(*) INTO :li_exist FROM item WHERE item_no = :ls_item AND qa = :ls_qa;
		if sqlca.sqlcode = 100 or li_exist = 0 then
		   MessageBox("오류3","사용자재등록의 " + string(ll_row) + " 번째 물품이 잘못되었습니다",exclamation!)
		   RETURN false
		end if
		
		if dw5.object.sfcuse_cnt[ll_row] > 0 then
			if dw5.object.sfcuse_cnt[ll_row] > dw5.object.qcnt[ll_row] then
				MessageBox("오류33","사용자재등록의 " + string(ll_row) + " 번째 사용수량이 저장수량보다 큽니다.",exclamation!)
				RETURN false
			end if
		end if
		
		// SHEET코일 사용시 LOT번호 체크
		choose case ls_item14
			case 'M1A1', 'M1A2', 'M1S1', 'M1S2', 'M1Z1', 'M1Z2', 'M3A1', 'M3A2', 'M3S1', 'M3S2', 'M3Z1', 'M3Z2', 'MZZZ'
				if isnull(ls_coil) or ls_coil = "" then
					MessageBox("오류4","사용자재등록의 " + string(ll_row) + " 번째 LOT번호 누락입니다.",exclamation!)
					RETURN false
				end if
		end choose
	end if
next

ls_wc    = trim(dw_2.object.wc_no[1])
ldt_date = dw_2.object.work_date[1]

ll_row = dw5.deletedcount()
if ll_row > 0 then
	if wf_dw5_delete() = false then
		rollback;
		RETURN false
	end if
end if

ll_row = dw5.rowcount()
if ll_row > 0 then
	if wf_dw5_insert() = false then
		rollback;
		RETURN false
	end if
end if

RETURN wf_update1(dw5,"N")

end function

public function boolean wf_dw6_update ();//
dwItemStatus l_status
datetime ld_ret_date, ldt_today
string ls_chk, ls_old_time, ls_wc, ls_loc, ls_item, ls_qa, ls_order, ls_coil, ls_rem, ls_etc
string ls_pcoil_no, ls_sqlerrtext
dec{1} ld_wid 
dec{4} ld_yrate, lr_sheet_unitqty, lr_ret_qty
long   ll_rowcount, ll_row, ll_unit_qty, ll_length, ll_count, ll_chkcount
int    li_seq, li_cnt

dw6.accepttext()
ls_chk = "N"
ll_rowcount = dw6.rowcount()
for ll_row = 1 to ll_rowcount
	l_status = dw6.GetItemStatus(ll_row, 0, Primary!)
	if l_status = new! or l_status = newmodified! then
	else
		continue
	end if
	
	ls_item = dw6.object.item_no[ll_row]
	ls_coil = dw6.object.coil_no[ll_row]
	ld_wid  = dw6.object.wid[ll_row]
	ls_loc  = dw6.object.loc_no[ll_row]
	
	if MidA(ls_item, 4, 1) = "1" then
		SELECT COUNT(*) INTO :ll_count FROM coilmst  WHERE coil_no = :ls_coil  AND loc_no = :ls_loc;
	else
		SELECT COUNT(*) INTO :ll_count FROM sheetmst WHERE sheet_no = :ls_coil AND loc_no = :ls_loc;
	end if
	if ll_count > 0 then
		rollback;
		messagebox('오류1',string(ll_row) + "의 LOT번호 [" + ls_coil + "] 는 이미 존재합니다.",exclamation!)
		RETURN false
	end if
next //dw6.rowcount()

ldt_today   = datetime(today())
ls_old_time = string(now(),'hh:mm:ss:fff')
ll_rowcount = dw6.deletedcount()
for ll_row = 1 to ll_rowcount
	l_status = dw6.GetItemStatus(ll_row, 0, Delete!)
	if l_status = new! or l_status = newmodified! then
		continue
	end if
	
	ls_chk      = "Y"
	ls_order    = trim(dw6.GetItemString(ll_row,"order_no", Delete!, TRUE))
	ld_ret_date = dw6.GetItemDatetime(ll_row,"ret_date",    Delete!, TRUE)
	li_seq      = dw6.GetItemnumber(ll_row,"seq_no",        Delete!, TRUE)
	lr_ret_qty  = dw6.GetItemnumber(ll_row,"ret_qty",       Delete!, TRUE)
	ls_wc       = trim(dw6.GetItemString(ll_row,"wc_no",    Delete!, TRUE))
	ls_loc      = trim(dw6.GetItemString(ll_row,"loc_no",   Delete!, TRUE))
	ls_item     = trim(dw6.GetItemString(ll_row,"item_no",  Delete!, TRUE))
	ls_qa       = trim(dw6.GetItemString(ll_row,"qa",       Delete!, TRUE))
	ls_coil     = trim(dw6.GetItemString(ll_row,"coil_no",  Delete!, TRUE))
	ld_wid      = dw6.GetItemnumber(ll_row,"wid",           Delete!, TRUE)
	ll_unit_qty = dw6.GetItemnumber(ll_row,"unit_qty",      Delete!, TRUE)
	li_cnt      = dw6.GetItemnumber(ll_row,"cnt",           Delete!, TRUE)

	if trim(ls_coil) = '' or isnull(ls_coil) then
	else
		if MidA(ls_item, 4, 1) = "1" then
			DELETE FROM coilmst WHERE coil_no = :ls_coil AND loc_no = :ls_loc;
			if sqlca.sqldbcode <> 0 then
				ls_sqlerrtext = sqlca.sqlerrtext
				rollback;
				messagebox('오류2','[코일마스터] delete중 DB오류발생하였습니다.~r~n' + ls_sqlerrtext,exclamation!)
				RETURN false
			end if
		else
			DELETE FROM sheetmst WHERE sheet_no = :ls_coil AND loc_no = :ls_loc;
			if sqlca.sqldbcode <> 0 then
				ls_sqlerrtext = sqlca.sqlerrtext
				rollback;
				messagebox('오류3','[코일마스터] delete중 DB오류발생하였습니다.~r~n' + ls_sqlerrtext,exclamation!)
				RETURN false
			end if
		end if
	end if
	
	////////////////////////////////////////////////////////////
	// 재고수불: RF
	////////////////////////////////////////////////////////////
	// 생산입고에 로직입니다.
//	for ll_count = 1 to 100000
//		IF ls_old_time <> string(now(),'hh:mm:ss:fff') then
//			ls_old_time  = string(now(),'hh:mm:ss:fff')	
//			exit
//		END IF	
//	NEXT		
	
	INSERT INTO inaudit (inaudit_time, inaudit_date, inaudit_item,qa, loc_no, inaudit_type, order_no,
		    rcpt_qty, issue_qty, cost, destination, serial_id, rem, unit_qty, cnt, com_qty, user_id)  
	VALUES (getdate(), :ld_ret_date, :ls_item, :ls_qa, :ls_loc, 'RF', :ls_order,
		    :lr_ret_qty * -1, 0, 0,	:ls_wc, :ls_coil, '삭제', :ll_unit_qty, :li_seq, :lr_ret_qty, :gs_userid );
	if sqlca.sqlcode < 0 then
		ls_sqlerrtext = sqlca.sqlerrtext
		rollback;
		messagebox('오류4',"[pb_save][inaudit] insert중 DB오류가 발생했습니다.~r~n" + ls_sqlerrtext,exclamation!)
		RETURN false
	end if		
next // dw6.deletecount()


ls_old_time = string(now(),'hh:mm:ss:fff')
ll_rowcount = dw6.rowcount()
dw6.accepttext()
for ll_row = 1 to ll_rowcount
	dw6.object.seq_no[ll_row]  = ll_row
	l_status = dw6.GetItemStatus(ll_row, 0, Primary!)
	if l_status = new! or l_status = newmodified! then
	else
		continue
	end if
	
	ls_chk  = "Y"
	li_cnt  = 0
	ls_item = dw6.object.item_no[ll_row]  
	ls_qa   = dw6.object.qa[ll_row]
	
	SELECT count(*) INTO :li_cnt FROM item WHERE item_no = :ls_item AND qa = :ls_qa;
	if li_cnt = 0 then
//		IF MessageBox("확인","아래와 같은 규격은 존재하지 않습니다!~r~n" &
//			+ "신규규격 " + ls_qa +"를 코드에 등록하시겠습니까?",Exclamation!, OKCancel!, 2) = 1 THEN
			if gf_iteminsert(ls_item, ls_qa) = false then
				rollback;
				RETURN false
			end if
//		end if
	end if
	
	ld_ret_date = dw6.object.ret_date[ll_row]
	ls_wc       = dw6.object.wc_no[ll_row]
	li_seq      = dw6.object.seq_no[ll_row]  
	lr_ret_qty  = dw6.object.ret_qty[ll_row]
	ls_loc      = dw6.object.loc_no[ll_row]
	ls_coil     = dw6.object.coil_no[ll_row]
	ld_wid      = dw6.object.wid[ll_row]
	ll_unit_qty = dw6.object.unit_qty[ll_row]
	li_cnt      = dw6.object.cnt[ll_row]
	ll_length   = dw6.object.length[ll_row]
	ls_order    = dw6.object.order_no[ll_row]
	ls_rem      = dw6.object.rem[ll_row]
	ls_etc      = dw6.object.etc_no[ll_row]
	
	if trim(ls_coil) = '' or isnull(ls_coil) then
		ll_unit_qty = lr_ret_qty
		li_cnt = 1
	else
		// 스리팅코일추가
		if MidA(ls_item, 4, 1) = "1" then
			SELECT Distinct pcoil_no INTO :ls_pcoil_no FROM coilmst WHERE coil_no = :ls_coil;
			INSERT INTO coilmst (coil_no,  wid,    item_no,   qa,    loc_no,  rcpt_date, unit_qty, length,  
					 cnt, qcnt,	color_no, supp_no, flag, porder_no, pseq_no, open_close, rem, rcpt_qty, rcpt_len, etc_no, pcoil_no)
			VALUES (:ls_coil, :ld_wid, :ls_item, :ls_qa, :ls_loc, :ld_ret_date, :ll_unit_qty, :ll_length,
					 :li_cnt, :li_cnt,    '',  :ls_wc, 'S', :ls_order, :li_seq, 'O', '', :ll_unit_qty, :ll_length, :ls_etc, :ls_pcoil_no);
			if sqlca.sqldbcode <> 0 then
				ls_sqlerrtext = sqlca.sqlerrtext
				rollback;
				messagebox('오류5',"[코일마스터-스리팅코일] insert중 DB오류발생하였습니다.~r~n" + ls_sqlerrtext,exclamation!)
				RETURN false
			end if

		// 쉬트코일추가
		else
			if MidA(ls_item, 3,1 ) = "A" then
				ld_yrate = 2.72
			else
				ld_yrate = 8.12
			end if // sheet 단중 = 두께 * 폭 * 길이 * 요율(스틸 = 8.12, 알미늄 = 2.72)
			
			lr_sheet_unitqty = truncate(dec(LeftA(ls_qa,1) + "." + MidA(ls_qa,2,2)) &
											  * dec( MidA(ls_qa ,  5,4 )) &
											  * dec( MidA(ls_qa , 10,4 )) &
											  * ld_yrate / 1000000 + 0.000000001,  3)
			INSERT INTO sheetmst (sheet_no,  item_no,   qa,    loc_no,  rcpt_date, unit_qty,   
					 cnt, qcnt,	color_no, supp_no, flag, porder_no, pseq_no, open_close, rem, rcpt_qty)
			VALUES (:ls_coil, :ls_item, :ls_qa, :ls_loc, :ld_ret_date, :lr_sheet_unitqty , 
					 :li_cnt, :li_cnt,    :ls_order,  :ls_wc, 'S', :ls_order, :li_seq, 'O', '사용자재등록', :lr_sheet_unitqty);
			if sqlca.sqldbcode <> 0 then
				ls_sqlerrtext = sqlca.sqlerrtext
				rollback;
				messagebox('오류5',"[코일마스터-쉬트코일] insert중 DB오류발생하였습니다.~r~n" + ls_sqlerrtext,exclamation!)
				RETURN false
			end if
		end if
	end if
	
	////////////////////////////////////////////////////////////
	// 재고수불: RF
	////////////////////////////////////////////////////////////
	// 생산입고에 로직입니다.
//	for ll_count = 1 to 100000
//		IF ls_old_time <> string(now(),'hh:mm:ss:fff') then
//			ls_old_time  = string(now(),'hh:mm:ss:fff')	
//			exit
//		END IF	
//	NEXT		
	
	INSERT INTO inaudit (inaudit_time, inaudit_date, inaudit_item,qa, loc_no, inaudit_type, order_no,
		    rcpt_qty, issue_qty, cost, destination, serial_id, rem, unit_qty, cnt, com_qty, user_id)  
	VALUES (getdate(), :ld_ret_date, :ls_item, :ls_qa, :ls_loc, 'RF', :ls_order,
		    :lr_ret_qty, 0, 0,	:ls_wc, :ls_coil, :ls_rem, :ll_unit_qty, :li_seq, :lr_ret_qty, :gs_userid );
	if sqlca.sqlcode < 0 then
		ls_sqlerrtext = sqlca.sqlerrtext
		rollback;
		messagebox('오류6',"[pb_save][inaudit] insert중 DB오류가 발생했습니다." + "~r~n" + ls_sqlerrtext,exclamation!)		
		RETURN false
	end if		
	////////////////////////////////////////////////////////////		
next //dw6.rowcount()

if	ls_chk = "N" then	RETURN true

RETURN wf_update1(dw6,"N")

end function

public function boolean wf_dw5_delete ();// 삭제
string   ls_magamyn, ls_yyyymm, ls_plan, ls_old_time, ls_item, ls_coil, ls_qa, ls_loc, ls_oc, ls_rem, ls_wc
string   ls_sqlerrtext
datetime ldt_date, ldt_today
dec{1}   ld_wid
real     lr_useqty , lr_unitqty //,  lr_modlen
long     ll_rowcount, ll_cnt, ll_row, ll_count, ll_chkcount
int      li_int
dwItemStatus l_status

dw_2.accepttext()
dw5.accepttext()

ls_wc       = trim(dw_2.object.wc_no[1])
ldt_date    = dw_2.object.work_date[1]			// 입출고일자
ls_old_time = string(now(),'hh:mm:ss:fff')
ll_rowcount = dw5.deletedcount()

for ll_row = 1 to ll_rowcount
//	l_status = dw5.GetItemStatus(ll_row,0, Primary!)
//	if l_status = new! or l_status = newModified! then continue

	ls_plan    = trim(dw5.GetItemString(ll_row,"order_no", Delete!, TRUE))
	ls_item    = trim(dw5.GetItemString(ll_row,"item_no",  Delete!, TRUE))
	ls_coil    = trim(dw5.GetItemString(ll_row,"coil_no",  Delete!, TRUE))
	ls_qa      = trim(dw5.GetItemString(ll_row,"qa",       Delete!, TRUE))
	ls_loc     = trim(dw5.GetItemString(ll_row,"loc_no",   Delete!, TRUE))
	ld_wid     = dw5.GetItemnumber(ll_row,"sfcuse_wid",    Delete!, TRUE)
	ll_cnt     = dw5.GetItemnumber(ll_row,"sfcuse_cnt",    Delete!, TRUE)
	lr_useqty  = dw5.GetItemnumber(ll_row,"use_qty",       Delete!, TRUE)
	lr_unitqty = dw5.GetItemnumber(ll_row,"sfcuse_unit_qty", Delete!, TRUE)
	ldt_today  = dw5.GetItemdatetime(ll_row,"use_date",      Delete!, TRUE)
	
	////////////////////////////////////////////////////////////
	// 재고수불: IW
	////////////////////////////////////////////////////////////
	INSERT INTO inaudit (inaudit_time,inaudit_date,inaudit_item,qa,order_no,rcpt_qty,issue_qty,loc_no,
          inaudit_type,destination, serial_id,cost,unit_qty,cnt, user_id)
	VALUES (getdate(), :ldt_date, :ls_item, :ls_qa, :ls_plan, 0, :lr_useqty * -1, :ls_loc,
          'IW',:ls_wc,:ls_coil,0,:lr_unitqty,:ll_cnt, :gs_userid);
	if sqlca.sqlcode < 0 then
		ls_sqlerrtext = sqlca.sqlerrtext
		rollback;
		MessageBox('오류1', "[INAUDIT: IW] delete중 DB오류가 발생했습니다.~r~n" + ls_sqlerrtext,exclamation!)				
		return false
	end if
	////////////////////////////////////////////////////////////

	if trim(ls_coil) = '' or isnull(ls_coil) then
	else
		if MidA(ls_item, 4, 1) = "1" then
			update coilmst 
			   set qcnt = qcnt + :ll_cnt, open_close = 'O' // 사용가능(미사용)
			 where coil_no    = :ls_coil and loc_no     = :ls_loc;
			if sqlca.sqlcode <> 0 then
				ls_sqlerrtext = sqlca.sqlerrtext
				rollback;
				messagebox('update오류2',"코일마스터[coilmst]UPDATE시 오류가 발생했습니다.~r~n" + ls_sqlerrtext,exclamation!)
				return false
			end if
		elseif MidA(ls_item, 4, 1) = "2" then
			update sheetmst 
			   set qcnt = qcnt + :ll_cnt, open_close = 'O'  // 사용가능(미사용)
			 where sheet_no = :ls_coil	and loc_no = :ls_loc;
			if sqlca.sqlcode <> 0 then
				ls_sqlerrtext = sqlca.sqlerrtext
				rollback;
				messagebox('update오류3',"SHEET마스터UPDATE시 오류가 발생했습니다.~r~n" + ls_sqlerrtext ,exclamation!)
				return false
			end if
		end if
		
		//=================================================================
		// 잔량 삭제 ======================================================
		//=================================================================
		ls_rem = 'N'
		li_int = 1
		if MidA(ls_item, 4, 1) = "1" then
			if dw5.GetItemnumber(ll_row,"rem_qty", Delete!, TRUE) > 0 then
				ls_coil    = trim(dw5.GetItemString(ll_row,"rem_lot", Delete!, TRUE))
				ls_rem     = 'Y'
				ls_coil    = trim(dw5.GetItemString(ll_row,"rem_lot", Delete!, TRUE))				
				lr_useqty  = dw5.GetItemnumber(ll_row,"rem_qty", Delete!, TRUE)
				lr_unitqty = dw5.GetItemnumber(ll_row,"rem_qty", Delete!, TRUE)

				//스리팅코일삭제
				delete from coilmst 
				 where coil_no = :ls_coil and loc_no = :ls_loc and open_close = 'O';
				 
				if sqlca.sqldbcode <> 0 then
					ls_sqlerrtext = sqlca.sqlerrtext
					if wf_oc(ls_coil, ls_loc) = false then // "M" 생산계획중, "P" 작업지시중, "C" 사용완료, "S" 외주이동
						rollback;
						return false
					end if
					
					select count(*) into :ll_count from coilmst where coil_no = :ls_coil;
					if ll_count > 0 then
						rollback;
						messagebox("확인4","이 로트번호[" + trim(ls_coil) + "]은 이미 외주로 이동되어있습니다")
						return false
					end if
					
					rollback;
					messagebox('오류5',"[코일마스터] delete중 DB오류발생하였습니다.~r~n" + ls_sqlerrtext,exclamation!)
					return false
				end if
			end if
		elseif MidA(ls_item, 4, 1) = "2" then
			ls_qa = dw5.GetItemstring(ll_row,"rem_qa", Delete!, TRUE)
			if isnull(ls_qa) or trim(ls_qa) = '' then
			else
				lr_useqty = dw5.GetItemnumber(ll_row,"rem_cnt", Delete!, TRUE)
				ls_rem = 'Y'
			end if
		end if

		if ls_rem = 'Y' then
		   // 스리팅코일 출고 로직입니다.
//			for ll_count = 1 to 100000
//				IF ls_old_time <> string(now(),'hh:mm:ss:fff') then
//					ls_old_time  = string(now(),'hh:mm:ss:fff')	
//					exit
//				END IF	
//			NEXT		
			////////////////////////////////////////////////////////////
			// 재고수불: RW
			////////////////////////////////////////////////////////////
			// 잔량입고에 로직입니다.
			INSERT INTO inaudit (inaudit_time, inaudit_date, inaudit_item, qa, order_no, rcpt_qty, issue_qty, loc_no,
				    inaudit_type, destination, serial_id, cost, unit_qty,  cnt, com_qty, user_id)
			VALUES (getdate(), :ldt_date, :ls_item, :ls_qa, :ls_plan, :lr_useqty * -1,  0, :ls_loc,
				    'RW', 		 :ls_loc, 	:ls_coil, 	0, :lr_unitqty, 1, :li_int, :gs_userid);
			if sqlca.sqlcode < 0 then
				ls_sqlerrtext = sqlca.sqlerrtext
				rollback;
				messagebox('오류1', "[INAUDIT: RW] delete중 DB오류가 발생했습니다.~r~n" + ls_sqlerrtext, exclamation!)				
				return false
			end if
			////////////////////////////////////////////////////////////
		end if
	end if
next

return true

end function

public function boolean wf_dw5_insert ();string ls_qs, ls_old_time, ls_loc, ls_plan, ls_wc, ls_item, ls_coil, ls_qa, ls_oc
string ls_rem, ls_etc, ls_pcoil_no, ls_sqlerrtext
real   lr_useqty, lr_unitqty,  lr_modlen
long   ll_rowcount, ll_cnt, ll_count, ll_row, ll_oricnt
int    li_int
dec{1} ld_wid
dec{2} ld_length
datetime ldt_date
dwItemStatus l_status

dw_2.accepttext()
dw5.accepttext()

ls_wc       = trim(dw_2.object.wc_no[1])
ldt_date    = dw_2.object.work_date[1]
ls_old_time = string(now(),'hh:mm:ss:fff')

ll_rowcount = dw5.rowcount()
for ll_row = 1 to ll_rowcount
   	
	l_status = dw5.GetItemStatus(ll_row,0, Primary!)
	
	if l_status = NotModified! then continue
	
	ls_loc     = trim(dw5.object.loc_no[ll_row])
	ls_plan    = trim(dw5.object.order_no[ll_row])
	ls_item    = trim(dw5.object.item_no[ll_row])
	ls_coil    = trim(dw5.object.coil_no[ll_row])
	ls_qa      = trim(dw5.object.qa[ll_row])
	lr_useqty  = dw5.object.use_qty[ll_row]
	ll_cnt     = dw5.object.sfcuse_cnt[ll_row]
	lr_unitqty = dw5.object.sfcuse_unit_qty[ll_row]
	ld_wid     = dw5.object.sfcuse_wid[ll_row]
	
	if trim(ls_coil) = '' or isnull(ls_coil) then
	else
		if MidA(ls_item, 4, 1) = "1" then
			select qcnt into :ll_oricnt from coilmst where coil_no = :ls_coil	and loc_no = :ls_loc;
			
		  /*2021.01.15 jowonsuk */
			if ll_oricnt < ll_cnt then
				
					messagebox('오류',  "["+ ls_coil + "] 코일 재고량을 확인해주시기 바랍니다.~r~n",exclamation!)
					RETURN false
					
			end if 			
			
			if ll_oricnt <= ll_cnt then
				ls_oc = "C"
			else
				ls_oc = "O"
			end if
			
			update coilmst 
			   set qcnt = qcnt - :ll_cnt, open_close = :ls_oc // 사용완료(작업일보사용)
			 where coil_no    = :ls_coil	and loc_no     = :ls_loc;
			if sqlca.sqlcode <> 0 then
				rollback;
				messagebox('UPDATE오류8',"코일마스터[coilmst]UPDATE시 오류가 발생했습니다." ,exclamation!)
				return false
			end if
			
			lr_useqty = dw5.object.sfcuse_mod_qty[ll_row]
			lr_modlen = dw5.object.sfcuse_mod_len[ll_row]
			
		elseif MidA(ls_item, 4, 1) = "2" then
			select qcnt into :ll_oricnt from sheetmst where sheet_no = :ls_coil and loc_no   = :ls_loc;
			
		  /*2021.01.15 jowonsuk */
			if ll_oricnt < ll_cnt then
				
					messagebox('오류',  "["+ ls_coil + "] 쉬트 재고량을 확인해주시기 바랍니다.~r~n",exclamation!)
					RETURN false
					
			end if 			
			
			if ll_oricnt <= ll_cnt then
				ls_oc = "C"
			else
				ls_oc = "O"
			end if
			
			update sheetmst 
			   set qcnt = qcnt - :ll_cnt, open_close = :ls_oc // 사용완료(작업일보사용)
			 where sheet_no   = :ls_coil and loc_no = :ls_loc;
			if sqlca.sqlcode <> 0 then
				rollback;
				messagebox('UPDATE오류9',"SHEET마스터UPDATE시 오류가 발생했습니다." ,exclamation!)
				return false
			end if
		end if		
	end if
	
	////////////////////////////////////////////////////////////
	// 재고수불: IW
	////////////////////////////////////////////////////////////
//	for ll_count = 1 to 100000
//		IF ls_old_time <> string(now(),'hh:mm:ss:fff') then
//			ls_old_time  = string(now(),'hh:mm:ss:fff')	
//			exit
//		END IF	
//	NEXT
	
	insert into inaudit (inaudit_time,inaudit_date,inaudit_item,qa,order_no,rcpt_qty,issue_qty,loc_no,
		    inaudit_type,destination, serial_id,cost,unit_qty,cnt, user_id)
	values (getdate(),:ldt_date,:ls_item,:ls_qa,:ls_plan,0,:lr_useqty,:ls_loc,
		    'IW',:ls_wc,:ls_coil,0,:lr_unitqty,:ll_cnt, :gs_userid);
	if sqlca.sqlcode < 0 then
		ls_sqlerrtext = sqlca.sqlerrtext
		rollback;
		messagebox('오류12',"[pb_save][inaudit] insert중 DB오류가 발생했습니다.~r~n" + ls_sqlerrtext, exclamation!)		
		return false
	end if
	////////////////////////////////////////////////////////////

	//=================================================================
	// 잔량 등록 ======================================================
	//=================================================================
	ls_rem = 'N'
	if trim(ls_coil) = '' or isnull(ls_coil) then
	else
		if MidA(ls_item, 4, 1) = "1" then
			if dw5.object.rem_qty[ll_row] > 0 then
				select distinct pcoil_no into :ls_pcoil_no from coilmst where coil_no = :ls_coil;
				
				ls_rem     = 'Y'
				dw5.object.rem_lot[ll_row] = wf_coil(ll_row)
				ls_coil    = trim(dw5.object.rem_lot[ll_row])
				
				lr_useqty  = dw5.object.rem_qty[ll_row]
				lr_unitqty = dw5.object.rem_qty[ll_row]
				ld_wid     = dec(MidA(dw5.object.qa[ll_row], 5,4) + "." + MidA(dw5.object.qa[ll_row], 10,1))
				ld_length  = dw5.object.rem_len[ll_row]
				ls_etc     = dw5.object.etc_no[ll_row]
				li_int     = 1
				//스리팅코일추가
				insert into coilmst (coil_no,  wid,    item_no,   qa,    loc_no,  rcpt_date, unit_qty, length,  
						 cnt, qcnt,	color_no, supp_no, flag, porder_no, pseq_no, open_close,
						 rem, rcpt_qty, rcpt_len, etc_no, pcoil_no)
				values (:ls_coil, :ld_wid, :ls_item, :ls_qa, :ls_loc, :ldt_date, :lr_unitqty, :ld_length,
						 1, 1,    :ls_plan,  :ls_loc, 'S', :ls_plan, :li_int, 'O', 
						 '사내사용잔량입고', :lr_unitqty, :ld_length, :ls_etc, :ls_pcoil_no);
				if sqlca.sqldbcode <> 0 then
					ls_sqlerrtext = sqlca.sqlerrtext
					rollback;
					messagebox('오류10',"[코일마스터] insert중 DB오류발생하였습니다.~r~n" + ls_sqlerrtext,exclamation!)
					return false
				end if
			end if
			
		elseif MidA(ls_item, 4, 1) = "2" then
			ls_qa = dw5.object.rem_qa[ll_row]
			if isnull(ls_qa) or trim(ls_qa) = '' then
			else
				dw5.object.rem_cnt[ll_row] = dw5.object.qcnt[ll_row] - dw5.object.sfcuse_cnt[ll_row]
				lr_useqty = dw5.object.rem_cnt[ll_row]
				ls_rem    = 'Y'
				select count(*) into :li_int from item where item_no = :ls_item and qa = :ls_qa;
				if li_int = 0 then
			//		IF MessageBox("확인","아래와 같은 규격은 존재하지 않습니다!~r~n" &
			//			+ "신규규격 " + ls_remqa +"를 코드에 등록하시겠습니까?",Exclamation!, OKCancel!, 1) = 1 THEN
						if gf_iteminsert(ls_item, ls_qa) = false then
							rollback;
							return false
						end if
			//		end if
				end if
			end if
		end if
		
		if ls_rem = 'Y' then
			li_int = 1
//			for ll_count = 1 to 100000
//				IF ls_old_time <> string(now(),'hh:mm:ss:fff') then
//					ls_old_time  = string(now(),'hh:mm:ss:fff')	
//					exit
//				END IF	
//			NEXT		

			////////////////////////////////////////////////////////////
			// 재고수불: RW
			////////////////////////////////////////////////////////////
			// 잔량입고에 로직입니다.
			insert into inaudit (inaudit_time, inaudit_date, inaudit_item, qa, order_no, rcpt_qty, issue_qty, loc_no,
				    inaudit_type, destination, serial_id, cost, unit_qty,  cnt, com_qty, user_id)
			values (getdate(), :ldt_date, :ls_item, :ls_qa, :ls_plan, :lr_useqty,  0, :ls_loc,
				    'RW', 			:ls_loc, 	:ls_coil, 	0, :lr_unitqty, 1, :li_int, :gs_userid);	
			if sqlca.sqlcode < 0 then
				ls_sqlerrtext = sqlca.sqlerrtext
				rollback;
				messagebox('오류',"입출고역에 추가중 DB오류발생하였습니다.~r~n" + ls_sqlerrtext,exclamation!)
				return false					
			end if
			////////////////////////////////////////////////////////////
		end if
	end if
next

return true

end function

public subroutine wf_cleardddw (datawindow arg_dw);//
arg_dw.Modify("coil_no.edit.case=any")
arg_dw.Modify("coil_no.edit.autoselect=yes")
arg_dw.Modify("coil_no.edit.nilisnull=yes")

RETURN

end subroutine

public subroutine wf_coildddw (datawindow arg_dw, string as_item, string as_qa, string as_loc);string  ls_where, ls_clause, ls_select, ls_qa
datawindowchild ldwc_lot

if arg_dw = dw5 then
	arg_dw.Modify("coil_no.dddw.Name='d_cdcoil_c'")
	arg_dw.Modify("coil_no.dddw.allowedit=no")
	arg_dw.Modify("coil_no.dddw.percentwidth='380'")
else
	arg_dw.Modify("coil_no.dddw.Name='d_cdcoilclose_c'")
	arg_dw.Modify("coil_no.dddw.allowedit=no")
	arg_dw.Modify("coil_no.dddw.percentwidth='300'")
end if
arg_dw.Modify("coil_no.dddw.displayColumn='coil_no'")
arg_dw.Modify("coil_no.dddw.DataColumn='coil_no'")
arg_dw.Modify("coil_no.dddw.vscrollbar=yes")

arg_dw.getchild('coil_no',ldwc_lot)
ldwc_lot.settransobject(sqlca)

ls_select = ldwc_lot.Describe("DataWindow.Table.Select")

ls_qa = "%" + MidA(as_qa, 4,7) + "%"
ls_where = " and item_no = ~~'" + as_item + "~~'"   &
			+ " and qa like ~~'" + ls_qa + "~~'" &
			+ " and coilmst.loc_no like ~~'" + as_loc + "~~'"
ls_clause = "DataWindow.Table.Select='"  + ls_select + ls_where + "'"
ldwc_lot.modify(ls_clause)
if ldwc_lot.retrieve() > 0 then
	ldwc_lot.SetSort("unit_qty , coil_no")
	ldwc_lot.Sort( )
end if

return
end subroutine

public subroutine wf_sheetdddw (datawindow arg_dw, string as_item, string as_qa, string as_loc);string  ls_where, ls_clause, ls_select
datawindowchild ldwc_lot

if arg_dw = dw5 then
	arg_dw.Modify("coil_no.dddw.Name='d_cdsheet_c'")
	arg_dw.Modify("coil_no.dddw.allowedit=no")
	arg_dw.Modify("coil_no.dddw.percentwidth='380'")
else
	arg_dw.Modify("coil_no.dddw.Name='d_cdsheetclose_c'")
	arg_dw.Modify("coil_no.dddw.allowedit=no")
	arg_dw.Modify("coil_no.dddw.percentwidth='300'")
end if 

arg_dw.Modify("coil_no.dddw.displayColumn='sheet_no'")
arg_dw.Modify("coil_no.dddw.DataColumn='sheet_no'")
arg_dw.Modify("coil_no.dddw.vscrollbar=yes")

arg_dw.getchild('coil_no',ldwc_lot)
ldwc_lot.settransobject(sqlca)
ls_select = ldwc_lot.Describe("DataWindow.Table.Select")

ls_where  = ' and item_no    = ~~"' + as_item + '~~" ' &
			 + " and qa      like ~~'" + as_qa   + "~~'" &
			 + ' and sheetmst.loc_no = ~~"' + as_loc + '~~" '
ls_clause = "DataWindow.Table.Select='"  + ls_select + ls_where + "'"
ldwc_lot.modify(ls_clause)
if ldwc_lot.retrieve() > 0 then
	ldwc_lot.SetSort("qa , sheet_no")
	ldwc_lot.Sort( )
end if
return

end subroutine

public function string wf_coil (long al_row);// wf_coil
string ls_coil, ls_maxcoil, ls_chkcoil, ls_loc
int    li_pos, li_len, li_start

ls_coil  = trim(dw5.object.coil_no[al_row])
ls_loc   = dw5.object.loc_no[al_row]
li_start = 0
Do 
	li_pos = li_start
	li_start = PosA(ls_coil, "-", li_start + 1)
Loop Until li_start = 0

if li_start = 1 then li_pos = 0
if li_pos > 0 then
	if integer( MidA(ls_coil, li_pos + 1, 2)) > 9 then
		ls_chkcoil = MidA(ls_coil, 1, LenA(trim(ls_coil)) - 2 ) + "%"
		li_len = LenA(trim(ls_chkcoil)) + 1
	else
		ls_chkcoil = MidA(ls_coil, 1, LenA(trim(ls_coil)) - 1 ) + "%"
		li_len = LenA(trim(ls_chkcoil))
	end if
	
	select max(coil_no) into :ls_maxcoil from coilmst
	 where datalength(coil_no) = :li_len
		and coil_no like :ls_chkcoil;
else
	ls_chkcoil = trim(ls_coil) + "-%"
	li_len     = LenA(trim(ls_chkcoil))
	setnull(ls_maxcoil)
	select max(coil_no) into :ls_maxcoil from coilmst
	 where datalength(coil_no) = :li_len + 1 
		and coil_no like :ls_chkcoil;
	if isnull(ls_maxcoil) then
		select max(coil_no) into :ls_maxcoil from coilmst
		 where datalength(coil_no) = :li_len
			and coil_no like :ls_chkcoil;
	end if
end if

IF isnull(ls_maxcoil) AND LenA(trim(ls_coil) + "-1") > 20 then
	ls_maxcoil = ls_coil
end if

if isnull(ls_maxcoil) then
	ls_chkcoil = trim(ls_coil) + "-1"
else
	li_start = 0
	Do
		li_pos = li_start
		li_start = PosA(ls_maxcoil, "-", li_start + 1)
	Loop Until li_start = 0
	
	if li_start = 1 then li_pos = 0
	if isnumber( MidA(ls_maxcoil, li_pos + 1, 2)) then
		Do Until sqlca.sqlcode = 100
			ls_chkcoil = LeftA(ls_maxcoil, li_pos) + string(integer(MidA(ls_maxcoil, li_pos + 1, 2)) + 1)
			select coil_no into :ls_maxcoil from coilmst
			 where coil_no = :ls_chkcoil
				and datalength(coil_no) = datalength(:ls_chkcoil);
		Loop
	else
		Do Until sqlca.sqlcode = 100
			ls_chkcoil = LeftA(ls_maxcoil, li_pos) + string(integer(MidA(ls_maxcoil, li_pos + 1, 1)) + 1)
			select coil_no into :ls_maxcoil from coilmst
			 where coil_no = :ls_chkcoil
				and datalength(coil_no) = datalength(:ls_chkcoil);
		Loop
	end if
end if

return ls_chkcoil

end function

public function string wf_newcoil (string as_item, string as_loc);//===================================================
// 로트번호 부여규칙.(2001/05/31변경)
//===================================================
// 소재      형태
//===================================================
// A: 알미늄 C: 원코일
// S: 스틸   H: Sheet
//	 		    S: 외주스리팅
// Y S : 유창작업장내 스리팅 -- 사내 작업일보시만 적용.
// 예)SC010531001 :스틸 원코일2001년 5월 31일자 001번째 로트번호
//===================================================
// 현 코드규칙
// mid(item_no, 1,1) = 'M' : 자재
// 	mid(item_no, 2,1) = '1' : 원코일
// 	mid(item_no, 2,1) = '3' : 스리팅
// 		mid(item_no, 3,1) = 'A' : 알미늄
// 		mid(item_no, 3,1) = 'S' : 스틸
// 			mid(item_no, 4,1) = '1' : COIL
// 			mid(item_no, 4,1) = '2' : SHEET
//===================================================
// Loss 코드규칙.(2001/07/16변경)
// 		첫번째 = 'A' : 알미늄
// 		첫번째 = 'S' : 스틸
//    		두번째 = 'L' : loss 	
// 예)AL01071701, SL01071701
//===================================================

long   ll_row, ll_count, l_len
int    li_col
string ls_coil, ls_date, ls_code1, ls_date_pre

dw_2.accepttext()
dw4.accepttext()

SELECT count(item_no) INTO :ll_count FROM lossitem WHERE loss_item = :as_item;
if ll_count > 0 then
	CHOOSE CASE MidA(as_item ,3,1)
		CASE 'A' // 알미늄
			ls_code1 = 'A'
		CASE 'S' // 스틸
			ls_code1 = 'S'
   END CHOOSE
	ls_date = ls_code1 + 'L' + MidA(string(dw_2.object.work_date[1], 'yyyymmdd'), 3) + "%"
	ls_date_pre = ls_code1 + 'L' + MidA(string(dw_2.object.work_date[1], 'yyyymmdd'), 3)
	li_col = 11
else
	ls_date = "YS" + MidA(string(dw_2.object.work_date[1], 'yyyymmdd'), 3) + "%"
	ls_date_pre = "YS" + MidA(string(dw_2.object.work_date[1], 'yyyymmdd'), 3)
	li_col = 12
end if

setnull(ls_coil)
l_len = 0

if MidA(as_item, 4, 1) = '1' then
//	SELECT max(coil_no) into :ls_coil 
//	  FROM coilmst
//	 WHERE flag = "S"	AND coil_no LIKE :ls_date	AND substring(coil_no, :li_col ,1) IS NULL;
	 
	SELECT :ls_date_pre + ( case when max(convert(decimal, substring(coil_no, 9, len(coil_no))))  < 10 then convert(char(1), max(convert(decimal, substring(coil_no, 9, len(coil_no))))  )
                                                when max(convert(decimal, substring(coil_no, 9, len(coil_no))))  < 100 then convert(char(2), max(convert(decimal, substring(coil_no, 9, len(coil_no)))) )
                                                when max(convert(decimal, substring(coil_no, 9, len(coil_no))))  < 1000 then convert(char(3), max(convert(decimal, substring(coil_no, 9, len(coil_no)))) )
                                                when max(convert(decimal, substring(coil_no, 9, len(coil_no))))  < 10000 then convert(char(4), max(convert(decimal, substring(coil_no, 9, len(coil_no)))) )
                                       end ) INTO :ls_coil													                 
	  FROM coilmst
	where flag = 'S'
	   AND substring(coil_no,1,8) = :ls_date_pre
	   AND ( ( substring(coil_no,:li_col,1) is null or  substring(coil_no,:li_col,1) = '' ) OR ( substring(coil_no,:li_col+1,1) is null or  substring(coil_no,:li_col+1,1) = '' ) ) ;	 
	 
else
//	SELECT max(sheet_no) INTO :ls_coil 
//	  FROM sheetmst
//	 WHERE sheet_no LIKE :ls_date  AND substring(sheet_no, :li_col,1) IS NULL;
	SELECT :ls_date_pre + ( case when max(convert(decimal, substring(sheet_no, 9, len(sheet_no))))  < 10 then convert(char(1), max(convert(decimal, substring(sheet_no, 9, len(sheet_no)))) )
                                               when max(convert(decimal, substring(sheet_no, 9, len(sheet_no))))  < 100 then convert(char(2), max(convert(decimal, substring(sheet_no, 9, len(sheet_no)))) )
                                               when max(convert(decimal, substring(sheet_no, 9, len(sheet_no))))  < 1000 then convert(char(3), max(convert(decimal, substring(sheet_no, 9, len(sheet_no)))) )
                                               when max(convert(decimal, substring(sheet_no, 9, len(sheet_no))))  < 10000 then convert(char(4), max(convert(decimal, substring(sheet_no, 9, len(sheet_no)))) )
                                  end ) INTO :ls_coil
	  FROM sheetmst
	where substring(sheet_no,1,8) = :ls_date_pre
	   AND ( ( substring(sheet_no,:li_col,1) is null or  substring(sheet_no,:li_col,1) = '' ) OR ( substring(sheet_no,:li_col+1,1) is null or  substring(sheet_no,:li_col+1,1) = '' ) ) ;

end if

select len(substring(:ls_coil,9,len(:ls_coil)) ) 
  into :l_len
from dual;

//if l_len = 0 then
//
//	if ll_count > 0 then
//		ls_coil = left(ls_date, 8) + "00"
//	else
//		ls_coil = left(ls_date, 8) + "000"
//	end if
//
//end if
// 2021.08.25 신규로직
if l_len <= 3 then
	
	if ll_count > 0 then
		ls_coil = LeftA(ls_coil, 8) + string(integer(MidA(ls_coil,9,2))  ,'00')
	else
		ls_coil = LeftA(ls_coil, 8) + string(integer(MidA(ls_coil,9,3))  ,'000')
	end if
	
	if l_len = 0 then
	  l_len = 3
	end if		
	
else

	if ll_count > 0 then
		ls_coil = LeftA(ls_coil, 8) + string(integer(MidA(ls_coil,9,3))  ,'000')
	else
		ls_coil = LeftA(ls_coil, 8) + string(integer(MidA(ls_coil,9,4))  ,'0000')
	end if	
	
end if


for ll_row = 1 to dw4.rowcount()
	if not isnull(dw4.object.lot_no[ll_row]) then
		if LeftA(ls_coil, 2) = LeftA(dw4.object.lot_no[ll_row], 2) &
			and long(MidA(ls_coil,9,4)) < long(MidA(dw4.object.lot_no[ll_row],9, 4)) then  //AND ls_coil < left(dw4.object.lot_no[ll_row], li_col -1) then
			ls_coil = dw4.object.lot_no[ll_row] 
		end if
	end if
next

select len(substring(:ls_coil,9,len(:ls_coil)) ) 
  into :l_len
from dual;

if l_len <= 3 then

	if ll_count > 0 then
		ls_coil = LeftA(ls_coil, 8) + string(integer(MidA(ls_coil,9,2)) + 1 ,'00')
	else
		ls_coil = LeftA(ls_coil, 8) + string(integer(MidA(ls_coil,9,3)) + 1 ,'000')
	end if
	
else
	
	if ll_count > 0 then
		ls_coil = LeftA(ls_coil, 8) + string(integer(MidA(ls_coil,9,3)) + 1 ,'000')
	else
		ls_coil = LeftA(ls_coil, 8) + string(integer(MidA(ls_coil,9,4)) + 1 ,'0000')
	end if	
	
end if

return ls_coil
end function

public function boolean wf_oc (string arg_lot, string arg_loc);string ls_oc

SELECT open_close INTO :ls_oc FROM coilmst  WHERE coil_no = :arg_lot AND loc_no = :arg_loc;
	
CHOOSE CASE ls_oc
	CASE "M" 
		messagebox("확인","이 로트번호[" + trim(arg_lot) + "]은 지금 생산계획중입니다.")
		return false
	CASE "P"
		messagebox("확인","이 로트번호[" + trim(arg_lot) + "]은 지금 작업지시중입니다.")
		return false
	CASE "C"
		messagebox("확인","이 로트번호[" + trim(arg_lot) + "]은 이미 사용이 완료되었습니다")
		return false
	CASE "S"
		messagebox("확인","이 로트번호[" + trim(arg_lot) + "]은 이미 외주로 이동되어있습니다")
		return false
END CHOOSE

return true

end function

public function boolean wf_itemselect (datawindow arg_dw, string arg_ms, integer ai_row);gs_where2 lstr_where
long ll_row, ll_cnt, ll_row1

arg_dw.accepttext()

lstr_where.chk  = arg_ms //'M' //M:multi S:single
lstr_where.chk1 = dw_2.object.loc_no[1]
ll_row1 = arg_dw.rowcount() + 1
if arg_ms = 'S' then
	lstr_where.str1[1] = arg_dw.object.item_no[ai_row]
	lstr_where.str2[1] = arg_dw.object.qa[ai_row]
end if

if dw_2.object.wc_no[1]= 'P01' or dw_2.object.wc_no[1] = 'P02' or dw_2.object.wc_no[1] = 'P03' or dw_2.object.wc_no[1] = 'P04' then
	openwithparm(w_whitemlocqohmulti_w4, lstr_where)
else
	openwithparm(w_whitemlocqohmulti_w,lstr_where)
end if	


lstr_where = Message.PowerObjectParm
if lstr_where.chk <> "Y" then return false

string ls_item, ls_qa, ls_loc, ls_null
setnull(ls_null)
arg_dw.SETREDRAW(FALSE)
for ll_row = 1 to UpperBound(lstr_where.str1)	
	if arg_ms = 'M' then
		ll_cnt = arg_dw.insertrow(0)
	else
		ll_row1 = ai_row
		ll_cnt = ai_row
	end if

	dw_2.AcceptText()
	arg_dw.object.item_no[ll_cnt] = lstr_where.str1[ll_row]
	arg_dw.object.qa[ll_cnt]  = lstr_where.str2[ll_row]
	arg_dw.object.uom[ll_cnt] = lstr_where.str3[ll_row]
	arg_dw.object.item_item_name[ll_cnt] = lstr_where.name[ll_row]
	arg_dw.object.area_no[ll_cnt] = gs_area
	arg_dw.object.wc_no[ll_cnt]   = trim(dw_2.object.wc_no[1])
	arg_dw.object.loc_no[ll_cnt]  = dw_2.object.loc_no[1]
	if arg_dw = dw5 then
		dw5.object.order_no[ll_cnt] = LeftA(gs_area,1) + 'NON' + string(dw_2.object.work_date[1],'yyyymmdd') + '-01'
		dw5.object.use_date[ll_cnt] = datetime(dw_2.object.work_date[1])
	elseif arg_dw = dw6 then
		dw6.object.ret_date[ll_cnt] = datetime(dw_2.object.work_date[1])
		dw6.object.order_no[ll_cnt] = LeftA(gs_area,1) + "NON" + string ( ll_cnt ,"000")
	end if
next

dw_2.accepttext()
arg_dw.accepttext()
//arg_dw.object.loc_no[ll_row1] = ls_null
arg_dw.scrolltorow(ll_row1)
arg_dw.object.coil_no[ll_row1] = ls_null
ls_item = arg_dw.object.item_no[ll_row1]
ls_qa   = trim(arg_dw.object.qa[ll_row1])
ls_loc  = trim(dw_2.object.loc_no[1])

if MidA(ls_item, 4, 1) = "1" then
	wf_coildddw(arg_dw, ls_item, ls_qa,ls_loc )
elseif MidA(ls_item, 4, 1) = "2" then
	wf_sheetdddw(arg_dw, ls_item, ls_qa, ls_loc)
else
	wf_cleardddw(arg_dw)
end if

arg_dw.SetReDraw(TRUE)
return true

end function

public function boolean wf_dw4_update ();// wf_dw4_update
datetime ldt_date, ldt_sfcdatetime
string   ls_wc,   ls_old_time, ls_loc,   ls_plan,  ls_item, ls_qa,   ls_assy, ls_assyqa, ls_type
string   ls_sale, ls_suju,     ls_like1, ls_like2, ls_coil, ls_flag, ls_etc,  ls_rout
string   ls_comp, ls_compqa,   ls_uom,   ls_area,  ls_chk,  ls_sqlerrtext
long     ll_rowcount, ll_count, ll_row,  ll_chkcount, ll_cnt
int      li_division, li_seq,   li_operation
real     lr_makeqty,  lr_orderqty, lr_solqty, lr_planqty, lr_rlseqty

dec{1}   ld_wid
dec{2}   ld_length

string   ls_name
dwItemStatus l_status

dw_2.accepttext()
dw4.accepttext()

SELECT user_name INTO :ls_name FROM login WHERE user_id = :gs_userid;

ls_wc = trim(dw_2.object.wc_no[1])
SELECT isnull(rout_auto,'N') INTO :ls_rout FROM wc WHERE work_no = :ls_wc;

ls_old_time = string(now(),'hh:mm:ss:fff')

////////////////////////////// 삭제 로직 start//////////////////////////////////////
ll_rowcount = dw4.deletedcount()

for ll_row = 1 to ll_rowcount
	
   l_status = dw4.GetItemStatus(ll_row,0, Delete!)
	
	if l_status = new! or l_status = newmodified! then
		CONTINUE
	end if
	
	ldt_sfcdatetime = dw4.GetItemdatetime(ll_row,"sfc_date", Delete!, true)	
	ldt_date   = datetime(date(string(ldt_sfcdatetime,'yyyy/mm/dd')))

	ls_loc     = trim(dw4.GetItemString(ll_row,"loc_no",      Delete!, true))
	ls_plan    = trim(dw4.GetItemString(ll_row,"order_no",    Delete!, true))
	ls_item    = trim(dw4.GetItemString(ll_row,"item_no",     Delete!, true))
	ls_qa      = trim(dw4.GetItemString(ll_row,"qa",          Delete!, true))
	ls_assy    = trim(dw4.GetItemString(ll_row,"assembly",    Delete!, true))
	ls_assyqa  = trim(dw4.GetItemString(ll_row,"assembly_qa", Delete!, true))
	ls_type    = trim(dw4.GetItemString(ll_row,"type",        Delete!, true))
	lr_makeqty = dw4.GetItemnumber(ll_row,"make_qty",         Delete!, true)
	lr_planqty = dw4.GetItemnumber(ll_row,"plan_qty",         Delete!, true)
	
	SELECT division, sale_no, seq_no, suju_type
	  INTO :li_division, :ls_sale, :li_seq, :ls_suju
	  FROM mpsdet 
	 WHERE plan_no = :ls_plan;
	 
	if sqlca.sqlcode <> 0 then
		ROLLBACK;
		MessageBox('오류2','검색중 오류가 발생했습니다.',exclamation!)
		RETURN false
	end if
	
	li_operation = dw4.GetItemnumber(ll_row,"sfcday_operation", Delete!, TRUE)
	
	if isnull(li_operation) or li_operation = 0 then
		SELECT operation INTO :li_operation 
		  FROM routtempnew 
		 WHERE division = :li_division 
			AND wc_no    = :ls_wc  AND sale_no  = :ls_sale 
			AND seq_no   = :li_seq AND process_flag <> 'C';
		if (sqlca.sqlcode = 100) or (sqlca.sqlcode < 0) then
			ROLLBACK;
			MessageBox('오류4','[pb_save][routtempnew] 해당자료가 없거나, DB오류가 발생했습니다.',exclamation!)
			RETURN false
		end if
	end if
	
   li_operation++
	UPDATE routtempnew 
	   SET process_flag = 'N' 
	 WHERE division = :li_division  AND sale_no  = :ls_sale 
		AND seq_no   = :li_seq       AND process_flag <> 'C'
		AND process_flag <> 'E'	     AND operation = :li_operation;	
	if sqlca.sqlcode < 0 then
		ROLLBACK;
		MessageBox('오류7','[pb_save][routtempnew] update중 DB오류가 발생했습니다.',exclamation!)
		RETURN false
	end if				
	
	li_operation --  // 현재공정
	// 제품별공정(작업일보 삭제시 개별삭제(행삭제)가 아니고 KeyItem 삭제방식이기에 make_qty는 ZERO UPDATE함)
   UPDATE routtempnew 
	   SET make_qty = 0
		  , process_flag = 'Y'
    WHERE division = :li_division  AND wc_no    = :ls_wc
	   AND sale_no  = :ls_sale      AND seq_no   = :li_seq
		AND process_flag <> 'C'      AND operation = :li_operation;
   if sqlca.sqlcode < 0 then
	   ROLLBACK;
     	MessageBox('오류9','[pb_save][routtempnew] update중 DB오류가 발생했습니다.',exclamation!)
	   RETURN false
   end if
	
//	for ll_count = 1 to 100000
//		if ls_old_time <> string(now(),'hh:mm:ss:fff') then
//			ls_old_time  = string(now(),'hh:mm:ss:fff')	
//			exit
//		end if	
//	next		
	
	////////////////////////////////////////////////////////////
	// 재고수불: RP
	////////////////////////////////////////////////////////////
	INSERT INTO inaudit ( inaudit_time, inaudit_date, inaudit_item, qa, order_no, loc_no, inaudit_type, 
                         rcpt_qty, issue_qty, cost, destination, rem, user_id )  
	VALUES ( getdate(), :ldt_date, :ls_assy, :ls_assyqa, :ls_plan, :ls_loc, 'RP',
		      :lr_makeqty * -1, 0, 0, :ls_wc,  '작업일보(ERP)',  :gs_userid  );
				
	if sqlca.sqlcode < 0 then
		ls_sqlerrtext = string(sqlca.sqlerrtext)
		ROLLBACK;
		MessageBox('오류1', "[inaudit: RP] delete중 DB오류가 발생했습니다.~r~n" + ls_sqlerrtext, exclamation!)		
		RETURN false
	end if
	////////////////////////////////////////////////////////////
	
	// 생산계획상세
   UPDATE mpsdet SET rcpt_qty = rcpt_qty - :lr_makeqty WHERE plan_no  = :ls_plan;
	
   if sqlca.sqlcode < 0 then
		ls_sqlerrtext = sqlca.sqlerrtext
      ROLLBACK;
     	MessageBox('오류11',"[pb_save][mpsdet] update중 DB오류가 발생했습니다.~r~n" + ls_sqlerrtext,exclamation!)
      RETURN false
   end if
	
	// 코일삭제
	if MidA(ls_assy, 4, 1) = "1" then
		ls_coil = trim(dw4.GetItemString(ll_row,"lot_no", Delete!, TRUE))
		DELETE FROM coilmst WHERE coil_no = :ls_coil 	AND loc_no = :ls_loc AND open_close = 'O';
		if sqlca.sqldbcode <> 0 then
			ls_sqlerrtext = sqlca.sqlerrtext
			ROLLBACK;
			
			wf_oc(ls_coil, ls_loc) // "M" 생산계획중, "P" 작업지시중, "C" 사용완료, "S" 외주이동
			MessageBox('오류11',"[pb_save][mpsdet] update중 DB오류가 발생했습니다.~r~n" + ls_sqlerrtext,exclamation!)
			RETURN false
		end if
	end if
	
	if ls_item = ls_assy and ls_qa = ls_assyqa then // 마지막 공정
		choose case ls_suju
			case 'E', 'Y'	// 2004/08/21 부로 'Y' 만 쓰지만 기존 데이타때문에 'E' 도 남겨둠.
				if ls_type = 'C' then 
					// 수주상세
			      UPDATE saledet 
					   SET plan_qty = plan_qty + :lr_planqty
						  , sol_qty  = (case when sol_qty - :lr_planqty < 0 then 0 else sol_qty - :lr_planqty end)
						  , saledet_text = 'P'
			       WHERE order_no = :ls_sale AND seq_no = :li_seq;
					if sqlca.sqlcode < 0 then
						ROLLBACK;
						MessageBox('오류12-2','saledet update중 DB오류가 발생했습니다.',exclamation!)
						RETURN false
					end if
				else
					// 수주상세
			      UPDATE saledet 
					   SET plan_qty = plan_qty + :lr_makeqty
						  , sol_qty  = (case when sol_qty - :lr_makeqty < 0 then 0 else sol_qty - :lr_makeqty end)
						  , saledet_text = 'P'
			       WHERE order_no = :ls_sale AND seq_no = :li_seq;					
					if sqlca.sqlcode < 0 then
						ROLLBACK;
						MessageBox('오류12-4','saledet update중 DB오류가 발생했습니다.',exclamation!)
						RETURN false
					end if
				end if
		end choose
	end if
	
	if ls_rout = 'Y' and li_operation > 1 then  //wc.auto_rout = 'Y' 
								  //				then 공정자동수불=이전공정의 자재에 대하여 사용자재내역(sfcuse)을 자동으로 생성
								  //				=> 생성시 inaudit 추가 및 수량은 현공정의 수량그대로 이전공정수불.
    //ls_assyqa = trim(dw4.GetItemString(ll_row,"assembly_qa", Delete!, TRUE))
	 
		li_operation --   // 이전공정
		
	   ls_like1 = MidA(ls_qa,1,13) + '%'
		ls_area  = dw_area.object.area[1]
		SELECT assembly, assy_qa into :ls_comp, :ls_compqa 
		  FROM rout
		 WHERE item_no      = :ls_item
			AND qa        LIKE :ls_like1
			AND operation    = :li_operation;
		if sqlca.sqlcode < 0 then
			ROLLBACK;
			MessageBox('오류13',string(ll_row)+ ' 줄에서 [pb_save][rout] 해당자료가 없거나, DB오류가 발생했습니다.',exclamation!)
			RETURN false
		end if
		
		ls_compqa = LeftA(ls_compqa, 14) + MidA(ls_assyqa,15,5)
		ll_cnt    = 0
		
		SELECT count(*) into :ll_cnt 
		  FROM sfcuse
		 WHERE order_no  = :ls_plan   AND wc_no    = :ls_wc
		   AND use_date  = :ldt_date  AND item_no  = :ls_comp
		   AND qa        = :ls_compqa AND use_qty  = :lr_makeqty
		   AND auto_rout = 'A';
			
		if ll_cnt > 0 then
			// 작업일보사용내역
			DELETE FROM sfcuse
			 WHERE order_no  = :ls_plan   AND wc_no     = :ls_wc
			   AND use_date  = :ldt_date  AND item_no   = :ls_comp
			   AND qa        = :ls_compqa AND use_qty   = :lr_makeqty
			   AND auto_rout = 'A';
			if sqlca.sqlcode < 0 then
				ls_sqlerrtext = string(sqlca.sqlerrtext)
				ROLLBACK;
				MessageBox('오류14','[pb_save][sfcuse] DELETE DB오류가 발생했습니다.' + "~r~n" + ls_sqlerrtext, exclamation!)
				RETURN false
			end if
			
//			for ll_count = 1 to 100000
//				if ls_old_time <> string(now(),'hh:mm:ss:fff') then
//					ls_old_time  = string(now(),'hh:mm:ss:fff')	
//					EXIT
//				end if	
//			next
			
	      ////////////////////////////////////////////////////////////
			// 재고수불: IW
	      ////////////////////////////////////////////////////////////
			INSERT INTO inaudit ( inaudit_time, inaudit_date, inaudit_item, qa, order_no, rcpt_qty, issue_qty, loc_no,
                inaudit_type, destination, serial_id, cost, unit_qty, cnt, rem, user_id )
			VALUES (getdate(), :ldt_date, :ls_comp, :ls_compqa, :ls_plan, 0, :lr_makeqty * -1, :ls_loc,
				    'IW', :ls_wc, :ls_coil, 0, :lr_makeqty,0, '작업일보(ERP)',:gs_userid);
			if sqlca.sqlcode < 0 then
				ls_sqlerrtext = string(sqlca.sqlerrtext)
				ROLLBACK;
				MessageBox('오류14-1','[pb_save][inaudit] insert중 DB오류가 발생했습니다.'&
										+ "~r~n" + ls_sqlerrtext, exclamation!)				
				RETURN false
			end if
	      ////////////////////////////////////////////////////////////
		end if
	end if
next
//////////////////////////////////////////////////////////////////////////////////////////
// 										삭제 로직 end 	
//////////////////////////////////////////////////////////////////////////////////////////


//////////////////////////////////////////////////////////////////////////////////////////
// 										추가 로직 start 	
//////////////////////////////////////////////////////////////////////////////////////////
ll_rowcount = dw4.rowcount()
for ll_row = 1 to ll_rowcount	
   l_status = dw4.GetItemStatus(ll_row, 0, Primary!)
	if l_status = newmodified! OR l_status = new! then 
	else
		CONTINUE
	end if
	
	ldt_sfcdatetime = dw4.object.sfc_date[ll_row]
	ldt_date   = datetime(date(string(ldt_sfcdatetime,'yyyy/mm/dd')))
	
	ls_loc     = trim(dw4.object.loc_no[ll_row])
	ls_plan    = trim(dw4.object.order_no[ll_row])
	ls_item    = trim(dw4.object.item_no[ll_row])
	ls_qa      = trim(dw4.object.qa[ll_row])
	ls_assy    = trim(dw4.object.assembly[ll_row])
	ls_assyqa  = trim(dw4.object.assembly_qa[ll_row])
	lr_makeqty = dw4.object.make_qty[ll_row] 
	lr_planqty = dw4.object.plan_qty[ll_row] 
	ls_type    = trim(dw4.object.type[ll_row])	

	SELECT division, sale_no, seq_no, suju_type
	  INTO :li_division, :ls_sale, :li_seq, :ls_suju
	  FROM mpsdet 
	 WHERE plan_no = :ls_plan;
	if sqlca.sqlcode <> 0 then
		ROLLBACK;
		MessageBox('오류15',string(ll_row)+ ' 줄에서 mpsdet검색중 오류가 발생했습니다.',exclamation!)
		RETURN false
	end if

	// 자동생산계획(가생산계획)
	li_operation = dw4.object.sfcday_operation[ll_row]
	li_operation++   //다음공정
	
	// 자동생산계획(가생산계획)의 다음공정 상태변경 (Y:생산계획 작성가능)
	UPDATE routtempnew 
	   SET process_flag   = 'Y' 
	 WHERE division       = :li_division AND sale_no       = :ls_sale 
		AND seq_no         = :li_seq 		 AND operation     = :li_operation
		AND process_flag  <> 'C'		    AND process_flag <> 'E';	
	if sqlca.sqlcode < 0 then
		 ROLLBACK;
		 MessageBox('오류15-1',string(ll_row)+ ' 줄에서 [pb_save][routtempnew] update중 DB오류가 발생했습니다.',exclamation!)
		 RETURN false
	end if				
	
	if ls_type = 'C' then 
		ls_type = 'E'  // 완료
	else
		ls_type = 'Y'  // 가능
	end if
	
	li_operation --  //다음공정 - 1 = 현재공정

	// 자동생산계획(가생산계획)의 현재공정 상태변경 (Y:생산계획 작성가능)
	UPDATE routtempnew 
	   SET make_qty = make_qty + :lr_makeqty, process_flag = :ls_type
	 WHERE division       = :li_division AND wc_no     = :ls_wc 
	   AND sale_no        = :ls_sale     AND seq_no    = :li_seq 
	   AND process_flag  <> 'C'	       AND operation = :li_operation;
	if sqlca.sqlcode < 0 then
		ROLLBACK;
		MessageBox('오류15-2',string(ll_row)+ ' 줄에서 [pb_save][routtempnew] update중 DB오류가 발생했습니다.',exclamation!)
		RETURN false
	end if		
	
	// 코일등록
	if MidA(ls_assy, 4, 1) = "1" then
		ls_coil = wf_newcoil(ls_assy, ls_loc)
		dw4.object.lot_no[ll_row] = trim(ls_coil)
		
		if MidA(ls_assy, 2, 1) = "1" then
			ls_flag = 'W'
		else
			ls_flag = 'S'
		end if
		
		ld_wid    = dec(MidA(dw4.object.qa[ll_row], 5,4) + "." + MidA(dw4.object.qa[ll_row], 10,1))
		ld_length = 0
		
		// 스리팅코일추가
		INSERT INTO coilmst (coil_no,  wid,    item_no,   qa,    loc_no,  rcpt_date, unit_qty, length,  
				 cnt, qcnt,	color_no, supp_no, flag, porder_no, pseq_no, open_close,
				 rem, rcpt_qty, rcpt_len, etc_no, pcoil_no)
		VALUES (:ls_coil, :ld_wid, :ls_assy, :ls_assyqa, :ls_loc, :ldt_date, :lr_makeqty, :ld_length,
				 1, 1,    :ls_plan,  :ls_loc, :ls_flag , :ls_plan, 1, 'O', 
				 '생산입고(RP)', :lr_makeqty, :ld_length, :ls_etc,'생산입고');
		if sqlca.sqldbcode <> 0 then
			ROLLBACK;
			MessageBox('오류15-3',string(ll_row)+ ' 줄에서 [코일마스터] insert중 DB오류발생하였습니다.',exclamation!)
			RETURN false
		end if
	end if

//	// 입출고 히스토리 추가
//	for ll_count = 1 to 100000
//		if ls_old_time <> string(now(),'hh:mm:ss:fff') then
//			ls_old_time  = string(now(),'hh:mm:ss:fff')	
//			EXIT
//		end if	
//	next		

	////////////////////////////////////////////////////////////
	// 재고수불: RP
	////////////////////////////////////////////////////////////
	INSERT INTO inaudit ( inaudit_time, inaudit_date, inaudit_item, qa, order_no, rcpt_qty, issue_qty, loc_no,
		 	               inaudit_type, cost, destination, rem, user_id )
	VALUES (getdate(), :ldt_date, :ls_assy, :ls_assyqa, :ls_plan, :lr_makeqty, 0, :ls_loc, 'RP', 0, :ls_wc, '작업일보(ERP)', :gs_userid);
	if sqlca.sqlcode < 0 then
		ls_sqlerrtext = string(sqlca.sqlerrtext)
		ROLLBACK;
		MessageBox('오류23',string(ll_row)+ ' 줄에서 [pb_save][inaudit] insert중 DB오류가 발생했습니다.~r~n'+ ls_sqlerrtext, exclamation!)
		RETURN false
	end if		
	////////////////////////////////////////////////////////////

	// 생산계획상세 변경
	UPDATE mpsdet SET rcpt_qty = rcpt_qty + :lr_makeqty WHERE plan_no = :ls_plan;
	if sqlca.sqlcode < 0 then
		ROLLBACK;
		MessageBox('오류24',string(ll_row)+ ' 줄에서 [pb_save][mpsdet] update중 DB오류가 발생했습니다.',exclamation!)
		RETURN false
	end if
	
	if ls_item = ls_assy and ls_qa = ls_assyqa then // 마지막 공정
		choose case ls_suju
			case 'E', 'Y' // 2004/08/21 부로 'Y' 만 쓰지만 기존 데이타때문에 'E' 도 남겨둠.
				// 수주상세 변경
				if ls_type = 'E' then
					UPDATE saledet SET plan_qty = 0, sol_qty = order_qty WHERE order_no = :ls_sale AND seq_no = :li_seq;
					if sqlca.sqlcode < 0 then
						ROLLBACK;
						MessageBox('오류26-2',string(ll_row)+ ' 줄에서 판매예약량 update중 DB오류가 발생했습니다.',exclamation!)
						RETURN false
					end if					
				else
					UPDATE saledet 
					   SET plan_qty = (case when plan_qty - :lr_makeqty < 0 then 0 else plan_qty - :lr_makeqty end)
						  , sol_qty  = sol_qty + :lr_makeqty
					 WHERE order_no = :ls_sale AND seq_no = :li_seq;		
					if sqlca.sqlcode < 0 then
						ROLLBACK;
						MessageBox('오류26-4',string(ll_row)+ ' 줄에서 판매예약량 update중 DB오류가 발생했습니다.',exclamation!)
						RETURN false
					end if					
				end if
				
				SELECT order_qty,    plan_qty,    sol_qty,    rlse_qty
				  INTO :lr_orderqty, :lr_planqty, :lr_solqty, :lr_rlseqty
				  FROM saledet
				 WHERE order_no = :ls_sale AND seq_no = :li_seq;
				if sqlca.sqlcode < 0 then
					ROLLBACK;
					MessageBox('오류27',string(ll_row)+ ' 줄에서 [pb_save][saledet] 해당자료가 없거나, DB오류가 발생했습니다.',exclamation!)
					RETURN false
				end if			

				// 전공정이 완료가 되지않아도 마지막공정 완료시 출고가능으로 flag를 바꿈
				if (lr_solqty + lr_rlseqty) >= lr_orderqty then
				   // 출고가능 하게 수주상세 변경 
					UPDATE saledet SET saledet_text = 'X' WHERE order_no = :ls_sale AND seq_no = :li_seq;	
					if sqlca.sqlcode < 0 then
						ROLLBACK;
						MessageBox('오류28',string(ll_row)+ ' 줄에서 [pb_save][saledet] update중 DB오류가 발생했습니다.',exclamation!)
						RETURN false
					end if						
				end if
		end choose
	end if
	
	if ls_rout = 'Y' and li_operation > 1 then  //wc.auto_rout = 'Y' 
					  //				then 공정자동수불=이전공정의 자재에 대하여 사용자재내역(sfcuse)을 자동으로 생성
					  //				=> 생성시 inaudit 추가 및 수량은 현공정의 수량그대로 이전공정수불.
		
		li_operation --   //이전공정
	   
		ls_like1 = MidA(ls_qa,1,13) + '%'
		ls_area  = dw_area.object.area[1]
		ls_chk   = 'N'
		SELECT assembly, assy_qa INTO :ls_comp, :ls_compqa 
		  FROM rout
		 WHERE item_no = :ls_item AND qa LIKE :ls_like1 AND operation = :li_operation;
		if sqlca.sqlcode < 0 then
			ROLLBACK;
			MessageBox('오류30',string(ll_row)+ ' 줄에서 [pb_save][rout] 해당자료가 없거나, DB오류가 발생했습니다.',exclamation!)
			RETURN false
		end if
		if sqlca.sqlcode = 100 then
			if MessageBox("확인",string(ll_row)+ " 줄의 품목이 공정에 등록되어 있지 않습니다.~r~n" &
			            + "계속진행하시려면[Y] => 사용자재등록않함~r~n" &
			            + "공정등록후에 다시진행하시려면(취소)[N]", Exclamation!, YesNo!, 2) = 1 then
				ls_chk = 'Y'
			else
				ROLLBACK;
				RETURN false
			end if
		end if
		
		if ls_chk = 'N' then
			ls_compqa = LeftA(ls_compqa, 14) + MidA(ls_assyqa,15,5) //wc.rout_auto
			// 작업일보사용내역
			INSERT INTO sfcuse ( order_no, wc_no, use_date, item_no, qa, uom, use_qty, coil_no, color, color_type, loc_no,   
					 coil_type, cnt, unit_qty, mod_qty, division, mod_len, seq, wid, rem_qty, rem_len, rem_lot,
					 rem_qa, rem_cnt, area_no, auto_rout )  
			VALUES ( :ls_plan, :ls_wc, :ldt_date, :ls_comp, :ls_compqa, :ls_uom, :lr_makeqty, NULL, NULL, NULL, :ls_loc,
						NULL, 0, 0, 0, 0, 0, 0, 0, 0, 0, NULL, NULL, 0, :ls_area, 'A' );
			if sqlca.sqlcode < 0 then
				ROLLBACK;
				MessageBox('오류31','[pb_save][sfcuse] INSERT중 DB오류가 발생했습니다.',exclamation!)
				RETURN false
			end if
			
//			for ll_count = 1 to 100000
//				if ls_old_time <> string(now(),'hh:mm:ss:fff') then
//					ls_old_time  = string(now(),'hh:mm:ss:fff')	
//					EXIT
//				end if	
//			NEXT
			
	      ////////////////////////////////////////////////////////////
			// 재고수불: IW
	      ////////////////////////////////////////////////////////////
			INSERT INTO inaudit ( inaudit_time, inaudit_date, inaudit_item, qa, order_no, rcpt_qty, issue_qty, loc_no,
				 	 inaudit_type, destination, serial_id, cost, unit_qty, cnt, rem, user_id )
			VALUES (getdate(), :ldt_date, :ls_comp, :ls_compqa, :ls_plan, 0, :lr_makeqty, :ls_loc,
				    'IW', :ls_wc, :ls_coil, 0, :lr_makeqty, 0, '작업일보(ERP)', :gs_userid);
			if sqlca.sqlcode < 0 then
				ls_sqlerrtext = string(sqlca.sqlerrtext)
				ROLLBACK;				
				MessageBox('오류32','[pb_save][inaudit] insert중 DB오류가 발생했습니다.~r~n' + ls_sqlerrtext, exclamation!)
				RETURN false
			end if
	      ////////////////////////////////////////////////////////////
		end if
	end if
next
////////////////////////////// 추가 로직 end //////////////////////////////////////

RETURN true

end function

on w_mpwork_m1.create
int iCurrent
call super::create
this.tab_1=create tab_1
this.st_3=create st_3
this.gb_15=create gb_15
this.dw_area=create dw_area
this.st_5=create st_5
this.pb_6=create pb_6
this.st_12=create st_12
this.st_15=create st_15
this.cbx_multi=create cbx_multi
this.cb_17=create cb_17
this.cb_23=create cb_23
this.cb_24=create cb_24
iCurrent=UpperBound(this.Control)
this.Control[iCurrent+1]=this.tab_1
this.Control[iCurrent+2]=this.st_3
this.Control[iCurrent+3]=this.gb_15
this.Control[iCurrent+4]=this.dw_area
this.Control[iCurrent+5]=this.st_5
this.Control[iCurrent+6]=this.pb_6
this.Control[iCurrent+7]=this.st_12
this.Control[iCurrent+8]=this.st_15
this.Control[iCurrent+9]=this.cbx_multi
this.Control[iCurrent+10]=this.cb_17
this.Control[iCurrent+11]=this.cb_23
this.Control[iCurrent+12]=this.cb_24
end on

on w_mpwork_m1.destroy
call super::destroy
destroy(this.tab_1)
destroy(this.st_3)
destroy(this.gb_15)
destroy(this.dw_area)
destroy(this.st_5)
destroy(this.pb_6)
destroy(this.st_12)
destroy(this.st_15)
destroy(this.cbx_multi)
destroy(this.cb_17)
destroy(this.cb_23)
destroy(this.cb_24)
end on

event open;call super::open;//==GF_USEPROGRAM(프로그램 사용현황)===========================================================
GF_USEPROGRAM( gs_userid, THIS.ClassName(), "O", string(gf_today(),"yyyy/mm/dd"), THIS.Title )
//=============================================================================================

DataWindowChild  ldwc_loc2
string ls_locno 

tab_1.tabpage_5.ddlb_col.text  = "팀명"
tab_1.tabpage_5.ddlb_2.text    = "LIKE"
tab_1.tabpage_5.sle_value.text = ""

tab_1.tabpage_5.ddlb_col2.text  = "작업장"
tab_1.tabpage_5.ddlb_4.text     = "LIKE"
tab_1.tabpage_5.sle_value2.text = ""

tab_1.tabpage_5.ddlb_3.text     = "전체"

tab_1.tabpage_5.visible  = false		// 작업자투입
tab_1.tabpage_6.visible  = false		// 비가동시간

dw_1.visible = false
dw_2.insertrow(0)
dw_2.object.work_date[1] = wf_today()
/*
dw_2.insertrow(1)
dw_2.getchild("wc_no",idwc_wc)
idwc_wc.settransobject(sqlca)
idwc_wc.insertrow(1)
idwc_wc.setitem(1,"work_no","%")
idwc_wc.setitem(1,"work_name","전체")
idwc_wc.accepttext()
dw_2.object.wc_no[1] = "%"
*/

id_date = date(wf_today())

dw3  = tab_1.tabpage_1.dw_3
dw4  = tab_1.tabpage_2.dw_4
dw5  = tab_1.tabpage_3.dw_5
dw6  = tab_1.tabpage_4.dw_6
dw7  = tab_1.tabpage_2.dw_7
dw8  = tab_1.tabpage_5.dw_8
dw9  = tab_1.tabpage_5.dw_9
dw10 = tab_1.tabpage_6.dw_10
dw11 = tab_1.tabpage_6.dw_11

///////////////////////////////////////////////
tab_1.tabpage_1.ddlb_fld.reset()
tab_1.tabpage_1.ddlb_dwtitles.reset()
tab_1.tabpage_1.ddlb_dwtitles.visible = false
GF_DWTitle2ddlb( dw3, tab_1.tabpage_1.ddlb_fld, tab_1.tabpage_1.ddlb_dwtitles )
///////////////////////////////////////////////

dw3.settransobject(sqlca)
dw4.settransobject(sqlca)
dw5.settransobject(sqlca)
dw6.settransobject(sqlca)
dw7.settransobject(sqlca)
dw8.settransobject(sqlca)
dw9.settransobject(sqlca)
dw10.settransobject(sqlca)
dw11.settransobject(sqlca)

// 사업장
dw_area.settransobject(sqlca)
dw_area.insertrow(0)  
dw_area.object.area[1] = gs_area

if GF_PERMISSION("작업일보등록_사업장변경", gs_userid) = "Y" then
	dw_area.enabled = true
else
	dw_area.enabled = false
end if

// 작업장
dw_2.getchild("wc_no",idwc_wc)
idwc_wc.settransobject(sqlca)
idwc_wc.setfilter( "area_no = '" + gs_area + "'" )
idwc_wc.filter()

// 입고저장소
dw_2.getchild("loc_no",ldwc_loc2)
ldwc_loc2.settransobject(sqlca)

SELECT def_loc INTO :ls_locno FROM area WHERE area_no = :gs_area; 
dw_2.object.loc_no[1] = ls_locno


// 사용자재 LOT번호
dw5.getchild("coil_no",idwc_coil)
idwc_coil.insertrow(1)
idwc_coil.settransobject(sqlca)
is_select1 = idwc_coil.Describe("DataWindow.Table.Select")

dw5.getchild("rem_qa",idwc_qa)
//idwc_qa.insertrow(1)
gs_ds_qaall.ShareData(idwc_qa)
dw5.settransobject(sqlca)

// 자재반납
dw6.getchild("coil_no",idwc_coil6)
idwc_coil6.insertrow(1)
idwc_coil6.settransobject(sqlca)
dw6.settransobject(sqlca)

//
if dw_area.event itemchanged(1, dw_area.object.area, gs_area) = 1 then
	dw_area.event itemerror( 1, dw_area.object.area, gs_area )
end if


if gs_userid = '1999010s' then
	cb_24.visible = true
	cb_24.enabled = true
end if	

end event

event resize;call super::resize;//
long  ll_width, ll_height

gb_3.width   = newwidth  - (gb_3.x * 2)

tab_1.width  = newwidth  - (gb_3.x * 2)
tab_1.height = newheight - tab_1.y - gb_3.x

//
ll_width  = tab_1.tabpage_1.width
ll_height = tab_1.tabpage_1.height

tab_1.tabpage_1.dw_3.width   = ll_width
tab_1.tabpage_1.dw_3.height  = ll_height - tab_1.tabpage_1.dw_3.y

tab_1.tabpage_2.dw_7.width   = ll_width
tab_1.tabpage_2.dw_4.width   = ll_width
tab_1.tabpage_2.dw_4.height  = ll_height - tab_1.tabpage_2.dw_4.y

tab_1.tabpage_3.dw_5.width   = ll_width
tab_1.tabpage_3.dw_5.height  = ll_height - tab_1.tabpage_3.dw_5.y

tab_1.tabpage_4.dw_6.width   = ll_width
tab_1.tabpage_4.dw_6.height  = ll_height - tab_1.tabpage_4.dw_6.y

tab_1.tabpage_5.dw_8.height  = ll_height - tab_1.tabpage_5.dw_8.y
tab_1.tabpage_5.dw_9.width   = ll_width  - tab_1.tabpage_5.dw_9.x
tab_1.tabpage_5.dw_9.height  = ll_height - tab_1.tabpage_5.dw_9.y

tab_1.tabpage_6.dw_11.width  = ll_width
//tab_1.tabpage_6.dw_11.height = ll_height - tab_1.tabpage_6.dw_11.y

tab_1.tabpage_6.dw_10.width  = ll_width
tab_1.tabpage_6.dw_10.height = ll_height - tab_1.tabpage_6.dw_10.y

end event

type pb_save from w_inheritance`pb_save within w_mpwork_m1
integer x = 3141
integer y = 64
end type

event pb_save::clicked;// 저장
long   ll_row, ll_del
string ls_rem[], ls_nullarray[], ls_bigo, ls_continue
string ls_work1, ls_work2, ls_work3

ll_del = 0
dw4.accepttext()
dw9.accepttext()

dw9.setredraw(false)
// 투입인원 중 구분설정 안된 작업자는 삭제
for ll_row = dw9.rowcount() to 1 step -1
	ls_work1 = dw9.object.work1[ll_row] 
	ls_work2 = dw9.object.work2[ll_row] 
	ls_work3 = dw9.object.work3[ll_row] 

   if ls_work1 = "0" and ls_work2 = "0" and ls_work3 = "0" then
		ll_del = ll_del + 1

		dw9.scrolltorow(ll_row)			
		dw9.deleterow(ll_row)
	end if
next
dw9.setredraw(true)

if ll_del > 0 then
	if MessageBox("확인","투입인원 중 구분설정 안된 작업자는 삭제 후 저장합니다.", Exclamation!, OKCancel!, 1) = 2 THEN
		RETURN
	end if
end if


////////////////////////////////////////////////
// 실적일자와 계획일자 체크(work_date) CHECK
////////////////////////////////////////////////
DateTime ld_sdate, ld_edate
string   ls_orderno, ls_colordraw, ls_wcno, ls_color

ls_wcno  = dw_2.object.wc_no[1]		// 작업장
ld_sdate = dw_2.object.work_date[1]	// 실적일자

if dw4.rowcount() > 0 then
	for ll_row = 1 to dw4.rowcount()
		ls_orderno = LeftA(dw4.object.order_no[ll_row],11)
		
		SELECT start_date INTO :ld_edate FROM mps WHERE order_no = :ls_orderno;
		if ld_sdate >= ld_edate then		// 실적일자 >= 생산시작일자 [정상]
		else
			dw_2.setcolumn('work_date')
			dw_2.setfocus()
			MessageBox("경고", string(ll_row) + "행 실적일자 >= 생산시작일자 이후로 처리하시기 바랍니다.")  
			RETURN
		end if
		
		// 수주비고색상 -> 작업색상명
		if ls_wcno = "P02" then		// 도장 2호
			ls_color = dw4.object.color[ll_row]
			
			choose case ls_color
				case "0000", "Z000" // 무도장, 기타
					ls_colordraw = dw4.object.color_draw[ll_row]
					
					if isnull(ls_colordraw) OR trim(ls_colordraw) = "" then
						dw4.scrolltorow( ll_row )
						dw4.setcolumn("color_draw")
						dw4.setfocus()
						
						if ls_continue <> "Y" then
							if MessageBox("경고", string(ll_row) + "행 작업색상명을 반드시 입력하시기 바랍니다.", Exclamation!, OKCancel!, 1) = 2 THEN
								RETURN
							else
								ls_continue = "Y" 
							end if
						end if
					end if				
			end choose
		end if
	next
end if
////////////////////////////////////////////////

if MessageBox("확인","저장 하시겠습니까?", Exclamation!, OKCancel!, 1) = 2 then
	RETURN
end if

// 작업자 투입현황 저장
if wf_update1(dw9,"N") = false then
	MessageBox('오류dw9','작업자 투입현황 저장중 오류가 발생했습니다.',exclamation!)
	RETURN
end if

// 비 가동시간 저장
if wf_update1(dw11,"N") = false then
	MessageBox('오류dw11','비 가동시간 저장중 오류가 발생했습니다.',exclamation!)
	RETURN
end if

// 사용자재 저장
if wf_dw5_update() = false then
	MessageBox('오류dw5','사용자재 저장중 오류가 발생했습니다.',exclamation!)
	RETURN
end if

// 자재반납 저장
if wf_dw6_update() = false then 
	MessageBox('오류dw6','자재반납 저장중 오류가 발생했습니다.',exclamation!)
	RETURN
end if

// 작업일보 저장
if wf_dw4_update() = false then 
	MessageBox('오류dw4','작업일보 저장중 오류가 발생했습니다.',exclamation!)
	RETURN
end if

// 
if wf_update1(dw4,"Y") = true then
   dw3.reset()
end if

