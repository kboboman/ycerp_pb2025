 retrieve="  SELECT scene.cust_no        
       , scene.scene_code     
       , scene.scene_desc     
       , scene.scene_charge   
       , scene.start_date     
       , scene.end_date       
       , scene.scene_tel      
       , scene.scene_scale    
       , scene.scene_addr     
       , scene.rem  
    FROM scene  
   WHERE scene.cust_no = :as_cust    
" update="scene" updatewhere=1 updatekeyinplace=no arguments=(("as_cust", string))  sort="scene_code D " )
