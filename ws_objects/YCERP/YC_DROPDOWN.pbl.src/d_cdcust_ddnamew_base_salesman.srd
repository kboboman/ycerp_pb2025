$PBExportComments$고객명별 고객리스트
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=68 color="8421504" )
detail(height=68 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(5) updatewhereclause=yes name=team_code dbname="team_code" )
 column=(type=char(30) updatewhereclause=yes name=team_name dbname="team_name" )
 column=(type=char(10) updatewhereclause=yes name=team_manager dbname="team_manager" )
 column=(type=long updatewhereclause=yes name=credit_cnt dbname="credit_cnt" )
 retrieve="  SELECT distinct customer.cust_no
       , customer.cust_name
       , login.user_name  
       , team.team_code
       , team.team_name
       , team.team_manager
       , credit_cnt = ( select count(distinct cust_no) from customer_credit (nolock) where customer.cust_no = customer_credit.cust_no )
    FROM UF_MyCustomers( :as_salesman ) M
         LEFT OUTER JOIN customer ON m.cust_no = customer.cust_no
         LEFT OUTER JOIN login    ON customer.salesman = login.user_id 
         LEFT OUTER JOIN team     ON login.team_code   = team.team_code
   WHERE customer.open_close <> 'C'   
" arguments=(("as_salesman", string))  sort="cust_name A cust_no A " )
