text(band=header alignment="2" text="현장코드" border="6" color="33554432" x="9" y="8" height="60" width="379" html.valueishtml="0"  name=scene_code_t visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="15780518" )
