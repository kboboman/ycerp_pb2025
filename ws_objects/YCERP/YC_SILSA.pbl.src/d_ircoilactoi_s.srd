$PBExportComments$코일실사관리(2004/12/30,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=67108864 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=76 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes key=yes name=coileoymu_cdate dbname="coileoymu.cdate" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=coileoymu_user_id dbname="coileoymu.user_id" )
 column=(type=char(20) updatewhereclause=yes key=yes name=c_coil_coil_no dbname="coileoymu.coil_no" )
 column=(type=char(10) update=yes updatewhereclause=yes key=yes name=coileoymu_loc_no dbname="coileoymu.loc_no" )
 column=(type=long update=yes updatewhereclause=yes name=coileoymu_cnt dbname="coileoymu.cnt" )
 column=(type=char(1) update=yes updatewhereclause=yes name=coileoymu_mode_flag dbname="coileoymu.mode_flag" )
 column=(type=datetime update=yes updatewhereclause=yes name=coileoymu_log_date dbname="coileoymu.log_date" )
 column=(type=char(10) updatewhereclause=yes name=coileoymu_item_no dbname="coileoymu.item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=coilmst_qa dbname="coilmst.qa" )
 column=(type=long updatewhereclause=yes name=coilmst_unit_qty dbname="coilmst.unit_qty" )
 column=(type=long updatewhereclause=yes name=coilmst_qcnt dbname="coilmst.qcnt" )
 column=(type=char(30) updatewhereclause=yes name=location_loc_name dbname="location.loc_name" )
 retrieve="SELECT distinct coileoymu.cdate,   
         coileoymu.user_id,   
         c_coil.coil_no,   
         coileoymu.loc_no,   
         coileoymu.cnt,   
         coileoymu.mode_flag,   
         coileoymu.log_date,   
         item_no,   
         item_name = dbo.uf_getitemname(coilmst.item_no),   
         coilmst.qa,   
         coilmst.unit_qty,   
         coilmst.qcnt,
			location.loc_name  
    FROM 
			(
					 select coil_no, loc_no from coileoymu 
					  where cdate = :as_date 
						 and ( (:as_wc = 'N' and loc_no = :as_loc )
								or (:as_wc = 'Y' and (loc_no = :as_loc or loc_no in (select loc_no from location where loc_type ='W'))))
					 union all
					 select distinct coil_no, loc_no from coilmst
					  where open_close <> 'C'
						and flag like :as_ws
						and item_no like :as_item
						and not exists ( select * from lossitem where loss_item = coilmst.item_no )
						 and ( (:as_wc = 'N' and loc_no = :as_loc )
								or (:as_wc = 'Y' and (loc_no = :as_loc or loc_no in (select loc_no from location where loc_type ='W'))))
  			 ) c_coil left outer join   coileoymu on c_coil.coil_no =  coileoymu.coil_no and c_coil.loc_no =  coileoymu.loc_no
                     left outer join coilmst on c_coil.coil_no =  coilmst.coil_no and c_coil.loc_no =  coilmst.loc_no
		                 left outer join location on c_coil.loc_no =  location.loc_no
   WHERE  coilmst.open_close <> 'C' and
			coilmst.flag like :as_ws and
			item_no like :as_item and
			coileoymu.cdate = :as_date" update="coileoymu" updatewhere=0 updatekeyinplace=no arguments=(("as_date", string),("as_loc", string),("as_wc", string),("as_ws", string),("as_item", string))  sort="mid(coileoymu_item_no, 3, 1)
 A coileoymu_item_no A coilmst_qa A coilmst_unit_qty A c_coil_coil_no A coileoymu_loc_no A " )
group(level=1 header.height=0 trailer.height=68 by=("mid( coileoymu_item_no , 3,1) + mid( coileoymu_item_no , 2,1)" ) header.color="536870912" trailer.color="553648127" )
group(level=2 header.height=0 trailer.height=72 by=("coileoymu_item_no" ) header.color="536870912" trailer.color="553648127" )
