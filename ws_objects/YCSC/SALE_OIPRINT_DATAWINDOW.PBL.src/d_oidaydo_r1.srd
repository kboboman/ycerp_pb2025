compute(band=detail alignment="1" expression="if ( round = 'Y', if ( cqty < 0,  round(price * cqty, 0),  round(price * cqty, 0)), if ( cqty < 0,  truncate(price * cqty, 0),  truncate(price * cqty + 0.000001, 0)) )"border="0" color="33554432" x="4585" y="8" height="72" width="503" format="#,##0" html.valueishtml="0"  name=compute_2 visible="1"  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="1" background.color="536870912" )
