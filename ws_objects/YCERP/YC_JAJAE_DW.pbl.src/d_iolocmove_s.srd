$PBExportHeader$d_iolocmove_s.srd
$PBExportComments$저장소이동관리조회(2001/05/14,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=80 color="536870912" )
summary(height=0 color="536870912" )
footer(height=72 color="8421504" )
detail(height=80 color="536870912" )
table(column=(type=char(13) updatewhereclause=yes name=move_no dbname="itemmove.move_no" )
 column=(type=datetime updatewhereclause=yes name=move_date dbname="itemmove.move_date" )
 column=(type=char(30) updatewhereclause=yes name=location_loc_name_i dbname="location.loc_name" )
 column=(type=char(13) updatewhereclause=yes name=pre_move_no dbname="itemmove.pre_move_no" )
 column=(type=char(1) updatewhereclause=yes name=flag dbname="itemmove.flag" values="사내	M/외주	S/" )
 column=(type=char(30) updatewhereclause=yes name=location_loc_name_o dbname="location.loc_name" )
 column=(type=char(10) updatewhereclause=yes name=log_id dbname="itemmove.log_id" )
 retrieve="  SELECT itemmove.move_no       
		     , itemmove.move_date     
      		, location_a.loc_name    
		     , itemmove.pre_move_no   
		     , itemmove.flag          
		     , location_b.loc_name    
		     , itemmove.log_id  
    FROM itemmove LEFT OUTER JOIN location location_a ON     itemmove.tar_loc  = location_a.loc_no
						  LEFT OUTER JOIN  location location_b  ON   itemmove.src_loc = location_b.loc_no
   WHERE  ( 
				( itemmove.move_date BETWEEN :as_start and :as_end ) AND  
         		      ( itemmove.class           = :as_class ) 
		         )    
/*
    FROM itemmove              
       , location location_a   
       , location location_b  
   WHERE ( itemmove.tar_loc     *= location_a.loc_no ) 
     AND ( itemmove.src_loc     *= location_b.loc_no ) 
     AND ( ( itemmove.move_date BETWEEN :as_start and :as_end ) AND  
           ( itemmove.class           = :as_class ) 
         )    
*/" arguments=(("as_start", date),("as_end", date),("as_class", string))  sort="move_date D move_no A " )
