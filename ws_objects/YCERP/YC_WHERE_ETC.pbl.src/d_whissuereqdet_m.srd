 column=(type=char(14) update=yes updatewhereclause=yes name=issuereqdet_sale_no dbname="issuereqdet.sale_no" )
 column=(type=char(60) update=yes updatewhereclause=yes name=issuereqdet_item_name dbname="issuereqdet.item_name" )
 column=(type=char(3) update=yes updatewhereclause=yes name=issuereqdet_uom dbname="issuereqdet.uom" )
 column=(type=char(1) update=yes updatewhereclause=yes name=issuereqdet_issue_flag dbname="issuereqdet.issue_flag" values="전량	A/부분	P/잔여분	R/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=issuereqdet_issue_schedule dbname="issuereqdet.issue_schedule" values="직출	A/생산후직출	B/저녁상차	J/택배//정기	K/방문	D/야간도착	I/외주(시화)	E/외주(본사)	F/유창강건	G/지점이송	H/자동작성	C/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=issuereqdet_ship_flag dbname="issuereqdet.ship_flag" )
 column=(type=char(1) update=yes updatewhereclause=yes name=issuereqdet_ship_case dbname="issuereqdet.ship_case" values="정기화물	J/택배	T/오토바이	A/선박	S/항공	P/기타	E/" )
 column=(type=char(60) update=yes updatewhereclause=yes name=issuereqdet_tel dbname="issuereqdet.tel" )
 column=(type=char(60) update=yes updatewhereclause=yes name=issuereqdet_rem dbname="issuereqdet.rem" )
 column=(type=datetime update=yes updatewhereclause=yes name=issuereqdet_sys_date dbname="issuereqdet.sys_date" initial="getdate()" )
 column=(type=char(1) updatewhereclause=yes name=confirm_flag dbname="issuereq.confirm_flag" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="SCENE.scene_desc" )
 column=(type=decimal(0) updatewhereclause=yes name=issueqty dbname="issueqty" )
 retrieve="  SELECT issuereqdet.req_date         
       , issuereqdet.salesman         
       , issuereqdet.req_seq          
       , issuereqdet.req_flag         
       , issuereqdet.seq              
       , issuereqdet.cust_no          
       , issuereqdet.scene_code       
       , issuereqdet.add_scene        
       , issuereqdet.sale_no          
       , issuereqdet.item_name         
       , issuereqdet.uom              
       , issuereqdet.issue_flag       
       , issuereqdet.issue_schedule   
       , issuereqdet.ship_flag        
       , issuereqdet.ship_case        
       , issuereqdet.tel              
       , issuereqdet.rem              
       , issuereqdet.sys_date              
       , issuereq.confirm_flag        
       , customer.cust_name           
       , scene.scene_desc  
       , issueqty = ( SELECT SUM(ISNULL(ISSUE_QTY,0)) FROM ISSUEREQDET_SALE 
                                     WHERE  ( ISSUEREQDET_SALE.req_date    = :ad_date          )  
								  AND ( ISSUEREQDET_SALE.salesman    = :as_user          )
								  AND ( ISSUEREQDET_SALE.req_seq     = :ai_seq           )
                                            AND ISSUEREQDET_SALE.REQ_DATE = ISSUEREQDET.REQ_DATE 
                                            AND ISSUEREQDET_SALE.SALESMAN =ISSUEREQDET.SALESMAN 
                                            AND ISSUEREQDET_SALE.REQ_SEQ = ISSUEREQDET.REQ_SEQ
                                            AND ISSUEREQDET_SALE.SEQ = ISSUEREQDET.SEQ
                                            AND ISSUEREQDET_SALE.ORDER_NO = ISSUEREQDET.sale_no
                           )
    FROM issuereqdet LEFT OUTER JOIN  issuereq ON  issuereqdet.req_date  = issuereq.req_date AND issuereqdet.salesman  = issuereq.salesman  AND  issuereqdet.req_seq   = issuereq.req_seq
                                              LEFT OUTER JOIN  scene      ON  issuereqdet.scene_code = scene.scene_code
                                              INNER JOIN  customer  ON  issuereqdet.cust_no     = customer.cust_no
   WHERE  ( issuereqdet.req_date    = :ad_date          )  
     AND ( issuereqdet.salesman    = :as_user          )
     AND ( issuereqdet.req_seq     = :ai_seq           )
     AND ( issuereqdet.req_flag    = :as_flag          )
/*
       , issueqty = (SELECT sum(saledet.issue_qty) 
                       FROM saledet 
                      WHERE ( saledet.order_no  = issuereqdet.sale_no ) 
                        AND ((saledet.loc_no    = :as_locno OR saledet.loc_no IS NULL))
                        AND ( saledet.order_qty > saledet.rlse_qty )
                    )
    FROM issuereqdet
       , issuereq   
       , scene      
       , customer  
   WHERE ( issuereqdet.req_date   *= issuereq.req_date )    
     AND ( issuereqdet.salesman   *= issuereq.salesman )    
     AND ( issuereqdet.req_seq    *= issuereq.req_seq  )   
     AND ( issuereqdet.scene_code *= scene.scene_code  )
     AND ( issuereqdet.cust_no     = customer.cust_no  )    
     AND ( issuereqdet.req_date    = :ad_date          )  
     AND ( issuereqdet.salesman    = :as_user          )
     AND ( issuereqdet.req_seq     = :ai_seq           )
     AND ( issuereqdet.req_flag    = :as_flag          )
*/" update="issuereqdet" updatewhere=0 updatekeyinplace=no arguments=(("ad_date", date),("as_user", string),("ai_seq", number),("as_flag", string),("as_locno", string))  sort="issuereqdet_req_date A issuereqdet_salesman A issuereqdet_req_seq A issuereqdet_req_flag A issuereqdet_seq A " )
