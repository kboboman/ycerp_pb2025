footer(height=0 color="536870912" )
detail(height=72 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=ineoym_cyear dbname="cyear" )
 column=(type=char(2) updatewhereclause=yes name=ineoym_cmon dbname="cmon" )
 column=(type=char(10) updatewhereclause=yes name=ineoym_item_no dbname="item_no" )
 column=(type=char(20) updatewhereclause=yes name=ineoym_qa dbname="qa" )
 column=(type=char(10) updatewhereclause=yes name=ineoym_loc_no dbname="loc_no" )
 column=(type=decimal(4) updatewhereclause=yes name=ineoym_rcpt_qty dbname="rcpt_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=ineoym_issue_qty dbname="issue_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=itemloc_qoh dbname="qoh" )
 column=(type=decimal(4) updatewhereclause=yes name=ineoym_qoh dbname="qoh" initial="0" )
 column=(type=decimal(4) updatewhereclause=yes name=nqty dbname="nqty" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=decimal(4) updatewhereclause=yes name=drcpt dbname="drcpt" )
 column=(type=decimal(4) updatewhereclause=yes name=dissue dbname="dissue" )
 retrieve="  SELECT ineoym.cyear,   
         ineoym.cmon,   
         ineoym.item_no,   
         ineoym.qa,   
         ineoym.loc_no,   
         ineoym.rcpt_qty,   
         ineoym.issue_qty,   
         itemloc.qoh,   
         ineoym.qoh, 
	    nday.nqty,   
         ineoday.item_no,   
         ineoday.qa,   
         drcpt = sum(ineoday.rcpt_qty),   
         dissue = sum(ineoday.issue_qty)
    FROM ineoday left outer join ineoym on ineoday.item_no = ineoym.item_no 
                                             and ineoday.qa = ineoym.qa 
                                             and ineoday.loc_no = ineoym.loc_no
                                             and ( ( substring(ineoday.cdate,1,4) = ineoym.cyear ) AND  
                                                      ( substring(ineoday.cdate,5,2) = ineoym.cmon ) AND  
                                                      ( ineoym.cyear = :ai_yy ) AND  
                                                      ( ineoym.cmon = :ai_mm ) )   
                              left outer join itemloc on ineoday.item_no = itemloc.item_no
                                             and ineoday.qa = itemloc.qa
                                             and ineoday.loc_no = itemloc.loc_no
                        	    left outer join (select item_no, qa, loc_no, nqty = sum(ineoday.rcpt_qty) - sum(ineoday.issue_qty) 
                                            			   from ineoday
                                                       where cdate > rtrim(:ai_yy) + rtrim(:ai_mm) +'99' 
                                            			 group by item_no, qa, loc_no 
                                                   ) nday on ineoday.item_no = nday.item_no
                                              and ineoday.qa = nday.qa
                                              and ineoday.loc_no = nday.loc_no
   WHERE ( ( CONVERT(INTEGER, substring(ineoday.cdate,1,4)) = :ai_yy ) AND  
                    ( CONVERT(INTEGER, substring(ineoday.cdate,5,2)) = :ai_mm  ) )
GROUP BY ineoym.cyear,   
         ineoym.cmon,   
         ineoym.item_no,   
         ineoym.qa,   
         ineoym.loc_no,   
         ineoym.rcpt_qty,   
         ineoym.issue_qty,   
         itemloc.qoh,   
         ineoym.qoh, 
	    nday.nqty,
         ineoday.item_no,   
         ineoday.qa  " arguments=(("ai_yy", string),("ai_mm", string))  sort="ineoym_loc_no A ineoym_item_no A ineoym_qa A " )
