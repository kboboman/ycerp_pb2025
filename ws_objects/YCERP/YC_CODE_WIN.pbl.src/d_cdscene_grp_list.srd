 retrieve="  SELECT customer.cust_no
       , customer.cust_name  
       , cnt     = (SELECT count(*) FROM scene WHERE cust_no = customer.cust_no)
    FROM customer   
" update="customer" updatewhere=1 updatekeyinplace=no  sort="cust_name A " )
