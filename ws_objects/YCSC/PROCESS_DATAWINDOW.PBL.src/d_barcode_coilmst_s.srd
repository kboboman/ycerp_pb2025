$PBExportHeader$d_barcode_coilmst_s.srd
$PBExportComments$바코드재출력용데이타윈도우(2004년어느날, 정갑용)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=92 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="15780518" )
detail(height=92 color="536870912" )
table(column=(type=decimal(1) updatewhereclause=yes name=swid dbname="swid" )
 column=(type=long updatewhereclause=yes name=cnt dbname="cnt" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(10) updatewhereclause=yes name=loc_no dbname="loc_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=long updatewhereclause=yes name=unit_qty dbname="unit_qty" )
 column=(type=decimal(2) updatewhereclause=yes name=thin dbname="thin" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(20) updatewhereclause=yes name=coil_no dbname="coil_no" )
 retrieve="SELECT swid = convert (decimal (5,1), substring(coilmst.qa,5,4) + '.' + substring(coilmst.qa, 10,1)),   
       cnt  = coilmst.qcnt,
       qa   = coilmst.qa,
       loc_no = coilmst.loc_no,
		 item_no = coilmst.item_no,
		 unit_qty = coilmst.unit_qty,
       thin = convert (decimal (3,2), substring(coilmst.qa,1,1) + '.' + substring(coilmst.qa, 2,2)),   
		 groupitem.item_name,
		 coil_no = coilmst.coil_no
  FROM coilmst,
		 groupitem
 WHERE ( coilmst.item_no = groupitem.item_no ) and
		 ( coilmst.loc_no like :as_loc ) and
       ( coilmst.flag like :as_flag ) and
       ( coilmst.open_close in (:as_oc) ) and
       ( coilmst.coil_no like :as_coil ) and
       ( coilmst.item_no not in ( select lossitem.loss_item from lossitem )) 
" arguments=(("as_loc", string),("as_flag", string),("as_oc", stringlist),("as_coil", string))  sort="coil_no A " )
