 retrieve="  SELECT glbilldet.vc_no,   
         glbilldet.billdet_vcno,   
         glbilldet.det_class,   
         glbilldet.close_date,   
         glbilldet.start_date,   
         glbilldet.acct_date,   
         glbilldet.bank_code,   
         glbilldet.bill_area,   
         glbilldet.amount,   
         glbilldet.draft,   
         glbilldet.rem,   
         glbilldet.user_id,   
         glbilldet.bill_no,   
         glbilldet.billdet_no  
    FROM glbilldet  
   WHERE glbilldet.vc_no = :as_vc_no    
" update="glbilldet" updatewhere=1 updatekeyinplace=yes arguments=(("as_vc_no", string)) )
