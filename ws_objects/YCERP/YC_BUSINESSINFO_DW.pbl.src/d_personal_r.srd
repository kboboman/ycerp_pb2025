text(band=header alignment="2" text="기관(회사)명" border="0" color="0" x="462" y="4" height="76" width="901" html.valueishtml="0"  name=company_t visible="1"  font.face="굴림체" font.height="-11" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="15780518" )
