$PBExportComments$품목별 재고현황(2001/10/16,이인호)
release 6;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=80 color="536870912" )
table(column=(type=char(20) updatewhereclause=yes name=incounu_qa dbname="incounu.qa" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(10) updatewhereclause=yes name=incounu_item_no dbname="incounu.item_no" )
 retrieve="  SELECT incounu.qa,   
         groupitem.item_name,   
         incounu.item_no  
    FROM incounu,   
         groupitem  
   WHERE ( incounu.item_no = groupitem.item_no ) and  
         ( incounu.user_id = :as_user ) and
			( incounu.loc_no = :as_loc )" arguments=(("as_user", string),("as_loc", string))  sort="groupitem_item_name A incounu_qa A " )
text(band=header alignment="2" text="품명"border="6" color="0" x="9" y="8" height="60" width="590"  name=groupitem_item_name_t  font.face="굴림체" font.height="-10" font.weight="400"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="79741120" )
