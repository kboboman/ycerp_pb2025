 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"sfcday~" )  TABLE(NAME=~"wc~" )  TABLE(NAME=~"groupitem~" ) COLUMN(NAME=~"sfcday.sfc_date~") COLUMN(NAME=~"wc.work_name~") COLUMN(NAME=~"groupitem.item_name~") COLUMN(NAME=~"sfcday.assembly_qa~") COLUMN(NAME=~"sfcday.make_qty~") COLUMN(NAME=~"sfcday.order_no~") COLUMN(NAME=~"sfcday.item_no~") COLUMN(NAME=~"sfcday.qa~") COLUMN(NAME=~"sfcday.assembly~") COLUMN(NAME=~"sfcday.cust_name~") COLUMN(NAME=~"sfcday.cust_no~") COLUMN(NAME=~"sfcday.scene_code~")    JOIN (LEFT=~"sfcday.assembly~"    OP =~"=~"RIGHT=~"groupitem.item_no~" )    JOIN (LEFT=~"sfcday.wc_no~"    OP =~"=~"RIGHT=~"wc.work_no~" )WHERE(    EXP1 =~"sfcday.sale_no~"   OP =~"=~"    EXP2 =~"(select distinct sale_no from dodet where do_no = :as_dono)~" ) ) ARG(NAME = ~"as_dono~" TYPE = string) " arguments=(("as_dono", string)) )
