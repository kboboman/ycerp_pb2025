$PBExportHeader$d_cditemalllocqoh_paint_c.srd
$PBExportComments$저장소규격(1998/10/08,곽용덕)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=68 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=decimal(4) updatewhereclause=yes name=qoh dbname="qoh" )
 column=(type=decimal(0) updatewhereclause=yes name=qty dbname="qty" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(10) updatewhereclause=yes name=item_item_no dbname="item_no" )
 column=(type=char(50) updatewhereclause=yes name=paint_no dbname="paint_no" )
 column=(type=char(50) updatewhereclause=yes name=paint_name dbname="paint_name" )
 column=(type=char(50) updatewhereclause=yes name=paint_company dbname="paint_company" )
 retrieve="  SELECT qoh     = sum(a.qoh)
       , qty     = sum(a.qty)
       , qa      = a.qa
       , item_no = a.item_no  
	  , paint_no = a.paint_no
	  , paint_name = a.paint_name
	  , paint_company = a.paint_company
    FROM (
			SELECT qoh = 0
				  , qty = 0
				  , item.qa
				  , item.item_no  
				  , item.paint_no
				  , item.paint_name
				  , item.paint_company
			  FROM item with(nolock)              
/*          WHERE ( loc_no    = :as_loc   )*/
		     WHERE  ( loc_no    LIKE   ( CASE  WHEN :as_loc = '%' THEN '%' ELSE :as_loc end  )   ) /*2018.02.07 조원석 수정 */
				AND ( item_no      = :as_item     )
				AND ( item.use_flag     = 'Y'     )
			UNION ALL
			SELECT qoh = isnull(itemloc.qoh, 0)
				  , qty = 0
				  , item.qa
				  , item.item_no  
				  , item.paint_no
				  , item.paint_name
				  , item.paint_company
			  FROM item with(nolock) LEFT OUTER JOIN itemloc with(nolock) ON item.item_no = itemloc.item_no  AND item.qa = itemloc.qa
/*       WHERE ( itemloc.loc_no    = :as_loc         )*/
	 		WHERE ( itemloc.loc_no LIKE   ( CASE  WHEN :as_loc = '%' THEN '%' ELSE :as_loc end   )   )
				AND ( item.item_no      = :as_item        )
				AND ( item.use_flag     = 'Y'             )
		 
			UNION ALL
			SELECT qoh = 0
				  , qty = isnull(itemstock.qty, 0)
				  , item.qa
				  , item.item_no  
				  , item.paint_no
				  , item.paint_name
				  , item.paint_company
			  FROM item with(nolock) LEFT OUTER JOIN itemstock with(nolock) ON item.item_no = itemstock.item_no  AND item.qa = itemstock.qa
/*          WHERE ( itemstock.loc_no  = :as_loc           )  	*/
	          WHERE ( itemstock.loc_no LIKE   ( CASE  WHEN :as_loc = '%' THEN '%' ELSE :as_loc end   )   )
				AND ( item.item_no      = :as_item          )
				AND ( item.use_flag     = 'Y'               )
         ) A
   GROUP BY a.item_no, a.qa, a.paint_no, a.paint_name, a.paint_company
" arguments=(("as_loc", string),("as_item", string))  sort="qa A " )
