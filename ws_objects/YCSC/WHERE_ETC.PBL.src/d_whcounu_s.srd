$PBExportHeader$d_whcounu_s.srd
$PBExportComments$담당자별실사품목(2001/09/11,이대준)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=72 color="536870912" )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=68 color="536870912" )
table(column=(type=char(10) update=yes updatewhereclause=yes name=user_id dbname="incounu.user_id" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="incounu.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="incounu.qa" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="GroupItem.item_name" )
 column=(type=char(30) updatewhereclause=yes name=location_loc_name dbname="location.loc_name" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=char(2) updatewhereclause=yes name=com_uom dbname="com_uom" )
 column=(type=decimal(4) updatewhereclause=yes name=qoh dbname="itemloc.qoh" )
 retrieve="  SELECT incounu.user_id,   
         incounu.item_no,   
         incounu.qa,   
         groupitem.item_name,   
         location.loc_name,
			uom = groupitem.uom ,
			com_uom = (case groupitem.uom when 'M'  then 'EA'
						  					 when 'M2' then 'EA'
											 else groupitem.uom
				   end),
			itemloc.qoh   
FROM incounu with(nolock) inner join groupitem with(nolock) on incounu.item_no = groupitem.item_no
                                                inner join location with(nolock) on incounu.loc_no = location.loc_no
          			                           left outer join itemloc with(nolock) on incounu.loc_no = itemloc.loc_no and incounu.item_no = itemloc.item_no and incounu.qa = itemloc.qa
WHERE ( incounu.loc_no = :as_loc ) and  ( incounu.user_id = :as_user )
			
" arguments=(("as_user", string),("as_loc", string))  sort="location_loc_name A item_name A qa A " )
