table(column=(type=char(12) updatewhereclause=yes key=yes name=driver dbname="docar.driver" )
 column=(type=char(10) updatewhereclause=yes name=name dbname="docar.name" )
 column=(type=char(40) updatewhereclause=yes name=cargo_name dbname="docar.cargo_name" )
 column=(type=char(13) updatewhereclause=yes name=hp dbname="hp" )
 retrieve="  SELECT docar.driver
       , docar.name
       , docar.cargo_name
       , hp   = isnull(docar.hp,'')
    FROM docar  
   WHERE docar.open_close = 'O'    
" update="docar" updatewhere=0 updatekeyinplace=no  sort="driver A " )
