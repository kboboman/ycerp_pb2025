text(band=header alignment="2" text="입고" border="0" color="33554432" x="2464" y="344" height="60" width="2290" html.valueishtml="0"  name=t_4 visible="1"  font.face="굴림체" font.height="-10" font.weight="700"  font.family="1" font.pitch="1" font.charset="129" background.mode="2" background.color="67108864" )
