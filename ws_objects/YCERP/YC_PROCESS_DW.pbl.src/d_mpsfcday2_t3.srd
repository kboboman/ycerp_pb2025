table(column=(type=char(10) updatewhereclause=yes name=wc_no dbname="wc_no" )
 column=(type=char(10) updatewhereclause=yes name=work_name dbname="work_name" )
 column=(type=char(10) updatewhereclause=yes name=cdate dbname="cdate" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=decimal(4) updatewhereclause=yes name=sum_qty dbname="sum_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=sum_ret dbname="sum_ret" )
 column=(type=decimal(4) updatewhereclause=yes name=sum_rem dbname="sum_rem" )
 column=(type=char(20) updatewhereclause=yes name=coil_no dbname="coil_no" )
 column=(type=char(17) updatewhereclause=yes name=order_no dbname="order_no" )
 column=(type=char(16) updatewhereclause=yes name=mpsorder dbname="mpsorder" )
 retrieve="  SELECT wc_no      = a.wc_no               /* 일자별 사용자재 */
       , work_name  = d.work_name
       , cdate      = convert(char(10),a.use_date,111)
       , item_no    = a.item_no
       , item_name  = c.item_name   
       , qa         = a.qa             
       , uom        = a.uom
/*    , sum_qty    = (case when a.uom = 'SH' then a.use_qty else a.unit_qty * a.cnt end)*/		/* 2018.05.24 jowonsuk 주석처리 */
/*	  , sum_qty   = ( a.use_qty )	*/																			/* 2018.05.24 jowonsuk 사용수량을 사용  */	
	  /*2018.08.03 jowonsuk 반영 */
  	  , sum_qty =  (    case when c.p4 = '1' then isnull(a.mod_qty,0)
								when c.p4 = '2' then isnull(a.use_qty,0) 
								else  isnull(a.use_qty,0) 
							      end 
					  )
       , sum_ret   =  (case when b.unit_qty * b.cnt is not null then b.unit_qty * b.cnt else 0 end)
                    + (case when a.rem_qty          is not null then a.rem_qty          else 0 end)
		/*2018.08.03 jowonsuk 반영 */
       , sum_rem    = /*(case when a.rem_qty          is null     then a.unit_qty * a.cnt else a.unit_qty * a.cnt - a.rem_qty end)*/  
							(    case when c.p4 = '1' then isnull(a.mod_qty,0) - isnull(a.rem_qty,0)
									    when c.p4 = '2' then isnull(a.use_qty,0) - isnull(a.rem_cnt,0)
									    else  isnull(a.use_qty,0) - isnull(a.rem_qty,0)
									    end 
					           )                            /*jowonsuk 2018.08.03 반영 */
       , coil_no    = a.coil_no
       , order_no   = a.order_no
       , mpsorder   = e.mpsorder_order
    FROM (
                    select loc_no, coil_no, order_no, wc_no, use_date, item_no, qa, uom, unit_qty, sum(cnt) cnt, sum(rem_qty) rem_qty,  sum(use_qty) use_qty, sum(mod_qty) mod_qty, sum(rem_cnt)  rem_cnt
                      from sfcuse  a
                       where  ( a.item_no          = :as_itemno     )
                            and ( a.coil_no       is not null         )
                            and ( a.area_no       LIKE :as_area + '%' )                          
                             and ( a.qa               = :as_qa         )             
                             and ((:as_coilno  = '%' ) OR
                                       (:as_coilno <> '%' AND a.coil_no  = :as_coilno)
                                    )
                            and convert(char(10),a.use_date,111) BETWEEN :as_sdate AND :as_edate
                      group by loc_no, coil_no, order_no, wc_no, use_date, item_no, qa, uom, unit_qty
    
                )    A   
         LEFT OUTER JOIN sfcret    B ON a.use_date = b.ret_date AND a.coil_no = b.wcoil_no AND a.loc_no = b.loc_no
         LEFT OUTER JOIN groupitem C ON a.item_no = c.item_no
         LEFT OUTER JOIN wc        D ON a.wc_no   = d.work_no
         LEFT OUTER JOIN (         
                                              select distinct order_no, mpsorder_order                                        
                                              from sfcday         
                                       ) E ON a.order_no = e.order_no
   WHERE  ( d.work_name     LIKE :as_wc + '%'   )
/*
    FROM sfcuse    A   
         LEFT OUTER JOIN sfcret    B ON a.use_date = b.ret_date AND a.coil_no = b.wcoil_no AND a.loc_no = b.loc_no
         LEFT OUTER JOIN groupitem C ON a.item_no = c.item_no
         LEFT OUTER JOIN wc        D ON a.wc_no   = d.work_no
         LEFT OUTER JOIN sfcday    E ON a.order_no = e.order_no
   WHERE ( a.coil_no       is not null         )
     AND ( a.area_no       LIKE :as_area + '%' )   
     AND ( d.work_name     LIKE :as_wc + '%'   )
     AND ( a.item_no          = :as_itemno     )
     AND ( a.qa               = :as_qa         )             
     AND ((:as_coilno  = '%' ) OR
          (:as_coilno <> '%' AND a.coil_no  = :as_coilno)
         )
     AND ( convert(char(10),a.use_date,111) BETWEEN :as_sdate AND :as_edate )
*/" arguments=(("as_area", string),("as_wc", string),("as_itemno", string),("as_qa", string),("as_coilno", string),("as_sdate", string),("as_edate", string)) )
