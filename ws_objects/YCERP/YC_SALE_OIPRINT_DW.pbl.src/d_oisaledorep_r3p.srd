$PBExportComments$영업사원별 출고현황 DISPLAY(1999/07/13, 이종탁)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
header(height=532 color="16777215" )
summary(height=68 color="536870912" )
footer(height=0 color="536870912" )
detail(height=68 color="536870912" )
table(column=(type=char(10) updatewhereclause=yes name=login_user_name dbname="user_name" )
 column=(type=char(4) updatewhereclause=yes name=do_cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="cust_name" )
 column=(type=char(11) updatewhereclause=yes name=do_spot_code dbname="spot_code" )
 column=(type=char(40) updatewhereclause=yes name=scene_scene_desc dbname="scene_desc" )
 column=(type=datetime updatewhereclause=yes name=do_do_date dbname="do_date" )
 column=(type=char(12) updatewhereclause=yes name=inv_no dbname="inv_no" )
 column=(type=char(30) updatewhereclause=yes name=do_ship_flag dbname="ship_flag" )
 column=(type=char(1) updatewhereclause=yes name=ship_flag2 dbname="ship_flag2" )
 column=(type=decimal(0) updatewhereclause=yes name=do_ship_amount dbname="ship_amount" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_rate dbname="do_rate" )
 column=(type=char(3) updatewhereclause=yes name=do_curr_code dbname="curr_code" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_cash dbname="do_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=do_do_total dbname="do_total" )
 column=(type=char(1) updatewhereclause=yes name=shipamt_case dbname="shipamt_case" )
 column=(type=char(14) updatewhereclause=yes name=do_do_no dbname="do_no" )
 column=(type=long updatewhereclause=yes name=dodet_oi_no dbname="oi_no" )
 column=(type=char(10) updatewhereclause=yes name=dodet_item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=dodet_qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=dodet_uom dbname="uom" )
 column=(type=decimal(2) updatewhereclause=yes name=dodet_ship_qty dbname="ship_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=dodet_price dbname="price" )
 column=(type=decimal(4) updatewhereclause=yes name=dodet_rate_cash dbname="rate_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=c_acc_qty dbname="c_acc_qty" )
 column=(type=char(1) updatewhereclause=yes name=round dbname="round" )
 column=(type=char(14) updatewhereclause=yes name=sale_no dbname="sale_no" )
 column=(type=datetime updatewhereclause=yes name=prt_date dbname="prt_date" )
 column=(type=datetime updatewhereclause=yes name=issue_date dbname="issue_date" )
 column=(type=datetime updatewhereclause=yes name=ship_date dbname="ship_date" )
 column=(type=long updatewhereclause=yes name=datecalc dbname="datecalc" )
 retrieve="  SELECT distinct login.user_name
       , do.cust_no        
       , c.cust_name   
       , do.spot_code   
       , scene.scene_desc   
       , do.do_date     
       , do.inv_no         
       , ship_flag  = dbo.uf_getshipflag(do.ship_flag)
       , ship_flag2 = do.ship_flag
       , do.ship_amount
       , do.do_rate        
       , do.curr_code      
       , do.do_cash        
       , do.do_total       
       , do.shipamt_case   
       , do.do_no       
       , dodet.oi_no     
       , dodet.item_no   
       , groupitem.item_name
       , dodet.qa    
       , dodet.uom   
       , dodet.ship_qty   
       , dodet.price   
       , dodet.rate_cash
       , c_acc_qty = round(dbo.uf_getqty(dodet.item_no, dodet.qa, dodet.uom, dodet.ship_qty),2,1)
       , c.round
       , dodet.sale_no

       , do.prt_date
       , do.issue_date
       , do.ship_date
       , datecalc    = DATEDIFF(month, do.issue_date, do.do_date) 
    FROM UF_MyCustomers( :as_salesman ) M
         LEFT OUTER JOIN customer C ON m.cust_no     = c.cust_no
         LEFT OUTER JOIN do         ON c.cust_no     = do.cust_no
         LEFT OUTER JOIN dodet      ON do.do_no      = dodet.do_no
         LEFT OUTER JOIN groupitem  ON dodet.item_no = groupitem.item_no
         LEFT OUTER JOIN scene      ON do.spot_code  = scene.scene_code 
         LEFT OUTER JOIN login      ON c.salesman    = login.user_id
   WHERE ( do.do_no           LIKE :as_area          )
     AND ( do.do_date      BETWEEN :as_sdate and :as_edate )
     AND ((:as_team  = '%' AND m.cust_no   LIKE '%'  ) OR 
          (:as_team <> '%' AND m.salesman     = :as_salesman )
         )
     AND ((:as_custno  = '%'   AND m.cust_no   LIKE '%'  ) OR 
          (:as_custno  = 'ALL' AND m.cust_no   LIKE '%'  ) OR 
          (:as_custno <> 'ALL' AND m.cust_no      = :as_custno )
         )
" arguments=(("as_area", string),("as_custno", string),("as_sdate", string),("as_edate", string),("as_salesman", string),("as_team", string))  sort="login_user_name A dodet_item_no A do_cust_no A do_spot_code A do_do_no A dodet_oi_no A " )
