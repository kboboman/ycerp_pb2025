table(column=(type=long updatewhereclause=yes name=seq dbname="seq" )
 column=(type=char(20) updatewhereclause=yes name=area dbname="area" )
 column=(type=char(20) updatewhereclause=yes name=sector dbname="sector" )
 column=(type=char(20) updatewhereclause=yes name=team dbname="team" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="user_id" )
 column=(type=char(20) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(10) updatewhereclause=yes name=rank dbname="rank" )
 column=(type=decimal(2) updatewhereclause=yes name=inv01 dbname="inv01" )
 column=(type=decimal(2) updatewhereclause=yes name=inv02 dbname="inv02" )
 column=(type=decimal(2) updatewhereclause=yes name=inv03 dbname="inv03" )
 column=(type=decimal(2) updatewhereclause=yes name=inv04 dbname="inv04" )
 column=(type=decimal(2) updatewhereclause=yes name=inv05 dbname="inv05" )
 column=(type=decimal(2) updatewhereclause=yes name=inv06 dbname="inv06" )
 column=(type=decimal(2) updatewhereclause=yes name=inv07 dbname="inv07" )
 column=(type=decimal(2) updatewhereclause=yes name=inv08 dbname="inv08" )
 column=(type=decimal(2) updatewhereclause=yes name=inv09 dbname="inv09" )
 column=(type=decimal(2) updatewhereclause=yes name=inv10 dbname="inv10" )
 column=(type=decimal(2) updatewhereclause=yes name=inv11 dbname="inv11" )
 column=(type=decimal(2) updatewhereclause=yes name=inv12 dbname="inv12" )
 retrieve="  SELECT seq         = o.seq                                /* 순서     */
       , area        = o.area                               /* 권역     */
       , sector      = o.sector                             /* 본부     */
       , team        = o.team                               /* 팀       */
       , user_id     = o.user_id                            /* 담당자   */
       , user_name   = o.user_name                          /* 담당자명 */
       , rank        = o.rank                               /* 직책     */
       
       , inv01       = sum(a.inv01)
       , inv02       = sum(a.inv02)
       , inv03       = sum(a.inv03)
       , inv04       = sum(a.inv04)
       , inv05       = sum(a.inv05)
       , inv06       = sum(a.inv06)
       , inv07       = sum(a.inv07)
       , inv08       = sum(a.inv08)
       , inv09       = sum(a.inv09)
       , inv10       = sum(a.inv10)
       , inv11       = sum(a.inv11)
       , inv12       = sum(a.inv12)
    FROM (
         SELECT cust_no     = opeom.cust_no
              , salesman    = c.salesman
              , user_name   = l.user_name
              , inv01       = opeom.inv_01
              , inv02       = opeom.inv_02
              , inv03       = opeom.inv_03
              , inv04       = opeom.inv_04
              , inv05       = opeom.inv_05
              , inv06       = opeom.inv_06
              , inv07       = opeom.inv_07
              , inv08       = opeom.inv_08
              , inv09       = opeom.inv_09
              , inv10       = opeom.inv_10
              , inv11       = opeom.inv_11
              , inv12       = opeom.inv_12
           FROM opeom 
                LEFT OUTER JOIN customer C ON opeom.cust_no = c.cust_no
                LEFT OUTER JOIN login    L ON c.salesman = l.user_id
          WHERE datepart(year, eom_year) = :ai_year
         ) A
         FULL JOIN opeom_org       O  ON o.user_id  = a.salesman
   WHERE o.seq  IS NOT NULL
   GROUP BY o.seq  
          , o.area 
          , o.sector
          , o.team  
          , o.user_id
          , o.user_name
          , o.rank     
   ORDER BY o.seq
" arguments=(("ai_year", number))  sort="seq A " )
