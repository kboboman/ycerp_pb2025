event clicked;// [[[ 판매거래처 변경작업 실행 ]]]
long   ll_row, ll_cnt, ll_dw26Row, ll_id
string ls_custno, ls_chk, ls_query, ls_field, ls_cols, ls_type

if GF_PERMISSION("판매거래처관리EDIT(일괄)", gs_userid) = "Y" then
else
   MessageBox("확인", "'판매거래처관리EDIT(일괄)' 작업권한이 없습니다.")
	RETURN
end if

if dw_26.object.chk_cnt[1] < 1 then
   MessageBox("확인", "작업할 대상필드를 선택 하시기 바랍니다.")
   dw_26.setcolumn("chk")
   dw_26.setfocus()
   return
end if

if dw_27.object.chk_cnt[1] < 1 then
   MessageBox("확인", "작업할 대상을 선택 하시기 바랍니다.")
   dw_27.setcolumn("chk")
   dw_27.setfocus()
   return
end if

if MessageBox("확인","[[[ 판매거래처 변경작업 실행 ]]]~r~n~r~n작업을 진행 하시겠습니까?", Exclamation!, YesNo!, 2) = 2 then RETURN

Pointer oldpointer // Declares a pointer variable
oldpointer = SetPointer(HourGlass!)
dw_26.enabled = false	// LOCKING

