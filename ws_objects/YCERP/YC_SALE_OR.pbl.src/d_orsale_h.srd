detail(height=392 color="536870912" )
table(column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=decimal(0) updatewhereclause=yes name=pavg dbname="pavg" )
 column=(type=decimal(0) updatewhereclause=yes name=pmon dbname="pmon" )
 column=(type=decimal(0) updatewhereclause=yes name=pmonth dbname="pmonth" )
 column=(type=decimal(0) updatewhereclause=yes name=pamt dbname="pamt" )
 column=(type=decimal(0) updatewhereclause=yes name=pbalbfamt dbname="pbalbfamt" )
 column=(type=decimal(4) updatewhereclause=yes name=balance_amt dbname="balance_amt" )
 retrieve="  SELECT cust_name   = customer.cust_name
       , pavg        = dbo.UF_GetPreviousAVG( :as_custno, :ai_year )
       , pmon        = dbo.UF_GetMonthAVG( :as_custno, :ai_year, :ai_month )
       , pmonth      = dbo.UF_GetPreviousMONTH( :as_custno, getdate() )
       , pamt        = dbo.UF_GetMonthAMT( :as_custno, :ai_year, :ai_month )
       , pbalbfamt   = dbo.UF_GetBALBFAMOUNT( :as_custno, :ai_year )
       , balance_amt = customer.balance_amt
    FROM customer
   WHERE cust_no = :as_custno
" arguments=(("as_custno", string),("ai_year", number),("ai_month", number)) )
