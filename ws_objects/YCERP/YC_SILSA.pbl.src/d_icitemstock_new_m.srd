$PBExportHeader$d_icitemstock_new_m.srd
$PBExportComments$장기재고관리(2003/08/25, 이인호)
release 8;
datawindow(units=0 timer_interval=0 color=67108864 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no )
summary(height=0 color="536870912" )
footer(height=0 color="536870912" )
detail(height=488 color="536870912" )
table(column=(type=long updatewhereclause=yes key=yes identity=yes name=id dbname="itemstockdet.id" )
 column=(type=char(10) update=yes updatewhereclause=yes name=loc_no dbname="itemstockdet.loc_no" )
 column=(type=char(10) update=yes updatewhereclause=yes name=item_no dbname="itemstockdet.item_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=qa dbname="itemstockdet.qa" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=qty dbname="itemstockdet.qty" )
 column=(type=char(60) update=yes updatewhereclause=yes name=reason1 dbname="itemstockdet.reason1" )
 column=(type=char(60) update=yes updatewhereclause=yes name=reason2 dbname="itemstockdet.reason2" )
 column=(type=char(60) update=yes updatewhereclause=yes name=reason3 dbname="itemstockdet.reason3" )
 column=(type=char(10) update=yes updatewhereclause=yes name=chk1_user dbname="itemstockdet.chk1_user" )
 column=(type=char(10) update=yes updatewhereclause=yes name=chk2_user dbname="itemstockdet.chk2_user" )
 column=(type=datetime update=yes updatewhereclause=yes name=user_date dbname="itemstockdet.user_date" )
 column=(type=char(14) update=yes updatewhereclause=yes name=itemstockdet_sale_no dbname="itemstockdet.sale_no" )
 column=(type=long update=yes updatewhereclause=yes name=itemstockdet_sale_seq dbname="itemstockdet.sale_seq" )
 column=(type=char(16) updatewhereclause=yes name=itemstockdet_order_no dbname="itemstockdet.order_no" )
 column=(type=long updatewhereclause=yes name=itemstockdet_seq dbname="itemstockdet.seq" )
 column=(type=char(1) update=yes updatewhereclause=yes name=itemstockdet_kind dbname="itemstockdet.kind" values="생산미출고	1/반품	2/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=itemstockdet_close_yn dbname="itemstockdet.close_yn" values="사용	O/종료	C/" )
 column=(type=char(1) update=yes updatewhereclause=yes name=reason_code dbname="itemstockdet.reason_code" )
 column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="GroupItem.item_name" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="GroupItem.uom" )
 column=(type=decimal(4) updatewhereclause=yes name=loc_qoh dbname="loc_qoh" )
 retrieve="  SELECT  itemstockdet.id
                 , itemstockdet.loc_no
			 , itemstockdet.item_no
			 , itemstockdet.qa
			 , itemstockdet.qty
			 , itemstockdet.reason1
			 , itemstockdet.reason2
			 , itemstockdet.reason3
			 , itemstockdet.chk1_user
			 , itemstockdet.chk2_user
			 , itemstockdet.user_date
			 , itemstockdet.sale_no
			 , itemstockdet.sale_seq
			 , itemstockdet.order_no
			 , itemstockdet.seq
			 , itemstockdet.kind
			 , itemstockdet.close_yn
			 , itemstockdet.reason_code
			 , groupitem.item_name
			 , groupitem.uom
			 , loc_qoh = itemloc.qoh 
		 FROM itemstockdet INNER JOIN  groupitem ON itemstockdet.item_no   = groupitem.item_no
								    LEFT OUTER JOIN itemloc  ON  itemstockdet.loc_no  = itemloc.loc_no 
																  AND  itemstockdet.item_no  = itemloc.item_no
																  AND  itemstockdet.qa       = itemloc.qa  
		WHERE itemstockdet.id = :as_id" update="itemstockdet" updatewhere=0 updatekeyinplace=no arguments=(("as_id", number)) )
