 column=(type=char(20) updatewhereclause=yes name=bill_area dbname="BILL_AREA" )
 column=(type=decimal(0) updatewhereclause=yes name=bill_amount dbname="BILL_AMOUNT" )
 column=(type=decimal(0) updatewhereclause=yes name=retamt dbname="RETAMT" )
 column=(type=char(1) updatewhereclause=yes name=set_flag dbname="SET_FLAG" )
 column=(type=datetime updatewhereclause=yes name=glbill_set_date dbname="SET_DATE" )
 column=(type=char(20) updatewhereclause=yes name=draft dbname="DRAFT" )
 column=(type=char(40) updatewhereclause=yes name=rem dbname="REM" )
 column=(type=char(10) updatewhereclause=yes name=set_user dbname="SET_USER" )
 retrieve="  SELECT A.VC_NO         
       , A.BILL_NO       
       , A.BILL_CLASS    
       , A.CUST_NO        
       , A.CLOSE_DATE    
       , A.START_DATE    
       , A.BANK_CODE     
       , A.BILL_AREA     
       , A.BILL_AMOUNT 
       , RETAMT = ISNULL(B.RETAMT,0)             
       , A.SET_FLAG      
       , A.SET_DATE      
       , A.DRAFT         
       , A.REM           
       , A.SET_USER  
    FROM GLBILL A
         LEFT OUTER JOIN 
         (
          SELECT GLBILLDET.VC_NO, RETAMT = SUM(GLBILLDET.AMOUNT)
            FROM GLBILLDET  
           GROUP BY GLBILLDET.VC_NO
         ) B ON A.VC_NO = B.VC_NO
   WHERE ( A.CUST_NO    = :aa    )
     AND ( A.SET_FLAG  <> 'Y'    )
" arguments=(("aa", string)) )
