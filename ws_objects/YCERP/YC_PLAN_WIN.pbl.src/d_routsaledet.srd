table(column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(40) updatewhereclause=yes name=scene_desc dbname="scene_desc" )
 column=(type=char(14) updatewhereclause=yes name=order_no dbname="order_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="seq_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=datetime updatewhereclause=yes name=napgi_date dbname="napgi_date" )
 column=(type=datetime updatewhereclause=yes name=napgi_chk dbname="napgi_chk" )
 column=(type=decimal(4) updatewhereclause=yes name=order_qty dbname="order_qty" )
 column=(type=char(10) updatewhereclause=yes name=wc1 dbname="wc1" )
 column=(type=char(10) updatewhereclause=yes name=w1nm dbname="w1nm" )
 column=(type=datetime updatewhereclause=yes name=b1wd dbname="b1wd" )
 column=(type=char(4) updatewhereclause=yes name=b1flag dbname="b1flag" )
 column=(type=decimal(4) updatewhereclause=yes name=b1qty dbname="b1qty" )
 column=(type=char(10) updatewhereclause=yes name=wc2 dbname="wc2" )
 column=(type=char(10) updatewhereclause=yes name=w2nm dbname="w2nm" )
 column=(type=datetime updatewhereclause=yes name=b2wd dbname="b2wd" )
 column=(type=char(4) updatewhereclause=yes name=b2flag dbname="b2flag" )
 column=(type=decimal(4) updatewhereclause=yes name=b2qty dbname="b2qty" )
 column=(type=char(10) updatewhereclause=yes name=wc3 dbname="wc3" )
 column=(type=char(10) updatewhereclause=yes name=w3nm dbname="w3nm" )
 column=(type=datetime updatewhereclause=yes name=b3wd dbname="b3wd" )
 column=(type=char(4) updatewhereclause=yes name=b3flag dbname="b3flag" )
 column=(type=decimal(4) updatewhereclause=yes name=b3qty dbname="b3qty" )
 column=(type=char(50) updatewhereclause=yes name=bigo dbname="bigo" )
 retrieve="  SELECT user_name  = a.user_name
       , cust_name  = a.cust_name
       , scene_desc = a.scene_desc
       , order_no   = a.order_no
       , seq_no     = a.seq_no
       , item_no    = a.item_no
       , item_name  = g.item_name
       , qa         = a.qa19 

       , napgi_date = b1.napgi_date
       , napgi_chk  = (case when b1.napgi_date >= b1.work_date  then b1.napgi_date
                            when b1.work_date  >= b2.work_date  then b1.work_date
                            when b2.work_date  >= b3.work_date  then b2.work_date
                            when b3.work_date  >= b1.napgi_date then b3.work_date
                            else b1.napgi_date
                       end)
       , order_qty  = b1.order_qty

       , wc1        = a.wc1
       , w1nm       = w1.work_name
       , b1wd       = b1.work_date
       , b1flag     = b1.process_flag
       , b1qty      = b1.plan_qty
  
       , wc2        = a.wc2
       , w2nm       = w2.work_name
       , b2wd       = b2.work_date
       , b2flag     = b2.process_flag
       , b2qty      = b2.plan_qty
  
       , wc3        = a.wc3
       , w3nm       = w3.work_name
       , b3wd       = b3.work_date
       , b3flag     = b3.process_flag
       , b3qty      = b3.plan_qty

       , bigo       = b1.rem
    FROM (
          SELECT a.user_name
               , a.cust_name
               , a.scene_desc
               , a.order_no
               , a.seq_no
               , a.item_no
               , a.qa   
               , a.qa19 
               , wc1 = max((case when r.operation = 1 then r.wc_no else null end))
               , wc2 = max((case when r.operation = 2 then r.wc_no else null end))
               , wc3 = max((case when r.operation = 3 then r.wc_no else null end))
            FROM (
                  SELECT l.user_name
                       , c.cust_name
                       , s.scene_desc
                       , a.order_no
                       , a.seq_no
                       , a.item_no
                       , qa   = left(a.qa ,14) + '00000'
                       , qa19 = a.qa
                    FROM saledet A
                         LEFT OUTER JOIN sale       B ON a.order_no   = b.order_no
                         LEFT OUTER JOIN customer   C ON b.cust_no    = c.cust_no
                         LEFT OUTER JOIN scene      S ON b.scene_code = s.scene_code
                         LEFT OUTER JOIN login      L ON c.salesman   = l.user_id
                   WHERE b.order_date  BETWEEN :as_sdate AND :as_edate
/*                     AND b.open_close       <> 'C' 한도초과	*/
                     AND b.open_close = 'O'
                     AND b.tracking          = 'Y'
                     AND ((:as_custno  = '%' AND b.cust_no    LIKE '%') OR
                          (:as_custno <> '%' AND b.cust_no       = :as_custno)
                         )
                     AND ((:as_scene   = '%' AND b.scene_code LIKE '%') OR
                          (:as_scene  <> '%' AND b.scene_code    = :as_scene )
                         )
                 ) A
                 LEFT OUTER JOIN rout R ON a.item_no = r.item_no AND a.qa = r.qa
           GROUP BY a.user_name, a.cust_name, a.scene_desc, a.order_no, a.seq_no, a.item_no, a.qa, a.qa19
         ) A
         LEFT OUTER JOIN groupitem  G ON a.item_no = g.item_no
         LEFT OUTER JOIN wc        W1 ON a.wc1     = w1.work_no
         LEFT OUTER JOIN wc        W2 ON a.wc2     = w2.work_no
         LEFT OUTER JOIN wc        W3 ON a.wc3     = w3.work_no
         LEFT OUTER JOIN (
              SELECT area_no, work_date, sale_no, seq_no, napgi_date, rem, wc_no, operation, order_qty, plan_qty
                   , process_flag = (case r.process_flag when 'N' then '불가' when 'Y' then '가능' 
                                                         when 'P' then '진행' when 'E' then '완료' else '마감' 
                                     end)
                FROM routtempnew R
               WHERE r.work_date >= :as_sdate AND operation = 1
         ) B1 ON a.order_no = b1.sale_no AND a.seq_no = b1.seq_no AND a.wc1 = b1.wc_no
         LEFT OUTER JOIN (
              SELECT area_no, work_date, sale_no, seq_no, napgi_date, rem, wc_no, operation, plan_qty
                   , process_flag = (case r.process_flag when 'N' then '불가' when 'Y' then '가능' 
                                                         when 'P' then '진행' when 'E' then '완료' else '마감' 
                                     end)
                FROM routtempnew R
               WHERE r.work_date >= :as_sdate AND operation = 2
         ) B2 ON a.order_no = b2.sale_no AND a.seq_no = b2.seq_no AND a.wc2 = b2.wc_no
         LEFT OUTER JOIN (
              SELECT area_no, work_date, sale_no, seq_no, napgi_date, rem, wc_no, operation, plan_qty
                   , process_flag = (case r.process_flag when 'N' then '불가' when 'Y' then '가능' 
                                                         when 'P' then '진행' when 'E' then '완료' else '마감' 
                                     end)
                FROM routtempnew R
               WHERE r.work_date >= :as_sdate AND operation = 3
         ) B3 ON a.order_no = b3.sale_no AND a.seq_no = b3.seq_no AND a.wc3 = b3.wc_no
" arguments=(("as_custno", string),("as_scene", string),("as_sdate", string),("as_edate", string))  sort="cust_name A scene_desc A order_no A seq_no A " )
