event rowfocuschanged;//
string ls_teamid, ls_divid

if dw4.rowcount() < 1 then return

sle_1.text = this.object.sos_no[currentrow]
ls_teamid  = this.object.team_id[currentrow]
ls_divid   = this.object.div_id[currentrow]

// 담당결재
if isnull(ls_teamid) or ls_teamid = "" then		
	pb_insert.enabled = true
	pb_delete.enabled = true
	pb_save.enabled   = true

	// 팀장결재 열림
	dw5.object.team_nm.background.color  = rgb(255,255,255)
	dw5.object.team_nm.protect  = 0
	dw5.object.team_chk.background.color = rgb(255,255,255)
	dw5.object.team_chk.protect = 0
	// 최종결재 열림
	dw5.object.div_nm.background.color   = rgb(255,255,255)
	dw5.object.div_nm.protect   = 0
	dw5.object.div_chk.background.color  = rgb(255,255,255)
	dw5.object.div_chk.protect  = 0

	// 거래처, 현장 열림
	dw5.object.cust_no.background.color   = rgb(255,255,255)
	dw5.object.cust_no.protect  = 0
	dw5.object.scene_code.background.color= rgb(255,255,255)
	dw5.object.scene_code.protect = 0
// 팀장결재(최종 미결재)
elseif isnull(ls_divid) or ls_divid = "" then		
	pb_insert.enabled = false
	pb_delete.enabled = false
	pb_save.enabled   = false

	if (gs_userid = ls_teamid) and (ls_divid = "" or isnull(ls_divid)) then
		pb_save.enabled   = true
		dw5.object.team_nm.background.color  = rgb(255,255,255)
		dw5.object.team_nm.protect  = 0
		dw5.object.team_chk.background.color = rgb(255,255,255)
		dw5.object.team_chk.protect = 0
	else
		dw5.object.team_nm.background.color  = rgb(192,192,192)
		dw5.object.team_nm.protect  = 1
		dw5.object.team_chk.background.color = rgb(192,192,192)
		dw5.object.team_chk.protect = 1
	end if
	// 최종결재 잠금
	dw5.object.div_nm.background.color   = rgb(255,255,255)
	dw5.object.div_nm.protect   = 0
	dw5.object.div_chk.background.color  = rgb(255,255,255)
	dw5.object.div_chk.protect  = 0
else	// 최종 결재완료
	pb_insert.enabled = false
	pb_delete.enabled = false
	pb_save.enabled   = false
	
	// 거래처, 현장 잠금
	dw5.object.cust_no.background.color   = rgb(192,192,192)
	dw5.object.cust_no.protect  = 1
	dw5.object.scene_code.background.color= rgb(192,192,192)
	dw5.object.scene_code.protect = 1
	// 팀장결재 잠금
	dw5.object.team_nm.background.color  = rgb(192,192,192)
	dw5.object.team_nm.protect  = 1
	dw5.object.team_chk.background.color = rgb(192,192,192)
	dw5.object.team_chk.protect = 1

	if ls_divid = gs_userid then	// 최종결재 당사자인 경우
		pb_save.enabled   = true
		dw5.object.div_nm.background.color   = rgb(255,255,255)
		dw5.object.div_nm.protect   = 0
		dw5.object.div_chk.background.color  = rgb(255,255,255)
		dw5.object.div_chk.protect  = 0
	else									// 최종결재 당사자가 아니면
		dw5.object.div_nm.background.color   = rgb(192,192,192)
		dw5.object.div_nm.protect   = 1
		dw5.object.div_chk.background.color  = rgb(192,192,192)
		dw5.object.div_chk.protect  = 1
	end if
end if
pb_retrieve.triggerevent(clicked!)

end event

event getfocus;is_dwidx = "dw4"
end event

