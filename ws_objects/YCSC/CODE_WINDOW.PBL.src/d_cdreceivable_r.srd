table(column=(type=char(10) updatewhereclause=yes name=user_id dbname="user_id" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="cust_no" )
 column=(type=decimal(1) updatewhereclause=yes name=rotate dbname="rotate" )
 column=(type=char(255) updatewhereclause=yes name=bigo dbname="bigo" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=char(10) updatewhereclause=yes name=salesman dbname="salesman" )
 column=(type=char(2) updatewhereclause=yes name=price_level dbname="price_level" )
 column=(type=decimal(2) updatewhereclause=yes name=sinv dbname="sinv" )
 column=(type=decimal(2) updatewhereclause=yes name=balanceamt dbname="balanceAMT" )
 column=(type=decimal(2) updatewhereclause=yes name=invamt dbname="invAMT" )
 column=(type=decimal(2) updatewhereclause=yes name=collamt dbname="collAMT" )
 column=(type=char(10) updatewhereclause=yes name=prt_date dbname="prt_date" )
 retrieve="  SELECT receivable.user_id
       , receivable.cust_no
       , rotate      = c.rotate
       , bigo        = receivable.bigo
       , cust_name   = c.cust_name
       , salesman    = login.user_name
       , price_level = c.price_level
       , sinv        = dbo.UF_GetOPEOM_SINV( receivable.cust_no, DatePart(Year, GetDate()), DatePart(Month, GetDate()) )
       , balanceAMT  = v.balanceAMT
       , invAMT      = o.invAMT
       , collAMT     = o.collAMT
       , prt_date    = convert(char(10), :ad_date, 111)
    FROM receivable
         LEFT OUTER JOIN customer   C ON receivable.cust_no = c.cust_no   
         LEFT OUTER JOIN login        ON c.salesman  = login.user_id
         LEFT OUTER JOIN (
              SELECT cyear       = v.cyear
                   , cust_no     = v.cust_no
                   , balanceAMT  = (case datepart(month, dateadd(month, -1, :ad_date)) 
													 when 01 then balbf_amount + sinv01 - scoll01
													 when 02 then balbf_amount + sinv02 - scoll02
													 when 03 then balbf_amount + sinv03 - scoll03
													 when 04 then balbf_amount + sinv04 - scoll04
													 when 05 then balbf_amount + sinv05 - scoll05
													 when 06 then balbf_amount + sinv06 - scoll06
													 when 07 then balbf_amount + sinv07 - scoll07
													 when 08 then balbf_amount + sinv08 - scoll08
													 when 09 then balbf_amount + sinv09 - scoll09
													 when 10 then balbf_amount + sinv10 - scoll10
													 when 11 then balbf_amount + sinv11 - scoll11
													 when 12 then balbf_amount + sinv12 - scoll12
											  end)
                FROM V_OPEOM  V
               WHERE cyear       = datepart(year, dateadd(month, -1, :ad_date))
         ) V ON receivable.cust_no = v.cust_no
         LEFT OUTER JOIN (
              SELECT cust_no     = opeom.cust_no
                   , invAMT      = (case datepart(month, :ad_date) 
													 when 01 then inv_01
													 when 02 then inv_02
													 when 03 then inv_03
													 when 04 then inv_04
													 when 05 then inv_05
													 when 06 then inv_06
													 when 07 then inv_07
													 when 08 then inv_08
													 when 09 then inv_09
													 when 10 then inv_10
													 when 11 then inv_11
													 when 12 then inv_12
											  end)
                   , collAMT     = (case datepart(month, :ad_date) 
													 when 01 then coll_01
													 when 02 then coll_02
													 when 03 then coll_03
													 when 04 then coll_04
													 when 05 then coll_05
													 when 06 then coll_06
													 when 07 then coll_07
													 when 08 then coll_08
													 when 09 then coll_09
													 when 10 then coll_10
													 when 11 then coll_11
													 when 12 then coll_12
											  end)
                 FROM opeom
                WHERE datepart(year, opeom.eom_year)  = datepart(year, :ad_date)
         ) O ON receivable.cust_no = o.cust_no
   WHERE ((:as_userid   = '%' AND receivable.user_id LIKE :as_userid) OR
          (:as_userid  <> '%' AND receivable.user_id    = :as_userid)
         )
     AND ((:as_custno   = '%' AND receivable.cust_no LIKE :as_custno) OR
          (:as_custno  <> '%' AND receivable.cust_no    = :as_custno)
         )

" arguments=(("ad_date", date),("as_userid", string),("as_custno", string)) )
