 column=(type=char(60) updatewhereclause=yes name=cust_sale_company_name dbname="cust_sale.company_name" )
 column=(type=decimal(0) updatewhereclause=yes name=cust_sale_amt dbname="cust_sale.amt" )
 column=(type=char(100) updatewhereclause=yes name=cust_sale_project_name dbname="cust_sale.project_name" )
 column=(type=decimal(0) updatewhereclause=yes name=cust_sale_kind_qty1 dbname="cust_sale.kind_qty1" )
 column=(type=decimal(0) updatewhereclause=yes name=cust_sale_kind_amt1 dbname="cust_sale.kind_amt1" )
 column=(type=decimal(0) updatewhereclause=yes name=cust_sale_kind_qty2 dbname="cust_sale.kind_qty2" )
