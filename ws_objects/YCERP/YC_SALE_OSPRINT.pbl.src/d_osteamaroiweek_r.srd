$PBExportHeader$d_osteamaroiweek_r.srd
$PBExportComments$국내판매부 팀별 매출실적집계(2005/05/25,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=1073741824 processing=0 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 96 print.margin.bottom = 96 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=yes )
header(height=520 color="536870912" )
summary(height=124 color="553648127" )
footer(height=0 color="536870912" )
detail(height=92 color="536870912" )
table(column=(type=long updatewhereclause=yes name=teamgroup dbname="teamgroup" )
 column=(type=char(1) updatewhereclause=yes name=team dbname="team" )
 column=(type=char(10) updatewhereclause=yes name=team_nm dbname="team_nm" )
 column=(type=char(5) updatewhereclause=yes name=team_code dbname="team_code" )
 column=(type=char(30) updatewhereclause=yes name=team_name dbname="team_name" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="user_id" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="user_name" )
 column=(type=char(10) updatewhereclause=yes name=rank_no dbname="rank_no" )
 column=(type=char(20) updatewhereclause=yes name=rank dbname="rank" )
 column=(type=long updatewhereclause=yes name=cyear dbname="cyear" )
 column=(type=long updatewhereclause=yes name=cmon dbname="cmon" )
 column=(type=decimal(6) updatewhereclause=yes name=mod_mm dbname="mod_mm" )
 column=(type=decimal(6) updatewhereclause=yes name=coll1 dbname="coll1" )
 column=(type=decimal(6) updatewhereclause=yes name=week1 dbname="week1" )
 column=(type=decimal(6) updatewhereclause=yes name=coll2 dbname="coll2" )
 column=(type=decimal(6) updatewhereclause=yes name=week2 dbname="week2" )
 column=(type=decimal(6) updatewhereclause=yes name=coll3 dbname="coll3" )
 column=(type=decimal(6) updatewhereclause=yes name=week3 dbname="week3" )
 column=(type=decimal(6) updatewhereclause=yes name=coll4 dbname="coll4" )
 column=(type=decimal(6) updatewhereclause=yes name=week4 dbname="week4" )
 column=(type=decimal(6) updatewhereclause=yes name=coll5 dbname="coll5" )
 column=(type=decimal(6) updatewhereclause=yes name=week5 dbname="week5" )
 column=(type=decimal(6) updatewhereclause=yes name=collt dbname="collt" )
 column=(type=decimal(6) updatewhereclause=yes name=weekt dbname="weekt" )
 retrieve="  SELECT teamgroup = (case when a.team = 1 then 1
                           when a.team = 2 then 1
                           when a.team = 3 then 1
                           when a.team = 4 then 2
                      end)
       , team      = a.team
       , team_nm   = (case when a.team = 1 then '영업 1본부'
                           when a.team = 2 then '영업 2본부'
                           when a.team = 3 then '영업 3본부'
                           when a.team = 4 then '시화+채권'
                      end)
       , team_code = a.team_code
       , team_name = a.team_name 
       , user_id   = a.user_id   
       , user_name = a.user_name 
       , rank_no   = a.rank_no   
       , rank      = isnull(a.rank,'')      
       , cyear     = a.cyear     
       , cmon      = a.cmon      
       , mod_mm    = a.mod_mm
       , coll1     = a.coll1     
       , week1     = a.week1     
       , coll2     = a.coll2     
       , week2     = a.week2     
       , coll3     = a.coll3     
       , week3     = a.week3     
       , coll4     = a.coll4     
       , week4     = a.week4     
       , coll5     = a.coll5     
       , week5     = a.week5     
       , collt     = a.collt     
       , weekt     = a.weekt
    FROM (
         SELECT team     = (case c.team_code  
                                 when '71000' then '1' /*영업1팀   */
                                 when '73000' then '1' /*특판1팀   */
                                 when '76000' then '1' /*중부호남  */
                                 when '77000' then '1' /*서부점    */
                                 when '78000' then '1' /*특판2팀   */
                                 when '74000' then '2' /*동부점    */
                                 when '72000' then '3' /*영업2팀   */
                                 when '75000' then '4' /*시화점    */
                                 when '79000' then '4' /*채권팀    */
                                 else              '5' 
                             end)
              , team_code = a.team_code
              , team_name = c.team_name
              , user_id   = a.user_id
              , user_name = a.user_name       
              , rank_no   = a.rank_no
              , rank      = a.rank
              , cyear     = :ai_year    
              , cmon      = :ai_mon     
              , mod_mm    = d.mod_mm
              , coll1     = isnull(b.coll1,0)
              , week1     = isnull(a.week1,0)
              , coll2     = isnull(b.coll2,0)
              , week2     = isnull(a.week2,0)
              , coll3     = isnull(b.coll3,0)
              , week3     = isnull(a.week3,0)
              , coll4     = isnull(b.coll4,0)
              , week4     = isnull(a.week4,0)
              , coll5     = isnull(b.coll5,0)
              , week5     = isnull(a.week5,0)
              , collt     = isnull(b.coll1,0) + isnull(b.coll2,0) + isnull(b.coll3,0) + isnull(b.coll4,0) + isnull(b.coll5,0)
              , weekt     = isnull(a.week1,0) + isnull(a.week2,0) + isnull(a.week3,0) + isnull(a.week4,0) + isnull(a.week5,0)
           FROM (
                SELECT user_id   = a.user_id
                     , user_name = a.user_name
                     , team_code = a.team_code
                     , rank_no   = a.rank_no
                     , rank      = a.rank
                     , week1     = max(a.week1)
                     , week2     = max(a.week2)
                     , week3     = max(a.week3)
                     , week4     = max(a.week4)
                     , week5     = max(a.week5)
                  FROM (
                       SELECT user_id   = a.user_id
                            , user_name = a.user_name
                            , team_code = a.team_code
                            , rank_no   = (case when a.user_id = 'W_POS' then '999' else a.rank_no end)
                            , rank      = a.rank
                            , week1     = (case when a.weeks = 1 then a.do_total else 0 end)
                            , week2     = (case when a.weeks = 2 then a.do_total else 0 end)
                            , week3     = (case when a.weeks = 3 then a.do_total else 0 end)
                            , week4     = (case when a.weeks = 4 then a.do_total else 0 end)
                            , week5     = (case when a.weeks = 5 then a.do_total else 0 end)
                         FROM (
                              SELECT user_id   = b.salesman
                                   , user_name = c.user_name
                                   , team_code = c.team_code
                                   , rank_no   = c.rank_no
                                   , rank      = c.rank
                                   , weeks     = dbo.UF_MonthWEEK(a.DO_DATE, 1)
                                   , do_total  = SUM(a.do_total) / 1.1 / 1000
                                FROM do a with(nolock)
                                     LEFT OUTER JOIN customer b with(nolock) ON a.cust_no  = b.cust_no
															                                 AND  b.cust_flag         = 'N' 
																					 AND  b.cust_type        <> 'E' 
																					 AND  b.credit_level     <> 'Z' 
                                     LEFT OUTER JOIN login    c  with(nolock) ON b.salesman = c.user_id
                               WHERE CONVERT(CHAR(10), a.do_date, 111) BETWEEN :as_sdate AND :as_edate
                                 AND (a.cust_no       NOT IN ('U580','N002','K023','S396','H479','N014') )                
                               GROUP BY b.salesman, c.user_name, c.team_code, c.rank_no, c.rank, dbo.UF_MonthWEEK(a.do_date, 1)
                              ) a
                       ) a
                 GROUP BY a.user_id, a.user_name, a.team_code, a.rank_no, a.rank
                ) a
                LEFT OUTER JOIN ( /* 매출목표 */
                     SELECT user_id   = a.user_id
                          , coll1     = sum(a.coll1) / 1.1 / 1000
                          , coll2     = sum(a.coll2) / 1.1 / 1000
                          , coll3     = sum(a.coll3) / 1.1 / 1000
                          , coll4     = sum(a.coll4) / 1.1 / 1000
                          , coll5     = sum(a.coll5) / 1.1 / 1000
                       FROM (
                            SELECT user_id   = a.user_id
                                 , cust_no   = a.cust_no
                                 , coll1     = max(a.coll1)
                                 , coll2     = max(a.coll2)
                                 , coll3     = max(a.coll3)
                                 , coll4     = max(a.coll4)
                                 , coll5     = max(a.coll5)
                              FROM (                                                  
                                   SELECT user_id   = b.salesman
                                        , cust_no   = a.cust_no
                                        , coll1     = (case when a.weeks = 1 then isnull(a.coll,0) else 0 end)
                                        , coll2     = (case when a.weeks = 2 then isnull(a.coll,0) else 0 end)
                                        , coll3     = (case when a.weeks = 3 then isnull(a.coll,0) else 0 end)
                                        , coll4     = (case when a.weeks = 4 then isnull(a.coll,0) else 0 end)
                                        , coll5     = (case when a.weeks = 5 then isnull(a.coll,0) else 0 end)
                                     FROM cust_aimdet a   with(nolock)                                    
                                          LEFT OUTER JOIN customer b  with(nolock) ON a.cust_no = b.cust_no
                                    WHERE CONVERT(CHAR(7),a.tar_year,111) = :as_yyyymm
                                      AND (a.cust_no        NOT IN ('U580','N002','K023','S396','H479','N014') )
                                   ) a                                                
                             GROUP BY a.user_id, a.cust_no
                            ) a
                      GROUP BY a.user_id
                ) b   ON a.user_id  = b.user_id
                LEFT OUTER JOIN team  c ON a.team_code = c.team_code
                LEFT OUTER JOIN ( /* 수정목표 */
											SELECT user_id   = b.salesman
												  , mod_mm    = sum((case :ai_mon 
																				when  1 then isnull(a.mod_01,0) 
																				when  2 then isnull(a.mod_02,0) 
																				when  3 then isnull(a.mod_03,0) 
																				when  4 then isnull(a.mod_04,0) 
																				when  5 then isnull(a.mod_05,0) 
																				when  6 then isnull(a.mod_06,0) 
																				when  7 then isnull(a.mod_07,0) 
																				when  8 then isnull(a.mod_08,0) 
																				when  9 then isnull(a.mod_09,0) 
																				when 10 then isnull(a.mod_10,0) 
																				when 11 then isnull(a.mod_11,0) 
																				when 12 then isnull(a.mod_12,0) 
																			end)) / 1.1 / 1000
											 FROM cust_aim a  with(nolock)                                     
											LEFT OUTER JOIN customer b  with(nolock) ON a.cust_code = b.cust_no
											WHERE datepart(year, a.tar_year) = :ai_year
											  AND ( a.cust_code      NOT IN ('U580','N002','K023','S396','H479','N014') )
											GROUP BY b.salesman
                ) d   ON a.user_id  = d.user_id 
         
         /*====================*/
         UNION ALL 
         /*====================*/
          
         /* 매출실적(내부업체) */
         SELECT team     = (case c.team_code  
                                 when '71000' then '1' /*영업1팀   */
                                 when '73000' then '1' /*특판1팀   */
                                 when '76000' then '1' /*중부호남  */
                                 when '77000' then '1' /*서부점    */
                                 when '78000' then '1' /*특판2팀   */
                                 when '74000' then '2' /*동부점    */
                                 when '72000' then '3' /*영업2팀   */
                                 when '75000' then '4' /*시화점    */
                                 when '79000' then '4' /*채권팀    */
                                 else              '5' 
                             end)
              , team_code = a.team_code
              , team_name = c.team_name
              , user_id   = a.user_id
              , user_name = '내부업체' /* a.user_name */
              , rank_no   = ''         /* a.rank_no   */
              , rank      = ''         /* a.rank      */               
              , cyear     = a.cyear          
              , cmon      = a.cmon       
              , mod_mm    = d.mod_mm
              , coll1     = isnull(b.coll1,0)
              , week1     = isnull(a.week1,0)
              , coll2     = isnull(b.coll2,0)
              , week2     = isnull(a.week2,0)
              , coll3     = isnull(b.coll3,0)
              , week3     = isnull(a.week3,0)
              , coll4     = isnull(b.coll4,0)
              , week4     = isnull(a.week4,0)
              , coll5     = isnull(b.coll5,0)
              , week5     = isnull(a.week5,0)
              , collt     = isnull(b.coll1,0) + isnull(b.coll2,0) + isnull(b.coll3,0) + isnull(b.coll4,0) + isnull(b.coll5,0)
              , weekt     = isnull(a.week1,0) + isnull(a.week2,0) + isnull(a.week3,0) + isnull(a.week4,0) + isnull(a.week5,0)
           FROM (
                SELECT user_id   = a.user_id
                     , user_name = a.user_name
                     , team_code = a.team_code
                     , rank_no   = a.rank_no
                     , rank      = a.rank
                     , cyear     = :ai_year
                     , cmon      = :ai_mon
                     , week1     = max(a.week1)
                     , week2     = max(a.week2)
                     , week3     = max(a.week3)
                     , week4     = max(a.week4)
                     , week5     = max(a.week5)
                  FROM (
                       SELECT user_id   = a.user_id
                            , user_name = a.user_name
                            , team_code = a.team_code
                            , rank_no   = (case when a.user_id = 'W_POS' then '999' else a.rank_no end)
                            , rank      = a.rank
                            , week1     = (case when a.weeks = 1 then a.do_total else 0 end)
                            , week2     = (case when a.weeks = 2 then a.do_total else 0 end)
                            , week3     = (case when a.weeks = 3 then a.do_total else 0 end)
                            , week4     = (case when a.weeks = 4 then a.do_total else 0 end)
                            , week5     = (case when a.weeks = 5 then a.do_total else 0 end)
                         FROM (
                              SELECT user_id     = b.salesman
                                   , user_name   = c.user_name
                                   , team_code   = c.team_code
                                   , rank_no     = c.rank_no
                                   , rank        = c.rank
                                   , weeks       = dbo.UF_MonthWEEK(a.DO_DATE, 1)
                                   , do_total    = SUM(a.do_total) / 1.1 / 1000
                                FROM do a  with(nolock)
                                     LEFT OUTER JOIN customer b   with(nolock) ON a.cust_no  = b.cust_no
																					 AND b.cust_flag        = 'N' 
																					AND  b.cust_type       <> 'E'
																					AND  b.credit_level     = 'Z'
                                     LEFT OUTER JOIN login    c   with(nolock) ON b.salesman = c.user_id
														                                 AND c.user_id            = 'killby' /* 길병학 */
                               WHERE CONVERT(CHAR(10), a.do_date, 111) BETWEEN :as_sdate AND :as_edate                 
					            AND ( a.cust_no         IN ('N002','K023','S396','H479','N014') )
                               GROUP BY b.salesman, c.user_name, c.team_code, c.rank_no, c.rank, dbo.UF_MonthWEEK(a.do_date, 1)
                              ) a
                       ) a
                 GROUP BY a.user_id, a.user_name, a.team_code, a.rank_no, a.rank
                ) a
                LEFT OUTER JOIN ( /* 매출목표 */
                     SELECT user_id   = a.user_id
                          , coll1     = sum(a.coll1) / 1.1 / 1000
                          , coll2     = sum(a.coll2) / 1.1 / 1000
                          , coll3     = sum(a.coll3) / 1.1 / 1000
                          , coll4     = sum(a.coll4) / 1.1 / 1000
                          , coll5     = sum(a.coll5) / 1.1 / 1000
                       FROM (
                            SELECT user_id   = a.user_id
                                 , cust_no   = a.cust_no
                                 , coll1     = max(a.coll1)
                                 , coll2     = max(a.coll2)
                                 , coll3     = max(a.coll3)
                                 , coll4     = max(a.coll4)
                                 , coll5     = max(a.coll5)
                              FROM (                                                  
                                   SELECT user_id   = b.salesman
                                        , cust_no   = a.cust_no
                                        , coll1     = (case when a.weeks = 1 then isnull(a.coll,0) else 0 end)
                                        , coll2     = (case when a.weeks = 2 then isnull(a.coll,0) else 0 end)
                                        , coll3     = (case when a.weeks = 3 then isnull(a.coll,0) else 0 end)
                                        , coll4     = (case when a.weeks = 4 then isnull(a.coll,0) else 0 end)
                                        , coll5     = (case when a.weeks = 5 then isnull(a.coll,0) else 0 end)
                                     FROM cust_aimdet a                                      
                                          LEFT OUTER JOIN customer b ON a.cust_no = b.cust_no
                                    WHERE CONVERT(CHAR(7),a.tar_year,111) = :as_yyyymm
                                      AND ( a.cust_no         IN ('N002','K023','S396','H479','N014') )
                                   ) a                                                
                             GROUP BY a.user_id, a.cust_no
                            ) a
                      GROUP BY a.user_id
                ) b   ON a.user_id  = b.user_id
                LEFT OUTER JOIN team  c ON a.team_code = c.team_code                     
                LEFT OUTER JOIN ( /* 수정목표 */
                     SELECT user_id   = b.salesman
                          , mod_mm    = sum((case :ai_mon
                                                when  1 then isnull(a.mod_01,0) 
                                                when  2 then isnull(a.mod_02,0) 
                                                when  3 then isnull(a.mod_03,0) 
                                                when  4 then isnull(a.mod_04,0) 
                                                when  5 then isnull(a.mod_05,0) 
                                                when  6 then isnull(a.mod_06,0) 
                                                when  7 then isnull(a.mod_07,0) 
                                                when  8 then isnull(a.mod_08,0) 
                                                when  9 then isnull(a.mod_09,0) 
                                                when 10 then isnull(a.mod_10,0) 
                                                when 11 then isnull(a.mod_11,0) 
                                                when 12 then isnull(a.mod_12,0) 
                                             end)) / 1.1 / 1000
                      FROM cust_aim a                                      
                           LEFT OUTER JOIN customer b ON a.cust_code = b.cust_no
                     WHERE datepart(year, a.tar_year) = :ai_year
                       AND ( a.cust_code             IN ('N002','K023','S396','H479','N014') )
                     GROUP BY b.salesman
                ) d   ON a.user_id  = d.user_id 

         /*====================*/
         UNION ALL 
         /*====================*/
          
         /* 매출실적(송천건업) */
         SELECT team     = (case c.team_code  
                                 when '71000' then '1' /*영업1팀   */
                                 when '73000' then '1' /*특판1팀   */
                                 when '76000' then '1' /*중부호남  */
                                 when '77000' then '1' /*서부점    */
                                 when '78000' then '1' /*특판2팀   */
                                 when '74000' then '2' /*동부점    */
                                 when '72000' then '3' /*영업2팀   */
                                 when '75000' then '4' /*시화점    */
                                 when '79000' then '4' /*채권팀    */
                                 else              '5' 
                             end)
              , team_code = a.team_code
              , team_name = c.team_name
              , user_id   = a.user_id
              , user_name = '송천건업' /* a.user_name */
              , rank_no   = ''         /* a.rank_no   */
              , rank      = ''         /* a.rank      */               
              , cyear     = a.cyear          
              , cmon      = a.cmon       
              , mod_mm    = d.mod_mm
              , coll1     = isnull(b.coll1,0)
              , week1     = isnull(a.week1,0)
              , coll2     = isnull(b.coll2,0)
              , week2     = isnull(a.week2,0)
              , coll3     = isnull(b.coll3,0)
              , week3     = isnull(a.week3,0)
              , coll4     = isnull(b.coll4,0)
              , week4     = isnull(a.week4,0)
              , coll5     = isnull(b.coll5,0)
              , week5     = isnull(a.week5,0)
              , collt     = isnull(b.coll1,0) + isnull(b.coll2,0) + isnull(b.coll3,0) + isnull(b.coll4,0) + isnull(b.coll5,0)
              , weekt     = isnull(a.week1,0) + isnull(a.week2,0) + isnull(a.week3,0) + isnull(a.week4,0) + isnull(a.week5,0)
           FROM (
                SELECT user_id   = a.user_id
                     , user_name = a.user_name
                     , team_code = a.team_code
                     , rank_no   = a.rank_no
                     , rank      = a.rank
                     , cyear     = :ai_year
                     , cmon      = :ai_mon
                     , week1     = max(a.week1)
                     , week2     = max(a.week2)
                     , week3     = max(a.week3)
                     , week4     = max(a.week4)
                     , week5     = max(a.week5)
                  FROM (
                       SELECT user_id   = a.user_id
                            , user_name = a.user_name
                            , team_code = a.team_code
                            , rank_no   = (case when a.user_id = 'W_POS' then '999' else a.rank_no end)
                            , rank      = a.rank
                            , week1     = (case when a.weeks = 1 then a.do_total else 0 end)
                            , week2     = (case when a.weeks = 2 then a.do_total else 0 end)
                            , week3     = (case when a.weeks = 3 then a.do_total else 0 end)
                            , week4     = (case when a.weeks = 4 then a.do_total else 0 end)
                            , week5     = (case when a.weeks = 5 then a.do_total else 0 end)
                         FROM (
                              SELECT user_id     = b.salesman
                                   , user_name   = c.user_name
                                   , team_code   = '75000'
                                   , rank_no     = c.rank_no
                                   , rank        = c.rank
                                   , weeks       = dbo.UF_MonthWEEK(a.DO_DATE, 1)
                                   , do_total    = SUM(a.do_total) / 1.1 / 1000
                                FROM do a with(nolock)
                                     LEFT OUTER JOIN customer b with(nolock)  ON a.cust_no  = b.cust_no
                                     LEFT OUTER JOIN login    c with(nolock) ON b.salesman = c.user_id
                               WHERE CONVERT(CHAR(10), a.do_date, 111) BETWEEN :as_sdate AND :as_edate
                                 AND ( a.cust_no          = 'U580' ) /* 송천건업 */
                               GROUP BY b.salesman, c.user_name, c.team_code, c.rank_no, c.rank, dbo.UF_MonthWEEK(a.do_date, 1)
                              ) a
                       ) a
                 GROUP BY a.user_id, a.user_name, a.team_code, a.rank_no, a.rank
                ) a
                LEFT OUTER JOIN ( /* 매출목표 */
                     SELECT user_id   = a.user_id
                          , coll1     = sum(a.coll1) / 1.1 / 1000
                          , coll2     = sum(a.coll2) / 1.1 / 1000
                          , coll3     = sum(a.coll3) / 1.1 / 1000
                          , coll4     = sum(a.coll4) / 1.1 / 1000
                          , coll5     = sum(a.coll5) / 1.1 / 1000
                       FROM (
                            SELECT user_id   = a.user_id
                                 , cust_no   = a.cust_no
                                 , coll1     = max(a.coll1)
                                 , coll2     = max(a.coll2)
                                 , coll3     = max(a.coll3)
                                 , coll4     = max(a.coll4)
                                 , coll5     = max(a.coll5)
                              FROM (                                                  
                                   SELECT user_id   = b.salesman
                                        , cust_no   = a.cust_no
                                        , coll1     = (case when a.weeks = 1 then isnull(a.coll,0) else 0 end)
                                        , coll2     = (case when a.weeks = 2 then isnull(a.coll,0) else 0 end)
                                        , coll3     = (case when a.weeks = 3 then isnull(a.coll,0) else 0 end)
                                        , coll4     = (case when a.weeks = 4 then isnull(a.coll,0) else 0 end)
                                        , coll5     = (case when a.weeks = 5 then isnull(a.coll,0) else 0 end)
                                     FROM cust_aimdet a  with(nolock)                                    
                                          LEFT OUTER JOIN customer b with(nolock) ON a.cust_no = b.cust_no
                                    WHERE CONVERT(CHAR(7),a.tar_year,111) = :as_yyyymm
                                      AND ( a.cust_no          = 'U580' ) /* 송천건업 */
                                   ) a                                                
                             GROUP BY a.user_id, a.cust_no
                            ) a
                      GROUP BY a.user_id
                ) b   ON a.user_id  = b.user_id
                LEFT OUTER JOIN team  c ON a.team_code = c.team_code                     
                LEFT OUTER JOIN ( /* 수정목표 */
                     SELECT user_id   = b.salesman
                          , mod_mm    = sum((case :ai_mon
                                                when  1 then isnull(a.mod_01,0) 
                                                when  2 then isnull(a.mod_02,0) 
                                                when  3 then isnull(a.mod_03,0) 
                                                when  4 then isnull(a.mod_04,0) 
                                                when  5 then isnull(a.mod_05,0) 
                                                when  6 then isnull(a.mod_06,0) 
                                                when  7 then isnull(a.mod_07,0) 
                                                when  8 then isnull(a.mod_08,0) 
                                                when  9 then isnull(a.mod_09,0) 
                                                when 10 then isnull(a.mod_10,0) 
                                                when 11 then isnull(a.mod_11,0) 
                                                when 12 then isnull(a.mod_12,0) 
                                             end)) / 1.1 / 1000
                      FROM cust_aim a  with(nolock)                                    
                           LEFT OUTER JOIN customer b with(nolock) ON a.cust_code = b.cust_no
                     WHERE datepart(year, a.tar_year) = :ai_year
                       AND ( a.cust_code        = 'U580' ) /* 송천건업 */
                     GROUP BY b.salesman
                ) d   ON a.user_id  = d.user_id 
         ) a
   ORDER BY teamgroup, team, team_code, rank_no, user_name
" arguments=(("as_sdate", string),("as_edate", string),("as_yyyymm", string),("ai_year", number),("ai_mon", number)) )
