 retrieve="  SELECT bsupp.supp_no
       , bsupp.supp_name
       , bsupp.icube_no
       , bsupp.salesman
       , bsupp.register_no
       , bsupp.represent
       , bsupp.addr
       , bsupp.tel_no
       , bsupp.fax_no
       , bsupp.fob
       , bsupp.rem  
    FROM bsupp   
" update="bsupp" updatewhere=1 updatekeyinplace=no )
