$PBExportHeader$d_mpsfcday_calc_check.srd
$PBExportComments$생산일보조회(1998/05/08,이인호)
release 8;
datawindow(units=0 timer_interval=0 color=16777215 processing=1 HTMLDW=no print.documentname="" print.orientation = 0 print.margin.left = 110 print.margin.right = 110 print.margin.top = 97 print.margin.bottom = 97 print.paper.source = 0 print.paper.size = 0 print.prompt=no print.buttons=no print.preview.buttons=no grid.lines=0 )
header(height=76 color="536870912" )
summary(height=0 color="536870912" )
footer(height=76 color="8421504" )
detail(height=76 color="536870912" )
table(column=(type=char(1) updatewhereclause=yes name=chk dbname="chk" values="	Y/	N" )
 column=(type=char(10) updatewhereclause=yes name=wc_no dbname="wc_no" )
 column=(type=char(10) updatewhereclause=yes name=work_name dbname="work_name" initial=" " )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="item_no" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="qa" )
 column=(type=char(2) updatewhereclause=yes name=uom dbname="uom" )
 column=(type=decimal(4) updatewhereclause=yes name=qty dbname="qty" )
 column=(type=char(100) updatewhereclause=yes name=formula dbname="formula" )
 column=(type=long updatewhereclause=yes name=calc dbname="calc" )
 column=(type=decimal(4) updatewhereclause=yes name=calvalue dbname="calvalue" )
 retrieve="    SELECT chk       = 'N'
         , wc_no     = a.wc_no                
         , work_name = a.work_name              
         , item_no   = a.item_no   
         , item_name = a.item_name         
         , qa        = a.qa     
         , uom       = a.uom                  
         , qty       = a.qty
         , formula   = b.formula
         , calc      = b.calc
         , calvalue  = a.calvalue
      FROM (
           SELECT wc_no     = a.wc_no                
                , work_name = b.work_name              
                , item_no   = a.assembly   
                , item_name = c.item_name         
                , qa        = a.assembly_qa     
                , uom       = a.uom                  
                , qty       = sum(a.make_qty)     
                , calvalue  = isnull(DBO.UF_GetItemCalc_PUB(a.wc_no, a.assembly, a.assembly_qa, sum(a.make_qty)), 0)
             FROM sfcday    a  
                  LEFT OUTER JOIN wc        b  ON a.wc_no      = b.work_no
                  LEFT OUTER JOIN groupitem c  ON a.assembly   = c.item_no
            WHERE ( b.work_name      LIKE :as_wc + '%' ) 
              AND ( convert(char(10),a.sfc_date,111)   BETWEEN :as_start and :as_end ) 
              AND ( a.area_no           = :as_area     ) 
              AND NOT ( a.assembly = 'PZAARMDB0Z' OR  /* R-몰딩(도장) */
                        a.assembly = 'PZZZACCZZZ' OR  /* SELF-CLEANING COATING */
                        a.assembly = 'PZZZPP3ZZZ' OR  /* 도장비 */
                        charindex('스마트패널', c.item_name) > 0 OR 
                        charindex('절곡판넬',   c.item_name) > 0  
                      )
            GROUP BY a.wc_no         
                   , b.work_name     
                   , a.assembly      
                   , c.item_name
                   , a.assembly_qa   
                   , a.uom           
         ) a
         LEFT OUTER JOIN itemcalc_pub b  ON a.wc_no = b.work_no AND a.item_no = b.item_no AND a.qa = b.qa
    WHERE ( a.qty      > 0    )
      AND ( a.calvalue = 0    )
    ORDER BY a.work_name, a.item_name, a.qa
    " arguments=(("as_wc", string),("as_start", string),("as_end", string),("as_area", string))  sort="work_name A item_name A qa A " )
group(level=1 header.height=0 trailer.height=0 by=("wc_no" ) header.color="536870912" trailer.color="536870912" )
