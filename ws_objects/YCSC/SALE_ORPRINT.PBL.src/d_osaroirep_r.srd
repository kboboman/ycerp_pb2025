detail(height=68 color="536870912" )
table(column=(type=char(4) updatewhereclause=yes name=aroiinv_cust_no dbname="aroiinv.cust_no" )
 column=(type=char(1) updatewhereclause=yes name=aroiinv_inv_type dbname="aroiinv.inv_type" values="매출	Y/선매출	N/" )
 column=(type=char(1) updatewhereclause=yes name=aroiinv_sale_flag dbname="aroiinv.sale_flag" values="내수	D/수출	E/L//C	L/" )
 column=(type=datetime updatewhereclause=yes name=aroiinv_oi_date dbname="aroiinv.oi_date" )
 column=(type=char(3) updatewhereclause=yes name=aroiinv_curr_code dbname="aroiinv.curr_code" )
 column=(type=decimal(4) updatewhereclause=yes name=aroiinv_gl_cur_rate dbname="aroiinv.gl_cur_rate" )
 column=(type=decimal(4) updatewhereclause=yes name=aroiinv_aroiinv_cash dbname="aroiinv.aroiinv_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=aroiinv_aroiinv_rate dbname="aroiinv.aroiinv_rate" )
 column=(type=decimal(4) updatewhereclause=yes name=aroiinv_ship_cost dbname="aroiinv.ship_cost" )
 column=(type=decimal(0) updatewhereclause=yes name=aroiinv_dc dbname="aroiinv.dc" )
 column=(type=decimal(0) updatewhereclause=yes name=aroiinv_dc_rate dbname="aroiinv.dc_rate" )
 column=(type=decimal(0) updatewhereclause=yes name=aroiinv_discount dbname="aroiinv.discount" )
 column=(type=char(12) updatewhereclause=yes name=aroiinv_aroiinv_no dbname="aroiinv.aroiinv_no" )
 column=(type=char(14) updatewhereclause=yes name=aroi_do_no dbname="aroi.do_no" )
 column=(type=long updatewhereclause=yes name=aroi_seq_no dbname="aroi.seq_no" )
 column=(type=char(10) updatewhereclause=yes name=aroi_item_no dbname="aroi.item_no" )
 column=(type=char(20) updatewhereclause=yes name=aroi_qa dbname="aroi.qa" )
 column=(type=char(2) updatewhereclause=yes name=aroi_uom dbname="aroi.uom" )
 column=(type=decimal(2) updatewhereclause=yes name=aroi_ship_qty dbname="aroi.ship_qty" )
 column=(type=decimal(4) updatewhereclause=yes name=aroi_price dbname="aroi.price" )
 column=(type=decimal(4) updatewhereclause=yes name=aroi_rate_cash dbname="aroi.rate_cash" )
 column=(type=decimal(4) updatewhereclause=yes name=aroi_ori_amount dbname="aroi.ori_amount" )
 column=(type=long updatewhereclause=yes name=aroi_dc_rate dbname="aroi.dc_rate" )
 column=(type=char(50) updatewhereclause=yes name=customer_cust_name dbname="customer.cust_name" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="item_name" )
 column=(type=datetime updatewhereclause=yes name=c_start dbname="c_start" )
 column=(type=datetime updatewhereclause=yes name=c_end dbname="c_end" )
 retrieve="  SELECT aroiinv.cust_no,   
         aroiinv.inv_type,   
         aroiinv.sale_flag,   
         aroiinv.oi_date,   
         aroiinv.curr_code,   
         aroiinv.gl_cur_rate,   
         aroiinv.aroiinv_cash,   
         aroiinv.aroiinv_rate,   
         aroiinv.ship_cost,   
         aroiinv.dc,   
         aroiinv.dc_rate,   
         aroiinv.discount,   
         aroiinv.aroiinv_no,   
         aroi.do_no,   
         aroi.seq_no,   
         aroi.item_no,   
         aroi.qa,   
         aroi.uom,   
         aroi.ship_qty,   
         aroi.price,   
         aroi.rate_cash,   
         aroi.ori_amount,   
         aroi.dc_rate ,   
         customer.cust_name,   
         item_name = dbo.uf_getitemname(aroi.item_no),   
         c_start = convert(smalldatetime, :ad_start, 111),   
         c_end = convert(smalldatetime, :ad_end, 111)
    FROM aroiinv left outer join aroi on aroiinv.aroiinv_no = aroi.aroiinv_no   
                            inner join customer on aroiinv.cust_no = customer.cust_no
   WHERE ( ( aroiinv.sale_flag in ( :asa_flag ) ) AND  
                    ( aroiinv.oi_date between :ad_start and :ad_end ) AND  
                    ( aroiinv.delete_flag = 'N' ) and 
			    ( customer.salesman like :as_ret ) )
" arguments=(("asa_flag", stringlist),("ad_start", date),("ad_end", date),("as_ret", string))  sort="customer_cust_name A aroiinv_oi_date A aroiinv_aroiinv_no A aroi_seq_no A " )
