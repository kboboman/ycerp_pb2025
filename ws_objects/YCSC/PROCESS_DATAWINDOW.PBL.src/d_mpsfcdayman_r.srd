table(column=(type=char(10) updatewhereclause=yes name=area_no dbname="AREA_NO" )
 column=(type=char(20) updatewhereclause=yes name=area_name dbname="AREA_NAME" )
 column=(type=datetime updatewhereclause=yes name=sfc_date dbname="SFC_DATE" )
 column=(type=char(10) updatewhereclause=yes name=wc_no dbname="WC_NO" )
 column=(type=char(10) updatewhereclause=yes name=wc_name dbname="WC_NAME" )
 column=(type=char(10) updatewhereclause=yes name=user_id dbname="USER_ID" )
 column=(type=char(10) updatewhereclause=yes name=user_name dbname="USER_NAME" )
 column=(type=char(1) updatewhereclause=yes name=work1 dbname="WORK1" values="	1/	0" )
 column=(type=char(1) updatewhereclause=yes name=work2 dbname="WORK2" values="	1/	0" )
 column=(type=char(1) updatewhereclause=yes name=work3 dbname="WORK3" values="	1/	0" )
 column=(type=real updatewhereclause=yes name=time1 dbname="TIME1" )
 column=(type=real updatewhereclause=yes name=time2 dbname="TIME2" )
 column=(type=real updatewhereclause=yes name=time3 dbname="TIME3" )
 column=(type=char(50) updatewhereclause=yes name=bigo dbname="BIGO" )
 retrieve="  SELECT AREA_NO  = A.AREA_NO                                      
       , AREA_NAME= B.AREA_NAME
       , SFC_DATE = A.SFC_DATE                                     
       , WC_NO    = A.WC_NO                                        
       , WC_NAME  = C.WORK_NAME
       , USER_ID  = A.USER_ID                                      
       , USER_NAME= D.USER_NAME
       , WORK1    = A.WORK1
       , WORK2    = A.WORK2                                        
       , WORK3    = A.WORK3                                        
       , TIME1    = A.TIME1
       , TIME2    = A.TIME2                                        
       , TIME3    = A.TIME3                                        
       , BIGO     = A.BIGO                                         
    FROM SFCDAYMAN A                                             
         LEFT OUTER JOIN AREA B   ON A.AREA_NO  = B.AREA_NO
         LEFT OUTER JOIN WC   C   ON A.WC_NO    = C.WORK_NO
         LEFT OUTER JOIN LOGIN D  ON A.USER_ID  = D.USER_ID
   WHERE A.AREA_NO      LIKE :as_area
     AND A.WC_NO        LIKE :as_wcno
     AND CONVERT(CHAR(10), A.SFC_DATE,111)  BETWEEN :AS_START AND :AS_END
   ORDER BY AREA_NO, SFC_DATE, USER_ID, WORK1 DESC, WORK2 DESC, WORK3 DESC" arguments=(("as_area", string),("as_wcno", string),("as_start", string),("as_end", string)) )
