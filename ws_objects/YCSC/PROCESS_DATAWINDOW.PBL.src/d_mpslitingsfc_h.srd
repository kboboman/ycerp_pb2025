table(column=(type=char(60) updatewhereclause=yes name=groupitem_item_name dbname="groupitem.item_name" )
 column=(type=char(14) updatewhereclause=yes name=coilorder_order dbname="coilorderdet.coilorder_order" )
 column=(type=long updatewhereclause=yes name=order_seq dbname="coilorderdet.order_seq" )
 column=(type=long updatewhereclause=yes name=coilorderdet_div dbname="coilorderdet.div" initial="0" )
 column=(type=char(20) updatewhereclause=yes name=coilmst_qa dbname="coilmst.qa" )
 column=(type=long updatewhereclause=yes name=coilmst_length dbname="coilmst.length" )
 column=(type=long updatewhereclause=yes name=wunit dbname="wunit" )
 column=(type=char(60) updatewhereclause=yes name=witem_name dbname="groupitem.item_name" )
 column=(type=char(14) updatewhereclause=yes name=order_no dbname="coilsliting.order_no" )
 column=(type=long updatewhereclause=yes name=seq dbname="coilsliting.seq" )
 column=(type=decimal(1) updatewhereclause=yes name=wid dbname="coilsliting.wid" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="coilsliting.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="coilsliting.qa" )
 column=(type=decimal(4) updatewhereclause=yes name=unit_qty dbname="coilsliting.unit_qty" )
 column=(type=long updatewhereclause=yes name=cnt dbname="coilsliting.cnt" )
 column=(type=decimal(2) updatewhereclause=yes name=length dbname="coilsliting.length" )
 column=(type=char(1) updatewhereclause=yes name=proc_flag dbname="coilsliting.proc_flag" )
 column=(type=char(30) updatewhereclause=yes name=rem dbname="coilsliting.rem" )
 column=(type=char(1) updatewhereclause=yes name=sheet dbname="coilsliting.sheet" )
 column=(type=char(1) updatewhereclause=yes name=work_type dbname="coilorderdet.work_type" )
 column=(type=long updatewhereclause=yes name=coilorderdet_cnt dbname="coilorderdet.cnt" )
 column=(type=char(10) updatewhereclause=yes name=loc_no dbname="coilsliting.loc_no" )
 column=(type=char(20) updatewhereclause=yes name=coil_no dbname="coilsliting.coil_no" )
 column=(type=char(2) updatewhereclause=yes name=coilmst_etc_no dbname="coilmst.etc_no" )
 retrieve="PBSELECT( VERSION(400) TABLE(NAME=~"coilsliting~" )  TABLE(NAME=~"coilorderdet~" )  TABLE(NAME=~"groupitem~" ALIAS=~"groupitem_a~" )  TABLE(NAME=~"coilmst~" )  TABLE(NAME=~"groupitem~" ALIAS=~"groupitem_b~" ) COLUMN(NAME=~"groupitem_a.item_name~") COLUMN(NAME=~"coilorderdet.coilorder_order~") COLUMN(NAME=~"coilorderdet.order_seq~") COLUMN(NAME=~"coilorderdet.div~") COLUMN(NAME=~"coilmst.qa~") COLUMN(NAME=~"coilmst.length~") COMPUTE(NAME=~"wunit = coilmst.unit_qty * coilmst.qcnt~") COLUMN(NAME=~"groupitem_b.item_name~") COLUMN(NAME=~"coilsliting.order_no~") COLUMN(NAME=~"coilsliting.seq~") COLUMN(NAME=~"coilsliting.wid~") COLUMN(NAME=~"coilsliting.item_no~") COLUMN(NAME=~"coilsliting.qa~") COLUMN(NAME=~"coilsliting.unit_qty~") COLUMN(NAME=~"coilsliting.cnt~") COLUMN(NAME=~"coilsliting.length~") COLUMN(NAME=~"coilsliting.proc_flag~") COLUMN(NAME=~"coilsliting.rem~") COLUMN(NAME=~"coilsliting.sheet~") COLUMN(NAME=~"coilorderdet.work_type~") COLUMN(NAME=~"coilorderdet.cnt~") COLUMN(NAME=~"coilsliting.loc_no~") COLUMN(NAME=~"coilsliting.coil_no~") COLUMN(NAME=~"coilmst.etc_no~")    JOIN (LEFT=~"coilorderdet.order_no~"    OP =~"=~"RIGHT=~"coilsliting.order_no~" )    JOIN (LEFT=~"coilsliting.item_no~"    OP =~"=~"RIGHT=~"groupitem_a.item_no~" )    JOIN (LEFT=~"coilorderdet.coil_no~"    OP =~"=~"RIGHT=~"coilmst.coil_no~" )    JOIN (LEFT=~"coilmst.item_no~"    OP =~"=~"RIGHT=~"groupitem_b.item_no~" )    JOIN (LEFT=~"coilorderdet.loc_no~"    OP =~"=~"RIGHT=~"coilmst.loc_no~" )WHERE(    EXP1 =~"coilorderdet.coilorder_order~"   OP =~"=~"    EXP2 =~":as_order~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"coilorderdet.order_seq~"   OP =~"=~"    EXP2 =~":as_seq~"    LOGIC =~"and~" ) WHERE(    EXP1 =~"coilorderdet.proc_flag~"   OP =~"=~"    EXP2 =~"'M'~" ) ) ORDER(NAME=~"coilorderdet.coilorder_order~" ASC=yes )  ORDER(NAME=~"coilorderdet.order_seq~" ASC=yes ) ARG(NAME = ~"as_order~" TYPE = string)  ARG(NAME = ~"as_seq~" TYPE = number) " arguments=(("as_order", string),("as_seq", number)) )
