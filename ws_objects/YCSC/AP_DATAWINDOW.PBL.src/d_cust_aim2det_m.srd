table(column=(type=char(4) update=yes updatewhereclause=yes key=yes name=cust_no dbname="cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="cust_name" )
 column=(type=datetime update=yes updatewhereclause=yes key=yes name=tar_year dbname="tar_year" )
 column=(type=long update=yes updatewhereclause=yes key=yes name=weeks dbname="weeks" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=cash dbname="cash" initial="0" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=bill dbname="bill" initial="0" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=setoff dbname="setoff" initial="0" )
 column=(type=char(50) update=yes updatewhereclause=yes name=bigo dbname="bigo" )
 column=(type=decimal(0) updatewhereclause=yes name=cash1 dbname="cash1" )
 column=(type=decimal(0) updatewhereclause=yes name=bill1 dbname="bill1" )
 column=(type=decimal(0) updatewhereclause=yes name=setoff1 dbname="setoff1" )
 column=(type=char(50) updatewhereclause=yes name=bigo1 dbname="bigo1" )
 column=(type=decimal(0) update=yes updatewhereclause=yes name=coll dbname="coll" )
 retrieve="  SELECT cust_no   = a.cust_no    
       , cust_name = b.cust_name  
       , tar_year  = a.tar_year   
       , weeks     = a.weeks      
       , cash      = a.cash       
       , bill      = a.bill       
       , setoff    = a.setoff     
       , bigo      = a.bigo      
       , cash1     = a.cash     
       , bill1     = a.bill     
       , setoff1   = a.setoff   
       , bigo1     = a.bigo
       , coll      = a.coll

    FROM cust_aimdet A  
         LEFT OUTER JOIN customer B ON a.cust_no = b.cust_no
   WHERE a.cust_no     = :as_cust
     AND SUBSTRING(CONVERT(CHAR(10),a.tar_year,111),1,7) = :as_yyyymm
" update="cust_aimdet" updatewhere=0 updatekeyinplace=no arguments=(("as_cust", string),("as_yyyymm", string)) )
