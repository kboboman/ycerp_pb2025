detail(height=92 color="536870912" )
table(column=(type=datetime updatewhereclause=yes name=req_date dbname="issuereqdet_sale.req_date" )
 column=(type=char(10) updatewhereclause=yes name=salesman dbname="issuereqdet_sale.salesman" )
 column=(type=long updatewhereclause=yes name=req_seq dbname="issuereqdet_sale.req_seq" )
 column=(type=long updatewhereclause=yes name=sale_seq dbname="issuereqdet_sale.seq" )
 column=(type=char(14) updatewhereclause=yes name=order_no dbname="issuereqdet_sale.order_no" )
 column=(type=long updatewhereclause=yes name=seq_no dbname="issuereqdet_sale.seq_no" )
 column=(type=char(10) updatewhereclause=yes name=item_no dbname="issuereqdet_sale.item_no" )
 column=(type=char(20) updatewhereclause=yes name=qa dbname="issuereqdet_sale.qa" )
 column=(type=char(60) updatewhereclause=yes name=item_name dbname="groupitem.item_name" )
 column=(type=decimal(0) updatewhereclause=yes name=issue_qty dbname="issuereqdet_sale.issue_qty" )
 column=(type=datetime updatewhereclause=yes name=sys_date dbname="issuereqdet_sale.sys_date" )
 retrieve="  SELECT a.req_date   
       , a.salesman   
       , a.req_seq   
       , a.seq   
       , a.order_no   
       , a.seq_no   
       , a.item_no   
       , a.qa   
       , g.item_name
       , a.issue_qty   
       , a.sys_date  
    FROM issuereqdet_sale  A
         LEFT OUTER JOIN groupitem G ON a.item_no = g.item_no
   WHERE a.req_date     = :ad_reqdate
     AND a.salesman     = :as_salesman
     AND a.req_seq      = :ai_reqseq
     AND a.seq          = :ai_seq
     AND a.order_no     = :as_orderno

" arguments=(("ad_reqdate", datetime),("as_salesman", string),("ai_reqseq", number),("ai_seq", number),("as_orderno", string)) )
