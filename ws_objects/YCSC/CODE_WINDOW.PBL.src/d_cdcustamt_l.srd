table(column=(type=long updatewhereclause=yes name=cyear dbname="V_OPEOM_AMT.cyear" )
 column=(type=char(4) updatewhereclause=yes name=cust_no dbname="V_OPEOM_AMT.cust_no" )
 column=(type=char(50) updatewhereclause=yes name=cust_name dbname="V_OPEOM_AMT.cust_name" )
 column=(type=char(10) updatewhereclause=yes name=salesman dbname="V_OPEOM_AMT.salesman" )
 column=(type=decimal(2) updatewhereclause=yes name=balanceamt dbname="V_OPEOM_AMT.balanceAMT" )
 column=(type=datetime updatewhereclause=yes name=do_date dbname="V_OPEOM_AMT.do_date" )
 column=(type=datetime updatewhereclause=yes name=oi_date dbname="V_OPEOM_AMT.oi_date" )
 retrieve="  SELECT cyear
       , cust_no
       , cust_name
       , salesman
       , balanceAMT
       , do_date
       , oi_date
    FROM v_opeom_amt
   WHERE balanceAMT   <> 0
   ORDER BY cust_name" )
