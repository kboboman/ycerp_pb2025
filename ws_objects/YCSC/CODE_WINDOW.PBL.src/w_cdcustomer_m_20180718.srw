String  ls_contract_yn, ls_joint_head, ls_jointor, ls_dambo_rem, ls_dambo_bigo, ls_custmain, ls_licensenm
                
decimal  ll_credit_limit, ll_joint_amt, ll_dambo_amt
Datetime ld_contract_day, ld_dambo_ymd, ld_collect_ymd, ld_cap_birthday

integer  SWUpdate

for ll_row = 1 to dw_27.rowcount()                                           
   ls_chk          = dw_27.object.chk[ll_row]             // 선택            
	if ls_chk = "N" then CONTINUE
	
   ls_custno       = dw_27.object.cust_no[ll_row]         // 거래처          
                                                                             
   ls_salesman     = dw_27.object.salesman[ll_row]        // 담당자          
   ld_collect_ymd  = dw_27.object.collect_ymd[ll_row]     // 채권관리      
   ls_credit_level = dw_27.object.credit_level[ll_row]    // 신용등급        
   ls_level_grade  = dw_27.object.level_grade[ll_row]     // 매출등급        
   ls_price_level  = dw_27.object.price_level[ll_row]     // 단가등급        

   ls_credit_day   = dw_27.object.credit_day[ll_row]      // 여신일자        
   ls_addr1        = dw_27.object.addr1[ll_row]           // 거래처우편      
   ls_addr2        = dw_27.object.addr2[ll_row]           // 거래처주소1     
   ls_addr3        = dw_27.object.addr3[ll_row]           // 거래처주소2     
   ls_terms        = dw_27.object.terms[ll_row]           // 결재기간        
   
   ll_credit_limit = dw_27.object.credit_limit[ll_row]    // 신용한도액      
   ls_bus_addr1    = dw_27.object.bus_addr1[ll_row]       // 실채무자우편    
   ls_bus_addr2    = dw_27.object.bus_addr2[ll_row]       // 실채무자주소1   
   ls_bus_addr3    = dw_27.object.bus_addr3[ll_row]       // 실채무자주소2   
   ls_shipto_addr1 = dw_27.object.shipto_addr1[ll_row]    // 운송처우편      
   ls_shipto_addr2 = dw_27.object.shipto_addr2[ll_row]    // 운송처주소1     
   ls_shipto_addr3 = dw_27.object.shipto_addr3[ll_row]    // 운송처주소2     
   
   ls_vat_user     = dw_27.object.vat_user[ll_row]        // VAT담당자       
   ls_vat_phone    = dw_27.object.vat_phone[ll_row]       // VAT연락처       
   ls_vat_email    = dw_27.object.vat_email[ll_row]       // VAT메일         
   
   ls_icube_no     = dw_27.object.icube_no[ll_row]        // 더존            
   ld_contract_day = dw_27.object.contract_day[ll_row]    // 계약일         
   ls_contract_yn  = dw_27.object.contract_yn[ll_row]     // 계약서          
   ls_joint_head   = dw_27.object.joint_head[ll_row]      // 대표자보증      
   ls_jointor      = dw_27.object.jointor[ll_row]         // 유한연대보증인  
   ll_joint_amt    = dw_27.object.joint_amt[ll_row]       // 보증금액        
   ld_dambo_ymd    = dw_27.object.dambo_ymd[ll_row]       // 담보일자      
   ll_dambo_amt    = dw_27.object.dambo_amt[ll_row]       // 담보금액        
   ls_dambo_rem    = dw_27.object.dambo_rem[ll_row]       // 담보내역내용    
   ls_dambo_bigo   = dw_27.object.dambo_bigo[ll_row]      // 담보비고        

   ls_custmain     = dw_27.object.custmain[ll_row]        // 주거래건설사
   ls_licensenm    = dw_27.object.licensenm[ll_row]       // 면허명   
   ld_cap_birthday = dw_27.object.cap_birthday[ll_row]    // 대표자생년   

   if ls_chk = "N" or isnull(ls_custno) or ls_custno = "" then 
   else                                                        
      for ll_dw26Row = 1 to dw_26.rowcount()                   
         if dw_26.object.chk[ll_dw26Row] = "Y" then            
            ls_field = dw_26.object.field[ll_dw26Row]          

            choose case ls_field                               
               case "cap_birthday"   // 대표자생년                          
                  if isnull(ld_cap_birthday) then                  
                  else                                         
                     UPDATE customer SET cap_birthday = :ld_cap_birthday  WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if 
						
               case "salesman"      // 담당자                  
                  if isnull(ls_salesman) then                  
                  else                                         
                     UPDATE customer SET pre_salesman = salesman, salesman = :ls_salesman WHERE CUST_NO = :ls_custno; 
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if                                       
                                                               
               case "collect_ymd"   // 채권관리                
                  if isnull(ld_collect_ymd) then               
                  else                                         
                     UPDATE customer SET collect_ymd = :ld_collect_ymd   WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if                                       
                                                               
               case "credit_level"   // 신용등급               
                  if isnull(ls_credit_level) then              
                  else                                         
                     UPDATE customer SET credit_level = :ls_credit_level WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if                                       
                                                               
               case "level_grade"   // 매출등급                
                  if isnull(ls_level_grade) then               
                  else                                         
                     UPDATE customer SET level_grade = :ls_level_grade   WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if                                       

               case "price_level"   // 단가등급                
                  if isnull(ls_price_level) then               
                  else                                         
                     UPDATE customer SET price_level = :ls_price_level  WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if                                       

               case "credit_day"   // 여신일자                 
                  if isnull(ls_credit_day) then                
                  else                                         
                     UPDATE customer SET credit_day = :ls_credit_day  WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if                                       

               case "addr1"   // 거래처우편                    
                  if isnull(ls_addr1) then                     
                  else                                         
                     UPDATE customer SET addr1 = :ls_addr1  WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if                                       

               case "addr2"   // 거래처주소1                   
                  if isnull(ls_addr2) then                     
                  else                                         
                     UPDATE customer SET addr2 = :ls_addr2  WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if                                       

               case "addr3"   // 거래처주소2                   
                  if isnull(ls_addr3) then                     
                  else                                         
                     UPDATE customer SET addr3 = :ls_addr3  WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if                                       

               case "terms"   // 결재기간                      
                  if isnull(ls_terms) then                     
                  else                                         
                     UPDATE customer SET terms = :ls_terms  WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if                                       

               case "credit_limit"   // 신용한도액             
                  if isnull(ll_credit_limit) then              
                  else                                         
                     UPDATE customer SET credit_limit = :ll_credit_limit  WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if                                       

               case "bus_addr1"   // 실채무자우편              
                  if isnull(ls_bus_addr1) then                 
                  else                                         
                     UPDATE customer SET bus_addr1 = :ls_bus_addr1  WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if                                       

               case "bus_addr2"   // 실채무자주소1             
                  if isnull(ls_bus_addr2) then                 
                  else                                         
                     UPDATE customer SET bus_addr2 = :ls_bus_addr2  WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if                                       

               case "bus_addr3"   // 실채무자주소2             
                  if isnull(ls_bus_addr3) then                 
                  else                                         
                     UPDATE customer SET bus_addr3 = :ls_bus_addr3  WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if                                       

               case "shipto_addr1"   // 운송처우편             
                  if isnull(ls_shipto_addr1) then              
                  else                                         
                     UPDATE customer SET shipto_addr1 = :ls_shipto_addr1  WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if                                       

               case "shipto_addr2"   // 운송처주소1            
                  if isnull(ls_shipto_addr2) then              
                  else                                         
                     UPDATE customer SET shipto_addr2 = :ls_shipto_addr2  WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if                                       

               case "shipto_addr3"   // 운송처주소2            
                  if isnull(ls_shipto_addr3) then              
                  else                                         
                     UPDATE customer SET shipto_addr3 = :ls_shipto_addr3  WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if                                       

               case "vat_user"   // VAT담당자                  
                  if isnull(ls_vat_user) then                  
                  else                                         
                     UPDATE customer SET vat_user = :ls_vat_user  WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if                                       

               case "vat_phone"   // VAT연락처                 
                  if isnull(ls_vat_phone) then                 
                  else                                         
                     UPDATE customer SET vat_phone = :ls_vat_phone  WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if                                       

               case "vat_email"   // VAT메일                   
                  if isnull(ls_vat_email) then                 
                  else                                         
                     UPDATE customer SET vat_email = :ls_vat_email  WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if                                       

               case "icube_no"   // 더존                       
                  if isnull(ls_icube_no) then                  
                  else                                         
                     UPDATE customer SET icube_no = :ls_icube_no  WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if 
						
               case "custmain"   // 주거래건설사(CUSTINFO)
                  if isnull(ls_custmain) then                  
                  else                                         
                     UPDATE custinfo SET main_co = :ls_custmain  WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if 

               case "licensenm"   // 면허명(CUSTINFO)                          
                  if isnull(ls_licensenm) then                  
                  else                                         
                     UPDATE custinfo SET license_name = :ls_licensenm  WHERE CUST_NO = :ls_custno;
                     if SQLCA.SQLCode = 0 then                 
                        COMMIT;                                
                     else                                      
                        SWUpdate = SWUpdate + 1                
                     end if                                    
                  end if 
						
            end choose                                         
            //////////////////////////////////////////////////////////////
                                                               
            if SWUpdate <> 0 then                              
               ROLLBACK;                                       
               mle_1.text = mle_1.text + string(ll_row,"000") + "행 오류 : " + ls_custno + "~r~n"
            end if                                             
            //////////////////////////////////////////////////////////////
         end if                                                
      next                                                     
   end if                                                      
next                                                           

SetPointer(oldpointer)
dw_26.enabled = true
MessageBox("확인", "거래처 일괄변경 작업완료 하였습니다.")

end event

