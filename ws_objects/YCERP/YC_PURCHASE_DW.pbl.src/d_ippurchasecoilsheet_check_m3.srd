 column=(type=char(30) update=yes updatewhereclause=yes name=supply_lot_no dbname="order_coilsheet_check_det.supply_lot_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=coil_no dbname="order_coilsheet_check_det.coil_no" )
 column=(type=char(20) update=yes updatewhereclause=yes name=rem dbname="order_coilsheet_check_det.rem" )
 retrieve="  SELECT   order_coilsheet_check_det.order_no order_no
                 , order_coilsheet_check_det.round
                 , order_coilsheet_check_det.order_seq
                 , order_coilsheet_check_det.check_seq
                 , order_coilsheet_check_det.cnt
                 , order_coilsheet_check_det.in_date
			 , order_coilsheet_check_det.supply_lot_no
			 , order_coilsheet_check_det.coil_no
                 , order_coilsheet_check_det.rem
    FROM order_coilsheet_check_det
   WHERE ( order_coilsheet_check_det.order_no = :as_order_no ) 
     AND ( order_coilsheet_check_det.order_seq = :as_seq  ) 
     AND ( order_coilsheet_check_det.round = 2 )" update="order_coilsheet_check_det" updatewhere=0 updatekeyinplace=no arguments=(("as_order_no", string),("as_seq", string))  sort="order_seq A " )
